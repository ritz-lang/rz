# test/test_collection.ritz - Tests for Collection storage
#
# Tests for storing and retrieving documents in collections

import ritzlib.sys
import ritzlib.io
import ritzlib.str

import lib.m7m_types
import lib.buffer_pool
import lib.btree
import lib.document
import lib.collection

# ============================================================================
# Collection Creation Tests
# ============================================================================

[[test]]
fn test_collection_new() -> i32
    var pool: *BufferPool = buffer_pool_new(64)
    var col: Collection
    var result: i32 = collection_init(@col, pool, 1)
    if result != ERR_OK
        return 1
    if col.collection_id != 1
        return 2
    if col.next_sequence != 1
        return 3
    0

[[test]]
fn test_collection_new_null_pool() -> i32
    var col: Collection
    var result: i32 = collection_init(@col, null, 1)
    if result != ERR_INVALID
        return 1
    0

# ============================================================================
# Document Insert Tests
# ============================================================================

[[test]]
fn test_collection_insert_empty_doc() -> i32
    var pool: *BufferPool = buffer_pool_new(64)
    var col: Collection
    collection_init(@col, pool, 1)

    var doc: Document
    var id: DocumentId = doc_id_invalid()
    doc_init(@doc, @id)

    var new_id: DocumentId
    var result: i32 = collection_insert(@col, @doc, @new_id)
    if result != ERR_OK
        return 1
    if doc_id_is_valid(@new_id) != 1
        return 2
    if doc_id_collection(@new_id) != 1
        return 3
    if doc_id_sequence(@new_id) != 1
        return 4
    0

[[test]]
fn test_collection_insert_with_fields() -> i32
    var pool: *BufferPool = buffer_pool_new(64)
    var col: Collection
    collection_init(@col, pool, 1)

    var doc: Document
    var id: DocumentId = doc_id_invalid()
    doc_init(@doc, @id)

    var f1: Field = field_int(42)
    var f2: Field = field_bool(1)
    doc_set_field(@doc, c"age", @f1)
    doc_set_field(@doc, c"active", @f2)

    var new_id: DocumentId
    var result: i32 = collection_insert(@col, @doc, @new_id)
    if result != ERR_OK
        return 1
    0

[[test]]
fn test_collection_insert_multiple() -> i32
    var pool: *BufferPool = buffer_pool_new(64)
    var col: Collection
    collection_init(@col, pool, 1)

    var doc1: Document
    var doc2: Document
    var doc3: Document
    var id: DocumentId = doc_id_invalid()
    doc_init(@doc1, @id)
    doc_init(@doc2, @id)
    doc_init(@doc3, @id)

    var id1: DocumentId
    var id2: DocumentId
    var id3: DocumentId

    collection_insert(@col, @doc1, @id1)
    collection_insert(@col, @doc2, @id2)
    collection_insert(@col, @doc3, @id3)

    if doc_id_sequence(@id1) != 1
        return 1
    if doc_id_sequence(@id2) != 2
        return 2
    if doc_id_sequence(@id3) != 3
        return 3
    0

[[test]]
fn test_collection_insert_null_collection() -> i32
    var doc: Document
    var id: DocumentId = doc_id_invalid()
    doc_init(@doc, @id)

    var new_id: DocumentId
    var result: i32 = collection_insert(null, @doc, @new_id)
    if result != ERR_INVALID
        return 1
    0

[[test]]
fn test_collection_insert_null_doc() -> i32
    var pool: *BufferPool = buffer_pool_new(64)
    var col: Collection
    collection_init(@col, pool, 1)

    var new_id: DocumentId
    var result: i32 = collection_insert(@col, null, @new_id)
    if result != ERR_INVALID
        return 1
    0

# ============================================================================
# Document Get Tests
# ============================================================================

[[test]]
fn test_collection_get() -> i32
    var pool: *BufferPool = buffer_pool_new(64)
    var col: Collection
    collection_init(@col, pool, 1)

    # Insert a document with fields
    var doc: Document
    var id: DocumentId = doc_id_invalid()
    doc_init(@doc, @id)

    var f: Field = field_int(99)
    doc_set_field(@doc, c"value", @f)

    var new_id: DocumentId
    collection_insert(@col, @doc, @new_id)

    # Retrieve it
    var retrieved: Document
    var result: i32 = collection_get(@col, @new_id, @retrieved)
    if result != ERR_OK
        return 1

    # Check the field is there
    var rf: Field
    if doc_get_field(@retrieved, c"value", @rf) != ERR_OK
        return 2
    if field_as_int(@rf) != 99
        return 3
    0

[[test]]
fn test_collection_get_not_found() -> i32
    var pool: *BufferPool = buffer_pool_new(64)
    var col: Collection
    collection_init(@col, pool, 1)

    var id: DocumentId = doc_id_new(1, 999)
    var doc: Document
    var result: i32 = collection_get(@col, @id, @doc)
    if result != ERR_NOT_FOUND
        return 1
    0

[[test]]
fn test_collection_get_multiple() -> i32
    var pool: *BufferPool = buffer_pool_new(64)
    var col: Collection
    collection_init(@col, pool, 1)

    # Insert several documents
    var doc1: Document
    var doc2: Document
    var doc3: Document
    var tmp_id: DocumentId = doc_id_invalid()

    doc_init(@doc1, @tmp_id)
    var f1: Field = field_int(100)
    doc_set_field(@doc1, c"n", @f1)

    doc_init(@doc2, @tmp_id)
    var f2: Field = field_int(200)
    doc_set_field(@doc2, c"n", @f2)

    doc_init(@doc3, @tmp_id)
    var f3: Field = field_int(300)
    doc_set_field(@doc3, c"n", @f3)

    var id1: DocumentId
    var id2: DocumentId
    var id3: DocumentId
    collection_insert(@col, @doc1, @id1)
    collection_insert(@col, @doc2, @id2)
    collection_insert(@col, @doc3, @id3)

    # Retrieve each and verify
    var r1: Document
    var r2: Document
    var r3: Document
    collection_get(@col, @id1, @r1)
    collection_get(@col, @id2, @r2)
    collection_get(@col, @id3, @r3)

    var rf1: Field
    var rf2: Field
    var rf3: Field
    doc_get_field(@r1, c"n", @rf1)
    doc_get_field(@r2, c"n", @rf2)
    doc_get_field(@r3, c"n", @rf3)

    if field_as_int(@rf1) != 100
        return 1
    if field_as_int(@rf2) != 200
        return 2
    if field_as_int(@rf3) != 300
        return 3
    0

[[test]]
fn test_collection_get_null_collection() -> i32
    var id: DocumentId = doc_id_new(1, 1)
    var doc: Document
    var result: i32 = collection_get(null, @id, @doc)
    if result != ERR_INVALID
        return 1
    0

# ============================================================================
# Document Update Tests
# ============================================================================

[[test]]
fn test_collection_update() -> i32
    var pool: *BufferPool = buffer_pool_new(64)
    var col: Collection
    collection_init(@col, pool, 1)

    # Insert
    var doc: Document
    var id: DocumentId = doc_id_invalid()
    doc_init(@doc, @id)
    var f: Field = field_int(10)
    doc_set_field(@doc, c"x", @f)

    var new_id: DocumentId
    collection_insert(@col, @doc, @new_id)

    # Update
    var f2: Field = field_int(20)
    doc_set_field(@doc, c"x", @f2)
    # doc.id was already set by collection_insert via out_id

    var result: i32 = collection_update(@col, @doc)
    if result != ERR_OK
        return 1

    # Verify update
    var retrieved: Document
    collection_get(@col, @doc.id, @retrieved)
    var rf: Field
    doc_get_field(@retrieved, c"x", @rf)
    if field_as_int(@rf) != 20
        return 2
    0

[[test]]
fn test_collection_update_not_found() -> i32
    var pool: *BufferPool = buffer_pool_new(64)
    var col: Collection
    collection_init(@col, pool, 1)

    var doc: Document
    var id: DocumentId = doc_id_new(1, 999)
    doc_init(@doc, @id)

    var result: i32 = collection_update(@col, @doc)
    if result != ERR_NOT_FOUND
        return 1
    0

# ============================================================================
# Document Delete Tests
# ============================================================================

[[test]]
fn test_collection_delete() -> i32
    var pool: *BufferPool = buffer_pool_new(64)
    var col: Collection
    collection_init(@col, pool, 1)

    # Insert
    var doc: Document
    var id: DocumentId = doc_id_invalid()
    doc_init(@doc, @id)

    var new_id: DocumentId
    collection_insert(@col, @doc, @new_id)

    # Delete
    var result: i32 = collection_delete(@col, @new_id)
    if result != ERR_OK
        return 1

    # Verify gone
    var retrieved: Document
    result = collection_get(@col, @new_id, @retrieved)
    if result != ERR_NOT_FOUND
        return 2
    0

[[test]]
fn test_collection_delete_not_found() -> i32
    var pool: *BufferPool = buffer_pool_new(64)
    var col: Collection
    collection_init(@col, pool, 1)

    var id: DocumentId = doc_id_new(1, 999)
    var result: i32 = collection_delete(@col, @id)
    if result != ERR_NOT_FOUND
        return 1
    0

# ============================================================================
# Collection Count Tests
# ============================================================================

[[test]]
fn test_collection_count_empty() -> i32
    var pool: *BufferPool = buffer_pool_new(64)
    var col: Collection
    collection_init(@col, pool, 1)

    if collection_count(@col) != 0
        return 1
    0

[[test]]
fn test_collection_count_after_insert() -> i32
    var pool: *BufferPool = buffer_pool_new(64)
    var col: Collection
    collection_init(@col, pool, 1)

    var doc: Document
    var id: DocumentId = doc_id_invalid()
    doc_init(@doc, @id)

    var new_id: DocumentId
    collection_insert(@col, @doc, @new_id)
    if collection_count(@col) != 1
        return 1

    collection_insert(@col, @doc, @new_id)
    if collection_count(@col) != 2
        return 2
    0

[[test]]
fn test_collection_count_after_delete() -> i32
    var pool: *BufferPool = buffer_pool_new(64)
    var col: Collection
    collection_init(@col, pool, 1)

    var doc: Document
    var id: DocumentId = doc_id_invalid()
    doc_init(@doc, @id)

    var id1: DocumentId
    var id2: DocumentId
    collection_insert(@col, @doc, @id1)
    collection_insert(@col, @doc, @id2)

    if collection_count(@col) != 2
        return 1

    collection_delete(@col, @id1)
    if collection_count(@col) != 1
        return 2
    0
