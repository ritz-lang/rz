# test/test_types.ritz - Tests for core type definitions
#
# Tests for PageId, Result, Span, Timestamp, LSN, and TxnId types

import ritzlib.sys
import ritzlib.io
import ritzlib.str
import ritzlib.result

import lib.m7m_types

# ============================================================================
# PageId Tests
# ============================================================================

[[test]]
fn test_page_id_new() -> i32
    var id: PageId = page_id_new(1, 42)
    if page_id_file(@id) != 1
        return 1
    if page_id_num(@id) != 42
        return 1
    0

[[test]]
fn test_page_id_invalid() -> i32
    var id: PageId = page_id_invalid()
    if page_id_is_valid(@id) != 0
        return 1
    0

[[test]]
fn test_page_id_valid() -> i32
    var id: PageId = page_id_new(0, 0)
    if page_id_is_valid(@id) != 1
        return 1
    0

[[test]]
fn test_page_id_eq() -> i32
    var a: PageId = page_id_new(1, 100)
    var b: PageId = page_id_new(1, 100)
    var c: PageId = page_id_new(1, 101)
    var d: PageId = page_id_new(2, 100)

    # Same page
    if page_id_eq(@a, @b) != 1
        return 1
    # Different page num
    if page_id_eq(@a, @c) != 0
        return 2
    # Different file
    if page_id_eq(@a, @d) != 0
        return 3
    0

[[test]]
fn test_page_id_large_values() -> i32
    # Test with large file and page numbers
    var id: PageId = page_id_new(0x7FFFFFFF, 0x7FFFFFFF)
    if page_id_file(@id) != 0x7FFFFFFF
        return 1
    if page_id_num(@id) != 0x7FFFFFFF
        return 2
    0

# ============================================================================
# Result Tests
# ============================================================================

[[test]]
fn test_result_ok() -> i32
    var r: Result<i64, i32> = m7m_ok(42)
    match r
        Ok(v) =>
            if v != 42
                return 1
        Err(_) => return 2
    0

[[test]]
fn test_result_err() -> i32
    var r: Result<i64, i32> = m7m_err(ERR_NOT_FOUND)
    match r
        Ok(_) => return 1
        Err(e) =>
            if e != ERR_NOT_FOUND
                return 2
    0

# ============================================================================
# Span Tests
# ============================================================================

[[test]]
fn test_span_empty() -> i32
    var s: Span = span_empty()
    if s.ptr != null
        return 1
    if s.len != 0
        return 2
    0

[[test]]
fn test_span_new() -> i32
    var buf: [16]u8
    buf[0] = 65  # 'A'
    buf[1] = 66  # 'B'
    buf[2] = 67  # 'C'

    var s: Span = span_new(@buf[0], 3)
    if s.len != 3
        return 1
    if s.ptr != @buf[0]
        return 2
    0

[[test]]
fn test_span_eq_same() -> i32
    var buf1: [8]u8
    buf1[0] = 1
    buf1[1] = 2
    buf1[2] = 3

    var buf2: [8]u8
    buf2[0] = 1
    buf2[1] = 2
    buf2[2] = 3

    var s1: Span = span_new(@buf1[0], 3)
    var s2: Span = span_new(@buf2[0], 3)

    if span_eq(@s1, @s2) != 1
        return 1
    0

[[test]]
fn test_span_eq_different() -> i32
    var buf1: [8]u8
    buf1[0] = 1
    buf1[1] = 2
    buf1[2] = 3

    var buf2: [8]u8
    buf2[0] = 1
    buf2[1] = 2
    buf2[2] = 4  # Different

    var s1: Span = span_new(@buf1[0], 3)
    var s2: Span = span_new(@buf2[0], 3)

    if span_eq(@s1, @s2) != 0
        return 1
    0

[[test]]
fn test_span_eq_different_len() -> i32
    var buf: [8]u8
    buf[0] = 1
    buf[1] = 2
    buf[2] = 3

    var s1: Span = span_new(@buf[0], 3)
    var s2: Span = span_new(@buf[0], 2)

    if span_eq(@s1, @s2) != 0
        return 1
    0

[[test]]
fn test_span_eq_empty() -> i32
    var s1: Span = span_empty()
    var s2: Span = span_empty()

    if span_eq(@s1, @s2) != 1
        return 1
    0

[[test]]
fn test_span_copy_to() -> i32
    var src_buf: [8]u8
    src_buf[0] = 10
    src_buf[1] = 20
    src_buf[2] = 30

    var dst_buf: [8]u8
    memset(@dst_buf[0], 0, 8)

    var s: Span = span_new(@src_buf[0], 3)
    span_copy_to(@s, @dst_buf[0])

    if dst_buf[0] != 10
        return 1
    if dst_buf[1] != 20
        return 2
    if dst_buf[2] != 30
        return 3
    0

# ============================================================================
# Timestamp Tests
# ============================================================================

[[test]]
fn test_timestamp_zero() -> i32
    var ts: Timestamp = timestamp_zero()
    if ts.nanos != 0
        return 1
    0

[[test]]
fn test_timestamp_now() -> i32
    var ts: Timestamp = timestamp_now()
    # Should be some reasonable value (after year 2020)
    # 2020-01-01 in nanos: ~1577836800000000000
    if ts.nanos < 1577836800000000000
        return 1
    0

# ============================================================================
# LSN Tests
# ============================================================================

[[test]]
fn test_lsn_zero() -> i32
    var lsn: LSN = lsn_zero()
    if lsn.value != 0
        return 1
    0

[[test]]
fn test_lsn_new() -> i32
    var lsn: LSN = lsn_new(12345)
    if lsn.value != 12345
        return 1
    0

[[test]]
fn test_lsn_next() -> i32
    var lsn1: LSN = lsn_new(100)
    var lsn2: LSN = lsn_next(@lsn1)
    if lsn2.value != 101
        return 1
    0

[[test]]
fn test_lsn_cmp() -> i32
    var a: LSN = lsn_new(10)
    var b: LSN = lsn_new(20)
    var c: LSN = lsn_new(10)

    if lsn_cmp(@a, @b) != -1
        return 1
    if lsn_cmp(@b, @a) != 1
        return 2
    if lsn_cmp(@a, @c) != 0
        return 3
    0

# ============================================================================
# TxnId Tests
# ============================================================================

[[test]]
fn test_txn_id_new() -> i32
    var id: TxnId = txn_id_new(42)
    if id.value != 42
        return 1
    0

[[test]]
fn test_txn_id_invalid() -> i32
    var id: TxnId = txn_id_invalid()
    if txn_id_is_valid(@id) != 0
        return 1
    0

[[test]]
fn test_txn_id_valid() -> i32
    var id: TxnId = txn_id_new(0)
    if txn_id_is_valid(@id) != 1
        return 1

    var id2: TxnId = txn_id_new(100)
    if txn_id_is_valid(@id2) != 1
        return 2
    0
