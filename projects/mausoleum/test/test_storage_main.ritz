# test/test_storage_main.ritz - Standalone storage test
#
# Run with:
#   RITZ_PATH=./projects python3 projects/ritz/ritz0/ritz0.py projects/mausoleum/test/test_storage_main.ritz -o /tmp/test.ll
#   clang /tmp/test.ll -o /tmp/test -no-pie
#   /tmp/test

import ritzlib.sys
import ritzlib.io
import ritzlib.option

import lib.m7m_types
import lib.page
import lib.buffer_pool
import lib.storage

fn main() -> i32
    print("Testing storage_open_new...\n")

    # Cleanup
    let path: StrView = "/tmp/mausoleum_test_db"
    sys_unlink("/tmp/mausoleum_test_db/data.m7m")
    sys_unlink("/tmp/mausoleum_test_db/wal.wal.000000")
    sys_unlink("/tmp/mausoleum_test_db/meta.m7m")
    sys_rmdir(path.ptr)

    let storage_opt: Option<*Storage> = storage_open(path.ptr)
    if option_is_none<*Storage>(@storage_opt) == 1
        print("FAIL: storage_open returned None\n")
        return 1

    let storage: *Storage = option_unwrap_or<*Storage>(@storage_opt, null)
    if storage_is_open(storage) != 1
        print("FAIL: storage not open\n")
        storage_destroy(storage)
        return 2

    print("Testing transactions...\n")
    let txn: i64 = storage_begin_txn(storage)
    if txn < 0
        print("FAIL: begin_txn failed\n")
        storage_destroy(storage)
        return 3

    print("Allocating page...\n")
    let page_opt: Option<*Page> = storage_alloc_page(storage, PAGE_MAGIC_HEAP)
    if option_is_none<*Page>(@page_opt) == 1
        print("FAIL: alloc_page returned None\n")
        storage_destroy(storage)
        return 4

    let page: *Page = option_unwrap_or<*Page>(@page_opt, null)
    if page_type(page) != PAGE_MAGIC_HEAP
        print("FAIL: wrong page type\n")
        storage_destroy(storage)
        return 5

    print("Committing...\n")
    let result: i32 = storage_commit_txn(storage)
    if result != ERR_OK
        print("FAIL: commit failed\n")
        storage_destroy(storage)
        return 6

    print("Closing and reopening...\n")
    storage_destroy(storage)

    # Reopen to test persistence
    let storage2_opt: Option<*Storage> = storage_open(path.ptr)
    if option_is_none<*Storage>(@storage2_opt) == 1
        print("FAIL: storage reopen returned None\n")
        return 7

    let storage2: *Storage = option_unwrap_or<*Storage>(@storage2_opt, null)

    print("Checking page count...\n")
    if storage_page_count(storage2) < 1
        print("FAIL: page count should be >= 1\n")
        storage_destroy(storage2)
        return 8

    storage_destroy(storage2)

    # Cleanup
    sys_unlink("/tmp/mausoleum_test_db/data.m7m")
    sys_unlink("/tmp/mausoleum_test_db/wal.wal.000000")
    sys_unlink("/tmp/mausoleum_test_db/meta.m7m")
    sys_rmdir(path.ptr)

    print("PASS: All storage tests passed!\n")
    0
