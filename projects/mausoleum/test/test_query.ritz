[[test]]
fn test_query_multiple_filters() -> i32
    var q: Query = query_new()
    query_gte_int(@q, "age", 18)
    query_lte_int(@q, "age", 65)
    query_not_null(@q, "email")
    assert q.filter_count == 3
    0

[[test]]
fn test_query_filter_limit() -> i32
    var q: Query = query_new()
    var i: i32 = 0
    while i < MAX_FILTERS
        query_eq_int(@q, "field", i as i64)
        i = i + 1

    # One more should fail
    var result: i32 = query_eq_int(@q, "field", 999)
    assert result == ERR_FULL
    0

