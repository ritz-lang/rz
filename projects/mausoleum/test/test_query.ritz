[[test]]
fn test_query_exec_multiple_filters() -> i32
    var pool: *BufferPool = make_test_pool()
    var col: Collection
    collection_init(@col, pool, 1)

    insert_test_doc(@col, "Alice", 30, 1)
    insert_test_doc(@col, "Bob", 25, 1)
    insert_test_doc(@col, "Carol", 35, 0)
    insert_test_doc(@col, "Dave", 28, 1)

    # Query age >= 25 AND age <= 30 AND active == true
    var q: Query = query_new()
    query_gte_int(@q, "age", 25)
    query_lte_int(@q, "age", 30)
    var active: Field = field_bool(1)
    query_eq(@q, "active", @active)
    var result: *QueryResult = query_exec(@q, @col)

    assert result != null
    assert result.count == 3  # Alice (30), Bob (25), Dave (28)

    query_result_destroy(result)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_query_exec_not_null() -> i32
    var pool: *BufferPool = make_test_pool()
    var col: Collection
    collection_init(@col, pool, 1)

    # Insert doc with email
    var doc1: Document
    var id1: DocumentId = doc_id_invalid()
    doc_init(@doc1, @id1)
    var email: Field = field_string("test@example.com", 16)
    doc_set_field(@doc1, "email", @email)
    var out1: DocumentId
    collection_insert(@col, @doc1, @out1)

    # Insert doc without email
    var doc2: Document
    var id2: DocumentId = doc_id_invalid()
    doc_init(@doc2, @id2)
    var out2: DocumentId
    collection_insert(@col, @doc2, @out2)

    # Query email is not null
    var q: Query = query_new()
    query_not_null(@q, "email")
    var result: *QueryResult = query_exec(@q, @col)

    assert result != null
    assert result.count == 1

    query_result_destroy(result)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_query_exec_is_null() -> i32
    var pool: *BufferPool = make_test_pool()
    var col: Collection
    collection_init(@col, pool, 1)

    # Insert doc with email
    var doc1: Document
    var id1: DocumentId = doc_id_invalid()
    doc_init(@doc1, @id1)
    var email: Field = field_string("test@example.com", 16)
    doc_set_field(@doc1, "email", @email)
    var out1: DocumentId
    collection_insert(@col, @doc1, @out1)

    # Insert doc without email
    var doc2: Document
    var id2: DocumentId = doc_id_invalid()
    doc_init(@doc2, @id2)
    var out2: DocumentId
    collection_insert(@col, @doc2, @out2)

    # Query email is null
    var q: Query = query_new()
    query_is_null(@q, "email")
    var result: *QueryResult = query_exec(@q, @col)

    assert result != null
    assert result.count == 1

    query_result_destroy(result)
    buffer_pool_destroy(pool)
    0

