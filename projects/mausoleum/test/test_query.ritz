# ============================================================================
# Ordering Execution Tests
# ============================================================================

[[test]]
fn test_query_exec_order_asc() -> i32
    var pool: *BufferPool = make_test_pool()
    var col: Collection
    collection_init(@col, pool, 1)

    insert_test_doc(@col, "Carol", 35, 0)
    insert_test_doc(@col, "Alice", 30, 1)
    insert_test_doc(@col, "Bob", 25, 1)

    # Query ordered by age ascending
    var q: Query = query_new()
    query_order_asc(@q, "age")
    var result: *QueryResult = query_exec(@q, @col)

    assert result != null
    assert result.count == 3

    # Verify order: Bob (25), Alice (30), Carol (35)
    var doc: Document
    var id0: DocumentId = query_result_get(result, 0)
    collection_get(@col, @id0, @doc)
    var age0: Field
    doc_get_field(@doc, "age", @age0)
    assert field_as_int(@age0) == 25

    var id1: DocumentId = query_result_get(result, 1)
    collection_get(@col, @id1, @doc)
    var age1: Field
    doc_get_field(@doc, "age", @age1)
    assert field_as_int(@age1) == 30

    var id2: DocumentId = query_result_get(result, 2)
    collection_get(@col, @id2, @doc)
    var age2: Field
    doc_get_field(@doc, "age", @age2)
    assert field_as_int(@age2) == 35

    query_result_destroy(result)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_query_exec_order_desc() -> i32
    var pool: *BufferPool = make_test_pool()
    var col: Collection
    collection_init(@col, pool, 1)

    insert_test_doc(@col, "Alice", 30, 1)
    insert_test_doc(@col, "Bob", 25, 1)
    insert_test_doc(@col, "Carol", 35, 0)

    # Query ordered by age descending
    var q: Query = query_new()
    query_order_desc(@q, "age")
    var result: *QueryResult = query_exec(@q, @col)

    assert result != null
    assert result.count == 3

    # Verify order: Carol (35), Alice (30), Bob (25)
    var doc: Document
    var id0: DocumentId = query_result_get(result, 0)
    collection_get(@col, @id0, @doc)
    var age0: Field
    doc_get_field(@doc, "age", @age0)
    assert field_as_int(@age0) == 35

    query_result_destroy(result)
    buffer_pool_destroy(pool)
    0

