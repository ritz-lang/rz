[[test]]
fn test_query_count_with_pagination() -> i32
    var pool: *BufferPool = make_test_pool()
    var col: Collection
    collection_init(@col, pool, 1)

    # Insert 5 documents
    var i: i32 = 0
    while i < 5
        insert_test_doc(@col, "User", i as i64, 1)
        i = i + 1

    # Query with limit - count should return total matching, not limited
    var q: Query = query_new()
    query_limit(@q, 2)

    var count: i64 = query_count(@q, @col)
    assert count == 5  # Total count, ignoring limit

    buffer_pool_destroy(pool)
    0

