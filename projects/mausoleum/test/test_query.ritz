# test/test_query.ritz - Tests for query builder

import ritzlib.sys
import ritzlib.str
import ritzlib.strview
import ritzlib.memory
import ritzlib.option

import lib.m7m_types
import lib.buffer_pool
import lib.document
import lib.collection
import lib.query

# ============================================================================
# Test Helpers
# ============================================================================

fn make_test_pool() -> *BufferPool
    let pool_opt = buffer_pool_new(64)
    if option_is_none<*BufferPool>(@pool_opt) == 1
        return null
    return option_unwrap_or<*BufferPool>(@pool_opt, null)

fn insert_test_doc(col: *Collection, name: *u8, age: i64, active: i32) -> DocumentId
    var doc: Document
    var id: DocumentId = doc_id_invalid()
    doc_init(@doc, @id)

    var name_field: Field = field_string(name, strlen(name))
    doc_set_field(@doc, "name", @name_field)

    var age_field: Field = field_int(age)
    doc_set_field(@doc, "age", @age_field)

    var active_field: Field = field_bool(active)
    doc_set_field(@doc, "active", @active_field)

    var out_id: DocumentId
    collection_insert(col, @doc, @out_id)
    return out_id

# ============================================================================
# Query Creation Tests
# ============================================================================

[[test]]
fn test_query_new() -> i32
    var q: Query = query_new()
    assert q.filter_count == 0
    assert q.order_count == 0
    assert q.limit_val == MAX_RESULTS
    assert q.offset_val == 0
    0

[[test]]
fn test_query_init() -> i32
    var q: Query
    query_init(@q)
    assert q.filter_count == 0
    assert q.order_count == 0
    0

# ============================================================================
# Filter Builder Tests
# ============================================================================

[[test]]
fn test_query_eq() -> i32
    var q: Query = query_new()
    var val: Field = field_int(42)
    var result: i32 = query_eq(@q, "age", @val)
    assert result == ERR_OK
    assert q.filter_count == 1
    assert q.filters[0].op == FILTER_EQ
    0

[[test]]
fn test_query_eq_int() -> i32
    var q: Query = query_new()
    var result: i32 = query_eq_int(@q, "age", 42)
    assert result == ERR_OK
