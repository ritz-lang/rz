# test/test_encrypted_channel.ritz - Tests for encrypted channel module
#
# Tests the encrypted channel implementation constants and API.
# Note: Full integration tests would require socketpair or loopback sockets.

import ritzlib.sys

import ritzunit.src.types

import lib.encrypted_channel

# ============================================================================
# Channel Constant Tests
# ============================================================================

[[test]]
fn test_channel_key_size() -> i32
    assert CHANNEL_KEY_SIZE == 32
    0

[[test]]
fn test_channel_nonce_size() -> i32
    assert CHANNEL_NONCE_SIZE == 12
    0

[[test]]
fn test_channel_tag_size() -> i32
    assert CHANNEL_TAG_SIZE == 16
    0

[[test]]
fn test_channel_max_msg_size() -> i32
    assert CHANNEL_MAX_MSG_SIZE == 65536
    0

[[test]]
fn test_channel_state_init() -> i32
    assert CHANNEL_STATE_INIT == 0
    0

[[test]]
fn test_channel_state_handshake() -> i32
    assert CHANNEL_STATE_HANDSHAKE == 1
    0

[[test]]
fn test_channel_state_connected() -> i32
    assert CHANNEL_STATE_CONNECTED == 2
    0

[[test]]
fn test_channel_state_error() -> i32
    assert CHANNEL_STATE_ERROR == -1
    0

[[test]]
fn test_channel_error_ok() -> i32
    assert CHANNEL_OK == 0
    0

[[test]]
fn test_channel_error_handshake() -> i32
    assert CHANNEL_ERR_HANDSHAKE == -1
    0

[[test]]
fn test_channel_error_decrypt() -> i32
    assert CHANNEL_ERR_DECRYPT == -2
    0

[[test]]
fn test_channel_error_buffer() -> i32
    assert CHANNEL_ERR_BUFFER == -3
    0

[[test]]
fn test_channel_error_io() -> i32
    assert CHANNEL_ERR_IO == -4
    0

# ============================================================================
# Protocol Format Tests
# ============================================================================

# Message format: [length: 4 BE][nonce: 12][ciphertext][tag: 16]
[[test]]
fn test_message_overhead() -> i32
    # Length prefix is 4 bytes
    let length_size: i32 = 4

    # Nonce is 12 bytes
    let nonce_size: i32 = CHANNEL_NONCE_SIZE

    # Tag is 16 bytes
    let tag_size: i32 = CHANNEL_TAG_SIZE

    # Total overhead per message
    let overhead: i32 = length_size + nonce_size + tag_size
    assert overhead == 32

    0

# Test that the max message size accounts for crypto overhead
[[test]]
fn test_max_payload_size() -> i32
    # Maximum payload = max message - overhead
    let overhead: i32 = 4 + CHANNEL_NONCE_SIZE + CHANNEL_TAG_SIZE
    let max_payload: i32 = CHANNEL_MAX_MSG_SIZE - overhead

    # Should allow at least 64KB - 32 bytes of payload
    assert max_payload > 65000
    0
