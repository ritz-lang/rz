    0

# ============================================================================
# WAL Reader Tests
# ============================================================================

[[test]]
fn test_wal_reader_new() -> i32
    var reader: *WalReader = wal_reader_new()
    if reader == null
        return 1

    wal_reader_destroy(reader)
    0

[[test]]
fn test_wal_write_then_read() -> i32
    # Write some records
    var path: *u8 = get_test_path(8)
    var writer: *WalWriter = wal_writer_new(path)
    wal_writer_open(writer)

    wal_write_begin(writer, 600)
    wal_write_commit(writer, 600, 1)
    wal_write_checkpoint(writer)

    wal_writer_close(writer)
    wal_writer_destroy(writer)

    # Build WAL file path
    var wal_path: [64]u8
    memcpy(@wal_path[0], path, 20)
    memcpy(@wal_path[19], c".wal.000000", 12)

    # Read them back
    var reader: *WalReader = wal_reader_new()
    var err: i32 = wal_reader_open(reader, @wal_path[0])
    if err != ERR_OK
        wal_reader_destroy(reader)
        sys_unlink(@wal_path[0])
        free(path)
        return 1

    var header: WalRecordHeader

    # Read first record (BEGIN)
    err = wal_reader_next(reader, @header)
    if err != ERR_OK
        wal_reader_destroy(reader)
        sys_unlink(@wal_path[0])
        free(path)
        return 2

    if header.rec_type != WAL_REC_BEGIN
        wal_reader_destroy(reader)
        sys_unlink(@wal_path[0])
        free(path)
        return 3

    if header.txn_id != 600
        wal_reader_destroy(reader)
        sys_unlink(@wal_path[0])
        free(path)
        return 4

    # Read second record (COMMIT)
    err = wal_reader_next(reader, @header)
    if err != ERR_OK
        wal_reader_destroy(reader)
        sys_unlink(@wal_path[0])
        free(path)
        return 5

    if header.rec_type != WAL_REC_COMMIT
        wal_reader_destroy(reader)
        sys_unlink(@wal_path[0])
        free(path)
        return 6

    # Read third record (CHECKPOINT)
    err = wal_reader_next(reader, @header)
    if err != ERR_OK
        wal_reader_destroy(reader)
        sys_unlink(@wal_path[0])
        free(path)
        return 7

    if header.rec_type != WAL_REC_CHECKPOINT
        wal_reader_destroy(reader)
        sys_unlink(@wal_path[0])
        free(path)
        return 8

    # Should be EOF now
    err = wal_reader_next(reader, @header)
    if err != -1  # -1 is EOF
        wal_reader_destroy(reader)
        sys_unlink(@wal_path[0])
        free(path)
        return 9

    wal_reader_destroy(reader)
    sys_unlink(@wal_path[0])
    free(path)
    0

# ============================================================================
# WAL Statistics Tests
# ============================================================================

[[test]]
fn test_wal_writer_lsn() -> i32
    var path: *u8 = get_test_path(9)
    var writer: *WalWriter = wal_writer_new(path)
    wal_writer_open(writer)

    # Initial LSN should be 1
    if wal_writer_lsn(writer) != 1
        wal_writer_destroy(writer)
        free(path)
        return 1

    wal_write_begin(writer, 700)

    # After one write, LSN should be 2
    if wal_writer_lsn(writer) != 2
        wal_writer_destroy(writer)
        free(path)
        return 2

    wal_writer_destroy(writer)

    # Cleanup
    var wal_path: [64]u8
    memcpy(@wal_path[0], path, 20)
    memcpy(@wal_path[19], c".wal.000000", 12)
    sys_unlink(@wal_path[0])
    free(path)
    0

# ============================================================================
# Transaction Sequence Tests
# ============================================================================

[[test]]
fn test_wal_full_transaction() -> i32
    var path: *u8 = get_test_path(10)
    var writer: *WalWriter = wal_writer_new(path)
    wal_writer_open(writer)

    # Simulate a complete transaction
    var txn_id: i64 = 1000

    # Begin
    var begin_lsn: i64 = wal_write_begin(writer, txn_id)
    if begin_lsn < 0
        wal_writer_destroy(writer)
        free(path)
        return 1

    # Multiple inserts
    var data: [32]u8
    for i in 0..5
        var lsn: i64 = wal_write_insert(writer, txn_id, begin_lsn, i as i64, i, @data[0], 8)
        if lsn < 0
            wal_writer_destroy(writer)
            free(path)
            return 2

    # Commit
    var commit_lsn: i64 = wal_write_commit(writer, txn_id, begin_lsn)
    if commit_lsn < 0
        wal_writer_destroy(writer)
        free(path)
        return 3

    # Check final LSN (1 begin + 5 inserts + 1 commit = 7)
    if wal_writer_lsn(writer) != 8
        wal_writer_destroy(writer)
        free(path)
        return 4

    wal_writer_destroy(writer)

    # Cleanup
    var wal_path: [64]u8
    memcpy(@wal_path[0], path, 20)
    memcpy(@wal_path[19], c".wal.000000", 12)
    sys_unlink(@wal_path[0])
    free(path)
    0
