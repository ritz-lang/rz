# test/test_server.ritz - Tests for server module

import ritzlib.memory
import ritzlib.str

import lib.m7m_types
import lib.protocol
import lib.buffer_pool
import lib.collection
import lib.server

# ============================================================================
# Server creation tests
# ============================================================================

[[test]]
fn test_server_new() -> i32
    var pool: *BufferPool = buffer_pool_new(16)
    var col: Collection
    collection_init(@col, pool, 1)

    var server: *Server = server_new(pool, @col)
    assert server != null
    assert server_connection_count(server) == 0
    assert server_is_running(server) == 0

    server_free(server)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_server_new_null_pool() -> i32
    var server: *Server = server_new(null, null)
    # Should still create server (allows lazy pool init)
    if server != null
        server_free(server)
    0

[[test]]
fn test_server_free_null() -> i32
    # Should not crash on null
    server_free(null)
    0

[[test]]
fn test_server_stop() -> i32
    var pool: *BufferPool = buffer_pool_new(16)
    var col: Collection
    collection_init(@col, pool, 1)
    var server: *Server = server_new(pool, @col)

    assert server_is_running(server) == 0
    server_stop(server)
    assert server_is_running(server) == 0

    server_free(server)
    buffer_pool_destroy(pool)
    0

# ============================================================================
# Connection structure tests
# ============================================================================

[[test]]
fn test_conn_init() -> i32
    var conn: Connection
    let result: i32 = conn_init(@conn, 10)
    assert result == 0
    assert conn.fd == 10
    assert conn.state == CONN_STATE_READING
    assert conn.recv_buf != null
    assert conn.send_buf != null
    assert conn.recv_len == 0
    assert conn.send_len == 0
    assert conn.session_id == 0
    assert conn.txn_id == 0

    conn_cleanup(@conn)
    assert conn.recv_buf == null
    assert conn.send_buf == null
    0

[[test]]
fn test_conn_cleanup_twice() -> i32
    var conn: Connection
    conn_init(@conn, 5)
    conn_cleanup(@conn)
    # Second cleanup should not crash
    conn_cleanup(@conn)
    0

# ============================================================================
# Server constants tests
# ============================================================================

[[test]]
fn test_server_constants() -> i32
    assert MAX_CONNECTIONS == 64
    assert RECV_BUFFER_SIZE == 65536
    assert SEND_BUFFER_SIZE == 65536
    assert BACKLOG == 128
    0

[[test]]
fn test_connection_states() -> i32
    assert CONN_STATE_READING == 0
    assert CONN_STATE_PROCESSING == 1
    assert CONN_STATE_WRITING == 2
    assert CONN_STATE_CLOSED == 3
    0
