# ============================================================================
# Error codes tests
# ============================================================================

[[test]]
fn test_error_codes() -> i32
    assert PROTO_OK == 0
    assert PROTO_ERR_PROTOCOL == 1
    assert PROTO_ERR_MESSAGE_TOO_LARGE == 2
    assert PROTO_ERR_INVALID_MSG_TYPE == 3
    assert PROTO_ERR_NOT_FOUND == 4
    assert PROTO_ERR_ALREADY_EXISTS == 5
    assert PROTO_ERR_INVALID_DOCUMENT == 6
    assert PROTO_ERR_TXN_CONFLICT == 7
    assert PROTO_ERR_TXN_NOT_ACTIVE == 8
    assert PROTO_ERR_INTERNAL == 9
    assert PROTO_ERR_DISCONNECTED == 10
    0

