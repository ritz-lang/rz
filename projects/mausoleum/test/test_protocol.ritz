# Flag tests
# ============================================================================

[[test]]
fn test_flags() -> i32
    assert FLAG_NONE == 0
    assert FLAG_COMPRESSED == 1
    assert FLAG_MORE_DATA == 2
    assert FLAG_IN_TXN == 4
    0

[[test]]
fn test_msgreader_flags() -> i32
    var buf: *MessageBuffer = msgbuf_new(1024)
    msgbuf_start(buf, MSG_INSERT, 1)
    buf.header.flags = FLAG_IN_TXN
    msgbuf_finish(buf)

    var reader: MessageReader
    msgreader_init(@reader, buf.data, buf.length)
    assert msgreader_flags(@reader) == FLAG_IN_TXN

    msgbuf_free(buf)
    0

# ============================================================================
# Edge cases
# ============================================================================

[[test]]
fn test_empty_bytes() -> i32
    var buf: *MessageBuffer = msgbuf_new(1024)
    msgbuf_start(buf, MSG_PING, 1)
    msgbuf_write_bytes(buf, null, 0)
    msgbuf_finish(buf)

    var reader: MessageReader
    msgreader_init(@reader, buf.data, buf.length)

    var len: i32 = 0
    var data: *u8 = msgreader_read_bytes(@reader, @len)
    assert len == 0
    assert data == null

    msgbuf_free(buf)
    0

[[test]]
fn test_multiple_writes() -> i32
    var buf: *MessageBuffer = msgbuf_new(1024)
    msgbuf_start(buf, MSG_PING, 1)
    msgbuf_write_i32(buf, 111)
    msgbuf_write_i64(buf, 222)
    msgbuf_write_i32(buf, 333)
    msgbuf_finish(buf)

    var reader: MessageReader
    msgreader_init(@reader, buf.data, buf.length)

    let v1: i32 = msgreader_read_i32(@reader)
    let v2: i64 = msgreader_read_i64(@reader)
    let v3: i32 = msgreader_read_i32(@reader)

    assert v1 == 111
    assert v2 == 222
    assert v3 == 333

    msgbuf_free(buf)
    0

[[test]]
fn test_null_buffer() -> i32
    # msgbuf_new with zero should still work
    var buf: *MessageBuffer = msgbuf_new(0)
    # Don't crash on free
    if buf != null
        msgbuf_free(buf)
    0

[[test]]
fn test_buffer_reuse() -> i32
    var buf: *MessageBuffer = msgbuf_new(1024)

    # First message
    build_ping(buf, 1)
    var reader: MessageReader
    msgreader_init(@reader, buf.data, buf.length)
    assert msgreader_msg_type(@reader) == MSG_PING
    assert msgreader_request_id(@reader) == 1

    # Reuse for second message
    build_get(buf, 2, 999)
    msgreader_init(@reader, buf.data, buf.length)
    assert msgreader_msg_type(@reader) == MSG_GET
    assert msgreader_request_id(@reader) == 2

    msgbuf_free(buf)
    0
