[[test]]
fn test_get_backlinks_found() -> i32
    var pool_opt = buffer_pool_new(64)
    if option_is_none<*BufferPool>(@pool_opt) == 1
        return 10
    var pool: *BufferPool = option_unwrap_or<*BufferPool>(@pool_opt, null)
    var col: Collection
    collection_init(@col, pool, 1)

    # Insert target document
    var target: Document
    var id: DocumentId = doc_id_invalid()
    doc_init(@target, @id)
    var target_id: DocumentId
    collection_insert(@col, @target, @target_id)

    # Insert two sources that link to target
    var s1: Document
    var s2: Document
    doc_init(@s1, @id)
    doc_init(@s2, @id)
    doc_add_link(@s1, "related", @target_id)
    doc_add_link(@s2, "related", @target_id)
    var s1_id: DocumentId
    var s2_id: DocumentId
    collection_insert(@col, @s1, @s1_id)
    collection_insert(@col, @s2, @s2_id)

    # Get backlinks to target
    var backlinks: [16]DocumentId
    var count: i32 = 0
    get_backlinks(@col, @target_id, "related", @backlinks[0], 16, @count)
    if count != 2
        return 1
    0
