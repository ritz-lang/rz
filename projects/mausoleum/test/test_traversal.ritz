# test/test_traversal.ritz - Tests for document tree and graph traversal
#
# Tests for ancestor/descendant traversal and link-based graph traversal

import ritzlib.sys
import ritzlib.io
import ritzlib.str
import ritzlib.option

import lib.m7m_types
import lib.buffer_pool
import lib.btree
import lib.document
import lib.collection
import lib.traversal

# ============================================================================
# Tree Traversal Tests (Parent/Child)
# ============================================================================

[[test]]
fn test_get_children_none() -> i32
    var pool_opt = buffer_pool_new(64)
    if option_is_none<*BufferPool>(@pool_opt) == 1
        return 10
    var pool: *BufferPool = option_unwrap_or<*BufferPool>(@pool_opt, null)
    var col: Collection
    collection_init(@col, pool, 1)

    # Insert a document with no children
    var doc: Document
    var id: DocumentId = doc_id_invalid()
    doc_init(@doc, @id)
    var new_id: DocumentId
    collection_insert(@col, @doc, @new_id)

    # Get children - should be empty
    var children: [16]DocumentId
    var count: i32 = 0
    var result: i32 = get_children(@col, @new_id, @children[0], 16, @count)
    if result != ERR_OK
        return 1
    if count != 0
        return 2
    0

[[test]]
fn test_get_children_single() -> i32
    var pool_opt = buffer_pool_new(64)
    if option_is_none<*BufferPool>(@pool_opt) == 1
        return 10
    var pool: *BufferPool = option_unwrap_or<*BufferPool>(@pool_opt, null)
    var col: Collection
    collection_init(@col, pool, 1)

    # Insert parent
    var parent: Document
    var id: DocumentId = doc_id_invalid()
    doc_init(@parent, @id)
    var parent_id: DocumentId
    collection_insert(@col, @parent, @parent_id)

    # Insert child with parent reference
    var child: Document
    doc_init(@child, @id)
    doc_set_parent(@child, @parent_id)
    var child_id: DocumentId
    collection_insert(@col, @child, @child_id)

    # Get children of parent
    var children: [16]DocumentId
    var count: i32 = 0
    var result: i32 = get_children(@col, @parent_id, @children[0], 16, @count)
    if result != ERR_OK
        return 1
    if count != 1
        return 2
    if doc_id_eq(@children[0], @child_id) != 1
        return 3
    0

[[test]]
fn test_get_children_multiple() -> i32
    var pool_opt = buffer_pool_new(64)
    if option_is_none<*BufferPool>(@pool_opt) == 1
        return 10
    var pool: *BufferPool = option_unwrap_or<*BufferPool>(@pool_opt, null)
    var col: Collection
    collection_init(@col, pool, 1)

    # Insert parent
    var parent: Document
    var id: DocumentId = doc_id_invalid()
    doc_init(@parent, @id)
    var parent_id: DocumentId
    collection_insert(@col, @parent, @parent_id)

    # Insert 3 children
    var c1: Document
    var c2: Document
    var c3: Document
    doc_init(@c1, @id)
    doc_init(@c2, @id)
    doc_init(@c3, @id)
    doc_set_parent(@c1, @parent_id)
    doc_set_parent(@c2, @parent_id)
    doc_set_parent(@c3, @parent_id)

    var c1_id: DocumentId
    var c2_id: DocumentId
    var c3_id: DocumentId
    collection_insert(@col, @c1, @c1_id)
    collection_insert(@col, @c2, @c2_id)
    collection_insert(@col, @c3, @c3_id)

    # Get children
    var children: [16]DocumentId
    var count: i32 = 0
    get_children(@col, @parent_id, @children[0], 16, @count)
    if count != 3
        return 1
    0

[[test]]
fn test_get_ancestors_none() -> i32
    var pool_opt = buffer_pool_new(64)
    if option_is_none<*BufferPool>(@pool_opt) == 1
        return 10
    var pool: *BufferPool = option_unwrap_or<*BufferPool>(@pool_opt, null)
    var col: Collection
    collection_init(@col, pool, 1)

    # Insert root document (no parent)
    var doc: Document
    var id: DocumentId = doc_id_invalid()
    doc_init(@doc, @id)
    var new_id: DocumentId
    collection_insert(@col, @doc, @new_id)

    # Get ancestors - should be empty
    var ancestors: [16]DocumentId
    var count: i32 = 0
    var result: i32 = get_ancestors(@col, @new_id, @ancestors[0], 16, @count)
    if result != ERR_OK
        return 1
    if count != 0
        return 2
    0

[[test]]
fn test_get_ancestors_chain() -> i32
    var pool_opt = buffer_pool_new(64)
    if option_is_none<*BufferPool>(@pool_opt) == 1
        return 10
    var pool: *BufferPool = option_unwrap_or<*BufferPool>(@pool_opt, null)
    var col: Collection
    collection_init(@col, pool, 1)

    # Build chain: grandparent -> parent -> child
    var gp: Document
    var p: Document
    var c: Document
    var id: DocumentId = doc_id_invalid()

    doc_init(@gp, @id)
    var gp_id: DocumentId
    collection_insert(@col, @gp, @gp_id)

    doc_init(@p, @id)
    doc_set_parent(@p, @gp_id)
    var p_id: DocumentId
    collection_insert(@col, @p, @p_id)

    doc_init(@c, @id)
    doc_set_parent(@c, @p_id)
    var c_id: DocumentId
    collection_insert(@col, @c, @c_id)

    # Get ancestors of child - should be [parent, grandparent]
    var ancestors: [16]DocumentId
    var count: i32 = 0
    get_ancestors(@col, @c_id, @ancestors[0], 16, @count)
    if count != 2
        return 1
    # Ancestors in order: immediate parent first
    if doc_id_eq(@ancestors[0], @p_id) != 1
        return 2
    if doc_id_eq(@ancestors[1], @gp_id) != 1
        return 3
    0

[[test]]
fn test_get_descendants_all() -> i32
    var pool_opt = buffer_pool_new(64)
    if option_is_none<*BufferPool>(@pool_opt) == 1
        return 10
    var pool: *BufferPool = option_unwrap_or<*BufferPool>(@pool_opt, null)
    var col: Collection
    collection_init(@col, pool, 1)

    # Build tree: root -> [child1, child2] -> [grandchild]
    var root: Document
    var id: DocumentId = doc_id_invalid()
    doc_init(@root, @id)
    var root_id: DocumentId
    collection_insert(@col, @root, @root_id)

    var c1: Document
    var c2: Document
    doc_init(@c1, @id)
    doc_init(@c2, @id)
    doc_set_parent(@c1, @root_id)
    doc_set_parent(@c2, @root_id)
    var c1_id: DocumentId
    var c2_id: DocumentId
    collection_insert(@col, @c1, @c1_id)
    collection_insert(@col, @c2, @c2_id)

    var gc: Document
    doc_init(@gc, @id)
    doc_set_parent(@gc, @c1_id)
    var gc_id: DocumentId
    collection_insert(@col, @gc, @gc_id)

    # Get all descendants of root
    var descendants: [16]DocumentId
    var count: i32 = 0
    get_descendants(@col, @root_id, @descendants[0], 16, @count)
    # Should have child1, child2, grandchild = 3
    if count != 3
        return 1
    0

