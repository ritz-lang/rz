# Graph Traversal Tests (Links)
# ============================================================================

[[test]]
fn test_get_linked_none() -> i32
    var pool_opt = buffer_pool_new(64)
    if option_is_none<*BufferPool>(@pool_opt) == 1
        return 10
    var pool: *BufferPool = option_unwrap_or<*BufferPool>(@pool_opt, null)
    var col: Collection
    collection_init(@col, pool, 1)

    # Insert document with no links
    var doc: Document
    var id: DocumentId = doc_id_invalid()
    doc_init(@doc, @id)
    var new_id: DocumentId
    collection_insert(@col, @doc, @new_id)

    # Get links by label
    var linked: [16]DocumentId
    var count: i32 = 0
    var result: i32 = get_linked(@col, @new_id, "related", @linked[0], 16, @count)
    if result != ERR_OK
        return 1
    if count != 0
        return 2
    0

[[test]]
fn test_get_linked_single() -> i32
    var pool_opt = buffer_pool_new(64)
    if option_is_none<*BufferPool>(@pool_opt) == 1
        return 10
    var pool: *BufferPool = option_unwrap_or<*BufferPool>(@pool_opt, null)
    var col: Collection
    collection_init(@col, pool, 1)

    # Insert target document
    var target: Document
    var id: DocumentId = doc_id_invalid()
    doc_init(@target, @id)
    var target_id: DocumentId
    collection_insert(@col, @target, @target_id)

    # Insert source with link to target
    var source: Document
    doc_init(@source, @id)
    doc_add_link(@source, "related", @target_id)
    var source_id: DocumentId
    collection_insert(@col, @source, @source_id)

    # Get linked documents
    var linked: [16]DocumentId
    var count: i32 = 0
    get_linked(@col, @source_id, "related", @linked[0], 16, @count)
    if count != 1
        return 1
    if doc_id_eq(@linked[0], @target_id) != 1
        return 2
    0

[[test]]
fn test_get_linked_multiple_labels() -> i32
    var pool_opt = buffer_pool_new(64)
    if option_is_none<*BufferPool>(@pool_opt) == 1
        return 10
    var pool: *BufferPool = option_unwrap_or<*BufferPool>(@pool_opt, null)
    var col: Collection
    collection_init(@col, pool, 1)

    # Insert targets
    var t1: Document
    var t2: Document
    var t3: Document
    var id: DocumentId = doc_id_invalid()
    doc_init(@t1, @id)
    doc_init(@t2, @id)
    doc_init(@t3, @id)
    var t1_id: DocumentId
    var t2_id: DocumentId
    var t3_id: DocumentId
    collection_insert(@col, @t1, @t1_id)
    collection_insert(@col, @t2, @t2_id)
    collection_insert(@col, @t3, @t3_id)

    # Insert source with different link types
    var source: Document
    doc_init(@source, @id)
    doc_add_link(@source, "child", @t1_id)
    doc_add_link(@source, "child", @t2_id)
    doc_add_link(@source, "reference", @t3_id)
    var source_id: DocumentId
    collection_insert(@col, @source, @source_id)

    # Get only "child" links
    var linked: [16]DocumentId
    var count: i32 = 0
    get_linked(@col, @source_id, "child", @linked[0], 16, @count)
    if count != 2
        return 1

    # Get only "reference" links
    count = 0
    get_linked(@col, @source_id, "reference", @linked[0], 16, @count)
    if count != 1
        return 2
    0

