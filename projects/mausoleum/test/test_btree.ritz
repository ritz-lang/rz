# test/test_btree.ritz - Tests for B-tree implementation
#
# Comprehensive TDD tests for B-tree operations:
# - Happy path: normal operations work correctly
# - Sad path: error handling, edge cases, corruption
#
# Test categories:
# 1. Node creation and initialization
# 2. Key-value operations (get, put, delete)
# 3. Node splitting and merging
# 4. Range scans and iteration
# 5. Error handling and edge cases
# 6. Concurrency and crash safety

import ritzlib.sys
import ritzlib.io
import ritzlib.str
import ritzlib.memory

import lib.m7m_types
import lib.page
import lib.buffer_pool
import lib.btree

# ============================================================================
# Test Helpers
# ============================================================================

# Create a test key from an integer
fn make_key(n: i32, buf: *u8) -> i32
    # Format: "key_NNNNNNNN" (12 bytes)
    buf[0] = 107  # 'k'
    buf[1] = 101  # 'e'
    buf[2] = 121  # 'y'
    buf[3] = 95   # '_'

    # Write 8 digits
    var val: i32 = n
    for i in 0..8
        let digit: i32 = val % 10
        buf[11 - i] = (48 + digit) as u8
        val = val / 10

    return 12

# Create a test value from an integer
fn make_value(n: i32, buf: *u8) -> i32
    # Format: "val_NNNNNNNN" (12 bytes)
    buf[0] = 118  # 'v'
    buf[1] = 97   # 'a'
    buf[2] = 108  # 'l'
    buf[3] = 95   # '_'

    var val: i32 = n
    for i in 0..8
        let digit: i32 = val % 10
        buf[11 - i] = (48 + digit) as u8
        val = val / 10

    return 12

# Create an in-memory buffer pool for testing (no file I/O)
fn create_test_pool() -> *BufferPool
    return buffer_pool_new(64)

# ============================================================================
# Node Creation Tests (Happy Path)
# ============================================================================

[[test]]
fn test_btree_create_empty() -> i32
    var pool: *BufferPool = create_test_pool()
    if pool == null
        return 1

    var tree: *BTree = btree_create(pool)
    if tree == null
        buffer_pool_destroy(pool)
        return 2

    # Empty tree should have zero entries
    if btree_count(tree) != 0
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 3

    btree_destroy(tree)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_btree_root_is_leaf() -> i32
    var pool: *BufferPool = create_test_pool()
    var tree: *BTree = btree_create(pool)
    if tree == null
        buffer_pool_destroy(pool)
        return 1

    # Empty tree's root should be a leaf
    if btree_root_is_leaf(tree) != 1
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 2

    btree_destroy(tree)
    buffer_pool_destroy(pool)
    0

# ============================================================================
# Single Key-Value Operations (Happy Path)
# ============================================================================

[[test]]
fn test_btree_put_single() -> i32
    var pool: *BufferPool = create_test_pool()
    var tree: *BTree = btree_create(pool)
    if tree == null
        buffer_pool_destroy(pool)
        return 1

    var key: [16]u8
    var val: [16]u8
    let key_len: i32 = make_key(42, @key[0])
    let val_len: i32 = make_value(42, @val[0])

    let err: i32 = btree_put(tree, @key[0], key_len, @val[0], val_len)
    if err != ERR_OK
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 2

    # Count should be 1
    if btree_count(tree) != 1
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 3

    btree_destroy(tree)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_btree_get_single() -> i32
    var pool: *BufferPool = create_test_pool()
    var tree: *BTree = btree_create(pool)

    var key: [16]u8
    var val: [16]u8
    let key_len: i32 = make_key(100, @key[0])
    let val_len: i32 = make_value(100, @val[0])

    btree_put(tree, @key[0], key_len, @val[0], val_len)

    # Get the value back
    var result: [16]u8
    var result_len: i32 = 0
    let err: i32 = btree_get(tree, @key[0], key_len, @result[0], @result_len)

    if err != ERR_OK
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 1

    if result_len != val_len
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 2

    # Verify value matches
    if memcmp(@result[0], @val[0], val_len as i64) != 0
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 3

    btree_destroy(tree)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_btree_put_overwrite() -> i32
    var pool: *BufferPool = create_test_pool()
    var tree: *BTree = btree_create(pool)

    var key: [16]u8
    var val1: [16]u8
    var val2: [16]u8
    let key_len: i32 = make_key(50, @key[0])
    let val1_len: i32 = make_value(50, @val1[0])
    let val2_len: i32 = make_value(999, @val2[0])

    # Insert first value
    btree_put(tree, @key[0], key_len, @val1[0], val1_len)

    # Overwrite with second value
    btree_put(tree, @key[0], key_len, @val2[0], val2_len)

    # Count should still be 1
    if btree_count(tree) != 1
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 1

    # Get should return second value
    var result: [16]u8
    var result_len: i32 = 0
    btree_get(tree, @key[0], key_len, @result[0], @result_len)

    if memcmp(@result[0], @val2[0], val2_len as i64) != 0
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 2

    btree_destroy(tree)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_btree_delete_single() -> i32
    var pool: *BufferPool = create_test_pool()
    var tree: *BTree = btree_create(pool)

    var key: [16]u8
    var val: [16]u8
    let key_len: i32 = make_key(75, @key[0])
    let val_len: i32 = make_value(75, @val[0])

    btree_put(tree, @key[0], key_len, @val[0], val_len)

    # Delete the key
    let err: i32 = btree_delete(tree, @key[0], key_len)
    if err != ERR_OK
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 1

    # Count should be 0
    if btree_count(tree) != 0
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 2

    btree_destroy(tree)
    buffer_pool_destroy(pool)
    0

# ============================================================================
# Multiple Key-Value Operations (Happy Path)
# ============================================================================

[[test]]
fn test_btree_put_multiple_ascending() -> i32
    var pool: *BufferPool = create_test_pool()
    var tree: *BTree = btree_create(pool)

    # Insert 10 keys in ascending order
    for i in 0..10
        var key: [16]u8
        var val: [16]u8
        let key_len: i32 = make_key(i, @key[0])
        let val_len: i32 = make_value(i, @val[0])

        let err: i32 = btree_put(tree, @key[0], key_len, @val[0], val_len)
        if err != ERR_OK
            btree_destroy(tree)
            buffer_pool_destroy(pool)
            return 1

    if btree_count(tree) != 10
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 2

    btree_destroy(tree)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_btree_put_multiple_descending() -> i32
    var pool: *BufferPool = create_test_pool()
    var tree: *BTree = btree_create(pool)

    # Insert 10 keys in descending order
    for i in 0..10
        let n: i32 = 9 - i
        var key: [16]u8
        var val: [16]u8
        let key_len: i32 = make_key(n, @key[0])
        let val_len: i32 = make_value(n, @val[0])

        btree_put(tree, @key[0], key_len, @val[0], val_len)

    if btree_count(tree) != 10
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 1

    btree_destroy(tree)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_btree_put_multiple_random() -> i32
    var pool: *BufferPool = create_test_pool()
    var tree: *BTree = btree_create(pool)

    # Insert keys in pseudo-random order
    var order: [10]i32
    order[0] = 5
    order[1] = 2
    order[2] = 8
    order[3] = 1
    order[4] = 9
    order[5] = 3
    order[6] = 7
    order[7] = 0
    order[8] = 6
    order[9] = 4

    for i in 0..10
        var key: [16]u8
        var val: [16]u8
        let key_len: i32 = make_key(order[i], @key[0])
        let val_len: i32 = make_value(order[i], @val[0])

        btree_put(tree, @key[0], key_len, @val[0], val_len)

    if btree_count(tree) != 10
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 1

    # Verify all keys can be retrieved
    for i in 0..10
        var key: [16]u8
        var result: [16]u8
        var result_len: i32 = 0
        let key_len: i32 = make_key(i, @key[0])

        let err: i32 = btree_get(tree, @key[0], key_len, @result[0], @result_len)
        if err != ERR_OK
            btree_destroy(tree)
            buffer_pool_destroy(pool)
            return 2

    btree_destroy(tree)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_btree_get_all_multiple() -> i32
    var pool: *BufferPool = create_test_pool()
    var tree: *BTree = btree_create(pool)

    # Insert 20 keys
    for i in 0..20
        var key: [16]u8
        var val: [16]u8
        let key_len: i32 = make_key(i, @key[0])
        let val_len: i32 = make_value(i * 10, @val[0])
        btree_put(tree, @key[0], key_len, @val[0], val_len)

    # Verify each key returns the correct value
    for i in 0..20
        var key: [16]u8
        var expected: [16]u8
        var result: [16]u8
        var result_len: i32 = 0

        let key_len: i32 = make_key(i, @key[0])
        make_value(i * 10, @expected[0])

        let err: i32 = btree_get(tree, @key[0], key_len, @result[0], @result_len)
        if err != ERR_OK
            btree_destroy(tree)
            buffer_pool_destroy(pool)
            return 1

        if memcmp(@result[0], @expected[0], result_len as i64) != 0
            btree_destroy(tree)
            buffer_pool_destroy(pool)
            return 2

    btree_destroy(tree)
    buffer_pool_destroy(pool)
    0

# ============================================================================
# Node Splitting Tests (Happy Path)
# ============================================================================

[[test]]
fn test_btree_split_leaf() -> i32
    var pool: *BufferPool = create_test_pool()
    var tree: *BTree = btree_create(pool)

    # Insert enough keys to cause a leaf split
    # With 4KB pages and ~24 byte entries, we need ~100+ entries
    for i in 0..150
        var key: [16]u8
        var val: [16]u8
        let key_len: i32 = make_key(i, @key[0])
        let val_len: i32 = make_value(i, @val[0])
        btree_put(tree, @key[0], key_len, @val[0], val_len)

    # Tree should have multiple levels now
    if btree_height(tree) < 2
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 1

    # All keys should still be retrievable
    for i in 0..150
        var key: [16]u8
        var result: [16]u8
        var result_len: i32 = 0
        let key_len: i32 = make_key(i, @key[0])

        let err: i32 = btree_get(tree, @key[0], key_len, @result[0], @result_len)
        if err != ERR_OK
            btree_destroy(tree)
            buffer_pool_destroy(pool)
            return 2

    btree_destroy(tree)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_btree_split_internal() -> i32
    # With 4KB pages, ~125 entries/leaf, and ~180 children/internal node,
    # we need ~22,500 entries for height 3. Use 25,000 to ensure internal splits.
    var pool: *BufferPool = buffer_pool_new(512)  # More pages needed
    var tree: *BTree = btree_create(pool)

    # Insert many keys to cause internal node splits
    for i in 0..25000
        var key: [16]u8
        var val: [16]u8
        let key_len: i32 = make_key(i, @key[0])
        let val_len: i32 = make_value(i, @val[0])
        let err: i32 = btree_put(tree, @key[0], key_len, @val[0], val_len)
        if err != ERR_OK
            btree_destroy(tree)
            buffer_pool_destroy(pool)
            return 3

    # Tree should have 3+ levels
    if btree_height(tree) < 3
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 1

    if btree_count(tree) != 25000
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 2

    # Verify some keys can still be retrieved
    for i in 0..100
        var key: [16]u8
        var result: [16]u8
        var result_len: i32 = 0
        let idx: i32 = i * 250  # Sample across range
        let key_len: i32 = make_key(idx, @key[0])
        let err: i32 = btree_get(tree, @key[0], key_len, @result[0], @result_len)
        if err != ERR_OK
            btree_destroy(tree)
            buffer_pool_destroy(pool)
            return 4

    btree_destroy(tree)
    buffer_pool_destroy(pool)
    0

# ============================================================================
# Deletion and Merging Tests (Happy Path)
# ============================================================================

[[test]]
fn test_btree_delete_multiple() -> i32
    var pool: *BufferPool = create_test_pool()
    var tree: *BTree = btree_create(pool)

    # Insert 50 keys
    for i in 0..50
        var key: [16]u8
        var val: [16]u8
        let key_len: i32 = make_key(i, @key[0])
        let val_len: i32 = make_value(i, @val[0])
        btree_put(tree, @key[0], key_len, @val[0], val_len)

    # Delete every other key
    for i in 0..25
        var key: [16]u8
        let key_len: i32 = make_key(i * 2, @key[0])
        btree_delete(tree, @key[0], key_len)

    # Count should be 25
    if btree_count(tree) != 25
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 1

    # Odd keys should still exist
    for i in 0..25
        var key: [16]u8
        var result: [16]u8
        var result_len: i32 = 0
        let key_len: i32 = make_key(i * 2 + 1, @key[0])

        let err: i32 = btree_get(tree, @key[0], key_len, @result[0], @result_len)
        if err != ERR_OK
            btree_destroy(tree)
            buffer_pool_destroy(pool)
            return 2

    btree_destroy(tree)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_btree_delete_all() -> i32
    var pool: *BufferPool = create_test_pool()
    var tree: *BTree = btree_create(pool)

    # Insert 100 keys
    for i in 0..100
        var key: [16]u8
        var val: [16]u8
        let key_len: i32 = make_key(i, @key[0])
        let val_len: i32 = make_value(i, @val[0])
        btree_put(tree, @key[0], key_len, @val[0], val_len)

    # Delete all keys
    for i in 0..100
        var key: [16]u8
        let key_len: i32 = make_key(i, @key[0])
        btree_delete(tree, @key[0], key_len)

    # Tree should be empty
    if btree_count(tree) != 0
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 1

    btree_destroy(tree)
    buffer_pool_destroy(pool)
    0

# ============================================================================
# Sad Path: Key Not Found
# ============================================================================

[[test]]
fn test_btree_get_nonexistent() -> i32
    var pool: *BufferPool = create_test_pool()
    var tree: *BTree = btree_create(pool)

    # Try to get a key that doesn't exist
    var key: [16]u8
    var result: [16]u8
    var result_len: i32 = 0
    let key_len: i32 = make_key(999, @key[0])

    let err: i32 = btree_get(tree, @key[0], key_len, @result[0], @result_len)
    if err != ERR_NOT_FOUND
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 1

    btree_destroy(tree)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_btree_get_nonexistent_after_inserts() -> i32
    var pool: *BufferPool = create_test_pool()
    var tree: *BTree = btree_create(pool)

    # Insert some keys
    for i in 0..10
        var key: [16]u8
        var val: [16]u8
        let key_len: i32 = make_key(i * 2, @key[0])  # Even keys only
        let val_len: i32 = make_value(i, @val[0])
        btree_put(tree, @key[0], key_len, @val[0], val_len)

    # Try to get odd keys (don't exist)
    for i in 0..10
        var key: [16]u8
        var result: [16]u8
        var result_len: i32 = 0
        let key_len: i32 = make_key(i * 2 + 1, @key[0])

        let err: i32 = btree_get(tree, @key[0], key_len, @result[0], @result_len)
        if err != ERR_NOT_FOUND
            btree_destroy(tree)
            buffer_pool_destroy(pool)
            return 1

    btree_destroy(tree)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_btree_delete_nonexistent() -> i32
    var pool: *BufferPool = create_test_pool()
    var tree: *BTree = btree_create(pool)

    # Try to delete a key that doesn't exist
    var key: [16]u8
    let key_len: i32 = make_key(999, @key[0])

    let err: i32 = btree_delete(tree, @key[0], key_len)
    if err != ERR_NOT_FOUND
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 1

    btree_destroy(tree)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_btree_get_after_delete() -> i32
    var pool: *BufferPool = create_test_pool()
    var tree: *BTree = btree_create(pool)

    var key: [16]u8
    var val: [16]u8
    let key_len: i32 = make_key(42, @key[0])
    let val_len: i32 = make_value(42, @val[0])

    btree_put(tree, @key[0], key_len, @val[0], val_len)
    btree_delete(tree, @key[0], key_len)

    # Get should now return NOT_FOUND
    var result: [16]u8
    var result_len: i32 = 0
    let err: i32 = btree_get(tree, @key[0], key_len, @result[0], @result_len)
    if err != ERR_NOT_FOUND
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 1

    btree_destroy(tree)
    buffer_pool_destroy(pool)
    0

