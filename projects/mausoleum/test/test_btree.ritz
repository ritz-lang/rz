# Range Scan Tests (Happy Path)
# ============================================================================

[[test]]
fn test_btree_scan_empty() -> i32
    var pool: *BufferPool = create_test_pool()
    var tree: *BTree = btree_create(pool)

    var iter: *BTreeIter = btree_scan(tree, null, 0, null, 0)
    if iter == null
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 1

    # Should be no entries
    if btree_iter_valid(iter) != 0
        btree_iter_destroy(iter)
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 2

    btree_iter_destroy(iter)
    btree_destroy(tree)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_btree_scan_all() -> i32
    var pool: *BufferPool = create_test_pool()
    var tree: *BTree = btree_create(pool)

    # Insert 20 keys
    for i in 0..20
        var key: [16]u8
        var val: [16]u8
        let key_len: i32 = make_key(i, @key[0])
        let val_len: i32 = make_value(i, @val[0])
        btree_put(tree, @key[0], key_len, @val[0], val_len)

    # Scan all
    var iter: *BTreeIter = btree_scan(tree, null, 0, null, 0)
    if iter == null
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 1

    # Count entries
    var count: i32 = 0
    while btree_iter_valid(iter) != 0
        count += 1
        btree_iter_next(iter)

    if count != 20
        btree_iter_destroy(iter)
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 2

    btree_iter_destroy(iter)
    btree_destroy(tree)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_btree_scan_range() -> i32
    var pool: *BufferPool = create_test_pool()
    var tree: *BTree = btree_create(pool)

    # Insert keys 0-99
    for i in 0..100
        var key: [16]u8
        var val: [16]u8
        let key_len: i32 = make_key(i, @key[0])
        let val_len: i32 = make_value(i, @val[0])
        btree_put(tree, @key[0], key_len, @val[0], val_len)

    # Scan range [key_25, key_75)
    var start_key: [16]u8
    var end_key: [16]u8
    let start_len: i32 = make_key(25, @start_key[0])
    let end_len: i32 = make_key(75, @end_key[0])

    var iter: *BTreeIter = btree_scan(tree, @start_key[0], start_len, @end_key[0], end_len)
    if iter == null
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 1

    # Should get keys 25-74 (50 entries)
    var count: i32 = 0
    while btree_iter_valid(iter) != 0
        count += 1
        btree_iter_next(iter)

    if count != 50
        btree_iter_destroy(iter)
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 2

    btree_iter_destroy(iter)
    btree_destroy(tree)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_btree_scan_ordered() -> i32
    var pool: *BufferPool = create_test_pool()
    var tree: *BTree = btree_create(pool)

    # Insert keys in random order
    var order: [10]i32
    order[0] = 5
    order[1] = 2
    order[2] = 8
    order[3] = 1
    order[4] = 9
    order[5] = 3
    order[6] = 7
    order[7] = 0
    order[8] = 6
    order[9] = 4

    for i in 0..10
        var key: [16]u8
        var val: [16]u8
        let key_len: i32 = make_key(order[i], @key[0])
        let val_len: i32 = make_value(order[i], @val[0])
        btree_put(tree, @key[0], key_len, @val[0], val_len)

    # Scan should return keys in sorted order
    var iter: *BTreeIter = btree_scan(tree, null, 0, null, 0)

    var prev: i32 = -1
    while btree_iter_valid(iter) != 0
        var key: [16]u8
        var key_len: i32 = 0
        btree_iter_key(iter, @key[0], @key_len)

        # Extract number from key (bytes 4-11)
        var n: i32 = 0
        for j in 4..12
            n = n * 10 + (key[j] - 48) as i32

        # Should be greater than previous
        if n <= prev
            btree_iter_destroy(iter)
            btree_destroy(tree)
            buffer_pool_destroy(pool)
            return 1

        prev = n
        btree_iter_next(iter)

    btree_iter_destroy(iter)
    btree_destroy(tree)
    buffer_pool_destroy(pool)
    0

# ============================================================================
# Statistics Tests
# ============================================================================

[[test]]
fn test_btree_height_empty() -> i32
    var pool: *BufferPool = create_test_pool()
    var tree: *BTree = btree_create(pool)

    # Empty tree has height 1 (just root leaf)
    if btree_height(tree) != 1
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 1

    btree_destroy(tree)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_btree_node_count() -> i32
    var pool: *BufferPool = create_test_pool()
    var tree: *BTree = btree_create(pool)

    # Empty tree has 1 node (root)
    if btree_node_count(tree) != 1
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 1

    # Insert enough to split
    for i in 0..200
        var key: [16]u8
        var val: [16]u8
        let key_len: i32 = make_key(i, @key[0])
        let val_len: i32 = make_value(i, @val[0])
        btree_put(tree, @key[0], key_len, @val[0], val_len)

    # Should have multiple nodes now
    if btree_node_count(tree) <= 1
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 2

    btree_destroy(tree)
    buffer_pool_destroy(pool)
    0
