    buffer_pool_destroy(pool)
    0

# ============================================================================
# Edge Cases
# ============================================================================

[[test]]
fn test_btree_empty_value() -> i32
    var pool: *BufferPool = create_test_pool()
    var tree: *BTree = btree_create(pool)

    var key: [16]u8
    let key_len: i32 = make_key(1, @key[0])

    # Insert with empty value
    let err: i32 = btree_put(tree, @key[0], key_len, null, 0)
    if err != ERR_OK
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 1

    # Get should succeed with zero length
    var result: [16]u8
    var result_len: i32 = 99
    let err2: i32 = btree_get(tree, @key[0], key_len, @result[0], @result_len)
    if err2 != ERR_OK
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 2

    if result_len != 0
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 3

    btree_destroy(tree)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_btree_duplicate_inserts() -> i32
    var pool: *BufferPool = create_test_pool()
    var tree: *BTree = btree_create(pool)

    var key: [16]u8
    var val: [16]u8
    let key_len: i32 = make_key(42, @key[0])
    let val_len: i32 = make_value(42, @val[0])

    # Insert same key 100 times
    for i in 0..100
        btree_put(tree, @key[0], key_len, @val[0], val_len)

    # Count should still be 1
    if btree_count(tree) != 1
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 1

    btree_destroy(tree)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_btree_single_byte_key() -> i32
    var pool: *BufferPool = create_test_pool()
    var tree: *BTree = btree_create(pool)

    var key: u8 = 65  # 'A'
    var val: [16]u8
    let val_len: i32 = make_value(1, @val[0])

    let err: i32 = btree_put(tree, @key, 1, @val[0], val_len)
    if err != ERR_OK
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 1

    var result: [16]u8
    var result_len: i32 = 0
    let err2: i32 = btree_get(tree, @key, 1, @result[0], @result_len)
    if err2 != ERR_OK
        btree_destroy(tree)
        buffer_pool_destroy(pool)
        return 2

    btree_destroy(tree)
    buffer_pool_destroy(pool)
    0

