# test/test_client.ritz - Tests for client module

import ritzlib.memory
import ritzlib.str

import lib.protocol
import lib.client

# ============================================================================
# Client creation tests
# ============================================================================

[[test]]
fn test_client_new() -> i32
    var client: *Client = client_new()
    assert client != null
    assert client_is_connected(client) == 0
    assert client_session_id(client) == 0
    assert client_has_txn(client) == 0

    client_free(client)
    0

[[test]]
fn test_client_free_null() -> i32
    # Should not crash on null
    client_free(null)
    0

[[test]]
fn test_client_is_connected_null() -> i32
    assert client_is_connected(null) == 0
    0

[[test]]
fn test_client_session_id_null() -> i32
    assert client_session_id(null) == 0
    0

[[test]]
fn test_client_last_error_null() -> i32
    assert client_last_error(null) == PROTO_ERR_INTERNAL
    0

[[test]]
fn test_client_has_txn_null() -> i32
    assert client_has_txn(null) == 0
    0

# ============================================================================
# Disconnected client operation tests
# ============================================================================

[[test]]
fn test_client_ping_not_connected() -> i32
    var client: *Client = client_new()
    let result: i32 = client_ping(client)
    assert result < 0  # Should fail when not connected

    client_free(client)
    0

[[test]]
fn test_client_insert_not_connected() -> i32
    var client: *Client = client_new()
    var data: [8]u8
    memset(@data[0], 0, 8)

    let result: i64 = client_insert(client, @data[0], 8)
    assert result < 0  # Should fail when not connected

    client_free(client)
    0

[[test]]
fn test_client_get_not_connected() -> i32
    var client: *Client = client_new()
    var data: *u8 = null
    var len: i32 = 0

    let result: i32 = client_get(client, 1, @data, @len)
    assert result < 0  # Should fail when not connected

    client_free(client)
    0

[[test]]
fn test_client_delete_not_connected() -> i32
    var client: *Client = client_new()
    let result: i32 = client_delete(client, 1)
    assert result < 0  # Should fail when not connected

    client_free(client)
    0

[[test]]
fn test_client_begin_txn_not_connected() -> i32
    var client: *Client = client_new()
    let result: i64 = client_begin_txn(client)
    assert result < 0  # Should fail when not connected

    client_free(client)
    0

[[test]]
fn test_client_commit_txn_not_connected() -> i32
    var client: *Client = client_new()
    let result: i32 = client_commit_txn(client)
    assert result < 0  # Should fail when not connected

    client_free(client)
    0

[[test]]
fn test_client_abort_txn_not_connected() -> i32
    var client: *Client = client_new()
    let result: i32 = client_abort_txn(client)
    assert result < 0  # Should fail when not connected

    client_free(client)
    0

[[test]]
fn test_client_disconnect_not_connected() -> i32
    var client: *Client = client_new()
    let result: i32 = client_disconnect(client)
    assert result == 0  # Should be no-op

    client_free(client)
    0

# ============================================================================
# Client constant tests
# ============================================================================

[[test]]
fn test_client_buffer_size() -> i32
    assert CLIENT_BUFFER_SIZE == 65536
    0

# ============================================================================
# Null parameter tests
# ============================================================================

[[test]]
fn test_client_connect_null() -> i32
    let result: i32 = client_connect(null, "127.0.0.1", 9999, "test", 4)
    assert result == -1
    0

[[test]]
fn test_client_disconnect_null() -> i32
    let result: i32 = client_disconnect(null)
    assert result == -1
    0

[[test]]
fn test_client_ping_null() -> i32
    let result: i32 = client_ping(null)
    assert result == -1
    0

[[test]]
fn test_client_insert_null() -> i32
    var data: [8]u8
    let result: i64 = client_insert(null, @data[0], 8)
    assert result == -1
    0

[[test]]
fn test_client_get_null() -> i32
    var data: *u8 = null
    var len: i32 = 0
    let result: i32 = client_get(null, 1, @data, @len)
    assert result == -1
    0

[[test]]
fn test_client_delete_null() -> i32
    let result: i32 = client_delete(null, 1)
    assert result == -1
    0

[[test]]
fn test_client_begin_txn_null() -> i32
    let result: i64 = client_begin_txn(null)
    assert result == -1
    0

[[test]]
fn test_client_commit_txn_null() -> i32
    let result: i32 = client_commit_txn(null)
    assert result == -1
    0

[[test]]
fn test_client_abort_txn_null() -> i32
    let result: i32 = client_abort_txn(null)
    assert result == -1
    0
