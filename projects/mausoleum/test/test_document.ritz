# test/test_document.ritz - Tests for Document layer
#
# Tests for Document, DocumentId, Field, and document operations

import ritzlib.sys
import ritzlib.io
import ritzlib.str
import ritzlib.strview

import lib.m7m_types
import lib.document

# ============================================================================
# DocumentId Tests
# ============================================================================

[[test]]
fn test_doc_id_new() -> i32
    var id: DocumentId = doc_id_new(1, 42)
    if doc_id_collection(@id) != 1
        return 1
    if doc_id_sequence(@id) != 42
        return 1
    0

[[test]]
fn test_doc_id_invalid() -> i32
    var id: DocumentId = doc_id_invalid()
    if doc_id_is_valid(@id) != 0
        return 1
    0

[[test]]
fn test_doc_id_valid() -> i32
    var id: DocumentId = doc_id_new(0, 1)
    if doc_id_is_valid(@id) != 1
        return 1
    0

[[test]]
fn test_doc_id_eq() -> i32
    var a: DocumentId = doc_id_new(1, 100)
    var b: DocumentId = doc_id_new(1, 100)
    var c: DocumentId = doc_id_new(1, 101)
    var d: DocumentId = doc_id_new(2, 100)

    # Same doc
    if doc_id_eq(@a, @b) != 1
        return 1
    # Different sequence
    if doc_id_eq(@a, @c) != 0
        return 2
    # Different collection
    if doc_id_eq(@a, @d) != 0
        return 3
    0

# ============================================================================
# Field Type Tests
# ============================================================================

[[test]]
fn test_field_type_null() -> i32
    var f: Field = field_null()
    if field_type(@f) != FIELD_NULL
        return 1
    if field_is_null(@f) != 1
        return 2
    0

[[test]]
fn test_field_type_int() -> i32
    var f: Field = field_int(42)
    if field_type(@f) != FIELD_INT
        return 1
    if field_as_int(@f) != 42
        return 2
    0

[[test]]
fn test_field_type_int_negative() -> i32
    var f: Field = field_int(-100)
    if field_as_int(@f) != -100
        return 1
    0

[[test]]
fn test_field_type_bool_true() -> i32
    var f: Field = field_bool(1)
    if field_type(@f) != FIELD_BOOL
        return 1
    if field_as_bool(@f) != 1
        return 2
    0

[[test]]
fn test_field_type_bool_false() -> i32
    var f: Field = field_bool(0)
    if field_as_bool(@f) != 0
        return 1
    0

[[test]]
fn test_field_type_fixed() -> i32
    # Fixed-point: 3.14 stored as 3140000 (value * 1000000)
    var f: Field = field_fixed(3140000)
    if field_type(@f) != FIELD_FLOAT
        return 1
    if field_as_fixed(@f) != 3140000
        return 2
    0

[[test]]
fn test_field_type_string() -> i32
    var buf: [32]u8
    let msg: StrView = "hello"
    strcpy(@buf[0], msg)
    var f: Field = field_string(@buf[0], 5)
    if field_type(@f) != FIELD_STRING
        return 1
    if field_string_len(@f) != 5
        return 2
    0

[[test]]
fn test_field_type_bytes() -> i32
    var buf: [8]u8
    buf[0] = 0xDE
    buf[1] = 0xAD
    buf[2] = 0xBE
    buf[3] = 0xEF
    var f: Field = field_bytes(@buf[0], 4)
    if field_type(@f) != FIELD_BYTES
        return 1
    if field_bytes_len(@f) != 4
        return 2
    0

[[test]]
fn test_field_type_docref() -> i32
    var ref_id: DocumentId = doc_id_new(5, 123)
    var f: Field = field_docref(@ref_id)
    if field_type(@f) != FIELD_DOCREF
        return 1
    var retrieved: DocumentId = field_as_docref(@f)
    if doc_id_eq(@ref_id, @retrieved) != 1
        return 2
    0

# ============================================================================
# Document Tests
# ============================================================================

[[test]]
fn test_document_init() -> i32
    var doc: Document
    var id: DocumentId = doc_id_new(1, 1)
    doc_init(@doc, @id)

    if doc_id_eq(@doc.id, @id) != 1
        return 1
    if doc.field_count != 0
        return 2
    if doc.version != 1
        return 3
    0

[[test]]
fn test_document_set_field() -> i32
    var doc: Document
    var id: DocumentId = doc_id_new(1, 1)
    doc_init(@doc, @id)

    var field: Field = field_int(42)
    let key: StrView = "age"
    var result: i32 = doc_set_field(@doc, key, @field)
    if result != ERR_OK
        return 1
    if doc.field_count != 1
        return 2
    0

[[test]]
fn test_document_get_field() -> i32
    var doc: Document
    var id: DocumentId = doc_id_new(1, 1)
    doc_init(@doc, @id)

    var field: Field = field_int(42)
    let key: StrView = "age"
    doc_set_field(@doc, key, @field)

    var retrieved: Field
    var result: i32 = doc_get_field(@doc, key, @retrieved)
    if result != ERR_OK
        return 1
    if field_as_int(@retrieved) != 42
        return 2
    0

[[test]]
fn test_document_get_field_not_found() -> i32
    var doc: Document
    var id: DocumentId = doc_id_new(1, 1)
    doc_init(@doc, @id)

    let key: StrView = "missing"
    var field: Field
    var result: i32 = doc_get_field(@doc, key, @field)
    if result != ERR_NOT_FOUND
        return 1
    0

[[test]]
fn test_document_multiple_fields() -> i32
    var doc: Document
    var id: DocumentId = doc_id_new(1, 1)
    doc_init(@doc, @id)

    var f1: Field = field_int(25)
    var f2: Field = field_bool(1)
    var f3: Field = field_fixed(1500000)  # 1.5 as fixed-point

    doc_set_field(@doc, "age", @f1)
    doc_set_field(@doc, "active", @f2)
    doc_set_field(@doc, "score", @f3)

    if doc.field_count != 3
        return 1

    var r1: Field
    var r2: Field
    var r3: Field
    doc_get_field(@doc, "age", @r1)
    doc_get_field(@doc, "active", @r2)
    doc_get_field(@doc, "score", @r3)

    if field_as_int(@r1) != 25
        return 2
    if field_as_bool(@r2) != 1
        return 3
    if field_as_fixed(@r3) != 1500000
        return 4
    0

[[test]]
fn test_document_update_field() -> i32
    var doc: Document
    var id: DocumentId = doc_id_new(1, 1)
    doc_init(@doc, @id)

    var f1: Field = field_int(10)
    doc_set_field(@doc, "count", @f1)

    # Update existing field
    var f2: Field = field_int(20)
    doc_set_field(@doc, "count", @f2)

    # Should still have 1 field, not 2
    if doc.field_count != 1
        return 1

    var r: Field
    doc_get_field(@doc, "count", @r)
    if field_as_int(@r) != 20
        return 2
    0

[[test]]
fn test_document_remove_field() -> i32
    var doc: Document
    var id: DocumentId = doc_id_new(1, 1)
    doc_init(@doc, @id)

    var f: Field = field_int(42)
    doc_set_field(@doc, "x", @f)
    if doc.field_count != 1
        return 1

    var result: i32 = doc_remove_field(@doc, "x")
    if result != ERR_OK
        return 2
    if doc.field_count != 0
        return 3
    0

[[test]]
fn test_document_remove_field_not_found() -> i32
    var doc: Document
    var id: DocumentId = doc_id_new(1, 1)
    doc_init(@doc, @id)

    var result: i32 = doc_remove_field(@doc, "missing")
    if result != ERR_NOT_FOUND
        return 1
    0

# ============================================================================
# Parent/Child Relationship Tests
# ============================================================================

[[test]]
fn test_document_parent() -> i32
    var doc: Document
    var id: DocumentId = doc_id_new(1, 1)
    doc_init(@doc, @id)

    # Initially no parent
    if doc_has_parent(@doc) != 0
        return 1

    var parent_id: DocumentId = doc_id_new(1, 0)
    doc_set_parent(@doc, @parent_id)

    if doc_has_parent(@doc) != 1
        return 2

    var retrieved: DocumentId = doc_get_parent(@doc)
    if doc_id_eq(@parent_id, @retrieved) != 1
        return 3
    0

[[test]]
fn test_document_clear_parent() -> i32
    var doc: Document
    var id: DocumentId = doc_id_new(1, 1)
    doc_init(@doc, @id)

    var parent_id: DocumentId = doc_id_new(1, 0)
    doc_set_parent(@doc, @parent_id)
    if doc_has_parent(@doc) != 1
        return 1

    doc_clear_parent(@doc)
    if doc_has_parent(@doc) != 0
        return 2
    0

# ============================================================================
# Version Tests
# ============================================================================

[[test]]
fn test_document_version() -> i32
    var doc: Document
    var id: DocumentId = doc_id_new(1, 1)
    doc_init(@doc, @id)

    if doc.version != 1
        return 1

    doc_increment_version(@doc)
    if doc.version != 2
        return 2

    doc_increment_version(@doc)
    if doc.version != 3
        return 3
    0

# ============================================================================
# Timestamp Tests
# ============================================================================

[[test]]
fn test_document_timestamps() -> i32
    var doc: Document
    var id: DocumentId = doc_id_new(1, 1)
    doc_init(@doc, @id)

    # created_at should be set
    if doc.created_at.nanos == 0
        return 1

    # updated_at should match created_at initially
    if doc.updated_at.nanos != doc.created_at.nanos
        return 2

    # Touch updates the updated_at
    var old_updated: i64 = doc.updated_at.nanos
    doc_touch(@doc)
    # In practice updated_at may or may not change (depends on time resolution)
    # Just verify the function doesn't crash
    0

# ============================================================================
# Link/Edge Tests
# ============================================================================

[[test]]
fn test_document_add_link() -> i32
    var doc: Document
    var id: DocumentId = doc_id_new(1, 1)
    doc_init(@doc, @id)

    var target: DocumentId = doc_id_new(2, 10)
    var result: i32 = doc_add_link(@doc, "relates_to", @target)
    if result != ERR_OK
        return 1
    if doc.link_count != 1
        return 2
    0

[[test]]
fn test_document_has_link() -> i32
    var doc: Document
    var id: DocumentId = doc_id_new(1, 1)
    doc_init(@doc, @id)

    var target: DocumentId = doc_id_new(2, 10)
    doc_add_link(@doc, "relates_to", @target)

    if doc_has_link(@doc, "relates_to", @target) != 1
        return 1

    # Non-existent link
    var other: DocumentId = doc_id_new(2, 11)
    if doc_has_link(@doc, "relates_to", @other) != 0
        return 2
    0

[[test]]
fn test_document_remove_link() -> i32
    var doc: Document
    var id: DocumentId = doc_id_new(1, 1)
    doc_init(@doc, @id)

    var target: DocumentId = doc_id_new(2, 10)
    doc_add_link(@doc, "relates_to", @target)
    if doc.link_count != 1
        return 1

    var result: i32 = doc_remove_link(@doc, "relates_to", @target)
    if result != ERR_OK
        return 2
    if doc.link_count != 0
        return 3
    0

[[test]]
fn test_document_multiple_links() -> i32
    var doc: Document
    var id: DocumentId = doc_id_new(1, 1)
    doc_init(@doc, @id)

    var t1: DocumentId = doc_id_new(2, 1)
    var t2: DocumentId = doc_id_new(2, 2)
    var t3: DocumentId = doc_id_new(3, 1)

    doc_add_link(@doc, "child", @t1)
    doc_add_link(@doc, "child", @t2)
    doc_add_link(@doc, "references", @t3)

    if doc.link_count != 3
        return 1

    if doc_has_link(@doc, "child", @t1) != 1
        return 2
    if doc_has_link(@doc, "child", @t2) != 1
        return 3
    if doc_has_link(@doc, "references", @t3) != 1
        return 4
    0
