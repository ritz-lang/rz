# ============================================================================
# Edge Cases
# ============================================================================

[[test]]
fn test_index_null_field() -> i32
    var pool: *BufferPool = make_test_pool()
    var col: Collection
    collection_init(@col, pool, 1)

    # Insert document without 'age' field
    var doc: Document
    var id: DocumentId = doc_id_invalid()
    doc_init(@doc, @id)
    var name: Field = field_string(c"Alice", 5)
    doc_set_field(@doc, c"name", @name)
    var out_id: DocumentId
    collection_insert(@col, @doc, @out_id)

    var mgr: *IndexManager = index_manager_new(pool, @col)
    index_create(mgr, c"idx_age", c"age", 0)
    var idx: *Index = index_get(mgr, c"idx_age")

    # Document with null age should still be indexed (as null)
    assert index_entry_count(idx) == 1

    index_manager_destroy(mgr)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_index_string_field() -> i32
    var pool: *BufferPool = make_test_pool()
    var col: Collection
    collection_init(@col, pool, 1)

    insert_test_doc(@col, c"Alice", 30, 1)
    insert_test_doc(@col, c"Bob", 25, 1)
    insert_test_doc(@col, c"Carol", 35, 0)

    var mgr: *IndexManager = index_manager_new(pool, @col)
    var result: i32 = index_create(mgr, c"idx_name", c"name", 0)
    assert result == ERR_OK

    var idx: *Index = index_get(mgr, c"idx_name")
    assert index_entry_count(idx) == 3

    index_manager_destroy(mgr)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_index_stats_null() -> i32
    assert index_entry_count(null) == 0
    assert index_is_unique(null) == 0
    assert index_field_count(null) == 0
    0

[[test]]
fn test_index_manager_destroy_null() -> i32
    index_manager_destroy(null)  # Should not crash
    0

[[test]]
fn test_index_count_null() -> i32
    assert index_count(null) == 0
    0
