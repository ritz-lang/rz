    var no_idx: *Index = index_find_for_field(mgr, c"name")
    assert no_idx == null

    index_manager_destroy(mgr)
    buffer_pool_destroy(pool)
    0

# ============================================================================
# Index Build Tests (with existing documents)
# ============================================================================

[[test]]
fn test_index_build_from_existing() -> i32
    var pool: *BufferPool = make_test_pool()
    var col: Collection
    collection_init(@col, pool, 1)

    # Insert documents first
    insert_test_doc(@col, c"Alice", 30, 1)
    insert_test_doc(@col, c"Bob", 25, 1)
    insert_test_doc(@col, c"Carol", 35, 0)

    # Create index after documents exist
    var mgr: *IndexManager = index_manager_new(pool, @col)
    var result: i32 = index_create(mgr, c"idx_age", c"age", 0)
    assert result == ERR_OK

    var idx: *Index = index_get(mgr, c"idx_age")
    assert idx != null
    assert index_entry_count(idx) == 3

    index_manager_destroy(mgr)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_index_build_unique_violation() -> i32
    var pool: *BufferPool = make_test_pool()
    var col: Collection
    collection_init(@col, pool, 1)

    # Insert documents with duplicate ages
    insert_test_doc(@col, c"Alice", 30, 1)
    insert_test_doc(@col, c"Bob", 30, 1)  # Same age!

    # Create unique index should fail
    var mgr: *IndexManager = index_manager_new(pool, @col)
    var result: i32 = index_create(mgr, c"idx_age_unique", c"age", 1)
    assert result == ERR_EXISTS  # Duplicate detected

    assert index_count(mgr) == 0  # Index not created

    index_manager_destroy(mgr)
    buffer_pool_destroy(pool)
    0

# ============================================================================
# Index Maintenance Tests
# ============================================================================

[[test]]
fn test_index_insert_doc() -> i32
    var pool: *BufferPool = make_test_pool()
    var col: Collection
    collection_init(@col, pool, 1)
    var mgr: *IndexManager = index_manager_new(pool, @col)

    index_create(mgr, c"idx_age", c"age", 0)
    var idx: *Index = index_get(mgr, c"idx_age")
    assert index_entry_count(idx) == 0

    # Insert document and update index
    var doc: Document
    var id: DocumentId = doc_id_invalid()
    doc_init(@doc, @id)
    var age: Field = field_int(25)
    doc_set_field(@doc, c"age", @age)

    var out_id: DocumentId
    collection_insert(@col, @doc, @out_id)
    index_insert_doc(mgr, @doc)

    assert index_entry_count(idx) == 1

    index_manager_destroy(mgr)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_index_delete_doc() -> i32
    var pool: *BufferPool = make_test_pool()
    var col: Collection
    collection_init(@col, pool, 1)
    var mgr: *IndexManager = index_manager_new(pool, @col)

    # Insert and index
    var doc: Document
    var id: DocumentId = doc_id_invalid()
    doc_init(@doc, @id)
    var age: Field = field_int(25)
    doc_set_field(@doc, c"age", @age)

    var out_id: DocumentId
    collection_insert(@col, @doc, @out_id)

    index_create(mgr, c"idx_age", c"age", 0)
    var idx: *Index = index_get(mgr, c"idx_age")
    assert index_entry_count(idx) == 1

    # Delete from index
    index_delete_doc(mgr, @doc)
    assert index_entry_count(idx) == 0

    index_manager_destroy(mgr)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_index_update_doc() -> i32
    var pool: *BufferPool = make_test_pool()
    var col: Collection
    collection_init(@col, pool, 1)
    var mgr: *IndexManager = index_manager_new(pool, @col)

    # Insert and index
    var doc: Document
    var id: DocumentId = doc_id_invalid()
    doc_init(@doc, @id)
    var age: Field = field_int(25)
    doc_set_field(@doc, c"age", @age)

    var out_id: DocumentId
    collection_insert(@col, @doc, @out_id)

    index_create(mgr, c"idx_age", c"age", 0)
    var idx: *Index = index_get(mgr, c"idx_age")
    assert index_entry_count(idx) == 1

    # Update document (change age)
    # Create copies for old/new to avoid ownership issues
    var old_doc: Document
    memcpy(@old_doc, @doc, sizeof(Document) as i64)

    var new_age: Field = field_int(30)
    doc_set_field(@doc, c"age", @new_age)

    index_update_doc(mgr, @old_doc, @doc)
    assert index_entry_count(idx) == 1  # Still one entry

    index_manager_destroy(mgr)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_index_unique_insert_violation() -> i32
    var pool: *BufferPool = make_test_pool()
    var col: Collection
    collection_init(@col, pool, 1)
    var mgr: *IndexManager = index_manager_new(pool, @col)

    index_create(mgr, c"idx_age_unique", c"age", 1)

    # Insert first document
    var doc1: Document
    var id1: DocumentId = doc_id_invalid()
    doc_init(@doc1, @id1)
    var age1: Field = field_int(25)
    doc_set_field(@doc1, c"age", @age1)
    var out1: DocumentId
    collection_insert(@col, @doc1, @out1)
    var result1: i32 = index_insert_doc(mgr, @doc1)
    assert result1 == ERR_OK

    # Insert second document with same age
    var doc2: Document
    var id2: DocumentId = doc_id_invalid()
    doc_init(@doc2, @id2)
    var age2: Field = field_int(25)  # Same age!
    doc_set_field(@doc2, c"age", @age2)
    var out2: DocumentId
    collection_insert(@col, @doc2, @out2)
    var result2: i32 = index_insert_doc(mgr, @doc2)
    assert result2 == ERR_EXISTS  # Should fail

    index_manager_destroy(mgr)
    buffer_pool_destroy(pool)
    0

# ============================================================================
# Index Scan Tests
# ============================================================================

[[test]]
fn test_index_scan_eq() -> i32
    var pool: *BufferPool = make_test_pool()
    var col: Collection
    collection_init(@col, pool, 1)

    insert_test_doc(@col, c"Alice", 30, 1)
    insert_test_doc(@col, c"Bob", 25, 1)
    insert_test_doc(@col, c"Carol", 30, 0)

    var mgr: *IndexManager = index_manager_new(pool, @col)
    index_create(mgr, c"idx_age", c"age", 0)
    var idx: *Index = index_get(mgr, c"idx_age")

    # Just verify the index was built correctly
    assert index_entry_count(idx) == 3

    # Scan for age starting from 30
    var search_val: Field = field_int(30)
    var iter: *BTreeIter = index_scan_eq(idx, @search_val)
    assert iter != null

    btree_iter_destroy(iter)

    index_manager_destroy(mgr)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_index_scan_range() -> i32
    var pool: *BufferPool = make_test_pool()
    var col: Collection
    collection_init(@col, pool, 1)

    insert_test_doc(@col, c"Alice", 20, 1)
    insert_test_doc(@col, c"Bob", 25, 1)
    insert_test_doc(@col, c"Carol", 30, 0)
    insert_test_doc(@col, c"Dave", 35, 1)
    insert_test_doc(@col, c"Eve", 40, 0)

    var mgr: *IndexManager = index_manager_new(pool, @col)
    index_create(mgr, c"idx_age", c"age", 0)
    var idx: *Index = index_get(mgr, c"idx_age")

    # Verify index built correctly
    assert index_entry_count(idx) == 5

    # Test range scan returns valid iterator
    var start_val: Field = field_int(25)
    var end_val: Field = field_int(35)
    var iter: *BTreeIter = index_scan_range(idx, @start_val, @end_val)
    assert iter != null

    btree_iter_destroy(iter)

    index_manager_destroy(mgr)
    buffer_pool_destroy(pool)
    0

