# test/test_index.ritz - Tests for secondary indexes

import ritzlib.sys
import ritzlib.str
import ritzlib.memory

import lib.m7m_types
import lib.buffer_pool
import lib.document
import lib.collection
import lib.index
import lib.btree

# ============================================================================
# Test Helpers
# ============================================================================

fn make_test_pool() -> *BufferPool
    return buffer_pool_new(128)

fn insert_test_doc(col: *Collection, name: *u8, age: i64, active: i32) -> DocumentId
    var doc: Document
    var id: DocumentId = doc_id_invalid()
    doc_init(@doc, @id)

    var name_field: Field = field_string(name, strlen(name))
    doc_set_field(@doc, c"name", @name_field)

    var age_field: Field = field_int(age)
    doc_set_field(@doc, c"age", @age_field)

    var active_field: Field = field_bool(active)
    doc_set_field(@doc, c"active", @active_field)

    var out_id: DocumentId
    collection_insert(col, @doc, @out_id)
    return out_id

# ============================================================================
# IndexManager Creation Tests
# ============================================================================

[[test]]
fn test_index_manager_new() -> i32
    var pool: *BufferPool = make_test_pool()
    var col: Collection
    collection_init(@col, pool, 1)

    var mgr: *IndexManager = index_manager_new(pool, @col)
    assert mgr != null
    assert index_count(mgr) == 0

    index_manager_destroy(mgr)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_index_manager_new_null_pool() -> i32
    var col: Collection
    var mgr: *IndexManager = index_manager_new(null, @col)
    assert mgr == null
    0

[[test]]
fn test_index_manager_new_null_collection() -> i32
    var pool: *BufferPool = make_test_pool()
    var mgr: *IndexManager = index_manager_new(pool, null)
    assert mgr == null
    buffer_pool_destroy(pool)
    0

# ============================================================================
# Index Creation Tests
# ============================================================================

[[test]]
fn test_index_create_single_field() -> i32
    var pool: *BufferPool = make_test_pool()
    var col: Collection
    collection_init(@col, pool, 1)
    var mgr: *IndexManager = index_manager_new(pool, @col)

    var result: i32 = index_create(mgr, c"idx_age", c"age", 0)
    assert result == ERR_OK
    assert index_count(mgr) == 1

    index_manager_destroy(mgr)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_index_create_unique() -> i32
    var pool: *BufferPool = make_test_pool()
    var col: Collection
    collection_init(@col, pool, 1)
    var mgr: *IndexManager = index_manager_new(pool, @col)

    var result: i32 = index_create(mgr, c"idx_email", c"email", 1)
    assert result == ERR_OK

    var idx: *Index = index_get(mgr, c"idx_email")
    assert idx != null
    assert index_is_unique(idx) == 1

    index_manager_destroy(mgr)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_index_create_non_unique() -> i32
    var pool: *BufferPool = make_test_pool()
    var col: Collection
    collection_init(@col, pool, 1)
    var mgr: *IndexManager = index_manager_new(pool, @col)

    var result: i32 = index_create(mgr, c"idx_age", c"age", 0)
    assert result == ERR_OK

    var idx: *Index = index_get(mgr, c"idx_age")
    assert idx != null
    assert index_is_unique(idx) == 0

    index_manager_destroy(mgr)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_index_create_duplicate_name() -> i32
    var pool: *BufferPool = make_test_pool()
    var col: Collection
    collection_init(@col, pool, 1)
    var mgr: *IndexManager = index_manager_new(pool, @col)

    index_create(mgr, c"idx_age", c"age", 0)
    var result: i32 = index_create(mgr, c"idx_age", c"name", 0)
    assert result == ERR_EXISTS

    index_manager_destroy(mgr)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_index_create_null_params() -> i32
    var pool: *BufferPool = make_test_pool()
    var col: Collection
    collection_init(@col, pool, 1)
    var mgr: *IndexManager = index_manager_new(pool, @col)

    assert index_create(null, c"idx", c"field", 0) == ERR_INVALID
    assert index_create(mgr, null, c"field", 0) == ERR_INVALID
    assert index_create(mgr, c"idx", null, 0) == ERR_INVALID

    index_manager_destroy(mgr)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_index_create_multiple() -> i32
    var pool: *BufferPool = make_test_pool()
    var col: Collection
    collection_init(@col, pool, 1)
    var mgr: *IndexManager = index_manager_new(pool, @col)

    index_create(mgr, c"idx_age", c"age", 0)
    index_create(mgr, c"idx_name", c"name", 0)
    index_create(mgr, c"idx_active", c"active", 0)

    assert index_count(mgr) == 3

    index_manager_destroy(mgr)
    buffer_pool_destroy(pool)
    0

# ============================================================================
# Index Drop Tests
# ============================================================================

[[test]]
fn test_index_drop() -> i32
    var pool: *BufferPool = make_test_pool()
    var col: Collection
    collection_init(@col, pool, 1)
    var mgr: *IndexManager = index_manager_new(pool, @col)

    index_create(mgr, c"idx_age", c"age", 0)
    assert index_count(mgr) == 1

    var result: i32 = index_drop(mgr, c"idx_age")
    assert result == ERR_OK
    assert index_count(mgr) == 0

    index_manager_destroy(mgr)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_index_drop_not_found() -> i32
    var pool: *BufferPool = make_test_pool()
    var col: Collection
    collection_init(@col, pool, 1)
    var mgr: *IndexManager = index_manager_new(pool, @col)

    var result: i32 = index_drop(mgr, c"nonexistent")
    assert result == ERR_NOT_FOUND

    index_manager_destroy(mgr)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_index_drop_middle() -> i32
    var pool: *BufferPool = make_test_pool()
    var col: Collection
    collection_init(@col, pool, 1)
    var mgr: *IndexManager = index_manager_new(pool, @col)

    index_create(mgr, c"idx_a", c"a", 0)
    index_create(mgr, c"idx_b", c"b", 0)
    index_create(mgr, c"idx_c", c"c", 0)

    index_drop(mgr, c"idx_b")
    assert index_count(mgr) == 2

    # Check remaining indexes
    assert index_get(mgr, c"idx_a") != null
    assert index_get(mgr, c"idx_b") == null
    assert index_get(mgr, c"idx_c") != null

    index_manager_destroy(mgr)
    buffer_pool_destroy(pool)
    0

