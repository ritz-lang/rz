# test/test_buffer_pool.ritz - Tests for buffer pool manager
#
# Tests for buffer pool creation, page fetching, pinning, and eviction

import ritzlib.sys
import ritzlib.io
import ritzlib.str
import ritzlib.memory
import ritzlib.option

import lib.m7m_types
import lib.page
import lib.buffer_pool

# ============================================================================
# Buffer Pool Creation Tests
# ============================================================================

[[test]]
fn test_buffer_pool_new() -> i32
    let pool_opt = buffer_pool_new(16)
    if option_is_none<*BufferPool>(@pool_opt) == 1
        return 1
    let pool: *BufferPool = option_unwrap_or<*BufferPool>(@pool_opt, null)

    buffer_pool_destroy(pool)
    0

[[test]]
fn test_buffer_pool_default() -> i32
    let pool_opt = buffer_pool_default()
    if option_is_none<*BufferPool>(@pool_opt) == 1
        return 1
    let pool: *BufferPool = option_unwrap_or<*BufferPool>(@pool_opt, null)

    buffer_pool_destroy(pool)
    0

[[test]]
fn test_buffer_pool_new_invalid() -> i32
    # Zero frames - should return None
    let pool1_opt = buffer_pool_new(0)
    if option_is_some<*BufferPool>(@pool1_opt) == 1
        return 1

    # Negative frames - should return None
    let pool2_opt = buffer_pool_new(-1)
    if option_is_some<*BufferPool>(@pool2_opt) == 1
        return 2

    0

# ============================================================================
# Page Allocation Tests (in-memory only, no file)
# ============================================================================

[[test]]
fn test_buffer_pool_alloc_single() -> i32
    let pool_opt = buffer_pool_new(8)
    if option_is_none<*BufferPool>(@pool_opt) == 1
        return 1
    let pool: *BufferPool = option_unwrap_or<*BufferPool>(@pool_opt, null)

    let page_opt = buffer_pool_alloc(pool, PAGE_MAGIC_HEAP)
    if option_is_none<*Page>(@page_opt) == 1
        buffer_pool_destroy(pool)
        return 2
    let page: *Page = option_unwrap_or<*Page>(@page_opt, null)

    # Check page is initialized
    if page_type(page) != PAGE_MAGIC_HEAP
        buffer_pool_destroy(pool)
        return 3

    # Get page ID
    var page_id: i64 = buffer_pool_page_id(pool, page)
    if page_id != 0
        buffer_pool_destroy(pool)
        return 4

    buffer_pool_unpin(pool, page_id, 0)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_buffer_pool_alloc_multiple() -> i32
    let pool_opt = buffer_pool_new(8)
    if option_is_none<*BufferPool>(@pool_opt) == 1
        return 1
    let pool: *BufferPool = option_unwrap_or<*BufferPool>(@pool_opt, null)

    let page1_opt = buffer_pool_alloc(pool, PAGE_MAGIC_HEAP)
    let page2_opt = buffer_pool_alloc(pool, PAGE_MAGIC_BTREE)
    let page3_opt = buffer_pool_alloc(pool, PAGE_MAGIC_META)

    if option_is_none<*Page>(@page1_opt) == 1 or option_is_none<*Page>(@page2_opt) == 1 or option_is_none<*Page>(@page3_opt) == 1
        buffer_pool_destroy(pool)
        return 2

    let page1: *Page = option_unwrap_or<*Page>(@page1_opt, null)
    let page2: *Page = option_unwrap_or<*Page>(@page2_opt, null)
    let page3: *Page = option_unwrap_or<*Page>(@page3_opt, null)

    var id1: i64 = buffer_pool_page_id(pool, page1)
    var id2: i64 = buffer_pool_page_id(pool, page2)
    var id3: i64 = buffer_pool_page_id(pool, page3)

    # Page IDs should be sequential
    if id1 != 0 or id2 != 1 or id3 != 2
        buffer_pool_destroy(pool)
        return 3

    buffer_pool_unpin(pool, id1, 0)
    buffer_pool_unpin(pool, id2, 0)
    buffer_pool_unpin(pool, id3, 0)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_buffer_pool_alloc_fills_pool() -> i32
    let pool_opt = buffer_pool_new(4)
    if option_is_none<*BufferPool>(@pool_opt) == 1
        return 1
    let pool: *BufferPool = option_unwrap_or<*BufferPool>(@pool_opt, null)

    # Allocate 4 pages (fills the pool)
    for i in 0..4
        let page_opt = buffer_pool_alloc(pool, PAGE_MAGIC_HEAP)
        if option_is_none<*Page>(@page_opt) == 1
            buffer_pool_destroy(pool)
            return 2

    # All pages are pinned, so 5th allocation should fail
    let page5_opt = buffer_pool_alloc(pool, PAGE_MAGIC_HEAP)
    if option_is_some<*Page>(@page5_opt) == 1
        buffer_pool_destroy(pool)
        return 3

    buffer_pool_destroy(pool)
    0

[[test]]
fn test_buffer_pool_unpin_allows_eviction() -> i32
    let pool_opt = buffer_pool_new(4)
    if option_is_none<*BufferPool>(@pool_opt) == 1
        return 1
    let pool: *BufferPool = option_unwrap_or<*BufferPool>(@pool_opt, null)

    # Allocate 4 pages
    var page_ids: [4]i64
    for i in 0..4
        let page_opt = buffer_pool_alloc(pool, PAGE_MAGIC_HEAP)
        if option_is_none<*Page>(@page_opt) == 1
            buffer_pool_destroy(pool)
            return 2
        let page: *Page = option_unwrap_or<*Page>(@page_opt, null)
        page_ids[i] = buffer_pool_page_id(pool, page)

    # Unpin one page
    buffer_pool_unpin(pool, page_ids[0], 0)

    # Now we can allocate another (evicts the unpinned page)
    let page5_opt = buffer_pool_alloc(pool, PAGE_MAGIC_HEAP)
    if option_is_none<*Page>(@page5_opt) == 1
        buffer_pool_destroy(pool)
        return 3

    buffer_pool_destroy(pool)
    0

# ============================================================================
# Statistics Tests
# ============================================================================

[[test]]
fn test_buffer_pool_stats_initial() -> i32
    let pool_opt = buffer_pool_new(8)
    if option_is_none<*BufferPool>(@pool_opt) == 1
        return 1
    let pool: *BufferPool = option_unwrap_or<*BufferPool>(@pool_opt, null)

    if buffer_pool_hit_count(pool) != 0
        buffer_pool_destroy(pool)
        return 2

    if buffer_pool_miss_count(pool) != 0
        buffer_pool_destroy(pool)
        return 3

    if buffer_pool_eviction_count(pool) != 0
        buffer_pool_destroy(pool)
        return 4

    buffer_pool_destroy(pool)
    0

[[test]]
fn test_buffer_pool_eviction_stats() -> i32
    let pool_opt = buffer_pool_new(2)
    if option_is_none<*BufferPool>(@pool_opt) == 1
        return 1
    let pool: *BufferPool = option_unwrap_or<*BufferPool>(@pool_opt, null)

    # Allocate 2 pages
    let page1_opt = buffer_pool_alloc(pool, PAGE_MAGIC_HEAP)
    let page2_opt = buffer_pool_alloc(pool, PAGE_MAGIC_HEAP)
    let page1: *Page = option_unwrap_or<*Page>(@page1_opt, null)
    let page2: *Page = option_unwrap_or<*Page>(@page2_opt, null)
    var id1: i64 = buffer_pool_page_id(pool, page1)
    var id2: i64 = buffer_pool_page_id(pool, page2)

    # Unpin both
    buffer_pool_unpin(pool, id1, 0)
    buffer_pool_unpin(pool, id2, 0)

    # Allocate a third - should evict one
    let page3_opt = buffer_pool_alloc(pool, PAGE_MAGIC_HEAP)
    if option_is_none<*Page>(@page3_opt) == 1
        buffer_pool_destroy(pool)
        return 2

    # Check eviction happened
    if buffer_pool_eviction_count(pool) != 1
        buffer_pool_destroy(pool)
        return 3

    buffer_pool_destroy(pool)
    0

# ============================================================================
# Dirty Page Tests
# ============================================================================

[[test]]
fn test_buffer_pool_dirty_tracking() -> i32
    let pool_opt = buffer_pool_new(4)
    if option_is_none<*BufferPool>(@pool_opt) == 1
        return 1
    let pool: *BufferPool = option_unwrap_or<*BufferPool>(@pool_opt, null)

    let page_opt = buffer_pool_alloc(pool, PAGE_MAGIC_HEAP)
    let page: *Page = option_unwrap_or<*Page>(@page_opt, null)
    var page_id: i64 = buffer_pool_page_id(pool, page)

    # Modify the page
    page.data[0] = 42

    # Unpin as dirty
    buffer_pool_unpin(pool, page_id, 1)

    # Fetch again - should get same page with our data
    let page2_opt = buffer_pool_fetch(pool, page_id)
    if option_is_none<*Page>(@page2_opt) == 1
        buffer_pool_destroy(pool)
        return 2
    let page2: *Page = option_unwrap_or<*Page>(@page2_opt, null)

    if page2.data[0] != 42
        buffer_pool_destroy(pool)
        return 3

    buffer_pool_unpin(pool, page_id, 0)
    buffer_pool_destroy(pool)
    0

# ============================================================================
# Fetch Tests (in-memory)
# ============================================================================

[[test]]
fn test_buffer_pool_fetch_allocated() -> i32
    let pool_opt = buffer_pool_new(4)
    if option_is_none<*BufferPool>(@pool_opt) == 1
        return 1
    let pool: *BufferPool = option_unwrap_or<*BufferPool>(@pool_opt, null)

    let page_opt = buffer_pool_alloc(pool, PAGE_MAGIC_HEAP)
    let page: *Page = option_unwrap_or<*Page>(@page_opt, null)
    var page_id: i64 = buffer_pool_page_id(pool, page)
    page.data[0] = 99

    # Unpin
    buffer_pool_unpin(pool, page_id, 1)

    # Fetch the same page
    let fetched_opt = buffer_pool_fetch(pool, page_id)
    if option_is_none<*Page>(@fetched_opt) == 1
        buffer_pool_destroy(pool)
        return 2
    let fetched: *Page = option_unwrap_or<*Page>(@fetched_opt, null)

    # Should have our data
    if fetched.data[0] != 99
        buffer_pool_destroy(pool)
        return 3

    # Check cache hit
    if buffer_pool_hit_count(pool) != 1
        buffer_pool_destroy(pool)
        return 4

    buffer_pool_unpin(pool, page_id, 0)
    buffer_pool_destroy(pool)
    0

[[test]]
fn test_buffer_pool_fetch_null_pool() -> i32
    let page_opt = buffer_pool_fetch(null, 0)
    if option_is_some<*Page>(@page_opt) == 1
        return 1
    0

[[test]]
fn test_buffer_pool_fetch_negative_id() -> i32
    let pool_opt = buffer_pool_new(4)
    if option_is_none<*BufferPool>(@pool_opt) == 1
        return 1
    let pool: *BufferPool = option_unwrap_or<*BufferPool>(@pool_opt, null)

    let page_opt = buffer_pool_fetch(pool, -1)
    if option_is_some<*Page>(@page_opt) == 1
        buffer_pool_destroy(pool)
        return 2

    buffer_pool_destroy(pool)
    0

# ============================================================================
# LRU Eviction Order Tests
# ============================================================================

[[test]]
fn test_buffer_pool_lru_eviction_order() -> i32
    let pool_opt = buffer_pool_new(2)
    if option_is_none<*BufferPool>(@pool_opt) == 1
        return 1
    let pool: *BufferPool = option_unwrap_or<*BufferPool>(@pool_opt, null)

    # Allocate page 0
    let page0_opt = buffer_pool_alloc(pool, PAGE_MAGIC_HEAP)
    let page0: *Page = option_unwrap_or<*Page>(@page0_opt, null)
    var id0: i64 = buffer_pool_page_id(pool, page0)
    page0.data[0] = 10
    buffer_pool_unpin(pool, id0, 1)

    # Allocate page 1
    let page1_opt = buffer_pool_alloc(pool, PAGE_MAGIC_HEAP)
    let page1: *Page = option_unwrap_or<*Page>(@page1_opt, null)
    var id1: i64 = buffer_pool_page_id(pool, page1)
    page1.data[0] = 20
    buffer_pool_unpin(pool, id1, 1)

    # Re-fetch page 0 (makes it most recently used)
    let refetched0_opt = buffer_pool_fetch(pool, id0)
    let refetched0: *Page = option_unwrap_or<*Page>(@refetched0_opt, null)
    buffer_pool_unpin(pool, id0, 0)

    # Now allocate page 2 - should evict page 1 (LRU)
    let page2_opt = buffer_pool_alloc(pool, PAGE_MAGIC_HEAP)
    if option_is_none<*Page>(@page2_opt) == 1
        buffer_pool_destroy(pool)
        return 2

    # Page 0 should still be in cache (was MRU)
    let check0_opt = buffer_pool_fetch(pool, id0)
    if option_is_none<*Page>(@check0_opt) == 1
        buffer_pool_destroy(pool)
        return 3
    let check0: *Page = option_unwrap_or<*Page>(@check0_opt, null)

    if check0.data[0] != 10
        buffer_pool_destroy(pool)
        return 4

    buffer_pool_destroy(pool)
    0

# ============================================================================
# Pin Count Tests
# ============================================================================

[[test]]
fn test_buffer_pool_multiple_pins() -> i32
    let pool_opt = buffer_pool_new(2)
    if option_is_none<*BufferPool>(@pool_opt) == 1
        return 1
    let pool: *BufferPool = option_unwrap_or<*BufferPool>(@pool_opt, null)

    # Allocate a page
    let page_opt = buffer_pool_alloc(pool, PAGE_MAGIC_HEAP)
    let page: *Page = option_unwrap_or<*Page>(@page_opt, null)
    var page_id: i64 = buffer_pool_page_id(pool, page)

    # Fetch it again (should increase pin count)
    let page2_opt = buffer_pool_fetch(pool, page_id)
    let page2: *Page = option_unwrap_or<*Page>(@page2_opt, null)

    # Both should point to the same page
    if page != page2
        buffer_pool_destroy(pool)
        return 2

    # Unpin once
    buffer_pool_unpin(pool, page_id, 0)

    # Allocate another page - first page still pinned, so use other frame
    let page3_opt = buffer_pool_alloc(pool, PAGE_MAGIC_HEAP)
    let page3: *Page = option_unwrap_or<*Page>(@page3_opt, null)
    var id3: i64 = buffer_pool_page_id(pool, page3)
    buffer_pool_unpin(pool, id3, 0)

    # Try to allocate third - both frames occupied, one pinned
    # Unpin the first completely
    buffer_pool_unpin(pool, page_id, 0)

    # Now allocation should work
    let page4_opt = buffer_pool_alloc(pool, PAGE_MAGIC_HEAP)
    if option_is_none<*Page>(@page4_opt) == 1
        buffer_pool_destroy(pool)
        return 3

    buffer_pool_destroy(pool)
    0
