# tools/concurrent_bench.ritz - Concurrency stress driver for the async server
#
# Phase 5 of the mausoleum-async refactor: prove the async loop can
# service multiple clients simultaneously without one stalling another.
# This binary is invoked from `tools/concurrent_test.sh` (and matrix
# regression in test_concurrent) to exercise three scenarios:
#
#   1. Parallel inserts — multiple --bulk-insert processes vs same DB
#   2. Slow-client isolation — silent nc + concurrent --ping-loop
#   3. Mid-scan starvation — long --scan-loop + concurrent --ping-loop
#
# Each subcommand exits with a non-zero rc on protocol/connection error
# so the harness can assert success across N concurrent invocations.

import ritzlib.sys
import ritzlib.io
import ritzlib.str
import ritzlib.strview
import ritzlib.memory

import lib.m7m_types
import lib.protocol
import lib.client
import lib.document
import lib.collection

const DEFAULT_PORT: i32 = 7777
const COLLECTION_NAME: StrView = "wiki_pages"

# ============================================================================
# Helpers
# ============================================================================

fn print_i32(n: i32)
    print_i64(n as i64)


fn print_err(msg: StrView)
    prints("ERROR: ")
    prints(msg)
    prints("\n")


fn parse_int_arg(s: *u8) -> i32
    var n: i32 = 0
    var i: i64 = 0
    while *(s + i) != 0
        var c: u8 = *(s + i)
        if c >= 48 and c <= 57
            n = n * 10 + (c - 48) as i32
        i += 1
    return n


fn parse_int_arg_i64(s: *u8) -> i64
    var n: i64 = 0
    var i: i64 = 0
    while *(s + i) != 0
        var c: u8 = *(s + i)
        if c >= 48 and c <= 57
            n = n * 10 + (c - 48) as i64
        i += 1
    return n


fn arg_eq(arg: *u8, literal: StrView) -> i32
    return strview_eq_cstr(@literal, arg)


# ============================================================================
# Tiny doc factory — every concurrent client builds the same shape so the
# server's cost is bounded and predictable.
# ============================================================================

fn build_tiny_doc(buf: *u8, buf_len: i64, n: i32) -> i64
    var doc: Document
    var tmp_id: DocumentId = doc_id_invalid()
    doc_init(@doc, @tmp_id)

    # `n_field` lets us correlate inserts back to caller iteration if we
    # ever want to verify document-level consistency.  For phase-5 the
    # only assertion is "exit rc == 0 across all callers".
    var n_field: Field = field_int(n as i64)
    doc_set_field(@doc, "n", @n_field)

    var marker_field: Field = field_string("p5", 2)
    doc_set_field(@doc, "marker", @marker_field)

    return doc_serialize(@doc, buf, buf_len)


# ============================================================================
# Subcommands
# ============================================================================

# Insert `count` docs sequentially.  Used to (a) seed enough rows to
# force a multi-batch SCAN, and (b) hammer concurrent INSERTs from
# multiple processes against the same async server.
fn cmd_bulk_insert(client: *Client, count: i32) -> i32
    var doc_buf: [256]u8
    var i: i32 = 0
    while i < count
        let doc_size: i64 = build_tiny_doc(@doc_buf[0], 256, i)
        if doc_size < 0
            print_err("doc_serialize failed")
            return 1
        let doc_id: i64 = client_insert(client, @doc_buf[0], doc_size as i32)
        if doc_id < 0
            print_err("INSERT failed")
            prints("  rc=")
            print_i32(doc_id as i32)
            prints(" at i=")
            print_i32(i)
            prints("\n")
            return 1
        i += 1
    prints("[bulk-insert] done count=")
    print_i32(count)
    prints("\n")
    return 0


# Issue `count` PINGs over a single keep-alive connection.  PING goes
# straight through the protocol (no DB work) so the response time is a
# clean signal of "is the event loop responsive right now?".  If
# anything in handle_task_event blocks an unrelated client, this loop
# will run noticeably slower than its single-client baseline.
fn cmd_ping_loop(client: *Client, count: i32) -> i32
    var i: i32 = 0
    while i < count
        let rc: i32 = client_ping(client)
        if rc != 0
            print_err("PING failed")
            prints("  rc=")
            print_i32(rc)
            prints(" at i=")
            print_i32(i)
            prints("\n")
            return 1
        i += 1
    prints("[ping-loop] done count=")
    print_i32(count)
    prints("\n")
    return 0


# Scan-with-discard callback — we don't care what comes back, only that
# the scan completes successfully without dropping a frame.
fn scan_discard_cb(doc_id: i64, data: *u8, data_len: i32, user_data: *u8) -> i32
    return 0


# Iterate the entire collection `iters` times.  Each scan runs to
# completion (SCAN_END drained) before the next one starts.  Useful as
# the long-running bg load for the mid-scan-starvation test.
fn cmd_scan_loop(client: *Client, iters: i32) -> i32
    var i: i32 = 0
    while i < iters
        let total: i32 = client_scan(client, scan_discard_cb as *u8, null)
        if total < 0
            print_err("SCAN failed")
            prints("  rc=")
            print_i32(total)
            prints(" at i=")
            print_i32(i)
            prints("\n")
            return 1
        prints("[scan-loop] iter=")
        print_i32(i)
        prints(" docs=")
        print_i32(total)
        prints("\n")
        i += 1
    return 0


# ============================================================================
# Main
# ============================================================================

pub fn main(argc: i32, argv: **u8) -> i32
    var port: i32 = DEFAULT_PORT
    var mode: i32 = 0          # 0 = none, 1 = bulk-insert, 2 = ping-loop, 3 = scan-loop
    var n_arg: i32 = 0          # count for bulk-insert / ping-loop / scan-loop

    var i: i32 = 1
    while i < argc
        var arg: *u8 = *(argv + i)
        if arg_eq(arg, "--port") != 0
            if i + 1 >= argc
                print_err("--port needs value")
                return 2
            port = parse_int_arg(*(argv + i + 1))
            i += 2
        else if arg_eq(arg, "--bulk-insert") != 0
            if i + 1 >= argc
                print_err("--bulk-insert needs count")
                return 2
            mode = 1
            n_arg = parse_int_arg(*(argv + i + 1))
            i += 2
        else if arg_eq(arg, "--ping-loop") != 0
            if i + 1 >= argc
                print_err("--ping-loop needs count")
                return 2
            mode = 2
            n_arg = parse_int_arg(*(argv + i + 1))
            i += 2
        else if arg_eq(arg, "--scan-loop") != 0
            if i + 1 >= argc
                print_err("--scan-loop needs iters")
                return 2
            mode = 3
            n_arg = parse_int_arg(*(argv + i + 1))
            i += 2
        else if arg_eq(arg, "--no-encryption") != 0
            # Accepted for parity with wiki-seed; this binary never uses
            # encryption.  Allows the same flags through bash harnesses.
            i += 1
        else
            prints("Unknown argument: ")
            prints_cstr(arg)
            prints("\n")
            return 2

    if mode == 0
        prints("Usage: concurrent_bench --port P [--bulk-insert N | --ping-loop N | --scan-loop N]\n")
        return 2

    var client: *Client = client_new()
    if client == null
        print_err("client_new returned null")
        return 1

    let connect_rc: i32 = client_connect(client, "127.0.0.1", port, "wiki_pages", 10)
    if connect_rc < 0
        print_err("client_connect failed")
        prints("  rc=")
        print_i32(connect_rc)
        prints("\n")
        client_free(client)
        return 1

    var rc: i32 = 0
    if mode == 1
        rc = cmd_bulk_insert(client, n_arg)
    else if mode == 2
        rc = cmd_ping_loop(client, n_arg)
    else if mode == 3
        rc = cmd_scan_loop(client, n_arg)

    client_disconnect(client)
    client_free(client)
    return rc
