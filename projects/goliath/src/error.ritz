# Goliath Error Types
#
# All error types for the Goliath filesystem.

import ritzlib.sys { write }

# Error codes for Goliath operations (as constants since ritz enums are ADTs)
pub const ERR_OK: i32 = 0
pub const ERR_NOT_FOUND: i32 = 1
pub const ERR_ALREADY_EXISTS: i32 = 2
pub const ERR_INVALID_PATH: i32 = 3
pub const ERR_INVALID_BLOB_ID: i32 = 4
pub const ERR_CORRUPT_BLOB: i32 = 5
pub const ERR_IO_ERROR: i32 = 6
pub const ERR_OUT_OF_SPACE: i32 = 7
pub const ERR_NOT_A_DIRECTORY: i32 = 8
pub const ERR_NOT_A_FILE: i32 = 9
pub const ERR_DIRECTORY_NOT_EMPTY: i32 = 10
pub const ERR_PERMISSION_DENIED: i32 = 11
pub const ERR_PATH_TOO_LONG: i32 = 12

# Type alias for error code
pub type ErrorCode = i32

# Filesystem error with context
pub struct Error
    code: ErrorCode
    # TODO: Add message when String is available

pub fn error_new(code: ErrorCode) -> Error
    Error { code: code }

pub fn error_code(err: Error) -> ErrorCode
    err.code

pub fn error_is_not_found(err: Error) -> bool
    err.code == ERR_NOT_FOUND

pub fn error_is_exists(err: Error) -> bool
    err.code == ERR_ALREADY_EXISTS
