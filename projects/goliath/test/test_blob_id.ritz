# Tests for BlobId
#
# Tests content addressing fundamentals.

import blob_id { BlobId, BLOB_ID_SIZE, blob_id_zero, blob_id_empty, blob_id_from_hash, blob_id_eq, blob_id_is_zero, blob_id_compute, blob_id_bytes, blob_id_copy }

# Test: Zero BlobId is all zeros
[[test]]
fn test_blob_id_zero_is_zeros() -> i32
    let zero: BlobId = blob_id_zero()

    var i: i32 = 0
    while i < 32
        if zero.hash[i] != 0
            return 1
        i = i + 1

    0

# Test: Zero BlobId is detected by is_zero
[[test]]
fn test_blob_id_is_zero() -> i32
    let zero: BlobId = blob_id_zero()
    if not blob_id_is_zero(@zero)
        return 1

    let empty: BlobId = blob_id_empty()
    if blob_id_is_zero(@empty)
        return 2  # Empty is NOT zero (it has a real hash)

    0

# Test: Empty content has known hash
[[test]]
fn test_blob_id_empty_known_hash() -> i32
    let empty: BlobId = blob_id_empty()

    # SHA-256 of empty string starts with e3b0c442...
    if empty.hash[0] != 0xe3
        return 1
    if empty.hash[1] != 0xb0
        return 2
    if empty.hash[2] != 0xc4
        return 3
    if empty.hash[3] != 0x42
        return 4

    0

# Test: Two zero BlobIds are equal
[[test]]
fn test_blob_id_eq_zero() -> i32
    let a: BlobId = blob_id_zero()
    let b: BlobId = blob_id_zero()

    if not blob_id_eq(@a, @b)
        return 1

    0

# Test: Two empty BlobIds are equal
[[test]]
fn test_blob_id_eq_empty() -> i32
    let a: BlobId = blob_id_empty()
    let b: BlobId = blob_id_empty()

    if not blob_id_eq(@a, @b)
        return 1

    0

# Test: Zero and empty are not equal
[[test]]
fn test_blob_id_zero_not_empty() -> i32
    let zero: BlobId = blob_id_zero()
    let empty: BlobId = blob_id_empty()

    if blob_id_eq(@zero, @empty)
        return 1

    0

# Test: Copy produces equal BlobId
[[test]]
fn test_blob_id_copy() -> i32
    let original: BlobId = blob_id_empty()
    let copy: BlobId = blob_id_copy(@original)

    if not blob_id_eq(@original, @copy)
        return 1

    0

# Test: from_hash correctly copies bytes
[[test]]
fn test_blob_id_from_hash() -> i32
    var hash: [32]u8
    var i: i32 = 0
    while i < 32
        hash[i] = i as u8
        i = i + 1

    let id: BlobId = blob_id_from_hash(@hash[0])

    i = 0
    while i < 32
        if id.hash[i] != i as u8
            return 1
        i = i + 1

    0

# Test: Compute returns empty hash for empty input
[[test]]
fn test_blob_id_compute_empty() -> i32
    let id: BlobId = blob_id_compute(0 as *u8, 0)
    let expected: BlobId = blob_id_empty()

    if not blob_id_eq(@id, @expected)
        return 1

    0
