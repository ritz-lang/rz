# Test Main - Entry point for test binary
#
# Simple test harness that runs all tests directly.
# (ritzunit integration is currently broken due to import path issues)

import ritzlib.sys { write, exit }
import ritzlib.strview { StrView, strview_as_ptr, strview_len }

# Import all test functions
import test_blob_id { test_blob_id_zero_is_zeros, test_blob_id_is_zero, test_blob_id_empty_known_hash, test_blob_id_eq_zero, test_blob_id_eq_empty, test_blob_id_zero_not_empty, test_blob_id_copy, test_blob_id_from_hash, test_blob_id_compute_empty }
import test_blob_store { test_store_new_empty, test_store_put_returns_id, test_store_get_retrieves, test_store_exists, test_store_delete, test_store_count, test_store_dedup }
import test_namespace { test_namespace_new_has_root, test_namespace_root_exists, test_namespace_nonexistent, test_namespace_write_read, test_namespace_mkdir, test_namespace_mkdir_exists, test_namespace_list_root, test_namespace_file_size, test_namespace_invalid_path, test_namespace_write_root_rejected }
import test_path { test_path_is_absolute, test_path_is_root, test_path_len, test_path_skip_slashes, test_path_first_component, test_path_parent_len, test_path_basename_start, test_path_validate_component, test_path_validate }

fn puts(msg: StrView)
    write(1, strview_as_ptr(@msg), strview_len(@msg))

var g_passed: i32 = 0
var g_failed: i32 = 0

fn run_test(name: StrView, test_fn: fn() -> i32)
    let result: i32 = test_fn()
    if result == 0
        puts("  PASS: ")
        puts(name)
        puts("\n")
        g_passed = g_passed + 1
    else
        puts("  FAIL: ")
        puts(name)
        puts(" (returned ")
        # Simple int print - just show single digit for now
        var digit: u8 = (result % 10) as u8 + 48  # '0' = 48
        write(1, @digit as *u8, 1)
        puts(")\n")
        g_failed = g_failed + 1

pub fn main() -> i32
    puts("Goliath Test Suite\n")
    puts("==================\n\n")

    puts("BlobId tests:\n")
    run_test("test_blob_id_zero_is_zeros", test_blob_id_zero_is_zeros)
    run_test("test_blob_id_is_zero", test_blob_id_is_zero)
    run_test("test_blob_id_empty_known_hash", test_blob_id_empty_known_hash)
    run_test("test_blob_id_eq_zero", test_blob_id_eq_zero)
    run_test("test_blob_id_eq_empty", test_blob_id_eq_empty)
    run_test("test_blob_id_zero_not_empty", test_blob_id_zero_not_empty)
    run_test("test_blob_id_copy", test_blob_id_copy)
    run_test("test_blob_id_from_hash", test_blob_id_from_hash)
    run_test("test_blob_id_compute_empty", test_blob_id_compute_empty)

    puts("\nBlobStore tests:\n")
    run_test("test_store_new_empty", test_store_new_empty)
    run_test("test_store_put_returns_id", test_store_put_returns_id)
    run_test("test_store_get_retrieves", test_store_get_retrieves)
    run_test("test_store_exists", test_store_exists)
    run_test("test_store_delete", test_store_delete)
    run_test("test_store_count", test_store_count)
    run_test("test_store_dedup", test_store_dedup)

    puts("\nNamespace tests:\n")
    run_test("test_namespace_new_has_root", test_namespace_new_has_root)
    run_test("test_namespace_root_exists", test_namespace_root_exists)
    run_test("test_namespace_nonexistent", test_namespace_nonexistent)
    run_test("test_namespace_write_read", test_namespace_write_read)
    run_test("test_namespace_mkdir", test_namespace_mkdir)
    run_test("test_namespace_mkdir_exists", test_namespace_mkdir_exists)
    run_test("test_namespace_list_root", test_namespace_list_root)
    run_test("test_namespace_file_size", test_namespace_file_size)
    run_test("test_namespace_invalid_path", test_namespace_invalid_path)
    run_test("test_namespace_write_root_rejected", test_namespace_write_root_rejected)

    puts("\nPath tests:\n")
    run_test("test_path_is_absolute", test_path_is_absolute)
    run_test("test_path_is_root", test_path_is_root)
    run_test("test_path_len", test_path_len)
    run_test("test_path_skip_slashes", test_path_skip_slashes)
    run_test("test_path_first_component", test_path_first_component)
    run_test("test_path_parent_len", test_path_parent_len)
    run_test("test_path_basename_start", test_path_basename_start)
    run_test("test_path_validate_component", test_path_validate_component)
    run_test("test_path_validate", test_path_validate)

    puts("\n==================\n")
    puts("Results: ")
    # Simple int output
    var p_tens: u8 = ((g_passed / 10) % 10) as u8 + 48
    var p_ones: u8 = (g_passed % 10) as u8 + 48
    if g_passed >= 10
        write(1, @p_tens as *u8, 1)
    write(1, @p_ones as *u8, 1)
    puts(" passed, ")
    var f_tens: u8 = ((g_failed / 10) % 10) as u8 + 48
    var f_ones: u8 = (g_failed % 10) as u8 + 48
    if g_failed >= 10
        write(1, @f_tens as *u8, 1)
    write(1, @f_ones as *u8, 1)
    puts(" failed\n")

    if g_failed > 0
        return 1
    0
