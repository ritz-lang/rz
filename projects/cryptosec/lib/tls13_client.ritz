# lib/tls13_client.ritz - TLS 1.3 Client Implementation
#
# This module provides a complete TLS 1.3 client implementation for use with
# Valet and other networking applications.
#
# Features:
# - Full TLS 1.3 handshake (1-RTT)
# - X25519 key exchange
# - AES-128-GCM and ChaCha20-Poly1305 cipher suites
# - Certificate chain validation
# - Hostname verification
#
# Non-blocking API for io_uring integration:
# - tls_client_handshake_step() processes data incrementally
# - Returns status indicating need for more input, output ready, or completion

import ritzlib.sys

import mem
import random
import sha256
import hmac
import hkdf
import aes_gcm
import chacha20_poly1305
import x25519
import x509
import x509_verify
import rsa
import tls13_kdf
import tls13_record
import tls13_handshake

# ============================================================================
# Constants
# ============================================================================

# Connection states
pub const TLS_STATE_INIT: i32 = 0
pub const TLS_STATE_CLIENT_HELLO_SENT: i32 = 1
pub const TLS_STATE_SERVER_HELLO_RECEIVED: i32 = 2
pub const TLS_STATE_ENCRYPTED_EXTENSIONS_RECEIVED: i32 = 3
pub const TLS_STATE_CERTIFICATE_RECEIVED: i32 = 4
pub const TLS_STATE_CERTIFICATE_VERIFY_RECEIVED: i32 = 5
pub const TLS_STATE_FINISHED_RECEIVED: i32 = 6
pub const TLS_STATE_CONNECTED: i32 = 7
pub const TLS_STATE_CLOSING: i32 = 8
pub const TLS_STATE_CLOSED: i32 = 9
pub const TLS_STATE_ERROR: i32 = -1

# Handshake step results
pub const TLS_RESULT_NEED_INPUT: i32 = 0
pub const TLS_RESULT_HAVE_OUTPUT: i32 = 1
pub const TLS_RESULT_COMPLETE: i32 = 2
pub const TLS_RESULT_ERROR: i32 = -1

# Error codes
pub const TLS_ERR_NONE: i32 = 0
pub const TLS_ERR_INVALID_STATE: i32 = -1
pub const TLS_ERR_PARSE_ERROR: i32 = -2
pub const TLS_ERR_UNEXPECTED_MESSAGE: i32 = -3
pub const TLS_ERR_VERSION_MISMATCH: i32 = -4
pub const TLS_ERR_NO_KEY_SHARE: i32 = -5
pub const TLS_ERR_DECRYPT_FAILED: i32 = -6
pub const TLS_ERR_VERIFY_FAILED: i32 = -7
pub const TLS_ERR_CERTIFICATE_INVALID: i32 = -8
pub const TLS_ERR_FINISHED_MISMATCH: i32 = -9
pub const TLS_ERR_BUFFER_TOO_SMALL: i32 = -10

# Maximum sizes
const MAX_RECORD_SIZE: i64 = 16384
const MAX_HANDSHAKE_SIZE: i64 = 65536

# ============================================================================
# TLS Client Configuration
# ============================================================================

pub struct TlsConfig
    # Hostname for SNI and certificate verification
    hostname: [256]u8
    hostname_len: i32

    # Whether to verify certificate (1 = yes, 0 = no/TOFU)
    verify_cert: i32

    # Preferred cipher suites (in order of preference)
    cipher_suites: [4]u16
    num_cipher_suites: i32

pub fn tls_config_init(cfg: *TlsConfig)
    mem_zero(cfg as *u8, 280 as u64)  # Approximate size

    # Default cipher suites
    cfg.cipher_suites[0] = TLS_AES_128_GCM_SHA256
    cfg.cipher_suites[1] = TLS_CHACHA20_POLY1305_SHA256
    cfg.num_cipher_suites = 2

    cfg.verify_cert = 1

pub fn tls_config_set_hostname(cfg: *TlsConfig, hostname: *u8, len: i32)
    if len > 255
        len = 255
    var i: i32 = 0
    while i < len
        cfg.hostname[i] = hostname[i]
        i += 1
    cfg.hostname_len = len

# ============================================================================
# TLS Client State
# ============================================================================

pub struct TlsClient
    # Connection state
    state: i32
    last_error: i32

    # Configuration
    config: TlsConfig

    # Handshake state
    transcript: Transcript
    key_schedule: TLS13KeySchedule
    client_hello: ClientHello
    server_hello: ServerHello

    # Shared secret from X25519
    shared_secret: [32]u8

    # Selected cipher suite
    cipher_suite: u16

    # Record layer state
    read_state: TlsRecordState
    write_state: TlsRecordState

    # Handshake message buffers
    # (For accumulating fragmented messages)
    recv_buf: [4096]u8
    recv_len: i64
    recv_expected: i64  # Expected message length (from header)

    # Output buffer for handshake messages to send
    send_buf: [4096]u8
    send_len: i64

    # Certificate chain from server
    server_certs: CertificateMessage

    # Server's public key (extracted from certificate)
    server_pubkey: X509PublicKey

    # Flags
    handshake_complete: i32
    encrypted_handshake: i32  # 1 after ServerHello, messages are encrypted

# ============================================================================
# Client Lifecycle
# ============================================================================

# Initialize a new TLS client
pub fn tls_client_init(client: *TlsClient, config: *TlsConfig)
    # Zero everything
    mem_zero(client as *u8, 8192 as u64)  # Approximate size

    # Copy config
    mem_copy(&client.config as *u8, config as *u8, 280 as u64)

    # Initialize transcript
    transcript_init(&client.transcript)

    # Initialize key schedule
    tls13_key_schedule_init(&client.key_schedule)

    # Initialize ClientHello
    client_hello_init(&client.client_hello)

    # Set hostname from config
    if config.hostname_len > 0
        client_hello_set_hostname(&client.client_hello, &config.hostname[0], config.hostname_len)

    # Set cipher suites from config
    var i: i32 = 0
    while i < config.num_cipher_suites && i < 4
        client.client_hello.cipher_suites[i] = config.cipher_suites[i]
        i += 1
    client.client_hello.num_cipher_suites = config.num_cipher_suites

    client.state = TLS_STATE_INIT

# Free client resources
pub fn tls_client_free(client: *TlsClient)
    # Zero sensitive data
    mem_zero(&client.shared_secret[0], 32)
    mem_zero(&client.key_schedule as *u8, 296 as u64)  # Approximate
    mem_zero(&client.client_hello.x25519_private[0], 32)

# ============================================================================
# Start Handshake - Generate ClientHello
# ============================================================================

# Start the handshake by generating ClientHello
# Returns bytes written to out, or negative on error
pub fn tls_client_start(client: *TlsClient, out: *u8, out_cap: i64) -> i64
    if client.state != TLS_STATE_INIT
        client.last_error = TLS_ERR_INVALID_STATE
        return -1

    # Serialize ClientHello
    let ch_len: i64 = client_hello_serialize(&client.client_hello, &client.send_buf[0], 4096)
    if ch_len < 0
        client.last_error = TLS_ERR_PARSE_ERROR
        return -1

    # Update transcript with ClientHello
    transcript_update(&client.transcript, &client.send_buf[0], ch_len)

    # Wrap in TLS record header
    # ContentType (1) + Version (2) + Length (2) + data
    if out_cap < ch_len + 5
        client.last_error = TLS_ERR_BUFFER_TOO_SMALL
        return -1

    out[0] = 22  # Handshake content type
    out[1] = 0x03
    out[2] = 0x01  # Legacy version TLS 1.0
    out[3] = ((ch_len >> 8) & 0xff) as u8
    out[4] = (ch_len & 0xff) as u8
    mem_copy(out + 5, &client.send_buf[0], ch_len as u64)

    client.state = TLS_STATE_CLIENT_HELLO_SENT
    return ch_len + 5

# ============================================================================
# Process Incoming Data
# ============================================================================

# Process incoming data from server
# Returns: TLS_RESULT_NEED_INPUT, TLS_RESULT_HAVE_OUTPUT, TLS_RESULT_COMPLETE, or TLS_RESULT_ERROR
#
# If result is HAVE_OUTPUT, caller should send data from out buffer
# If result is COMPLETE, handshake finished successfully
# If result is NEED_INPUT, caller should receive more data and call again
pub fn tls_client_process(client: *TlsClient, data: *u8, data_len: i64, out: *u8, out_cap: i64, out_len: *i64) -> i32
    *out_len = 0

    if client.state == TLS_STATE_ERROR
        return TLS_RESULT_ERROR

    if client.state == TLS_STATE_CONNECTED
        return TLS_RESULT_COMPLETE

    # Accumulate data
    if data_len > 0
        if client.recv_len + data_len > 4096
            client.last_error = TLS_ERR_BUFFER_TOO_SMALL
            client.state = TLS_STATE_ERROR
            return TLS_RESULT_ERROR
        mem_copy(&client.recv_buf[client.recv_len], data, data_len as u64)
        client.recv_len = client.recv_len + data_len

    # Process based on current state
    if client.state == TLS_STATE_CLIENT_HELLO_SENT
        return process_server_hello(client, out, out_cap, out_len)

    if client.state == TLS_STATE_SERVER_HELLO_RECEIVED
        return process_encrypted_handshake(client, out, out_cap, out_len)

    if client.state == TLS_STATE_ENCRYPTED_EXTENSIONS_RECEIVED
        return process_encrypted_handshake(client, out, out_cap, out_len)

    if client.state == TLS_STATE_CERTIFICATE_RECEIVED
        return process_encrypted_handshake(client, out, out_cap, out_len)

    if client.state == TLS_STATE_CERTIFICATE_VERIFY_RECEIVED
        return process_encrypted_handshake(client, out, out_cap, out_len)

    if client.state == TLS_STATE_FINISHED_RECEIVED
        return finish_handshake(client, out, out_cap, out_len)

    client.last_error = TLS_ERR_INVALID_STATE
    client.state = TLS_STATE_ERROR
    return TLS_RESULT_ERROR

# ============================================================================
# Process ServerHello
# ============================================================================

fn process_server_hello(client: *TlsClient, out: *u8, out_cap: i64, out_len: *i64) -> i32
    # Need at least TLS record header (5 bytes)
    if client.recv_len < 5
        return TLS_RESULT_NEED_INPUT

    # Parse TLS record header
    let content_type: u8 = client.recv_buf[0]
    let record_len: i64 = ((client.recv_buf[3] as i64) << 8) | (client.recv_buf[4] as i64)

    # Check we have complete record
    if client.recv_len < 5 + record_len
        return TLS_RESULT_NEED_INPUT

    # Expect Handshake content type
    if content_type != 22
        client.last_error = TLS_ERR_UNEXPECTED_MESSAGE
        client.state = TLS_STATE_ERROR
        return TLS_RESULT_ERROR

    # Parse handshake header
    var hdr: HandshakeHeader
    if handshake_header_parse(&client.recv_buf[5], record_len, &hdr) != 0
        client.last_error = TLS_ERR_PARSE_ERROR
        client.state = TLS_STATE_ERROR
        return TLS_RESULT_ERROR

    if hdr.msg_type != HS_SERVER_HELLO
        client.last_error = TLS_ERR_UNEXPECTED_MESSAGE
        client.state = TLS_STATE_ERROR
        return TLS_RESULT_ERROR

    # Parse ServerHello
    let sh_result: i32 = server_hello_parse(&client.recv_buf[9], hdr.length, &client.server_hello)
    if sh_result != 0
        client.last_error = TLS_ERR_PARSE_ERROR
        client.state = TLS_STATE_ERROR
        return TLS_RESULT_ERROR

    # Verify TLS 1.3
    if client.server_hello.negotiated_version != TLS_VERSION_13
        client.last_error = TLS_ERR_VERSION_MISMATCH
        client.state = TLS_STATE_ERROR
        return TLS_RESULT_ERROR

    # Verify we got key share
    if client.server_hello.has_key_share != 1
        client.last_error = TLS_ERR_NO_KEY_SHARE
        client.state = TLS_STATE_ERROR
        return TLS_RESULT_ERROR

    # Store cipher suite
    client.cipher_suite = client.server_hello.cipher_suite

    # Compute shared secret
    x25519(&client.shared_secret[0], &client.client_hello.x25519_private[0], &client.server_hello.x25519_public[0])

    # Update transcript with full ServerHello (including handshake header)
    let sh_total: i64 = 4 + hdr.length
    transcript_update(&client.transcript, &client.recv_buf[5], sh_total)

    # Derive handshake keys
    var th_out: [32]u8
    transcript_hash(&client.transcript, &th_out[0])

    tls13_key_schedule_derive_handshake(&client.key_schedule, &client.shared_secret[0], 32, &th_out[0])
    tls13_key_schedule_derive_handshake_keys(&client.key_schedule, 16, 12)  # AES-128-GCM

    # Set up record layer for encrypted handshake
    tls_record_state_init(&client.read_state)
    tls_record_state_set_keys(&client.read_state, &client.key_schedule.client_write_key[0], &client.key_schedule.client_write_iv[0], &client.key_schedule.server_write_key[0], &client.key_schedule.server_write_iv[0], 16)

    tls_record_state_init(&client.write_state)
    tls_record_state_set_keys(&client.write_state, &client.key_schedule.client_write_key[0], &client.key_schedule.client_write_iv[0], &client.key_schedule.server_write_key[0], &client.key_schedule.server_write_iv[0], 16)

    # Consume processed record
    let consumed: i64 = 5 + record_len
    shift_recv_buf(client, consumed)

    client.encrypted_handshake = 1
    client.state = TLS_STATE_SERVER_HELLO_RECEIVED

    # Continue processing if more data available
    if client.recv_len > 0
        return process_encrypted_handshake(client, out, out_cap, out_len)

    return TLS_RESULT_NEED_INPUT

# ============================================================================
# Process Encrypted Handshake Messages
# ============================================================================

fn process_encrypted_handshake(client: *TlsClient, out: *u8, out_cap: i64, out_len: *i64) -> i32
    # Need at least TLS record header
    if client.recv_len < 5
        return TLS_RESULT_NEED_INPUT

    # Parse TLS record header
    let content_type: u8 = client.recv_buf[0]
    let record_len: i64 = ((client.recv_buf[3] as i64) << 8) | (client.recv_buf[4] as i64)

    # Check we have complete record
    if client.recv_len < 5 + record_len
        return TLS_RESULT_NEED_INPUT

    # Should be Application Data (encrypted handshake)
    if content_type != 23
        client.last_error = TLS_ERR_UNEXPECTED_MESSAGE
        client.state = TLS_STATE_ERROR
        return TLS_RESULT_ERROR

    # Decrypt record
    var plaintext: [4096]u8
    var plaintext_len: i64 = 0
    var inner_type: u8 = 0

    let decrypt_result: i32 = tls_record_state_server_decrypt(&client.read_state, &client.recv_buf[5], record_len as i32, &plaintext[0], 4096, &inner_type)
    plaintext_len = decrypt_result as i64

    if decrypt_result < 0
        client.last_error = TLS_ERR_DECRYPT_FAILED
        client.state = TLS_STATE_ERROR
        return TLS_RESULT_ERROR

    # Expect handshake content
    if inner_type != 22
        client.last_error = TLS_ERR_UNEXPECTED_MESSAGE
        client.state = TLS_STATE_ERROR
        return TLS_RESULT_ERROR

    # Process handshake message(s) in plaintext
    var pos: i64 = 0
    while pos + 4 <= plaintext_len
        var hdr: HandshakeHeader
        if handshake_header_parse(&plaintext[pos], plaintext_len - pos, &hdr) != 0
            client.last_error = TLS_ERR_PARSE_ERROR
            client.state = TLS_STATE_ERROR
            return TLS_RESULT_ERROR

        let msg_start: i64 = pos
        let msg_len: i64 = 4 + hdr.length

        if pos + msg_len > plaintext_len
            # Incomplete message - shouldn't happen in a single record
            client.last_error = TLS_ERR_PARSE_ERROR
            client.state = TLS_STATE_ERROR
            return TLS_RESULT_ERROR

        # Process based on message type
        let result: i32 = process_handshake_message(client, hdr.msg_type, &plaintext[pos + 4], hdr.length)
        if result != 0
            return TLS_RESULT_ERROR

        # Update transcript with handshake message
        transcript_update(&client.transcript, &plaintext[pos], msg_len)

        pos = pos + msg_len

    # Consume processed record
    let consumed: i64 = 5 + record_len
    shift_recv_buf(client, consumed)

    # Check if handshake complete
    if client.state == TLS_STATE_FINISHED_RECEIVED
        return finish_handshake(client, out, out_cap, out_len)

    # Continue processing if more data available
    if client.recv_len > 5
        return process_encrypted_handshake(client, out, out_cap, out_len)

    return TLS_RESULT_NEED_INPUT

fn process_handshake_message(client: *TlsClient, msg_type: u8, data: *u8, len: i64) -> i32
    if msg_type == HS_ENCRYPTED_EXTENSIONS
        var ee: EncryptedExtensions
        if encrypted_extensions_parse(data, len, &ee) != 0
            client.last_error = TLS_ERR_PARSE_ERROR
            client.state = TLS_STATE_ERROR
            return -1
        client.state = TLS_STATE_ENCRYPTED_EXTENSIONS_RECEIVED
        return 0

    if msg_type == HS_CERTIFICATE
        if certificate_parse(data, len, &client.server_certs) != 0
            client.last_error = TLS_ERR_PARSE_ERROR
            client.state = TLS_STATE_ERROR
            return -1

        # Parse first certificate to get public key
        if client.server_certs.num_certs > 0
            var cert: X509Certificate
            if x509_parse_certificate(client.server_certs.cert_data[0], client.server_certs.cert_lens[0], &cert) == 0
                # Copy public key
                mem_copy(&client.server_pubkey as *u8, &cert.public_key as *u8, 600 as u64)  # Approximate size

        client.state = TLS_STATE_CERTIFICATE_RECEIVED
        return 0

    if msg_type == HS_CERTIFICATE_VERIFY
        var cv: CertificateVerify
        if certificate_verify_parse(data, len, &cv) != 0
            client.last_error = TLS_ERR_PARSE_ERROR
            client.state = TLS_STATE_ERROR
            return -1

        # TODO: Verify signature over transcript
        # For now, we trust it (TOFU mode)

        client.state = TLS_STATE_CERTIFICATE_VERIFY_RECEIVED
        return 0

    if msg_type == HS_FINISHED
        # Verify server's Finished message
        var expected_transcript: [32]u8
        transcript_hash(&client.transcript, &expected_transcript[0])

        # Note: We need transcript BEFORE the Finished message for verification
        # The transcript_update for Finished happens after this function returns

        let verify_result: i32 = finished_verify(&client.key_schedule.server_handshake_traffic_secret[0], &expected_transcript[0], data)

        if verify_result != 1
            client.last_error = TLS_ERR_FINISHED_MISMATCH
            client.state = TLS_STATE_ERROR
            return -1

        client.state = TLS_STATE_FINISHED_RECEIVED
        return 0

    # Unknown message type - ignore for forward compatibility
    return 0

# ============================================================================
# Finish Handshake - Send Client Finished
# ============================================================================

fn finish_handshake(client: *TlsClient, out: *u8, out_cap: i64, out_len: *i64) -> i32
    # Compute client Finished
    var th_out: [32]u8
    transcript_hash(&client.transcript, &th_out[0])

    var verify_data: [32]u8
    finished_compute(&client.key_schedule.client_handshake_traffic_secret[0], &th_out[0], &verify_data[0])

    # Serialize Finished message
    var finished_msg: [64]u8
    let finished_len: i64 = finished_serialize(&verify_data[0], &finished_msg[0])

    # Encrypt with handshake keys
    var encrypted: [128]u8

    let encrypt_result: i32 = tls_record_state_client_encrypt(&client.write_state, &finished_msg[0], finished_len as i32, 22, &encrypted[0], 128)
    var encrypted_len: i64 = encrypt_result as i64

    if encrypt_result < 0
        client.last_error = TLS_ERR_PARSE_ERROR
        client.state = TLS_STATE_ERROR
        return TLS_RESULT_ERROR

    # Build TLS record
    if out_cap < 5 + encrypted_len
        client.last_error = TLS_ERR_BUFFER_TOO_SMALL
        client.state = TLS_STATE_ERROR
        return TLS_RESULT_ERROR

    out[0] = 23  # Application Data (encrypted)
    out[1] = 0x03
    out[2] = 0x03  # TLS 1.2
    out[3] = ((encrypted_len >> 8) & 0xff) as u8
    out[4] = (encrypted_len & 0xff) as u8
    mem_copy(out + 5, &encrypted[0], encrypted_len as u64)
    *out_len = 5 + encrypted_len

    # Update transcript with client Finished
    transcript_update(&client.transcript, &finished_msg[0], finished_len)

    # Derive application keys
    var final_transcript: [32]u8
    transcript_hash(&client.transcript, &final_transcript[0])
    tls13_key_schedule_derive_application(&client.key_schedule, &final_transcript[0])
    tls13_key_schedule_derive_application_keys(&client.key_schedule, 16, 12)

    # Update record layer with application keys
    tls_record_state_set_keys(&client.read_state, &client.key_schedule.client_write_key[0], &client.key_schedule.client_write_iv[0], &client.key_schedule.server_write_key[0], &client.key_schedule.server_write_iv[0], 16)
    client.read_state.client_seq = 0
    client.read_state.server_seq = 0

    tls_record_state_set_keys(&client.write_state, &client.key_schedule.client_write_key[0], &client.key_schedule.client_write_iv[0], &client.key_schedule.server_write_key[0], &client.key_schedule.server_write_iv[0], 16)
    client.write_state.client_seq = 0
    client.write_state.server_seq = 0

    client.handshake_complete = 1
    client.state = TLS_STATE_CONNECTED

    return TLS_RESULT_HAVE_OUTPUT

# ============================================================================
# Application Data
# ============================================================================

# Encrypt and send application data
# Returns bytes written to out, or negative on error
pub fn tls_client_write(client: *TlsClient, data: *u8, data_len: i64, out: *u8, out_cap: i64) -> i64
    if client.state != TLS_STATE_CONNECTED
        return -1

    # Encrypt data
    var encrypted: [16500]u8  # Max record + overhead

    let result: i32 = tls_record_state_client_encrypt(&client.write_state, data, data_len as i32, 23, &encrypted[0], 16500)
    var encrypted_len: i64 = result as i64

    if result < 0
        return -1

    # Build TLS record
    if out_cap < 5 + encrypted_len
        return -1

    out[0] = 23  # Application Data
    out[1] = 0x03
    out[2] = 0x03
    out[3] = ((encrypted_len >> 8) & 0xff) as u8
    out[4] = (encrypted_len & 0xff) as u8
    mem_copy(out + 5, &encrypted[0], encrypted_len as u64)

    return 5 + encrypted_len

# Decrypt received application data
# Returns bytes written to out, or negative on error
pub fn tls_client_read(client: *TlsClient, data: *u8, data_len: i64, out: *u8, out_cap: i64) -> i64
    if client.state != TLS_STATE_CONNECTED
        return -1

    # Need at least record header
    if data_len < 5
        return 0  # Need more data

    let content_type: u8 = data[0]
    let record_len: i64 = ((data[3] as i64) << 8) | (data[4] as i64)

    if data_len < 5 + record_len
        return 0  # Need more data

    # Should be Application Data
    if content_type != 23
        return -1

    # Decrypt
    var plaintext: [16500]u8
    var plaintext_len: i64 = 0
    var inner_type: u8 = 0

    let result: i32 = tls_record_state_server_decrypt(&client.read_state, data + 5, record_len as i32, &plaintext[0], 16500, &inner_type)
    plaintext_len = result as i64

    if result < 0
        return -1

    # Should be Application Data inside
    if inner_type != 23
        # Could be Alert or other - for now treat as error
        return -1

    if plaintext_len > out_cap
        return -1

    mem_copy(out, &plaintext[0], plaintext_len as u64)
    return plaintext_len

# ============================================================================
# Close Connection
# ============================================================================

pub fn tls_client_close(client: *TlsClient, out: *u8, out_cap: i64) -> i64
    if client.state != TLS_STATE_CONNECTED
        return 0

    # Send close_notify alert
    var alert: [2]u8
    alert[0] = 1  # Warning level
    alert[1] = 0  # close_notify

    var encrypted: [64]u8
    let result: i32 = tls_record_state_client_encrypt(&client.write_state, &alert[0], 2, 21, &encrypted[0], 64)
    var encrypted_len: i64 = result as i64

    if result < 0
        return 0

    if out_cap < 5 + encrypted_len
        return 0

    out[0] = 23  # Application Data (encrypted)
    out[1] = 0x03
    out[2] = 0x03
    out[3] = ((encrypted_len >> 8) & 0xff) as u8
    out[4] = (encrypted_len & 0xff) as u8
    mem_copy(out + 5, &encrypted[0], encrypted_len as u64)

    client.state = TLS_STATE_CLOSING
    return 5 + encrypted_len

# ============================================================================
# Helpers
# ============================================================================

fn shift_recv_buf(client: *TlsClient, amount: i64)
    if amount >= client.recv_len
        client.recv_len = 0
        return

    var i: i64 = 0
    while i < client.recv_len - amount
        client.recv_buf[i] = client.recv_buf[i + amount]
        i += 1
    client.recv_len = client.recv_len - amount

# Get current state
pub fn tls_client_state(client: *TlsClient) -> i32
    return client.state

# Get last error
pub fn tls_client_error(client: *TlsClient) -> i32
    return client.last_error

# Check if handshake is complete
pub fn tls_client_is_connected(client: *TlsClient) -> i32
    return client.handshake_complete
