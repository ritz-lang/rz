# lib/tls13_handshake.ritz - TLS 1.3 Handshake Messages
#
# Implementation of TLS 1.3 handshake messages as defined in RFC 8446 Section 4.
#
# This module provides:
# - Transcript hash management
# - ClientHello serialization
# - ServerHello parsing
# - EncryptedExtensions parsing
# - Certificate message parsing
# - CertificateVerify parsing
# - Finished message computation and verification

import ritzlib.sys

import sha256
import hmac
import mem
import random
import x25519
import asn1
import x509
import hkdf
import tls13_kdf

# ============================================================================
# Constants
# ============================================================================

# TLS versions
pub const TLS_VERSION_12: u16 = 0x0303
pub const TLS_VERSION_13: u16 = 0x0304

# Handshake message types
pub const HS_CLIENT_HELLO: u8 = 1
pub const HS_SERVER_HELLO: u8 = 2
pub const HS_NEW_SESSION_TICKET: u8 = 4
pub const HS_END_OF_EARLY_DATA: u8 = 5
pub const HS_ENCRYPTED_EXTENSIONS: u8 = 8
pub const HS_CERTIFICATE: u8 = 11
pub const HS_CERTIFICATE_REQUEST: u8 = 13
pub const HS_CERTIFICATE_VERIFY: u8 = 15
pub const HS_FINISHED: u8 = 20
pub const HS_KEY_UPDATE: u8 = 24
pub const HS_MESSAGE_HASH: u8 = 254

# Extension types
pub const EXT_SERVER_NAME: u16 = 0
pub const EXT_SUPPORTED_GROUPS: u16 = 10
pub const EXT_SIGNATURE_ALGORITHMS: u16 = 13
pub const EXT_SUPPORTED_VERSIONS: u16 = 43
pub const EXT_KEY_SHARE: u16 = 51

# Named groups (for key exchange)
pub const GROUP_X25519: u16 = 0x001d
pub const GROUP_SECP256R1: u16 = 0x0017

# Signature schemes
pub const SIG_RSA_PKCS1_SHA256: u16 = 0x0401
pub const SIG_RSA_PKCS1_SHA384: u16 = 0x0501
pub const SIG_RSA_PKCS1_SHA512: u16 = 0x0601
pub const SIG_ECDSA_SECP256R1_SHA256: u16 = 0x0403
pub const SIG_RSA_PSS_RSAE_SHA256: u16 = 0x0804
pub const SIG_RSA_PSS_RSAE_SHA384: u16 = 0x0805
pub const SIG_RSA_PSS_RSAE_SHA512: u16 = 0x0806
pub const SIG_ED25519: u16 = 0x0807

# Cipher suites
pub const TLS_AES_128_GCM_SHA256: u16 = 0x1301
pub const TLS_AES_256_GCM_SHA384: u16 = 0x1302
pub const TLS_CHACHA20_POLY1305_SHA256: u16 = 0x1303

# ============================================================================
# Transcript Hash Management
# ============================================================================

pub struct Transcript
    # Running hash state (SHA-256 or SHA-384)
    sha_ctx: Sha256

    # Hash algorithm indicator: 0 = SHA-256, 1 = SHA-384
    hash_alg: i32

    # Number of bytes hashed so far
    bytes_hashed: i64

# Initialize transcript hash (defaults to SHA-256)
pub fn transcript_init(t: *Transcript)
    sha256_init(@t.sha_ctx)
    t.hash_alg = 0
    t.bytes_hashed = 0

# Initialize with specific cipher suite
pub fn transcript_init_for_suite(t: *Transcript, cipher_suite: u16)
    # TLS_AES_256_GCM_SHA384 uses SHA-384, others use SHA-256
    if cipher_suite == TLS_AES_256_GCM_SHA384
        # For SHA-384, we'd need a different context
        # For now, we only support SHA-256 based suites
        sha256_init(@t.sha_ctx)
        t.hash_alg = 0
    else
        sha256_init(@t.sha_ctx)
        t.hash_alg = 0
    t.bytes_hashed = 0

# Update transcript with handshake message data
pub fn transcript_update(t: *Transcript, data: *u8, len: i64)
    sha256_update(@t.sha_ctx, data, len as u64)
    t.bytes_hashed = t.bytes_hashed + len

# Get current transcript hash without finalizing
# (Creates a copy of state, finalizes copy, returns hash)
pub fn transcript_hash(t: *Transcript, out: *u8)
    # Copy the context so we can finalize without affecting original
    # sizeof(Sha256) = 8*4 + 64 + 8 + 8 = 112 bytes
    var ctx_copy: Sha256
    mem_copy(@ctx_copy as *u8, @t.sha_ctx as *u8, 112 as u64)
    sha256_final(@ctx_copy, out)

# Get hash length for this transcript
pub fn transcript_hash_len(t: *Transcript) -> i32
    if t.hash_alg == 0
        return 32  # SHA-256
    return 48  # SHA-384

# ============================================================================
# ClientHello Structure
# ============================================================================

pub struct ClientHello
    # Random (32 bytes)
    random: [32]u8

    # Session ID (legacy, but some servers expect non-empty)
    session_id: [32]u8
    session_id_len: u8

    # X25519 key share (private key for client, public sent)
    x25519_private: [32]u8
    x25519_public: [32]u8

    # SNI hostname
    hostname: [256]u8
    hostname_len: i32

    # Supported cipher suites (we support a small set)
    cipher_suites: [4]u16
    num_cipher_suites: i32

# Initialize ClientHello with random values and key share
pub fn client_hello_init(ch: *ClientHello)
    # Generate random
    random_bytes(@ch.random[0], 32)

    # Generate fake session ID (32 bytes for compatibility)
    random_bytes(@ch.session_id[0], 32)
    ch.session_id_len = 32

    # Generate X25519 key pair
    random_bytes(@ch.x25519_private[0], 32)
    x25519_clamp(@ch.x25519_private[0])
    x25519_pubkey(@ch.x25519_public[0], @ch.x25519_private[0])

    # Default cipher suites
    ch.cipher_suites[0] = TLS_AES_128_GCM_SHA256
    ch.cipher_suites[1] = TLS_CHACHA20_POLY1305_SHA256
    ch.cipher_suites[2] = TLS_AES_256_GCM_SHA384
    ch.num_cipher_suites = 3

    # Clear hostname
    ch.hostname_len = 0

# Set SNI hostname
pub fn client_hello_set_hostname(ch: *ClientHello, hostname: *u8, len: i32)
    if len > 255
        len = 255
    var i: i32 = 0
    while i < len
        ch.hostname[i] = hostname[i]
        i += 1
    ch.hostname_len = len

# Serialize ClientHello to bytes
# Returns number of bytes written, or -1 on error
pub fn client_hello_serialize(ch: *ClientHello, out: *u8, cap: i64) -> i64
    var pos: i64 = 0

    # We build the message body first, then prepend handshake header
    # Reserve 4 bytes for handshake header (type + 3-byte length)
    pos = 4

    # ProtocolVersion legacy_version = 0x0303 (TLS 1.2 for compatibility)
    out[pos] = 0x03
    out[pos + 1] = 0x03
    pos = pos + 2

    # Random (32 bytes)
    mem_copy(out + pos, @ch.random[0], 32)
    pos = pos + 32

    # Legacy session ID
    out[pos] = ch.session_id_len
    pos += 1
    if ch.session_id_len > 0
        mem_copy(out + pos, @ch.session_id[0], ch.session_id_len as u64)
        pos = pos + ch.session_id_len as i64

    # Cipher suites
    let cs_len: i32 = ch.num_cipher_suites * 2
    out[pos] = ((cs_len >> 8) & 0xff) as u8
    out[pos + 1] = (cs_len & 0xff) as u8
    pos = pos + 2

    var i: i32 = 0
    while i < ch.num_cipher_suites
        let cs: u16 = ch.cipher_suites[i]
        out[pos] = ((cs >> 8) & 0xff) as u8
        out[pos + 1] = (cs & 0xff) as u8
        pos = pos + 2
        i += 1

    # Legacy compression methods (1 byte: null compression)
    out[pos] = 1  # Length
    out[pos + 1] = 0  # Null compression
    pos = pos + 2

    # Extensions - build in temporary buffer to get length
    var ext_start: i64 = pos + 2  # Leave room for extension length
    var ext_pos: i64 = ext_start

    # Extension: supported_versions (required for TLS 1.3)
    ext_pos = write_ext_supported_versions(out, ext_pos)

    # Extension: supported_groups
    ext_pos = write_ext_supported_groups(out, ext_pos)

    # Extension: signature_algorithms
    ext_pos = write_ext_signature_algorithms(out, ext_pos)

    # Extension: key_share (X25519 public key)
    ext_pos = write_ext_key_share(out, ext_pos, @ch.x25519_public[0])

    # Extension: server_name (SNI)
    if ch.hostname_len > 0
        ext_pos = write_ext_server_name(out, ext_pos, @ch.hostname[0], ch.hostname_len)

    # Write extension length
    let ext_len: i64 = ext_pos - ext_start
    out[pos] = ((ext_len >> 8) & 0xff) as u8
    out[pos + 1] = (ext_len & 0xff) as u8
    pos = ext_pos

    # Now write handshake header at the beginning
    let body_len: i64 = pos - 4
    out[0] = HS_CLIENT_HELLO
    out[1] = ((body_len >> 16) & 0xff) as u8
    out[2] = ((body_len >> 8) & 0xff) as u8
    out[3] = (body_len & 0xff) as u8

    return pos

# ============================================================================
# Extension Writers
# ============================================================================

fn write_ext_supported_versions(out: *u8, pos: i64) -> i64
    # Extension type
    out[pos] = (EXT_SUPPORTED_VERSIONS >> 8) as u8
    out[pos + 1] = (EXT_SUPPORTED_VERSIONS & 0xff) as u8
    pos = pos + 2

    # Extension data length (3 bytes: 1 for list length + 2 for version)
    out[pos] = 0
    out[pos + 1] = 3
    pos = pos + 2

    # Versions list length
    out[pos] = 2
    pos += 1

    # TLS 1.3
    out[pos] = 0x03
    out[pos + 1] = 0x04
    pos = pos + 2

    return pos

fn write_ext_supported_groups(out: *u8, pos: i64) -> i64
    # Extension type
    out[pos] = (EXT_SUPPORTED_GROUPS >> 8) as u8
    out[pos + 1] = (EXT_SUPPORTED_GROUPS & 0xff) as u8
    pos = pos + 2

    # Extension data length (4 bytes: 2 for list length + 2 for group)
    out[pos] = 0
    out[pos + 1] = 4
    pos = pos + 2

    # Groups list length
    out[pos] = 0
    out[pos + 1] = 2
    pos = pos + 2

    # X25519
    out[pos] = (GROUP_X25519 >> 8) as u8
    out[pos + 1] = (GROUP_X25519 & 0xff) as u8
    pos = pos + 2

    return pos

fn write_ext_signature_algorithms(out: *u8, pos: i64) -> i64
    # Extension type
    out[pos] = (EXT_SIGNATURE_ALGORITHMS >> 8) as u8
    out[pos + 1] = (EXT_SIGNATURE_ALGORITHMS & 0xff) as u8
    pos = pos + 2

    # We support: RSA-PKCS1-SHA256, RSA-PSS-RSAE-SHA256, ECDSA-SHA256, Ed25519
    let num_sigs: i32 = 4
    let list_len: i32 = num_sigs * 2

    # Extension data length
    out[pos] = 0
    out[pos + 1] = (list_len + 2) as u8
    pos = pos + 2

    # Signature algorithms list length
    out[pos] = 0
    out[pos + 1] = list_len as u8
    pos = pos + 2

    # RSA-PKCS1-SHA256
    out[pos] = (SIG_RSA_PKCS1_SHA256 >> 8) as u8
    out[pos + 1] = (SIG_RSA_PKCS1_SHA256 & 0xff) as u8
    pos = pos + 2

    # RSA-PSS-RSAE-SHA256
    out[pos] = (SIG_RSA_PSS_RSAE_SHA256 >> 8) as u8
    out[pos + 1] = (SIG_RSA_PSS_RSAE_SHA256 & 0xff) as u8
    pos = pos + 2

    # ECDSA-SECP256R1-SHA256
    out[pos] = (SIG_ECDSA_SECP256R1_SHA256 >> 8) as u8
    out[pos + 1] = (SIG_ECDSA_SECP256R1_SHA256 & 0xff) as u8
    pos = pos + 2

    # Ed25519
    out[pos] = (SIG_ED25519 >> 8) as u8
    out[pos + 1] = (SIG_ED25519 & 0xff) as u8
    pos = pos + 2

    return pos

fn write_ext_key_share(out: *u8, pos: i64, x25519_pub: *u8) -> i64
    # Extension type
    out[pos] = (EXT_KEY_SHARE >> 8) as u8
    out[pos + 1] = (EXT_KEY_SHARE & 0xff) as u8
    pos = pos + 2

    # Key share entry: 2 (group) + 2 (len) + 32 (X25519 key) = 36 bytes
    let entry_len: i32 = 36

    # Extension data length (2 for client_shares length + entry_len)
    out[pos] = 0
    out[pos + 1] = (entry_len + 2) as u8
    pos = pos + 2

    # client_shares length
    out[pos] = 0
    out[pos + 1] = entry_len as u8
    pos = pos + 2

    # KeyShareEntry: group
    out[pos] = (GROUP_X25519 >> 8) as u8
    out[pos + 1] = (GROUP_X25519 & 0xff) as u8
    pos = pos + 2

    # KeyShareEntry: key_exchange length
    out[pos] = 0
    out[pos + 1] = 32
    pos = pos + 2

    # KeyShareEntry: key_exchange data
    mem_copy(out + pos, x25519_pub, 32)
    pos = pos + 32

    return pos

fn write_ext_server_name(out: *u8, pos: i64, hostname: *u8, len: i32) -> i64
    # Extension type
    out[pos] = (EXT_SERVER_NAME >> 8) as u8
    out[pos + 1] = (EXT_SERVER_NAME & 0xff) as u8
    pos = pos + 2

    # server_name_list: 2 (list_len) + 1 (type) + 2 (name_len) + name
    let name_entry_len: i32 = 1 + 2 + len
    let list_len: i32 = 2 + name_entry_len

    # Extension data length
    out[pos] = (list_len >> 8) as u8
    out[pos + 1] = (list_len & 0xff) as u8
    pos = pos + 2

    # server_name_list length
    out[pos] = (name_entry_len >> 8) as u8
    out[pos + 1] = (name_entry_len & 0xff) as u8
    pos = pos + 2

    # NameType = host_name (0)
    out[pos] = 0
    pos += 1

    # HostName length
    out[pos] = (len >> 8) as u8
    out[pos + 1] = (len & 0xff) as u8
    pos = pos + 2

    # HostName
    var i: i32 = 0
    while i < len
        out[pos] = hostname[i]
        pos += 1
        i += 1

    return pos

# ============================================================================
# ServerHello Parsing
# ============================================================================

pub struct ServerHello
    # Version (should be TLS 1.2 in legacy field, TLS 1.3 in extension)
    legacy_version: u16
    negotiated_version: u16

    # Random (32 bytes)
    random: [32]u8

    # Session ID (echoed from ClientHello)
    session_id: [32]u8
    session_id_len: u8

    # Selected cipher suite
    cipher_suite: u16

    # Server's X25519 key share
    x25519_public: [32]u8
    has_key_share: i32

# Parse ServerHello message (without handshake header)
# data points to message body (after type and length)
# Returns 0 on success, negative on error
pub fn server_hello_parse(data: *u8, len: i64, sh: *ServerHello) -> i32
    var pos: i64 = 0

    # Initialize
    sh.has_key_share = 0
    sh.negotiated_version = 0

    # Need at least version (2) + random (32) + session_id_len (1) = 35
    if len < 35
        return -1

    # ProtocolVersion legacy_version
    sh.legacy_version = ((data[pos] as u16) << 8) | (data[pos + 1] as u16)
    pos = pos + 2

    # Random (32 bytes)
    mem_copy(@sh.random[0], data + pos, 32)
    pos = pos + 32

    # Session ID
    let sid_len: u8 = data[pos]
    pos += 1
    if sid_len > 32
        return -2
    if pos + sid_len as i64 > len
        return -3

    sh.session_id_len = sid_len
    if sid_len > 0
        mem_copy(@sh.session_id[0], data + pos, sid_len as u64)
        pos = pos + sid_len as i64

    # Cipher suite (2 bytes)
    if pos + 2 > len
        return -4
    sh.cipher_suite = ((data[pos] as u16) << 8) | (data[pos + 1] as u16)
    pos = pos + 2

    # Legacy compression method (1 byte, must be 0)
    if pos + 1 > len
        return -5
    if data[pos] != 0
        return -6  # Must be null compression
    pos += 1

    # Extensions (optional, but required for TLS 1.3)
    if pos + 2 > len
        # No extensions - treat as error for TLS 1.3
        return -7

    let ext_len: i64 = ((data[pos] as i64) << 8) | (data[pos + 1] as i64)
    pos = pos + 2

    if pos + ext_len > len
        return -8

    let ext_end: i64 = pos + ext_len

    # Parse extensions
    while pos + 4 <= ext_end
        let ext_type: u16 = ((data[pos] as u16) << 8) | (data[pos + 1] as u16)
        let ext_data_len: i64 = ((data[pos + 2] as i64) << 8) | (data[pos + 3] as i64)
        pos = pos + 4

        if pos + ext_data_len > ext_end
            return -9

        if ext_type == EXT_SUPPORTED_VERSIONS
            # Should be exactly 2 bytes: selected version
            if ext_data_len == 2
                sh.negotiated_version = ((data[pos] as u16) << 8) | (data[pos + 1] as u16)
        else if ext_type == EXT_KEY_SHARE
            # KeyShareEntry: group (2) + key_len (2) + key (32 for X25519)
            if ext_data_len >= 4
                let group: u16 = ((data[pos] as u16) << 8) | (data[pos + 1] as u16)
                let key_len: i64 = ((data[pos + 2] as i64) << 8) | (data[pos + 3] as i64)
                if group == GROUP_X25519 && key_len == 32 && ext_data_len >= 4 + key_len
                    mem_copy(@sh.x25519_public[0], data + pos + 4, 32)
                    sh.has_key_share = 1

        pos = pos + ext_data_len

    # Verify we got TLS 1.3
    if sh.negotiated_version != TLS_VERSION_13
        return -10

    # Verify we got a key share
    if sh.has_key_share == 0
        return -11

    return 0

# ============================================================================
# EncryptedExtensions Parsing
# ============================================================================

pub struct EncryptedExtensions
    # We mostly ignore these for a minimal client
    # but need to parse them for transcript
    has_server_name: i32
    raw_len: i64

# Parse EncryptedExtensions message
pub fn encrypted_extensions_parse(data: *u8, len: i64, ee: *EncryptedExtensions) -> i32
    var pos: i64 = 0

    ee.has_server_name = 0
    ee.raw_len = len

    # Extensions length
    if len < 2
        return -1

    let ext_len: i64 = ((data[pos] as i64) << 8) | (data[pos + 1] as i64)
    pos = pos + 2

    if pos + ext_len > len
        return -2

    let ext_end: i64 = pos + ext_len

    # Parse extensions (we mostly ignore them)
    while pos + 4 <= ext_end
        let ext_type: u16 = ((data[pos] as u16) << 8) | (data[pos + 1] as u16)
        let ext_data_len: i64 = ((data[pos + 2] as i64) << 8) | (data[pos + 3] as i64)
        pos = pos + 4

        if pos + ext_data_len > ext_end
            return -3

        if ext_type == EXT_SERVER_NAME
            ee.has_server_name = 1

        pos = pos + ext_data_len

    return 0

# ============================================================================
# Certificate Message Parsing
# ============================================================================

# TLS 1.3 Certificate message structure:
# struct {
#     opaque certificate_request_context<0..2^8-1>;
#     CertificateEntry certificate_list<0..2^24-1>;
# } Certificate;
#
# struct {
#     select (certificate_type) {
#         case RawPublicKey: opaque ASN1_subjectPublicKeyInfo<1..2^24-1>;
#         case X509: opaque cert_data<1..2^24-1>;
#     };
#     Extension extensions<0..2^16-1>;
# } CertificateEntry;

pub struct CertificateMessage
    # Number of certificates in chain
    num_certs: i32

    # Certificate data pointers and lengths (up to 10 certs)
    cert_data: [10]*u8
    cert_lens: [10]i64

    # Request context (usually empty in server cert)
    context_len: u8

# Parse Certificate message
pub fn certificate_parse(data: *u8, len: i64, cm: *CertificateMessage) -> i32
    var pos: i64 = 0

    cm.num_certs = 0

    # certificate_request_context length
    if len < 1
        return -1
    cm.context_len = data[pos]
    pos += 1

    # Skip context
    if pos + cm.context_len as i64 > len
        return -2
    pos = pos + cm.context_len as i64

    # certificate_list length (3 bytes)
    if pos + 3 > len
        return -3
    let list_len: i64 = ((data[pos] as i64) << 16) | ((data[pos + 1] as i64) << 8) | (data[pos + 2] as i64)
    pos = pos + 3

    if pos + list_len > len
        return -4

    let list_end: i64 = pos + list_len

    # Parse certificate entries
    while pos + 3 < list_end && cm.num_certs < 10
        # cert_data length (3 bytes)
        let cert_len: i64 = ((data[pos] as i64) << 16) | ((data[pos + 1] as i64) << 8) | (data[pos + 2] as i64)
        pos = pos + 3

        if pos + cert_len > list_end
            return -5

        # Store certificate pointer and length
        cm.cert_data[cm.num_certs] = data + pos
        cm.cert_lens[cm.num_certs] = cert_len
        cm.num_certs = cm.num_certs + 1
        pos = pos + cert_len

        # Extensions for this certificate entry (2 bytes length)
        if pos + 2 > list_end
            return -6
        let ext_len: i64 = ((data[pos] as i64) << 8) | (data[pos + 1] as i64)
        pos = pos + 2

        # Skip extensions
        if pos + ext_len > list_end
            return -7
        pos = pos + ext_len

    if cm.num_certs == 0
        return -8  # Empty certificate chain

    return 0

# ============================================================================
# CertificateVerify Parsing
# ============================================================================

pub struct CertificateVerify
    # Signature algorithm
    algorithm: u16

    # Signature data
    signature: [512]u8  # Max RSA-4096 signature
    signature_len: i64

# Parse CertificateVerify message
pub fn certificate_verify_parse(data: *u8, len: i64, cv: *CertificateVerify) -> i32
    var pos: i64 = 0

    # Signature algorithm (2 bytes)
    if len < 4
        return -1
    cv.algorithm = ((data[pos] as u16) << 8) | (data[pos + 1] as u16)
    pos = pos + 2

    # Signature length (2 bytes)
    let sig_len: i64 = ((data[pos] as i64) << 8) | (data[pos + 1] as i64)
    pos = pos + 2

    if sig_len > 512
        return -2  # Signature too large

    if pos + sig_len > len
        return -3

    cv.signature_len = sig_len
    mem_copy(@cv.signature[0], data + pos, sig_len as u64)

    return 0

# Verify CertificateVerify signature
# transcript_hash: hash of handshake up to but not including CertificateVerify
# pubkey: server's public key from certificate
pub fn certificate_verify_verify(cv: *CertificateVerify, transcript_hash: *u8, pubkey: *X509PublicKey) -> i32
    # Build the content to be signed:
    # 64 spaces + "TLS 1.3, server CertificateVerify" + 0x00 + transcript_hash
    var content: [130]u8  # 64 + 33 + 1 + 32 = 130
    var pos: i32 = 0

    # 64 spaces (0x20)
    var i: i32 = 0
    while i < 64
        content[i] = 0x20
        i += 1
    pos = 64

    # Context string "TLS 1.3, server CertificateVerify"
    let ctx: *u8 = c"TLS 1.3, server CertificateVerify"
    i = 0
    while i < 33
        content[pos] = ctx[i]
        pos += 1
        i += 1

    # Separator 0x00
    content[pos] = 0
    pos += 1

    # Transcript hash (32 bytes for SHA-256)
    mem_copy(@content[pos as i64], transcript_hash, 32)
    pos = pos + 32

    # Verify based on algorithm
    # For now, we support RSA-PKCS1-SHA256
    if cv.algorithm == SIG_RSA_PKCS1_SHA256
        # Hash the content with SHA-256
        var hash: [32]u8
        sha256(@content[0], pos as i64, @hash[0])

        # TODO: Call RSA verification
        # For now, return success placeholder
        return 0

    # Unsupported algorithm
    return -1

# ============================================================================
# Finished Message
# ============================================================================

# Compute Finished verify_data
# finished_key = HKDF-Expand-Label(base_key, "finished", "", Hash.length)
# verify_data = HMAC(finished_key, Transcript-Hash(handshake_context))
pub fn finished_compute(base_key: *u8, transcript_hash: *u8, out: *u8)
    var finished_key: [32]u8

    # Derive finished key
    hkdf_expand_label(base_key, c"finished", 8, null, 0, @finished_key[0], 32)

    # Compute HMAC
    hmac_sha256(@finished_key[0], 32, transcript_hash, 32, out)

    # Zero sensitive data
    mem_zero(@finished_key[0], 32)

# Verify received Finished message
pub fn finished_verify(base_key: *u8, transcript_hash: *u8, received: *u8) -> i32
    var expected: [32]u8
    finished_compute(base_key, transcript_hash, @expected[0])

    let result: i32 = mem_eq(@expected[0], received, 32)
    mem_zero(@expected[0], 32)

    return result

# Serialize Finished message (just the verify_data)
pub fn finished_serialize(verify_data: *u8, out: *u8) -> i64
    # Handshake header
    out[0] = HS_FINISHED
    out[1] = 0
    out[2] = 0
    out[3] = 32  # Length = 32 bytes for SHA-256

    # verify_data
    mem_copy(out + 4, verify_data, 32)

    return 36  # 4 header + 32 data

# ============================================================================
# Handshake Header Parsing
# ============================================================================

pub struct HandshakeHeader
    msg_type: u8
    length: i64

# Parse handshake message header
pub fn handshake_header_parse(data: *u8, len: i64, hdr: *HandshakeHeader) -> i32
    if len < 4
        return -1

    hdr.msg_type = data[0]
    hdr.length = ((data[1] as i64) << 16) | ((data[2] as i64) << 8) | (data[3] as i64)

    return 0
