# lib/tls13_record.ritz - TLS 1.3 Record Layer
#
# RFC 8446 Section 5 - Record Protocol

import ritzlib.sys

import aes_gcm
import mem

# ============================================================================
# Constants
# ============================================================================

# Content types
pub const TLS_CONTENT_CHANGE_CIPHER_SPEC: u8 = 20
pub const TLS_CONTENT_ALERT: u8 = 21
pub const TLS_CONTENT_HANDSHAKE: u8 = 22
pub const TLS_CONTENT_APPLICATION: u8 = 23

# Record layer constants
const TLS_RECORD_HEADER_LEN: i32 = 5
const TLS_AES_GCM_TAG_LEN: i32 = 16

# ============================================================================
# Nonce Construction
# ============================================================================

pub fn tls13_compute_nonce(iv: *u8, seq: u64, nonce: *u8)
    var i: i32 = 0
    while i < 12
        nonce[i] = iv[i]
        i += 1

    nonce[4] = nonce[4] ^ ((seq >> 56) & 0xff) as u8
    nonce[5] = nonce[5] ^ ((seq >> 48) & 0xff) as u8
    nonce[6] = nonce[6] ^ ((seq >> 40) & 0xff) as u8
    nonce[7] = nonce[7] ^ ((seq >> 32) & 0xff) as u8
    nonce[8] = nonce[8] ^ ((seq >> 24) & 0xff) as u8
    nonce[9] = nonce[9] ^ ((seq >> 16) & 0xff) as u8
    nonce[10] = nonce[10] ^ ((seq >> 8) & 0xff) as u8
    nonce[11] = nonce[11] ^ (seq & 0xff) as u8

# ============================================================================
# Additional Authenticated Data (AAD)
# ============================================================================

pub fn tls13_build_aad(ciphertext_len: i32, aad: *u8)
    aad[0] = TLS_CONTENT_APPLICATION
    aad[1] = 0x03
    aad[2] = 0x03
    aad[3] = ((ciphertext_len >> 8) & 0xff) as u8
    aad[4] = (ciphertext_len & 0xff) as u8

# ============================================================================
# Inner Plaintext Construction
# ============================================================================

pub fn tls13_build_inner_plaintext(content: *u8, content_len: i32, content_type: u8, out: *u8, out_cap: i32) -> i32
    let min_len: i32 = content_len + 1
    if min_len > out_cap
        return -1
    mem_copy(out, content, content_len as u64)
    out[content_len] = content_type
    return min_len

pub fn tls13_parse_inner_plaintext(inner: *u8, inner_len: i32, content_type: *u8) -> i32
    var i: i32 = inner_len - 1
    while i >= 0
        let b: u8 = inner[i]
        if b != 0
            *content_type = b
            return i
        i -= 1
    *content_type = 0
    return -1

# ============================================================================
# Record Encryption
# ============================================================================

pub fn tls13_record_encrypt(key: *u8, key_len: i32, iv: *u8, seq: u64, plaintext: *u8, plaintext_len: i32, content_type: u8, out: *u8, out_cap: i32) -> i32
    var inner: [1024]u8
    let inner_len: i32 = tls13_build_inner_plaintext(plaintext, plaintext_len, content_type, &inner[0], 1024)
    if inner_len < 0
        return -1

    let ciphertext_len: i32 = inner_len + TLS_AES_GCM_TAG_LEN
    let record_len: i32 = TLS_RECORD_HEADER_LEN + ciphertext_len
    if record_len > out_cap
        return -2

    out[0] = TLS_CONTENT_APPLICATION
    out[1] = 0x03
    out[2] = 0x03
    out[3] = ((ciphertext_len >> 8) & 0xff) as u8
    out[4] = (ciphertext_len & 0xff) as u8

    var aad: [5]u8
    aad[0] = out[0]
    aad[1] = out[1]
    aad[2] = out[2]
    aad[3] = out[3]
    aad[4] = out[4]

    var nonce: [12]u8
    tls13_compute_nonce(iv, seq, &nonce[0])

    var ctx: AesGcm128
    if key_len == 16
        aes128_gcm_init(&ctx, key)
    else
        return -3

    var tag: [16]u8
    aes128_gcm_encrypt(&ctx, &nonce[0], 12, &aad[0], 5, &inner[0], inner_len as u64, &out[TLS_RECORD_HEADER_LEN], &tag[0])
    mem_copy(&out[TLS_RECORD_HEADER_LEN + inner_len], &tag[0], 16)

    mem_zero(&inner[0], inner_len as u64)
    mem_zero(&nonce[0], 12)

    return record_len

# ============================================================================
# Record Decryption
# ============================================================================

pub fn tls13_record_decrypt(key: *u8, key_len: i32, iv: *u8, seq: u64, record: *u8, record_len: i32, out: *u8, out_cap: i32, content_type: *u8) -> i32
    if record_len < TLS_RECORD_HEADER_LEN + TLS_AES_GCM_TAG_LEN
        return -1

    let rec_type: u8 = record[0]
    if rec_type != TLS_CONTENT_APPLICATION
        return -2

    let ver_hi: u8 = record[1]
    let ver_lo: u8 = record[2]
    if ver_hi != 0x03 || ver_lo != 0x03
        return -3

    let len_hi: u8 = record[3]
    let len_lo: u8 = record[4]
    let ciphertext_len: i32 = ((len_hi as i32) << 8) | (len_lo as i32)

    if ciphertext_len != record_len - TLS_RECORD_HEADER_LEN
        return -4

    let inner_len: i32 = ciphertext_len - TLS_AES_GCM_TAG_LEN
    if inner_len < 1
        return -5

    var aad: [5]u8
    aad[0] = record[0]
    aad[1] = record[1]
    aad[2] = record[2]
    aad[3] = record[3]
    aad[4] = record[4]

    var nonce: [12]u8
    tls13_compute_nonce(iv, seq, &nonce[0])

    var ctx: AesGcm128
    if key_len == 16
        aes128_gcm_init(&ctx, key)
    else
        return -6

    var inner: [1024]u8
    let ct_ptr: *u8 = &record[TLS_RECORD_HEADER_LEN]
    let tag_ptr: *u8 = &record[TLS_RECORD_HEADER_LEN + inner_len]

    let result: i32 = aes128_gcm_decrypt(&ctx, &nonce[0], 12, &aad[0], 5, ct_ptr, inner_len as u64, tag_ptr, &inner[0])
    if result != 1
        mem_zero(&inner[0], inner_len as u64)
        mem_zero(&nonce[0], 12)
        return -7

    let plaintext_len: i32 = tls13_parse_inner_plaintext(&inner[0], inner_len, content_type)
    if plaintext_len < 0
        mem_zero(&inner[0], inner_len as u64)
        return -8

    if plaintext_len > out_cap
        mem_zero(&inner[0], inner_len as u64)
        return -9

    mem_copy(out, &inner[0], plaintext_len as u64)
    mem_zero(&inner[0], inner_len as u64)
    mem_zero(&nonce[0], 12)

    return plaintext_len

# ============================================================================
# Record State Management
# ============================================================================

pub struct TlsRecordState
    client_key: [32]u8
    client_iv: [12]u8
    client_seq: u64
    server_key: [32]u8
    server_iv: [12]u8
    server_seq: u64
    key_len: i32

pub fn tls_record_state_init(state: *TlsRecordState)
    mem_zero(state as *u8, 120 as u64)

pub fn tls_record_state_set_keys(state: *TlsRecordState, client_key: *u8, client_iv: *u8, server_key: *u8, server_iv: *u8, key_len: i32)
    mem_copy(&state.client_key[0], client_key, key_len as u64)
    mem_copy(&state.client_iv[0], client_iv, 12)
    mem_copy(&state.server_key[0], server_key, key_len as u64)
    mem_copy(&state.server_iv[0], server_iv, 12)
    state.key_len = key_len
    state.client_seq = 0
    state.server_seq = 0

pub fn tls_record_state_client_encrypt(state: *TlsRecordState, plaintext: *u8, plaintext_len: i32, content_type: u8, out: *u8, out_cap: i32) -> i32
    let result: i32 = tls13_record_encrypt(&state.client_key[0], state.key_len, &state.client_iv[0], state.client_seq, plaintext, plaintext_len, content_type, out, out_cap)
    if result > 0
        state.client_seq = state.client_seq + 1
    return result

pub fn tls_record_state_server_decrypt(state: *TlsRecordState, record: *u8, record_len: i32, out: *u8, out_cap: i32, content_type: *u8) -> i32
    let result: i32 = tls13_record_decrypt(&state.server_key[0], state.key_len, &state.server_iv[0], state.server_seq, record, record_len, out, out_cap, content_type)
    if result >= 0
        state.server_seq = state.server_seq + 1
    return result

pub fn tls_record_state_server_encrypt(state: *TlsRecordState, plaintext: *u8, plaintext_len: i32, content_type: u8, out: *u8, out_cap: i32) -> i32
    let result: i32 = tls13_record_encrypt(&state.server_key[0], state.key_len, &state.server_iv[0], state.server_seq, plaintext, plaintext_len, content_type, out, out_cap)
    if result > 0
        state.server_seq = state.server_seq + 1
    return result

pub fn tls_record_state_client_decrypt(state: *TlsRecordState, record: *u8, record_len: i32, out: *u8, out_cap: i32, content_type: *u8) -> i32
    let result: i32 = tls13_record_decrypt(&state.client_key[0], state.key_len, &state.client_iv[0], state.client_seq, record, record_len, out, out_cap, content_type)
    if result >= 0
        state.client_seq = state.client_seq + 1
    return result
