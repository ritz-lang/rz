# ============================================================================
# Block processing
# ============================================================================

# Process a single 128-byte block (used internally for both SHA-512 and SHA-384)
fn sha512_transform_internal(h0: *u64, h1: *u64, h2: *u64, h3: *u64, h4: *u64, h5: *u64, h6: *u64, h7: *u64, block: *u8)
    # Message schedule (80 words)
    var w: [80]u64

    # Load first 16 words from block (big-endian)
    # NOTE: Must use intermediate variables due to Ritz compiler bug with
    # direct cast from pointer dereference to wider integer types
    var i: i32 = 0
    while i < 16
        let offset: i32 = i * 8
        let t0: u8 = block[offset]
        let t1: u8 = block[offset + 1]
        let t2: u8 = block[offset + 2]
        let t3: u8 = block[offset + 3]
        let t4: u8 = block[offset + 4]
        let t5: u8 = block[offset + 5]
        let t6: u8 = block[offset + 6]
        let t7: u8 = block[offset + 7]
        let b0: u64 = t0 as u64
        let b1: u64 = t1 as u64
        let b2: u64 = t2 as u64
        let b3: u64 = t3 as u64
        let b4: u64 = t4 as u64
        let b5: u64 = t5 as u64
        let b6: u64 = t6 as u64
        let b7: u64 = t7 as u64
        w[i] = (b0 << 56) | (b1 << 48) | (b2 << 40) | (b3 << 32) | (b4 << 24) | (b5 << 16) | (b6 << 8) | b7
        i += 1

    # Extend to 80 words
    while i < 80
        w[i] = gamma1_512(w[i - 2]) + w[i - 7] + gamma0_512(w[i - 15]) + w[i - 16]
        i += 1

    # Working variables
    var a: u64 = *h0
    var b: u64 = *h1
    var c: u64 = *h2
    var d: u64 = *h3
    var e: u64 = *h4
    var f: u64 = *h5
    var g: u64 = *h6
    var h: u64 = *h7

    # 80 rounds
    i = 0
    while i < 80
        let t1: u64 = h + sigma1_512(e) + ch64(e, f, g) + get_k512(i) + w[i]
        let t2: u64 = sigma0_512(a) + maj64(a, b, c)
        h = g
        g = f
        f = e
        e = d + t1
        d = c
        c = b
        b = a
        a = t1 + t2
        i += 1

    # Add to hash state
    *h0 = *h0 + a
    *h1 = *h1 + b
    *h2 = *h2 + c
    *h3 = *h3 + d
    *h4 = *h4 + e
    *h5 = *h5 + f
    *h6 = *h6 + g
    *h7 = *h7 + h

# Transform wrapper for Sha512
fn sha512_transform(ctx: *Sha512, block: *u8)
    sha512_transform_internal(@ctx.h0, @ctx.h1, @ctx.h2, @ctx.h3, @ctx.h4, @ctx.h5, @ctx.h6, @ctx.h7, block)

# Transform wrapper for Sha384
fn sha384_transform(ctx: *Sha384, block: *u8)
    sha512_transform_internal(@ctx.h0, @ctx.h1, @ctx.h2, @ctx.h3, @ctx.h4, @ctx.h5, @ctx.h6, @ctx.h7, block)

# ============================================================================
# Public API - SHA-512
# ============================================================================

# Create new SHA-512 context (uninitialized)
pub fn sha512_new() -> Sha512
    var ctx: Sha512
    ctx.h0 = 0
    ctx.h1 = 0
    ctx.h2 = 0
    ctx.h3 = 0
    ctx.h4 = 0
    ctx.h5 = 0
    ctx.h6 = 0
    ctx.h7 = 0
    ctx.buflen = 0
    ctx.total_len = 0
    return ctx

# Initialize SHA-512 context
pub fn sha512_init(ctx: *Sha512)
    ctx.h0 = H512_0_INIT
    ctx.h1 = H512_1_INIT
    ctx.h2 = H512_2_INIT
    ctx.h3 = H512_3_INIT
    ctx.h4 = H512_4_INIT
    ctx.h5 = H512_5_INIT
    ctx.h6 = H512_6_INIT
    ctx.h7 = H512_7_INIT
    ctx.buflen = 0
    ctx.total_len = 0

    # Zero the buffer
    var i: i32 = 0
    while i < 128
        ctx.buffer[i] = 0
        i += 1

# Update SHA-512 context with data
pub fn sha512_update(ctx: *Sha512, data: *u8, len: u64)
    if len == 0
        return

    ctx.total_len = ctx.total_len + len

    var offset: u64 = 0

    # If we have buffered data, try to complete a block
    if ctx.buflen > 0
        let space: u64 = 128 - ctx.buflen
        var to_copy: u64 = len
        if len > space
            to_copy = space

        # Copy to buffer
        var i: u64 = 0
        while i < to_copy
            ctx.buffer[ctx.buflen + i] = data[i]
            i += 1
        ctx.buflen = ctx.buflen + to_copy
        offset = to_copy

        # If buffer is full, process it
        if ctx.buflen == 128
            sha512_transform(ctx, @ctx.buffer[0])
            ctx.buflen = 0

    # Process full blocks directly from input
    while offset + 128 <= len
        sha512_transform(ctx, (data as u64 + offset) as *u8)
        offset = offset + 128

    # Buffer remaining bytes
    while offset < len
        ctx.buffer[ctx.buflen] = data[offset]
        ctx.buflen = ctx.buflen + 1
        offset += 1

# Finalize SHA-512 and output 64-byte hash
pub fn sha512_final(ctx: *Sha512, out: *u8)
    # Padding: append 1 bit, then zeros, then 128-bit length
    let total_bits: u64 = ctx.total_len * 8

    # Append 0x80 (1 bit followed by zeros)
    ctx.buffer[ctx.buflen] = 0x80
    ctx.buflen = ctx.buflen + 1

    # If not enough room for length (need 16 bytes), pad and process
    if ctx.buflen > 112
        while ctx.buflen < 128
            ctx.buffer[ctx.buflen] = 0
            ctx.buflen = ctx.buflen + 1
        sha512_transform(ctx, @ctx.buffer[0])
        ctx.buflen = 0

    # Pad with zeros up to length field
    while ctx.buflen < 112
        ctx.buffer[ctx.buflen] = 0
        ctx.buflen = ctx.buflen + 1

    # Append length in bits (big-endian, 128 bits - upper 64 bits are 0 for us)
    ctx.buffer[112] = 0
    ctx.buffer[113] = 0
    ctx.buffer[114] = 0
    ctx.buffer[115] = 0
    ctx.buffer[116] = 0
    ctx.buffer[117] = 0
    ctx.buffer[118] = 0
    ctx.buffer[119] = 0
    ctx.buffer[120] = (total_bits >> 56) as u8
    ctx.buffer[121] = (total_bits >> 48) as u8
    ctx.buffer[122] = (total_bits >> 40) as u8
    ctx.buffer[123] = (total_bits >> 32) as u8
    ctx.buffer[124] = (total_bits >> 24) as u8
    ctx.buffer[125] = (total_bits >> 16) as u8
    ctx.buffer[126] = (total_bits >> 8) as u8
    ctx.buffer[127] = total_bits as u8

    # Process final block
    sha512_transform(ctx, @ctx.buffer[0])

    # Output hash (big-endian)
    out[0] = (ctx.h0 >> 56) as u8
    out[1] = (ctx.h0 >> 48) as u8
    out[2] = (ctx.h0 >> 40) as u8
    out[3] = (ctx.h0 >> 32) as u8
    out[4] = (ctx.h0 >> 24) as u8
    out[5] = (ctx.h0 >> 16) as u8
    out[6] = (ctx.h0 >> 8) as u8
    out[7] = ctx.h0 as u8
    out[8] = (ctx.h1 >> 56) as u8
    out[9] = (ctx.h1 >> 48) as u8
    out[10] = (ctx.h1 >> 40) as u8
    out[11] = (ctx.h1 >> 32) as u8
    out[12] = (ctx.h1 >> 24) as u8
    out[13] = (ctx.h1 >> 16) as u8
    out[14] = (ctx.h1 >> 8) as u8
    out[15] = ctx.h1 as u8
    out[16] = (ctx.h2 >> 56) as u8
    out[17] = (ctx.h2 >> 48) as u8
    out[18] = (ctx.h2 >> 40) as u8
    out[19] = (ctx.h2 >> 32) as u8
    out[20] = (ctx.h2 >> 24) as u8
    out[21] = (ctx.h2 >> 16) as u8
    out[22] = (ctx.h2 >> 8) as u8
    out[23] = ctx.h2 as u8
    out[24] = (ctx.h3 >> 56) as u8
    out[25] = (ctx.h3 >> 48) as u8
    out[26] = (ctx.h3 >> 40) as u8
    out[27] = (ctx.h3 >> 32) as u8
    out[28] = (ctx.h3 >> 24) as u8
    out[29] = (ctx.h3 >> 16) as u8
    out[30] = (ctx.h3 >> 8) as u8
    out[31] = ctx.h3 as u8
    out[32] = (ctx.h4 >> 56) as u8
    out[33] = (ctx.h4 >> 48) as u8
    out[34] = (ctx.h4 >> 40) as u8
    out[35] = (ctx.h4 >> 32) as u8
    out[36] = (ctx.h4 >> 24) as u8
    out[37] = (ctx.h4 >> 16) as u8
    out[38] = (ctx.h4 >> 8) as u8
    out[39] = ctx.h4 as u8
    out[40] = (ctx.h5 >> 56) as u8
    out[41] = (ctx.h5 >> 48) as u8
    out[42] = (ctx.h5 >> 40) as u8
    out[43] = (ctx.h5 >> 32) as u8
    out[44] = (ctx.h5 >> 24) as u8
    out[45] = (ctx.h5 >> 16) as u8
    out[46] = (ctx.h5 >> 8) as u8
    out[47] = ctx.h5 as u8
    out[48] = (ctx.h6 >> 56) as u8
    out[49] = (ctx.h6 >> 48) as u8
    out[50] = (ctx.h6 >> 40) as u8
    out[51] = (ctx.h6 >> 32) as u8
    out[52] = (ctx.h6 >> 24) as u8
    out[53] = (ctx.h6 >> 16) as u8
    out[54] = (ctx.h6 >> 8) as u8
    out[55] = ctx.h6 as u8
    out[56] = (ctx.h7 >> 56) as u8
    out[57] = (ctx.h7 >> 48) as u8
    out[58] = (ctx.h7 >> 40) as u8
    out[59] = (ctx.h7 >> 32) as u8
    out[60] = (ctx.h7 >> 24) as u8
    out[61] = (ctx.h7 >> 16) as u8
    out[62] = (ctx.h7 >> 8) as u8
    out[63] = ctx.h7 as u8

# One-shot SHA-512 hash function
pub fn sha512(data: *u8, len: u64, out: *u8)
    var ctx: Sha512
    sha512_init(@ctx)
    sha512_update(@ctx, data, len)
    sha512_final(@ctx, out)

# ============================================================================
# Public API - SHA-384
# ============================================================================

# Create new SHA-384 context (uninitialized)
pub fn sha384_new() -> Sha384
    var ctx: Sha384
    ctx.h0 = 0
    ctx.h1 = 0
    ctx.h2 = 0
    ctx.h3 = 0
    ctx.h4 = 0
    ctx.h5 = 0
    ctx.h6 = 0
    ctx.h7 = 0
    ctx.buflen = 0
    ctx.total_len = 0
    return ctx

# Initialize SHA-384 context
pub fn sha384_init(ctx: *Sha384)
    ctx.h0 = H384_0_INIT
    ctx.h1 = H384_1_INIT
    ctx.h2 = H384_2_INIT
    ctx.h3 = H384_3_INIT
    ctx.h4 = H384_4_INIT
    ctx.h5 = H384_5_INIT
    ctx.h6 = H384_6_INIT
    ctx.h7 = H384_7_INIT
    ctx.buflen = 0
    ctx.total_len = 0

    # Zero the buffer
    var i: i32 = 0
    while i < 128
        ctx.buffer[i] = 0
        i += 1

# Update SHA-384 context with data
pub fn sha384_update(ctx: *Sha384, data: *u8, len: u64)
    if len == 0
        return

    ctx.total_len = ctx.total_len + len

    var offset: u64 = 0

    if ctx.buflen > 0
        let space: u64 = 128 - ctx.buflen
        var to_copy: u64 = len
        if len > space
            to_copy = space

        var i: u64 = 0
        while i < to_copy
            ctx.buffer[ctx.buflen + i] = data[i]
            i += 1
        ctx.buflen = ctx.buflen + to_copy
        offset = to_copy

        if ctx.buflen == 128
            sha384_transform(ctx, @ctx.buffer[0])
            ctx.buflen = 0

    while offset + 128 <= len
        sha384_transform(ctx, (data as u64 + offset) as *u8)
        offset = offset + 128

    while offset < len
        ctx.buffer[ctx.buflen] = data[offset]
        ctx.buflen = ctx.buflen + 1
        offset += 1

# Finalize SHA-384 and output 48-byte hash (truncated SHA-512)
pub fn sha384_final(ctx: *Sha384, out: *u8)
    let total_bits: u64 = ctx.total_len * 8

    ctx.buffer[ctx.buflen] = 0x80
    ctx.buflen = ctx.buflen + 1

    if ctx.buflen > 112
        while ctx.buflen < 128
            ctx.buffer[ctx.buflen] = 0
            ctx.buflen = ctx.buflen + 1
        sha384_transform(ctx, @ctx.buffer[0])
        ctx.buflen = 0

    while ctx.buflen < 112
        ctx.buffer[ctx.buflen] = 0
        ctx.buflen = ctx.buflen + 1

    ctx.buffer[112] = 0
    ctx.buffer[113] = 0
    ctx.buffer[114] = 0
    ctx.buffer[115] = 0
    ctx.buffer[116] = 0
    ctx.buffer[117] = 0
    ctx.buffer[118] = 0
    ctx.buffer[119] = 0
    ctx.buffer[120] = (total_bits >> 56) as u8
    ctx.buffer[121] = (total_bits >> 48) as u8
    ctx.buffer[122] = (total_bits >> 40) as u8
    ctx.buffer[123] = (total_bits >> 32) as u8
    ctx.buffer[124] = (total_bits >> 24) as u8
    ctx.buffer[125] = (total_bits >> 16) as u8
    ctx.buffer[126] = (total_bits >> 8) as u8
    ctx.buffer[127] = total_bits as u8

    sha384_transform(ctx, @ctx.buffer[0])

    # Output first 6 words (48 bytes) - truncate h6 and h7
    out[0] = (ctx.h0 >> 56) as u8
    out[1] = (ctx.h0 >> 48) as u8
    out[2] = (ctx.h0 >> 40) as u8
    out[3] = (ctx.h0 >> 32) as u8
    out[4] = (ctx.h0 >> 24) as u8
    out[5] = (ctx.h0 >> 16) as u8
    out[6] = (ctx.h0 >> 8) as u8
    out[7] = ctx.h0 as u8
    out[8] = (ctx.h1 >> 56) as u8
    out[9] = (ctx.h1 >> 48) as u8
    out[10] = (ctx.h1 >> 40) as u8
    out[11] = (ctx.h1 >> 32) as u8
    out[12] = (ctx.h1 >> 24) as u8
    out[13] = (ctx.h1 >> 16) as u8
    out[14] = (ctx.h1 >> 8) as u8
    out[15] = ctx.h1 as u8
    out[16] = (ctx.h2 >> 56) as u8
    out[17] = (ctx.h2 >> 48) as u8
    out[18] = (ctx.h2 >> 40) as u8
    out[19] = (ctx.h2 >> 32) as u8
    out[20] = (ctx.h2 >> 24) as u8
    out[21] = (ctx.h2 >> 16) as u8
    out[22] = (ctx.h2 >> 8) as u8
    out[23] = ctx.h2 as u8
    out[24] = (ctx.h3 >> 56) as u8
    out[25] = (ctx.h3 >> 48) as u8
    out[26] = (ctx.h3 >> 40) as u8
    out[27] = (ctx.h3 >> 32) as u8
    out[28] = (ctx.h3 >> 24) as u8
    out[29] = (ctx.h3 >> 16) as u8
    out[30] = (ctx.h3 >> 8) as u8
    out[31] = ctx.h3 as u8
    out[32] = (ctx.h4 >> 56) as u8
    out[33] = (ctx.h4 >> 48) as u8
    out[34] = (ctx.h4 >> 40) as u8
    out[35] = (ctx.h4 >> 32) as u8
    out[36] = (ctx.h4 >> 24) as u8
    out[37] = (ctx.h4 >> 16) as u8
    out[38] = (ctx.h4 >> 8) as u8
    out[39] = ctx.h4 as u8
    out[40] = (ctx.h5 >> 56) as u8
    out[41] = (ctx.h5 >> 48) as u8
    out[42] = (ctx.h5 >> 40) as u8
    out[43] = (ctx.h5 >> 32) as u8
    out[44] = (ctx.h5 >> 24) as u8
    out[45] = (ctx.h5 >> 16) as u8
    out[46] = (ctx.h5 >> 8) as u8
    out[47] = ctx.h5 as u8

# One-shot SHA-384 hash function
pub fn sha384(data: *u8, len: u64, out: *u8)
    var ctx: Sha384
    sha384_init(@ctx)
    sha384_update(@ctx, data, len)
    sha384_final(@ctx, out)
