# lib/sha512.ritz - SHA-512 and SHA-384 implementation
#
# Implementation of SHA-512 and SHA-384 (FIPS 180-4) for cryptographic hashing.
# SHA-512 uses 64-bit state words and 80 rounds.
# SHA-384 is SHA-512 with different IV and truncated output.
#
# API:
# - Sha512/Sha384 struct: hash context (state + buffer)
# - sha512_init(ctx): Initialize context for SHA-512
# - sha384_init(ctx): Initialize context for SHA-384
# - sha512_update(ctx, data, len): Process data
# - sha512_final(ctx, out): Finalize and output 64-byte hash
# - sha384_final(ctx, out): Finalize and output 48-byte hash
# - sha512(data, len, out): One-shot convenience function (64-byte output)
# - sha384(data, len, out): One-shot convenience function (48-byte output)

import ritzlib.sys

# ============================================================================
# Constants
# ============================================================================

# SHA-512 block size in bytes (1024 bits)
const SHA512_BLOCK_SIZE: u64 = 128

# SHA-512 digest size in bytes
const SHA512_DIGEST_SIZE: u64 = 64

# SHA-384 digest size in bytes
const SHA384_DIGEST_SIZE: u64 = 48

# SHA-512 Initial hash values (first 64 bits of fractional parts of square roots of first 8 primes)
const H512_0_INIT: u64 = 0x6a09e667f3bcc908
const H512_1_INIT: u64 = 0xbb67ae8584caa73b
const H512_2_INIT: u64 = 0x3c6ef372fe94f82b
const H512_3_INIT: u64 = 0xa54ff53a5f1d36f1
const H512_4_INIT: u64 = 0x510e527fade682d1
const H512_5_INIT: u64 = 0x9b05688c2b3e6c1f
const H512_6_INIT: u64 = 0x1f83d9abfb41bd6b
const H512_7_INIT: u64 = 0x5be0cd19137e2179

# SHA-384 Initial hash values (first 64 bits of fractional parts of square roots of 9th-16th primes)
const H384_0_INIT: u64 = 0xcbbb9d5dc1059ed8
const H384_1_INIT: u64 = 0x629a292a367cd507
const H384_2_INIT: u64 = 0x9159015a3070dd17
const H384_3_INIT: u64 = 0x152fecd8f70e5939
const H384_4_INIT: u64 = 0x67332667ffc00b31
const H384_5_INIT: u64 = 0x8eb44a8768581511
const H384_6_INIT: u64 = 0xdb0c2e0d64f98fa7
const H384_7_INIT: u64 = 0x47b5481dbefa4fa4

# ============================================================================
# SHA-512 Context
# ============================================================================

struct Sha512
    # Hash state (8 x 64-bit words)
    h0: u64
    h1: u64
    h2: u64
    h3: u64
    h4: u64
    h5: u64
    h6: u64
    h7: u64
    # Message buffer (128 bytes = 1024 bits = 1 block)
    buffer: [128]u8
    # Number of bytes in buffer
    buflen: u64
    # Total message length in bytes (low 64 bits - sufficient for most uses)
    total_len: u64

# SHA-384 uses same structure, just different IV and truncated output
struct Sha384
    h0: u64
    h1: u64
    h2: u64
    h3: u64
    h4: u64
    h5: u64
    h6: u64
    h7: u64
    buffer: [128]u8
    buflen: u64
    total_len: u64

# ============================================================================
# Bit operations (64-bit)
# ============================================================================

# Right rotate
fn rotr64(x: u64, n: u64) -> u64
    return (x >> n) | (x << (64 - n))

# SHA-512 sigma functions
fn sigma0_512(x: u64) -> u64
    return rotr64(x, 28) ^ rotr64(x, 34) ^ rotr64(x, 39)

fn sigma1_512(x: u64) -> u64
    return rotr64(x, 14) ^ rotr64(x, 18) ^ rotr64(x, 41)

fn gamma0_512(x: u64) -> u64
    return rotr64(x, 1) ^ rotr64(x, 8) ^ (x >> 7)

fn gamma1_512(x: u64) -> u64
    return rotr64(x, 19) ^ rotr64(x, 61) ^ (x >> 6)

# Choice: (x AND y) XOR (NOT x AND z)
fn ch64(x: u64, y: u64, z: u64) -> u64
    return (x & y) ^ ((~x) & z)

# Majority: (x AND y) XOR (x AND z) XOR (y AND z)
fn maj64(x: u64, y: u64, z: u64) -> u64
    return (x & y) ^ (x & z) ^ (y & z)

# ============================================================================
# Round constants (K) - 80 constants for SHA-512
# ============================================================================

fn get_k512(i: i32) -> u64
    if i == 0
        return 0x428a2f98d728ae22
    if i == 1
        return 0x7137449123ef65cd
    if i == 2
        return 0xb5c0fbcfec4d3b2f
    if i == 3
        return 0xe9b5dba58189dbbc
    if i == 4
        return 0x3956c25bf348b538
    if i == 5
        return 0x59f111f1b605d019
