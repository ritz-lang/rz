# AES Block Cipher Implementation
# FIPS 197 compliant AES-128 and AES-256
#
# This implementation includes:
# - Software implementation (always available)
# - AES-NI hardware acceleration (runtime detection via CPUID)
#
# The dispatcher functions automatically select the fastest path.

import mem
import cpuid

# ============================================================================
# AES Constants
# ============================================================================

const AES_BLOCK_SIZE: u64 = 16

# ============================================================================
# AES S-Box Lookup Tables (FIPS 197)
# ============================================================================

