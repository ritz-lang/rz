# test/test_ed25519.ritz - Ed25519 tests (RFC 8032)

import lib.ed25519
import lib.mem

# ============================================================================
# RFC 8032 Test Vectors
# ============================================================================

# Test base point operations
[[test]]
fn test_ed25519_vector1() -> i32
    # Get base point
    var B: Ge25519
    ge_basepoint(@B)

    # Encode base point
    var bytes: [32]u8
    ge_tobytes(@bytes[0], @B)

    # Check encoding is non-zero
    var all_zero: i32 = 1
    var i: i32 = 0
    while i < 32
        if bytes[i] != 0
            all_zero = 0
        i += 1

    if all_zero == 1
        return 1

    return 0

# Test base point encoding against known value
[[test]]
fn test_basepoint_encoding() -> i32
    var B: Ge25519
    ge_basepoint(@B)

    var B_bytes: [32]u8
    ge_tobytes(@B_bytes[0], @B)

    # Expected encoding of base point (y-coordinate with sign bit = 0)
    # Base point y = 4/5, x is positive (odd, so sign bit = 1)
    # y = 46316835694926478169428394003475163141307993866256225615783033603165251855960
    # In little-endian hex: 5866666666666666666666666666666666666666666666666666666666666666
    # BUT: x is odd so sign bit (bit 255) is set, making byte 31 = 0x66 | 0x80 = 0xe6? No wait...
    # Actually x coord is: 15112221349535807912866137220509078935008241517919938459256001405341651378822
    # which is even (ends in 2), so sign bit = 0
    var expected: [32]u8
    expected[0] = 0x58
    expected[1] = 0x66
    expected[2] = 0x66
    expected[3] = 0x66
    expected[4] = 0x66
    expected[5] = 0x66
    expected[6] = 0x66
    expected[7] = 0x66
    expected[8] = 0x66
    expected[9] = 0x66
    expected[10] = 0x66
    expected[11] = 0x66
    expected[12] = 0x66
    expected[13] = 0x66
    expected[14] = 0x66
    expected[15] = 0x66
    expected[16] = 0x66
    expected[17] = 0x66
    expected[18] = 0x66
    expected[19] = 0x66
    expected[20] = 0x66
    expected[21] = 0x66
    expected[22] = 0x66
    expected[23] = 0x66
    expected[24] = 0x66
    expected[25] = 0x66
    expected[26] = 0x66
    expected[27] = 0x66
    expected[28] = 0x66
    expected[29] = 0x66
    expected[30] = 0x66
    expected[31] = 0x66

    # Check encoding matches expected
    if mem_eq(@B_bytes[0], @expected[0], 32) != 1
        # Debug: return first differing byte position + 100
        var i: i32 = 0
        while i < 32
            if B_bytes[i] != expected[i]
                return 100 + i
            i += 1
        return 1

    return 0

# Test point doubling (neutral element)
[[test]]
fn test_ge_double_neutral() -> i32
    var zero: Ge25519
    ge_zero(@zero)

    var doubled: Ge25519
    ge_double(@doubled, @zero)

    # Doubling the neutral element should give neutral element
    # Check Z is non-zero (valid point)
    var z_bytes: [32]u8
    fe_tobytes(@z_bytes[0], @doubled.Z)

    # Z should not be all zeros
    var z_nonzero: i32 = 0
    var i: i32 = 0
    while i < 32
        if z_bytes[i] != 0
            z_nonzero = 1
        i += 1

    if z_nonzero == 0
        return 1

    return 0

# Test point addition with neutral element
[[test]]
fn test_ge_add_neutral() -> i32
    var B: Ge25519
    ge_basepoint(@B)

    var zero: Ge25519
    ge_zero(@zero)

    var result: Ge25519
    ge_add(@result, @B, @zero)

    # B + 0 should equal B
    var B_bytes: [32]u8
    var result_bytes: [32]u8
    ge_tobytes(@B_bytes[0], @B)
    ge_tobytes(@result_bytes[0], @result)

    if mem_eq(@B_bytes[0], @result_bytes[0], 32) != 1
        return 1

    return 0

# Test scalar multiplication by 1
[[test]]
fn test_scalarmult_one() -> i32
    var B: Ge25519
    ge_basepoint(@B)

    # Scalar = 1
    var one: [32]u8
    mem_zero(@one[0], 32)
    one[0] = 1

    var result: Ge25519
    ge_scalarmult(@result, @one[0], @B)

    # 1 * B should equal B
    var B_bytes: [32]u8
    var result_bytes: [32]u8
    ge_tobytes(@B_bytes[0], @B)
    ge_tobytes(@result_bytes[0], @result)

    if mem_eq(@B_bytes[0], @result_bytes[0], 32) != 1
        return 1

    return 0

# Test ed25519_keygen with zero seed
[[test]]
fn test_ed25519_keygen_basic() -> i32
    # Test seed (all zeros - for simplicity)
    var seed: [32]u8
    mem_zero(@seed[0], 32)

    var privkey: [32]u8
    var pubkey: [32]u8

    ed25519_keygen(@pubkey[0], @privkey[0], @seed[0])

    # Check pubkey is non-zero
    var all_zero: i32 = 1
    var i: i32 = 0
    while i < 32
        if pubkey[i] != 0
            all_zero = 0
        i += 1

    if all_zero == 1
        return 1

    return 0

