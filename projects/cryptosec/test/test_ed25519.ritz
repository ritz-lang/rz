# Test scalar multiplication by 2
[[test]]
fn test_scalarmult_two() -> i32
    var B: Ge25519
    ge_basepoint(@B)

    # Compute 2*B via doubling
    var B2_dbl: Ge25519
    ge_double(@B2_dbl, @B)

    var dbl_bytes: [32]u8
    ge_tobytes(@dbl_bytes[0], @B2_dbl)

    # Expected encoding of 2*B (computed in Python)
    # c9a3f86aae465f0e56513864510f3997561fa2c9e85ea21dc2292309f3cd6022
    var expected_2B: [32]u8
    expected_2B[0] = 0xc9
    expected_2B[1] = 0xa3
    expected_2B[2] = 0xf8
    expected_2B[3] = 0x6a
    expected_2B[4] = 0xae
    expected_2B[5] = 0x46
    expected_2B[6] = 0x5f
    expected_2B[7] = 0x0e
    expected_2B[8] = 0x56
    expected_2B[9] = 0x51
    expected_2B[10] = 0x38
    expected_2B[11] = 0x64
    expected_2B[12] = 0x51
    expected_2B[13] = 0x0f
    expected_2B[14] = 0x39
    expected_2B[15] = 0x97
    expected_2B[16] = 0x56
    expected_2B[17] = 0x1f
    expected_2B[18] = 0xa2
    expected_2B[19] = 0xc9
    expected_2B[20] = 0xe8
    expected_2B[21] = 0x5e
    expected_2B[22] = 0xa2
    expected_2B[23] = 0x1d
    expected_2B[24] = 0xc2
    expected_2B[25] = 0x29
    expected_2B[26] = 0x23
    expected_2B[27] = 0x09
    expected_2B[28] = 0xf3
    expected_2B[29] = 0xcd
    expected_2B[30] = 0x60
    expected_2B[31] = 0x22

    if mem_eq(@dbl_bytes[0], @expected_2B[0], 32) != 1
        # Debug: return first byte of computed value
        return dbl_bytes[0] as i32

    # Also verify B + B = 2B (test addition)
    var B_plus_B: Ge25519
    ge_add(@B_plus_B, @B, @B)

    var add_bytes: [32]u8
    ge_tobytes(@add_bytes[0], @B_plus_B)

    if mem_eq(@add_bytes[0], @expected_2B[0], 32) != 1
        # Return 200 + first byte to distinguish from doubling failure
        return 200 + (add_bytes[0] as i32)

    return 0

# ============================================================================
# RFC 8032 Ed25519 Sign/Verify Test Vectors
