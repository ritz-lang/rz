    if result != 0
        return 1

    return 0

# Test sign/verify round-trip with custom message
[[test]]
fn test_ed25519_sign_verify_roundtrip() -> i32
    # Generate keypair from test seed
    var seed: [32]u8
    seed[0] = 0x01
    seed[1] = 0x02
    seed[2] = 0x03
    seed[3] = 0x04
    seed[4] = 0x05
    seed[5] = 0x06
    seed[6] = 0x07
    seed[7] = 0x08
    var i: i32 = 8
    while i < 32
        seed[i] = (i as u8)
        i += 1

    var privkey: [32]u8
    var pubkey: [32]u8
    ed25519_keygen(@pubkey[0], @privkey[0], @seed[0])

    # Test message: "hello"
    var msg: [5]u8
    msg[0] = 0x68  # 'h'
    msg[1] = 0x65  # 'e'
    msg[2] = 0x6c  # 'l'
    msg[3] = 0x6c  # 'l'
    msg[4] = 0x6f  # 'o'

    # Sign the message
    var sig: [64]u8
    ed25519_sign(@sig[0], @msg[0], 5, @privkey[0])

    # Verify the signature
    let result: i32 = ed25519_verify(@sig[0], @msg[0], 5, @pubkey[0])
    if result != 0
        return 1

    return 0

# Test that modified message fails verification
[[test]]
fn test_ed25519_verify_tampered_msg() -> i32
    # Generate keypair
    var seed: [32]u8
    mem_zero(@seed[0], 32)
    seed[0] = 0xaa
    seed[1] = 0xbb

    var privkey: [32]u8
    var pubkey: [32]u8
    ed25519_keygen(@pubkey[0], @privkey[0], @seed[0])

    # Sign message "test"
    var msg: [4]u8
    msg[0] = 0x74  # 't'
    msg[1] = 0x65  # 'e'
    msg[2] = 0x73  # 's'
    msg[3] = 0x74  # 't'

    var sig: [64]u8
    ed25519_sign(@sig[0], @msg[0], 4, @privkey[0])

    # Tamper with message
    msg[0] = 0x54  # 'T' instead of 't'

    # Verify should fail (return != 0)
    let result: i32 = ed25519_verify(@sig[0], @msg[0], 4, @pubkey[0])
    if result == 0
        return 1  # Should have failed!

    return 0

# Test that modified signature fails verification
[[test]]
fn test_ed25519_verify_tampered_sig() -> i32
    # Generate keypair
    var seed: [32]u8
    mem_zero(@seed[0], 32)
    seed[0] = 0xcc
    seed[1] = 0xdd

    var privkey: [32]u8
    var pubkey: [32]u8
    ed25519_keygen(@pubkey[0], @privkey[0], @seed[0])

    # Sign message "data"
    var msg: [4]u8
    msg[0] = 0x64  # 'd'
    msg[1] = 0x61  # 'a'
    msg[2] = 0x74  # 't'
    msg[3] = 0x61  # 'a'

    var sig: [64]u8
    ed25519_sign(@sig[0], @msg[0], 4, @privkey[0])

    # Tamper with signature (modify s component)
    sig[32] = sig[32] ^ 0x01

    # Verify should fail
    let result: i32 = ed25519_verify(@sig[0], @msg[0], 4, @pubkey[0])
    if result == 0
        return 1  # Should have failed!

    return 0
