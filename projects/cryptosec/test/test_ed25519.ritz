    seed[16] = 0x44
    seed[17] = 0x49
    seed[18] = 0xc5
    seed[19] = 0x69
    seed[20] = 0x7b
    seed[21] = 0x32
    seed[22] = 0x69
    seed[23] = 0x19
    seed[24] = 0x70
    seed[25] = 0x3b
    seed[26] = 0xac
    seed[27] = 0x03
    seed[28] = 0x1c
    seed[29] = 0xae
    seed[30] = 0x7f
    seed[31] = 0x60

    # Step 1: hash = SHA512(seed)
    var hash: [64]u8
    sha512(@seed[0], 32, @hash[0])

    # Step 2: r = SHA512(prefix) mod l (empty message)
    # prefix = hash[32:64]
    var r_hash: [64]u8
    var ctx: Sha512
    sha512_init(@ctx)
    sha512_update(@ctx, @hash[32], 32)
    # Empty message, so no more updates
    sha512_final(@ctx, @r_hash[0])

    sc_reduce(@r_hash[0])

    # Step 3: R = r * B
    var R: Ge25519
    ge_scalarmult_base(@R, @r_hash[0])

    var R_bytes: [32]u8
    ge_tobytes(@R_bytes[0], @R)

    # Expected R from signature
    var expected_R: [32]u8
    expected_R[0] = 0xe5
    expected_R[1] = 0x56
    expected_R[2] = 0x43
    expected_R[3] = 0x00
    expected_R[4] = 0xc3
    expected_R[5] = 0x60
    expected_R[6] = 0xac
    expected_R[7] = 0x72
    expected_R[8] = 0x90
    expected_R[9] = 0x86
    expected_R[10] = 0xe2
    expected_R[11] = 0xcc
    expected_R[12] = 0x80
    expected_R[13] = 0x6e
    expected_R[14] = 0x82
    expected_R[15] = 0x8a
    expected_R[16] = 0x84
    expected_R[17] = 0x87
    expected_R[18] = 0x7f
    expected_R[19] = 0x1e
    expected_R[20] = 0xb8
    expected_R[21] = 0xe5
    expected_R[22] = 0xd9
    expected_R[23] = 0x74
    expected_R[24] = 0xd8
    expected_R[25] = 0x73
    expected_R[26] = 0xe0
    expected_R[27] = 0x65
    expected_R[28] = 0x22
    expected_R[29] = 0x49
    expected_R[30] = 0x01
    expected_R[31] = 0x55

    if mem_eq(@R_bytes[0], @expected_R[0], 32) != 1
        # Debug: return first differing byte + 100
        var i: i32 = 0
        while i < 32
            if R_bytes[i] != expected_R[i]
                return 100 + i
            i += 1
        return 1

    return 0

