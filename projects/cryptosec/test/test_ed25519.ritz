# Test fe_sqrt on a known square
[[test]]
fn test_fe_sqrt_simple() -> i32
    # 4 = 2^2, sqrt(4) = 2
    var four: Fe25519
    fe_zero(@four)
    four.l0 = 4

    var two: Fe25519
    let result: i32 = fe_sqrt(@two, @four)
    if result != 0
        return 1  # Failed to find sqrt

    # Check two^2 == 4
    var check: Fe25519
    fe_sq(@check, @two)
    fe_reduce(@check)
    if check.l0 != 4
        return 2
    if check.l1 != 0
        return 3

    return 0

# Test that we can encode and decode the base point
[[test]]
fn test_encode_decode_basepoint() -> i32
    var B: Ge25519
    ge_basepoint(@B)

    var bytes: [32]u8
    ge_tobytes(@bytes[0], @B)

    var B2: Ge25519
    if ge_frombytes(@B2, @bytes[0]) != 0
        return 1

    return 0

