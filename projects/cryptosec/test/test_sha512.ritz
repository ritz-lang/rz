# test/test_sha512.ritz - Tests for SHA-512 and SHA-384
#
# Tests for lib/sha512.ritz with NIST FIPS 180-4 test vectors

import ritzlib.sys
import ritzlib.io
import ritzlib.strview

import cryptosec.sha512
import cryptosec.mem

# ============================================================================
# Helper: Compare hash output to expected hex
# ============================================================================

fn hex_char_to_val(c: u8) -> u8
    if c >= 48 and c <= 57
        # '0'-'9' -> 0-9
        return c - 48
    if c >= 97 and c <= 102
        # 'a'-'f' -> 10-15
        return c - 97 + 10
    if c >= 65 and c <= 70
        # 'A'-'F' -> 10-15
        return c - 65 + 10
    return 0

# Compare 64-byte hash output to hex string (128 chars for SHA-512)
fn hash512_eq_hex(hash: *u8, expected: StrView) -> i32
    var i: i32 = 0
    while i < 64
        let hi = hex_char_to_val(expected.get(i * 2))
        let lo = hex_char_to_val(expected.get(i * 2 + 1))
        let exp_byte: u8 = (hi << 4) | lo
        if hash[i] != exp_byte
            return 0
        i += 1
    return 1

# Compare 48-byte hash output to hex string (96 chars for SHA-384)
fn hash384_eq_hex(hash: *u8, expected: StrView) -> i32
    var i: i32 = 0
    while i < 48
        let hi = hex_char_to_val(expected.get(i * 2))
        let lo = hex_char_to_val(expected.get(i * 2 + 1))
        let exp_byte: u8 = (hi << 4) | lo
        if hash[i] != exp_byte
            return 0
        i += 1
    return 1

# =============================================================================
# SHA-512 Test Vectors (FIPS 180-4 / NIST CAVP)
# =============================================================================

[[test]]
fn test_sha512_empty() -> i32
    # SHA-512("")
    var hash: [64]u8
    let msg = ""
    sha512_str(@msg, @hash[0])

    let expected = "cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e"
    if hash512_eq_hex(@hash[0], expected) != 1
        return 1
    0

[[test]]
fn test_sha512_abc() -> i32
    # SHA-512("abc")
    var hash: [64]u8
    let msg = "abc"
    sha512_str(@msg, @hash[0])

    let expected = "ddaf35a193617abacc417349ae20413112e6fa4e89a97ea20a9eeee64b55d39a2192992a274fc1a836ba3c23a3feebbd454d4423643ce80e2a9ac94fa54ca49f"
    if hash512_eq_hex(@hash[0], expected) != 1
        return 1
    0

[[test]]
fn test_sha512_448_bits() -> i32
    # SHA-512("abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq")
    var hash: [64]u8
    let msg = "abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq"
    sha512_str(@msg, @hash[0])

    let expected = "204a8fc6dda82f0a0ced7beb8e08a41657c16ef468b228a8279be331a703c33596fd15c13b1b07f9aa1d3bea57789ca031ad85c7a71dd70354ec631238ca3445"
    if hash512_eq_hex(@hash[0], expected) != 1
        return 1
    0

[[test]]
fn test_sha512_896_bits() -> i32
    # SHA-512("abcdefghbcdefghicdefghijdefghijkefghijklfghijklmghijklmnhijklmnoijklmnopjklmnopqklmnopqrlmnopqrsmnopqrstnopqrstu")
    var hash: [64]u8
    let msg = "abcdefghbcdefghicdefghijdefghijkefghijklfghijklmghijklmnhijklmnoijklmnopjklmnopqklmnopqrlmnopqrsmnopqrstnopqrstu"
    sha512_str(@msg, @hash[0])

    let expected = "8e959b75dae313da8cf4f72814fc143f8f7779c6eb9f7fa17299aeadb6889018501d289e4900f7e4331b99dec4b5433ac7d329eeb6dd26545e96e55b874be909"
    if hash512_eq_hex(@hash[0], expected) != 1
        return 1
    0

[[test]]
fn test_sha512_incremental() -> i32
    # Test streaming API: hash "abc" in parts
    var hash: [64]u8
    let a = "a"
    let b = "b"
    let c = "c"

    var ctx: Sha512 = sha512_new()
    sha512_init(@ctx)
    sha512_update_str(@ctx, @a)
    sha512_update_str(@ctx, @b)
    sha512_update_str(@ctx, @c)
    sha512_final(@ctx, @hash[0])

    let expected = "ddaf35a193617abacc417349ae20413112e6fa4e89a97ea20a9eeee64b55d39a2192992a274fc1a836ba3c23a3feebbd454d4423643ce80e2a9ac94fa54ca49f"
    if hash512_eq_hex(@hash[0], expected) != 1
        return 1
    0

[[test]]
fn test_sha512_single_byte() -> i32
    # SHA-512("a")
    var hash: [64]u8
    let msg = "a"
    sha512_str(@msg, @hash[0])

    let expected = "1f40fc92da241694750979ee6cf582f2d5d7d28e18335de05abc54d0560e0f5302860c652bf08d560252aa5e74210546f369fbbbce8c12cfc7957b2652fe9a75"
    if hash512_eq_hex(@hash[0], expected) != 1
        return 1
    0

# =============================================================================
# SHA-384 Test Vectors (FIPS 180-4 / NIST CAVP)
# =============================================================================

[[test]]
fn test_sha384_empty() -> i32
    # SHA-384("")
    var hash: [48]u8
    let msg = ""
    sha384_str(@msg, @hash[0])

    let expected = "38b060a751ac96384cd9327eb1b1e36a21fdb71114be07434c0cc7bf63f6e1da274edebfe76f65fbd51ad2f14898b95b"
    if hash384_eq_hex(@hash[0], expected) != 1
        return 1
    0

[[test]]
fn test_sha384_abc() -> i32
    # SHA-384("abc")
    var hash: [48]u8
    let msg = "abc"
    sha384_str(@msg, @hash[0])

    let expected = "cb00753f45a35e8bb5a03d699ac65007272c32ab0eded1631a8b605a43ff5bed8086072ba1e7cc2358baeca134c825a7"
    if hash384_eq_hex(@hash[0], expected) != 1
        return 1
    0

[[test]]
fn test_sha384_448_bits() -> i32
    # SHA-384("abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq")
    var hash: [48]u8
    let msg = "abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq"
    sha384_str(@msg, @hash[0])

    let expected = "3391fdddfc8dc7393707a65b1b4709397cf8b1d162af05abfe8f450de5f36bc6b0455a8520bc4e6f5fe95b1fe3c8452b"
    if hash384_eq_hex(@hash[0], expected) != 1
        return 1
    0

[[test]]
fn test_sha384_incremental() -> i32
    # Test streaming API: hash "abc" in parts
    var hash: [48]u8
    let a = "a"
    let b = "b"
    let c = "c"

    var ctx: Sha384 = sha384_new()
    sha384_init(@ctx)
    sha384_update_str(@ctx, @a)
    sha384_update_str(@ctx, @b)
    sha384_update_str(@ctx, @c)
    sha384_final(@ctx, @hash[0])

    let expected = "cb00753f45a35e8bb5a03d699ac65007272c32ab0eded1631a8b605a43ff5bed8086072ba1e7cc2358baeca134c825a7"
    if hash384_eq_hex(@hash[0], expected) != 1
        return 1
    0

# =============================================================================
# Additional Tests
# =============================================================================

[[test]]
fn test_sha512_deterministic() -> i32
    # Same input should always produce same output
    var hash1: [64]u8
    var hash2: [64]u8
    let msg = "hello"
    sha512_str(@msg, @hash1[0])
    sha512_str(@msg, @hash2[0])
    if mem_eq(@hash1[0], @hash2[0], 64) != 1
        return 1
    0

[[test]]
fn test_sha384_deterministic() -> i32
    var hash1: [48]u8
    var hash2: [48]u8
    let msg = "hello"
    sha384_str(@msg, @hash1[0])
    sha384_str(@msg, @hash2[0])
    if mem_eq(@hash1[0], @hash2[0], 48) != 1
        return 1
    0

[[test]]
fn test_sha512_different_inputs() -> i32
    var hash1: [64]u8
    var hash2: [64]u8
    let msg1 = "abc"
    let msg2 = "abd"
    sha512_str(@msg1, @hash1[0])
    sha512_str(@msg2, @hash2[0])
    # Different inputs should produce different outputs
    if mem_eq(@hash1[0], @hash2[0], 64) == 1
        return 1
    0

[[test]]
fn test_sha512_large_message() -> i32
    # Test with message > 1 block (128 bytes)
    var msg: [200]u8
    var i: i32 = 0
    while i < 200
        msg[i] = 0x61  # 'a'
        i += 1
    var hash: [64]u8
    sha512(@msg[0], 200, @hash[0])
    # Just verify it doesn't crash and produces non-zero output
    var zeros: [64]u8
    i = 0
    while i < 64
        zeros[i] = 0
        i += 1
    if mem_eq(@hash[0], @zeros[0], 64) == 1
        return 1
    0

[[test]]
fn test_sha384_large_message() -> i32
    var msg: [200]u8
    var i: i32 = 0
    while i < 200
        msg[i] = 0x61
        i += 1
    var hash: [48]u8
    sha384(@msg[0], 200, @hash[0])
    var zeros: [48]u8
    i = 0
    while i < 48
        zeros[i] = 0
        i += 1
    if mem_eq(@hash[0], @zeros[0], 48) == 1
        return 1
    0

[[test]]
fn test_sha512_block_boundary() -> i32
    # Test message exactly at block boundary (128 bytes)
    var msg: [128]u8
    var i: i32 = 0
    while i < 128
        msg[i] = 0x62  # 'b'
        i += 1
    var hash: [64]u8
    sha512(@msg[0], 128, @hash[0])
    var zeros: [64]u8
    i = 0
    while i < 64
        zeros[i] = 0
        i += 1
    if mem_eq(@hash[0], @zeros[0], 64) == 1
        return 1
    0
