# test/test_u128.ritz - Tests for 128-bit integer emulation
#
# Tests for lib/u128.ritz:
# - U128 struct: { lo: u64, hi: u64 }
# - Arithmetic: add, sub, mul
# - Bitwise: shl, shr, and, or, xor
# - Comparison: eq, lt, gt

import ritzlib.sys
import ritzlib.io

import cryptosec.u128

# ============================================================================
# Construction and basic operations
# ============================================================================

[[test]]
fn test_u128_zero() -> i32
    let z: U128 = u128_zero()
    assert z.lo == 0, "lo should be 0"
    assert z.hi == 0, "hi should be 0"
    0

[[test]]
fn test_u128_from_u64() -> i32
    let a: U128 = u128_from_u64(0xDEADBEEF)
    assert a.lo == 0xDEADBEEF, "lo should be 0xDEADBEEF"
    assert a.hi == 0, "hi should be 0"
    0

[[test]]
fn test_u128_from_parts() -> i32
    let a: U128 = u128_from_parts(0x1234, 0x5678)
    assert a.lo == 0x1234, "lo should be 0x1234"
    assert a.hi == 0x5678, "hi should be 0x5678"
    0

# ============================================================================
# Addition tests
# ============================================================================

[[test]]
fn test_u128_add_simple() -> i32
    let a: U128 = u128_from_u64(100)
    let b: U128 = u128_from_u64(200)
    let c: U128 = u128_add(a, b)
    assert c.lo == 300, "100 + 200 = 300"
    assert c.hi == 0, "no carry"
    0

[[test]]
fn test_u128_add_carry() -> i32
    # Test carry from lo to hi
    let a: U128 = u128_from_u64(0xFFFFFFFFFFFFFFFF)
    let b: U128 = u128_from_u64(1)
    let c: U128 = u128_add(a, b)
    assert c.lo == 0, "should wrap to 0"
    assert c.hi == 1, "should carry to hi"
    0

[[test]]
fn test_u128_add_large() -> i32
    # (2^64 - 1) + (2^64 - 1) = 2^65 - 2
    let a: U128 = u128_from_u64(0xFFFFFFFFFFFFFFFF)
    let b: U128 = u128_from_u64(0xFFFFFFFFFFFFFFFF)
    let c: U128 = u128_add(a, b)
    assert c.lo == 0xFFFFFFFFFFFFFFFE, "lo should be max-1"
    assert c.hi == 1, "hi should be 1"
    0

[[test]]
fn test_u128_add_both_parts() -> i32
    let a: U128 = u128_from_parts(0x1000000000000000, 0x1)
    let b: U128 = u128_from_parts(0x2000000000000000, 0x2)
    let c: U128 = u128_add(a, b)
    assert c.lo == 0x3000000000000000, "lo sum"
    assert c.hi == 0x3, "hi sum"
    0

# ============================================================================
# Subtraction tests
# ============================================================================

[[test]]
fn test_u128_sub_simple() -> i32
    let a: U128 = u128_from_u64(300)
    let b: U128 = u128_from_u64(100)
    let c: U128 = u128_sub(a, b)
    assert c.lo == 200, "300 - 100 = 200"
    assert c.hi == 0, "no borrow"
    0

[[test]]
fn test_u128_sub_borrow() -> i32
    # Test borrow from hi
    let a: U128 = u128_from_parts(0, 1)  # 2^64
    let b: U128 = u128_from_u64(1)
    let c: U128 = u128_sub(a, b)
    assert c.lo == 0xFFFFFFFFFFFFFFFF, "should borrow"
    assert c.hi == 0, "hi decremented"
    0

[[test]]
fn test_u128_sub_zero() -> i32
    let a: U128 = u128_from_u64(42)
    let b: U128 = u128_from_u64(42)
    let c: U128 = u128_sub(a, b)
    assert c.lo == 0, "42 - 42 = 0"
    assert c.hi == 0, "no borrow"
    0

# ============================================================================
# Multiplication tests
# ============================================================================

[[test]]
fn test_u128_mul_simple() -> i32
    let a: U128 = u128_from_u64(100)
    let b: U128 = u128_from_u64(200)
    let c: U128 = u128_mul(a, b)
    assert c.lo == 20000, "100 * 200 = 20000"
    assert c.hi == 0, "fits in 64 bits"
    0

[[test]]
fn test_u128_mul_overflow_to_hi() -> i32
    # 2^32 * 2^32 = 2^64, which goes into hi
    let a: U128 = u128_from_u64(0x100000000)  # 2^32
    let b: U128 = u128_from_u64(0x100000000)  # 2^32
    let c: U128 = u128_mul(a, b)
    assert c.lo == 0, "lo should be 0"
    assert c.hi == 1, "2^64 in hi"
    0

[[test]]
fn test_u128_mul_max_u32() -> i32
    # (2^32 - 1) * (2^32 - 1) = 2^64 - 2^33 + 1
    let a: U128 = u128_from_u64(0xFFFFFFFF)
    let b: U128 = u128_from_u64(0xFFFFFFFF)
    let c: U128 = u128_mul(a, b)
    assert c.lo == 0xFFFFFFFE00000001, "known result lo"
    assert c.hi == 0, "fits in 64 bits"
    0

# ============================================================================
# Shift tests
# ============================================================================

[[test]]
fn test_u128_shl_small() -> i32
    let a: U128 = u128_from_u64(1)
    let b: U128 = u128_shl(a, 4)
    assert b.lo == 16, "1 << 4 = 16"
    assert b.hi == 0, "no overflow"
    0

[[test]]
fn test_u128_shl_to_hi() -> i32
    let a: U128 = u128_from_u64(1)
    let b: U128 = u128_shl(a, 64)
    assert b.lo == 0, "shifted out of lo"
    assert b.hi == 1, "into hi"
    0

[[test]]
fn test_u128_shl_cross_boundary() -> i32
    let a: U128 = u128_from_u64(0x8000000000000000)  # MSB set
    let b: U128 = u128_shl(a, 1)
    assert b.lo == 0, "shifted out"
    assert b.hi == 1, "into hi"
    0

[[test]]
fn test_u128_shr_small() -> i32
    let a: U128 = u128_from_u64(16)
    let b: U128 = u128_shr(a, 4)
    assert b.lo == 1, "16 >> 4 = 1"
    assert b.hi == 0, "still 0"
    0

[[test]]
fn test_u128_shr_from_hi() -> i32
    let a: U128 = u128_from_parts(0, 1)  # 2^64
    let b: U128 = u128_shr(a, 64)
    assert b.lo == 1, "hi shifted to lo"
    assert b.hi == 0, "hi cleared"
    0

[[test]]
fn test_u128_shr_cross_boundary() -> i32
    let a: U128 = u128_from_parts(0, 1)  # 2^64
    let b: U128 = u128_shr(a, 1)
    assert b.lo == 0x8000000000000000, "bit from hi"
    assert b.hi == 0, "hi shifted"
    0

# ============================================================================
# Comparison tests
# ============================================================================

[[test]]
fn test_u128_eq_true() -> i32
    let a: U128 = u128_from_parts(0x1234, 0x5678)
    let b: U128 = u128_from_parts(0x1234, 0x5678)
    assert u128_eq(a, b) == 1, "should be equal"
    0

[[test]]
fn test_u128_eq_false_lo() -> i32
    let a: U128 = u128_from_parts(0x1234, 0x5678)
    let b: U128 = u128_from_parts(0x1235, 0x5678)
    assert u128_eq(a, b) == 0, "lo differs"
    0

[[test]]
fn test_u128_eq_false_hi() -> i32
    let a: U128 = u128_from_parts(0x1234, 0x5678)
    let b: U128 = u128_from_parts(0x1234, 0x5679)
    assert u128_eq(a, b) == 0, "hi differs"
    0

[[test]]
fn test_u128_lt() -> i32
    let a: U128 = u128_from_u64(100)
    let b: U128 = u128_from_u64(200)
    assert u128_lt(a, b) == 1, "100 < 200"
    assert u128_lt(b, a) == 0, "200 not < 100"
    assert u128_lt(a, a) == 0, "not < self"
    0

[[test]]
fn test_u128_lt_hi_matters() -> i32
    let a: U128 = u128_from_parts(0xFFFFFFFFFFFFFFFF, 0)
    let b: U128 = u128_from_parts(0, 1)
    assert u128_lt(a, b) == 1, "hi takes precedence"
    0

# ============================================================================
# Bitwise tests
# ============================================================================

[[test]]
fn test_u128_and() -> i32
    let a: U128 = u128_from_parts(0xFF00FF00FF00FF00, 0x00FF00FF00FF00FF)
    let b: U128 = u128_from_parts(0x0F0F0F0F0F0F0F0F, 0xF0F0F0F0F0F0F0F0)
    let c: U128 = u128_and(a, b)
    assert c.lo == 0x0F000F000F000F00, "and lo"
    assert c.hi == 0x00F000F000F000F0, "and hi"
    0

[[test]]
fn test_u128_or() -> i32
    let a: U128 = u128_from_parts(0xFF00000000000000, 0x00000000000000FF)
    let b: U128 = u128_from_parts(0x00000000000000FF, 0xFF00000000000000)
    let c: U128 = u128_or(a, b)
    assert c.lo == 0xFF000000000000FF, "or lo"
    assert c.hi == 0xFF000000000000FF, "or hi"
    0

[[test]]
fn test_u128_xor() -> i32
    let a: U128 = u128_from_parts(0xAAAAAAAAAAAAAAAA, 0x5555555555555555)
    let b: U128 = u128_from_parts(0x5555555555555555, 0xAAAAAAAAAAAAAAAA)
    let c: U128 = u128_xor(a, b)
    assert c.lo == 0xFFFFFFFFFFFFFFFF, "xor lo"
    assert c.hi == 0xFFFFFFFFFFFFFFFF, "xor hi"
    0

