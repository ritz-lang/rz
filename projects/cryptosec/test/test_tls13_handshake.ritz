# test/test_tls13_handshake.ritz - Tests for TLS 1.3 Handshake Messages

import ritzlib.sys

import cryptosec.mem
import cryptosec.sha256
import cryptosec.tls13_handshake
import cryptosec.tls13_kdf

# ============================================================================
# Transcript Hash Tests
# ============================================================================

[[test]]
fn test_transcript_init() -> i32
    var t: Transcript
    transcript_init(@t)

    if t.bytes_hashed != 0
        return 1
    if t.hash_alg != 0  # SHA-256
        return 2

    return 0

[[test]]
fn test_transcript_update_and_hash() -> i32
    var t: Transcript
    transcript_init(@t)

    # Hash "abc"
    transcript_update(@t, c"abc", 3)

    var hash: [32]u8
    transcript_hash(@t, @hash[0])

    # SHA-256("abc") = ba7816bf...
    if hash[0] != 0xba
        return 1
    if hash[1] != 0x78
        return 2
    if hash[2] != 0x16
        return 3
    if hash[3] != 0xbf
        return 4

    return 0

[[test]]
fn test_transcript_incremental() -> i32
    var t: Transcript
    transcript_init(@t)

    # Hash in parts
    transcript_update(@t, c"a", 1)
    transcript_update(@t, c"bc", 2)

    var hash: [32]u8
    transcript_hash(@t, @hash[0])

    # Should be same as SHA-256("abc")
    if hash[0] != 0xba
        return 1
    if hash[1] != 0x78
        return 2

    return 0

[[test]]
fn test_transcript_multiple_hashes() -> i32
    var t: Transcript
    transcript_init(@t)

    transcript_update(@t, c"hello", 5)

    var hash1: [32]u8
    transcript_hash(@t, @hash1[0])

    # Update more
    transcript_update(@t, c"world", 5)

    var hash2: [32]u8
    transcript_hash(@t, @hash2[0])

    # Hashes should be different
    if mem_eq(@hash1[0], @hash2[0], 32) == 1
        return 1

    return 0

# ============================================================================
# ClientHello Tests
# ============================================================================

[[test]]
fn test_client_hello_init() -> i32
    var ch: ClientHello
    client_hello_init(@ch)

    # Should have random data (check it's not all zeros)
    var all_zero: i32 = 1
    var i: i32 = 0
    while i < 32
        if ch.random[i] != 0
            all_zero = 0
        i += 1

    if all_zero == 1
        return 1  # Random should not be all zeros

    # Should have X25519 key pair
    all_zero = 1
    i = 0
    while i < 32
        if ch.x25519_public[i] != 0
            all_zero = 0
        i += 1

    if all_zero == 1
        return 2  # Public key should not be all zeros

    # Should have cipher suites
    if ch.num_cipher_suites < 1
        return 3

    return 0

[[test]]
fn test_client_hello_set_hostname() -> i32
    var ch: ClientHello
    client_hello_init(@ch)

    client_hello_set_hostname(@ch, c"example.com", 11)

    if ch.hostname_len != 11
        return 1

    if ch.hostname[0] != 101  # 'e'
        return 2
    if ch.hostname[10] != 109  # 'm'
        return 3

    return 0

[[test]]
fn test_client_hello_serialize() -> i32
    var ch: ClientHello
    client_hello_init(@ch)
    client_hello_set_hostname(@ch, c"test.local", 10)

    var buf: [512]u8
    let len: i64 = client_hello_serialize(@ch, @buf[0], 512)

    if len < 100
        return 1  # Too short

    # Check handshake header
    if buf[0] != HS_CLIENT_HELLO
        return 2

    # Check legacy version
    if buf[4] != 0x03 || buf[5] != 0x03
        return 3

    return 0

[[test]]
fn test_client_hello_extensions() -> i32
    var ch: ClientHello
    client_hello_init(@ch)

    var buf: [512]u8
    let len: i64 = client_hello_serialize(@ch, @buf[0], 512)

    # Look for supported_versions extension (type 43 = 0x002B)
    var found_versions: i32 = 0
    var found_key_share: i32 = 0

    var i: i64 = 0
    while i < len - 3
        let ext_type: u16 = ((buf[i] as u16) << 8) | (buf[i + 1] as u16)
        if ext_type == EXT_SUPPORTED_VERSIONS
            found_versions = 1
        if ext_type == EXT_KEY_SHARE
            found_key_share = 1
        i += 1

    if found_versions == 0
        return 1
    if found_key_share == 0
        return 2

    return 0

# ============================================================================
# ServerHello Tests
# ============================================================================

[[test]]
fn test_server_hello_parse_basic() -> i32
    # Minimal ServerHello:
    # version (2) + random (32) + session_id_len (1) + session_id (0) +
    # cipher_suite (2) + compression (1) + extensions_len (2) + extensions
    var data: [128]u8

    var pos: i32 = 0

    # Legacy version TLS 1.2
    data[pos] = 0x03
    data[pos + 1] = 0x03
    pos = pos + 2

    # Random (32 bytes)
    var i: i32 = 0
    while i < 32
        data[pos] = (i + 1) as u8
        pos += 1
        i += 1

    # Session ID length (0)
    data[pos] = 0
    pos += 1

    # Cipher suite: TLS_AES_128_GCM_SHA256
    data[pos] = 0x13
    data[pos + 1] = 0x01
    pos = pos + 2

    # Compression method (null)
    data[pos] = 0
    pos += 1

    # Extensions
    let ext_start: i32 = pos + 2

    # supported_versions extension
    data[ext_start] = 0x00
    data[ext_start + 1] = 0x2b  # Type 43
    data[ext_start + 2] = 0x00
    data[ext_start + 3] = 0x02  # Length 2
    data[ext_start + 4] = 0x03
    data[ext_start + 5] = 0x04  # TLS 1.3

    # key_share extension
    data[ext_start + 6] = 0x00
    data[ext_start + 7] = 0x33  # Type 51
    data[ext_start + 8] = 0x00
    data[ext_start + 9] = 0x24  # Length 36
    data[ext_start + 10] = 0x00
    data[ext_start + 11] = 0x1d  # X25519
    data[ext_start + 12] = 0x00
    data[ext_start + 13] = 0x20  # Key length 32

    # X25519 public key (32 bytes)
    i = 0
    while i < 32
        data[ext_start + 14 + i] = (0x50 + i) as u8
        i += 1

    let ext_len: i32 = 6 + 4 + 36  # supported_versions + key_share
    data[pos] = (ext_len >> 8) as u8
    data[pos + 1] = (ext_len & 0xff) as u8

    let total_len: i32 = pos + 2 + ext_len

    var sh: ServerHello
    let result: i32 = server_hello_parse(@data[0], total_len as i64, @sh)

    if result != 0
        return 1 + (-result)

    if sh.cipher_suite != TLS_AES_128_GCM_SHA256
        return 10

    if sh.negotiated_version != TLS_VERSION_13
        return 11

    if sh.has_key_share != 1
        return 12

    # Check X25519 key was parsed
    if sh.x25519_public[0] != 0x50
        return 13

    return 0

[[test]]
fn test_server_hello_missing_version() -> i32
    # ServerHello without supported_versions extension
    var data: [64]u8

    var pos: i32 = 0

    # Version
    data[pos] = 0x03
    data[pos + 1] = 0x03
    pos = pos + 2

    # Random
    var i: i32 = 0
    while i < 32
        data[pos] = 0
        pos += 1
        i += 1

    # Session ID length
    data[pos] = 0
    pos += 1

    # Cipher suite
    data[pos] = 0x13
    data[pos + 1] = 0x01
    pos = pos + 2

    # Compression
    data[pos] = 0
    pos += 1

    # Extensions length (empty)
    data[pos] = 0
    data[pos + 1] = 0
    pos = pos + 2

    var sh: ServerHello
    let result: i32 = server_hello_parse(@data[0], pos as i64, @sh)

    # Should fail because no TLS 1.3 version
    if result >= 0
        return 1

    return 0

# ============================================================================
# EncryptedExtensions Tests
# ============================================================================

[[test]]
fn test_encrypted_extensions_empty() -> i32
    # Minimal EncryptedExtensions: just 2-byte length (0)
    var data: [2]u8
    data[0] = 0
    data[1] = 0

    var ee: EncryptedExtensions
    let result: i32 = encrypted_extensions_parse(@data[0], 2, @ee)

    if result != 0
        return 1

    if ee.has_server_name != 0
        return 2

    return 0

[[test]]
fn test_encrypted_extensions_with_sni() -> i32
    # EncryptedExtensions with server_name acknowledgment
    var data: [8]u8

    # Extensions length
    data[0] = 0
    data[1] = 4  # 4 bytes of extensions

    # server_name extension (type 0, empty value)
    data[2] = 0
    data[3] = 0  # Type 0
    data[4] = 0
    data[5] = 0  # Length 0

    var ee: EncryptedExtensions
    let result: i32 = encrypted_extensions_parse(@data[0], 6, @ee)

    if result != 0
        return 1

    if ee.has_server_name != 1
        return 2

    return 0

# ============================================================================
# Certificate Message Tests
# ============================================================================

[[test]]
fn test_certificate_parse_single() -> i32
    # Certificate message with one certificate
    var data: [100]u8

    var pos: i32 = 0

    # certificate_request_context (length 0)
    data[pos] = 0
    pos += 1

    # Certificate list length (3 bytes)
    # One cert entry: 3 (cert len) + 20 (cert data) + 2 (ext len) + 0 = 25
    data[pos] = 0
    data[pos + 1] = 0
    data[pos + 2] = 25
    pos = pos + 3

    # Certificate entry 1
    # cert_data length (3 bytes)
    data[pos] = 0
    data[pos + 1] = 0
    data[pos + 2] = 20
    pos = pos + 3

    # cert_data (20 bytes of dummy data)
    var i: i32 = 0
    while i < 20
        data[pos] = (0x30 + i) as u8
        pos += 1
        i += 1

    # Extensions length (2 bytes, 0)
    data[pos] = 0
    data[pos + 1] = 0
    pos = pos + 2

    var cm: CertificateMessage
    let result: i32 = certificate_parse(@data[0], pos as i64, @cm)

    if result != 0
        return 1

    if cm.num_certs != 1
        return 2

    if cm.cert_lens[0] != 20
        return 3

    # Check cert data pointer
    let first_byte: u8 = cm.cert_data[0][0]
    if first_byte != 0x30
        return 4

    return 0

[[test]]
fn test_certificate_parse_chain() -> i32
    # Certificate message with two certificates
    var data: [200]u8

    var pos: i32 = 0

    # certificate_request_context (length 0)
    data[pos] = 0
    pos += 1

    # Certificate list length (3 bytes)
    # Two cert entries: (3+10+2) + (3+15+2) = 35
    data[pos] = 0
    data[pos + 1] = 0
    data[pos + 2] = 35
    pos = pos + 3

    # Certificate entry 1 (10 bytes)
    data[pos] = 0
    data[pos + 1] = 0
    data[pos + 2] = 10
    pos = pos + 3

    var i: i32 = 0
    while i < 10
        data[pos] = 0xAA
        pos += 1
        i += 1

    data[pos] = 0
    data[pos + 1] = 0
    pos = pos + 2

    # Certificate entry 2 (15 bytes)
    data[pos] = 0
    data[pos + 1] = 0
    data[pos + 2] = 15
    pos = pos + 3

    i = 0
    while i < 15
        data[pos] = 0xBB
        pos += 1
        i += 1

    data[pos] = 0
    data[pos + 1] = 0
    pos = pos + 2

    var cm: CertificateMessage
    let result: i32 = certificate_parse(@data[0], pos as i64, @cm)

    if result != 0
        return 1

    if cm.num_certs != 2
        return 2

    if cm.cert_lens[0] != 10
        return 3

    if cm.cert_lens[1] != 15
        return 4

    return 0

# ============================================================================
# CertificateVerify Tests
# ============================================================================

[[test]]
fn test_certificate_verify_parse() -> i32
    var data: [100]u8

    # Signature algorithm RSA-PKCS1-SHA256 (0x0401)
    data[0] = 0x04
    data[1] = 0x01

    # Signature length (32 bytes for test)
    data[2] = 0
    data[3] = 32

    # Signature data
    var i: i32 = 0
    while i < 32
        data[4 + i] = (i + 1) as u8
        i += 1

    var cv: CertificateVerify
    let result: i32 = certificate_verify_parse(@data[0], 36, @cv)

    if result != 0
        return 1

    if cv.algorithm != SIG_RSA_PKCS1_SHA256
        return 2

    if cv.signature_len != 32
        return 3

    if cv.signature[0] != 1
        return 4

    return 0

# ============================================================================
# Finished Message Tests
# ============================================================================

[[test]]
fn test_finished_compute() -> i32
    # Use a known base_key and transcript_hash
    var base_key: [32]u8
    var transcript_hash: [32]u8
    var verify_data: [32]u8

    # Fill with test values
    var i: i32 = 0
    while i < 32
        base_key[i] = (i + 1) as u8
        transcript_hash[i] = (i + 0x10) as u8
        i += 1

    finished_compute(@base_key[0], @transcript_hash[0], @verify_data[0])

    # verify_data should not be all zeros
    var all_zero: i32 = 1
    i = 0
    while i < 32
        if verify_data[i] != 0
            all_zero = 0
        i += 1

    if all_zero == 1
        return 1

    return 0

[[test]]
fn test_finished_verify_success() -> i32
    var base_key: [32]u8
    var transcript_hash: [32]u8
    var verify_data: [32]u8

    var i: i32 = 0
    while i < 32
        base_key[i] = (i + 5) as u8
        transcript_hash[i] = (i + 0x20) as u8
        i += 1

    # Compute expected verify_data
    finished_compute(@base_key[0], @transcript_hash[0], @verify_data[0])

    # Verify should succeed
    let result: i32 = finished_verify(@base_key[0], @transcript_hash[0], @verify_data[0])

    if result != 1
        return 1

    return 0

[[test]]
fn test_finished_verify_failure() -> i32
    var base_key: [32]u8
    var transcript_hash: [32]u8
    var verify_data: [32]u8

    var i: i32 = 0
    while i < 32
        base_key[i] = (i + 5) as u8
        transcript_hash[i] = (i + 0x20) as u8
        verify_data[i] = 0xFF  # Wrong value
        i += 1

    # Verify should fail
    let result: i32 = finished_verify(@base_key[0], @transcript_hash[0], @verify_data[0])

    if result != 0
        return 1

    return 0

[[test]]
fn test_finished_serialize() -> i32
    var verify_data: [32]u8
    var i: i32 = 0
    while i < 32
        verify_data[i] = (i + 1) as u8
        i += 1

    var out: [64]u8
    let len: i64 = finished_serialize(@verify_data[0], @out[0])

    if len != 36
        return 1

    # Check header
    if out[0] != HS_FINISHED
        return 2

    # Check length
    if out[3] != 32
        return 3

    # Check data
    if out[4] != 1
        return 4

    return 0

# ============================================================================
# Handshake Header Tests
# ============================================================================

[[test]]
fn test_handshake_header_parse() -> i32
    var data: [4]u8
    data[0] = HS_CLIENT_HELLO
    data[1] = 0x00
    data[2] = 0x01
    data[3] = 0x00  # Length = 256

    var hdr: HandshakeHeader
    let result: i32 = handshake_header_parse(@data[0], 4, @hdr)

    if result != 0
        return 1

    if hdr.msg_type != HS_CLIENT_HELLO
        return 2

    if hdr.length != 256
        return 3

    return 0

# ============================================================================
# Integration: ClientHello to Transcript
# ============================================================================

[[test]]
fn test_client_hello_transcript() -> i32
    var ch: ClientHello
    client_hello_init(@ch)

    var buf: [512]u8
    let len: i64 = client_hello_serialize(@ch, @buf[0], 512)

    # Add to transcript
    var t: Transcript
    transcript_init(@t)
    transcript_update(@t, @buf[0], len)

    # Get hash
    var hash: [32]u8
    transcript_hash(@t, @hash[0])

    # Should have non-zero hash
    var all_zero: i32 = 1
    var i: i32 = 0
    while i < 32
        if hash[i] != 0
            all_zero = 0
        i += 1

    if all_zero == 1
        return 1

    return 0
