# test/test_bigint.ritz - Tests for big integer arithmetic

import lib.bigint

# ============================================================================
# Basic Operations Tests
# ============================================================================

[[test]]
fn test_bigint_zero()
    var a: BigInt
    bigint_zero(@a)
    assert bigint_is_zero(@a) == 1

[[test]]
fn test_bigint_one()
    var a: BigInt
    bigint_one(@a)
    assert bigint_is_zero(@a) == 0
    assert a.limbs[0] == 1
    assert a.limbs[1] == 0

[[test]]
fn test_bigint_from_u64()
    var a: BigInt
    bigint_from_u64(@a, 0x123456789abcdef0)
    assert a.limbs[0] == 0x123456789abcdef0
    assert a.limbs[1] == 0

[[test]]
fn test_bigint_copy()
    var a: BigInt
    var b: BigInt
    bigint_from_u64(@a, 42)
    bigint_copy(@b, @a)
    assert b.limbs[0] == 42
    assert bigint_eq(@a, @b) == 1

# ============================================================================
# Byte Conversion Tests
# ============================================================================

[[test]]
fn test_bigint_from_bytes_simple()
    var a: BigInt
    var bytes: [4]u8
    bytes[0] = 0x12
    bytes[1] = 0x34
    bytes[2] = 0x56
    bytes[3] = 0x78
    bigint_from_bytes(@a, @bytes[0], 4)
    assert a.limbs[0] == 0x12345678

[[test]]
fn test_bigint_from_bytes_64bit()
    var a: BigInt
    var bytes: [8]u8
    bytes[0] = 0x01
    bytes[1] = 0x02
    bytes[2] = 0x03
    bytes[3] = 0x04
    bytes[4] = 0x05
    bytes[5] = 0x06
    bytes[6] = 0x07
    bytes[7] = 0x08
    bigint_from_bytes(@a, @bytes[0], 8)
    assert a.limbs[0] == 0x0102030405060708

[[test]]
fn test_bigint_from_bytes_multi_limb()
    var a: BigInt
    var bytes: [16]u8
    # First 8 bytes (high limb)
    bytes[0] = 0x11
    bytes[1] = 0x22
    bytes[2] = 0x33
    bytes[3] = 0x44
    bytes[4] = 0x55
    bytes[5] = 0x66
    bytes[6] = 0x77
    bytes[7] = 0x88
    # Last 8 bytes (low limb)
    bytes[8] = 0xaa
    bytes[9] = 0xbb
    bytes[10] = 0xcc
    bytes[11] = 0xdd
    bytes[12] = 0xee
    bytes[13] = 0xff
    bytes[14] = 0x00
    bytes[15] = 0x11
    bigint_from_bytes(@a, @bytes[0], 16)
    # Little-endian limb order, so limbs[0] is low
    assert a.limbs[0] == 0xaabbccddeeff0011
    assert a.limbs[1] == 0x1122334455667788

[[test]]
fn test_bigint_to_bytes_roundtrip()
    var a: BigInt
    var bytes_in: [8]u8
    bytes_in[0] = 0xde
    bytes_in[1] = 0xad
    bytes_in[2] = 0xbe
    bytes_in[3] = 0xef
    bytes_in[4] = 0xca
    bytes_in[5] = 0xfe
    bytes_in[6] = 0xba
    bytes_in[7] = 0xbe
    bigint_from_bytes(@a, @bytes_in[0], 8)

    var bytes_out: [8]u8
    bigint_to_bytes_fixed(@a, @bytes_out[0], 8)

    var i: i32 = 0
    while i < 8
        assert bytes_in[i] == bytes_out[i]
        i += 1

# ============================================================================
# Comparison Tests
# ============================================================================

[[test]]
fn test_bigint_eq()
    var a: BigInt
    var b: BigInt
    bigint_from_u64(@a, 12345)
    bigint_from_u64(@b, 12345)
    assert bigint_eq(@a, @b) == 1

    bigint_from_u64(@b, 12346)
    assert bigint_eq(@a, @b) == 0

[[test]]
fn test_bigint_lt()
    var a: BigInt
    var b: BigInt
    bigint_from_u64(@a, 100)
    bigint_from_u64(@b, 200)
    assert bigint_lt(@a, @b) == 1
    assert bigint_lt(@b, @a) == 0
    assert bigint_lt(@a, @a) == 0

[[test]]
fn test_bigint_ge()
    var a: BigInt
    var b: BigInt
    bigint_from_u64(@a, 100)
    bigint_from_u64(@b, 200)
    assert bigint_ge(@a, @b) == 0
    assert bigint_ge(@b, @a) == 1
    assert bigint_ge(@a, @a) == 1

[[test]]
fn test_bigint_bit_length()
    var a: BigInt
    bigint_from_u64(@a, 0)
    assert bigint_bit_length(@a) == 0

    bigint_from_u64(@a, 1)
    assert bigint_bit_length(@a) == 1

    bigint_from_u64(@a, 255)
    assert bigint_bit_length(@a) == 8

    bigint_from_u64(@a, 256)
    assert bigint_bit_length(@a) == 9

    bigint_from_u64(@a, 0x8000000000000000)
    assert bigint_bit_length(@a) == 64

# ============================================================================
# Arithmetic Tests
# ============================================================================

[[test]]
fn test_bigint_add_simple()
    var a: BigInt
    var b: BigInt
    bigint_from_u64(@a, 100)
    bigint_from_u64(@b, 50)
    bigint_add(@a, @b)
    assert a.limbs[0] == 150

[[test]]
fn test_bigint_add_overflow()
    var a: BigInt
    var b: BigInt
    bigint_from_u64(@a, 0xffffffffffffffff)
    bigint_from_u64(@b, 1)
    let carry: u64 = bigint_add(@a, @b)
    # a should now be 0x10000000000000000 (in two limbs)
    assert a.limbs[0] == 0
    assert a.limbs[1] == 1

[[test]]
fn test_bigint_sub_simple()
    var a: BigInt
    var b: BigInt
    bigint_from_u64(@a, 100)
    bigint_from_u64(@b, 30)
    bigint_sub(@a, @b)
    assert a.limbs[0] == 70

[[test]]
fn test_bigint_mul_simple()
    var a: BigInt
    var b: BigInt
    var result: BigInt
    bigint_from_u64(@a, 12345)
    bigint_from_u64(@b, 6789)
    bigint_mul(@result, @a, @b)
    # 12345 * 6789 = 83810205
    assert result.limbs[0] == 83810205

[[test]]
fn test_bigint_mul_large()
    var a: BigInt
    var b: BigInt
    var result: BigInt
    bigint_from_u64(@a, 0xffffffff)
    bigint_from_u64(@b, 0xffffffff)
    bigint_mul(@result, @a, @b)
    # (2^32 - 1)^2 = 2^64 - 2^33 + 1 = 0xfffffffe00000001
    assert result.limbs[0] == 0xfffffffe00000001

# ============================================================================
# Shift Tests
# ============================================================================

[[test]]
fn test_bigint_shl()
    var a: BigInt
    bigint_from_u64(@a, 1)
    bigint_shl(@a, 64)
    assert a.limbs[0] == 0
    assert a.limbs[1] == 1

[[test]]
fn test_bigint_shr()
    var a: BigInt
    bigint_zero(@a)
    a.limbs[1] = 1
    bigint_shr(@a, 64)
    assert a.limbs[0] == 1
    assert a.limbs[1] == 0

[[test]]
fn test_bigint_get_bit()
    var a: BigInt
    bigint_from_u64(@a, 0b10101010)
    assert bigint_get_bit(@a, 0) == 0
    assert bigint_get_bit(@a, 1) == 1
    assert bigint_get_bit(@a, 2) == 0
    assert bigint_get_bit(@a, 3) == 1
    assert bigint_get_bit(@a, 7) == 1
    assert bigint_get_bit(@a, 8) == 0

# ============================================================================
# Modular Arithmetic Tests
# ============================================================================

[[test]]
fn test_bigint_mod_simple()
    var a: BigInt
    var n: BigInt
    var result: BigInt
    bigint_from_u64(@a, 17)
    bigint_from_u64(@n, 5)
    bigint_mod_fast(@result, @a, @n)
    # 17 mod 5 = 2
    assert result.limbs[0] == 2

[[test]]
fn test_bigint_mod_larger()
    var a: BigInt
    var n: BigInt
    var result: BigInt
    bigint_from_u64(@a, 1000000)
    bigint_from_u64(@n, 97)
    bigint_mod_fast(@result, @a, @n)
    # 1000000 mod 97 = 9 (since 1000000 = 10309 * 97 + 27)
    # Actually: 1000000 / 97 = 10309.27..., 10309 * 97 = 999973, 1000000 - 999973 = 27
    assert result.limbs[0] == 27

[[test]]
fn test_bigint_mod_exp_small()
    var base: BigInt
    var exp: BigInt
    var n: BigInt
    var result: BigInt

    # 2^10 mod 1000 = 1024 mod 1000 = 24
    bigint_from_u64(@base, 2)
    bigint_from_u64(@exp, 10)
    bigint_from_u64(@n, 1000)
    bigint_mod_exp(@result, @base, @exp, @n)
    assert result.limbs[0] == 24

[[test]]
fn test_bigint_mod_exp_fermat()
    var base: BigInt
    var exp: BigInt
    var n: BigInt
    var result: BigInt

    # Fermat's little theorem: a^(p-1) = 1 mod p for prime p
    # 3^6 mod 7 = 729 mod 7 = 1
    bigint_from_u64(@base, 3)
    bigint_from_u64(@exp, 6)
    bigint_from_u64(@n, 7)
    bigint_mod_exp(@result, @base, @exp, @n)
    assert result.limbs[0] == 1

[[test]]
fn test_bigint_mod_exp_rsa_small()
    # Simulate tiny RSA: n = 33 (3 * 11), e = 3, d = 7
    # Encrypt: m^e mod n, Decrypt: c^d mod n
    # m = 5: c = 5^3 mod 33 = 125 mod 33 = 26
    # Verify: 26^7 mod 33 should = 5
    var base: BigInt
    var exp: BigInt
    var n: BigInt
    var result: BigInt

    bigint_from_u64(@base, 5)
    bigint_from_u64(@exp, 3)
    bigint_from_u64(@n, 33)
    bigint_mod_exp(@result, @base, @exp, @n)
    assert result.limbs[0] == 26

    # Decrypt
    bigint_from_u64(@base, 26)
    bigint_from_u64(@exp, 7)
    bigint_mod_exp(@result, @base, @exp, @n)
    assert result.limbs[0] == 5
