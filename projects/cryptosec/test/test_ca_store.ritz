# test/test_ca_store.ritz - Tests for Root CA Store
#
# Tests certificate store initialization, loading, and lookup.

import lib.ca_store
import lib.x509
import lib.mem
import lib.pem

# ============================================================================
# Test Data
# ============================================================================

# A minimal self-signed certificate for testing (base64 PEM content)
# This is a simplified test cert - in production you'd use real CA certs

# PEM-encoded test certificate (self-signed, CN=Test CA)
# Generated with: openssl req -x509 -newkey rsa:2048 -keyout /dev/null -nodes \
#   -subj "/CN=Test Root CA/O=Test Org/C=US" -days 365 -outform PEM
fn get_test_pem_data() -> *u8
    # Small self-signed RSA cert for testing
    # This is a real PEM certificate for test purposes
    return c"-----BEGIN CERTIFICATE-----\nMIIBkTCB+wIJAKHBfpegPpHGMA0GCSqGSIb3DQEBCwUAMBExDzANBgNVBAMMBlRl\nc3RDQTAeFw0yNTAxMDEwMDAwMDBaFw0yNjAxMDEwMDAwMDBaMBExDzANBgNVBAMM\nBlRlc3RDQTBcMA0GCSqGSIb3DQEBAQUAA0sAMEgCQQC5xr0WmjLNkTv2K3LBoEJB\nVH6qN8yBBm8xNzVsHZLmYm5k5mRVZ5BgKWbZqJpbQvRmVmVmZWZmZmZmZmZmZmZm\nAgMBAAGjUzBRMB0GA1UdDgQWBBQQEBAQEBAQEBAQEBAQEBAQEBAQEDAfBgNVHSME\nGDAWgBQQEBAQEBAQEBAQEBAQEBAQEBAQEDAPBgNVHRMBAf8EBTADAQH/MA0GCSqG\nSIb3DQEBCwUAA0EAqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqq\nqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqg==\n-----END CERTIFICATE-----\n"

fn get_test_pem_len() -> i64
    return 583

# ============================================================================
# Basic Initialization Tests
# ============================================================================

[[test]]
fn test_ca_store_init() -> i32
    var store: CaStore
    ca_store_init(&store)

    if ca_store_valid(&store) != 1
        ca_store_destroy(&store)
        return 1

    if ca_store_count(&store) != 0
        ca_store_destroy(&store)
        return 2

    ca_store_destroy(&store)
    return 0

[[test]]
fn test_ca_store_destroy() -> i32
    var store: CaStore
    ca_store_init(&store)

    if ca_store_valid(&store) != 1
        return 1

    ca_store_destroy(&store)

    if ca_store_valid(&store) != 0
        return 2

    return 0

[[test]]
fn test_ca_store_get_empty() -> i32
    var store: CaStore
    ca_store_init(&store)

    # Getting from empty store should return null
    let cert: *X509Certificate = ca_store_get(&store, 0)
    if cert != null
        ca_store_destroy(&store)
        return 1

    let cert2: *X509Certificate = ca_store_get(&store, -1)
    if cert2 != null
        ca_store_destroy(&store)
        return 2

    ca_store_destroy(&store)
    return 0

# ============================================================================
# PEM Bundle Loading Tests
# ============================================================================

# Test loading a small PEM bundle (multiple certs concatenated)
fn get_multi_cert_pem() -> *u8
    # Two minimal PEM certificates concatenated
    # These are simplified test certs - just header/footer structure
    return c"-----BEGIN CERTIFICATE-----\nMIIBkTCB+wIJAKHBfpegPpHGMA0GCSqGSIb3DQEBCwUAMBExDzANBgNVBAMMBlRl\nc3RDQTAeFw0yNTAxMDEwMDAwMDBaFw0yNjAxMDEwMDAwMDBaMBExDzANBgNVBAMM\nBlRlc3RDQTBcMA0GCSqGSIb3DQEBAQUAA0sAMEgCQQC5xr0WmjLNkTv2K3LBoEJB\nVH6qN8yBBm8xNzVsHZLmYm5k5mRVZ5BgKWbZqJpbQvRmVmVmZWZmZmZmZmZmZmZm\nAgMBAAGjUzBRMB0GA1UdDgQWBBQQEBAQEBAQEBAQEBAQEBAQEBAQEDAfBgNVHSME\nGDAWgBQQEBAQEBAQEBAQEBAQEBAQEBAQEDAPBgNVHRMBAf8EBTADAQH/MA0GCSqG\nSIb3DQEBCwUAA0EAqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqq\nqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqg==\n-----END CERTIFICATE-----\n-----BEGIN CERTIFICATE-----\nMIIBkTCB+wIJAKHBfpegPpHGMA0GCSqGSIb3DQEBCwUAMBExDzANBgNVBAMMBlRl\nc3RDQTAeFw0yNTAxMDEwMDAwMDBaFw0yNjAxMDEwMDAwMDBaMBExDzANBgNVBAMM\nBlRlc3RDQTBcMA0GCSqGSIb3DQEBAQUAA0sAMEgCQQC5xr0WmjLNkTv2K3LBoEJB\nVH6qN8yBBm8xNzVsHZLmYm5k5mRVZ5BgKWbZqJpbQvRmVmVmZWZmZmZmZmZmZmZm\nAgMBAAGjUzBRMB0GA1UdDgQWBBQQEBAQEBAQEBAQEBAQEBAQEBAQEDAfBgNVHSME\nGDAWgBQQEBAQEBAQEBAQEBAQEBAQEBAQEDAPBgNVHRMBAf8EBTADAQH/MA0GCSqG\nSIb3DQEBCwUAA0EAqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqq\nqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqg==\n-----END CERTIFICATE-----\n"

fn get_multi_cert_pem_len() -> i64
    return 1166  # 583 * 2

[[test]]
fn test_ca_store_count_pem() -> i32
    let pem: *u8 = get_multi_cert_pem()
    let pem_len: i64 = get_multi_cert_pem_len()

    let count: i32 = pem_count_certificates(pem, pem_len)
    if count != 2
        return 1

    return 0

# ============================================================================
# Certificate Lookup Tests
# ============================================================================

[[test]]
fn test_ca_store_find_by_subject_not_found() -> i32
    var store: CaStore
    ca_store_init(&store)

    # Create a fake X509Name to search for
    var fake_name: X509Name
    mem_zero(&fake_name as *u8, 200)
    fake_name.common_name[0] = 'X'
    fake_name.common_name_len = 1

    let found: *X509Certificate = ca_store_find_by_subject(&store, &fake_name)
    if found != null
        ca_store_destroy(&store)
        return 1

    ca_store_destroy(&store)
    return 0

[[test]]
fn test_ca_store_contains_empty() -> i32
    var store: CaStore
    ca_store_init(&store)

    var dummy_cert: X509Certificate
    mem_zero(&dummy_cert as *u8, 1200)

    let contains: i32 = ca_store_contains(&store, &dummy_cert)
    if contains != 0
        ca_store_destroy(&store)
        return 1

    ca_store_destroy(&store)
    return 0

# ============================================================================
# Array Access Tests
# ============================================================================

[[test]]
fn test_ca_store_as_array() -> i32
    var store: CaStore
    ca_store_init(&store)

    let arr: **X509Certificate = ca_store_as_array(&store)
    if arr == null
        ca_store_destroy(&store)
        return 1

    # Empty store, first element should be null
    if arr[0] != null
        ca_store_destroy(&store)
        return 2

    ca_store_destroy(&store)
    return 0

# ============================================================================
# Edge Case Tests
# ============================================================================

[[test]]
fn test_ca_store_get_out_of_bounds() -> i32
    var store: CaStore
    ca_store_init(&store)

    let cert: *X509Certificate = ca_store_get(&store, 1000)
    if cert != null
        ca_store_destroy(&store)
        return 1

    let cert2: *X509Certificate = ca_store_get(&store, -5)
    if cert2 != null
        ca_store_destroy(&store)
        return 2

    ca_store_destroy(&store)
    return 0

[[test]]
fn test_ca_store_load_empty_bundle() -> i32
    var store: CaStore
    ca_store_init(&store)

    # Empty data should load 0 certs
    let empty: *u8 = c""
    let loaded: i32 = ca_store_load_pem_bundle(&store, empty, 0)

    if loaded != 0
        ca_store_destroy(&store)
        return 1

    if ca_store_count(&store) != 0
        ca_store_destroy(&store)
        return 2

    ca_store_destroy(&store)
    return 0

[[test]]
fn test_ca_store_load_garbage() -> i32
    var store: CaStore
    ca_store_init(&store)

    # Non-PEM data should load 0 certs
    let garbage: *u8 = c"This is not PEM data at all.\nJust random text.\n"
    let loaded: i32 = ca_store_load_pem_bundle(&store, garbage, 48)

    if loaded != 0
        ca_store_destroy(&store)
        return 1

    if ca_store_count(&store) != 0
        ca_store_destroy(&store)
        return 2

    ca_store_destroy(&store)
    return 0

[[test]]
fn test_ca_store_load_partial_pem() -> i32
    var store: CaStore
    ca_store_init(&store)

    # PEM with BEGIN but no END
    let partial: *u8 = c"-----BEGIN CERTIFICATE-----\nSomeBase64Data\n"
    let loaded: i32 = ca_store_load_pem_bundle(&store, partial, 45)

    # Should fail gracefully (load 0)
    if loaded != 0
        ca_store_destroy(&store)
        return 1

    ca_store_destroy(&store)
    return 0

[[test]]
fn test_ca_store_load_non_cert_pem() -> i32
    var store: CaStore
    ca_store_init(&store)

    # PEM with different type (RSA PRIVATE KEY)
    let key_pem: *u8 = c"-----BEGIN RSA PRIVATE KEY-----\nMIIBogIBAAJBAK==\n-----END RSA PRIVATE KEY-----\n"
    let loaded: i32 = ca_store_load_pem_bundle(&store, key_pem, 73)

    # Should skip non-certificate entries
    if loaded != 0
        ca_store_destroy(&store)
        return 1

    ca_store_destroy(&store)
    return 0

# ============================================================================
# File Loading Tests (Conditional)
# ============================================================================

# This test only works if the system CA bundle exists
[[test]]
fn test_ca_store_load_nonexistent_file() -> i32
    var store: CaStore
    ca_store_init(&store)

    # File that definitely doesn't exist
    let path: *u8 = c"/nonexistent/path/to/certs.pem"
    let loaded: i32 = ca_store_load_pem_file(&store, path, 30)

    if loaded != -1
        ca_store_destroy(&store)
        return 1

    ca_store_destroy(&store)
    return 0

# ============================================================================
# Stress Tests
# ============================================================================

[[test]]
fn test_ca_store_multiple_init_destroy() -> i32
    # Multiple init/destroy cycles should work
    var i: i32 = 0
    while i < 5
        var store: CaStore
        ca_store_init(&store)

        if ca_store_valid(&store) != 1
            return 1

        ca_store_destroy(&store)

        if ca_store_valid(&store) != 0
            return 2

        i += 1

    return 0
