# test/test_hmac.ritz - Tests for HMAC implementations
#
# Test vectors from RFC 4231:
# https://datatracker.ietf.org/doc/html/rfc4231
#
# Supports HMAC-SHA-256, HMAC-SHA-384, and HMAC-SHA-512

import ritzlib.sys
import ritzlib.io
import ritzlib.strview

import cryptosec.hmac
import cryptosec.mem

# ============================================================================
# Helper: Compare hash output to expected hex
# ============================================================================

fn hex_char_to_val(c: u8) -> u8
    if c >= 48
        if c <= 57
            return c - 48
    if c >= 97
        if c <= 102
            return c - 97 + 10
    if c >= 65
        if c <= 70
            return c - 65 + 10
    return 0

fn hash_eq_hex(hash: *u8, expected: StrView, len: i32) -> i32
    var i: i32 = 0
    while i < len
        let hi: u8 = hex_char_to_val(expected.get(i * 2))
        let lo: u8 = hex_char_to_val(expected.get(i * 2 + 1))
        let exp_byte: u8 = (hi << 4) | lo
        if hash[i] != exp_byte
            return 0
        i += 1
    return 1

# ============================================================================
# RFC 4231 Test Vectors
# ============================================================================

[[test]]
fn test_hmac_sha256_rfc4231_test1() -> i32
    # Test Case 1
    # Key = 0x0b repeated 20 times
    # Data = "Hi There" (8 bytes)
    # HMAC-SHA-256 = b0344c61d8db38535ca8afceaf0bf12b881dc200c9833da726e9376c2e32cff7
    var key: [20]u8
    var i: i32 = 0
    while i < 20
        key[i] = 0x0b
        i += 1

    let data = "Hi There"
    var mac: [32]u8

    hmac_sha256(@key[0], 20, data.ptr, data.len as u64, @mac[0])

    let expected = "b0344c61d8db38535ca8afceaf0bf12b881dc200c9833da726e9376c2e32cff7"
    if hash_eq_hex(@mac[0], expected, 32) != 1
        return 1
    0

[[test]]
fn test_hmac_sha256_rfc4231_test2() -> i32
    # Test Case 2
    # Key = "Jefe" (4 bytes)
    # Data = "what do ya want for nothing?" (28 bytes)
    # HMAC-SHA-256 = 5bdcc146bf60754e6a042426089575c75a003f089d2739839dec58b964ec3843

    let key = "Jefe"
    let data = "what do ya want for nothing?"
    var mac: [32]u8

    hmac_sha256_str(@key, @data, @mac[0])

    let expected = "5bdcc146bf60754e6a042426089575c75a003f089d2739839dec58b964ec3843"
    if hash_eq_hex(@mac[0], expected, 32) != 1
        return 1
    0

[[test]]
fn test_hmac_sha256_rfc4231_test3() -> i32
    # Test Case 3
    # Key = 0xaa repeated 20 times
    # Data = 0xdd repeated 50 times
    # HMAC-SHA-256 = 773ea91e36800e46854db8ebd09181a72959098b3ef8c122d9635514ced565fe

    var key: [20]u8
    var i: i32 = 0
    while i < 20
        key[i] = 0xaa
        i += 1

    var data: [50]u8
    i = 0
    while i < 50
        data[i] = 0xdd
        i += 1

    var mac: [32]u8
    hmac_sha256(@key[0], 20, @data[0], 50, @mac[0])

    let expected = "773ea91e36800e46854db8ebd09181a72959098b3ef8c122d9635514ced565fe"
    if hash_eq_hex(@mac[0], expected, 32) != 1
        return 1
    0

[[test]]
fn test_hmac_sha256_rfc4231_test4() -> i32
    # Test Case 4
    # Key = 0x0102030405060708090a0b0c0d0e0f10111213141516171819 (25 bytes)
    # Data = 0xcd repeated 50 times
    # HMAC-SHA-256 = 82558a389a443c0ea4cc819899f2083a85f0faa3e578f8077a2e3ff46729665b

    var key: [25]u8
    var i: i32 = 0
    while i < 25
        key[i] = (i + 1) as u8
        i += 1

    var data: [50]u8
    i = 0
    while i < 50
        data[i] = 0xcd
        i += 1

    var mac: [32]u8
    hmac_sha256(@key[0], 25, @data[0], 50, @mac[0])

    let expected = "82558a389a443c0ea4cc819899f2083a85f0faa3e578f8077a2e3ff46729665b"
    if hash_eq_hex(@mac[0], expected, 32) != 1
        return 1
    0

[[test]]
fn test_hmac_sha256_rfc4231_test6() -> i32
    # Test Case 6 (Test Case 5 tests truncation, skip it)
    # Key = 0xaa repeated 131 times (longer than block size)
    # Data = "Test Using Larger Than Block-Size Key - Hash Key First"
    # HMAC-SHA-256 = 60e431591ee0b67f0d8a26aacbf5b77f8e0bc6213728c5140546040f0ee37f54

    var key: [131]u8
    var i: i32 = 0
    while i < 131
        key[i] = 0xaa
        i += 1

    let data = "Test Using Larger Than Block-Size Key - Hash Key First"
    var mac: [32]u8

    hmac_sha256(@key[0], 131, data.ptr, data.len as u64, @mac[0])

    let expected = "60e431591ee0b67f0d8a26aacbf5b77f8e0bc6213728c5140546040f0ee37f54"
    if hash_eq_hex(@mac[0], expected, 32) != 1
        return 1
    0

[[test]]
fn test_hmac_sha256_rfc4231_test7() -> i32
    # Test Case 7
    # Key = 0xaa repeated 131 times
    # Data = "This is a test using a larger than block-size key and a larger than block-size data. The key needs to be hashed before being used by the HMAC algorithm."
    # HMAC-SHA-256 = 9b09ffa71b942fcb27635fbcd5b0e944bfdc63644f0713938a7f51535c3a35e2

    var key: [131]u8
    var i: i32 = 0
    while i < 131
        key[i] = 0xaa
        i += 1

    let data = "This is a test using a larger than block-size key and a larger than block-size data. The key needs to be hashed before being used by the HMAC algorithm."
    var mac: [32]u8

    hmac_sha256(@key[0], 131, data.ptr, data.len as u64, @mac[0])

    let expected = "9b09ffa71b942fcb27635fbcd5b0e944bfdc63644f0713938a7f51535c3a35e2"
    if hash_eq_hex(@mac[0], expected, 32) != 1
        return 1
    0

# ============================================================================
# Edge cases
# ============================================================================

[[test]]
fn test_hmac_sha256_empty_data() -> i32
    # HMAC with empty data
    var key: [16]u8
    var i: i32 = 0
    while i < 16
        key[i] = (i + 1) as u8
        i += 1

    let empty = ""
    var mac: [32]u8
    hmac_sha256(@key[0], 16, empty.ptr, 0, @mac[0])

    # Just verify it produces output (not all zeros)
    if mem_is_zero(@mac[0], 32) == 1
        return 1
    0

[[test]]
fn test_hmac_sha256_deterministic() -> i32
    # Same inputs should produce same output
    let key = "secret"
    let data = "message"

    var mac1: [32]u8
    var mac2: [32]u8

    hmac_sha256_str(@key, @data, @mac1[0])
    hmac_sha256_str(@key, @data, @mac2[0])

    if mem_eq(@mac1[0], @mac2[0], 32) != 1
        return 1
    0

[[test]]
fn test_hmac_sha256_different_keys() -> i32
    # Different keys should produce different MACs
    let key1 = "key1"
    let key2 = "key2"
    let data = "message"

    var mac1: [32]u8
    var mac2: [32]u8

    hmac_sha256_str(@key1, @data, @mac1[0])
    hmac_sha256_str(@key2, @data, @mac2[0])

    if mem_eq(@mac1[0], @mac2[0], 32) == 1
        return 1  # Should be different!
    0

[[test]]
fn test_hmac_sha256_different_data() -> i32
    # Different data should produce different MACs
    let key = "secret"
    let data1 = "message1"
    let data2 = "message2"

    var mac1: [32]u8
    var mac2: [32]u8

    hmac_sha256_str(@key, @data1, @mac1[0])
    hmac_sha256_str(@key, @data2, @mac2[0])

    if mem_eq(@mac1[0], @mac2[0], 32) == 1
        return 1  # Should be different!
    0

# ============================================================================
# HMAC-SHA-512 Tests (RFC 4231)
# ============================================================================

[[test]]
fn test_hmac_sha512_rfc4231_test1() -> i32
    # Test Case 1
    # Key = 0x0b repeated 20 times
    # Data = "Hi There" (8 bytes)
    # HMAC-SHA-512 = 87aa7cdea5ef619d4ff0b4241a1d6cb02379f4e2ce4ec2787ad0b30545e17cde
    #                daa833b7d6b8a702038b274eaea3f4e4be9d914eeb61f1702e696c203a126854
    var key: [20]u8
    var i: i32 = 0
    while i < 20
        key[i] = 0x0b
        i += 1

    let data = "Hi There"
    var mac: [64]u8

    hmac_sha512(@key[0], 20, data.ptr, data.len as u64, @mac[0])

    let expected = "87aa7cdea5ef619d4ff0b4241a1d6cb02379f4e2ce4ec2787ad0b30545e17cdedaa833b7d6b8a702038b274eaea3f4e4be9d914eeb61f1702e696c203a126854"
    if hash_eq_hex(@mac[0], expected, 64) != 1
        return 1
    0

[[test]]
fn test_hmac_sha512_rfc4231_test2() -> i32
    # Test Case 2
    # Key = "Jefe" (4 bytes)
    # Data = "what do ya want for nothing?" (28 bytes)
    # HMAC-SHA-512 = 164b7a7bfcf819e2e395fbe73b56e0a387bd64222e831fd610270cd7ea250554
    #                9758bf75c05a994a6d034f65f8f0e6fdcaeab1a34d4a6b4b636e070a38bce737

    let key = "Jefe"
    let data = "what do ya want for nothing?"
    var mac: [64]u8

    hmac_sha512_str(@key, @data, @mac[0])

    let expected = "164b7a7bfcf819e2e395fbe73b56e0a387bd64222e831fd610270cd7ea2505549758bf75c05a994a6d034f65f8f0e6fdcaeab1a34d4a6b4b636e070a38bce737"
    if hash_eq_hex(@mac[0], expected, 64) != 1
        return 1
    0

[[test]]
fn test_hmac_sha512_deterministic() -> i32
    let key = "secret"
    let data = "message"

    var mac1: [64]u8
    var mac2: [64]u8

    hmac_sha512_str(@key, @data, @mac1[0])
    hmac_sha512_str(@key, @data, @mac2[0])

    if mem_eq(@mac1[0], @mac2[0], 64) != 1
        return 1
    0

# ============================================================================
# HMAC-SHA-384 Tests (RFC 4231)
# ============================================================================

[[test]]
fn test_hmac_sha384_rfc4231_test1() -> i32
    # Test Case 1
    # Key = 0x0b repeated 20 times
    # Data = "Hi There" (8 bytes)
    # HMAC-SHA-384 = afd03944d84895626b0825f4ab46907f15f9dadbe4101ec682aa034c7cebc59c
    #                faea9ea9076ede7f4af152e8b2fa9cb6
    var key: [20]u8
    var i: i32 = 0
    while i < 20
        key[i] = 0x0b
        i += 1

    let data = "Hi There"
    var mac: [48]u8

    hmac_sha384(@key[0], 20, data.ptr, data.len as u64, @mac[0])

    let expected = "afd03944d84895626b0825f4ab46907f15f9dadbe4101ec682aa034c7cebc59cfaea9ea9076ede7f4af152e8b2fa9cb6"
    if hash_eq_hex(@mac[0], expected, 48) != 1
        return 1
    0

[[test]]
fn test_hmac_sha384_rfc4231_test2() -> i32
    # Test Case 2
    # Key = "Jefe" (4 bytes)
    # Data = "what do ya want for nothing?" (28 bytes)
    # HMAC-SHA-384 = af45d2e376484031617f78d2b58a6b1b9c7ef464f5a01b47e42ec3736322445e
    #                8e2240ca5e69e2c78b3239ecfab21649

    let key = "Jefe"
    let data = "what do ya want for nothing?"
    var mac: [48]u8

    hmac_sha384_str(@key, @data, @mac[0])

    let expected = "af45d2e376484031617f78d2b58a6b1b9c7ef464f5a01b47e42ec3736322445e8e2240ca5e69e2c78b3239ecfab21649"
    if hash_eq_hex(@mac[0], expected, 48) != 1
        return 1
    0

[[test]]
fn test_hmac_sha384_deterministic() -> i32
    let key = "secret"
    let data = "message"

    var mac1: [48]u8
    var mac2: [48]u8

    hmac_sha384_str(@key, @data, @mac1[0])
    hmac_sha384_str(@key, @data, @mac2[0])

    if mem_eq(@mac1[0], @mac2[0], 48) != 1
        return 1
    0
