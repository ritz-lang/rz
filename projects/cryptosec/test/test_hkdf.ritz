# test/test_hkdf.ritz - Tests for HKDF (RFC 5869)
#
# HKDF = HMAC-based Key Derivation Function
# Test vectors from RFC 5869

import ritzlib.sys
import ritzlib.io

import lib.hkdf
import lib.mem

# ============================================================================
# Helper: Compare output to expected hex
# ============================================================================

fn hex_char_to_val(c: u8) -> u8
    if c >= 48
        if c <= 57
            return c - 48
    if c >= 97
        if c <= 102
            return c - 97 + 10
    if c >= 65
        if c <= 70
            return c - 65 + 10
    return 0

fn bytes_eq_hex(bytes: *u8, hex: *u8, len: i32) -> i32
    var i: i32 = 0
    while i < len
        let hi: u8 = hex_char_to_val(hex[i * 2])
        let lo: u8 = hex_char_to_val(hex[i * 2 + 1])
        let expected: u8 = (hi << 4) | lo
        if bytes[i] != expected
            return 0
        i += 1
    return 1

fn fill_from_hex(out: *u8, hex: *u8, len: i32)
    var i: i32 = 0
    while i < len
        let hi: u8 = hex_char_to_val(hex[i * 2])
        let lo: u8 = hex_char_to_val(hex[i * 2 + 1])
        out[i] = (hi << 4) | lo
        i += 1

# ============================================================================
# RFC 5869 Test Vectors - Test Case 1
# ============================================================================

[[test]]
fn test_hkdf_sha256_rfc5869_test1() -> i32
    # Test Case 1 - Basic test
    # IKM  = 0x0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b (22 octets)
    # salt = 0x000102030405060708090a0b0c (13 octets)
    # info = 0xf0f1f2f3f4f5f6f7f8f9 (10 octets)
    # L    = 42
    # PRK  = 0x077709362c2e32df0ddc3f0dc47bba63...
    # OKM  = 0x3cb25f25faacd57a90434f64d0362f2a...

    var ikm: [22]u8
    var i: i32 = 0
    while i < 22
        ikm[i] = 0x0b
        i += 1

    var salt: [13]u8
    i = 0
    while i < 13
        salt[i] = i as u8
        i += 1

    var info: [10]u8
    i = 0
    while i < 10
        info[i] = (0xf0 + i) as u8
        i += 1

    var okm: [42]u8
    hkdf_sha256(&salt[0], 13, &ikm[0], 22, &info[0], 10, &okm[0], 42)

    let expected: *u8 = c"3cb25f25faacd57a90434f64d0362f2a2d2d0a90cf1a5a4c5db02d56ecc4c5bf34007208d5b887185865"
    if bytes_eq_hex(&okm[0], expected, 42) != 1
        return 1
    0

[[test]]
fn test_hkdf_sha256_rfc5869_test2() -> i32
    # Test Case 2 - Longer inputs/outputs
    # IKM  = 0x000102...4f (80 octets)
    # salt = 0x606162...af (80 octets)
    # info = 0xb0b1b2...ff (80 octets)
    # L    = 82

    var ikm: [80]u8
    var i: i32 = 0
    while i < 80
        ikm[i] = i as u8
        i += 1

    var salt: [80]u8
    i = 0
    while i < 80
        salt[i] = (0x60 + i) as u8
        i += 1

    var info: [80]u8
    i = 0
    while i < 80
        info[i] = (0xb0 + i) as u8
        i += 1

    var okm: [82]u8
    hkdf_sha256(&salt[0], 80, &ikm[0], 80, &info[0], 80, &okm[0], 82)

    let expected: *u8 = c"b11e398dc80327a1c8e7f78c596a49344f012eda2d4efad8a050cc4c19afa97c59045a99cac7827271cb41c65e590e09da3275600c2f09b8367793a9aca3db71cc30c58179ec3e87c14c01d5c1f3434f1d87"
    if bytes_eq_hex(&okm[0], expected, 82) != 1
        return 1
    0

[[test]]
fn test_hkdf_sha256_rfc5869_test3() -> i32
    # Test Case 3 - Zero-length salt/info
    # IKM  = 0x0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b (22 octets)
    # salt = (0 octets)
    # info = (0 octets)
    # L    = 42

    var ikm: [22]u8
    var i: i32 = 0
    while i < 22
        ikm[i] = 0x0b
        i += 1

    var okm: [42]u8
    hkdf_sha256(null, 0, &ikm[0], 22, null, 0, &okm[0], 42)

    let expected: *u8 = c"8da4e775a563c18f715f802a063c5a31b8a11f5c5ee1879ec3454e5f3c738d2d9d201395faa4b61a96c8"
    if bytes_eq_hex(&okm[0], expected, 42) != 1
        return 1
    0

# ============================================================================
# HKDF-Extract tests
# ============================================================================

[[test]]
fn test_hkdf_extract_basic() -> i32
    # Test extract step alone
    var ikm: [22]u8
    var i: i32 = 0
    while i < 22
        ikm[i] = 0x0b
        i += 1

    var salt: [13]u8
    i = 0
    while i < 13
        salt[i] = i as u8
        i += 1

    var prk: [32]u8
    hkdf_extract(&salt[0], 13, &ikm[0], 22, &prk[0])

    let expected: *u8 = c"077709362c2e32df0ddc3f0dc47bba6390b6c73bb50f9c3122ec844ad7c2b3e5"
    if bytes_eq_hex(&prk[0], expected, 32) != 1
        return 1
    0

[[test]]
fn test_hkdf_extract_no_salt() -> i32
    # Extract with zero-length salt
    var ikm: [22]u8
    var i: i32 = 0
    while i < 22
        ikm[i] = 0x0b
        i += 1

    var prk: [32]u8
    hkdf_extract(null, 0, &ikm[0], 22, &prk[0])

    # PRK should not be all zeros
    if mem_is_zero(&prk[0], 32) == 1
        return 1
    0

# ============================================================================
# HKDF-Expand tests
# ============================================================================

[[test]]
fn test_hkdf_expand_basic() -> i32
    # Test expand step with known PRK
    # PRK from test case 1
    var prk: [32]u8
    fill_from_hex(&prk[0], c"077709362c2e32df0ddc3f0dc47bba6390b6c73bb50f9c3122ec844ad7c2b3e5", 32)

    var info: [10]u8
    var i: i32 = 0
    while i < 10
        info[i] = (0xf0 + i) as u8
        i += 1

    var okm: [42]u8
    hkdf_expand(&prk[0], &info[0], 10, &okm[0], 42)

    let expected: *u8 = c"3cb25f25faacd57a90434f64d0362f2a2d2d0a90cf1a5a4c5db02d56ecc4c5bf34007208d5b887185865"
    if bytes_eq_hex(&okm[0], expected, 42) != 1
        return 1
    0

[[test]]
fn test_hkdf_expand_no_info() -> i32
    # Expand with zero-length info
    var prk: [32]u8
    fill_from_hex(&prk[0], c"077709362c2e32df0ddc3f0dc47bba6390b6c73bb50f9c3122ec844ad7c2b3e5", 32)

    var okm: [32]u8
    hkdf_expand(&prk[0], null, 0, &okm[0], 32)

    # Output should not be all zeros
    if mem_is_zero(&okm[0], 32) == 1
        return 1
    0

# ============================================================================
# Edge cases
# ============================================================================

[[test]]
fn test_hkdf_deterministic() -> i32
    # Same inputs should produce same output
    var ikm: [16]u8
    var i: i32 = 0
    while i < 16
        ikm[i] = (i + 1) as u8
        i += 1

    let salt: *u8 = c"salt"
    let info: *u8 = c"info"

    var okm1: [32]u8
    var okm2: [32]u8

    hkdf_sha256(salt, 4, &ikm[0], 16, info, 4, &okm1[0], 32)
    hkdf_sha256(salt, 4, &ikm[0], 16, info, 4, &okm2[0], 32)

    if mem_eq(&okm1[0], &okm2[0], 32) != 1
        return 1
    0

[[test]]
fn test_hkdf_different_info_different_output() -> i32
    # Different info should produce different output
    var ikm: [16]u8
    var i: i32 = 0
    while i < 16
        ikm[i] = (i + 1) as u8
        i += 1

    let salt: *u8 = c"salt"
    let info1: *u8 = c"info1"
    let info2: *u8 = c"info2"

    var okm1: [32]u8
    var okm2: [32]u8

    hkdf_sha256(salt, 4, &ikm[0], 16, info1, 5, &okm1[0], 32)
    hkdf_sha256(salt, 4, &ikm[0], 16, info2, 5, &okm2[0], 32)

    if mem_eq(&okm1[0], &okm2[0], 32) == 1
        return 1  # Should be different!
    0

[[test]]
fn test_hkdf_short_output() -> i32
    # Request only 16 bytes
    var ikm: [16]u8
    var i: i32 = 0
    while i < 16
        ikm[i] = 0xaa
        i += 1

    var okm: [16]u8
    hkdf_sha256(null, 0, &ikm[0], 16, null, 0, &okm[0], 16)

    if mem_is_zero(&okm[0], 16) == 1
        return 1
    0

