# test/test_p256.ritz - Tests for P-256 (secp256r1) Elliptic Curve
#
# Test vectors from NIST FIPS 186-4 and RFC 6979

import ritzlib.sys
import lib.p256
import lib.mem

# ============================================================================
# Field Element Tests
# ============================================================================

[[test]]
fn test_fep256_zero() -> i32
    var a: FeP256
    fep256_zero(&a)

    if a.limbs[0] != 0
        return 1
    if a.limbs[1] != 0
        return 2
    if a.limbs[2] != 0
        return 3
    if a.limbs[3] != 0
        return 4
    if fep256_is_zero(&a) != 1
        return 5
    return 0

[[test]]
fn test_fep256_one() -> i32
    var a: FeP256
    fep256_one(&a)

    if a.limbs[0] != 1
        return 1
    if a.limbs[1] != 0
        return 2
    if a.limbs[2] != 0
        return 3
    if a.limbs[3] != 0
        return 4
    if fep256_is_zero(&a) != 0
        return 5
    return 0

[[test]]
fn test_fep256_copy() -> i32
    var a: FeP256
    var b: FeP256

    a.limbs[0] = 0x1234567890ABCDEF
    a.limbs[1] = 0xFEDCBA0987654321
    a.limbs[2] = 0x0011223344556677
    a.limbs[3] = 0x8899AABBCCDDEEFF

    fep256_copy(&b, &a)

    if b.limbs[0] != a.limbs[0]
        return 1
    if b.limbs[1] != a.limbs[1]
        return 2
    if b.limbs[2] != a.limbs[2]
        return 3
    if b.limbs[3] != a.limbs[3]
        return 4
    return 0

[[test]]
fn test_fep256_cmp_equal() -> i32
    var a: FeP256
    var b: FeP256

    a.limbs[0] = 0x1234
    a.limbs[1] = 0x5678
    a.limbs[2] = 0x9ABC
    a.limbs[3] = 0xDEF0

    fep256_copy(&b, &a)

    if fep256_cmp(&a, &b) != 0
        return 1
    return 0

[[test]]
fn test_fep256_cmp_less() -> i32
    var a: FeP256
    var b: FeP256

    fep256_one(&a)
    fep256_zero(&b)
    b.limbs[0] = 2

    if fep256_cmp(&a, &b) != -1
        return 1
    return 0

[[test]]
fn test_fep256_cmp_greater() -> i32
    var a: FeP256
    var b: FeP256

    fep256_zero(&a)
    a.limbs[3] = 1

    fep256_one(&b)

    if fep256_cmp(&a, &b) != 1
        return 1
    return 0

# ============================================================================
# Byte Conversion Tests
# ============================================================================

[[test]]
fn test_fep256_from_bytes() -> i32
    # Test value: 0x0102030405060708090A0B0C0D0E0F101112131415161718191A1B1C1D1E1F20
    var data: [32]u8
    var i: i32 = 0
    while i < 32
        data[i] = (i + 1) as u8
        i += 1

    var a: FeP256
    fep256_from_bytes(&a, &data[0])

    # In little-endian limbs:
    # limbs[3] = 0x0102030405060708
    # limbs[2] = 0x090A0B0C0D0E0F10
    # limbs[1] = 0x1112131415161718
    # limbs[0] = 0x191A1B1C1D1E1F20
    if a.limbs[3] != 0x0102030405060708
        return 1
    if a.limbs[2] != 0x090A0B0C0D0E0F10
        return 2
    if a.limbs[1] != 0x1112131415161718
        return 3
    if a.limbs[0] != 0x191A1B1C1D1E1F20
        return 4
    return 0

[[test]]
fn test_fep256_to_bytes() -> i32
    var a: FeP256
    a.limbs[0] = 0x191A1B1C1D1E1F20
    a.limbs[1] = 0x1112131415161718
    a.limbs[2] = 0x090A0B0C0D0E0F10
    a.limbs[3] = 0x0102030405060708

    var out: [32]u8
    fep256_to_bytes(&a, &out[0])

    # Should get sequential bytes 1-32
    var i: i32 = 0
    while i < 32
        if out[i] != (i + 1) as u8
            return i + 1
        i += 1
    return 0

[[test]]
fn test_fep256_roundtrip() -> i32
    var a: FeP256
    a.limbs[0] = 0xDEADBEEFCAFEBABE
    a.limbs[1] = 0x123456789ABCDEF0
    a.limbs[2] = 0xFEDCBA9876543210
    a.limbs[3] = 0x0011223344556677

    var bytes: [32]u8
    fep256_to_bytes(&a, &bytes[0])

    var b: FeP256
    fep256_from_bytes(&b, &bytes[0])

    if fep256_cmp(&a, &b) != 0
        return 1
    return 0

# ============================================================================
# Addition Tests
# ============================================================================

[[test]]
fn test_fep256_add_simple() -> i32
    var a: FeP256
    var b: FeP256
    var c: FeP256

    fep256_one(&a)
    fep256_one(&b)
    fep256_add(&c, &a, &b)

    if c.limbs[0] != 2
        return 1
    if c.limbs[1] != 0
        return 2
    if c.limbs[2] != 0
        return 3
    if c.limbs[3] != 0
        return 4
    return 0

[[test]]
fn test_fep256_add_with_carry() -> i32
    var a: FeP256
    var b: FeP256
    var c: FeP256

    fep256_zero(&a)
    a.limbs[0] = 0xFFFFFFFFFFFFFFFF

    fep256_one(&b)
    fep256_add(&c, &a, &b)

    # Should carry to limb 1
    if c.limbs[0] != 0
        return 1
    if c.limbs[1] != 1
        return 2
    return 0

# ============================================================================
# Subtraction Tests
# ============================================================================

[[test]]
fn test_fep256_sub_simple() -> i32
    var a: FeP256
    var b: FeP256
    var c: FeP256

    fep256_zero(&a)
    a.limbs[0] = 5

    fep256_zero(&b)
    b.limbs[0] = 3

    fep256_sub(&c, &a, &b)

    if c.limbs[0] != 2
        return 1
    if c.limbs[1] != 0
        return 2
    return 0

[[test]]
fn test_fep256_sub_wrap() -> i32
    # 0 - 1 should wrap to p - 1
    var a: FeP256
    var b: FeP256
    var c: FeP256

    fep256_zero(&a)
    fep256_one(&b)
    fep256_sub(&c, &a, &b)

    # Result should be p - 1
    # p = FFFFFFFF00000001000000000000000000000000FFFFFFFFFFFFFFFFFFFFFFFF
    # p - 1 = FFFFFFFF00000001000000000000000000000000FFFFFFFFFFFFFFFFFFFFFFFE
    if c.limbs[0] != 0xFFFFFFFFFFFFFFFE
        return 1
    if c.limbs[1] != 0x00000000FFFFFFFF
        return 2
    if c.limbs[2] != 0x0000000000000000
        return 3
    if c.limbs[3] != 0xFFFFFFFF00000001
        return 4
    return 0

# ============================================================================
# Negation Tests
# ============================================================================

[[test]]
fn test_fep256_neg_zero() -> i32
    var a: FeP256
    var c: FeP256

    fep256_zero(&a)
    fep256_neg(&c, &a)

    if fep256_is_zero(&c) != 1
        return 1
    return 0

[[test]]
fn test_fep256_neg_one() -> i32
    var a: FeP256
    var c: FeP256

    fep256_one(&a)
    fep256_neg(&c, &a)

    # -1 mod p -= 1
    if c.limbs[0] != 0xFFFFFFFFFFFFFFFE
        return 1
    return 0

[[test]]
fn test_fep256_neg_double() -> i32
    # -(-a) = a
    var a: FeP256
    var b: FeP256
    var c: FeP256

    fep256_zero(&a)
    a.limbs[0] = 12345

    fep256_neg(&b, &a)
    fep256_neg(&c, &b)

    if fep256_cmp(&a, &c) != 0
        return 1
    return 0

# ============================================================================
# Multiplication Tests
# ============================================================================

[[test]]
fn test_fep256_mul_one() -> i32
    var a: FeP256
    var one: FeP256
    var c: FeP256

    fep256_zero(&a)
    a.limbs[0] = 0x123456789ABCDEF0

    fep256_one(&one)
    fep256_mul(&c, &a, &one)

    if fep256_cmp(&a, &c) != 0
        return 1
    return 0

[[test]]
fn test_fep256_mul_zero() -> i32
    var a: FeP256
    var zero: FeP256
    var c: FeP256

    fep256_zero(&a)
    a.limbs[0] = 0x123456789ABCDEF0

    fep256_zero(&zero)
    fep256_mul(&c, &a, &zero)

    if fep256_is_zero(&c) != 1
        return 1
    return 0

[[test]]
fn test_fep256_mul_small() -> i32
    var a: FeP256
    var b: FeP256
    var c: FeP256

    fep256_zero(&a)
    a.limbs[0] = 7

    fep256_zero(&b)
    b.limbs[0] = 11

    fep256_mul(&c, &a, &b)

    if c.limbs[0] != 77
        return 1
    if c.limbs[1] != 0
        return 2
    return 0

# ============================================================================
# Squaring Tests
# ============================================================================

[[test]]
fn test_fep256_sqr_small() -> i32
    var a: FeP256
    var c: FeP256

    fep256_zero(&a)
    a.limbs[0] = 9

    fep256_sqr(&c, &a)

    if c.limbs[0] != 81
        return 1
    if c.limbs[1] != 0
        return 2
    return 0

[[test]]
fn test_fep256_sqr_equals_mul() -> i32
    var a: FeP256
    var sqr: FeP256
    var mul: FeP256

    fep256_zero(&a)
    a.limbs[0] = 0x123456789ABCDEF0
    a.limbs[1] = 0xFEDCBA9876543210

    fep256_sqr(&sqr, &a)
    fep256_mul(&mul, &a, &a)

    if fep256_cmp(&sqr, &mul) != 0
        return 1
    return 0

