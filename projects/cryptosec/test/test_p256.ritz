[[test]]
fn test_fep256_inv_one() -> i32
    # 1^(-1) = 1
    var one: FeP256
    var inv: FeP256

    fep256_one(&one)
    fep256_inv(&inv, &one)

    if inv.limbs[0] != 1
        return 1
    if inv.limbs[1] != 0
        return 2
    if inv.limbs[2] != 0
        return 3
    if inv.limbs[3] != 0
        return 4
    return 0

