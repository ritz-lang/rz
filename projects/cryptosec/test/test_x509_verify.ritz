# test/test_x509_verify.ritz - Tests for X.509 certificate chain validation

import cryptosec.x509
import cryptosec.x509_verify
import cryptosec.asn1
import cryptosec.mem
import cryptosec.rsa

# ============================================================================
# Certificate Signature Verification Tests
# ============================================================================

[[test]]
fn test_x509_verify_self_signed_rsa()
    # Create a minimal self-signed RSA certificate for testing
    # This tests the signature verification path
    #
    # For a real test, we'd use an actual certificate. For now, we test
    # the verification infrastructure with invalid signatures to ensure
    # proper rejection.

    # Minimal test: verify that x509_verify_signature exists and returns
    # proper error codes for invalid inputs

    var cert: X509Certificate
    mem_zero(@cert as *u8, 1200)

    cert.sig_algorithm = SIG_ALG_SHA256_RSA
    cert.tbs_data = null
    cert.tbs_len = 0
    cert.signature_len = 0

    var issuer_key: X509PublicKey
    issuer_key.algorithm = PUBKEY_TYPE_RSA
    issuer_key.key_len = 0

    # Should fail with null/empty data
    let result: i32 = x509_verify_signature(@cert, @issuer_key)
    assert result == 0

[[test]]
fn test_x509_verify_algorithm_mismatch()
    # Test that algorithm mismatch is detected
    var cert: X509Certificate
    mem_zero(@cert as *u8, 1200)

    cert.sig_algorithm = SIG_ALG_SHA256_RSA

    var issuer_key: X509PublicKey
    issuer_key.algorithm = PUBKEY_TYPE_EC  # Mismatch: cert expects RSA

    let result: i32 = x509_verify_signature(@cert, @issuer_key)
    assert result == 0  # Should fail due to algorithm mismatch

[[test]]
fn test_x509_verify_unknown_algorithm()
    var cert: X509Certificate
    mem_zero(@cert as *u8, 1200)

    cert.sig_algorithm = SIG_ALG_UNKNOWN

    var issuer_key: X509PublicKey
    issuer_key.algorithm = PUBKEY_TYPE_RSA

    let result: i32 = x509_verify_signature(@cert, @issuer_key)
    assert result == 0  # Should fail for unknown algorithm

# ============================================================================
# Certificate Chain Validation Tests
# ============================================================================

[[test]]
fn test_x509_chain_empty()
    # Empty chain should fail
    var chain: [4]*X509Certificate
    chain[0] = null
    chain[1] = null
    chain[2] = null
    chain[3] = null

    let result: i32 = x509_verify_chain(@chain[0], 0, null, 0)
    assert result == 0

[[test]]
fn test_x509_chain_single_self_signed()
    # Single self-signed certificate (root CA)
    # Should pass if it's in the trust store

    var cert: X509Certificate
    mem_zero(@cert as *u8, 1200)

    # Make it "self-signed" by having issuer == subject
    cert.issuer.der_data = @cert.subject.common_name[0]
    cert.issuer.der_len = 10
    cert.subject.der_data = @cert.subject.common_name[0]
    cert.subject.der_len = 10

    cert.is_ca = 1

    # We can't fully test without a real certificate, but we can test
    # the structure. For now, verify the function exists.
    assert x509_is_self_signed(@cert) == 1

# ============================================================================
# Hostname Verification Tests
# ============================================================================

[[test]]
fn test_hostname_match_exact()
    var cn: [20]u8
    cn[0] = 0x65  # 'e'
    cn[1] = 0x78  # 'x'
    cn[2] = 0x61  # 'a'
    cn[3] = 0x6d  # 'm'
    cn[4] = 0x70  # 'p'
    cn[5] = 0x6c  # 'l'
    cn[6] = 0x65  # 'e'
    cn[7] = 0x2e  # '.'
    cn[8] = 0x63  # 'c'
    cn[9] = 0x6f  # 'o'
    cn[10] = 0x6d # 'm'

    let hostname: *u8 = c"example.com"

    let result: i32 = x509_hostname_match(@cn[0], 11, hostname, 11)
    assert result == 1

[[test]]
fn test_hostname_match_case_insensitive()
    var cn: [20]u8
    cn[0] = 0x45  # 'E'
    cn[1] = 0x58  # 'X'
    cn[2] = 0x41  # 'A'
    cn[3] = 0x4d  # 'M'
    cn[4] = 0x50  # 'P'
    cn[5] = 0x4c  # 'L'
    cn[6] = 0x45  # 'E'
    cn[7] = 0x2e  # '.'
    cn[8] = 0x43  # 'C'
    cn[9] = 0x4f  # 'O'
    cn[10] = 0x4d # 'M'

    let hostname: *u8 = c"example.com"

    let result: i32 = x509_hostname_match(@cn[0], 11, hostname, 11)
    assert result == 1

[[test]]
fn test_hostname_wildcard_simple()
    # *.example.com should match www.example.com
    var cn: [20]u8
    cn[0] = 0x2a  # '*'
    cn[1] = 0x2e  # '.'
    cn[2] = 0x65  # 'e'
    cn[3] = 0x78  # 'x'
    cn[4] = 0x61  # 'a'
    cn[5] = 0x6d  # 'm'
    cn[6] = 0x70  # 'p'
    cn[7] = 0x6c  # 'l'
    cn[8] = 0x65  # 'e'
    cn[9] = 0x2e  # '.'
    cn[10] = 0x63 # 'c'
    cn[11] = 0x6f # 'o'
    cn[12] = 0x6d # 'm'

    let hostname: *u8 = c"www.example.com"

    let result: i32 = x509_hostname_match(@cn[0], 13, hostname, 15)
    assert result == 1

[[test]]
fn test_hostname_wildcard_no_match_root()
    # *.example.com should NOT match example.com (no subdomain)
    var cn: [20]u8
    cn[0] = 0x2a  # '*'
    cn[1] = 0x2e  # '.'
    cn[2] = 0x65  # 'e'
    cn[3] = 0x78  # 'x'
    cn[4] = 0x61  # 'a'
    cn[5] = 0x6d  # 'm'
    cn[6] = 0x70  # 'p'
    cn[7] = 0x6c  # 'l'
    cn[8] = 0x65  # 'e'
    cn[9] = 0x2e  # '.'
    cn[10] = 0x63 # 'c'
    cn[11] = 0x6f # 'o'
    cn[12] = 0x6d # 'm'

    let hostname: *u8 = c"example.com"

    let result: i32 = x509_hostname_match(@cn[0], 13, hostname, 11)
    assert result == 0

[[test]]
fn test_hostname_mismatch()
    var cn: [20]u8
    cn[0] = 0x66  # 'f'
    cn[1] = 0x6f  # 'o'
    cn[2] = 0x6f  # 'o'
    cn[3] = 0x2e  # '.'
    cn[4] = 0x63  # 'c'
    cn[5] = 0x6f  # 'o'
    cn[6] = 0x6d  # 'm'

    let hostname: *u8 = c"bar.com"

    let result: i32 = x509_hostname_match(@cn[0], 7, hostname, 7)
    assert result == 0

# ============================================================================
# Time Validation Tests
# ============================================================================

[[test]]
fn test_validity_time_valid()
    var cert: X509Certificate
    mem_zero(@cert as *u8, 1200)

    # notBefore: 2020-01-01 00:00:00 UTC = 1577836800
    # notAfter: 2030-01-01 00:00:00 UTC = 1893456000
    cert.validity.not_before = 1577836800
    cert.validity.not_after = 1893456000

    # Current time: 2025-06-15 = approximately 1750000000
    let current_time: i64 = 1750000000

    let result: i32 = x509_is_valid_time(@cert, current_time)
    assert result == 1

[[test]]
fn test_validity_time_expired()
    var cert: X509Certificate
    mem_zero(@cert as *u8, 1200)

    # notBefore: 2020-01-01
    # notAfter: 2024-01-01 = 1704067200
    cert.validity.not_before = 1577836800
    cert.validity.not_after = 1704067200

    # Current time: 2025-06-15
    let current_time: i64 = 1750000000

    let result: i32 = x509_is_valid_time(@cert, current_time)
    assert result == 0

[[test]]
fn test_validity_time_not_yet_valid()
    var cert: X509Certificate
    mem_zero(@cert as *u8, 1200)

    # notBefore: 2026-01-01 = 1767225600
    # notAfter: 2030-01-01
    cert.validity.not_before = 1767225600
    cert.validity.not_after = 1893456000

    # Current time: 2025-06-15
    let current_time: i64 = 1750000000

    let result: i32 = x509_is_valid_time(@cert, current_time)
    assert result == 0
