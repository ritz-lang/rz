# test/test_helpers.ritz - Shared test helper functions
#
# This module provides common helper functions used across cryptosec tests.
# Import this instead of duplicating helpers in each test file.

import ritzlib.sys
import lib.mem

# ============================================================================
# Hex Conversion Helpers
# ============================================================================

# Convert a hex character to its value (0-15)
# Returns 0xff on invalid input (matches most test files' convention)
pub fn hex_char_to_val(c: u8) -> u8
    if c >= 0x30 && c <= 0x39
        return c - 0x30
    if c >= 0x61 && c <= 0x66
        return c - 0x61 + 10
    if c >= 0x41 && c <= 0x46
        return c - 0x41 + 10
    return 0xff

# Check if bytes match hex string
pub fn bytes_eq_hex(data: *u8, data_len: i32, hex: *u8, hex_len: i32) -> i32
    if hex_len != data_len * 2
        return 0

    var i: i32 = 0
    while i < data_len
        let hi: u8 = hex_char_to_val(hex[i * 2])
        let lo: u8 = hex_char_to_val(hex[i * 2 + 1])
        if hi == 0xff || lo == 0xff
            return 0
        let expected: u8 = (hi << 4) | lo
        if data[i] != expected
            return 0
        i += 1
    return 1

# Check if hash matches hex string (wrapper for bytes_eq_hex)
pub fn hash_eq_hex(hash: *u8, hash_len: i32, expected_hex: *u8) -> i32
    return bytes_eq_hex(hash, hash_len, expected_hex, hash_len * 2)

# Fill buffer from hex string
pub fn fill_from_hex(hex: *u8, hex_len: i32, out: *u8, out_len: i32) -> i32
    if hex_len != out_len * 2
        return -1

    var i: i32 = 0
    while i < out_len
        let hi: u8 = hex_char_to_val(hex[i * 2])
        let lo: u8 = hex_char_to_val(hex[i * 2 + 1])
        if hi == 0xff || lo == 0xff
            return -1
        out[i] = (hi << 4) | lo
        i += 1
    return 0

# ============================================================================
# Comparison Helpers
# ============================================================================

# Compare two byte arrays for equality
pub fn bytes_equal(a: *u8, b: *u8, len: i64) -> i32
    var i: i64 = 0
    while i < len
        if a[i] != b[i]
            return 0
        i += 1
    return 1

# ============================================================================
# Debug Output Helpers
# ============================================================================

# Print bytes in hex format
pub fn print_hex_bytes(data: *u8, len: i32)
    var i: i32 = 0
    while i < len
        let byte: u8 = data[i]
        var hi: u8 = (byte >> 4) & 0x0f
        var lo: u8 = byte & 0x0f

        if hi < 10
            hi = hi + 0x30
        else
            hi = hi + 0x57

        if lo < 10
            lo = lo + 0x30
        else
            lo = lo + 0x57

        var buf: [2]u8
        buf[0] = hi
        buf[1] = lo
        sys_write(1, @buf[0], 2)
        i += 1
    var newline: u8 = 0x0a
    sys_write(1, @newline, 1)
