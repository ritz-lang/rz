# test/test_mem.ritz - Tests for secure memory utilities
#
# Tests for lib/mem.ritz:
# - mem_zero: Constant-time memory zeroing
# - mem_eq: Constant-time memory comparison
# - mem_copy: Safe memory copy
# - ct_select_u8/u64: Constant-time conditional select

import ritzlib.sys
import ritzlib.io
import ritzlib.memory

import lib.mem

# ============================================================================
# mem_zero tests
# ============================================================================

[[test]]
fn test_mem_zero_basic() -> i32
    # Zero a small buffer
    var buf: [16]u8
    buf[0] = 0xAA
    buf[1] = 0xBB
    buf[15] = 0xFF

    mem_zero(@buf[0], 16)

    assert buf[0] == 0, "buf[0] should be zero"
    assert buf[1] == 0, "buf[1] should be zero"
    assert buf[15] == 0, "buf[15] should be zero"
    0

[[test]]
fn test_mem_zero_partial() -> i32
    # Zero only part of a buffer
    var buf: [16]u8
    for i in 0..16
        buf[i] = 0xFF

    # Zero middle 8 bytes
    mem_zero(@buf[4], 8)

    assert buf[0] == 0xFF, "buf[0] should be unchanged"
    assert buf[3] == 0xFF, "buf[3] should be unchanged"
    assert buf[4] == 0, "buf[4] should be zero"
    assert buf[11] == 0, "buf[11] should be zero"
    assert buf[12] == 0xFF, "buf[12] should be unchanged"
    0

[[test]]
fn test_mem_zero_empty() -> i32
    # Zero with length 0 should be a no-op
    var buf: [4]u8
    buf[0] = 0xAA

    mem_zero(@buf[0], 0)

    assert buf[0] == 0xAA, "buf[0] should be unchanged"
    0

# ============================================================================
# mem_eq tests
# ============================================================================

[[test]]
fn test_mem_eq_equal() -> i32
    var a: [8]u8
    var b: [8]u8

    for i in 0..8
        a[i] = i as u8
        b[i] = i as u8

    let result: i32 = mem_eq(@a[0], @b[0], 8)
    assert result == 1, "identical buffers should be equal"
    0

[[test]]
fn test_mem_eq_different() -> i32
    var a: [8]u8
    var b: [8]u8

    for i in 0..8
        a[i] = i as u8
        b[i] = i as u8

    # Differ in one byte
    b[4] = 0xFF

    let result: i32 = mem_eq(@a[0], @b[0], 8)
    assert result == 0, "different buffers should not be equal"
    0

[[test]]
fn test_mem_eq_first_byte_differs() -> i32
    var a: [4]u8 = [1, 2, 3, 4]
    var b: [4]u8 = [0, 2, 3, 4]

    let result: i32 = mem_eq(@a[0], @b[0], 4)
    assert result == 0, "first byte difference should be detected"
    0

[[test]]
fn test_mem_eq_last_byte_differs() -> i32
    var a: [4]u8 = [1, 2, 3, 4]
    var b: [4]u8 = [1, 2, 3, 5]

    let result: i32 = mem_eq(@a[0], @b[0], 4)
    assert result == 0, "last byte difference should be detected"
    0

[[test]]
fn test_mem_eq_empty() -> i32
    var a: [4]u8 = [0xAA, 0xBB, 0xCC, 0xDD]
    var b: [4]u8 = [0x11, 0x22, 0x33, 0x44]

    # Zero length comparison should return equal
    let result: i32 = mem_eq(@a[0], @b[0], 0)
    assert result == 1, "zero length should be equal"
    0

# ============================================================================
# mem_copy tests
# ============================================================================

[[test]]
fn test_mem_copy_basic() -> i32
    var src: [8]u8 = [1, 2, 3, 4, 5, 6, 7, 8]
    var dst: [8]u8

    for i in 0..8
        dst[i] = 0

    mem_copy(@dst[0], @src[0], 8)

    assert dst[0] == 1, "dst[0] should be 1"
    assert dst[7] == 8, "dst[7] should be 8"
    0

[[test]]
fn test_mem_copy_partial() -> i32
    var src: [8]u8 = [0xAA, 0xBB, 0xCC, 0xDD, 0xEE, 0xFF, 0x11, 0x22]
    var dst: [8]u8

    for i in 0..8
        dst[i] = 0

    # Copy middle 4 bytes to offset 2 in dst
    mem_copy(@dst[2], @src[2], 4)

    assert dst[0] == 0, "dst[0] should be unchanged"
    assert dst[1] == 0, "dst[1] should be unchanged"
    assert dst[2] == 0xCC, "dst[2] should be 0xCC"
    assert dst[5] == 0xFF, "dst[5] should be 0xFF"
    assert dst[6] == 0, "dst[6] should be unchanged"
    0

[[test]]
fn test_mem_copy_empty() -> i32
    var src: [4]u8 = [1, 2, 3, 4]
    var dst: [4]u8 = [0xAA, 0xBB, 0xCC, 0xDD]

    mem_copy(@dst[0], @src[0], 0)

    assert dst[0] == 0xAA, "dst should be unchanged"
    0

# ============================================================================
# ct_select tests (constant-time conditional select)
# ============================================================================

[[test]]
fn test_ct_select_u8_true() -> i32
    let a: u8 = 0xAA
    let b: u8 = 0xBB

    # condition=1 should select a
    let result: u8 = ct_select_u8(a, b, 1)
    assert result == 0xAA, "ct_select(a, b, 1) should return a"
    0

[[test]]
fn test_ct_select_u8_false() -> i32
    let a: u8 = 0xAA
    let b: u8 = 0xBB

    # condition=0 should select b
    let result: u8 = ct_select_u8(a, b, 0)
    assert result == 0xBB, "ct_select(a, b, 0) should return b"
    0

[[test]]
fn test_ct_select_u64_true() -> i32
    let a: u64 = 0xDEADBEEFCAFEBABE
    let b: u64 = 0x1234567890ABCDEF

    let result: u64 = ct_select_u64(a, b, 1)
    assert result == 0xDEADBEEFCAFEBABE, "ct_select_u64(a, b, 1) should return a"
    0

[[test]]
fn test_ct_select_u64_false() -> i32
    let a: u64 = 0xDEADBEEFCAFEBABE
    let b: u64 = 0x1234567890ABCDEF

    let result: u64 = ct_select_u64(a, b, 0)
    assert result == 0x1234567890ABCDEF, "ct_select_u64(a, b, 0) should return b"
    0

# ============================================================================
# ct_is_zero tests (constant-time zero check)
# ============================================================================

[[test]]
fn test_ct_is_zero_zero() -> i32
    let result: i32 = ct_is_zero_u64(0)
    assert result == 1, "ct_is_zero(0) should return 1"
    0

[[test]]
fn test_ct_is_zero_nonzero() -> i32
    let result1: i32 = ct_is_zero_u64(1)
    assert result1 == 0, "ct_is_zero(1) should return 0"

    let result2: i32 = ct_is_zero_u64(0xFFFFFFFFFFFFFFFF)
    assert result2 == 0, "ct_is_zero(max) should return 0"
    0

# ============================================================================
# mem_is_zero tests
# ============================================================================

[[test]]
fn test_mem_is_zero_all_zeros() -> i32
    var buf: [16]u8
    for i in 0..16
        buf[i] = 0

    let result: i32 = mem_is_zero(@buf[0], 16)
    assert result == 1, "all zeros should return 1"
    0

[[test]]
fn test_mem_is_zero_has_nonzero() -> i32
    var buf: [16]u8
    for i in 0..16
        buf[i] = 0
    buf[8] = 1

    let result: i32 = mem_is_zero(@buf[0], 16)
    assert result == 0, "buffer with nonzero should return 0"
    0

[[test]]
fn test_mem_is_zero_empty() -> i32
    var buf: [4]u8 = [0xFF, 0xFF, 0xFF, 0xFF]

    let result: i32 = mem_is_zero(@buf[0], 0)
    assert result == 1, "empty buffer should return 1"
    0
