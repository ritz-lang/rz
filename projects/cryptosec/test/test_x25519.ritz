# Test that both parties compute the same shared secret
[[test]]
fn test_x25519_key_agreement() -> i32
    # Alice's private key
    var k_alice: [32]u8
    k_alice[0] = 0x77
    k_alice[1] = 0x07
    k_alice[2] = 0x6d
    k_alice[3] = 0x0a
    k_alice[4] = 0x73
    k_alice[5] = 0x18
    k_alice[6] = 0xa5
    k_alice[7] = 0x7d
    k_alice[8] = 0x3c
    k_alice[9] = 0x16
    k_alice[10] = 0xc1
    k_alice[11] = 0x72
    k_alice[12] = 0x51
    k_alice[13] = 0xb2
    k_alice[14] = 0x66
    k_alice[15] = 0x45
    k_alice[16] = 0xdf
    k_alice[17] = 0x4c
    k_alice[18] = 0x2f
    k_alice[19] = 0x87
    k_alice[20] = 0xeb
    k_alice[21] = 0xc0
    k_alice[22] = 0x99
    k_alice[23] = 0x2a
    k_alice[24] = 0xb1
    k_alice[25] = 0x77
    k_alice[26] = 0xfb
    k_alice[27] = 0xa5
    k_alice[28] = 0x1d
    k_alice[29] = 0xb9
    k_alice[30] = 0x2c
    k_alice[31] = 0x2a

    # Bob's private key
    var k_bob: [32]u8
    k_bob[0] = 0x5d
    k_bob[1] = 0xab
    k_bob[2] = 0x08
    k_bob[3] = 0x7e
    k_bob[4] = 0x62
    k_bob[5] = 0x4a
    k_bob[6] = 0x8a
    k_bob[7] = 0x4b
    k_bob[8] = 0x79
    k_bob[9] = 0xe1
    k_bob[10] = 0x7f
    k_bob[11] = 0x8b
    k_bob[12] = 0x83
    k_bob[13] = 0x80
    k_bob[14] = 0x0e
    k_bob[15] = 0xe6
    k_bob[16] = 0x6f
    k_bob[17] = 0x3b
    k_bob[18] = 0xb1
    k_bob[19] = 0x29
    k_bob[20] = 0x26
    k_bob[21] = 0x18
    k_bob[22] = 0xb6
    k_bob[23] = 0xfd
    k_bob[24] = 0x1c
    k_bob[25] = 0x2f
    k_bob[26] = 0x8b
    k_bob[27] = 0x27
    k_bob[28] = 0xff
    k_bob[29] = 0x88
    k_bob[30] = 0xe0
    k_bob[31] = 0xeb

    # Basepoint
    var basepoint: [32]u8
    basepoint[0] = 0x09
    mem_zero(&basepoint[1], 31)

    # Alice computes her public key
    var pk_alice: [32]u8
    x25519(&pk_alice[0], &k_alice[0], &basepoint[0])

    # Bob computes his public key
    var pk_bob: [32]u8
    x25519(&pk_bob[0], &k_bob[0], &basepoint[0])

    # Alice computes shared secret using Bob's public key
    var ss_alice: [32]u8
    x25519(&ss_alice[0], &k_alice[0], &pk_bob[0])

    # Bob computes shared secret using Alice's public key
    var ss_bob: [32]u8
    x25519(&ss_bob[0], &k_bob[0], &pk_alice[0])

    # Both should be equal!
    if mem_eq(&ss_alice[0], &ss_bob[0], 32) == 0
        return 1
    return 0

