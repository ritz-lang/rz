# test/test_x25519.ritz - X25519 key exchange tests
#
# Test vectors from RFC 7748 and related sources

import lib.x25519
import lib.mem

# ============================================================================
# RFC 7748 Test Vectors
# ============================================================================

# Test vector 1 from RFC 7748 Section 5.2
[[test]]
fn test_x25519_rfc7748_1() -> i32
    # Alice's private key (clamped scalar)
    var k: [32]u8
    k[0] = 0x77
    k[1] = 0x07
    k[2] = 0x6d
    k[3] = 0x0a
    k[4] = 0x73
    k[5] = 0x18
    k[6] = 0xa5
    k[7] = 0x7d
    k[8] = 0x3c
    k[9] = 0x16
    k[10] = 0xc1
    k[11] = 0x72
    k[12] = 0x51
    k[13] = 0xb2
    k[14] = 0x66
    k[15] = 0x45
    k[16] = 0xdf
    k[17] = 0x4c
    k[18] = 0x2f
    k[19] = 0x87
    k[20] = 0xeb
    k[21] = 0xc0
    k[22] = 0x99
    k[23] = 0x2a
    k[24] = 0xb1
    k[25] = 0x77
    k[26] = 0xfb
    k[27] = 0xa5
    k[28] = 0x1d
    k[29] = 0xb9
    k[30] = 0x2c
    k[31] = 0x2a

    # Input u-coordinate (basepoint for keygen, or peer's public key)
    var u: [32]u8
    u[0] = 0x09  # basepoint
    mem_zero(&u[1], 31)

    # Expected output
    var expected: [32]u8
    expected[0] = 0x85
    expected[1] = 0x20
    expected[2] = 0xf0
    expected[3] = 0x09
    expected[4] = 0x89
    expected[5] = 0x30
    expected[6] = 0xa7
    expected[7] = 0x54
    expected[8] = 0x74
    expected[9] = 0x8b
    expected[10] = 0x7d
    expected[11] = 0xdc
    expected[12] = 0xb4
    expected[13] = 0x3e
    expected[14] = 0xf7
    expected[15] = 0x5a
    expected[16] = 0x0d
    expected[17] = 0xbf
    expected[18] = 0x3a
    expected[19] = 0x0d
    expected[20] = 0x26
    expected[21] = 0x38
    expected[22] = 0x1a
    expected[23] = 0xf4
    expected[24] = 0xeb
    expected[25] = 0xa4
    expected[26] = 0xa9
    expected[27] = 0x8e
    expected[28] = 0xaa
    expected[29] = 0x9b
    expected[30] = 0x4e
    expected[31] = 0x6a

    var result: [32]u8
    x25519(&result[0], &k[0], &u[0])

    if mem_eq(&result[0], &expected[0], 32) == 0
        return 1
    return 0

