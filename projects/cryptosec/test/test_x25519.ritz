    pk_bob[28] = 0x6f
    pk_bob[29] = 0x88
    pk_bob[30] = 0x2b
    pk_bob[31] = 0x4f

    # Expected shared secret from RFC 7748
    var expected: [32]u8
    expected[0] = 0x4a
    expected[1] = 0x5d
    expected[2] = 0x9d
    expected[3] = 0x5b
    expected[4] = 0xa4
    expected[5] = 0xce
    expected[6] = 0x2d
    expected[7] = 0xe1
    expected[8] = 0x72
    expected[9] = 0x8e
    expected[10] = 0x3b
