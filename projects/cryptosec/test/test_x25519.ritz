# Test scalar clamping
[[test]]
fn test_x25519_clamp() -> i32
    # A scalar that needs clamping
    var scalar: [32]u8
    scalar[0] = 0xff  # Should become 0xf8 (clear low 3 bits)
    scalar[31] = 0xff  # Should become 0x7f (clear high bit, set bit 6)
    var i: i32 = 1
    while i < 31
        scalar[i] = 0x00
        i += 1

    x25519_clamp(&scalar[0])

    # Check clamping was applied
    if scalar[0] != 0xf8
        return 1
    if scalar[31] != 0x7f
        return 2
    return 0
