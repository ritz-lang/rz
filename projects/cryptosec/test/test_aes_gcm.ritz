# AES-GCM tests
# Test vectors from NIST SP 800-38D and RFC 5116

import lib.aes_gcm
import lib.mem
import lib.cpuid

# Helper to check if two byte arrays are equal
fn bytes_equal(a: *u8, b: *u8, len: i64) -> i32
    var i: i64 = 0
    while i < len
        if a[i] != b[i]
            return 0
        i += 1
    return 1

# =============================================================================
# AES-128-GCM Tests
# =============================================================================

# NIST SP 800-38D Test Case 1: Empty plaintext, no AAD
[[test]]
fn test_aes128_gcm_empty_pt_no_aad() -> i32
    var key: [16]u8
    var nonce: [12]u8
    var ct: [16]u8
    var tag: [16]u8

    mem_zero(&key[0], 16)
    mem_zero(&nonce[0], 12)

    var ctx: AesGcm128
    aes128_gcm_init(&ctx, &key[0])

    let ct_len: i64 = aes128_gcm_encrypt(&ctx, &nonce[0], 12, nil, 0, nil, 0, &ct[0], &tag[0])

    # Expected tag: 58e2fccefa7e3061367f1d57a4e7455a
    var expected_tag: [16]u8
    expected_tag[0] = 0x58
    expected_tag[1] = 0xe2
    expected_tag[2] = 0xfc
    expected_tag[3] = 0xce
    expected_tag[4] = 0xfa
    expected_tag[5] = 0x7e
    expected_tag[6] = 0x30
    expected_tag[7] = 0x61
    expected_tag[8] = 0x36
    expected_tag[9] = 0x7f
    expected_tag[10] = 0x1d
    expected_tag[11] = 0x57
    expected_tag[12] = 0xa4
    expected_tag[13] = 0xe7
    expected_tag[14] = 0x45
    expected_tag[15] = 0x5a

    if ct_len != 0
        return 1
    if bytes_equal(&tag[0], &expected_tag[0], 16) == 0
        return 2
    return 0

# NIST SP 800-38D Test Case 2: 16 bytes plaintext, no AAD
[[test]]
fn test_aes128_gcm_16byte_pt() -> i32
    var key: [16]u8
    var nonce: [12]u8
    var pt: [16]u8
    var ct: [16]u8
    var tag: [16]u8

    mem_zero(&key[0], 16)
    mem_zero(&nonce[0], 12)
    mem_zero(&pt[0], 16)

    var ctx: AesGcm128
    aes128_gcm_init(&ctx, &key[0])

    let ct_len: i64 = aes128_gcm_encrypt(&ctx, &nonce[0], 12, nil, 0, &pt[0], 16, &ct[0], &tag[0])

    # Expected ciphertext: 0388dace60b6a392f328c2b971b2fe78
    var expected_ct: [16]u8
    expected_ct[0] = 0x03
    expected_ct[1] = 0x88
    expected_ct[2] = 0xda
    expected_ct[3] = 0xce
    expected_ct[4] = 0x60
    expected_ct[5] = 0xb6
    expected_ct[6] = 0xa3
    expected_ct[7] = 0x92
    expected_ct[8] = 0xf3
    expected_ct[9] = 0x28
    expected_ct[10] = 0xc2
    expected_ct[11] = 0xb9
    expected_ct[12] = 0x71
    expected_ct[13] = 0xb2
    expected_ct[14] = 0xfe
    expected_ct[15] = 0x78

    # Expected tag: ab6e47d42cec13bdf53a67b21257bddf
    var expected_tag: [16]u8
    expected_tag[0] = 0xab
    expected_tag[1] = 0x6e
    expected_tag[2] = 0x47
    expected_tag[3] = 0xd4
    expected_tag[4] = 0x2c
    expected_tag[5] = 0xec
    expected_tag[6] = 0x13
    expected_tag[7] = 0xbd
    expected_tag[8] = 0xf5
    expected_tag[9] = 0x3a
    expected_tag[10] = 0x67
    expected_tag[11] = 0xb2
    expected_tag[12] = 0x12
    expected_tag[13] = 0x57
    expected_tag[14] = 0xbd
    expected_tag[15] = 0xdf

    if ct_len != 16
        return 1
    if bytes_equal(&ct[0], &expected_ct[0], 16) == 0
        return 2
    if bytes_equal(&tag[0], &expected_tag[0], 16) == 0
        return 3
    return 0

# Test decryption roundtrip
[[test]]
fn test_aes128_gcm_roundtrip() -> i32
    var key: [16]u8
    var nonce: [12]u8
    var pt: [32]u8
    var ct: [32]u8
    var decrypted: [32]u8
    var tag: [16]u8

    var i: i64 = 0
    while i < 16
        key[i] = (i * 17) as u8
        i += 1
    i = 0
    while i < 12
        nonce[i] = (i * 13) as u8
        i += 1
    i = 0
    while i < 32
        pt[i] = (i * 7) as u8
        i += 1

    var ctx: AesGcm128
    aes128_gcm_init(&ctx, &key[0])

    let ct_len: i64 = aes128_gcm_encrypt(&ctx, &nonce[0], 12, nil, 0, &pt[0], 32, &ct[0], &tag[0])
    let result: i32 = aes128_gcm_decrypt(&ctx, &nonce[0], 12, nil, 0, &ct[0], ct_len, &tag[0], &decrypted[0])

    if result != 1
        return 1
    if bytes_equal(&pt[0], &decrypted[0], 32) == 0
        return 2
    return 0

# Test with AAD (Additional Authenticated Data)
[[test]]
fn test_aes128_gcm_with_aad() -> i32
    var key: [16]u8
    var nonce: [12]u8
    var aad: [16]u8
    var pt: [16]u8
    var ct: [16]u8
    var decrypted: [16]u8
    var tag: [16]u8

    var i: i64 = 0
    while i < 16
        key[i] = (i + 1) as u8
        aad[i] = (i + 0x10) as u8
        pt[i] = (i + 0x20) as u8
        i += 1
    i = 0
    while i < 12
        nonce[i] = (i + 0x30) as u8
        i += 1

    var ctx: AesGcm128
    aes128_gcm_init(&ctx, &key[0])

    let ct_len: i64 = aes128_gcm_encrypt(&ctx, &nonce[0], 12, &aad[0], 16, &pt[0], 16, &ct[0], &tag[0])
    let result: i32 = aes128_gcm_decrypt(&ctx, &nonce[0], 12, &aad[0], 16, &ct[0], ct_len, &tag[0], &decrypted[0])

    if result != 1
        return 1
    if bytes_equal(&pt[0], &decrypted[0], 16) == 0
        return 2
    return 0

# Test tag verification failure (tampered ciphertext)
[[test]]
fn test_aes128_gcm_tampered_ct() -> i32
    var key: [16]u8
    var nonce: [12]u8
    var pt: [16]u8
    var ct: [16]u8
    var decrypted: [16]u8
    var tag: [16]u8

    mem_zero(&key[0], 16)
    mem_zero(&nonce[0], 12)
    mem_zero(&pt[0], 16)

    var ctx: AesGcm128
    aes128_gcm_init(&ctx, &key[0])

    let ct_len: i64 = aes128_gcm_encrypt(&ctx, &nonce[0], 12, nil, 0, &pt[0], 16, &ct[0], &tag[0])

    # Tamper with ciphertext
    ct[0] = ct[0] ^ 0x01

    let result: i32 = aes128_gcm_decrypt(&ctx, &nonce[0], 12, nil, 0, &ct[0], ct_len, &tag[0], &decrypted[0])

    if result != 0
        return 1
    return 0

# Test tag verification failure (tampered tag)
[[test]]
fn test_aes128_gcm_tampered_tag() -> i32
    var key: [16]u8
    var nonce: [12]u8
    var pt: [16]u8
    var ct: [16]u8
    var decrypted: [16]u8
    var tag: [16]u8

    mem_zero(&key[0], 16)
    mem_zero(&nonce[0], 12)
    mem_zero(&pt[0], 16)

    var ctx: AesGcm128
    aes128_gcm_init(&ctx, &key[0])

    let ct_len: i64 = aes128_gcm_encrypt(&ctx, &nonce[0], 12, nil, 0, &pt[0], 16, &ct[0], &tag[0])

    # Tamper with tag
    tag[0] = tag[0] ^ 0x01

    let result: i32 = aes128_gcm_decrypt(&ctx, &nonce[0], 12, nil, 0, &ct[0], ct_len, &tag[0], &decrypted[0])

    if result != 0
        return 1
    return 0

# =============================================================================
# AES-256-GCM Tests
# =============================================================================

[[test]]
fn test_aes256_gcm_roundtrip() -> i32
    var key: [32]u8
    var nonce: [12]u8
    var pt: [48]u8
    var ct: [48]u8
    var decrypted: [48]u8
    var tag: [16]u8

    var i: i64 = 0
    while i < 32
        key[i] = (i * 11) as u8
        i += 1
    i = 0
    while i < 12
        nonce[i] = (i * 23) as u8
        i += 1
    i = 0
    while i < 48
        pt[i] = (i * 3) as u8
        i += 1

    var ctx: AesGcm256
    aes256_gcm_init(&ctx, &key[0])

    let ct_len: i64 = aes256_gcm_encrypt(&ctx, &nonce[0], 12, nil, 0, &pt[0], 48, &ct[0], &tag[0])
    let result: i32 = aes256_gcm_decrypt(&ctx, &nonce[0], 12, nil, 0, &ct[0], ct_len, &tag[0], &decrypted[0])

    if result != 1
        return 1
    if bytes_equal(&pt[0], &decrypted[0], 48) == 0
        return 2
    return 0

[[test]]
fn test_aes256_gcm_with_aad() -> i32
    var key: [32]u8
    var nonce: [12]u8
    var aad: [20]u8
    var pt: [64]u8
    var ct: [64]u8
    var decrypted: [64]u8
    var tag: [16]u8

    var i: i64 = 0
    while i < 32
        key[i] = (i * 5) as u8
        i += 1
    i = 0
    while i < 12
        nonce[i] = (i * 7) as u8
        i += 1
    i = 0
    while i < 20
        aad[i] = (i * 11) as u8
        i += 1
    i = 0
    while i < 64
        pt[i] = (i * 13) as u8
        i += 1

    var ctx: AesGcm256
    aes256_gcm_init(&ctx, &key[0])

    let ct_len: i64 = aes256_gcm_encrypt(&ctx, &nonce[0], 12, &aad[0], 20, &pt[0], 64, &ct[0], &tag[0])
    let result: i32 = aes256_gcm_decrypt(&ctx, &nonce[0], 12, &aad[0], 20, &ct[0], ct_len, &tag[0], &decrypted[0])

    if result != 1
        return 1
    if bytes_equal(&pt[0], &decrypted[0], 64) == 0
        return 2
    return 0

# Test wrong AAD causes failure
[[test]]
fn test_aes256_gcm_wrong_aad() -> i32
    var key: [32]u8
    var nonce: [12]u8
    var aad: [16]u8
    var wrong_aad: [16]u8
    var pt: [16]u8
    var ct: [16]u8
    var decrypted: [16]u8
    var tag: [16]u8

    mem_zero(&key[0], 32)
    mem_zero(&nonce[0], 12)
    mem_zero(&aad[0], 16)
    mem_zero(&wrong_aad[0], 16)
    mem_zero(&pt[0], 16)
    wrong_aad[0] = 0x01

    var ctx: AesGcm256
    aes256_gcm_init(&ctx, &key[0])

    let ct_len: i64 = aes256_gcm_encrypt(&ctx, &nonce[0], 12, &aad[0], 16, &pt[0], 16, &ct[0], &tag[0])
    let result: i32 = aes256_gcm_decrypt(&ctx, &nonce[0], 12, &wrong_aad[0], 16, &ct[0], ct_len, &tag[0], &decrypted[0])

    if result != 0
        return 1
    return 0
