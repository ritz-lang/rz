    pt[100] = 0x6e # n
    pt[101] = 0x20 # (space)
    pt[102] = 0x77 # w
    pt[103] = 0x6f # o
    pt[104] = 0x75 # u
    pt[105] = 0x6c # l
    pt[106] = 0x64 # d
    pt[107] = 0x20 # (space)
    pt[108] = 0x62 # b
    pt[109] = 0x65 # e
    pt[110] = 0x20 # (space)
    pt[111] = 0x69 # i
    pt[112] = 0x74 # t
    pt[113] = 0x2e # .

    var ct: [114]u8
    chacha20_xor(@key[0], @nonce[0], 1, @pt[0], 114, @ct[0])

    # Expected first 16 bytes of ciphertext
    var expected: [16]u8
    expected[0] = 0x6e
    expected[1] = 0x2e
    expected[2] = 0x35
    expected[3] = 0x9a
    expected[4] = 0x25
