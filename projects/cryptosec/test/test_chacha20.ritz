    expected[11] = 0x28
    expected[12] = 0xdd
    expected[13] = 0x0d
    expected[14] = 0x69
    expected[15] = 0x81

    if bytes_equal(@ct[0], @expected[0], 16) == 0
        return 1
    return 0

# Test roundtrip encryption/decryption
[[test]]
fn test_chacha20_roundtrip() -> i32
    var key: [32]u8
    var nonce: [12]u8
    var pt: [64]u8
    var ct: [64]u8
    var decrypted: [64]u8

    var i: i64 = 0
    while i < 32
        key[i] = (i * 7) as u8
        i += 1

    i = 0
    while i < 12
        nonce[i] = (i * 13) as u8
        i += 1

    i = 0
    while i < 64
        pt[i] = (i * 3) as u8
        i += 1

    var ctx: ChaCha20
    chacha20_init(@ctx, @key[0], @nonce[0])
    chacha20_encrypt(@ctx, @pt[0], 64, @ct[0])

    chacha20_init(@ctx, @key[0], @nonce[0])
    chacha20_decrypt(@ctx, @ct[0], 64, @decrypted[0])

    if bytes_equal(@pt[0], @decrypted[0], 64) == 0
        return 1
    return 0

# Test partial block encryption
[[test]]
fn test_chacha20_partial_block() -> i32
    var key: [32]u8
    var nonce: [12]u8
    var pt: [37]u8  # Not a multiple of 64
    var ct: [37]u8
    var decrypted: [37]u8

    mem_zero(@key[0], 32)
    mem_zero(@nonce[0], 12)

    var i: i64 = 0
    while i < 37
        pt[i] = i as u8
        i += 1

    chacha20_xor(@key[0], @nonce[0], 0, @pt[0], 37, @ct[0])
    chacha20_xor(@key[0], @nonce[0], 0, @ct[0], 37, @decrypted[0])

    if bytes_equal(@pt[0], @decrypted[0], 37) == 0
        return 1
    return 0
