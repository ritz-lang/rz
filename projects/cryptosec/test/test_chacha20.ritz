    pt[47] = 0x63  # c
    pt[48] = 0x6f  # o
    pt[49] = 0x75  # u
    pt[50] = 0x6c  # l
    pt[51] = 0x64  # d
    pt[52] = 0x20  # (space)
    pt[53] = 0x6f  # o
    pt[54] = 0x66  # f
    pt[55] = 0x66  # f
