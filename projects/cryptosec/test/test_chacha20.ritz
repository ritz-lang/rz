# ChaCha20 tests
# RFC 8439 test vectors

import lib.chacha20
import lib.mem

# Helper to check if two byte arrays are equal
fn bytes_equal(a: *u8, b: *u8, len: i64) -> i32
    var i: i64 = 0
    while i < len
        if a[i] != b[i]
            return 0
        i += 1
    return 1

# =============================================================================
# ChaCha20 Block Function Tests
# =============================================================================

# RFC 8439 Section 2.3.2 Test Vector
[[test]]
fn test_chacha20_block_rfc8439() -> i32
    # Key: 00:01:02:03:...:1f
    var key: [32]u8
    var i: i64 = 0
    while i < 32
        key[i] = i as u8
        i += 1

    # Nonce: 00:00:00:09:00:00:00:4a:00:00:00:00
    var nonce: [12]u8
    nonce[0] = 0x00
    nonce[1] = 0x00
    nonce[2] = 0x00
    nonce[3] = 0x09
    nonce[4] = 0x00
    nonce[5] = 0x00
    nonce[6] = 0x00
    nonce[7] = 0x4a
    nonce[8] = 0x00
    nonce[9] = 0x00
    nonce[10] = 0x00
    nonce[11] = 0x00

    var out: [64]u8
    chacha20_block(@key[0], 1, @nonce[0], @out[0])

    # Expected first 16 bytes: 10 f1 e7 e4 d1 3b 59 15 50 0f dd 1f a3 20 71 c4
    var expected: [16]u8
    expected[0] = 0x10
    expected[1] = 0xf1
    expected[2] = 0xe7
    expected[3] = 0xe4
    expected[4] = 0xd1
    expected[5] = 0x3b
    expected[6] = 0x59
    expected[7] = 0x15
    expected[8] = 0x50
    expected[9] = 0x0f
    expected[10] = 0xdd
    expected[11] = 0x1f
    expected[12] = 0xa3
    expected[13] = 0x20
    expected[14] = 0x71
    expected[15] = 0xc4

    if bytes_equal(@out[0], @expected[0], 16) == 0
        return 1
    return 0

# Test with all-zero key and nonce
[[test]]
fn test_chacha20_block_zeros() -> i32
    var key: [32]u8
    var nonce: [12]u8
    var out: [64]u8

    mem_zero(@key[0], 32)
    mem_zero(@nonce[0], 12)

    chacha20_block(@key[0], 0, @nonce[0], @out[0])

    # Known test vector for all-zeros
    # First word should be 0x76b8e0ad
    if out[0] != 0x76
        return 1
    if out[1] != 0xb8
        return 2
    if out[2] != 0xe0
        return 3
    if out[3] != 0xad
        return 4
    return 0

