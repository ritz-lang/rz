# AES Block Cipher Tests
# NIST FIPS 197 test vectors

import cryptosec.aes
import cryptosec.mem
import ritzlib.io

# Convert a hex character to its value (0-15)
fn hex_char_to_val(c: u8) -> u8
    if c >= 48
        if c <= 57
            return c - 48
    if c >= 97
        if c <= 102
            return c - 97 + 10
    if c >= 65
        if c <= 70
            return c - 65 + 10
    return 0

# Helper to convert hex string to bytes
fn hex_to_bytes(hex: *u8, out: *u8, out_len: u64) -> void
    var i: u64 = 0
    while i < out_len
        let hi: u8 = hex[i * 2]
        let lo: u8 = hex[i * 2 + 1]
        let hi_val: u8 = hex_char_to_val(hi)
        let lo_val: u8 = hex_char_to_val(lo)
        out[i] = (hi_val << 4) | lo_val
        i += 1

# ============================================================================
# AES-128 Tests (FIPS 197 Appendix B)
# ============================================================================

[[test]]
fn test_aes128_encrypt_fips197() -> i32
    # FIPS 197 Appendix B test vector
    # Key: 2b7e151628aed2a6abf7158809cf4f3c
    # Plaintext: 3243f6a8885a308d313198a2e0370734
    # Ciphertext: 3925841d02dc09fbdc118597196a0b32

    var key: [16]u8
    var pt: [16]u8
    var ct: [16]u8
    var expected: [16]u8

    hex_to_bytes(c"2b7e151628aed2a6abf7158809cf4f3c", @key[0], 16)
    hex_to_bytes(c"3243f6a8885a308d313198a2e0370734", @pt[0], 16)
    hex_to_bytes(c"3925841d02dc09fbdc118597196a0b32", @expected[0], 16)

    var ctx: Aes128
    aes128_init(@ctx, @key[0])
    aes128_encrypt_block(@ctx, @pt[0], @ct[0])

    if mem_eq(@ct[0], @expected[0], 16) == 0
        return 1
    return 0

[[test]]
fn test_aes128_decrypt_fips197() -> i32
    # Reverse of the encrypt test
    var key: [16]u8
    var ct: [16]u8
    var pt: [16]u8
    var expected: [16]u8

    hex_to_bytes(c"2b7e151628aed2a6abf7158809cf4f3c", @key[0], 16)
    hex_to_bytes(c"3925841d02dc09fbdc118597196a0b32", @ct[0], 16)
    hex_to_bytes(c"3243f6a8885a308d313198a2e0370734", @expected[0], 16)

    var ctx: Aes128
    aes128_init(@ctx, @key[0])
    aes128_decrypt_block(@ctx, @ct[0], @pt[0])

    if mem_eq(@pt[0], @expected[0], 16) == 0
        return 1
    return 0

[[test]]
fn test_aes128_roundtrip() -> i32
    var key: [16]u8
    var pt: [16]u8
    var ct: [16]u8
    var rt: [16]u8

    hex_to_bytes(c"000102030405060708090a0b0c0d0e0f", @key[0], 16)
    hex_to_bytes(c"00112233445566778899aabbccddeeff", @pt[0], 16)

    var ctx: Aes128
    aes128_init(@ctx, @key[0])
    aes128_encrypt_block(@ctx, @pt[0], @ct[0])
    aes128_decrypt_block(@ctx, @ct[0], @rt[0])

    if mem_eq(@pt[0], @rt[0], 16) == 0
        return 1
    return 0

# NIST SP 800-38A test vectors
[[test]]
fn test_aes128_nist_ecb_vector1() -> i32
    # ECB-AES128 test from NIST SP 800-38A
    # Key: 2b7e151628aed2a6abf7158809cf4f3c
    # Block 1 plaintext: 6bc1bee22e409f96e93d7e117393172a
    # Block 1 ciphertext: 3ad77bb40d7a3660a89ecaf32466ef97

    var key: [16]u8
    var pt: [16]u8
    var ct: [16]u8
    var expected: [16]u8

    hex_to_bytes(c"2b7e151628aed2a6abf7158809cf4f3c", @key[0], 16)
    hex_to_bytes(c"6bc1bee22e409f96e93d7e117393172a", @pt[0], 16)
    hex_to_bytes(c"3ad77bb40d7a3660a89ecaf32466ef97", @expected[0], 16)

    var ctx: Aes128
    aes128_init(@ctx, @key[0])
    aes128_encrypt_block(@ctx, @pt[0], @ct[0])

    if mem_eq(@ct[0], @expected[0], 16) == 0
        return 1
    return 0

[[test]]
fn test_aes128_nist_ecb_vector2() -> i32
    # Block 2
    var key: [16]u8
    var pt: [16]u8
    var ct: [16]u8
    var expected: [16]u8

    hex_to_bytes(c"2b7e151628aed2a6abf7158809cf4f3c", @key[0], 16)
    hex_to_bytes(c"ae2d8a571e03ac9c9eb76fac45af8e51", @pt[0], 16)
    hex_to_bytes(c"f5d3d58503b9699de785895a96fdbaaf", @expected[0], 16)

    var ctx: Aes128
    aes128_init(@ctx, @key[0])
    aes128_encrypt_block(@ctx, @pt[0], @ct[0])

    if mem_eq(@ct[0], @expected[0], 16) == 0
        return 1
    return 0

# ============================================================================
# AES-256 Tests (FIPS 197 Appendix C.3)
# ============================================================================

[[test]]
fn test_aes256_encrypt_fips197() -> i32
    # FIPS 197 Appendix C.3 test vector
    # Key: 000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f
    # Plaintext: 00112233445566778899aabbccddeeff
    # Ciphertext: 8ea2b7ca516745bfeafc49904b496089

    var key: [32]u8
    var pt: [16]u8
    var ct: [16]u8
    var expected: [16]u8

    hex_to_bytes(c"000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f", @key[0], 32)
    hex_to_bytes(c"00112233445566778899aabbccddeeff", @pt[0], 16)
    hex_to_bytes(c"8ea2b7ca516745bfeafc49904b496089", @expected[0], 16)

    var ctx: Aes256
    aes256_init(@ctx, @key[0])
    aes256_encrypt_block(@ctx, @pt[0], @ct[0])

    if mem_eq(@ct[0], @expected[0], 16) == 0
        return 1
    return 0

[[test]]
fn test_aes256_decrypt_fips197() -> i32
    # Reverse of encrypt test
    var key: [32]u8
    var ct: [16]u8
    var pt: [16]u8
    var expected: [16]u8

    hex_to_bytes(c"000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f", @key[0], 32)
    hex_to_bytes(c"8ea2b7ca516745bfeafc49904b496089", @ct[0], 16)
    hex_to_bytes(c"00112233445566778899aabbccddeeff", @expected[0], 16)

    var ctx: Aes256
    aes256_init(@ctx, @key[0])
    aes256_decrypt_block(@ctx, @ct[0], @pt[0])

    if mem_eq(@pt[0], @expected[0], 16) == 0
        return 1
    return 0

[[test]]
fn test_aes256_roundtrip() -> i32
    var key: [32]u8
    var pt: [16]u8
    var ct: [16]u8
    var rt: [16]u8

    hex_to_bytes(c"603deb1015ca71be2b73aef0857d77811f352c073b6108d72d9810a30914dff4", @key[0], 32)
    hex_to_bytes(c"6bc1bee22e409f96e93d7e117393172a", @pt[0], 16)

    var ctx: Aes256
    aes256_init(@ctx, @key[0])
    aes256_encrypt_block(@ctx, @pt[0], @ct[0])
    aes256_decrypt_block(@ctx, @ct[0], @rt[0])

    if mem_eq(@pt[0], @rt[0], 16) == 0
        return 1
    return 0

[[test]]
fn test_aes256_nist_ecb_vector1() -> i32
    # NIST SP 800-38A AES-256 ECB
    # Key: 603deb1015ca71be2b73aef0857d77811f352c073b6108d72d9810a30914dff4
    # Plaintext: 6bc1bee22e409f96e93d7e117393172a
    # Ciphertext: f3eed1bdb5d2a03c064b5a7e3db181f8

    var key: [32]u8
    var pt: [16]u8
    var ct: [16]u8
    var expected: [16]u8

    hex_to_bytes(c"603deb1015ca71be2b73aef0857d77811f352c073b6108d72d9810a30914dff4", @key[0], 32)
    hex_to_bytes(c"6bc1bee22e409f96e93d7e117393172a", @pt[0], 16)
    hex_to_bytes(c"f3eed1bdb5d2a03c064b5a7e3db181f8", @expected[0], 16)

    var ctx: Aes256
    aes256_init(@ctx, @key[0])
    aes256_encrypt_block(@ctx, @pt[0], @ct[0])

    if mem_eq(@ct[0], @expected[0], 16) == 0
        return 1
    return 0

# ============================================================================
# All-zeros and all-ones tests
# ============================================================================

[[test]]
fn test_aes128_zero_key_zero_pt() -> i32
    # Known answer for all-zero key and plaintext
    # Key: 00000000000000000000000000000000
    # PT: 00000000000000000000000000000000
    # CT: 66e94bd4ef8a2c3b884cfa59ca342b2e

    var key: [16]u8
    var pt: [16]u8
    var ct: [16]u8
    var expected: [16]u8

    # Zero-initialize key and plaintext
    mem_zero(@key[0], 16)
    mem_zero(@pt[0], 16)

    hex_to_bytes(c"66e94bd4ef8a2c3b884cfa59ca342b2e", @expected[0], 16)

    var ctx: Aes128
    aes128_init(@ctx, @key[0])
    aes128_encrypt_block(@ctx, @pt[0], @ct[0])

    if mem_eq(@ct[0], @expected[0], 16) == 0
        return 1
    return 0

[[test]]
fn test_aes256_zero_key_zero_pt() -> i32
    # All-zero key and plaintext for AES-256
    # Key: 0000...0000 (32 bytes)
    # PT: 00000000000000000000000000000000
    # CT: dc95c078a2408989ad48a21492842087

    var key: [32]u8
    var pt: [16]u8
    var ct: [16]u8
    var expected: [16]u8

    # Zero-initialize key and plaintext
    mem_zero(@key[0], 32)
    mem_zero(@pt[0], 16)

    hex_to_bytes(c"dc95c078a2408989ad48a21492842087", @expected[0], 16)

    var ctx: Aes256
    aes256_init(@ctx, @key[0])
    aes256_encrypt_block(@ctx, @pt[0], @ct[0])

    if mem_eq(@ct[0], @expected[0], 16) == 0
        return 1
    return 0

# ============================================================================
# Multiple blocks (in-place operation)
# ============================================================================

[[test]]
fn test_aes128_multiple_blocks() -> i32
    # Encrypt two blocks with same key
    var key: [16]u8
    var pt1: [16]u8
    var pt2: [16]u8
    var ct1: [16]u8
    var ct2: [16]u8
    var rt1: [16]u8
    var rt2: [16]u8

    hex_to_bytes(c"2b7e151628aed2a6abf7158809cf4f3c", @key[0], 16)
    hex_to_bytes(c"6bc1bee22e409f96e93d7e117393172a", @pt1[0], 16)
    hex_to_bytes(c"ae2d8a571e03ac9c9eb76fac45af8e51", @pt2[0], 16)

    var ctx: Aes128
    aes128_init(@ctx, @key[0])
    aes128_encrypt_block(@ctx, @pt1[0], @ct1[0])
    aes128_encrypt_block(@ctx, @pt2[0], @ct2[0])
    aes128_decrypt_block(@ctx, @ct1[0], @rt1[0])
    aes128_decrypt_block(@ctx, @ct2[0], @rt2[0])

    if mem_eq(@pt1[0], @rt1[0], 16) == 0
        return 1
    if mem_eq(@pt2[0], @rt2[0], 16) == 0
        return 2
    return 0
