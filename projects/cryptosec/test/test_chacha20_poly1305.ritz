# ChaCha20-Poly1305 AEAD tests
# RFC 8439 test vectors

import lib.chacha20_poly1305
import lib.mem

# Helper to check if two byte arrays are equal
fn bytes_equal(a: *u8, b: *u8, len: i64) -> i32
    var i: i64 = 0
    while i < len
        if a[i] != b[i]
            return 0
        i += 1
    return 1

