    var ct: [114]u8
    var tag: [16]u8

    let ct_len: i64 = chacha20_poly1305_encrypt(&key[0], &nonce[0], &aad[0], 12, &pt[0], 114, &ct[0], &tag[0])

    # Expected ciphertext first 16 bytes: d3 1a 8d 34 64 8e 60 db 7b 86 af bc 53 ef 7e c2
    var expected_ct: [16]u8
    expected_ct[0] = 0xd3
    expected_ct[1] = 0x1a
    expected_ct[2] = 0x8d
    expected_ct[3] = 0x34
    expected_ct[4] = 0x64
    expected_ct[5] = 0x8e
    expected_ct[6] = 0x60
    expected_ct[7] = 0xdb
    expected_ct[8] = 0x7b
    expected_ct[9] = 0x86
    expected_ct[10] = 0xaf
    expected_ct[11] = 0xbc
    expected_ct[12] = 0x53
    expected_ct[13] = 0xef
    expected_ct[14] = 0x7e
    expected_ct[15] = 0xc2

    if bytes_equal(&ct[0], &expected_ct[0], 16) == 0
        return 1

    # Expected tag: 1a:e1:0b:59:4f:09:e2:6a:7e:90:2e:cb:d0:60:06:91
    var expected_tag: [16]u8
    expected_tag[0] = 0x1a
    expected_tag[1] = 0xe1
    expected_tag[2] = 0x0b
    expected_tag[3] = 0x59
    expected_tag[4] = 0x4f
    expected_tag[5] = 0x09
    expected_tag[6] = 0xe2
    expected_tag[7] = 0x6a
    expected_tag[8] = 0x7e
    expected_tag[9] = 0x90
    expected_tag[10] = 0x2e
    expected_tag[11] = 0xcb
    expected_tag[12] = 0xd0
    expected_tag[13] = 0x60
    expected_tag[14] = 0x06
    expected_tag[15] = 0x91

    if bytes_equal(&tag[0], &expected_tag[0], 16) == 0
        # Debug: return different codes for each byte position that doesn't match
        var i: i64 = 0
        while i < 16
            if tag[i] != expected_tag[i]
                return 2 + (i as i32) * 1000
            i += 1
        return 2

    return 0

# Test roundtrip encryption/decryption
[[test]]
fn test_chacha20_poly1305_roundtrip() -> i32
    var key: [32]u8
    var nonce: [12]u8
    var aad: [16]u8
    var pt: [64]u8
    var ct: [64]u8
    var decrypted: [64]u8
    var tag: [16]u8

    var i: i64 = 0
    while i < 32
        key[i] = (i * 7) as u8
        i += 1

    i = 0
    while i < 12
        nonce[i] = (i * 13) as u8
        i += 1

    i = 0
    while i < 16
        aad[i] = (i * 3) as u8
        i += 1

    i = 0
    while i < 64
        pt[i] = (i * 5) as u8
        i += 1

    let ct_len: i64 = chacha20_poly1305_encrypt(&key[0], &nonce[0], &aad[0], 16, &pt[0], 64, &ct[0], &tag[0])
    let result: i32 = chacha20_poly1305_decrypt(&key[0], &nonce[0], &aad[0], 16, &ct[0], ct_len, &tag[0], &decrypted[0])

    if result != 1
        return 1
    if bytes_equal(&pt[0], &decrypted[0], 64) == 0
        return 2
    return 0

# Test no AAD
[[test]]
fn test_chacha20_poly1305_no_aad() -> i32
    var key: [32]u8
    var nonce: [12]u8
    var pt: [32]u8
    var ct: [32]u8
    var decrypted: [32]u8
    var tag: [16]u8

    mem_zero(&key[0], 32)
    mem_zero(&nonce[0], 12)

    var i: i64 = 0
    while i < 32
        pt[i] = i as u8
        i += 1

    chacha20_poly1305_encrypt(&key[0], &nonce[0], nil, 0, &pt[0], 32, &ct[0], &tag[0])
    let result: i32 = chacha20_poly1305_decrypt(&key[0], &nonce[0], nil, 0, &ct[0], 32, &tag[0], &decrypted[0])

    if result != 1
        return 1
    if bytes_equal(&pt[0], &decrypted[0], 32) == 0
        return 2
    return 0

# Test tampered ciphertext
[[test]]
fn test_chacha20_poly1305_tampered_ct() -> i32
    var key: [32]u8
    var nonce: [12]u8
    var pt: [32]u8
    var ct: [32]u8
    var decrypted: [32]u8
    var tag: [16]u8

    mem_zero(&key[0], 32)
    mem_zero(&nonce[0], 12)
    mem_zero(&pt[0], 32)

    chacha20_poly1305_encrypt(&key[0], &nonce[0], nil, 0, &pt[0], 32, &ct[0], &tag[0])

    # Tamper with ciphertext
    ct[0] = ct[0] ^ 0x01

    let result: i32 = chacha20_poly1305_decrypt(&key[0], &nonce[0], nil, 0, &ct[0], 32, &tag[0], &decrypted[0])

    if result != 0
        return 1
    return 0

# Test tampered tag
[[test]]
fn test_chacha20_poly1305_tampered_tag() -> i32
    var key: [32]u8
    var nonce: [12]u8
    var pt: [32]u8
    var ct: [32]u8
    var decrypted: [32]u8
    var tag: [16]u8

    mem_zero(&key[0], 32)
    mem_zero(&nonce[0], 12)
    mem_zero(&pt[0], 32)

    chacha20_poly1305_encrypt(&key[0], &nonce[0], nil, 0, &pt[0], 32, &ct[0], &tag[0])

    # Tamper with tag
    tag[0] = tag[0] ^ 0x01

    let result: i32 = chacha20_poly1305_decrypt(&key[0], &nonce[0], nil, 0, &ct[0], 32, &tag[0], &decrypted[0])

    if result != 0
        return 1
    return 0

# Test wrong AAD
[[test]]
fn test_chacha20_poly1305_wrong_aad() -> i32
    var key: [32]u8
    var nonce: [12]u8
    var aad: [8]u8
    var wrong_aad: [8]u8
    var pt: [16]u8
    var ct: [16]u8
    var decrypted: [16]u8
    var tag: [16]u8

    mem_zero(&key[0], 32)
    mem_zero(&nonce[0], 12)
    mem_zero(&aad[0], 8)
    mem_zero(&wrong_aad[0], 8)
    mem_zero(&pt[0], 16)
    wrong_aad[0] = 1

    chacha20_poly1305_encrypt(&key[0], &nonce[0], &aad[0], 8, &pt[0], 16, &ct[0], &tag[0])
    let result: i32 = chacha20_poly1305_decrypt(&key[0], &nonce[0], &wrong_aad[0], 8, &ct[0], 16, &tag[0], &decrypted[0])

    if result != 0
        return 1
    return 0

# Test empty plaintext
[[test]]
fn test_chacha20_poly1305_empty_pt() -> i32
    var key: [32]u8
    var nonce: [12]u8
    var aad: [16]u8
    var tag: [16]u8

    var i: i64 = 0
    while i < 32
        key[i] = i as u8
        i += 1

    i = 0
    while i < 12
        nonce[i] = i as u8
        i += 1

    i = 0
    while i < 16
        aad[i] = (i + 0x10) as u8
        i += 1

    # Encrypt empty plaintext with AAD
    chacha20_poly1305_encrypt(&key[0], &nonce[0], &aad[0], 16, nil, 0, nil, &tag[0])

    # Decrypt should succeed
    let result: i32 = chacha20_poly1305_decrypt(&key[0], &nonce[0], &aad[0], 16, nil, 0, &tag[0], nil)

    if result != 1
        return 1
    return 0
