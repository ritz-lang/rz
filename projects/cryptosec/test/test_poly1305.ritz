# Poly1305 tests
# RFC 8439 test vectors

import cryptosec.poly1305
import cryptosec.mem

# Helper to check if two byte arrays are equal
fn bytes_equal(a: *u8, b: *u8, len: i64) -> i32
    var i: i64 = 0
    while i < len
        if a[i] != b[i]
            return 0
        i += 1
    return 1

# =============================================================================
# Poly1305 Tests
# =============================================================================

# RFC 8439 Section 2.5.2 Test Vector
[[test]]
fn test_poly1305_rfc8439() -> i32
    # Key: 85:d6:be:78:57:55:6d:33:7f:44:52:fe:42:d5:06:a8:01:03:80:8a:fb:0d:b2:fd:4a:bf:f6:af:41:49:f5:1b
    var key: [32]u8
    key[0] = 0x85
    key[1] = 0xd6
    key[2] = 0xbe
    key[3] = 0x78
    key[4] = 0x57
    key[5] = 0x55
    key[6] = 0x6d
    key[7] = 0x33
    key[8] = 0x7f
    key[9] = 0x44
    key[10] = 0x52
    key[11] = 0xfe
    key[12] = 0x42
    key[13] = 0xd5
    key[14] = 0x06
    key[15] = 0xa8
    key[16] = 0x01
    key[17] = 0x03
    key[18] = 0x80
    key[19] = 0x8a
    key[20] = 0xfb
    key[21] = 0x0d
    key[22] = 0xb2
    key[23] = 0xfd
    key[24] = 0x4a
    key[25] = 0xbf
    key[26] = 0xf6
    key[27] = 0xaf
    key[28] = 0x41
    key[29] = 0x49
    key[30] = 0xf5
    key[31] = 0x1b

    # Message: "Cryptographic Forum Research Group"
    var msg: [34]u8
    msg[0] = 0x43   # C
    msg[1] = 0x72   # r
    msg[2] = 0x79   # y
    msg[3] = 0x70   # p
    msg[4] = 0x74   # t
    msg[5] = 0x6f   # o
    msg[6] = 0x67   # g
    msg[7] = 0x72   # r
    msg[8] = 0x61   # a
    msg[9] = 0x70   # p
    msg[10] = 0x68  # h
    msg[11] = 0x69  # i
    msg[12] = 0x63  # c
    msg[13] = 0x20  # (space)
    msg[14] = 0x46  # F
    msg[15] = 0x6f  # o
    msg[16] = 0x72  # r
    msg[17] = 0x75  # u
    msg[18] = 0x6d  # m
    msg[19] = 0x20  # (space)
    msg[20] = 0x52  # R
    msg[21] = 0x65  # e
    msg[22] = 0x73  # s
    msg[23] = 0x65  # e
    msg[24] = 0x61  # a
    msg[25] = 0x72  # r
    msg[26] = 0x63  # c
    msg[27] = 0x68  # h
    msg[28] = 0x20  # (space)
    msg[29] = 0x47  # G
    msg[30] = 0x72  # r
    msg[31] = 0x6f  # o
    msg[32] = 0x75  # u
    msg[33] = 0x70  # p

    var tag: [16]u8
    poly1305_mac(@key[0], @msg[0], 34, @tag[0])

    # Expected tag: a8:06:1d:c1:30:51:36:c6:c2:2b:8b:af:0c:01:27:a9
    var expected: [16]u8
    expected[0] = 0xa8
    expected[1] = 0x06
    expected[2] = 0x1d
    expected[3] = 0xc1
    expected[4] = 0x30
    expected[5] = 0x51
    expected[6] = 0x36
    expected[7] = 0xc6
    expected[8] = 0xc2
    expected[9] = 0x2b
    expected[10] = 0x8b
    expected[11] = 0xaf
    expected[12] = 0x0c
    expected[13] = 0x01
    expected[14] = 0x27
    expected[15] = 0xa9

    if bytes_equal(@tag[0], @expected[0], 16) == 0
        return 1
    return 0

# Test with empty message
[[test]]
fn test_poly1305_empty() -> i32
    var key: [32]u8
    var i: i64 = 0
    while i < 32
        key[i] = i as u8
        i += 1

    var tag: [16]u8
    poly1305_mac(@key[0], nil, 0, @tag[0])

    # For empty message, tag should just be s (the second half of key) clamped
    # This is a basic sanity check
    if tag[0] == 0 && tag[1] == 0 && tag[2] == 0 && tag[3] == 0
        # Not all zeros is a good sign (s != 0)
        return 1
    return 0

# Test streaming API
[[test]]
fn test_poly1305_streaming() -> i32
    var key: [32]u8
    var i: i64 = 0
    while i < 32
        key[i] = (i * 5) as u8
        i += 1

    var msg: [48]u8
    i = 0
    while i < 48
        msg[i] = i as u8
        i += 1

    # One-shot
    var tag1: [16]u8
    poly1305_mac(@key[0], @msg[0], 48, @tag1[0])

    # Streaming in chunks
    var tag2: [16]u8
    var ctx: Poly1305
    poly1305_init(@ctx, @key[0])
    poly1305_update(@ctx, @msg[0], 16)
    poly1305_update(@ctx, @msg[16], 16)
    poly1305_update(@ctx, @msg[32], 16)
    poly1305_final(@ctx, @tag2[0])

    if bytes_equal(@tag1[0], @tag2[0], 16) == 0
        return 1
    return 0

# Test with single byte message
[[test]]
fn test_poly1305_single_byte() -> i32
    var key: [32]u8
    mem_zero(@key[0], 32)
    key[0] = 1

    var msg: [1]u8
    msg[0] = 0x41  # 'A'

    var tag: [16]u8
    poly1305_mac(@key[0], @msg[0], 1, @tag[0])

    # Just verify we get a non-zero tag
    var sum: u32 = 0
    var i: i64 = 0
    while i < 16
        sum = sum + (tag[i] as u32)
        i += 1

    if sum == 0
        return 1
    return 0
