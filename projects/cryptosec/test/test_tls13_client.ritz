# test/test_tls13_client.ritz - Tests for TLS 1.3 Client

import ritzlib.sys

import cryptosec.mem
import cryptosec.tls13_client
import cryptosec.tls13_handshake

# ============================================================================
# Config Tests
# ============================================================================

[[test]]
fn test_config_init() -> i32
    var cfg: TlsConfig
    tls_config_init(@cfg)

    if cfg.num_cipher_suites != 2
        return 1

    if cfg.cipher_suites[0] != TLS_AES_128_GCM_SHA256
        return 2

    if cfg.verify_cert != 1
        return 3

    return 0

[[test]]
fn test_config_set_hostname() -> i32
    var cfg: TlsConfig
    tls_config_init(@cfg)

    tls_config_set_hostname(@cfg, "example.com", 11)

    if cfg.hostname_len != 11
        return 1

    if cfg.hostname[0] != 101  # 'e'
        return 2

    return 0

# ============================================================================
# Client Init Tests
# ============================================================================

[[test]]
fn test_client_init() -> i32
    var cfg: TlsConfig
    tls_config_init(@cfg)
    tls_config_set_hostname(@cfg, "test.local", 10)

    var client: TlsClient
    tls_client_init(@client, @cfg)

    if client.state != TLS_STATE_INIT
        return 1

    if client.handshake_complete != 0
        return 2

    # Check hostname was copied to ClientHello
    if client.client_hello.hostname_len != 10
        return 3

    return 0

[[test]]
fn test_client_start() -> i32
    var cfg: TlsConfig
    tls_config_init(@cfg)
    tls_config_set_hostname(@cfg, "example.com", 11)

    var client: TlsClient
    tls_client_init(@client, @cfg)

    var out: [1024]u8
    let len: i64 = tls_client_start(@client, @out[0], 1024)

    if len < 50
        return 1

    # Should have transitioned state
    if client.state != TLS_STATE_CLIENT_HELLO_SENT
        return 2

    # Check TLS record header
    if out[0] != 22  # Handshake
        return 3

    # Check handshake type inside
    if out[5] != HS_CLIENT_HELLO
        return 4

    return 0

[[test]]
fn test_client_start_small_buffer() -> i32
    var cfg: TlsConfig
    tls_config_init(@cfg)

    var client: TlsClient
    tls_client_init(@client, @cfg)

    var out: [10]u8  # Too small
    let len: i64 = tls_client_start(@client, @out[0], 10)

    if len >= 0
        return 1  # Should have failed

    if client.last_error != TLS_ERR_BUFFER_TOO_SMALL
        return 2

    return 0

# ============================================================================
# State Machine Tests
# ============================================================================

[[test]]
fn test_client_state_accessors() -> i32
    var cfg: TlsConfig
    tls_config_init(@cfg)

    var client: TlsClient
    tls_client_init(@client, @cfg)

    if tls_client_state(@client) != TLS_STATE_INIT
        return 1

    if tls_client_is_connected(@client) != 0
        return 2

    if tls_client_error(@client) != 0
        return 3

    return 0

[[test]]
fn test_client_process_wrong_state() -> i32
    var cfg: TlsConfig
    tls_config_init(@cfg)

    var client: TlsClient
    tls_client_init(@client, @cfg)

    # Try to process data without starting handshake
    var data: [10]u8
    var out: [100]u8
    var out_len: i64 = 0

    let result: i32 = tls_client_process(@client, @data[0], 10, @out[0], 100, @out_len)

    # Should fail - wrong state
    if result != TLS_RESULT_ERROR
        return 1

    return 0

# ============================================================================
# ServerHello Processing Tests
# ============================================================================

[[test]]
fn test_client_needs_more_data() -> i32
    var cfg: TlsConfig
    tls_config_init(@cfg)

    var client: TlsClient
    tls_client_init(@client, @cfg)

    # Start handshake
    var ch_out: [1024]u8
    tls_client_start(@client, @ch_out[0], 1024)

    # Send incomplete data
    var partial: [3]u8
    partial[0] = 22  # Handshake
    partial[1] = 0x03
    partial[2] = 0x03

    var out: [100]u8
    var out_len: i64 = 0

    let result: i32 = tls_client_process(@client, @partial[0], 3, @out[0], 100, @out_len)

    if result != TLS_RESULT_NEED_INPUT
        return 1

    return 0

[[test]]
fn test_client_wrong_content_type() -> i32
    var cfg: TlsConfig
    tls_config_init(@cfg)

    var client: TlsClient
    tls_client_init(@client, @cfg)

    # Start handshake
    var ch_out: [1024]u8
    tls_client_start(@client, @ch_out[0], 1024)

    # Send wrong content type
    var data: [10]u8
    data[0] = 21  # Alert instead of Handshake
    data[1] = 0x03
    data[2] = 0x03
    data[3] = 0x00
    data[4] = 0x02  # Length 2
    data[5] = 0x01
    data[6] = 0x00

    var out: [100]u8
    var out_len: i64 = 0

    let result: i32 = tls_client_process(@client, @data[0], 7, @out[0], 100, @out_len)

    if result != TLS_RESULT_ERROR
        return 1

    if client.last_error != TLS_ERR_UNEXPECTED_MESSAGE
        return 2

    return 0

# ============================================================================
# Application Data Tests
# ============================================================================

[[test]]
fn test_write_not_connected() -> i32
    var cfg: TlsConfig
    tls_config_init(@cfg)

    var client: TlsClient
    tls_client_init(@client, @cfg)

    var data: [10]u8
    var out: [100]u8

    let result: i64 = tls_client_write(@client, @data[0], 10, @out[0], 100)

    if result >= 0
        return 1  # Should fail - not connected

    return 0

[[test]]
fn test_read_not_connected() -> i32
    var cfg: TlsConfig
    tls_config_init(@cfg)

    var client: TlsClient
    tls_client_init(@client, @cfg)

    var data: [10]u8
    var out: [100]u8

    let result: i64 = tls_client_read(@client, @data[0], 10, @out[0], 100)

    if result >= 0
        return 1  # Should fail - not connected

    return 0

# ============================================================================
# Close Tests
# ============================================================================

[[test]]
fn test_close_not_connected() -> i32
    var cfg: TlsConfig
    tls_config_init(@cfg)

    var client: TlsClient
    tls_client_init(@client, @cfg)

    var out: [100]u8
    let result: i64 = tls_client_close(@client, @out[0], 100)

    if result != 0
        return 1  # Should return 0 (nothing to send) when not connected

    return 0

# ============================================================================
# Memory Cleanup Tests
# ============================================================================

[[test]]
fn test_client_free() -> i32
    var cfg: TlsConfig
    tls_config_init(@cfg)

    var client: TlsClient
    tls_client_init(@client, @cfg)

    # Start handshake to populate some sensitive data
    var out: [1024]u8
    tls_client_start(@client, @out[0], 1024)

    # Free should zero sensitive data
    tls_client_free(@client)

    # Check that shared secret is zeroed
    var all_zero: i32 = 1
    var i: i32 = 0
    while i < 32
        if client.shared_secret[i] != 0
            all_zero = 0
        i += 1

    if all_zero != 1
        return 1

    return 0
