# test/test_cpuid.ritz - Tests for CPU feature detection
#
# Tests CPUID-based detection of:
# - SHA-NI (SHA extensions)
# - AES-NI (AES extensions)
# - AVX2 (Advanced Vector Extensions 2)
# - AVX-512F (AVX-512 Foundation)
# - PCLMULQDQ (carryless multiply)

import cryptosec.cpuid

# ============================================================================
# Basic Detection Tests
# ============================================================================

# These tests verify that the detection functions return valid booleans
# (0 or 1) and don't crash. Actual feature presence depends on hardware.

[[test]]
fn test_cpu_has_sha_ni_returns_bool() -> i32
    let result: i32 = cpu_has_sha_ni()
    if result != 0 && result != 1
        return 1  # Must return 0 or 1
    return 0

[[test]]
fn test_cpu_has_aes_ni_returns_bool() -> i32
    let result: i32 = cpu_has_aes_ni()
    if result != 0 && result != 1
        return 1
    return 0

[[test]]
fn test_cpu_has_avx_returns_bool() -> i32
    let result: i32 = cpu_has_avx()
    if result != 0 && result != 1
        return 1
    return 0

[[test]]
fn test_cpu_has_avx2_returns_bool() -> i32
    let result: i32 = cpu_has_avx2()
    if result != 0 && result != 1
        return 1
    return 0

[[test]]
fn test_cpu_has_avx512_returns_bool() -> i32
    let result: i32 = cpu_has_avx512()
    if result != 0 && result != 1
        return 1
    return 0

[[test]]
fn test_cpu_has_pclmulqdq_returns_bool() -> i32
    let result: i32 = cpu_has_pclmulqdq()
    if result != 0 && result != 1
        return 1
    return 0

# ============================================================================
# Consistency Tests
# ============================================================================

[[test]]
fn test_cpu_features_consistent() -> i32
    # Multiple calls should return the same result (features don't change at runtime)
    let sha1: i32 = cpu_has_sha_ni()
    let sha2: i32 = cpu_has_sha_ni()
    if sha1 != sha2
        return 1

    let aes1: i32 = cpu_has_aes_ni()
    let aes2: i32 = cpu_has_aes_ni()
    if aes1 != aes2
        return 2

    let avx1: i32 = cpu_has_avx2()
    let avx2: i32 = cpu_has_avx2()
    if avx1 != avx2
        return 3

    return 0

# ============================================================================
# Implication Tests
# ============================================================================

[[test]]
fn test_avx512_implies_avx2() -> i32
    # If AVX-512 is present, AVX2 must also be present
    let avx512: i32 = cpu_has_avx512()
    let avx2: i32 = cpu_has_avx2()
    if avx512 == 1 && avx2 == 0
        return 1  # Impossible: AVX-512 requires AVX2
    return 0

[[test]]
fn test_avx2_implies_avx() -> i32
    # If AVX2 is present, AVX must also be present
    let avx2: i32 = cpu_has_avx2()
    let avx: i32 = cpu_has_avx()
    if avx2 == 1 && avx == 0
        return 1  # Impossible: AVX2 requires AVX
    return 0

# ============================================================================
# Cache Tests
# ============================================================================

[[test]]
fn test_cpu_features_cached() -> i32
    # Features should be cached after first detection
    # This verifies no crash on many rapid calls
    var i: i32 = 0
    while i < 100
        cpu_has_sha_ni()
        cpu_has_aes_ni()
        cpu_has_avx2()
        cpu_has_avx512()
        cpu_has_pclmulqdq()
        i += 1
    return 0

# ============================================================================
# Raw CPUID Tests
# ============================================================================

[[test]]
fn test_cpuid_raw_leaf_0() -> i32
    # Leaf 0 returns vendor string and max leaf in EAX
    var eax: i32 = 0
    var ebx: i32 = 0
    var ecx: i32 = 0
    var edx: i32 = 0

    cpuid_raw(0, 0, @eax, @ebx, @ecx, @edx)

    # EAX should contain max supported leaf (at least 1 for any x86-64 CPU)
    if eax < 1
        return 1

    # EBX, EDX, ECX contain vendor string
    # Intel: "GenuineIntel" -> ebx='Genu', edx='ineI', ecx='ntel'
    # AMD: "AuthenticAMD" -> ebx='Auth', edx='enti', ecx='cAMD'
    # Should be non-zero for any real CPU
    if ebx == 0 && edx == 0 && ecx == 0
        return 2

    return 0

[[test]]
fn test_cpuid_raw_leaf_1() -> i32
    # Leaf 1 returns feature flags
    var eax: i32 = 0
    var ebx: i32 = 0
    var ecx: i32 = 0
    var edx: i32 = 0

    cpuid_raw(1, 0, @eax, @ebx, @ecx, @edx)

    # EAX contains processor info (stepping, model, family)
    # Should be non-zero for any real CPU
    if eax == 0
        return 1

    # EDX contains basic features that all x86-64 CPUs have
    # Bit 0: FPU (always present on x86-64)
    # Bit 4: TSC (time stamp counter, always present)
    # Bit 23: MMX (always present on x86-64)
    # Bit 25: SSE (always present on x86-64)
    # Bit 26: SSE2 (always present on x86-64)
    let has_sse2: i32 = (edx >> 26) & 1
    if has_sse2 != 1
        return 2  # All x86-64 CPUs have SSE2

    return 0

# ============================================================================
# Feature Structure Tests
# ============================================================================

[[test]]
fn test_cpu_detect_features_struct() -> i32
    var features: CpuFeatures

    cpu_detect_features(@features)

    # Verify all fields are valid booleans
    if features.has_aes_ni != 0 && features.has_aes_ni != 1
        return 1
    if features.has_sha_ni != 0 && features.has_sha_ni != 1
        return 2
    if features.has_avx != 0 && features.has_avx != 1
        return 3
    if features.has_avx2 != 0 && features.has_avx2 != 1
        return 4
    if features.has_avx512f != 0 && features.has_avx512f != 1
        return 5
    if features.has_pclmulqdq != 0 && features.has_pclmulqdq != 1
        return 6

    return 0

[[test]]
fn test_cpu_detect_features_matches_individual() -> i32
    var features: CpuFeatures
    cpu_detect_features(@features)

    # Struct should match individual function calls
    if features.has_aes_ni != cpu_has_aes_ni()
        return 1
    if features.has_sha_ni != cpu_has_sha_ni()
        return 2
    if features.has_avx != cpu_has_avx()
        return 3
    if features.has_avx2 != cpu_has_avx2()
        return 4
    if features.has_avx512f != cpu_has_avx512()
        return 5
    if features.has_pclmulqdq != cpu_has_pclmulqdq()
        return 6

    return 0
