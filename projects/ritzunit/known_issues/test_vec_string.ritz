# test/test_vec_string.ritz - Test Vec<u8> string operations
#
# Debug test for string comparison in Vec

import ritzlib.gvec
import ritzlib.str
import ritzlib.sys
import ritzlib.io
import ritzlib.memory

# Compare Vec<u8> to null-terminated string
fn str_eq_ptr(v:&Vec<u8>, s: *u8) -> i32
    var i: i64 = 0
    while i < v.len
        let c: u8 = *(s + i)
        if c == 0
            return 0  # s ended early
        if vec_get<u8>(v, i) != c
            return 0  # mismatch
        i += 1
    if *(s + i) == 0
        return 1
    return 0

[[test]]
fn test_simple_vec_str_compare() -> i32
    var v: Vec<u8> = vec_new<u8>()
    vec_push_str(&v, "hello")

    let eq: i32 = str_eq_ptr(&v, "hello")
    vec_drop<u8>(&v)

    if eq != 1
        return 1
    return 0

[[test]]
fn test_vec_str_different() -> i32
    var v: Vec<u8> = vec_new<u8>()
    vec_push_str(&v, "hello")

    let eq: i32 = str_eq_ptr(&v, "world")
    vec_drop<u8>(&v)

    if eq != 0
        return 1  # Should not be equal
    return 0

[[test]]
fn test_three_vecs() -> i32
    var v1: Vec<u8> = vec_new<u8>()
    var v2: Vec<u8> = vec_new<u8>()
    var v3: Vec<u8> = vec_new<u8>()

    vec_push_str(&v1, "sword")
    vec_push_str(&v2, "shield")
    vec_push_str(&v3, "potion")

    let r1: i32 = str_eq_ptr(&v1, "sword")
    let r2: i32 = str_eq_ptr(&v2, "shield")
    let r3: i32 = str_eq_ptr(&v3, "potion")

    vec_drop<u8>(&v1)
    vec_drop<u8>(&v2)
    vec_drop<u8>(&v3)

    if r1 != 1
        return 1
    if r2 != 1
        return 2
    if r3 != 1
        return 3
    return 0

struct TestItem
    name: Vec<u8>
    value: i32

[[test]]
fn test_struct_with_vec() -> i32
    var items: Vec<TestItem> = vec_new<TestItem>()

    var item1: TestItem
    item1.name = vec_new<u8>()
    vec_push_str(&item1.name, "sword")
    item1.value = 1
    vec_push<TestItem>(&items, item1)

    var item2: TestItem
    item2.name = vec_new<u8>()
    vec_push_str(&item2.name, "shield")
    item2.value = 2
    vec_push<TestItem>(&items, item2)

    var item3: TestItem
    item3.name = vec_new<u8>()
    vec_push_str(&item3.name, "potion")
    item3.value = 3
    vec_push<TestItem>(&items, item3)

    # Check item 0 (sword)
    let p0: *TestItem = vec_get_ptr<TestItem>(&items, 0)
    if str_eq_ptr(&p0.name, "sword") != 1
        return 1

    # Check item 1 (shield)
    let p1: *TestItem = vec_get_ptr<TestItem>(&items, 1)
    if str_eq_ptr(&p1.name, "shield") != 1
        return 2

    # Check item 2 (potion)
    let p2: *TestItem = vec_get_ptr<TestItem>(&items, 2)
    if str_eq_ptr(&p2.name, "potion") != 1
        return 3

    # Clean up
    var i: i64 = 0
    while i < 3
        let p: *TestItem = vec_get_ptr<TestItem>(&items, i)
        vec_drop<u8>(&p.name)
        i += 1
    vec_drop<TestItem>(&items)

    return 0
