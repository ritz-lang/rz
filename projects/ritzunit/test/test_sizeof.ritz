# Test sizeof for Item struct

import ritzlib.io
import ritzlib.sys

const MAX_NAME_LEN: i64 = 32

struct Item
    name: [32]u8       # Fixed-size name buffer
    name_len: i64      # Actual name length
    quantity: i32      # Current quantity

fn main() -> i32
    prints("sizeof(Item) = ")
    print_int(sizeof(Item))
    prints("\n")
    
    prints("sizeof(i64) = ")
    print_int(sizeof(i64))
    prints("\n")
    
    prints("sizeof(i32) = ")
    print_int(sizeof(i32))
    prints("\n")
    
    prints("sizeof(u8) = ")
    print_int(sizeof(u8))
    prints("\n")
    
    # Check struct layout by computing offsets
    var item: Item
    let base: i64 = @item as i64
    let name_addr: i64 = @item.name[0] as i64
    let name_len_addr: i64 = @item.name_len as i64
    let qty_addr: i64 = @item.quantity as i64
    
    prints("base addr = ")
    print_int(base)
    prints("\n")
    prints("name offset = ")
    print_int(name_addr - base)
    prints("\n")
    prints("name_len offset = ")
    print_int(name_len_addr - base)
    prints("\n")
    prints("quantity offset = ")
    print_int(qty_addr - base)
    prints("\n")
    
    return 0
