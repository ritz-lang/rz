# test/test_isolation.ritz - Tests to verify fork isolation works correctly
#
# These tests demonstrate that fork isolation properly:
# 1. Catches segmentation faults (SIGSEGV)
# 2. Catches assertion failures (non-zero exit)
# 3. Handles timeouts (infinite loops)
# 4. Continues running after crashes (doesn't crash the runner)
#
# Usage:
#   ./build/isolation_tests                  # All tests, fork isolation (default)
#   ./build/isolation_tests --no-fork        # Will crash on first segfault!
#   ./build/isolation_tests -t 100           # Shorter timeout for timeout test
#   ./build/isolation_tests -f crash         # Only run crash tests

import ritzlib.sys
import ritzlib.io

# ============================================================================
# Normal passing tests
# ============================================================================

[[test]]
fn test_normal_pass() -> i32
    return 0

[[test]]
fn test_simple_math() -> i32
    let x: i32 = 2 + 2
    if x != 4
        return 1
    return 0

# ============================================================================
# Assertion failure tests
# ============================================================================

[[test]]
fn test_assertion_failure() -> i32
    # This test intentionally fails to verify failure reporting
    return 42  # Non-zero = failure

# ============================================================================
# Crash tests - these will SIGSEGV
# ============================================================================
# WARNING: These tests cause segmentation faults.
# With fork isolation (default), these are caught safely.
# With --no-fork, these will crash the entire test runner!

[[test]]
fn test_null_pointer_crash() -> i32
    # Attempt to write to address 0 (null pointer dereference)
    let ptr: *i32 = 0 as *i32
    *ptr = 42  # BOOM - SIGSEGV
    return 0   # Never reached

[[test]]
fn test_invalid_address_crash() -> i32
    # Attempt to write to an invalid address
    let ptr: *i32 = 0xDEADBEEF as *i32
    *ptr = 42  # BOOM - SIGSEGV
    return 0   # Never reached

# ============================================================================
# Timeout tests - these will hang forever without timeout
# ============================================================================
# These tests verify the timeout mechanism.
# Default timeout is 5 seconds; use -t 100 for faster testing.

[[test]]
fn test_infinite_loop_timeout() -> i32
    # This test runs forever unless killed by timeout
    # Use -t 100 (100ms timeout) to test this quickly
    loop
        # Spin forever
        let x: i32 = 1

    return 0  # Never reached

# ============================================================================
# More normal tests to verify runner continues after crashes
# ============================================================================

[[test]]
fn test_after_crashes_still_works() -> i32
    # This should run even if previous tests crashed
    return 0

[[test]]
fn test_final_verification() -> i32
    # Prove the runner made it through all tests
    let answer: i32 = 6 * 7
    if answer != 42
        return 1
    return 0
