# ritzunit/src/types.ritz - Core types for the test framework
#
# Defines the data structures used by ritzunit for test discovery,
# execution, and reporting.

import ritzlib.gvec

# ============================================================================
# Test Status
# ============================================================================
# Represents the outcome of a single test execution.

const TEST_PASS: i32 = 0
const TEST_FAIL: i32 = 1
const TEST_SKIP: i32 = 2
const TEST_TIMEOUT: i32 = 3
const TEST_CRASH: i32 = 4

# ============================================================================
# Test Result
# ============================================================================
# Captures the result of running a single test.

struct TestResult
    name: Vec<u8>          # Test function name
    suite: Vec<u8>         # Suite/file name
    status: i32            # TEST_PASS, TEST_FAIL, etc.
    duration_ms: i64       # Execution time in milliseconds
    error_code: i32        # Return value from test (0 = pass)

# ============================================================================
# Test Summary
# ============================================================================
# Aggregated results for a test run.

struct TestSummary
    total: i32
    passed: i32
    failed: i32
    crashed: i32
    timeout: i32
    skipped: i32
    duration_ms: i64

# Initialize a fresh summary
pub fn summary_new() -> TestSummary
    var s: TestSummary
    s.total = 0
    s.passed = 0
    s.failed = 0
    s.crashed = 0
    s.timeout = 0
    s.skipped = 0
    s.duration_ms = 0
    return s

# Record a test result into the summary
pub fn summary_record(s:@TestSummary, status: i32, duration_ms: i64)
    s.total = s.total + 1
    s.duration_ms = s.duration_ms + duration_ms
    if status == TEST_PASS
        s.passed = s.passed + 1
    else if status == TEST_SKIP
        s.skipped = s.skipped + 1
    else if status == TEST_TIMEOUT
        s.timeout = s.timeout + 1
    else if status == TEST_CRASH
        s.crashed = s.crashed + 1
    else
        s.failed = s.failed + 1

# Merge one summary into another (for aggregating suite results)
pub fn summary_merge(dest:@TestSummary, src: *TestSummary)
    dest.total = dest.total + src.total
    dest.passed = dest.passed + src.passed
    dest.failed = dest.failed + src.failed
    dest.crashed = dest.crashed + src.crashed
    dest.timeout = dest.timeout + src.timeout
    dest.skipped = dest.skipped + src.skipped
    dest.duration_ms = dest.duration_ms + src.duration_ms
