# Entry point for the standalone `ritzunit` binary.
#
# This file is the package's `[[bin]]` entry (see ritz.toml's
# `entry = "bin_main::main"`).  It exists separately from runner.ritz
# so that per-package test binaries can link the runner WITHOUT picking
# up a conflicting `fn main` symbol — they provide their own.
import src.runner

fn main(argc: i32, argv: **u8) -> i32
    return ritzunit_main(argc, argv)
