# Sample file with intentional anti-patterns for testing ritz-lint

import ritzlib.sys
import ritzlib.io

# BAD: Raw pointer instead of borrow
fn process_request(req: *Request, resp: *mut Response) -> i32
    # BAD: C-string literal
    print(c"Processing request\n")

    # BAD: Symbol operators
    if req.valid && req.authenticated || !req.expired
        # BAD: null check instead of Option
        if req.user != null
            handle_user(req.user)
        else
            print(c"No user found\n")

    # BAD: Old attribute syntax
    @inline
    fn helper() -> i32
        42

    # BAD: Excessive mutability
    var result = compute()
    var status = 0
    var msg = "done"

    return status

# GOOD: This function is idiomatic
fn handle_connection(conn: Connection) -> Result<Response, Error>
    defer conn.close()

    let request = conn.read_request()?
    let response = process(request)

    match response.status
        Ok(data) => conn.send(data)
        Err(e) => conn.send_error(e)
