# ritz-stats: Source code analytics for Ritz
#
# Provides metrics similar to cloc/sloccount but tailored for Ritz:
# - Lines of code (total, source, comments, blank)
# - Function count, struct/enum count
# - Cyclomatic complexity metrics

import ritzlib.sys
import ritzlib.io

# Statistics accumulator
struct Stats
    file_count: i32
    total_lines: i32
    blank_lines: i32
    comment_lines: i32
    code_lines: i32
    function_count: i32
    struct_count: i32
    enum_count: i32
    max_complexity: i32
    total_complexity: i32
    total_fn_lines: i32
    max_nesting: i32

# Count leading spaces (4 spaces = 1 indent level)
fn count_indent(line: *u8, len: i32) -> i32
    var spaces: i32 = 0
    var i: i32 = 0
    while i < len
        if *(line + i) == ' '
            spaces = spaces + 1
            i = i + 1
        else
            break
    spaces / 4

# Check if line starts with prefix (after skipping whitespace)
fn starts_with_after_ws(line: *u8, len: i32, prefix: *u8, plen: i32) -> i32
    var i: i32 = 0
    # Skip whitespace
    while i < len
        let c = *(line + i)
        if c != ' '
            break
        i = i + 1

    # Check prefix
    var j: i32 = 0
    while j < plen
        if i + j >= len
            return 0
        if *(line + i + j) != *(prefix + j)
            return 0
        j = j + 1
    1

# Check if line contains substring
fn contains_str(line: *u8, len: i32, needle: *u8, nlen: i32) -> i32
    if len < nlen
        return 0
    var i: i32 = 0
    while i <= len - nlen
        var j: i32 = 0
        var ok: i32 = 1
        while j < nlen
            if *(line + i + j) != *(needle + j)
                ok = 0
                break
            j = j + 1
        if ok == 1
            return 1
        i = i + 1
    0

# Calculate complexity contribution from a line
fn line_complexity(line: *u8, len: i32) -> i32
    var cc: i32 = 0

    if starts_with_after_ws(line, len, c"if ", 3) == 1
        cc = cc + 1
    if starts_with_after_ws(line, len, c"else if ", 8) == 1
        cc = cc + 1
    if starts_with_after_ws(line, len, c"while ", 6) == 1
        cc = cc + 1
    if starts_with_after_ws(line, len, c"for ", 4) == 1
        cc = cc + 1
    if starts_with_after_ws(line, len, c"loop", 4) == 1
        cc = cc + 1
    if contains_str(line, len, c" => ", 4) == 1
        cc = cc + 1
    if contains_str(line, len, c" and ", 5) == 1
        cc = cc + 1
    if contains_str(line, len, c" or ", 4) == 1
        cc = cc + 1

    cc

# Analyze a file
fn analyze_file(path: *u8, stats: *Stats) -> i32
    let fd = sys_open(path, 0)
    if fd < 0
        return -1

    # Read file into buffer (max 1MB)
    var buf: [1048576]u8
    let n = sys_read(fd, @buf as *u8, 1048576)
    sys_close(fd)

    if n <= 0
        return -1

    var line_start: i32 = 0
    var i: i32 = 0

    var in_fn: i32 = 0
    var fn_indent: i32 = 0
    var fn_lines: i32 = 0
    var fn_cc: i32 = 1
    var fn_max_indent: i32 = 0

    while i < n as i32
        if buf[i] == '\n' or i == n as i32 - 1
            let line_len = i - line_start
            let line = @buf as *u8 + line_start

            let indent = count_indent(line, line_len)

            # Skip leading whitespace to check content
            var ws: i32 = 0
            while ws < line_len
                if *(line + ws) != ' '
                    break
                ws = ws + 1

            let trimmed_len = line_len - ws

            if trimmed_len == 0
                stats.blank_lines = stats.blank_lines + 1
            else if *(line + ws) == '#'
                stats.comment_lines = stats.comment_lines + 1
            else
                stats.code_lines = stats.code_lines + 1

                # Check for function start (fn or pub fn)
                var is_fn: i32 = 0
                if starts_with_after_ws(line, line_len, c"fn ", 3) == 1
                    is_fn = 1
                if starts_with_after_ws(line, line_len, c"pub fn ", 7) == 1
                    is_fn = 1

                if is_fn == 1
                    # Close previous function
                    if in_fn == 1
                        stats.function_count = stats.function_count + 1
                        stats.total_fn_lines = stats.total_fn_lines + fn_lines
                        stats.total_complexity = stats.total_complexity + fn_cc
                        if fn_cc > stats.max_complexity
                            stats.max_complexity = fn_cc
                        if fn_max_indent > stats.max_nesting
                            stats.max_nesting = fn_max_indent

                    in_fn = 1
                    fn_indent = indent
                    fn_lines = 0
                    fn_cc = 1
                    fn_max_indent = 0

                else if in_fn == 1
                    if indent > fn_indent
                        fn_lines = fn_lines + 1
                        fn_cc = fn_cc + line_complexity(line, line_len)
                        if indent > fn_max_indent
                            fn_max_indent = indent
                    else
                        # Dedented - end of function
                        stats.function_count = stats.function_count + 1
                        stats.total_fn_lines = stats.total_fn_lines + fn_lines
                        stats.total_complexity = stats.total_complexity + fn_cc
                        if fn_cc > stats.max_complexity
                            stats.max_complexity = fn_cc
                        if fn_max_indent > stats.max_nesting
                            stats.max_nesting = fn_max_indent
                        in_fn = 0

                # Check for struct/enum
                if starts_with_after_ws(line, line_len, c"struct ", 7) == 1
                    stats.struct_count = stats.struct_count + 1
                else if starts_with_after_ws(line, line_len, c"enum ", 5) == 1
                    stats.enum_count = stats.enum_count + 1

            stats.total_lines = stats.total_lines + 1
            line_start = i + 1

        i = i + 1

    # Close final function
    if in_fn == 1
        stats.function_count = stats.function_count + 1
        stats.total_fn_lines = stats.total_fn_lines + fn_lines
        stats.total_complexity = stats.total_complexity + fn_cc
        if fn_cc > stats.max_complexity
            stats.max_complexity = fn_cc
        if fn_max_indent > stats.max_nesting
            stats.max_nesting = fn_max_indent

    stats.file_count = stats.file_count + 1
    0

fn print_bar(n: i32)
    var i: i32 = 0
    while i < n
        prints("-")
        i = i + 1
    prints("\n")

fn print_num(n: i32)
    if n < 0
        prints("-")
        print_num(0 - n)
        return
    if n >= 10
        print_num(n / 10)
    let digit = (n % 10) + 48
    var buf: [1]u8
    buf[0] = digit as u8
    sys_write(1, @buf as *u8, 1)

fn print_summary(stats: *Stats)
    prints("============================================================\n")
    prints("                    RITZ SOURCE STATISTICS\n")
    prints("============================================================\n\n")

    prints("LINES OF CODE\n")
    print_bar(40)

    prints("  Total lines:      ")
    print_num(stats.total_lines)
    prints("\n")

    prints("  Code lines:       ")
    print_num(stats.code_lines)
    prints(" (")
    if stats.total_lines > 0
        print_num((stats.code_lines * 100) / stats.total_lines)
    else
        prints("0")
    prints("%)\n")

    prints("  Comment lines:    ")
    print_num(stats.comment_lines)
    prints(" (")
    if stats.total_lines > 0
        print_num((stats.comment_lines * 100) / stats.total_lines)
    else
        prints("0")
    prints("%)\n")

    prints("  Blank lines:      ")
    print_num(stats.blank_lines)
    prints(" (")
    if stats.total_lines > 0
        print_num((stats.blank_lines * 100) / stats.total_lines)
    else
        prints("0")
    prints("%)\n")

    prints("\nDEFINITIONS\n")
    print_bar(40)

    prints("  Functions:        ")
    print_num(stats.function_count)
    prints("\n")

    prints("  Structs:          ")
    print_num(stats.struct_count)
    prints("\n")

    prints("  Enums:            ")
    print_num(stats.enum_count)
    prints("\n")

    prints("  Files:            ")
    print_num(stats.file_count)
    prints("\n")

    prints("\nCOMPLEXITY\n")
    print_bar(40)

    prints("  Avg fn length:    ")
    if stats.function_count > 0
        print_num(stats.total_fn_lines / stats.function_count)
    else
        prints("0")
    prints(" lines\n")

    prints("  Avg complexity:   ")
    if stats.function_count > 0
        print_num(stats.total_complexity / stats.function_count)
    else
        prints("0")
    prints("\n")

    prints("  Max complexity:   ")
    print_num(stats.max_complexity)
    prints("\n")

    prints("  Max nesting:      ")
    print_num(stats.max_nesting)
    prints(" levels\n\n")

fn main(argc: i32, argv: **u8) -> i32
    if argc < 2
        prints("Usage: ritz-stats <file.ritz>\n")
        return 1

    var stats: Stats
    stats.file_count = 0
    stats.total_lines = 0
    stats.blank_lines = 0
    stats.comment_lines = 0
    stats.code_lines = 0
    stats.function_count = 0
    stats.struct_count = 0
    stats.enum_count = 0
    stats.max_complexity = 0
    stats.total_complexity = 0
    stats.total_fn_lines = 0
    stats.max_nesting = 0

    let path = *(argv + 1)
    let result = analyze_file(path, @stats)

    if result < 0
        prints("Error reading file\n")
        return 1

    print_summary(@stats)
    0
