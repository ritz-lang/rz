# test/test_arena.ritz - Tests for shared data arena
#
# TDD: These tests define the expected behavior of the data arena
# used to store request/response bodies and headers.
#
# Arena properties:
#   - Bump allocator (fast, no per-allocation overhead)
#   - Shared between Valet and Worker via mmap
#   - Reset on request completion (no fragmentation)
#   - Aligned allocations for performance

import ritzlib.sys
import ritzlib.io
import helpers

# Import our library
import zeus.arena

# ============================================================================
# DataArena Structure Tests
# ============================================================================

[[test]]
fn test_arena_create() -> i32
    # Create a small test arena (64KB)
    var arena: DataArena
    let result: i32 = data_arena_init(@arena, 65536)
    if result != 0
        "FAIL: data_arena_init failed\n"
        return 1

    let result2: i32 = assert_eq_i64(arena.size, 65536)
    if result2 != 0
        data_arena_destroy(@arena)
        return result2

    let result3: i32 = assert_eq_i64(arena.offset, 0)
    if result3 != 0
        data_arena_destroy(@arena)
        return result3

    let result4: i32 = assert_not_null(arena.base)
    if result4 != 0
        data_arena_destroy(@arena)
        return result4

    data_arena_destroy(@arena)
    return 0

[[test]]
fn test_arena_alloc_basic() -> i32
    var arena: DataArena
    data_arena_init(@arena, 65536)

    # Allocate 100 bytes
    let ptr: *u8 = data_arena_alloc(@arena, 100)
    let result: i32 = assert_not_null(ptr)
    if result != 0
        data_arena_destroy(@arena)
        return result

    # Offset should have advanced (aligned to 8)
    let result2: i32 = assert_eq_i64(arena.offset, 104)  # 100 aligned to 8 = 104
    if result2 != 0
        data_arena_destroy(@arena)
        return result2

    data_arena_destroy(@arena)
    return 0

[[test]]
fn test_arena_alloc_alignment() -> i32
    var arena: DataArena
    data_arena_init(@arena, 65536)

    # Allocate 1 byte - should still advance by 8 (alignment)
    let ptr1: *u8 = data_arena_alloc(@arena, 1)
    let result: i32 = assert_eq_i64(arena.offset, 8)
    if result != 0
        data_arena_destroy(@arena)
        return result

    # Allocate 7 bytes - should advance by 8
    let ptr2: *u8 = data_arena_alloc(@arena, 7)
    let result2: i32 = assert_eq_i64(arena.offset, 16)
    if result2 != 0
        data_arena_destroy(@arena)
        return result2

    # Allocate 9 bytes - should advance by 16
    let ptr3: *u8 = data_arena_alloc(@arena, 9)
    let result3: i32 = assert_eq_i64(arena.offset, 32)
    if result3 != 0
        data_arena_destroy(@arena)
        return result3

    data_arena_destroy(@arena)
    return 0

[[test]]
fn test_arena_alloc_sequential() -> i32
    var arena: DataArena
    data_arena_init(@arena, 65536)

    # Multiple allocations should be sequential
    let ptr1: *u8 = data_arena_alloc(@arena, 64)
    let ptr2: *u8 = data_arena_alloc(@arena, 64)
    let ptr3: *u8 = data_arena_alloc(@arena, 64)

    # ptr2 should be ptr1 + 64
    let diff1: i64 = (ptr2 as i64) - (ptr1 as i64)
    let result: i32 = assert_eq_i64(diff1, 64)
    if result != 0
        data_arena_destroy(@arena)
        return result

    # ptr3 should be ptr2 + 64
    let diff2: i64 = (ptr3 as i64) - (ptr2 as i64)
    let result2: i32 = assert_eq_i64(diff2, 64)
    if result2 != 0
        data_arena_destroy(@arena)
        return result2

    data_arena_destroy(@arena)
    return 0

[[test]]
fn test_arena_alloc_exhaustion() -> i32
    var arena: DataArena
    data_arena_init(@arena, 1024)  # Small arena

    # Allocate most of the space
    let ptr1: *u8 = data_arena_alloc(@arena, 900)
    let result: i32 = assert_not_null(ptr1)
    if result != 0
        data_arena_destroy(@arena)
        return result

    # Try to allocate more than remaining
    let ptr2: *u8 = data_arena_alloc(@arena, 200)  # Only ~124 bytes left
    let result2: i32 = assert_null(ptr2)
    if result2 != 0
        data_arena_destroy(@arena)
        return result2

    data_arena_destroy(@arena)
    return 0

[[test]]
fn test_arena_reset() -> i32
    var arena: DataArena
    data_arena_init(@arena, 65536)

    # Allocate some memory
    data_arena_alloc(@arena, 1000)
    data_arena_alloc(@arena, 2000)
    data_arena_alloc(@arena, 3000)

    # Offset should be non-zero
    if arena.offset == 0
        "FAIL: offset should be non-zero after allocations\n"
        data_arena_destroy(@arena)
        return 1

    # Reset
    data_arena_reset(@arena)

    # Offset should be back to 0
    let result: i32 = assert_eq_i64(arena.offset, 0)
    if result != 0
        data_arena_destroy(@arena)
        return result

    # Should be able to allocate again
    let ptr: *u8 = data_arena_alloc(@arena, 100)
    let result2: i32 = assert_not_null(ptr)
    if result2 != 0
        data_arena_destroy(@arena)
        return result2

    data_arena_destroy(@arena)
    return 0

[[test]]
fn test_arena_remaining() -> i32
    var arena: DataArena
    data_arena_init(@arena, 1024)

    # Initially all space is available
    let remaining: i64 = data_arena_remaining(@arena)
    let result: i32 = assert_eq_i64(remaining, 1024)
    if result != 0
        data_arena_destroy(@arena)
        return result

    # After allocation, space decreases
    data_arena_alloc(@arena, 100)
    let remaining2: i64 = data_arena_remaining(@arena)
    let result2: i32 = assert_eq_i64(remaining2, 920)  # 1024 - 104 (aligned)
    if result2 != 0
        data_arena_destroy(@arena)
        return result2

    data_arena_destroy(@arena)
    return 0

[[test]]
fn test_arena_offset_calculation() -> i32
    var arena: DataArena
    data_arena_init(@arena, 65536)

    # Get offset of first allocation
    let ptr1: *u8 = data_arena_alloc(@arena, 100)
    let offset1: i64 = data_arena_ptr_to_offset(@arena, ptr1)
    let result: i32 = assert_eq_i64(offset1, 0)  # First alloc at offset 0
    if result != 0
        data_arena_destroy(@arena)
        return result

    # Get offset of second allocation
    let ptr2: *u8 = data_arena_alloc(@arena, 100)
    let offset2: i64 = data_arena_ptr_to_offset(@arena, ptr2)
    let result2: i32 = assert_eq_i64(offset2, 104)  # After first alloc
    if result2 != 0
        data_arena_destroy(@arena)
        return result2

    data_arena_destroy(@arena)
    return 0

[[test]]
fn test_arena_offset_to_ptr() -> i32
    var arena: DataArena
    data_arena_init(@arena, 65536)

    # Allocate and get offset
    let ptr1: *u8 = data_arena_alloc(@arena, 100)
    let offset: i64 = data_arena_ptr_to_offset(@arena, ptr1)

    # Convert back to pointer
    let ptr2: *u8 = data_arena_offset_to_ptr(@arena, offset)

    # Should be same pointer
    if ptr1 != ptr2
        "FAIL: ptr round-trip failed\n"
        data_arena_destroy(@arena)
        return 1

    data_arena_destroy(@arena)
    return 0

[[test]]
fn test_arena_write_and_read() -> i32
    var arena: DataArena
    data_arena_init(@arena, 65536)

    # Allocate and write some data
    let ptr: *u8 = data_arena_alloc(@arena, 4)
    *ptr = 0x41        # 'A'
    *(ptr + 1) = 0x42  # 'B'
    *(ptr + 2) = 0x43  # 'C'
    *(ptr + 3) = 0x00  # null

    # Read back
    if *ptr != 0x41
        "FAIL: byte 0 mismatch\n"
        data_arena_destroy(@arena)
        return 1

    if *(ptr + 1) != 0x42
        "FAIL: byte 1 mismatch\n"
        data_arena_destroy(@arena)
        return 1

    if *(ptr + 2) != 0x43
        "FAIL: byte 2 mismatch\n"
        data_arena_destroy(@arena)
        return 1

    data_arena_destroy(@arena)
    return 0
