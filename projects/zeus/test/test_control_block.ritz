# test/test_control_block.ritz - Tests for shared memory control block
#
# TDD: These tests define the expected behavior of the control block
# that coordinates access between Valet and Zeus workers.
#
# Control block layout:
#   - Request ring indices (write/read)
#   - Response ring indices (write/read)
#   - Worker state flags
#   - Worker PID

import ritzlib.sys
import ritzlib.io
import helpers

# Import our library
import lib.control

# ============================================================================
# Control Block Structure Tests
# ============================================================================

[[test]]
fn test_control_block_size() -> i32
    # Control block should fit in one page (4KB) with room to spare
    # Expected: 64 bytes for indices + flags + padding
    let size: i64 = control_block_size()
    if size > 4096
        "FAIL: control block too large: {size}\n"
        return 1
    if size < 64
        "FAIL: control block too small: {size}\n"
        return 1
    return 0

[[test]]
fn test_control_block_init() -> i32
    # Create a control block in local memory for testing
    var cb: ControlBlock
    control_block_init(@cb)

    # All indices should start at 0
    let result: i32 = assert_eq_i64(cb.req_write_idx, 0)
    if result != 0
        return result

    let result2: i32 = assert_eq_i64(cb.req_read_idx, 0)
    if result2 != 0
        return result2

    let result3: i32 = assert_eq_i64(cb.resp_write_idx, 0)
    if result3 != 0
        return result3

    let result4: i32 = assert_eq_i64(cb.resp_read_idx, 0)
    if result4 != 0
        return result4

    # Worker should be in IDLE state
    let result5: i32 = assert_eq_i32(cb.state, WORKER_STATE_IDLE)
    if result5 != 0
        return result5

    # PID should be 0 (not assigned)
    let result6: i32 = assert_eq_i32(cb.worker_pid, 0)
    if result6 != 0
        return result6

    return 0

[[test]]
fn test_control_block_state_transitions() -> i32
    var cb: ControlBlock
    control_block_init(@cb)

    # IDLE -> RUNNING
    control_block_set_state(@cb, WORKER_STATE_RUNNING)
    let result: i32 = assert_eq_i32(cb.state, WORKER_STATE_RUNNING)
    if result != 0
        return result

    # RUNNING -> BUSY
    control_block_set_state(@cb, WORKER_STATE_BUSY)
    let result2: i32 = assert_eq_i32(cb.state, WORKER_STATE_BUSY)
    if result2 != 0
        return result2

    # BUSY -> RUNNING
    control_block_set_state(@cb, WORKER_STATE_RUNNING)
    let result3: i32 = assert_eq_i32(cb.state, WORKER_STATE_RUNNING)
    if result3 != 0
        return result3

    return 0

[[test]]
fn test_control_block_pid_assignment() -> i32
    var cb: ControlBlock
    control_block_init(@cb)

    # Set worker PID
    control_block_set_pid(@cb, 12345)
    let result: i32 = assert_eq_i32(cb.worker_pid, 12345)
    if result != 0
        return result

    # Clear PID on worker death
    control_block_set_pid(@cb, 0)
    let result2: i32 = assert_eq_i32(cb.worker_pid, 0)
    if result2 != 0
        return result2

    return 0

# ============================================================================
# Index Operations Tests
# ============================================================================

[[test]]
fn test_request_index_increment() -> i32
    var cb: ControlBlock
    control_block_init(@cb)

    # Increment write index (producer side - Valet)
    let old: i64 = control_block_req_write_inc(@cb)
    let result: i32 = assert_eq_i64(old, 0)
    if result != 0
        return result

    let result2: i32 = assert_eq_i64(cb.req_write_idx, 1)
    if result2 != 0
        return result2

    return 0

[[test]]
fn test_response_index_increment() -> i32
    var cb: ControlBlock
    control_block_init(@cb)

    # Increment write index (producer side - Worker)
    let old: i64 = control_block_resp_write_inc(@cb)
    let result: i32 = assert_eq_i64(old, 0)
    if result != 0
        return result

    let result2: i32 = assert_eq_i64(cb.resp_write_idx, 1)
    if result2 != 0
        return result2

    return 0

[[test]]
fn test_ring_empty_detection() -> i32
    var cb: ControlBlock
    control_block_init(@cb)

    # Initially both rings are empty
    let req_empty: i32 = control_block_req_empty(@cb)
    let result: i32 = assert_true(req_empty)
    if result != 0
        return result

    let resp_empty: i32 = control_block_resp_empty(@cb)
    let result2: i32 = assert_true(resp_empty)
    if result2 != 0
        return result2

    # After write, ring is not empty
    control_block_req_write_inc(@cb)
    let req_empty2: i32 = control_block_req_empty(@cb)
    if req_empty2 != 0
        "FAIL: request ring should not be empty after write\n"
        return 1

    return 0

[[test]]
fn test_ring_count() -> i32
    var cb: ControlBlock
    control_block_init(@cb)

    # Initially count is 0
    let count: i64 = control_block_req_count(@cb)
    let result: i32 = assert_eq_i64(count, 0)
    if result != 0
        return result

    # After 3 writes, count is 3
    control_block_req_write_inc(@cb)
    control_block_req_write_inc(@cb)
    control_block_req_write_inc(@cb)

    let count2: i64 = control_block_req_count(@cb)
    let result2: i32 = assert_eq_i64(count2, 3)
    if result2 != 0
        return result2

    # After 1 read, count is 2
    control_block_req_read_inc(@cb)
    let count3: i64 = control_block_req_count(@cb)
    let result3: i32 = assert_eq_i64(count3, 2)
    if result3 != 0
        return result3

    return 0
