# test/test_zeus_client.ritz - Tests for Zeus client adapter
#
# TDD: These tests define the expected behavior of the Zeus client
# that connects to the Zeus daemon to receive worker shm fds.
#
# Protocol:
#   1. Client connects to Zeus daemon via Unix socket
#   2. Daemon sends worker info + shm fd via SCM_RIGHTS
#   3. Client attaches to shm and uses ring buffers for IPC
#   4. Socket serves as wakeup mechanism when rings are empty

import ritzlib.sys
import ritzlib.io
import helpers

# Import our library
import lib.zeus_client
import lib.shm
import lib.control
import lib.ring
import lib.arena

# ============================================================================
# Client Configuration Tests
# ============================================================================

[[test]]
fn test_zeus_client_config_defaults() -> i32
    var cfg: ZeusClientConfig
    zeus_client_config_default(@cfg)

    # Check reasonable defaults
    let result: i32 = assert_eq_i32(cfg.max_workers, 16)
    if result != 0
        return result

    let result2: i32 = assert_eq_i32(cfg.connect_timeout_ms, 5000)
    if result2 != 0
        return result2

    return 0

[[test]]
fn test_zeus_client_config_custom() -> i32
    var cfg: ZeusClientConfig
    zeus_client_config_init(@cfg, 8, 10000)

    let result: i32 = assert_eq_i32(cfg.max_workers, 8)
    if result != 0
        return result

    let result2: i32 = assert_eq_i32(cfg.connect_timeout_ms, 10000)
    if result2 != 0
        return result2

    return 0

# ============================================================================
# Client Context Tests
# ============================================================================

[[test]]
fn test_zeus_client_init_destroy() -> i32
    var cfg: ZeusClientConfig
    zeus_client_config_default(@cfg)

    var client: ZeusClient
    let result: i32 = zeus_client_init(@client, @cfg)
    if result != 0
        "FAIL: zeus_client_init failed with code {result}\n"
        return 1

    # Check initial state
    let result2: i32 = assert_eq_i32(client.state, ZEUS_CLIENT_STATE_INIT)
    if result2 != 0
        zeus_client_destroy(@client)
        return result2

    let result3: i32 = assert_eq_i32(client.socket_fd, -1)
    if result3 != 0
        zeus_client_destroy(@client)
        return result3

    let result4: i32 = assert_eq_i32(client.worker_count, 0)
    if result4 != 0
        zeus_client_destroy(@client)
        return result4

    zeus_client_destroy(@client)
    return 0

# ============================================================================
# Worker Handle Tests
# ============================================================================

[[test]]
fn test_worker_handle_init() -> i32
    var handle: WorkerHandle
    worker_handle_init(@handle)

    let result: i32 = assert_eq_i32(handle.slot_idx, -1)
    if result != 0
        return result

    let result2: i32 = assert_eq_i32(handle.shm_fd, -1)
    if result2 != 0
        return result2

    let result3: i32 = assert_null(handle.shm_base as *u8)
    if result3 != 0
        return result3

    return 0

