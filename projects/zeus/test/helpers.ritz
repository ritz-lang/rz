# test/helpers.ritz - Shared test helper functions
#
# Common assertion functions used across all test files.

import ritzlib.sys
import ritzlib.io

# ============================================================================
# Assertion Helpers
# ============================================================================

pub fn assert_eq_i32(actual: i32, expected: i32) -> i32
    if actual == expected
        return 0
    "FAIL: expected {expected}, got {actual}\n"
    return 1

pub fn assert_eq_i64(actual: i64, expected: i64) -> i32
    if actual == expected
        return 0
    "FAIL: expected {expected}, got {actual}\n"
    return 1

pub fn assert_eq_u64(actual: u64, expected: u64) -> i32
    if actual == expected
        return 0
    "FAIL: expected {expected}, got {actual}\n"
    return 1

pub fn assert_eq_u32(actual: u32, expected: u32) -> i32
    if actual == expected
        return 0
    "FAIL: expected {expected}, got {actual}\n"
    return 1

pub fn assert_eq_u8(actual: u8, expected: u8) -> i32
    if actual == expected
        return 0
    "FAIL: expected {expected}, got {actual}\n"
    return 1

pub fn assert_true(val: i32) -> i32
    if val != 0
        return 0
    "FAIL: expected true\n"
    return 1

pub fn assert_false(val: i32) -> i32
    if val == 0
        return 0
    "FAIL: expected false\n"
    return 1

pub fn assert_not_null(ptr: *u8) -> i32
    if ptr != null
        return 0
    "FAIL: expected non-null\n"
    return 1

pub fn assert_null(ptr: *u8) -> i32
    if ptr == null
        return 0
    "FAIL: expected null\n"
    return 1

pub fn assert_ge_i32(actual: i32, minimum: i32) -> i32
    if actual >= minimum
        return 0
    "FAIL: expected >= {minimum}, got {actual}\n"
    return 1

pub fn assert_gt_i32(actual: i32, minimum: i32) -> i32
    if actual > minimum
        return 0
    "FAIL: expected > {minimum}, got {actual}\n"
    return 1

pub fn assert_le_i32(actual: i32, maximum: i32) -> i32
    if actual <= maximum
        return 0
    "FAIL: expected <= {maximum}, got {actual}\n"
    return 1

pub fn assert_lt_i32(actual: i32, maximum: i32) -> i32
    if actual < maximum
        return 0
    "FAIL: expected < {maximum}, got {actual}\n"
    return 1

pub fn assert_ge(actual: i64, minimum: i64) -> i32
    if actual >= minimum
        return 0
    "FAIL: expected >= {minimum}, got {actual}\n"
    return 1

pub fn assert_ne_i64(actual: i64, unexpected: i64) -> i32
    if actual != unexpected
        return 0
    "FAIL: expected != {unexpected}, got {actual}\n"
    return 1
