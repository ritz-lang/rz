# lib/commands.ritz - Command dispatcher for Tome
#
# Maps RESP commands to Store operations. Each command handler
# takes a parsed RespCommand and writes the response to a buffer.
#
# Supported commands:
#   String: GET, SET, SETEX, DEL, EXISTS, TTL, EXPIRE, PERSIST
#   List:   LPUSH, RPUSH, LPOP, RPOP, LLEN, LINDEX, LRANGE
#   Set:    SADD, SREM, SISMEMBER, SCARD, SMEMBERS
#   Hash:   HSET, HGET, HDEL, HEXISTS, HLEN, HKEYS, HVALS, HGETALL
#   ZSet:   ZADD, ZREM, ZSCORE, ZRANK, ZREVRANK, ZCARD, ZRANGE, ZREVRANGE
#   Server: PING, ECHO, COMMAND, INFO, DBSIZE, FLUSHDB

import ritzlib.memory
import ritzlib.str
import ritzlib.string
import ritzlib.strview
import lib.tome
import lib.resp


# ============================================================================
# Command result codes
# ============================================================================

const CMD_OK: i32 = 0           # Command executed successfully
const CMD_ERR_ARGC: i32 = -1    # Wrong number of arguments
const CMD_ERR_TYPE: i32 = -2    # Wrong type for operation
const CMD_ERR_SYNTAX: i32 = -3  # Syntax error
const CMD_ERR_UNKNOWN: i32 = -4 # Unknown command


# ============================================================================
# Command Context
# ============================================================================
# Holds the store and response buffer for command execution.

struct CommandContext
    store: *Store
    resp_buf: *u8       # Response output buffer
    resp_len: i32       # Length of response written
    resp_cap: i32       # Capacity of buffer
    password: *u8       # Required password (null = no auth required)
    is_authenticated: i32   # 1 if client is authenticated, 0 otherwise


# Initialize command context (no auth - backwards compatible)
pub fn cmd_ctx_init(ctx: *CommandContext, store: *Store, buf: *u8, cap: i32)
    ctx.store = store
    ctx.resp_buf = buf
    ctx.resp_len = 0
    ctx.resp_cap = cap
    ctx.password = null
    ctx.is_authenticated = 1  # No auth required = already authenticated


# Initialize command context with authentication
pub fn cmd_ctx_init_auth(ctx: *CommandContext, store: *Store, buf: *u8, cap: i32, password: *u8, is_authenticated: i32)
    ctx.store = store
    ctx.resp_buf = buf
    ctx.resp_len = 0
    ctx.resp_cap = cap
    ctx.password = password
    ctx.is_authenticated = is_authenticated


# Write response helpers (C-string versions - for FFI compatibility)
fn ctx_write_simple(ctx: *CommandContext, s: *u8)
    ctx.resp_len = resp_write_simple(ctx.resp_buf, s)

fn ctx_write_error(ctx: *CommandContext, s: *u8)
    ctx.resp_len = resp_write_error(ctx.resp_buf, s)

# Write response helpers (StrView versions - preferred)
fn ctx_write_simple_sv(ctx: *CommandContext, s: *StrView)
    ctx.resp_len = resp_write_simple_sv(ctx.resp_buf, s)

fn ctx_write_error_sv(ctx: *CommandContext, s: *StrView)
    ctx.resp_len = resp_write_error_sv(ctx.resp_buf, s)

fn ctx_write_int(ctx: *CommandContext, n: i64)
    ctx.resp_len = resp_write_int(ctx.resp_buf, n)

fn ctx_write_bulk(ctx: *CommandContext, data: *u8, len: i64)
    ctx.resp_len = resp_write_bulk(ctx.resp_buf, data, len)

fn ctx_write_null(ctx: *CommandContext)
    ctx.resp_len = resp_write_null(ctx.resp_buf)


# ============================================================================
# Individual Command Handlers
# ============================================================================

# PING [message]
fn cmd_ping(ctx: *CommandContext, cmd: *RespCommand) -> i32
    if cmd.argc == 1
        let pong: StrView = "PONG"
        ctx_write_simple_sv(ctx, @pong)
        return CMD_OK
    if cmd.argc == 2
        let arg: *RespArg = @cmd.args[1]
        ctx_write_bulk(ctx, arg.data, arg.len)
        return CMD_OK
    let err: StrView = "ERR wrong number of arguments for 'ping' command"
    ctx_write_error_sv(ctx, @err)
    return CMD_ERR_ARGC


# ECHO message
fn cmd_echo(ctx: *CommandContext, cmd: *RespCommand) -> i32
    if cmd.argc != 2
        let err: StrView = "ERR wrong number of arguments for 'echo' command"
        ctx_write_error_sv(ctx, @err)
        return CMD_ERR_ARGC
    let arg: *RespArg = @cmd.args[1]
    ctx_write_bulk(ctx, arg.data, arg.len)
    return CMD_OK


# GET key
fn cmd_get(ctx: *CommandContext, cmd: *RespCommand) -> i32
    if cmd.argc != 2
        let err: StrView = "ERR wrong number of arguments for 'get' command"
        ctx_write_error_sv(ctx, @err)
        return CMD_ERR_ARGC

    var key: [256]u8
    resp_arg_copy(@cmd.args[1], @key[0], 256)
    var key_sv: StrView = strview_from_cstr(@key[0])

    let val: *u8 = store_get(ctx.store, @key_sv)
    if val == null
        ctx_write_null(ctx)
    else
        let vlen: i64 = strlen(val)
        ctx_write_bulk(ctx, val, vlen)
    return CMD_OK


# SET key value
fn cmd_set(ctx: *CommandContext, cmd: *RespCommand) -> i32
    if cmd.argc < 3
        let err: StrView = "ERR wrong number of arguments for 'set' command"
        ctx_write_error_sv(ctx, @err)
        return CMD_ERR_ARGC

    var key: [256]u8
    var val: [8192]u8
    resp_arg_copy(@cmd.args[1], @key[0], 256)
    resp_arg_copy(@cmd.args[2], @val[0], 8192)
    var key_sv: StrView = strview_from_cstr(@key[0])
    var val_sv: StrView = strview_from_cstr(@val[0])

    store_set(ctx.store, @key_sv, @val_sv)
    let ok: StrView = "OK"
    ctx_write_simple_sv(ctx, @ok)
    return CMD_OK


# SETEX key seconds value
fn cmd_setex(ctx: *CommandContext, cmd: *RespCommand) -> i32
    if cmd.argc != 4
        let err: StrView = "ERR wrong number of arguments for 'setex' command"
        ctx_write_error_sv(ctx, @err)
        return CMD_ERR_ARGC

    var key: [256]u8
    var val: [8192]u8
    resp_arg_copy(@cmd.args[1], @key[0], 256)
    resp_arg_copy(@cmd.args[3], @val[0], 8192)
    var key_sv: StrView = strview_from_cstr(@key[0])
    var val_sv: StrView = strview_from_cstr(@val[0])

    var ok: i32 = 0
    let ttl: i64 = resp_arg_to_int(@cmd.args[2], @ok)
    if ok == 0 || ttl <= 0
        let err: StrView = "ERR invalid expire time in 'setex' command"
        ctx_write_error_sv(ctx, @err)
        return CMD_ERR_SYNTAX

    store_setex(ctx.store, @key_sv, @val_sv, ttl)
    let ok: StrView = "OK"
    ctx_write_simple_sv(ctx, @ok)
    return CMD_OK


# DEL key [key ...]
fn cmd_del(ctx: *CommandContext, cmd: *RespCommand) -> i32
    if cmd.argc < 2
        let err: StrView = "ERR wrong number of arguments for 'del' command"
        ctx_write_error_sv(ctx, @err)
        return CMD_ERR_ARGC

    var count: i64 = 0
    for i in 1..cmd.argc
        var key: [256]u8
        resp_arg_copy(@cmd.args[i], @key[0], 256)
        var key_sv: StrView = strview_from_cstr(@key[0])
        let deleted: i32 = store_del(ctx.store, @key_sv)
        if deleted == 1
            count += 1

    ctx_write_int(ctx, count)
    return CMD_OK


# EXISTS key [key ...]
fn cmd_exists(ctx: *CommandContext, cmd: *RespCommand) -> i32
    if cmd.argc < 2
        let err: StrView = "ERR wrong number of arguments for 'exists' command"
        ctx_write_error_sv(ctx, @err)
        return CMD_ERR_ARGC

    var count: i64 = 0
    for i in 1..cmd.argc
        var key: [256]u8
        resp_arg_copy(@cmd.args[i], @key[0], 256)
        var key_sv: StrView = strview_from_cstr(@key[0])
        if store_exists(ctx.store, @key_sv) == 1
            count += 1

    ctx_write_int(ctx, count)
    return CMD_OK


# TTL key
fn cmd_ttl(ctx: *CommandContext, cmd: *RespCommand) -> i32
    if cmd.argc != 2
        let err: StrView = "ERR wrong number of arguments for 'ttl' command"
        ctx_write_error_sv(ctx, @err)
        return CMD_ERR_ARGC

    var key: [256]u8
    resp_arg_copy(@cmd.args[1], @key[0], 256)
    var key_sv: StrView = strview_from_cstr(@key[0])

    let ttl: i64 = store_ttl(ctx.store, @key_sv)
    ctx_write_int(ctx, ttl)
    return CMD_OK


# EXPIRE key seconds
fn cmd_expire(ctx: *CommandContext, cmd: *RespCommand) -> i32
    if cmd.argc != 3
        let err: StrView = "ERR wrong number of arguments for 'expire' command"
        ctx_write_error_sv(ctx, @err)
        return CMD_ERR_ARGC

    var key: [256]u8
    resp_arg_copy(@cmd.args[1], @key[0], 256)
    var key_sv: StrView = strview_from_cstr(@key[0])

    var ok: i32 = 0
    let ttl: i64 = resp_arg_to_int(@cmd.args[2], @ok)
    if ok == 0 || ttl <= 0
        let err: StrView = "ERR invalid expire time in 'expire' command"
        ctx_write_error_sv(ctx, @err)
        return CMD_ERR_SYNTAX

    let result: i32 = store_expire(ctx.store, @key_sv, ttl)
    ctx_write_int(ctx, result as i64)
    return CMD_OK


# PERSIST key
fn cmd_persist(ctx: *CommandContext, cmd: *RespCommand) -> i32
    if cmd.argc != 2
        let err: StrView = "ERR wrong number of arguments for 'persist' command"
        ctx_write_error_sv(ctx, @err)
        return CMD_ERR_ARGC

    var key: [256]u8
    resp_arg_copy(@cmd.args[1], @key[0], 256)
    var key_sv: StrView = strview_from_cstr(@key[0])

    let result: i32 = store_persist(ctx.store, @key_sv)
    ctx_write_int(ctx, result as i64)
    return CMD_OK


# ============================================================================
# List Commands
# ============================================================================

# LPUSH key value [value ...]
fn cmd_lpush(ctx: *CommandContext, cmd: *RespCommand) -> i32
    if cmd.argc < 3
        let err: StrView = "ERR wrong number of arguments for 'lpush' command"
        ctx_write_error_sv(ctx, @err)
        return CMD_ERR_ARGC

    var key: [256]u8
    resp_arg_copy(@cmd.args[1], @key[0], 256)
    var key_sv: StrView = strview_from_cstr(@key[0])

    var len: i64 = -1
    for i in 2..cmd.argc
        var val: [8192]u8
        resp_arg_copy(@cmd.args[i], @val[0], 8192)
        var val_sv: StrView = strview_from_cstr(@val[0])
        len = store_lpush(ctx.store, @key_sv, @val_sv)
        if len < 0
            let wrongtype: StrView = "WRONGTYPE Operation against a key holding the wrong kind of value"
            ctx_write_error_sv(ctx, @wrongtype)
            return CMD_ERR_TYPE

    ctx_write_int(ctx, len)
    return CMD_OK


# RPUSH key value [value ...]
fn cmd_rpush(ctx: *CommandContext, cmd: *RespCommand) -> i32
    if cmd.argc < 3
        let err: StrView = "ERR wrong number of arguments for 'rpush' command"
        ctx_write_error_sv(ctx, @err)
        return CMD_ERR_ARGC

    var key: [256]u8
    resp_arg_copy(@cmd.args[1], @key[0], 256)
    var key_sv: StrView = strview_from_cstr(@key[0])

    var len: i64 = -1
    for i in 2..cmd.argc
        var val: [8192]u8
        resp_arg_copy(@cmd.args[i], @val[0], 8192)
        var val_sv: StrView = strview_from_cstr(@val[0])
        len = store_rpush(ctx.store, @key_sv, @val_sv)
        if len < 0
            let wrongtype: StrView = "WRONGTYPE Operation against a key holding the wrong kind of value"
            ctx_write_error_sv(ctx, @wrongtype)
            return CMD_ERR_TYPE

    ctx_write_int(ctx, len)
    return CMD_OK


# LPOP key
fn cmd_lpop(ctx: *CommandContext, cmd: *RespCommand) -> i32
    if cmd.argc != 2
        let err: StrView = "ERR wrong number of arguments for 'lpop' command"
        ctx_write_error_sv(ctx, @err)
        return CMD_ERR_ARGC

    var key: [256]u8
    resp_arg_copy(@cmd.args[1], @key[0], 256)
    var key_sv: StrView = strview_from_cstr(@key[0])

    var result: String = store_lpop(ctx.store, @key_sv)
    if string_len(@result) == 0
        ctx_write_null(ctx)
    else
        let vlen: i64 = string_len(@result)
        ctx_write_bulk(ctx, string_as_ptr(@result), vlen)
    string_drop(@result)
    return CMD_OK


# RPOP key
fn cmd_rpop(ctx: *CommandContext, cmd: *RespCommand) -> i32
    if cmd.argc != 2
        let err: StrView = "ERR wrong number of arguments for 'rpop' command"
        ctx_write_error_sv(ctx, @err)
        return CMD_ERR_ARGC

    var key: [256]u8
    resp_arg_copy(@cmd.args[1], @key[0], 256)
    var key_sv: StrView = strview_from_cstr(@key[0])

    var result: String = store_rpop(ctx.store, @key_sv)
    if string_len(@result) == 0
        ctx_write_null(ctx)
    else
        let vlen: i64 = string_len(@result)
        ctx_write_bulk(ctx, string_as_ptr(@result), vlen)
    string_drop(@result)
    return CMD_OK


# LLEN key
fn cmd_llen(ctx: *CommandContext, cmd: *RespCommand) -> i32
    if cmd.argc != 2
        let err: StrView = "ERR wrong number of arguments for 'llen' command"
        ctx_write_error_sv(ctx, @err)
        return CMD_ERR_ARGC

    var key: [256]u8
    resp_arg_copy(@cmd.args[1], @key[0], 256)
    var key_sv: StrView = strview_from_cstr(@key[0])

    let len: i64 = store_llen(ctx.store, @key_sv)
    if len < 0
        let wrongtype: StrView = "WRONGTYPE Operation against a key holding the wrong kind of value"
        ctx_write_error_sv(ctx, @wrongtype)
        return CMD_ERR_TYPE

    ctx_write_int(ctx, len)
    return CMD_OK


# LINDEX key index
fn cmd_lindex(ctx: *CommandContext, cmd: *RespCommand) -> i32
    if cmd.argc != 3
        let err: StrView = "ERR wrong number of arguments for 'lindex' command"
        ctx_write_error_sv(ctx, @err)
        return CMD_ERR_ARGC

    var key: [256]u8
    resp_arg_copy(@cmd.args[1], @key[0], 256)
    var key_sv: StrView = strview_from_cstr(@key[0])

    var ok: i32 = 0
    let idx: i64 = resp_arg_to_int(@cmd.args[2], @ok)
    if ok == 0
        let notint: StrView = "ERR value is not an integer or out of range"
        ctx_write_error_sv(ctx, @notint)
        return CMD_ERR_SYNTAX

    let val: *u8 = store_lindex(ctx.store, @key_sv, idx)
    if val == null
        ctx_write_null(ctx)
    else
        let vlen: i64 = strlen(val)
        ctx_write_bulk(ctx, val, vlen)
    return CMD_OK


# LRANGE key start stop
fn cmd_lrange(ctx: *CommandContext, cmd: *RespCommand) -> i32
    if cmd.argc != 4
        let err: StrView = "ERR wrong number of arguments for 'lrange' command"
        ctx_write_error_sv(ctx, @err)
        return CMD_ERR_ARGC

    var key: [256]u8
    resp_arg_copy(@cmd.args[1], @key[0], 256)
    var key_sv: StrView = strview_from_cstr(@key[0])

    var ok: i32 = 0
    let start: i64 = resp_arg_to_int(@cmd.args[2], @ok)
    if ok == 0
        let notint: StrView = "ERR value is not an integer or out of range"
        ctx_write_error_sv(ctx, @notint)
        return CMD_ERR_SYNTAX

    let stop: i64 = resp_arg_to_int(@cmd.args[3], @ok)
    if ok == 0
        let notint2: StrView = "ERR value is not an integer or out of range"
        ctx_write_error_sv(ctx, @notint2)
        return CMD_ERR_SYNTAX

    var count: i64 = 0
    let results: **u8 = store_lrange(ctx.store, @key_sv, start, stop, @count)

    # Write array response
    var pos: i32 = resp_write_array(ctx.resp_buf, count)
    for i in 0..count
        let v: *u8 = *(results + i)
        let vlen: i64 = strlen(v)
        pos += resp_write_bulk(ctx.resp_buf + pos, v, vlen)
    ctx.resp_len = pos

    # Free the results array (strings are borrowed, not owned)
    if results != null
        free(results as *u8)
    return CMD_OK


# ============================================================================
# Set Commands
# ============================================================================

# SADD key member [member ...]
fn cmd_sadd(ctx: *CommandContext, cmd: *RespCommand) -> i32
    if cmd.argc < 3
        let err: StrView = "ERR wrong number of arguments for 'sadd' command"
        ctx_write_error_sv(ctx, @err)
        return CMD_ERR_ARGC

    var key: [256]u8
    resp_arg_copy(@cmd.args[1], @key[0], 256)
    var key_sv: StrView = strview_from_cstr(@key[0])

    var added: i64 = 0
    for i in 2..cmd.argc
        var member: [8192]u8
        resp_arg_copy(@cmd.args[i], @member[0], 8192)
        var member_sv: StrView = strview_from_cstr(@member[0])
        let ret: i64 = store_sadd(ctx.store, @key_sv, @member_sv)
        if ret < 0
            let wrongtype: StrView = "WRONGTYPE Operation against a key holding the wrong kind of value"
            ctx_write_error_sv(ctx, @wrongtype)
            return CMD_ERR_TYPE
        added += ret

    ctx_write_int(ctx, added)
    return CMD_OK


# SREM key member [member ...]
fn cmd_srem(ctx: *CommandContext, cmd: *RespCommand) -> i32
    if cmd.argc < 3
        let err: StrView = "ERR wrong number of arguments for 'srem' command"
        ctx_write_error_sv(ctx, @err)
        return CMD_ERR_ARGC

    var key: [256]u8
    resp_arg_copy(@cmd.args[1], @key[0], 256)
    var key_sv: StrView = strview_from_cstr(@key[0])

    var removed: i64 = 0
    for i in 2..cmd.argc
        var member: [8192]u8
        resp_arg_copy(@cmd.args[i], @member[0], 8192)
        var member_sv: StrView = strview_from_cstr(@member[0])
        let ret: i64 = store_srem(ctx.store, @key_sv, @member_sv)
        if ret < 0
            let wrongtype: StrView = "WRONGTYPE Operation against a key holding the wrong kind of value"
            ctx_write_error_sv(ctx, @wrongtype)
            return CMD_ERR_TYPE
        removed += ret

    ctx_write_int(ctx, removed)
    return CMD_OK


# SISMEMBER key member
fn cmd_sismember(ctx: *CommandContext, cmd: *RespCommand) -> i32
    if cmd.argc != 3
