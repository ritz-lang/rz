fn test_cmd_del() -> i32
    var store: Store = store_new()
    var buf: [8192]u8

    # SET foo bar
    exec_cmd(@store, c"*3\r\n$3\r\nSET\r\n$3\r\nfoo\r\n$3\r\nbar\r\n", &buf[0])

    # DEL foo
    let len: i32 = exec_cmd(@store, c"*2\r\n$3\r\nDEL\r\n$3\r\nfoo\r\n", &buf[0])
    if len <= 0
        return 1
    buf[len] = 0
    if strcmp(@buf[0], c":1\r\n") != 0
        return 2

    # GET foo should return null
    let len2: i32 = exec_cmd(@store, c"*2\r\n$3\r\nGET\r\n$3\r\nfoo\r\n", &buf[0])
    buf[len2] = 0
    if strcmp(@buf[0], c"$-1\r\n") != 0
        return 3

    return 0


fn test_cmd_exists() -> i32
    var store: Store = store_new()
    var buf: [8192]u8

    # EXISTS foo (missing)
    let len1: i32 = exec_cmd(@store, c"*2\r\n$6\r\nEXISTS\r\n$3\r\nfoo\r\n", &buf[0])
    buf[len1] = 0
    if strcmp(@buf[0], c":0\r\n") != 0
        return 1

    # SET foo bar
    exec_cmd(@store, c"*3\r\n$3\r\nSET\r\n$3\r\nfoo\r\n$3\r\nbar\r\n", &buf[0])

    # EXISTS foo (exists)
    let len2: i32 = exec_cmd(@store, c"*2\r\n$6\r\nEXISTS\r\n$3\r\nfoo\r\n", &buf[0])
    buf[len2] = 0
    if strcmp(@buf[0], c":1\r\n") != 0
        return 2

    return 0


fn test_cmd_dbsize() -> i32
    var store: Store = store_new()
    var buf: [8192]u8

    # DBSIZE (empty)
    let len1: i32 = exec_cmd(@store, c"*1\r\n$6\r\nDBSIZE\r\n", &buf[0])
    buf[len1] = 0
    if strcmp(@buf[0], c":0\r\n") != 0
        return 1

    # Add some keys
    exec_cmd(@store, c"*3\r\n$3\r\nSET\r\n$1\r\na\r\n$1\r\n1\r\n", &buf[0])
    exec_cmd(@store, c"*3\r\n$3\r\nSET\r\n$1\r\nb\r\n$1\r\n2\r\n", &buf[0])

    # DBSIZE
    let len2: i32 = exec_cmd(@store, c"*1\r\n$6\r\nDBSIZE\r\n", &buf[0])
    buf[len2] = 0
    if strcmp(@buf[0], c":2\r\n") != 0
        return 2

    return 0


fn test_cmd_flushdb() -> i32
    var store: Store = store_new()
    var buf: [8192]u8

    # Add some keys
    exec_cmd(@store, c"*3\r\n$3\r\nSET\r\n$1\r\na\r\n$1\r\n1\r\n", &buf[0])
    exec_cmd(@store, c"*3\r\n$3\r\nSET\r\n$1\r\nb\r\n$1\r\n2\r\n", &buf[0])

    # FLUSHDB
    let len1: i32 = exec_cmd(@store, c"*1\r\n$7\r\nFLUSHDB\r\n", &buf[0])
    buf[len1] = 0
    if strcmp(@buf[0], c"+OK\r\n") != 0
        return 1

    # DBSIZE should be 0
    let len2: i32 = exec_cmd(@store, c"*1\r\n$6\r\nDBSIZE\r\n", &buf[0])
    buf[len2] = 0
    if strcmp(@buf[0], c":0\r\n") != 0
        return 2

    return 0


fn test_cmd_lpush_llen() -> i32
    var store: Store = store_new()
    var buf: [8192]u8

    # LPUSH mylist a
    let len1: i32 = exec_cmd(@store, c"*3\r\n$5\r\nLPUSH\r\n$6\r\nmylist\r\n$1\r\na\r\n", &buf[0])
    buf[len1] = 0
    if strcmp(@buf[0], c":1\r\n") != 0
        return 1

    # LPUSH mylist b
    let len2: i32 = exec_cmd(@store, c"*3\r\n$5\r\nLPUSH\r\n$6\r\nmylist\r\n$1\r\nb\r\n", &buf[0])
    buf[len2] = 0
    if strcmp(@buf[0], c":2\r\n") != 0
        return 2

    # LLEN mylist
    let len3: i32 = exec_cmd(@store, c"*2\r\n$4\r\nLLEN\r\n$6\r\nmylist\r\n", &buf[0])
    buf[len3] = 0
    if strcmp(@buf[0], c":2\r\n") != 0
        return 3

    return 0


