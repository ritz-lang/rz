# test/test_commands.ritz - Tests for command dispatcher
#
# Tests that RESP commands correctly interact with the Store.

import ritzlib.sys
import ritzlib.io
import ritzlib.str
import ritzlib.memory
import lib.tome
import lib.resp
import lib.commands


# ============================================================================
# Helper to execute a command
# ============================================================================

fn exec_cmd(store: *Store, input: *u8, resp_buf: *u8) -> i32
    let len: i64 = strlen(input)
    var parser: RespParser
    resp_parser_init(@parser, input, len)

    let parse_result: i32 = resp_parse(@parser)
    if parse_result != RESP_OK
        return -1

    var ctx: CommandContext
    cmd_ctx_init(@ctx, store, resp_buf, 8192)

    let result: i32 = cmd_dispatch(@ctx, @parser.command)
    return ctx.resp_len


# ============================================================================
# Tests
# ============================================================================

fn test_cmd_ping() -> i32
    var store: Store = store_new()
    var buf: [8192]u8

    let len: i32 = exec_cmd(@store, c"*1\r\n$4\r\nPING\r\n", &buf[0])
    if len <= 0
        return 1

    buf[len] = 0
    if strcmp(@buf[0], c"+PONG\r\n") != 0
        return 2

    return 0


fn test_cmd_ping_with_message() -> i32
    var store: Store = store_new()
    var buf: [8192]u8

    let len: i32 = exec_cmd(@store, c"*2\r\n$4\r\nPING\r\n$5\r\nhello\r\n", &buf[0])
    if len <= 0
        return 1

    buf[len] = 0
    if strcmp(@buf[0], c"$5\r\nhello\r\n") != 0
        return 2

    return 0


