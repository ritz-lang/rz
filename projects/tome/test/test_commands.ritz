# ============================================================================
# AUTH Command Tests
# ============================================================================

# Helper to execute a command with authentication context
fn exec_cmd_auth(store: *Store, input: *u8, resp_buf: *u8, password: *u8, is_authenticated: i32) -> i32
    let len: i64 = strlen(input)
    var parser: RespParser
    resp_parser_init(@parser, input, len)

    let parse_result: i32 = resp_parse(@parser)
    if parse_result != RESP_OK
        return -1

    var ctx: CommandContext
    cmd_ctx_init_auth(@ctx, store, resp_buf, 8192, password, is_authenticated)

    let result: i32 = cmd_dispatch(@ctx, @parser.command)
    return ctx.resp_len


fn test_auth_correct_password() -> i32
    # Test: AUTH with correct password returns OK
    var store: Store = store_new()
    var buf: [8192]u8

    # AUTH with correct password "secret123"
    let len: i32 = exec_cmd_auth(@store, c"*2\r\n$4\r\nAUTH\r\n$9\r\nsecret123\r\n", &buf[0], c"secret123", 0)
    if len <= 0
        return 1

    buf[len] = 0
    if strcmp(@buf[0], c"+OK\r\n") != 0
        return 2

    return 0


fn test_auth_wrong_password() -> i32
    # Test: AUTH with wrong password returns error
    var store: Store = store_new()
    var buf: [8192]u8

    # AUTH with wrong password
    let len: i32 = exec_cmd_auth(@store, c"*2\r\n$4\r\nAUTH\r\n$5\r\nwrong\r\n", &buf[0], c"secret123", 0)
    if len <= 0
        return 1

    buf[len] = 0
    # Should return error (starts with -)
    if buf[0] != 45  # '-'
        return 2

    return 0


fn test_auth_no_password_required() -> i32
    # Test: AUTH when no password is set returns error
    var store: Store = store_new()
    var buf: [8192]u8

    # AUTH when no password required (password is null)
    let len: i32 = exec_cmd_auth(@store, c"*2\r\n$4\r\nAUTH\r\n$3\r\nfoo\r\n", &buf[0], null, 0)
    if len <= 0
        return 1

    buf[len] = 0
    # Should return error (no password set)
    if buf[0] != 45  # '-'
        return 2

    return 0


fn test_noauth_blocks_commands() -> i32
    # Test: Commands blocked when authentication required but not done
    var store: Store = store_new()
    var buf: [8192]u8

    # SET when not authenticated (password required)
    let len: i32 = exec_cmd_auth(@store, c"*3\r\n$3\r\nSET\r\n$3\r\nfoo\r\n$3\r\nbar\r\n", &buf[0], c"secret123", 0)
    if len <= 0
        return 1

    buf[len] = 0
    # Should return NOAUTH error (starts with -)
    if buf[0] != 45  # '-'
        return 2

    return 0


fn test_auth_allows_commands() -> i32
    # Test: Commands allowed after authentication
    var store: Store = store_new()
    var buf: [8192]u8

    # SET when authenticated
    let len: i32 = exec_cmd_auth(@store, c"*3\r\n$3\r\nSET\r\n$3\r\nfoo\r\n$3\r\nbar\r\n", &buf[0], c"secret123", 1)
    if len <= 0
        return 1

    buf[len] = 0
    if strcmp(@buf[0], c"+OK\r\n") != 0
        return 2

    return 0
