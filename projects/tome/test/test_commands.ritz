fn test_cmd_unknown() -> i32
    var store: Store = store_new()
    var buf: [8192]u8

    let len: i32 = exec_cmd(@store, c"*1\r\n$7\r\nINVALID\r\n", &buf[0])
    if len <= 0
        return 1

    buf[len] = 0
    # Should start with error prefix
    if buf[0] != 45  # '-'
        return 2

    return 0


