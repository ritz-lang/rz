fn test_cmd_set_get() -> i32
    var store: Store = store_new()
    var buf: [8192]u8

    # SET foo bar
    let len1: i32 = exec_cmd(@store, c"*3\r\n$3\r\nSET\r\n$3\r\nfoo\r\n$3\r\nbar\r\n", &buf[0])
    if len1 <= 0
        return 1
    buf[len1] = 0
    if strcmp(@buf[0], c"+OK\r\n") != 0
        return 2

    # GET foo
    let len2: i32 = exec_cmd(@store, c"*2\r\n$3\r\nGET\r\n$3\r\nfoo\r\n", &buf[0])
    if len2 <= 0
        return 3
    buf[len2] = 0
    if strcmp(@buf[0], c"$3\r\nbar\r\n") != 0
        return 4

    return 0


