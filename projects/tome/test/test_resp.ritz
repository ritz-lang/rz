# test/test_resp.ritz - Tests for RESP protocol parsing and encoding
#
# Tests the Redis Serialization Protocol implementation.

import ritzlib.sys
import ritzlib.io
import ritzlib.str
import ritzlib.memory
import lib.resp


# ============================================================================
# Parser Tests
# ============================================================================

fn test_parse_array_simple() -> i32
    # *2\r\n$3\r\nGET\r\n$3\r\nfoo\r\n
    let input: *u8 = c"*2\r\n$3\r\nGET\r\n$3\r\nfoo\r\n"
    let len: i64 = strlen(input)

    var p: RespParser
    resp_parser_init(@p, input, len)

    let result: i32 = resp_parse(@p)
    if result != RESP_OK
        return 1

    if p.command.argc != 2
        return 2

    # Check first arg c"GET"
    let arg0: *RespArg = @p.command.args[0]
    if arg0.len != 3
        return 3
    if resp_arg_eq_ci(arg0, c"GET") != 1
        return 4

    # Check second arg c"foo"
    let arg1: *RespArg = @p.command.args[1]
    if arg1.len != 3
        return 5
    if resp_arg_eq(arg1, c"foo") != 1
        return 6

    return 0


fn test_parse_array_set() -> i32
    # *3\r\n$3\r\nSET\r\n$5\r\nhello\r\n$5\r\nworld\r\n
    let input: *u8 = c"*3\r\n$3\r\nSET\r\n$5\r\nhello\r\n$5\r\nworld\r\n"
    let len: i64 = strlen(input)

    var p: RespParser
    resp_parser_init(@p, input, len)

    let result: i32 = resp_parse(@p)
    if result != RESP_OK
        return 1

    if p.command.argc != 3
        return 2

    if resp_arg_eq_ci(@p.command.args[0], c"SET") != 1
        return 3
    if resp_arg_eq(@p.command.args[1], c"hello") != 1
        return 4
    if resp_arg_eq(@p.command.args[2], c"world") != 1
        return 5

    return 0


fn test_parse_inline() -> i32
    # Inline command: c"PING\r\n"
    let input: *u8 = c"PING\r\n"
    let len: i64 = strlen(input)

    var p: RespParser
    resp_parser_init(@p, input, len)

    let result: i32 = resp_parse(@p)
    if result != RESP_OK
        return 1

    if p.command.argc != 1
        return 2

    if resp_arg_eq_ci(@p.command.args[0], c"PING") != 1
        return 3

    return 0


fn test_parse_inline_with_args() -> i32
    # Inline command: c"SET foo bar\r\n"
    let input: *u8 = c"SET foo bar\r\n"
    let len: i64 = strlen(input)

    var p: RespParser
    resp_parser_init(@p, input, len)

    let result: i32 = resp_parse(@p)
    if result != RESP_OK
        return 1

    if p.command.argc != 3
        return 2

    if resp_arg_eq_ci(@p.command.args[0], c"SET") != 1
        return 3
    if resp_arg_eq(@p.command.args[1], c"foo") != 1
        return 4
    if resp_arg_eq(@p.command.args[2], c"bar") != 1
        return 5

    return 0


fn test_parse_incomplete() -> i32
    # Incomplete array - missing second arg
    let input: *u8 = c"*2\r\n$3\r\nGET\r\n"
    let len: i64 = strlen(input)

    var p: RespParser
    resp_parser_init(@p, input, len)

    let result: i32 = resp_parse(@p)
    if result != RESP_INCOMPLETE
        return 1

    return 0


fn test_parse_incomplete_bulk() -> i32
    # Bulk string without enough data
    let input: *u8 = c"*1\r\n$5\r\nhe"
    let len: i64 = strlen(input)

    var p: RespParser
    resp_parser_init(@p, input, len)

    let result: i32 = resp_parse(@p)
    if result != RESP_INCOMPLETE
        return 1

    return 0


fn test_parse_empty_buffer() -> i32
    var p: RespParser
    resp_parser_init(@p, null, 0)

    let result: i32 = resp_parse(@p)
    if result != RESP_INCOMPLETE
        return 1

    return 0


# ============================================================================
# Encoder Tests
# ============================================================================

fn test_write_simple() -> i32
    var buf: [64]u8
    let len: i32 = resp_write_simple(@buf[0], c"OK")
    buf[len] = 0

    if strcmp(@buf[0], c"+OK\r\n") != 0
        return 1

    return 0


fn test_write_error() -> i32
    var buf: [64]u8
    let len: i32 = resp_write_error(@buf[0], c"ERR unknown command")
    buf[len] = 0

    if strcmp(@buf[0], c"-ERR unknown command\r\n") != 0
        return 1

    return 0


fn test_write_int() -> i32
    var buf: [64]u8
    let len: i32 = resp_write_int(@buf[0], 42)
    buf[len] = 0

    if strcmp(@buf[0], c":42\r\n") != 0
        return 1

    return 0


fn test_write_int_negative() -> i32
    var buf: [64]u8
    let len: i32 = resp_write_int(@buf[0], -17)
    buf[len] = 0

    if strcmp(@buf[0], c":-17\r\n") != 0
        return 1

    return 0


fn test_write_int_zero() -> i32
    var buf: [64]u8
    let len: i32 = resp_write_int(@buf[0], 0)
    buf[len] = 0

    if strcmp(@buf[0], c":0\r\n") != 0
        return 1

    return 0


fn test_write_bulk() -> i32
    var buf: [64]u8
    let len: i32 = resp_write_bulk(@buf[0], c"hello", 5)
    buf[len] = 0

    if strcmp(@buf[0], c"$5\r\nhello\r\n") != 0
        return 1

    return 0


fn test_write_null() -> i32
    var buf: [64]u8
    let len: i32 = resp_write_null(@buf[0])
    buf[len] = 0

    if strcmp(@buf[0], c"$-1\r\n") != 0
        return 1

    return 0


fn test_write_array_header() -> i32
    var buf: [64]u8
    let len: i32 = resp_write_array(@buf[0], 3)
    buf[len] = 0

    if strcmp(@buf[0], c"*3\r\n") != 0
        return 1

    return 0


fn test_write_null_array() -> i32
    var buf: [64]u8
    let len: i32 = resp_write_null_array(@buf[0])
    buf[len] = 0

    if strcmp(@buf[0], c"*-1\r\n") != 0
        return 1

    return 0


# ============================================================================
# Argument Helper Tests
# ============================================================================

fn test_arg_eq_case_insensitive() -> i32
    var arg: RespArg
    arg.data = c"get"
    arg.len = 3

    if resp_arg_eq_ci(@arg, c"GET") != 1
        return 1
    if resp_arg_eq_ci(@arg, c"Get") != 1
        return 2
    if resp_arg_eq_ci(@arg, c"set") != 0
        return 3

    return 0


fn test_arg_to_int() -> i32
    var arg: RespArg
    var ok: i32 = 0

    arg.data = c"123"
    arg.len = 3
    let val1: i64 = resp_arg_to_int(@arg, @ok)
    if ok != 1
        return 1
    if val1 != 123
        return 2

    arg.data = c"-456"
    arg.len = 4
    let val2: i64 = resp_arg_to_int(@arg, @ok)
    if ok != 1
        return 3
    if val2 != -456
        return 4

    return 0


fn test_arg_copy() -> i32
    var arg: RespArg
    arg.data = c"hello world"
    arg.len = 5  # Only c"hello"

    var buf: [32]u8
    let len: i32 = resp_arg_copy(@arg, &buf[0], 32)

    if len != 5
        return 1
    if strcmp(@buf[0], c"hello") != 0
        return 2

    return 0
