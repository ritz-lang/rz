# ============================================================================
# Test: Sorted set with same scores (lexicographic ordering)
# ============================================================================

fn test_zset_same_scores() -> i32
    var store: Store = store_new()

    # All same score - should be sorted lexicographically
    store_zadd_cstr(@store, c"myzset", 1, c"charlie")
    store_zadd_cstr(@store, c"myzset", 1, c"alpha")
    store_zadd_cstr(@store, c"myzset", 1, c"bravo")
    # Expected order: alpha, bravo, charlie (lexicographic)

    var count: i64 = 0
    let members: **u8 = store_zrange_cstr(@store, c"myzset", 0, -1, @count)
    if count != 3
        if members != null
            free(members as *u8)
        return 1

    if strcmp(*members, c"alpha") != 0
        free(members as *u8)
        return 1
    if strcmp(*(members + 1), c"bravo") != 0
        free(members as *u8)
        return 1
    if strcmp(*(members + 2), c"charlie") != 0
        free(members as *u8)
        return 1
    free(members as *u8)

    return 0

# ============================================================================
# Hash Tests
# ============================================================================

# Test: HSET and HGET basic operations
fn test_hset_hget() -> i32
    var store: Store = store_new()

    # Set a field in a new hash
    let res1: i32 = store_hset_cstr(@store, c"myhash", c"field1", c"value1")
    if res1 != 1  # New field
        return 1

    # Get the field
    let val1: *u8 = store_hget_cstr(@store, c"myhash", c"field1")
    if val1 == null
        return 1
    if strcmp(val1, c"value1") != 0
        return 1

    # Update existing field
    let res2: i32 = store_hset_cstr(@store, c"myhash", c"field1", c"newvalue")
    if res2 != 0  # Updated, not new
        return 1

    let val2: *u8 = store_hget_cstr(@store, c"myhash", c"field1")
    if strcmp(val2, c"newvalue") != 0
        return 1

    # Get non-existent field
    let val3: *u8 = store_hget_cstr(@store, c"myhash", c"nofield")
    if val3 != null
        return 1

    # Get from non-existent key
    let val4: *u8 = store_hget_cstr(@store, c"nokey", c"field1")
    if val4 != null
        return 1

    return 0

# Test: HDEL field deletion
fn test_hdel() -> i32
    var store: Store = store_new()

    store_hset_cstr(@store, c"myhash", c"f1", c"v1")
    store_hset_cstr(@store, c"myhash", c"f2", c"v2")
    store_hset_cstr(@store, c"myhash", c"f3", c"v3")

    # Delete existing field
    let del1: i32 = store_hdel_cstr(@store, c"myhash", c"f2")
    if del1 != 1
        return 1

    # Verify deleted
    if store_hget_cstr(@store, c"myhash", c"f2") != null
        return 1

    # Other fields still exist
    if store_hget_cstr(@store, c"myhash", c"f1") == null
        return 1
    if store_hget_cstr(@store, c"myhash", c"f3") == null
        return 1

    # Delete non-existent field
    let del2: i32 = store_hdel_cstr(@store, c"myhash", c"nofield")
    if del2 != 0
        return 1

    # Delete from non-existent key
    let del3: i32 = store_hdel_cstr(@store, c"nokey", c"f1")
    if del3 != 0
        return 1

    return 0

# Test: HEXISTS and HLEN
fn test_hexists_hlen() -> i32
    var store: Store = store_new()

    store_hset_cstr(@store, c"myhash", c"f1", c"v1")
    store_hset_cstr(@store, c"myhash", c"f2", c"v2")

    # HEXISTS
    if store_hexists_cstr(@store, c"myhash", c"f1") != 1
        return 1
    if store_hexists_cstr(@store, c"myhash", c"nofield") != 0
        return 1
    if store_hexists_cstr(@store, c"nokey", c"f1") != 0
        return 1

    # HLEN
    let len1: i64 = store_hlen_cstr(@store, c"myhash")
    if len1 != 2
        return 1

    store_hset_cstr(@store, c"myhash", c"f3", c"v3")
    if store_hlen_cstr(@store, c"myhash") != 3
        return 1

    # Non-existent key returns 0
    if store_hlen_cstr(@store, c"nokey") != 0
        return 1

    return 0

# Test: HKEYS
fn test_hkeys() -> i32
    var store: Store = store_new()

    store_hset_cstr(@store, c"myhash", c"name", c"John")
    store_hset_cstr(@store, c"myhash", c"age", c"30")
    store_hset_cstr(@store, c"myhash", c"city", c"NYC")

    var count: i64 = 0
    let keys: **u8 = store_hkeys_cstr(@store, c"myhash", @count)
    if count != 3
        if keys != null
            free(keys as *u8)
        return 1

    # Check all keys present (order may vary due to hashing)
    var found_name: i32 = 0
    var found_age: i32 = 0
    var found_city: i32 = 0
    for i in 0..count
        let k: *u8 = *(keys + i)
        if strcmp(k, c"name") == 0
            found_name = 1
        if strcmp(k, c"age") == 0
            found_age = 1
        if strcmp(k, c"city") == 0
            found_city = 1

    free(keys as *u8)

    if found_name != 1 || found_age != 1 || found_city != 1
        return 1

    return 0

# Test: HVALS
fn test_hvals() -> i32
    var store: Store = store_new()

    store_hset_cstr(@store, c"myhash", c"a", c"1")
    store_hset_cstr(@store, c"myhash", c"b", c"2")

    var count: i64 = 0
    let vals: **u8 = store_hvals_cstr(@store, c"myhash", @count)
    if count != 2
        if vals != null
            free(vals as *u8)
        return 1

    # Check values present
    var found_1: i32 = 0
    var found_2: i32 = 0
    for i in 0..count
        let v: *u8 = *(vals + i)
        if strcmp(v, c"1") == 0
            found_1 = 1
        if strcmp(v, c"2") == 0
            found_2 = 1

    free(vals as *u8)

    if found_1 != 1 || found_2 != 1
        return 1

    return 0

# Test: HGETALL
fn test_hgetall() -> i32
    var store: Store = store_new()

    store_hset_cstr(@store, c"myhash", c"x", c"10")
    store_hset_cstr(@store, c"myhash", c"y", c"20")

    var count: i64 = 0
    let pairs: **u8 = store_hgetall_cstr(@store, c"myhash", @count)
    if count != 4  # 2 fields * 2 (field + value)
        if pairs != null
            free(pairs as *u8)
        return 1

    # Should have field-value pairs
    # pairs[0], pairs[1] = first field, first value
    # pairs[2], pairs[3] = second field, second value
    var found_x10: i32 = 0
    var found_y20: i32 = 0
    var i: i64 = 0
    while i < count
        let field: *u8 = *(pairs + i)
        let val: *u8 = *(pairs + i + 1)
        if strcmp(field, c"x") == 0 && strcmp(val, c"10") == 0
            found_x10 = 1
        if strcmp(field, c"y") == 0 && strcmp(val, c"20") == 0
            found_y20 = 1
        i += 2

    free(pairs as *u8)

    if found_x10 != 1 || found_y20 != 1
        return 1

    return 0

# Test: Hash type mismatch
fn test_hash_type_mismatch() -> i32
    var store: Store = store_new()

    # Set string key
    store_set_cstr(@store, c"key", c"value")

    # Hash ops on string should fail with -1
    let res: i32 = store_hset_cstr(@store, c"key", c"field", c"val")
    if res != -1
        return 1

    if store_hexists_cstr(@store, c"key", c"field") != -1
        return 1

    if store_hlen_cstr(@store, c"key") != -1
        return 1

    if store_hdel_cstr(@store, c"key", c"field") != -1
        return 1

    return 0

# Test: Delete hash key
fn test_del_hash() -> i32
    var store: Store = store_new()

    store_hset_cstr(@store, c"myhash", c"f1", c"v1")
    store_hset_cstr(@store, c"myhash", c"f2", c"v2")

    # Delete should work
    let deleted: i32 = store_del_cstr(@store, c"myhash")
    if deleted != 1
        return 1

    # Hash should be gone
    if store_hlen_cstr(@store, c"myhash") != 0
        return 1

    if store_hget_cstr(@store, c"myhash", c"f1") != null
        return 1

    return 0

# ============================================================================
# Pub/Sub Tests
# ============================================================================

# Global variables for tracking callback invocations
var g_callback_count: i64 = 0
var g_last_channel: *u8 = null
var g_last_message: *u8 = null

# A simple callback that increments counter
fn my_callback(channel: *u8, message: *u8, ctx: *u8) -> i32
    g_callback_count += 1
    g_last_channel = channel
    g_last_message = message
    return 0  # Continue receiving

# A callback that auto-unsubscribes after first message
fn my_callback_once(channel: *u8, message: *u8, ctx: *u8) -> i32
    g_callback_count += 1
    return 1  # Unsubscribe

# Test: Basic subscribe and publish
fn test_pubsub_basic() -> i32
    var ps: PubSub = pubsub_new()
    g_callback_count = 0

    # Subscribe to a channel
    let res: i32 = pubsub_subscribe(@ps, c"news", my_callback, null)
    if res != 1  # Should be new subscription
        return 1

    # Double subscribe should return 0
    let res2: i32 = pubsub_subscribe(@ps, c"news", my_callback, null)
    if res2 != 0
        return 1

    # Publish a message
    let count: i64 = pubsub_publish(@ps, c"news", c"hello")
    if count != 1
        return 1

    if g_callback_count != 1
        return 1

    if strcmp(g_last_message, c"hello") != 0
        return 1

    pubsub_drop(@ps)
    return 0

# Test: Multiple subscribers
fn test_pubsub_multi_sub() -> i32
    var ps: PubSub = pubsub_new()
    g_callback_count = 0

    # Subscribe same callback with different contexts
    pubsub_subscribe(@ps, c"events", my_callback, null)
    pubsub_subscribe(@ps, c"events", my_callback, c"ctx1" as *u8)
    pubsub_subscribe(@ps, c"events", my_callback, c"ctx2" as *u8)

    # Check subscriber count
    if pubsub_numsub(@ps, c"events") != 3
        return 1

    # Publish should hit all 3
    let count: i64 = pubsub_publish(@ps, c"events", c"test")
    if count != 3
        return 1

    if g_callback_count != 3
        return 1

    pubsub_drop(@ps)
    return 0

# Test: Unsubscribe
fn test_pubsub_unsubscribe() -> i32
    var ps: PubSub = pubsub_new()
    g_callback_count = 0

    pubsub_subscribe(@ps, c"ch", my_callback, null)
    pubsub_subscribe(@ps, c"ch", my_callback, c"ctx" as *u8)

    if pubsub_numsub(@ps, c"ch") != 2
        return 1

    # Unsubscribe one
    let res: i32 = pubsub_unsubscribe(@ps, c"ch", my_callback, null)
    if res != 1
        return 1

    if pubsub_numsub(@ps, c"ch") != 1
        return 1

    # Publish should only hit remaining subscriber
    pubsub_publish(@ps, c"ch", c"msg")
    if g_callback_count != 1
        return 1

    pubsub_drop(@ps)
    return 0

# Test: Auto-unsubscribe on callback return non-zero
fn test_pubsub_auto_unsub() -> i32
    var ps: PubSub = pubsub_new()
    g_callback_count = 0

    pubsub_subscribe(@ps, c"once", my_callback_once, null)
    pubsub_subscribe(@ps, c"once", my_callback, null)  # This one stays

    if pubsub_numsub(@ps, c"once") != 2
        return 1

    # First publish triggers both, one auto-unsubscribes
    pubsub_publish(@ps, c"once", c"first")
    if g_callback_count != 2
        return 1

    if pubsub_numsub(@ps, c"once") != 1
        return 1

    # Second publish only hits the remaining one
    pubsub_publish(@ps, c"once", c"second")
    if g_callback_count != 3
        return 1

    pubsub_drop(@ps)
    return 0

# Test: Pattern subscribe
fn test_pubsub_pattern() -> i32
    var ps: PubSub = pubsub_new()
    g_callback_count = 0

    # Subscribe to pattern
    let res: i32 = pubsub_psubscribe(@ps, c"news.*", my_callback, null)
    if res != 1
        return 1

    if pubsub_numpat(@ps) != 1
        return 1

    # Publish to matching channels
    pubsub_publish(@ps, c"news.sports", c"goal!")
    if g_callback_count != 1
        return 1

    pubsub_publish(@ps, c"news.weather", c"sunny")
    if g_callback_count != 2
        return 1

    # Non-matching channel
    pubsub_publish(@ps, c"alerts.urgent", c"fire")
    if g_callback_count != 2  # Should not increase
        return 1

    pubsub_drop(@ps)
    return 0

# Test: Pattern unsubscribe
fn test_pubsub_punsubscribe() -> i32
    var ps: PubSub = pubsub_new()
    g_callback_count = 0

    pubsub_psubscribe(@ps, c"foo.*", my_callback, null)
    pubsub_psubscribe(@ps, c"bar.*", my_callback, null)

    if pubsub_numpat(@ps) != 2
        return 1

    # Unsubscribe one pattern
    let res: i32 = pubsub_punsubscribe(@ps, c"foo.*", my_callback, null)
    if res != 1
        return 1

    if pubsub_numpat(@ps) != 1
        return 1

    # Only bar.* should match now
    pubsub_publish(@ps, c"foo.test", c"x")
    if g_callback_count != 0
        return 1

    pubsub_publish(@ps, c"bar.test", c"y")
    if g_callback_count != 1
        return 1

    pubsub_drop(@ps)
    return 0

# Test: Mixed channel and pattern
fn test_pubsub_mixed() -> i32
    var ps: PubSub = pubsub_new()
    g_callback_count = 0

    # Direct subscription
    pubsub_subscribe(@ps, c"events.login", my_callback, null)

    # Pattern subscription that also matches
    pubsub_psubscribe(@ps, c"events.*", my_callback, c"pattern" as *u8)

    # Publish to the matching channel - both should fire
    let count: i64 = pubsub_publish(@ps, c"events.login", c"user123")
    if count != 2
        return 1

    if g_callback_count != 2
        return 1

    pubsub_drop(@ps)
    return 0

# Test: pubsub_channels listing
fn test_pubsub_channels_list() -> i32
    var ps: PubSub = pubsub_new()

    pubsub_subscribe(@ps, c"ch1", my_callback, null)
    pubsub_subscribe(@ps, c"ch2", my_callback, null)
    pubsub_subscribe(@ps, c"ch3", my_callback, null)

    var count: i64 = 0
    let channels: **u8 = pubsub_channels(@ps, @count)
    if count != 3
        if channels != null
            free(channels as *u8)
        return 1

    free(channels as *u8)
    pubsub_drop(@ps)
    return 0

# Test: Glob pattern matching edge cases
fn test_glob_patterns() -> i32
    var ps: PubSub = pubsub_new()
    g_callback_count = 0

    # Test various patterns
    pubsub_psubscribe(@ps, c"*", my_callback, c"all" as *u8)
    pubsub_psubscribe(@ps, c"h?llo", my_callback, c"hello" as *u8)
    pubsub_psubscribe(@ps, c"foo*bar", my_callback, c"foobar" as *u8)

    if pubsub_numpat(@ps) != 3
        return 1

    # Test * matches everything
    g_callback_count = 0
    pubsub_publish(@ps, c"anything", c"msg")
    if g_callback_count != 1
        return 1

    # Test ? matches single char
    g_callback_count = 0
    pubsub_publish(@ps, c"hello", c"msg")
    if g_callback_count != 2  # * and h?llo
        return 1

    g_callback_count = 0
    pubsub_publish(@ps, c"hallo", c"msg")
    if g_callback_count != 2  # * and h?llo
        return 1

    # Test foo*bar
    g_callback_count = 0
    pubsub_publish(@ps, c"foobar", c"msg")
    if g_callback_count != 2  # * and foo*bar
        return 1

    g_callback_count = 0
    pubsub_publish(@ps, c"foo123bar", c"msg")
    if g_callback_count != 2  # * and foo*bar
        return 1

    pubsub_drop(@ps)
    return 0

# ============================================================================
# Memory Management Tests
# ============================================================================

# Test: Memory tracking on set/get/del
fn test_memory_tracking() -> i32
    var store: Store = store_new()

    # Initially 0
    if store_memory_usage(@store) != 0
        return 1

    # Set a key - should increase memory
    store_set_cstr(@store, c"key1", c"value1")
    let mem1: i64 = store_memory_usage(@store)
    if mem1 <= 0
        return 1

    # Set another key - memory increases
    store_set_cstr(@store, c"key2", c"value2")
    let mem2: i64 = store_memory_usage(@store)
    if mem2 <= mem1
        return 1

    # Delete a key - memory decreases
    store_del_cstr(@store, c"key1")
    let mem3: i64 = store_memory_usage(@store)
    if mem3 >= mem2
        return 1

    return 0

# Test: Max memory and eviction policy configuration
fn test_maxmemory_config() -> i32
    var store: Store = store_new()

    # Default is no limit
    if store_get_maxmemory(@store) != 0
        return 1

    # Set a limit
    store_set_maxmemory(@store, 1000)
    if store_get_maxmemory(@store) != 1000
        return 1

    # Set eviction policy
    store_set_eviction_policy(@store, EVICT_LRU)

    return 0

# Test: LRU eviction
fn test_eviction_lru() -> i32
    var store: Store = store_new()

    # Set small max memory
    store_set_maxmemory(@store, 100)
    store_set_eviction_policy(@store, EVICT_LRU)

    # Add some keys
    store_set_cstr(@store, c"old1", c"x")
    store_set_cstr(@store, c"old2", c"y")

    # Access old1 to make it more recently used
    store_get_cstr(@store, c"old1")

    # Add more keys to trigger eviction
    store_set_cstr(@store, c"new1", c"aaaaaaaaaaaaaaaaaaaaaaaaaa")
    store_set_cstr(@store, c"new2", c"bbbbbbbbbbbbbbbbbbbbbbbbbb")
    store_set_cstr(@store, c"new3", c"cccccccccccccccccccccccccc")

    # Memory should be under limit (or close to it)
    let mem: i64 = store_memory_usage(@store)
    if mem > 150  # Allow some slack
        return 1

    # old1 should be more likely to survive (accessed recently)
    # old2 should be more likely evicted (older access)
    # Can't guarantee order but eviction should have happened

    return 0

# Test: Random eviction
fn test_eviction_random() -> i32
    var store: Store = store_new()

    store_set_maxmemory(@store, 80)
    store_set_eviction_policy(@store, EVICT_RANDOM)

    # Add keys until we hit the limit
    store_set_cstr(@store, c"k1", c"value1")
    store_set_cstr(@store, c"k2", c"value2")
    store_set_cstr(@store, c"k3", c"value3")
    store_set_cstr(@store, c"k4", c"value4")

    # Memory should be under or around limit
    let mem: i64 = store_memory_usage(@store)
    if mem > 120
        return 1

    # Some keys may have been evicted
    let count: i64 = store_len(@store)
    if count > 4
        return 1

    return 0

# Test: Volatile TTL eviction (only evicts keys with expiration)
fn test_eviction_volatile_ttl() -> i32
    var store: Store = store_new()

    store_set_maxmemory(@store, 60)
    store_set_eviction_policy(@store, EVICT_VOLATILE_TTL)

    # Add persistent key
    store_set_cstr(@store, c"persistent", c"stays")

    # Add keys with TTL
    store_setex_cstr(@store, c"expires1", c"data1", 100)
    store_setex_cstr(@store, c"expires2", c"data2", 50)  # Closer to expiration
    store_setex_cstr(@store, c"expires3", c"data3", 200)

    # Add more to trigger eviction
    store_setex_cstr(@store, c"expires4", c"moredata", 150)

    # Persistent key should still exist (no TTL)
    if store_exists_cstr(@store, c"persistent") != 1
        return 1

    return 0

# Test: No eviction policy (default)
fn test_eviction_none() -> i32
    var store: Store = store_new()

    # Default policy is EVICT_NONE
    store_set_maxmemory(@store, 50)
    # Don't set eviction policy - defaults to NONE

    # Add keys - should still work even with limit
    store_set_cstr(@store, c"k1", c"v1")
    store_set_cstr(@store, c"k2", c"v2")
    store_set_cstr(@store, c"k3", c"v3")

    # With EVICT_NONE, no eviction happens
    # Keys are still added (memory tracking happens but no eviction)
    if store_len(@store) != 3
        return 1

    return 0

# Test: Memory tracking with complex types
# Note: Memory for complex types is tracked on key creation and deletion,
# but not on every element add (for performance). This test verifies
# that deletion properly frees memory.
fn test_memory_complex_types() -> i32
    var store: Store = store_new()

    # Add string key for baseline
    store_set_cstr(@store, c"baseline", c"value")
    let baseline: i64 = store_memory_usage(@store)
    if baseline <= 0
        return 1

    # Add complex types - memory should increase (key + initial struct)
    store_lpush_cstr(@store, c"mylist", c"a")
    store_lpush_cstr(@store, c"mylist", c"b")
    store_sadd_cstr(@store, c"myset", c"x")
    store_hset_cstr(@store, c"myhash", c"f1", c"v1")

    let with_complex: i64 = store_memory_usage(@store)
    # Memory should have increased due to key strings at minimum
    if with_complex <= baseline
        return 1

    # Delete complex types - memory should decrease significantly
    # because entry_memory calculates full value size on deletion
    store_del_cstr(@store, c"mylist")
    let after_list_del: i64 = store_memory_usage(@store)
    if after_list_del >= with_complex
        return 1

    store_del_cstr(@store, c"myset")
    let after_set_del: i64 = store_memory_usage(@store)
    if after_set_del >= after_list_del
        return 1

    store_del_cstr(@store, c"myhash")
    let after_hash_del: i64 = store_memory_usage(@store)
    if after_hash_del >= after_set_del
        return 1

    return 0
