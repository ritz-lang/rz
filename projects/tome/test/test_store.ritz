# ============================================================================
# Test: ZADD and ZSCORE
# ============================================================================

fn test_zadd_zscore() -> i32
    var store: Store = store_new()

    # ZADD creates sorted set and adds member with score
    let added1: i64 = store_zadd_cstr(@store, c"myzset", 1, c"one")
    if added1 != 1
        return 1

    # Adding same member again returns 0 (updated)
    let added2: i64 = store_zadd_cstr(@store, c"myzset", 10, c"one")
    if added2 != 0
        return 1

    # Add more members
    store_zadd_cstr(@store, c"myzset", 2, c"two")
    store_zadd_cstr(@store, c"myzset", 3, c"three")

    # ZSCORE gets score
    var score: i64 = 0
    let found: i32 = store_zscore_cstr(@store, c"myzset", c"one", @score)
    if found != 1
        return 1
    if score != 10  # Updated score
        return 1

    # Non-existent member
    let found2: i32 = store_zscore_cstr(@store, c"myzset", c"four", @score)
    if found2 != 0
        return 1

    return 0

# ============================================================================
# Test: ZREM
# ============================================================================

fn test_zrem() -> i32
    var store: Store = store_new()

    store_zadd_cstr(@store, c"myzset", 1, c"one")
    store_zadd_cstr(@store, c"myzset", 2, c"two")
    store_zadd_cstr(@store, c"myzset", 3, c"three")

    # Remove a member
    let removed: i64 = store_zrem_cstr(@store, c"myzset", c"two")
    if removed != 1
        return 1

    # Verify it's gone
    var score: i64 = 0
    if store_zscore_cstr(@store, c"myzset", c"two", @score) != 0
        return 1

    # Others still there
    if store_zscore_cstr(@store, c"myzset", c"one", @score) != 1
        return 1

    # Remove non-existent member
    let removed2: i64 = store_zrem_cstr(@store, c"myzset", c"four")
    if removed2 != 0
        return 1

    return 0

# ============================================================================
# Test: ZCARD
# ============================================================================

fn test_zcard() -> i32
    var store: Store = store_new()

    # Non-existent zset has cardinality 0
    if store_zcard_cstr(@store, c"nozset") != 0
        return 1

    store_zadd_cstr(@store, c"myzset", 1, c"one")
    if store_zcard_cstr(@store, c"myzset") != 1
        return 1

    store_zadd_cstr(@store, c"myzset", 2, c"two")
    store_zadd_cstr(@store, c"myzset", 3, c"three")
    if store_zcard_cstr(@store, c"myzset") != 3
        return 1

    # Update doesn't increase cardinality
    store_zadd_cstr(@store, c"myzset", 10, c"one")
    if store_zcard_cstr(@store, c"myzset") != 3
        return 1

    return 0

# ============================================================================
# Test: ZRANK and ZREVRANK
# ============================================================================

fn test_zrank() -> i32
    var store: Store = store_new()

    store_zadd_cstr(@store, c"myzset", 1, c"one")
    store_zadd_cstr(@store, c"myzset", 2, c"two")
    store_zadd_cstr(@store, c"myzset", 3, c"three")
    # Order: one(1), two(2), three(3)
    # Ranks: 0, 1, 2

    if store_zrank_cstr(@store, c"myzset", c"one") != 0
        return 1
    if store_zrank_cstr(@store, c"myzset", c"two") != 1
        return 1
    if store_zrank_cstr(@store, c"myzset", c"three") != 2
        return 1

    # ZREVRANK: highest score = 0
    if store_zrevrank_cstr(@store, c"myzset", c"three") != 0
        return 1
    if store_zrevrank_cstr(@store, c"myzset", c"two") != 1
        return 1
    if store_zrevrank_cstr(@store, c"myzset", c"one") != 2
        return 1

    # Non-existent member
    if store_zrank_cstr(@store, c"myzset", c"four") != -1
        return 1

    return 0

# ============================================================================
# Test: ZRANGE
# ============================================================================

fn test_zrange() -> i32
    var store: Store = store_new()

    store_zadd_cstr(@store, c"myzset", 1, c"one")
    store_zadd_cstr(@store, c"myzset", 2, c"two")
    store_zadd_cstr(@store, c"myzset", 3, c"three")
    store_zadd_cstr(@store, c"myzset", 4, c"four")
    store_zadd_cstr(@store, c"myzset", 5, c"five")
    # Order: one, two, three, four, five (by score)

    # Full range
    var count: i64 = 0
    let all: **u8 = store_zrange_cstr(@store, c"myzset", 0, -1, @count)
    if count != 5
        if all != null
            free(all as *u8)
        return 1
    if strcmp(*all, c"one") != 0 || strcmp(*(all + 4), c"five") != 0
        free(all as *u8)
        return 1
    free(all as *u8)

    # Partial range
    let partial: **u8 = store_zrange_cstr(@store, c"myzset", 1, 3, @count)
    if count != 3
        if partial != null
            free(partial as *u8)
        return 1
    if strcmp(*partial, c"two") != 0 || strcmp(*(partial + 2), c"four") != 0
        free(partial as *u8)
        return 1
    free(partial as *u8)

    return 0

# ============================================================================
# Test: ZREVRANGE
# ============================================================================

fn test_zrevrange() -> i32
    var store: Store = store_new()

    store_zadd_cstr(@store, c"myzset", 1, c"one")
    store_zadd_cstr(@store, c"myzset", 2, c"two")
    store_zadd_cstr(@store, c"myzset", 3, c"three")
    # Forward order: one, two, three
    # Reverse order: three, two, one

    var count: i64 = 0
    let all: **u8 = store_zrevrange_cstr(@store, c"myzset", 0, -1, @count)
    if count != 3
        if all != null
            free(all as *u8)
        return 1

    # Should be reversed: three, two, one
    if strcmp(*all, c"three") != 0
        free(all as *u8)
        return 1
    if strcmp(*(all + 1), c"two") != 0
        free(all as *u8)
        return 1
    if strcmp(*(all + 2), c"one") != 0
        free(all as *u8)
        return 1
    free(all as *u8)

    return 0

