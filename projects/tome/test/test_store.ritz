# test/test_store.ritz - Tests for the Tome key-value store
#
# Tests basic operations: set, get, del, exists, TTL

import ritzlib.sys
import ritzlib.io
import ritzlib.str
import ritzlib.timer
import lib.tome

# ============================================================================
# Test: Basic set and get
# ============================================================================

fn test_set_get() -> i32
    var store: Store = store_new()

    # Set a value
    store_set_cstr(@store, c"hello", c"world")

    # Get it back
    let val: *u8 = store_get_cstr(@store, c"hello")
    if val == null
        return 1

    # Check the value
    if strcmp(val, c"world") != 0
        return 1

    return 0

# ============================================================================
# Test: Get returns null for missing key
# ============================================================================

fn test_get_missing() -> i32
    var store: Store = store_new()

    let val: *u8 = store_get_cstr(@store, c"nonexistent")
    if val != null
        return 1

    return 0

# ============================================================================
# Test: Exists
# ============================================================================

fn test_exists() -> i32
    var store: Store = store_new()

    # Key doesn't exist yet
    if store_exists_cstr(@store, c"key") != 0
        return 1

    # Set it
    store_set_cstr(@store, c"key", c"value")

    # Now it exists
    if store_exists_cstr(@store, c"key") != 1
        return 1

    return 0

# ============================================================================
# Test: Delete
# ============================================================================

fn test_del() -> i32
    var store: Store = store_new()

    # Set a value
    store_set_cstr(@store, c"key", c"value")

    # Verify it exists
    if store_exists_cstr(@store, c"key") != 1
        return 1

    # Delete it
    let deleted: i32 = store_del_cstr(@store, c"key")
    if deleted != 1
        return 1

    # Verify it's gone
    if store_exists_cstr(@store, c"key") != 0
        return 1

    # Get should return null
    let val: *u8 = store_get_cstr(@store, c"key")
    if val != null
        return 1

    return 0

# ============================================================================
# Test: Delete non-existent key
# ============================================================================

fn test_del_missing() -> i32
    var store: Store = store_new()

    let deleted: i32 = store_del_cstr(@store, c"nonexistent")
    if deleted != 0
        return 1

    return 0

# ============================================================================
# Test: Overwrite existing key
# ============================================================================

fn test_overwrite() -> i32
    var store: Store = store_new()

    # Set initial value
    store_set_cstr(@store, c"key", c"first")
    let val1: *u8 = store_get_cstr(@store, c"key")
    if strcmp(val1, c"first") != 0
        return 1

    # Overwrite
    store_set_cstr(@store, c"key", c"second")
    let val2: *u8 = store_get_cstr(@store, c"key")
    if strcmp(val2, c"second") != 0
        return 1

    # Length should still be 1
    if store_len(@store) != 1
        return 1

    return 0

# ============================================================================
# Test: Multiple keys
# ============================================================================

fn test_multiple_keys() -> i32
    var store: Store = store_new()

    store_set_cstr(@store, c"a", c"1")
    store_set_cstr(@store, c"b", c"2")
    store_set_cstr(@store, c"c", c"3")

    if store_len(@store) != 3
        return 1

    let va: *u8 = store_get_cstr(@store, c"a")
    let vb: *u8 = store_get_cstr(@store, c"b")
    let vc: *u8 = store_get_cstr(@store, c"c")

    if strcmp(va, c"1") != 0
        return 1
    if strcmp(vb, c"2") != 0
        return 1
    if strcmp(vc, c"3") != 0
        return 1

    return 0

# ============================================================================
# Test: Len and is_empty
# ============================================================================

fn test_len_empty() -> i32
    var store: Store = store_new()

    # Initially empty
    if store_len(@store) != 0
        return 1
    if store_is_empty(@store) != 1
        return 1

    # Add one
    store_set_cstr(@store, c"key", c"value")
    if store_len(@store) != 1
        return 1
    if store_is_empty(@store) != 0
        return 1

    # Delete it
    store_del_cstr(@store, c"key")
    if store_len(@store) != 0
        return 1
    if store_is_empty(@store) != 1
        return 1

    return 0

# ============================================================================
# Test: Stress test - many keys trigger growth
# ============================================================================

fn test_growth() -> i32
    var store: Store = store_new()

    # Insert 20 keys to trigger growth (initial cap is 16, 75% threshold = 12)
    store_set_cstr(@store, c"key_00", c"v")
    store_set_cstr(@store, c"key_01", c"v")
    store_set_cstr(@store, c"key_02", c"v")
    store_set_cstr(@store, c"key_03", c"v")
    store_set_cstr(@store, c"key_04", c"v")
    store_set_cstr(@store, c"key_05", c"v")
    store_set_cstr(@store, c"key_06", c"v")
    store_set_cstr(@store, c"key_07", c"v")
    store_set_cstr(@store, c"key_08", c"v")
    store_set_cstr(@store, c"key_09", c"v")
    store_set_cstr(@store, c"key_10", c"v")
    store_set_cstr(@store, c"key_11", c"v")
    store_set_cstr(@store, c"key_12", c"v")
    store_set_cstr(@store, c"key_13", c"v")
    store_set_cstr(@store, c"key_14", c"v")
    store_set_cstr(@store, c"key_15", c"v")
    store_set_cstr(@store, c"key_16", c"v")
    store_set_cstr(@store, c"key_17", c"v")
    store_set_cstr(@store, c"key_18", c"v")
    store_set_cstr(@store, c"key_19", c"v")

    if store_len(@store) != 20
        return 1

    # Verify keys after multiple growths
    let v0: *u8 = store_get_cstr(@store, c"key_00")
    let v10: *u8 = store_get_cstr(@store, c"key_10")
    let v19: *u8 = store_get_cstr(@store, c"key_19")

    if v0 == null || v10 == null || v19 == null
        return 1

    return 0

# ============================================================================
# Test: SETEX - set with TTL
# ============================================================================

fn test_setex() -> i32
    var store: Store = store_new()

    # Set a key with 10 second TTL
    store_setex_cstr(@store, c"key", c"value", 10)

    # Verify it exists
    let val: *u8 = store_get_cstr(@store, c"key")
    if val == null
        return 1
    if strcmp(val, c"value") != 0
        return 1

    # TTL should be positive (close to 10)
    let ttl: i64 = store_ttl_cstr(@store, c"key")
    if ttl <= 0 || ttl > 10
        return 1

    return 0

# ============================================================================
# Test: TTL returns -1 for key without expiration
# ============================================================================

fn test_ttl_no_expire() -> i32
    var store: Store = store_new()

    # Set without TTL
    store_set_cstr(@store, c"key", c"value")

    # TTL should be -1 (no expiration)
    let ttl: i64 = store_ttl_cstr(@store, c"key")
    if ttl != -1
        return 1

    return 0

# ============================================================================
# Test: TTL returns -2 for non-existent key
# ============================================================================

fn test_ttl_missing() -> i32
    var store: Store = store_new()

    let ttl: i64 = store_ttl_cstr(@store, c"nonexistent")
    if ttl != -2
        return 1

    return 0

# ============================================================================
# Test: EXPIRE - set TTL on existing key
# ============================================================================

fn test_expire() -> i32
    var store: Store = store_new()

    # Set without TTL
    store_set_cstr(@store, c"key", c"value")
    if store_ttl_cstr(@store, c"key") != -1
        return 1

    # Add expiration
    let result: i32 = store_expire_cstr(@store, c"key", 60)
    if result != 1
        return 1

    # TTL should now be positive
    let ttl: i64 = store_ttl_cstr(@store, c"key")
    if ttl <= 0 || ttl > 60
        return 1

    return 0

# ============================================================================
# Test: EXPIRE on non-existent key
# ============================================================================

fn test_expire_missing() -> i32
    var store: Store = store_new()

    let result: i32 = store_expire_cstr(@store, c"nonexistent", 60)
    if result != 0
        return 1

    return 0

# ============================================================================
# Test: PERSIST - remove expiration
# ============================================================================

fn test_persist() -> i32
    var store: Store = store_new()

    # Set with TTL
    store_setex_cstr(@store, c"key", c"value", 60)
    if store_ttl_cstr(@store, c"key") <= 0
        return 1

    # Remove TTL
    let result: i32 = store_persist_cstr(@store, c"key")
    if result != 1
        return 1

    # TTL should now be -1
    if store_ttl_cstr(@store, c"key") != -1
        return 1

    return 0

# ============================================================================
# Test: PERSIST on key without TTL
# ============================================================================

fn test_persist_no_ttl() -> i32
    var store: Store = store_new()

    store_set_cstr(@store, c"key", c"value")

    let result: i32 = store_persist_cstr(@store, c"key")
    if result != 0
        return 1

    return 0

# ============================================================================
# Test: Lazy expiration - expired key returns null
# ============================================================================

fn test_lazy_expiration() -> i32
    var store: Store = store_new()

    # Set with 1 second TTL
    store_setex_cstr(@store, c"key", c"value", 1)

    # Should exist immediately
    let val1: *u8 = store_get_cstr(@store, c"key")
    if val1 == null
        return 1

    # Sleep for 2 seconds
    var req: [2]i64
    req[0] = 2  # tv_sec
    req[1] = 0  # tv_nsec
    sys_nanosleep(@req[0], null)

    # Now it should be expired
    let val2: *u8 = store_get_cstr(@store, c"key")
    if val2 != null
        return 1

    # Key should no longer exist
    if store_exists_cstr(@store, c"key") != 0
        return 1

    # TTL should be -2 (key gone)
    if store_ttl_cstr(@store, c"key") != -2
        return 1

    return 0

# ============================================================================
# Test: Active expiration sweep
# ============================================================================

fn test_expire_sweep() -> i32
    var store: Store = store_new()

    # Set multiple keys with 1 second TTL
    store_setex_cstr(@store, c"a", c"1", 1)
    store_setex_cstr(@store, c"b", c"2", 1)
    store_setex_cstr(@store, c"c", c"3", 1)
    # This one doesn't expire
    store_set_cstr(@store, c"d", c"4")

    # Should have 4 keys
    if store_len(@store) != 4
        return 1

    # Sleep for 2 seconds
    var req: [2]i64
    req[0] = 2
    req[1] = 0
    sys_nanosleep(@req[0], null)

    # Run sweep
    let deleted: i64 = store_expire_sweep(@store)
    if deleted != 3
        return 1

    # Should have 1 key left
    if store_len(@store) != 1
        return 1

    # The non-expiring key should still exist
    let val: *u8 = store_get_cstr(@store, c"d")
    if val == null
        return 1

    return 0

# ============================================================================
# Test: LPUSH and RPUSH
# ============================================================================

fn test_lpush_rpush() -> i32
    var store: Store = store_new()

    # LPUSH creates list and adds to head
    let len1: i64 = store_lpush_cstr(@store, c"mylist", c"a")
    if len1 != 1
        return 1

    # LPUSH again - adds to head
    let len2: i64 = store_lpush_cstr(@store, c"mylist", c"b")
    if len2 != 2
        return 1

    # RPUSH - adds to tail
    let len3: i64 = store_rpush_cstr(@store, c"mylist", c"c")
    if len3 != 3
        return 1

    # Order should be: b, a, c
    let v0: *u8 = store_lindex_cstr(@store, c"mylist", 0)
    let v1: *u8 = store_lindex_cstr(@store, c"mylist", 1)
    let v2: *u8 = store_lindex_cstr(@store, c"mylist", 2)

    if strcmp(v0, c"b") != 0
        return 1
    if strcmp(v1, c"a") != 0
        return 1
    if strcmp(v2, c"c") != 0
        return 1

    return 0

# ============================================================================
# Test: LPOP and RPOP
# ============================================================================

fn test_lpop_rpop() -> i32
    var store: Store = store_new()

    store_rpush_cstr(@store, c"mylist", c"a")
    store_rpush_cstr(@store, c"mylist", c"b")
    store_rpush_cstr(@store, c"mylist", c"c")
    # List: a, b, c

    # LPOP removes from head
    var val1: String = store_lpop_cstr(@store, c"mylist")
    if strcmp(string_as_ptr(@val1), c"a") != 0
        string_drop(@val1)
        return 1
    string_drop(@val1)

    # List: b, c
    var val2: String = store_rpop_cstr(@store, c"mylist")
    if strcmp(string_as_ptr(@val2), c"c") != 0
        string_drop(@val2)
        return 1
    string_drop(@val2)

    # List: b
    if store_llen_cstr(@store, c"mylist") != 1
        return 1

    return 0

# ============================================================================
# Test: LLEN
# ============================================================================

fn test_llen() -> i32
    var store: Store = store_new()

    # Non-existent list has length 0
    if store_llen_cstr(@store, c"nolist") != 0
        return 1

    store_rpush_cstr(@store, c"mylist", c"a")
    if store_llen_cstr(@store, c"mylist") != 1
        return 1

    store_rpush_cstr(@store, c"mylist", c"b")
    store_rpush_cstr(@store, c"mylist", c"c")
    if store_llen_cstr(@store, c"mylist") != 3
        return 1

    return 0

# ============================================================================
# Test: LINDEX with negative indices
# ============================================================================

fn test_lindex_negative() -> i32
    var store: Store = store_new()

    store_rpush_cstr(@store, c"mylist", c"a")
    store_rpush_cstr(@store, c"mylist", c"b")
    store_rpush_cstr(@store, c"mylist", c"c")
    # List: a, b, c (indices 0, 1, 2 or -3, -2, -1)

    # Positive indices
    let v0: *u8 = store_lindex_cstr(@store, c"mylist", 0)
    if strcmp(v0, c"a") != 0
        return 1

    # Negative indices
    let v_1: *u8 = store_lindex_cstr(@store, c"mylist", -1)
    if strcmp(v_1, c"c") != 0
        return 1

    let v_2: *u8 = store_lindex_cstr(@store, c"mylist", -2)
    if strcmp(v_2, c"b") != 0
        return 1

    # Out of bounds returns null
    let v_out: *u8 = store_lindex_cstr(@store, c"mylist", 10)
    if v_out != null
        return 1

    return 0

# ============================================================================
# Test: LRANGE
# ============================================================================

fn test_lrange() -> i32
    var store: Store = store_new()

    store_rpush_cstr(@store, c"mylist", c"a")
    store_rpush_cstr(@store, c"mylist", c"b")
    store_rpush_cstr(@store, c"mylist", c"c")
    store_rpush_cstr(@store, c"mylist", c"d")
    store_rpush_cstr(@store, c"mylist", c"e")
    # List: a, b, c, d, e

    # Full range
    var count: i64 = 0
    let all: **u8 = store_lrange_cstr(@store, c"mylist", 0, -1, @count)
    if count != 5
        if all != null
            free(all as *u8)
        return 1
    if strcmp(*all, c"a") != 0 || strcmp(*(all + 4), c"e") != 0
        free(all as *u8)
        return 1
    free(all as *u8)

    # Partial range
    let partial: **u8 = store_lrange_cstr(@store, c"mylist", 1, 3, @count)
    if count != 3
        if partial != null
            free(partial as *u8)
        return 1
    if strcmp(*partial, c"b") != 0 || strcmp(*(partial + 2), c"d") != 0
        free(partial as *u8)
        return 1
    free(partial as *u8)

    # Negative indices
    let tail: **u8 = store_lrange_cstr(@store, c"mylist", -2, -1, @count)
    if count != 2
        if tail != null
            free(tail as *u8)
        return 1
    if strcmp(*tail, c"d") != 0 || strcmp(*(tail + 1), c"e") != 0
        free(tail as *u8)
        return 1
    free(tail as *u8)

    return 0

# ============================================================================
# Test: List type mismatch
# ============================================================================

fn test_list_type_mismatch() -> i32
    var store: Store = store_new()

    # Set a string key
    store_set_cstr(@store, c"key", c"value")

    # Try to use list operations on it
    let len: i64 = store_lpush_cstr(@store, c"key", c"item")
    if len != -1  # Should fail with -1
        return 1

    let llen: i64 = store_llen_cstr(@store, c"key")
    if llen != -1  # Should fail with -1
        return 1

    return 0

# ============================================================================
# Test: Empty list operations
# ============================================================================

fn test_empty_list_ops() -> i32
    var store: Store = store_new()

    # Pop from non-existent list
    var val: String = store_lpop_cstr(@store, c"nolist")
    if string_len(@val) != 0  # Should be empty string
        string_drop(@val)
        return 1
    string_drop(@val)

    # Create list, pop everything
    store_rpush_cstr(@store, c"mylist", c"only")
    var popped: String = store_lpop_cstr(@store, c"mylist")
    string_drop(@popped)

    # Now empty - pop again
    var empty_pop: String = store_lpop_cstr(@store, c"mylist")
    if string_len(@empty_pop) != 0
        string_drop(@empty_pop)
        return 1
    string_drop(@empty_pop)

    # Length of empty list
    if store_llen_cstr(@store, c"mylist") != 0
        return 1

    return 0

# ============================================================================
# Test: Delete list key
# ============================================================================

fn test_del_list() -> i32
    var store: Store = store_new()

    store_rpush_cstr(@store, c"mylist", c"a")
    store_rpush_cstr(@store, c"mylist", c"b")
    store_rpush_cstr(@store, c"mylist", c"c")

    # Delete should work
    let deleted: i32 = store_del_cstr(@store, c"mylist")
    if deleted != 1
        return 1

    # List should be gone
    if store_llen_cstr(@store, c"mylist") != 0
        return 1

    return 0

# ============================================================================
# Test: SADD and SISMEMBER
# ============================================================================

fn test_sadd_sismember() -> i32
    var store: Store = store_new()

    # SADD creates set and adds member
    let added1: i64 = store_sadd_cstr(@store, c"myset", c"a")
    if added1 != 1
        return 1

    # Adding same member again returns 0
    let added2: i64 = store_sadd_cstr(@store, c"myset", c"a")
    if added2 != 0
        return 1

    # Add more members
    store_sadd_cstr(@store, c"myset", c"b")
    store_sadd_cstr(@store, c"myset", c"c")

    # SISMEMBER checks membership
    if store_sismember_cstr(@store, c"myset", c"a") != 1
        return 1
    if store_sismember_cstr(@store, c"myset", c"b") != 1
        return 1
    if store_sismember_cstr(@store, c"myset", c"d") != 0  # Not a member
        return 1

    return 0

# ============================================================================
# Test: SREM
# ============================================================================

fn test_srem() -> i32
    var store: Store = store_new()

    store_sadd_cstr(@store, c"myset", c"a")
    store_sadd_cstr(@store, c"myset", c"b")
    store_sadd_cstr(@store, c"myset", c"c")

    # Remove a member
    let removed: i64 = store_srem_cstr(@store, c"myset", c"b")
    if removed != 1
        return 1

    # Verify it's gone
    if store_sismember_cstr(@store, c"myset", c"b") != 0
        return 1

    # Others still there
    if store_sismember_cstr(@store, c"myset", c"a") != 1
        return 1

    # Remove non-existent member
    let removed2: i64 = store_srem_cstr(@store, c"myset", c"x")
    if removed2 != 0
        return 1

    return 0

# ============================================================================
# Test: SCARD
# ============================================================================

fn test_scard() -> i32
    var store: Store = store_new()

    # Non-existent set has cardinality 0
    if store_scard_cstr(@store, c"noset") != 0
        return 1

    store_sadd_cstr(@store, c"myset", c"a")
    if store_scard_cstr(@store, c"myset") != 1
        return 1

    store_sadd_cstr(@store, c"myset", c"b")
    store_sadd_cstr(@store, c"myset", c"c")
    if store_scard_cstr(@store, c"myset") != 3
        return 1

    # Duplicate doesn't increase cardinality
    store_sadd_cstr(@store, c"myset", c"a")
    if store_scard_cstr(@store, c"myset") != 3
        return 1

    return 0

# ============================================================================
# Test: SMEMBERS
# ============================================================================

fn test_smembers() -> i32
    var store: Store = store_new()

    store_sadd_cstr(@store, c"myset", c"a")
    store_sadd_cstr(@store, c"myset", c"b")
    store_sadd_cstr(@store, c"myset", c"c")

    var count: i64 = 0
    let members: **u8 = store_smembers_cstr(@store, c"myset", @count)

    if count != 3
        if members != null
            free(members as *u8)
        return 1

    # Members are returned in hash order (unordered)
    # Just verify we got 3 non-null strings
    if members == null
        return 1

    var found_a: i32 = 0
    var found_b: i32 = 0
    var found_c: i32 = 0

    for i in 0..count
        let m: *u8 = *(members + i)
        if strcmp(m, c"a") == 0
            found_a = 1
        if strcmp(m, c"b") == 0
            found_b = 1
        if strcmp(m, c"c") == 0
            found_c = 1

    free(members as *u8)

    if found_a != 1 || found_b != 1 || found_c != 1
        return 1

    return 0

# ============================================================================
# Test: SUNION
# ============================================================================

fn test_sunion() -> i32
    var store: Store = store_new()

    store_sadd_cstr(@store, c"set1", c"a")
    store_sadd_cstr(@store, c"set1", c"b")
    store_sadd_cstr(@store, c"set2", c"b")
    store_sadd_cstr(@store, c"set2", c"c")

    let result: *Set = store_sunion_cstr(@store, c"set1", c"set2")
    if result == null
        return 1

    if set_len(result) != 3  # {a, b, c}
        set_drop(result)
        return 1

    # Verify all members present
    if set_contains(result, c"a") != 1
        set_drop(result)
        return 1
    if set_contains(result, c"b") != 1
        set_drop(result)
        return 1
    if set_contains(result, c"c") != 1
        set_drop(result)
        return 1

    set_drop(result)
    return 0

# ============================================================================
# Test: SINTER
# ============================================================================

fn test_sinter() -> i32
    var store: Store = store_new()

    store_sadd_cstr(@store, c"set1", c"a")
    store_sadd_cstr(@store, c"set1", c"b")
    store_sadd_cstr(@store, c"set1", c"c")
    store_sadd_cstr(@store, c"set2", c"b")
    store_sadd_cstr(@store, c"set2", c"c")
    store_sadd_cstr(@store, c"set2", c"d")

    let result: *Set = store_sinter_cstr(@store, c"set1", c"set2")
    if result == null
        return 1

    if set_len(result) != 2  # {b, c}
        set_drop(result)
        return 1

    # Verify members
    if set_contains(result, c"b") != 1
        set_drop(result)
        return 1
    if set_contains(result, c"c") != 1
        set_drop(result)
        return 1
    # 'a' should NOT be in intersection
    if set_contains(result, c"a") != 0
        set_drop(result)
        return 1

    set_drop(result)
    return 0

# ============================================================================
# Test: SDIFF
# ============================================================================

fn test_sdiff() -> i32
    var store: Store = store_new()

    store_sadd_cstr(@store, c"set1", c"a")
    store_sadd_cstr(@store, c"set1", c"b")
    store_sadd_cstr(@store, c"set1", c"c")
    store_sadd_cstr(@store, c"set2", c"b")
    store_sadd_cstr(@store, c"set2", c"d")

    let result: *Set = store_sdiff_cstr(@store, c"set1", c"set2")
    if result == null
        return 1

    if set_len(result) != 2  # {a, c} - items in set1 but not set2
        set_drop(result)
        return 1

    # Verify members
    if set_contains(result, c"a") != 1
        set_drop(result)
        return 1
    if set_contains(result, c"c") != 1
        set_drop(result)
        return 1
    # 'b' should NOT be in diff (it's in set2)
    if set_contains(result, c"b") != 0
        set_drop(result)
        return 1

    set_drop(result)
    return 0

