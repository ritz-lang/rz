# valet/lib/router.ritz - HTTP routing framework
#
# Provides path-based routing for the Valet HTTP server.
# Supports:
#   - Exact path matching: "/api/users"
#   - Prefix matching: "/static/*" (matches /static/foo, /static/foo/bar)
#   - Simple wildcards: "/users/:id" (captures path segment)
#   - Catch-all wildcards: "/**" (matches everything, including nested paths)
#   - Middleware pipeline with before/after hooks
#
# Design:
#   Routes are stored in a fixed-size array for simplicity and cache locality.
#   Matching is done via linear scan (fast for typical route counts < 100).
#   For high-performance paths, use exact matches which are O(1) via hash lookup.
#   Middleware runs in registration order (before) and reverse order (after).
#
# Usage:
#   var router: Router
#   router_init(@router)
#   router_use(@router, logging_middleware)  # Global middleware
#   router_add(@router, "GET", "/", handle_index)
#   router_add(@router, "GET", "/users/:id", handle_user)
#   router_add(@router, "GET", "/static/*", handle_static)
#   router_add(@router, "GET", "/files/**", handle_files)  # Catch-all
#
#   var match: RouteMatch
#   if router_match(@router, "GET", "/users/42", @match) == 1
#       # match.handler is the handler function
#       # match.params[0] contains "42"

import ritzlib.str
import ritzlib.io

# ============================================================================
# Constants
# ============================================================================

const MAX_ROUTES: i32 = 64          # Maximum number of routes
const MAX_PARAMS: i32 = 8           # Maximum path parameters per route
const MAX_PARAM_LEN: i32 = 256      # Maximum length of a captured parameter
const MAX_MIDDLEWARE: i32 = 16      # Maximum middleware functions
const MAX_ROUTE_MW: i32 = 4         # Maximum middleware per route

# Route pattern types
const ROUTE_EXACT: i32 = 0          # Exact match: "/api/users"
const ROUTE_PREFIX: i32 = 1         # Prefix match: "/static/*"
const ROUTE_PARAM: i32 = 2          # Has parameters: "/users/:id"
const ROUTE_CATCHALL: i32 = 3       # Catch-all: "/files/**"

# Middleware return values
const MW_CONTINUE: i32 = 0          # Continue to next middleware/handler
const MW_HANDLED: i32 = 1           # Request was handled, skip remaining middleware
const MW_ERROR: i32 = -1            # Error occurred, abort request

# router_add return values
const ROUTER_OK: i32 = 0            # Route added successfully
const ROUTER_ERR_FULL: i32 = -1     # Router is full (MAX_ROUTES reached)
const ROUTER_ERR_MW_FULL: i32 = -1  # Middleware list is full


# ============================================================================
# Route - A single route definition
# ============================================================================

struct Route
    method: *u8                     # HTTP method (GET, POST, etc.) or null for any
    pattern: *u8                    # URL pattern
    pattern_len: i32                # Length of pattern
    route_type: i32                 # EXACT, PREFIX, or PARAM
    handler: fn(*u8, i32) -> i32    # Handler function (path, path_len) -> status
    param_count: i32                # Number of :param segments
    param_offsets: [8]i32           # Offsets of ':' in pattern
    # Per-route middleware (before/after hooks)
    before: [4]fn(*u8, i32) -> i32  # Before-handler interceptors
    before_count: i32               # Number of before interceptors
    after: [4]fn(*u8, i32) -> i32   # After-handler interceptors (run in reverse)
    after_count: i32                # Number of after interceptors


# ============================================================================
# RouteMatch - Result of a successful route match
# ============================================================================

struct RouteMatch
    handler: fn(*u8, i32) -> i32    # Matched handler
    route: *Route                   # Pointer to matched route
    param_count: i32                # Number of captured parameters
    param_starts: [8]*u8            # Start pointers into original path
    param_lens: [8]i32              # Lengths of captured parameters


# ============================================================================
# Middleware - Functions that run before/after handlers
# ============================================================================

# Middleware context passed to middleware functions
# Contains request info and allows setting response data
struct MiddlewareContext
    method: *u8                     # HTTP method (pointer into request buffer)
    method_len: i32                 # Method length
    path: *u8                       # Request path
    path_len: i32                   # Path length
    user_data: i64                  # Optional user data (can store pointer as i64)

# Middleware function type:
#   ctx: Context with request info
#   Returns: MW_CONTINUE (0) to continue, MW_HANDLED (1) to stop, MW_ERROR (-1) on error
# Note: Ritz doesn't support function pointer types with struct params directly,
#       so we use *u8, i32 (path, path_len) as a simpler signature

struct Middleware
    handler: fn(*u8, i32) -> i32    # Middleware function (path, path_len) -> status
    name: *u8                       # Optional name for debugging


# ============================================================================
# Router - Collection of routes
# ============================================================================

struct Router
    routes: [64]Route               # Fixed array of routes
    count: i32                      # Number of registered routes
    middleware: [16]Middleware      # Middleware pipeline
    mw_count: i32                   # Number of registered middleware


# Initialize an empty router
pub fn router_init(r: *Router)
    r.count = 0
    r.mw_count = 0
    for i in 0..MAX_ROUTES
        r.routes[i].method = null
        r.routes[i].pattern = null
        r.routes[i].handler = null
    for i in 0..MAX_MIDDLEWARE
        r.middleware[i].handler = null
        r.middleware[i].name = null


# Add middleware to the router
# Middleware runs in registration order before the handler
# Returns 0 on success, -1 if middleware array is full
pub fn router_use(r: *Router, handler: fn(*u8, i32) -> i32) -> i32
    if r.mw_count >= MAX_MIDDLEWARE
        return -1
    r.middleware[r.mw_count].handler = handler
    r.middleware[r.mw_count].name = null
    r.mw_count += 1
    return 0


# Add named middleware (for debugging)
pub fn router_use_named(r: *Router, name: *u8, handler: fn(*u8, i32) -> i32) -> i32
    if r.mw_count >= MAX_MIDDLEWARE
        return -1
    r.middleware[r.mw_count].handler = handler
    r.middleware[r.mw_count].name = name
    r.mw_count += 1
    return 0


# Run all middleware in the pipeline
# Returns MW_CONTINUE if all passed, MW_HANDLED if one handled the request,
# MW_ERROR if one returned an error
pub fn router_run_middleware(r: *Router, path: *u8, path_len: i32) -> i32
    for i in 0..r.mw_count
        let mw: *Middleware = @r.middleware[i]
        let h: fn(*u8, i32) -> i32 = mw.handler
        if h != null
            let result: i32 = h(path, path_len)
            if result != MW_CONTINUE
                return result
    return MW_CONTINUE


# Add a route to the router
# Returns 0 on success, -1 if router is full
pub fn router_add(r: *Router, method: *u8, pattern: *u8, handler: fn(*u8, i32) -> i32) -> i32
    if r.count >= MAX_ROUTES
        return -1

    let idx: i32 = r.count
    let route: *Route = @r.routes[idx]

    route.method = method
    route.pattern = pattern
    route.pattern_len = strlen(pattern) as i32
    route.handler = handler
    route.param_count = 0
    route.before_count = 0
    route.after_count = 0
    for i in 0..MAX_ROUTE_MW
        route.before[i] = null
        route.after[i] = null

    # Analyze pattern to determine type and find parameters
    route.route_type = ROUTE_EXACT
    var pos: i32 = 0
    while pos < route.pattern_len
        let c: u8 = *(pattern + pos)

        if c == '*'
            # Check for catch-all /** at end
            if pos == route.pattern_len - 2 && *(pattern + pos + 1) == '*'
                route.route_type = ROUTE_CATCHALL
                route.pattern_len -= 2  # Remove ** from matching
                break
            # Single * at end means prefix match
            if pos == route.pattern_len - 1
                route.route_type = ROUTE_PREFIX
                route.pattern_len -= 1  # Don't include * in matching
            break

        if c == ':'
            # Parameter segment
            route.route_type = ROUTE_PARAM
            if route.param_count < MAX_PARAMS
                route.param_offsets[route.param_count] = pos
                route.param_count += 1

        pos += 1

    r.count += 1
    return 0


# ============================================================================
# Per-route middleware (interceptors)
# ============================================================================

# Add a before-handler interceptor to the most recently added route.
# Before interceptors run after global middleware but before the route handler.
# Returns 0 on success, -1 if route has max interceptors or no routes exist.
pub fn router_route_before(r: *Router, handler: fn(*u8, i32) -> i32) -> i32
    if r.count == 0
        return -1
    let route: *Route = @r.routes[r.count - 1]
    if route.before_count >= MAX_ROUTE_MW
        return -1
    route.before[route.before_count] = handler
    route.before_count += 1
    return 0


# Add an after-handler interceptor to the most recently added route.
# After interceptors run after the route handler (in reverse registration order).
# Useful for response transformation, cleanup, or metrics.
# Returns 0 on success, -1 if route has max interceptors or no routes exist.
pub fn router_route_after(r: *Router, handler: fn(*u8, i32) -> i32) -> i32
    if r.count == 0
        return -1
    let route: *Route = @r.routes[r.count - 1]
    if route.after_count >= MAX_ROUTE_MW
        return -1
    route.after[route.after_count] = handler
    route.after_count += 1
    return 0


# Run before interceptors for a route.
# Returns MW_CONTINUE if all passed, MW_HANDLED if one handled request, MW_ERROR on error.
pub fn route_run_before(route: *Route, path: *u8, path_len: i32) -> i32
    for i in 0..route.before_count
        let h: fn(*u8, i32) -> i32 = route.before[i]
        if h != null
            let result: i32 = h(path, path_len)
            if result != MW_CONTINUE
                return result
    return MW_CONTINUE


# Run after interceptors for a route (in reverse registration order).
# Returns MW_CONTINUE if all passed, or first non-continue result.
pub fn route_run_after(route: *Route, path: *u8, path_len: i32) -> i32
    var i: i32 = route.after_count - 1
    while i >= 0
        let h: fn(*u8, i32) -> i32 = route.after[i]
        if h != null
            let result: i32 = h(path, path_len)
            if result != MW_CONTINUE
                return result
        i -= 1
    return MW_CONTINUE


# Match a request against registered routes
# method/path are pointers into the request buffer (not null-terminated)
# Returns 1 if match found (result populated), 0 if no match
pub fn router_match(r: *Router, method: *u8, path: *u8, path_len: i32, result: *RouteMatch) -> i32
    # Calculate method length by finding space or assuming common methods
    var method_len: i32 = 0
    while *(method + method_len) != ' ' && *(method + method_len) != 0 && method_len < 10
        method_len += 1

    for i in 0..r.count
        let route: *Route = @r.routes[i]

        # Check method (null means any method)
        if route.method != null
            let route_method_len: i32 = strlen(route.method) as i32
            if method_len != route_method_len
                continue
            if strneq(method, route.method, method_len as i64) == 0
                continue

        # Try to match based on route type
        if route.route_type == ROUTE_EXACT
            if route_match_exact(route, path, path_len) == 1
                result.handler = route.handler
                result.route = route
                result.param_count = 0
                return 1
        else
            if route.route_type == ROUTE_PREFIX
                if route_match_prefix(route, path, path_len) == 1
                    result.handler = route.handler
                    result.route = route
                    result.param_count = 0
                    return 1
            else
                if route.route_type == ROUTE_CATCHALL
                    if route_match_catchall(route, path, path_len, result) == 1
                        result.handler = route.handler
                        result.route = route
                        return 1
                else
                    if route.route_type == ROUTE_PARAM
                        if route_match_params(route, path, path_len, result) == 1
                            result.handler = route.handler
                            result.route = route
                            return 1

    return 0


# ============================================================================
# Internal matching functions
# ============================================================================

# Exact match: pattern must equal path exactly
pub fn route_match_exact(route: *Route, path: *u8, path_len: i32) -> i32
    if route.pattern_len != path_len
        return 0

    for i in 0..path_len
        if *(route.pattern + i) != *(path + i)
            return 0

    return 1


# Prefix match: path must start with pattern (minus trailing *)
pub fn route_match_prefix(route: *Route, path: *u8, path_len: i32) -> i32
    if path_len < route.pattern_len
        return 0

    for i in 0..route.pattern_len
        if *(route.pattern + i) != *(path + i)
            return 0

    return 1


# Catch-all match: pattern/** matches everything after the prefix
# The remainder of the path (after prefix) is captured as param[0]
# Pattern: /files/**
# Path:    /files/foo/bar/baz  -> captures "foo/bar/baz"
# Path:    /files/             -> captures ""
# Path:    /files              -> captures "" (exact prefix match also allowed)
pub fn route_match_catchall(route: *Route, path: *u8, path_len: i32, result: *RouteMatch) -> i32
    # Handle exact prefix match (e.g., "/api" matches "/api/**")
    # We need to check if path matches prefix without trailing slash
    var prefix_len: i32 = route.pattern_len
    # If pattern ends with '/', also allow matching without it
    if prefix_len > 0 && *(route.pattern + prefix_len - 1) == '/'
        # Pattern has trailing slash, check without it too
        if path_len == prefix_len - 1
            for i in 0..(prefix_len - 1)
                if *(route.pattern + i) != *(path + i)
                    return 0
            # Exact match without trailing slash
            result.param_count = 1
            result.param_starts[0] = path + path_len  # Empty remainder
            result.param_lens[0] = 0
            return 1

    # Path must be at least as long as the prefix
    if path_len < route.pattern_len
        return 0

    # Check that prefix matches
    for i in 0..route.pattern_len
        if *(route.pattern + i) != *(path + i)
            return 0

    # Capture the remainder of the path as param[0]
    let remainder_start: i32 = route.pattern_len
    let remainder_len: i32 = path_len - route.pattern_len

    result.param_count = 1
    result.param_starts[0] = path + remainder_start
    result.param_lens[0] = remainder_len

    return 1


# Parameter match: match pattern with :param segments capturing values
# Pattern: /users/:id/posts/:post_id
# Path:    /users/42/posts/100
# Captures: ["42", "100"]
pub fn route_match_params(route: *Route, path: *u8, path_len: i32, result: *RouteMatch) -> i32
    var pat_pos: i32 = 0
    var path_pos: i32 = 0
    var param_idx: i32 = 0

    result.param_count = 0

    while pat_pos < route.pattern_len && path_pos < path_len
        let pat_c: u8 = *(route.pattern + pat_pos)

        if pat_c == ':'
            # Start of parameter - skip param name in pattern
            pat_pos += 1
            while pat_pos < route.pattern_len
                let c: u8 = *(route.pattern + pat_pos)
                if c == '/'
                    break
                pat_pos += 1

            # Capture value from path until next '/' or end
            let value_start: i32 = path_pos
            while path_pos < path_len
                if *(path + path_pos) == '/'
                    break
                path_pos += 1

            # Store captured parameter
            if param_idx < MAX_PARAMS
                result.param_starts[param_idx] = path + value_start
                result.param_lens[param_idx] = path_pos - value_start
                param_idx += 1
                result.param_count = param_idx
        else
            # Literal character must match
            if *(path + path_pos) != pat_c
                return 0
            pat_pos += 1
            path_pos += 1

    # Both must be fully consumed (or pattern ends with param that consumed rest)
    if pat_pos == route.pattern_len && path_pos == path_len
        return 1

    return 0


# ============================================================================
# Helper: Get captured parameter by index
# ============================================================================

# Copy captured parameter to a buffer
# Returns length copied, or -1 if index out of range
pub fn route_match_get_param(result: *RouteMatch, idx: i32, buf: *u8, buf_len: i32) -> i32
    if idx < 0 || idx >= result.param_count
        return -1

    let len: i32 = result.param_lens[idx]
    if len >= buf_len
        return -1  # Buffer too small

    let src: *u8 = result.param_starts[idx]
    for i in 0..len
        *(buf + i) = *(src + i)
    *(buf + len) = 0  # Null terminate

    return len


# ============================================================================
# Debug: Print router state
# ============================================================================

pub fn router_debug(r: *Router)
    prints("Router: ")
    print_int(r.count as i64)
    prints(" routes, ")
    print_int(r.mw_count as i64)
    prints(" middleware\n")

    # Print middleware
    if r.mw_count > 0
        prints("  Middleware:\n")
        for i in 0..r.mw_count
            let mw: *Middleware = @r.middleware[i]
            prints("    [")
            print_int(i as i64)
            prints("] ")
            if mw.name != null
                prints_cstr(mw.name)
            else
                prints("(anonymous)")
            prints("\n")

    # Print routes
    prints("  Routes:\n")
    for i in 0..r.count
        let route: *Route = @r.routes[i]
        prints("    [")
        print_int(i as i64)
        prints("] ")
        if route.method != null
            prints_cstr(route.method)
        else
            prints("*")
        prints(" ")
        prints_cstr(route.pattern)
        prints(" (")
        if route.route_type == ROUTE_EXACT
            prints("exact")
        else
            if route.route_type == ROUTE_PREFIX
                prints("prefix")
            else
                if route.route_type == ROUTE_CATCHALL
                    prints("catchall")
                else
                    if route.route_type == ROUTE_PARAM
                        prints("param")
                    else
                        prints("unknown")
        if route.param_count > 0
            prints(", params=")
            print_int(route.param_count as i64)
        prints(")\n")
