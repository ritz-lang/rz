# tests/test_config.ritz - Config parsing tests using ritzunit
#
# Tests the configuration module: defaults, JSON parsing, file loading.

import ritzlib.sys
import ritzlib.io
import ritzlib.str
import ritzlib.memory

import lib.config

# ============================================================================
# Helper: Build JSON test strings byte-by-byte
# (Ritz doesn't support escaped quotes in strings yet)
# ============================================================================

# {"server": {"port": 9000}}
fn build_json_port_9000(buf: *u8)
    buf[0] = 123   # {
    buf[1] = 34    # "
    buf[2] = 's'
    buf[3] = 'e'
    buf[4] = 'r'
    buf[5] = 'v'
    buf[6] = 'e'
    buf[7] = 'r'
    buf[8] = 34    # "
    buf[9] = ':'
    buf[10] = ' '
    buf[11] = 123  # {
    buf[12] = 34   # "
    buf[13] = 'p'
    buf[14] = 'o'
    buf[15] = 'r'
    buf[16] = 't'
    buf[17] = 34   # "
    buf[18] = ':'
    buf[19] = ' '
    buf[20] = '9'
    buf[21] = '0'
    buf[22] = '0'
    buf[23] = '0'
    buf[24] = 125  # }
    buf[25] = 125  # }
    buf[26] = 0

# {"server": {"workers": 4}}
fn build_json_workers_4(buf: *u8)
    buf[0] = 123   # {
    buf[1] = 34    # "
    buf[2] = 's'
    buf[3] = 'e'
    buf[4] = 'r'
    buf[5] = 'v'
    buf[6] = 'e'
    buf[7] = 'r'
    buf[8] = 34    # "
    buf[9] = ':'
    buf[10] = 123  # {
    buf[11] = 34   # "
    buf[12] = 'w'
    buf[13] = 'o'
    buf[14] = 'r'
    buf[15] = 'k'
    buf[16] = 'e'
    buf[17] = 'r'
    buf[18] = 's'
    buf[19] = 34   # "
    buf[20] = ':'
    buf[21] = '4'
    buf[22] = 125  # }
    buf[23] = 125  # }
    buf[24] = 0

# ============================================================================
# Default Configuration Tests
# ============================================================================

[[test]]
fn test_config_default_port() -> i32
    var cfg: ValetConfig
    config_default(@cfg)
    if cfg.port != 8080
        return 1  # FAIL: default port should be 8080
    return 0

[[test]]
fn test_config_default_workers() -> i32
    var cfg: ValetConfig
    config_default(@cfg)
    if cfg.workers != 1
        return 1  # FAIL: default workers should be 1
    return 0

[[test]]
fn test_config_default_multishot() -> i32
    var cfg: ValetConfig
    config_default(@cfg)
    if cfg.multishot != 0
        return 1  # FAIL: default multishot should be 0 (disabled)
    return 0

[[test]]
fn test_config_default_backlog() -> i32
    var cfg: ValetConfig
    config_default(@cfg)
    if cfg.backlog != 1024
        return 1  # FAIL: default backlog should be 1024
    return 0

[[test]]
fn test_config_default_keepalive_requests() -> i32
    var cfg: ValetConfig
    config_default(@cfg)
    if cfg.keepalive_requests != 100
        return 1  # FAIL: default keepalive_requests should be 100
    return 0

# ============================================================================
# JSON Parsing Tests
# ============================================================================

[[test]]
fn test_config_parse_json_port() -> i32
    var cfg: ValetConfig
    config_default(@cfg)

    var json: [64]u8
    build_json_port_9000(@json[0])

    let ret: i32 = config_parse_json(@cfg, @json[0], strlen(@json[0]))
    if ret != 0
        return 1  # FAIL: parse should succeed
    if cfg.port != 9000
        return 2  # FAIL: port should be 9000
    return 0

[[test]]
fn test_config_parse_json_workers() -> i32
    var cfg: ValetConfig
    config_default(@cfg)

    var json: [64]u8
    build_json_workers_4(@json[0])

    let ret: i32 = config_parse_json(@cfg, @json[0], strlen(@json[0]))
    if ret != 0
        return 1  # FAIL: parse should succeed
    if cfg.workers != 4
        return 2  # FAIL: workers should be 4
    return 0

[[test]]
fn test_config_parse_json_preserves_defaults() -> i32
    # When parsing JSON that only sets port, other fields should keep defaults
    var cfg: ValetConfig
    config_default(@cfg)

    var json: [64]u8
    build_json_port_9000(@json[0])

    config_parse_json(@cfg, @json[0], strlen(@json[0]))

    # Port should be changed
    if cfg.port != 9000
        return 1
    # But workers should still be default
    if cfg.workers != 1
        return 2
    # And backlog should still be default
    if cfg.backlog != 1024
        return 3
    return 0

# ============================================================================
# File Loading Tests
# ============================================================================

# Build a minimal valid config JSON for file loading test
# {"server":{"port":8080},"limits":{"keepalive_requests":100}}
fn build_test_config_json(buf: *u8) -> i64
    # {"server":{"port":8080},"limits":{"keepalive_requests":100}}
    buf[0] = 123   # {
    buf[1] = 34    # "
    buf[2] = 's'
    buf[3] = 'e'
    buf[4] = 'r'
    buf[5] = 'v'
    buf[6] = 'e'
    buf[7] = 'r'
    buf[8] = 34    # "
    buf[9] = ':'
    buf[10] = 123  # {
    buf[11] = 34   # "
    buf[12] = 'p'
    buf[13] = 'o'
    buf[14] = 'r'
    buf[15] = 't'
    buf[16] = 34   # "
    buf[17] = ':'
    buf[18] = '8'
    buf[19] = '0'
    buf[20] = '8'
    buf[21] = '0'
    buf[22] = 125  # }
    buf[23] = ','
    buf[24] = 34   # "
    buf[25] = 'l'
    buf[26] = 'i'
    buf[27] = 'm'
    buf[28] = 'i'
    buf[29] = 't'
    buf[30] = 's'
    buf[31] = 34   # "
    buf[32] = ':'
    buf[33] = 123  # {
    buf[34] = 34   # "
    buf[35] = 'k'
    buf[36] = 'e'
    buf[37] = 'e'
    buf[38] = 'p'
    buf[39] = 'a'
    buf[40] = 'l'
    buf[41] = 'i'
    buf[42] = 'v'
    buf[43] = 'e'
    buf[44] = '_'
    buf[45] = 'r'
    buf[46] = 'e'
    buf[47] = 'q'
    buf[48] = 'u'
    buf[49] = 'e'
    buf[50] = 's'
    buf[51] = 't'
    buf[52] = 's'
    buf[53] = 34   # "
    buf[54] = ':'
    buf[55] = '1'
    buf[56] = '0'
    buf[57] = '0'
    buf[58] = 125  # }
    buf[59] = 125  # }
    buf[60] = 0
    return 60

[[test]]
fn test_config_load_from_file() -> i32
    # Create a temp test file with known JSON content
    var json_buf: [256]u8
    let json_len: i64 = build_test_config_json(@json_buf[0])

    # Write to temp file - O_WRONLY | O_CREAT | O_TRUNC = 577, mode 0644 = 420
    let fd: i32 = sys_open3(c"/tmp/valet_test_config.json", 577, 420)
    if fd < 0
        return 10  # FAIL: could not create temp file
    let written: i64 = sys_write(fd, @json_buf[0], json_len)
    sys_close(fd)
    if written != json_len
        return 11  # FAIL: write error

    # Now test config_load
    var cfg: ValetConfig
    config_default(@cfg)

    let ret: i32 = config_load(@cfg, c"/tmp/valet_test_config.json")

    # Clean up temp file
    sys_unlink(c"/tmp/valet_test_config.json")

    if ret != 0
        return 1  # FAIL: file load should succeed
    # Our test JSON has port 8080 and keepalive_requests 100
    if cfg.port != 8080
        return 2
    if cfg.keepalive_requests != 100
        return 3
    return 0

[[test]]
fn test_config_load_nonexistent_file() -> i32
    var cfg: ValetConfig
    config_default(@cfg)

    let ret: i32 = config_load(@cfg, c"/nonexistent/file.json")
    if ret == 0
        return 1  # FAIL: loading nonexistent file should fail
    return 0
