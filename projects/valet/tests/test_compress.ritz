# tests/test_compress.ritz - Compression module tests
#
# Tests for Accept-Encoding parsing, MIME type detection, and gzip compression.

import ritzlib.sys
import ritzlib.io
import ritzlib.str
import ritzlib.memory

import lib.compress


# ============================================================================
# Accept-Encoding Parser Tests
# ============================================================================

[[test]]
fn test_accept_encoding_gzip_only() -> i32
    let result: i32 = accept_encoding_parse(c"gzip", 4)
    if (result & ENCODING_GZIP) == 0
        return 1  # FAIL: should include gzip
    return 0

[[test]]
fn test_accept_encoding_deflate_only() -> i32
    let result: i32 = accept_encoding_parse(c"deflate", 7)
    if (result & ENCODING_DEFLATE) == 0
        return 1  # FAIL: should include deflate
    return 0

[[test]]
fn test_accept_encoding_gzip_deflate() -> i32
    let result: i32 = accept_encoding_parse(c"gzip, deflate", 13)
    if (result & ENCODING_GZIP) == 0
        return 1  # FAIL: should include gzip
    if (result & ENCODING_DEFLATE) == 0
        return 2  # FAIL: should include deflate
    return 0

[[test]]
fn test_accept_encoding_with_quality() -> i32
    let result: i32 = accept_encoding_parse(c"gzip;q=1.0, deflate;q=0.5", 25)
    if (result & ENCODING_GZIP) == 0
        return 1  # FAIL: should include gzip
    if (result & ENCODING_DEFLATE) == 0
        return 2  # FAIL: should include deflate
    return 0

[[test]]
fn test_accept_encoding_wildcard() -> i32
    let result: i32 = accept_encoding_parse(c"*", 1)
    if (result & ENCODING_GZIP) == 0
        return 1  # FAIL: wildcard should include gzip
    if (result & ENCODING_DEFLATE) == 0
        return 2  # FAIL: wildcard should include deflate
    return 0

[[test]]
fn test_accept_encoding_identity() -> i32
    let result: i32 = accept_encoding_parse(c"identity", 8)
    if (result & ENCODING_IDENTITY) == 0
        return 1  # FAIL: should include identity
    return 0

[[test]]
fn test_accept_encoding_case_insensitive() -> i32
    let result: i32 = accept_encoding_parse(c"GZIP", 4)
    if (result & ENCODING_GZIP) == 0
        return 1  # FAIL: should match case-insensitively
    return 0

[[test]]
fn test_accept_encoding_null() -> i32
    let result: i32 = accept_encoding_parse(null, 0)
    if (result & ENCODING_IDENTITY) == 0
        return 1  # FAIL: null should default to identity
    return 0

[[test]]
fn test_accept_encoding_complex() -> i32
    # Real-world Chrome header: "gzip, deflate, br, zstd"
    let result: i32 = accept_encoding_parse(c"gzip, deflate, br, zstd", 23)
    if (result & ENCODING_GZIP) == 0
        return 1  # FAIL: should include gzip
    if (result & ENCODING_DEFLATE) == 0
        return 2  # FAIL: should include deflate
    # br and zstd not supported yet, that's fine
    return 0


# ============================================================================
# Encoding Selection Tests
# ============================================================================

[[test]]
fn test_encoding_select_prefers_gzip() -> i32
    let accepted: i32 = ENCODING_GZIP | ENCODING_DEFLATE
    let selected: i32 = encoding_select(accepted)
    if selected != ENCODING_GZIP
        return 1  # FAIL: should prefer gzip
    return 0

[[test]]
fn test_encoding_select_deflate_fallback() -> i32
    let accepted: i32 = ENCODING_DEFLATE | ENCODING_IDENTITY
    let selected: i32 = encoding_select(accepted)
    if selected != ENCODING_DEFLATE
        return 1  # FAIL: should select deflate when gzip not available
    return 0

[[test]]
fn test_encoding_select_identity_only() -> i32
    let accepted: i32 = ENCODING_IDENTITY
    let selected: i32 = encoding_select(accepted)
    if selected != ENCODING_IDENTITY
        return 1  # FAIL: should select identity
    return 0


