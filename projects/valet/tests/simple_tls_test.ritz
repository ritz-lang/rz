import ritzlib.sys
import ritzlib.io

# DON'T import cryptosec.mem directly - let it come through lib.tls
import lib.tls

[[test]]
fn test_no_direct_mem() -> i32
    prints("Creating config...\n")
    var cfg: TlsServerConfig
    tls_server_config_init(@cfg)
    prints("Config done\n")
    
    prints("Creating server...\n")
    var server: TlsServer
    prints("Server created\n")
    
    prints("Calling tls_server_init...\n")
    tls_server_init(@server, @cfg)
    prints("Init done!\n")
    
    0
