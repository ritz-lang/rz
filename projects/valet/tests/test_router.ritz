    var result: RouteMatch
    let matched: i32 = router_match(@r, c"GET", c"/api/", 5, @result)
    if matched != 1
        return 1  # FAIL: /api/ should match /api/**
    return 0


# ============================================================================
# Per-Route Interceptor Tests
# ============================================================================

# Global test counter for interceptor verification
var g_before_count: i32 = 0
var g_after_count: i32 = 0
var g_before_order: [4]i32
var g_after_order: [4]i32

fn reset_interceptor_counts()
    g_before_count = 0
    g_after_count = 0

fn before_interceptor_1(path: *u8, path_len: i32) -> i32
    g_before_order[g_before_count] = 1
    g_before_count += 1
    return MW_CONTINUE

fn before_interceptor_2(path: *u8, path_len: i32) -> i32
    g_before_order[g_before_count] = 2
    g_before_count += 1
    return MW_CONTINUE

fn before_interceptor_halt(path: *u8, path_len: i32) -> i32
    g_before_count += 1
    return MW_HANDLED  # Stop further processing

fn after_interceptor_1(path: *u8, path_len: i32) -> i32
    g_after_order[g_after_count] = 1
    g_after_count += 1
    return MW_CONTINUE

fn after_interceptor_2(path: *u8, path_len: i32) -> i32
    g_after_order[g_after_count] = 2
    g_after_count += 1
    return MW_CONTINUE


[[test]]
fn test_route_before_interceptor_runs() -> i32
    reset_interceptor_counts()
    var r: Router
    router_init(@r)
    router_add(@r, c"GET", c"/test", handler_index)
    router_route_before(@r, before_interceptor_1)

    var result: RouteMatch
    let matched: i32 = router_match(@r, c"GET", c"/test", 5, @result)
    if matched != 1
        return 1  # FAIL: should match

    # Run the before interceptor
    let ret: i32 = route_run_before(result.route, c"/test", 5)
    if ret != MW_CONTINUE
        return 2  # FAIL: should return CONTINUE
    if g_before_count != 1
        return 3  # FAIL: before interceptor should have run once
    return 0


[[test]]
fn test_route_before_interceptor_order() -> i32
    reset_interceptor_counts()
    var r: Router
    router_init(@r)
    router_add(@r, c"GET", c"/test", handler_index)
    router_route_before(@r, before_interceptor_1)
    router_route_before(@r, before_interceptor_2)

    var result: RouteMatch
    router_match(@r, c"GET", c"/test", 5, @result)

    route_run_before(result.route, c"/test", 5)
    if g_before_count != 2
        return 1  # FAIL: both interceptors should run
    if g_before_order[0] != 1
        return 2  # FAIL: first registered should run first
    if g_before_order[1] != 2
        return 3  # FAIL: second registered should run second
    return 0


[[test]]
fn test_route_before_interceptor_halt() -> i32
    reset_interceptor_counts()
    var r: Router
    router_init(@r)
    router_add(@r, c"GET", c"/test", handler_index)
    router_route_before(@r, before_interceptor_halt)
    router_route_before(@r, before_interceptor_1)  # Should not run

    var result: RouteMatch
    router_match(@r, c"GET", c"/test", 5, @result)

    let ret: i32 = route_run_before(result.route, c"/test", 5)
    if ret != MW_HANDLED
        return 1  # FAIL: should return HANDLED
    if g_before_count != 1
        return 2  # FAIL: only first interceptor should run
    return 0


[[test]]
fn test_route_after_interceptor_runs() -> i32
    reset_interceptor_counts()
    var r: Router
    router_init(@r)
    router_add(@r, c"GET", c"/test", handler_index)
    router_route_after(@r, after_interceptor_1)

    var result: RouteMatch
    router_match(@r, c"GET", c"/test", 5, @result)

    route_run_after(result.route, c"/test", 5)
    if g_after_count != 1
        return 1  # FAIL: after interceptor should have run
    return 0


[[test]]
fn test_route_after_interceptor_reverse_order() -> i32
    reset_interceptor_counts()
    var r: Router
    router_init(@r)
    router_add(@r, c"GET", c"/test", handler_index)
    router_route_after(@r, after_interceptor_1)  # Registered first, runs second
    router_route_after(@r, after_interceptor_2)  # Registered second, runs first

    var result: RouteMatch
    router_match(@r, c"GET", c"/test", 5, @result)

    route_run_after(result.route, c"/test", 5)
    if g_after_count != 2
        return 1  # FAIL: both should run
    if g_after_order[0] != 2
        return 2  # FAIL: second registered should run first (reverse order)
    if g_after_order[1] != 1
        return 3  # FAIL: first registered should run last
    return 0


[[test]]
fn test_route_interceptors_only_on_matching_route() -> i32
    reset_interceptor_counts()
    var r: Router
    router_init(@r)
    router_add(@r, c"GET", c"/test", handler_index)
    router_route_before(@r, before_interceptor_1)  # Only for /test
    router_add(@r, c"GET", c"/other", handler_users)  # No interceptors

    var result: RouteMatch

    # Match /other - should have no interceptors
    router_match(@r, c"GET", c"/other", 6, @result)
    route_run_before(result.route, c"/other", 6)
    if g_before_count != 0
        return 1  # FAIL: /other route has no interceptors

    # Match /test - should have interceptor
    router_match(@r, c"GET", c"/test", 5, @result)
    route_run_before(result.route, c"/test", 5)
    if g_before_count != 1
        return 2  # FAIL: /test route should have interceptor
    return 0
