# tests/test_router.ritz - Unit tests for router
#
# Tests the routing framework with various patterns using ritzunit.
# Each test function is marked with @test and returns 0 on pass, non-zero on fail.

import ritzlib.io
import ritzlib.str
import ritzlib.sys

import lib.router

# ============================================================================
# Test handlers (just return 200)
# ============================================================================

fn handler_index(path: *u8, path_len: i32) -> i32
    return 200

fn handler_users(path: *u8, path_len: i32) -> i32
    return 200

fn handler_static(path: *u8, path_len: i32) -> i32
    return 200

fn handler_user_by_id(path: *u8, path_len: i32) -> i32
    return 200

fn handler_post(path: *u8, path_len: i32) -> i32
    return 200

fn handler_catchall(path: *u8, path_len: i32) -> i32
    return 200

# ============================================================================
# Helper: Create a router with standard routes
# ============================================================================

fn setup_router(r: *Router)
    router_init(r)
    router_add(r, c"GET", c"/", handler_index)
    router_add(r, c"GET", c"/users", handler_users)
    router_add(r, c"GET", c"/static/*", handler_static)
    router_add(r, c"GET", c"/users/:id", handler_user_by_id)
    router_add(r, c"GET", c"/users/:id/posts/:post_id", handler_post)
    router_add(r, null, c"/any-method", handler_index)
    router_add(r, c"GET", c"/api/**", handler_catchall)

# ============================================================================
# Exact Match Tests
# ============================================================================

[[test]]
fn test_router_exact_root_match() -> i32
    var r: Router
    setup_router(@r)
    var result: RouteMatch
    let matched: i32 = router_match(@r, c"GET", c"/", 1, @result)
    if matched != 1
        return 1  # FAIL: root path should match
    return 0

[[test]]
fn test_router_exact_users_match() -> i32
    var r: Router
    setup_router(@r)
    var result: RouteMatch
    let matched: i32 = router_match(@r, c"GET", c"/users", 6, @result)
    if matched != 1
        return 1  # FAIL: /users should match
    return 0

[[test]]
fn test_router_no_match_unknown_path() -> i32
    var r: Router
    setup_router(@r)
    var result: RouteMatch
    let matched: i32 = router_match(@r, c"GET", c"/notfound", 9, @result)
    if matched != 0
        return 1  # FAIL: unknown path should not match
    return 0

[[test]]
fn test_router_no_match_wrong_method() -> i32
    var r: Router
    setup_router(@r)
    var result: RouteMatch
    let matched: i32 = router_match(@r, c"POST", c"/users", 6, @result)
    if matched != 0
        return 1  # FAIL: POST /users should not match (only GET registered)
    return 0

# ============================================================================
# Prefix/Wildcard Match Tests
# ============================================================================

[[test]]
fn test_router_prefix_single_level() -> i32
    var r: Router
    setup_router(@r)
    var result: RouteMatch
    let matched: i32 = router_match(@r, c"GET", c"/static/foo.js", 14, @result)
    if matched != 1
        return 1  # FAIL: /static/foo.js should match /static/*
    return 0

[[test]]
fn test_router_prefix_nested_path() -> i32
    var r: Router
    setup_router(@r)
    var result: RouteMatch
    let matched: i32 = router_match(@r, c"GET", c"/static/css/style.css", 21, @result)
    if matched != 1
        return 1  # FAIL: /static/css/style.css should match /static/*
    return 0

[[test]]
fn test_router_prefix_no_trailing() -> i32
    var r: Router
    setup_router(@r)
    var result: RouteMatch
    let matched: i32 = router_match(@r, c"GET", c"/static", 7, @result)
    if matched != 0
        return 1  # FAIL: /static without trailing content should not match /static/*
    return 0

# ============================================================================
# Parameter Match Tests
# ============================================================================

[[test]]
fn test_router_param_numeric() -> i32
    var r: Router
    setup_router(@r)
    var result: RouteMatch
    let matched: i32 = router_match(@r, c"GET", c"/users/42", 9, @result)
    if matched != 1
        return 1  # FAIL: /users/42 should match /users/:id
    return 0

[[test]]
fn test_router_param_alpha() -> i32
    var r: Router
    setup_router(@r)
    var result: RouteMatch
    let matched: i32 = router_match(@r, c"GET", c"/users/abc", 10, @result)
    if matched != 1
        return 1  # FAIL: /users/abc should match /users/:id
    return 0

[[test]]
fn test_router_multi_param() -> i32
    var r: Router
    setup_router(@r)
    var result: RouteMatch
    let matched: i32 = router_match(@r, c"GET", c"/users/42/posts/100", 19, @result)
    if matched != 1
        return 1  # FAIL: /users/42/posts/100 should match /users/:id/posts/:post_id
    return 0

# ============================================================================
# Parameter Extraction Tests
# ============================================================================

[[test]]
fn test_router_param_extraction_single() -> i32
    var r: Router
    setup_router(@r)
    var result: RouteMatch
    router_match(@r, c"GET", c"/users/42", 9, @result)

    var buf: [256]u8
    let len: i32 = route_match_get_param(@result, 0, @buf[0], 256)
    if len < 0
        return 1  # FAIL: should have param
    if streq(@buf[0], c"42") == 0
        return 2  # FAIL: param should be "42"
    return 0

[[test]]
fn test_router_param_extraction_multi() -> i32
    var r: Router
    setup_router(@r)
    var result: RouteMatch
    router_match(@r, c"GET", c"/users/alice/posts/999", 22, @result)

    var buf1: [256]u8
    var buf2: [256]u8
    route_match_get_param(@result, 0, @buf1[0], 256)
    route_match_get_param(@result, 1, @buf2[0], 256)

    if streq(@buf1[0], c"alice") == 0
        return 1  # FAIL: first param should be "alice"
    if streq(@buf2[0], c"999") == 0
        return 2  # FAIL: second param should be "999"
    return 0

