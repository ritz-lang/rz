{
  "server": {
    "port": 8080,
    "workers": 1,
    "multishot": false,
    "use_send_zc": false,
    "backlog": 1024
  },
  "limits": {
    "max_connections": 10000,
    "max_request_size": 1048576,
    "keepalive_requests": 100,
    "idle_timeout": 60
  },
  "static": {
    "prefix": "/static/",
    "root": "./public"
  },
  "tls": {
    "enabled": false,
    "cert": "/etc/valet/cert.pem",
    "key": "/etc/valet/key.pem"
  }
}
