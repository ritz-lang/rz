# test/test_tls_server.ritz - Test TlsServer init

import ritzlib.sys
import ritzlib.io
import valet.tls
import cryptosec.mem

fn main() -> i32
    prints("Testing TlsServer init...\n")

    # First, load certificates like in test_tls_load
    let cert_path: StrView = "test/certs/fullchain.pem"
    let key_path: StrView = "test/certs/privkey.pem"

    # Read certificate file
    var cert_buf: [16384]u8
    let cert_fd: i32 = open(cert_path.ptr, 0, 0)
    if cert_fd < 0
        prints("ERROR: Failed to open certificate file\n")
        return 1
    let cert_len: i64 = read(cert_fd, @cert_buf[0], 16384)
    close(cert_fd)

    # Read private key file
    var key_buf: [1024]u8
    let key_fd: i32 = open(key_path.ptr, 0, 0)
    if key_fd < 0
        prints("ERROR: Failed to open key file\n")
        return 1
    let key_len: i64 = read(key_fd, @key_buf[0], 1024)
    close(key_fd)

    # Initialize TLS config
    var cfg: TlsServerConfig
    tls_server_config_init(@cfg)

    var der_buf: [8192]u8
    let cert_result: i32 = tls_server_config_load_cert(@cfg, @cert_buf[0], cert_len, @der_buf[0], 8192)
    if cert_result != 0
        prints("ERROR: Failed to load certificate chain\n")
        return 1

    let key_result: i32 = tls_server_config_load_ecdsa_p256_key(@cfg, @key_buf[0], key_len)
    if key_result != 0
        prints("ERROR: Failed to load ECDSA P-256 private key\n")
        return 1

    prints("Config loaded, now testing TlsServer init...\n")

    # Allocate TlsServer via mmap (like valet does)
    let size: i64 = 40960
    let flags: i32 = 0x02 | 0x20  # MAP_PRIVATE | MAP_ANONYMOUS
    let prot: i32 = 0x01 | 0x02   # PROT_READ | PROT_WRITE
    let ptr: *u8 = sys_mmap(0, size, prot, flags, -1, 0)
    if (ptr as i64) < 0
        prints("ERROR: mmap failed\n")
        return 1

    prints("mmap succeeded, ptr = ")
    print_hex64(ptr as u64)
    prints("\n")

    # Cast to TlsServer
    let server: *TlsServer = ptr as *TlsServer

    prints("Calling tls_server_init...\n")
    tls_server_init(server, @cfg)

    prints("TlsServer init complete!\n")
    prints("Server state: ")
    print_i64(server.state as i64)
    prints("\n")

    # Clean up
    tls_server_free(server)
    sys_munmap(ptr, size)

    prints("Test passed!\n")
    return 0
