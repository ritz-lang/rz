# Test HMAC - Minimal copy of test_hmac to debug

import ritzlib.sys
import ritzlib.io
import cryptosec.hmac
import cryptosec.hkdf
import cryptosec.mem

fn main(argc: i32, argv: **u8) -> i32
    prints("Testing HMAC-SHA256...\n")

    # Test data
    var key: [32]u8
    var data: [64]u8
    var out: [32]u8

    # Zero key and data
    mem_zero(@key[0], 32)
    mem_zero(@data[0], 64)

    prints("Calling hmac_sha256...\n")
    hmac_sha256(@key[0], 32, @data[0], 64, @out[0])

    prints("HMAC complete!\n")
    prints("First bytes: ")
    print_hex64(out[0] as u64)
    prints(" ")
    print_hex64(out[1] as u64)
    prints(" ")
    print_hex64(out[2] as u64)
    prints(" ")
    print_hex64(out[3] as u64)
    prints("\n")

    return 0

fn print_hex_bytes(data: *u8, len: i32)
    for i in 0..len
        let b: u8 = data[i]
        prints("0x")
        print_i64((b as i64) & 0xff)
        prints(" ")
