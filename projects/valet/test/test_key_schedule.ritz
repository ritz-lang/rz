# test/test_key_schedule.ritz - Test TLS 1.3 key schedule init

import ritzlib.sys
import ritzlib.io
import cryptosec.tls13_kdf
import cryptosec.mem

fn main() -> i32
    prints("Testing TLS 1.3 key schedule init...\n")

    # Allocate key schedule on stack (like HMAC test)
    var ks: TLS13KeySchedule

    prints("Calling tls13_key_schedule_init...\n")
    tls13_key_schedule_init(@ks)

    prints("Key schedule init complete!\n")
    prints("Early secret first bytes: ")
    print_hex64(ks.early_secret[0] as u64)
    prints(" ")
    print_hex64(ks.early_secret[1] as u64)
    prints(" ")
    print_hex64(ks.early_secret[2] as u64)
    prints(" ")
    print_hex64(ks.early_secret[3] as u64)
    prints("\n")

    return 0
