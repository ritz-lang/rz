# test/test_tls_load.ritz - Test TLS certificate and key loading
#
# Quick test to verify ECDSA P-256 key loading from Let's Encrypt certs

import ritzlib.sys
import ritzlib.io
import valet.tls

fn main() -> i32
    prints("Testing TLS certificate and key loading...\n")

    # Load the test certificates
    let cert_path: StrView = "test/certs/fullchain.pem"
    let key_path: StrView = "test/certs/privkey.pem"

    # Read certificate file
    var cert_buf: [16384]u8
    let cert_fd: i32 = open(cert_path.ptr, 0, 0)  # O_RDONLY
    if cert_fd < 0
        prints("ERROR: Failed to open certificate file\n")
        return 1

    let cert_len: i64 = read(cert_fd, @cert_buf[0], 16384)
    close(cert_fd)

    if cert_len <= 0
        prints("ERROR: Failed to read certificate file\n")
        return 1

    prints("Read certificate: ")
    print_i64(cert_len)
    prints(" bytes\n")

    # Read private key file
    var key_buf: [1024]u8
    let key_fd: i32 = open(key_path.ptr, 0, 0)
    if key_fd < 0
        prints("ERROR: Failed to open key file\n")
        return 1

    let key_len: i64 = read(key_fd, @key_buf[0], 1024)
    close(key_fd)

    if key_len <= 0
        prints("ERROR: Failed to read key file\n")
        return 1

    prints("Read private key: ")
    print_i64(key_len)
    prints(" bytes\n")

    # Initialize TLS config
    var cfg: TlsServerConfig
    tls_server_config_init(@cfg)

    # Load certificate chain
    var der_buf: [8192]u8
    let cert_result: i32 = tls_server_config_load_cert(@cfg, @cert_buf[0], cert_len, @der_buf[0], 8192)

    if cert_result != 0
        prints("ERROR: Failed to load certificate chain\n")
        return 1

    prints("Loaded ")
    print_i64(cfg.num_certs as i64)
    prints(" certificate(s), total DER: ")
    print_i64(cfg.cert_chain_len)
    prints(" bytes\n")

    # Load ECDSA P-256 private key
    let key_result: i32 = tls_server_config_load_ecdsa_p256_key(@cfg, @key_buf[0], key_len)

    if key_result != 0
        prints("ERROR: Failed to load ECDSA P-256 private key\n")
        return 1

    prints("Successfully loaded ECDSA P-256 private key\n")
    prints("Key type: ")
    print_i64(cfg.key_type as i64)
    prints(" (expected 2 for ECDSA_P256)\n")

    # Verify key type is ECDSA P-256
    if cfg.key_type != TLS_KEY_TYPE_ECDSA_P256
        prints("ERROR: Wrong key type loaded\n")
        return 1

    # Print first few bytes of private key (for debugging)
    prints("Private key first 4 bytes: ")
    print_hex64(cfg.ecdsa_p256_private[0] as u64)
    prints(" ")
    print_hex64(cfg.ecdsa_p256_private[1] as u64)
    prints(" ")
    print_hex64(cfg.ecdsa_p256_private[2] as u64)
    prints(" ")
    print_hex64(cfg.ecdsa_p256_private[3] as u64)
    prints("\n")

    prints("\nAll TLS loading tests passed!\n")
    return 0
