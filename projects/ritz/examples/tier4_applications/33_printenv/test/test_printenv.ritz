# Tests for 33_printenv — print env variable values.
import ritzlib.sys
import ritzlib.testlib

[[test]]
fn test_printenv_single_var() -> i32
    var argv: [3]*u8
    argv[0] = c"./printenv"
    argv[1] = c"HOME"
    argv[2] = null

    var envp: [3]*u8
    envp[0] = c"HOME=/test_home"
    envp[1] = c"USER=tester"
    envp[2] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./printenv", @argv[0], @envp[0], null, 0, @out[0], 1024, @n)

    assert exit_code == 0, "printenv HOME should exit 0"
    assert n == 11, "expected 11 bytes (/test_home\\n)"
    assert buf_eq(@out[0], c"/test_home\n", 11) == 1, "output mismatch"
    0

[[test]]
fn test_printenv_multiple_vars() -> i32
    var argv: [4]*u8
    argv[0] = c"./printenv"
    argv[1] = c"HOME"
    argv[2] = c"USER"
    argv[3] = null

    var envp: [3]*u8
    envp[0] = c"HOME=/h"
    envp[1] = c"USER=u"
    envp[2] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./printenv", @argv[0], @envp[0], null, 0, @out[0], 1024, @n)

    assert exit_code == 0, "printenv HOME USER should exit 0"
    assert buf_eq(@out[0], c"/h\nu\n", 5) == 1, "output mismatch"
    0

[[test]]
fn test_printenv_missing_var() -> i32
    var argv: [3]*u8
    argv[0] = c"./printenv"
    argv[1] = c"NONEXISTENT_XYZ"
    argv[2] = null

    var envp: [2]*u8
    envp[0] = c"PATH=/usr/bin"
    envp[1] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./printenv", @argv[0], @envp[0], null, 0, @out[0], 1024, @n)

    assert exit_code != 0, "missing var should exit non-zero"
    0

[[test]]
fn test_printenv_no_args_prints_all() -> i32
    var argv: [2]*u8
    argv[0] = c"./printenv"
    argv[1] = null

    var envp: [3]*u8
    envp[0] = c"X=1"
    envp[1] = c"Y=2"
    envp[2] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./printenv", @argv[0], @envp[0], null, 0, @out[0], 1024, @n)

    assert exit_code == 0, "printenv (no args) should exit 0"
    assert buf_contains(@out[0], n, c"X=1", 3) == 1, "missing X=1"
    assert buf_contains(@out[0], n, c"Y=2", 3) == 1, "missing Y=2"
    0
