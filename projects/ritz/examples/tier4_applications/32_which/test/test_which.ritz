# Tests for 32_which — find executables in PATH.
import ritzlib.sys
import ritzlib.testlib

[[test]]
fn test_which_finds_in_usr_bin() -> i32
    var argv: [3]*u8
    argv[0] = c"./which"
    argv[1] = c"true"
    argv[2] = null

    var envp: [2]*u8
    envp[0] = c"PATH=/usr/bin:/bin"
    envp[1] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./which", @argv[0], @envp[0], null, 0, @out[0], 1024, @n)

    assert exit_code == 0, "which true should exit 0"
    let found_usr: i32 = buf_contains(@out[0], n, c"/usr/bin/true", 13)
    let found_bin: i32 = buf_contains(@out[0], n, c"/bin/true", 9)
    assert found_usr == 1 || found_bin == 1, "expected path to true"
    0

[[test]]
fn test_which_not_found() -> i32
    var argv: [3]*u8
    argv[0] = c"./which"
    argv[1] = c"nonexistent_xyz_definitely_not_there"
    argv[2] = null

    var envp: [2]*u8
    envp[0] = c"PATH=/usr/bin:/bin"
    envp[1] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./which", @argv[0], @envp[0], null, 0, @out[0], 1024, @n)

    assert exit_code != 0, "which nonexistent should exit non-zero"
    0

[[test]]
fn test_which_empty_path_fails() -> i32
    var argv: [3]*u8
    argv[0] = c"./which"
    argv[1] = c"true"
    argv[2] = null

    var envp: [2]*u8
    envp[0] = c"PATH=/no_such_directory_xyzzy"
    envp[1] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./which", @argv[0], @envp[0], null, 0, @out[0], 1024, @n)

    assert exit_code != 0, "empty PATH should fail to find"
    0
