# Tests for 31_env - print environment variables
#
# Integration tests fork+exec ./env with a controlled envp.

import ritzlib.sys
import ritzlib.io
import ritzlib.str

fn buf_eq(a: *u8, b: *u8, len: i64) -> i32
    var i: i64 = 0
    while i < len
        if *(a + i) != *(b + i)
            return 0
        i += 1
    return 1

fn buf_contains(hay: *u8, hay_len: i64, needle: *u8, needle_len: i64) -> i32
    if needle_len == 0
        return 1
    if needle_len > hay_len
        return 0
    var i: i64 = 0
    while i <= hay_len - needle_len
        if buf_eq(hay + i, needle, needle_len) == 1
            return 1
        i += 1
    return 0

fn cstr_len(s: *u8) -> i64
    var n: i64 = 0
    while *(s + n) != 0
        n += 1
    return n

# Run ./env with controlled envp; capture stdout.
fn env_exec(argv: **u8, envp: **u8, out_buf: *u8, out_len: *i64) -> i32
    var stdout_pipe: [2]i32
    if sys_pipe(@stdout_pipe[0]) < 0
        return -1
    let pid: i32 = sys_fork()
    if pid < 0
        sys_close(stdout_pipe[0])
        sys_close(stdout_pipe[1])
        return -2
    if pid == 0
        sys_dup2(stdout_pipe[1], 1)
        sys_dup2(stdout_pipe[1], 2)
        sys_close(stdout_pipe[0])
        sys_close(stdout_pipe[1])
        sys_execve(c"./env", argv, envp)
        sys_exit(127)
    sys_close(stdout_pipe[1])
    var total: i64 = 0
    while total < 4096
        let r: i64 = sys_read(stdout_pipe[0], out_buf + total, 4096 - total)
        if r <= 0
            break
        total += r
    sys_close(stdout_pipe[0])
    *out_len = total
    var status: i32 = 0
    sys_wait4(pid, @status, 0, null)
    return (status >> 8) & 0xFF

[[test]]
fn test_env_prints_provided_vars() -> i32
    var argv: [2]*u8
    argv[0] = c"./env"
    argv[1] = null

    var envp: [4]*u8
    envp[0] = c"FOO=bar"
    envp[1] = c"BAZ=qux"
    envp[2] = c"NAME=ritz"
    envp[3] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = env_exec(@argv[0], @envp[0], @out[0], @n)

    assert exit_code == 0, c"env should exit 0"
    assert buf_contains(@out[0], n, c"FOO=bar", 7) == 1, c"missing FOO=bar"
    assert buf_contains(@out[0], n, c"BAZ=qux", 7) == 1, c"missing BAZ=qux"
    assert buf_contains(@out[0], n, c"NAME=ritz", 9) == 1, c"missing NAME=ritz"
    0

[[test]]
fn test_env_empty_envp() -> i32
    # With empty envp, env should produce no output (or near-empty).
    var argv: [2]*u8
    argv[0] = c"./env"
    argv[1] = null

    var envp: [1]*u8
    envp[0] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = env_exec(@argv[0], @envp[0], @out[0], @n)

    assert exit_code == 0, c"env empty should exit 0"
    # Empty envp => no env vars to print.  Allow minor stderr noise but
    # the output should be empty or whitespace.
    assert n == 0, c"expected empty output with empty envp"
    0

[[test]]
fn test_env_output_format() -> i32
    # All output lines should contain '='
    var argv: [2]*u8
    argv[0] = c"./env"
    argv[1] = null

    var envp: [3]*u8
    envp[0] = c"A=1"
    envp[1] = c"B=2"
    envp[2] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = env_exec(@argv[0], @envp[0], @out[0], @n)

    assert exit_code == 0, c"env should exit 0"
    # Count '=' signs — should match line count
    var equals: i64 = 0
    var newlines: i64 = 0
    var i: i64 = 0
    while i < n
        let c: u8 = *(@out[0] + i)
        if c == ('=' as u8)
            equals += 1
        if c == 10  # \n
            newlines += 1
        i += 1
    assert equals == 2, c"expected 2 '=' signs"
    assert newlines == 2, c"expected 2 newlines"
    0
