# Tests for 31_env — print environment variables.
import ritzlib.sys
import ritzlib.testlib

[[test]]
fn test_env_prints_provided_vars() -> i32
    var argv: [2]*u8
    argv[0] = c"./env"
    argv[1] = null

    var envp: [4]*u8
    envp[0] = c"FOO=bar"
    envp[1] = c"BAZ=qux"
    envp[2] = c"NAME=ritz"
    envp[3] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./env", @argv[0], @envp[0], null, 0, @out[0], 4096, @n)

    assert exit_code == 0, "env should exit 0"
    assert buf_contains(@out[0], n, c"FOO=bar", 7) == 1, "missing FOO=bar"
    assert buf_contains(@out[0], n, c"BAZ=qux", 7) == 1, "missing BAZ=qux"
    assert buf_contains(@out[0], n, c"NAME=ritz", 9) == 1, "missing NAME=ritz"
    0

[[test]]
fn test_env_empty_envp() -> i32
    var argv: [2]*u8
    argv[0] = c"./env"
    argv[1] = null

    var envp: [1]*u8
    envp[0] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./env", @argv[0], @envp[0], null, 0, @out[0], 4096, @n)

    assert exit_code == 0, "env empty should exit 0"
    assert n == 0, "expected empty output with empty envp"
    0

[[test]]
fn test_env_output_format() -> i32
    var argv: [2]*u8
    argv[0] = c"./env"
    argv[1] = null

    var envp: [3]*u8
    envp[0] = c"A=1"
    envp[1] = c"B=2"
    envp[2] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./env", @argv[0], @envp[0], null, 0, @out[0], 4096, @n)

    assert exit_code == 0, "env should exit 0"
    var equals: i64 = 0
    var newlines: i64 = 0
    var i: i64 = 0
    while i < n
        let c: u8 = *(@out[0] + i)
        if c == ('=' as u8)
            equals += 1
        if c == 10
            newlines += 1
        i += 1
    assert equals == 2, "expected 2 '=' signs"
    assert newlines == 2, "expected 2 newlines"
    0
