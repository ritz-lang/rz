# Tests for 38_tee — read from stdin, write to stdout and files.
#
# Helpers (exec_capture, make_sandbox_path, read_file, buf_eq) live in
# ritzlib.testlib; see docs/TESTING.md.

import ritzlib.sys
import ritzlib.testlib

[[test]]
fn test_tee_single_file() -> i32
    var path: [128]u8
    make_sandbox_path(@path[0], c"tee", c"single")
    sys_unlink(@path[0])

    var argv: [3]*u8
    argv[0] = c"./tee"
    argv[1] = @path[0]
    argv[2] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./tee", @argv[0], null, c"hello", 5, @out[0], 1024, @n)

    var rd_buf: [64]u8
    let rd: i64 = read_file(@path[0], @rd_buf[0], 64)
    sys_unlink(@path[0])

    assert exit_code == 0, "tee single should exit 0"
    assert n == 5, "stdout should be 5 bytes"
    assert buf_eq(@out[0], c"hello", 5) == 1, "stdout mismatch"
    assert rd == 5, "file should be 5 bytes"
    assert buf_eq(@rd_buf[0], c"hello", 5) == 1, "file content mismatch"
    0

[[test]]
fn test_tee_multiple_files() -> i32
    var p1: [128]u8
    var p2: [128]u8
    make_sandbox_path(@p1[0], c"tee", c"a")
    make_sandbox_path(@p2[0], c"tee", c"b")
    sys_unlink(@p1[0])
    sys_unlink(@p2[0])

    var argv: [4]*u8
    argv[0] = c"./tee"
    argv[1] = @p1[0]
    argv[2] = @p2[0]
    argv[3] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./tee", @argv[0], null, c"world", 5, @out[0], 1024, @n)

    var b1: [64]u8
    var b2: [64]u8
    let r1: i64 = read_file(@p1[0], @b1[0], 64)
    let r2: i64 = read_file(@p2[0], @b2[0], 64)
    sys_unlink(@p1[0])
    sys_unlink(@p2[0])

    assert exit_code == 0, "tee multi should exit 0"
    assert n == 5, "stdout 5 bytes"
    assert r1 == 5, "file 1 should have 5 bytes"
    assert buf_eq(@b1[0], c"world", 5) == 1, "file 1 content mismatch"
    assert r2 == 5, "file 2 should have 5 bytes"
    assert buf_eq(@b2[0], c"world", 5) == 1, "file 2 content mismatch"
    0

[[test]]
fn test_tee_overwrite_default() -> i32
    var path: [128]u8
    make_sandbox_path(@path[0], c"tee", c"ow")
    sys_unlink(@path[0])

    var argv1: [3]*u8
    argv1[0] = c"./tee"
    argv1[1] = @path[0]
    argv1[2] = null
    var out: [1024]u8
    var n: i64 = 0
    exec_capture(c"./tee", @argv1[0], null, c"first", 5, @out[0], 1024, @n)

    let exit_code: i32 = exec_capture(c"./tee", @argv1[0], null, c"second", 6, @out[0], 1024, @n)

    var rd_buf: [64]u8
    let rd: i64 = read_file(@path[0], @rd_buf[0], 64)
    sys_unlink(@path[0])

    assert exit_code == 0, "second tee should exit 0"
    assert rd == 6, "file should be 6 bytes after overwrite"
    assert buf_eq(@rd_buf[0], c"second", 6) == 1, "file should contain 'second'"
    0

[[test]]
fn test_tee_append_flag() -> i32
    var path: [128]u8
    make_sandbox_path(@path[0], c"tee", c"ap")
    sys_unlink(@path[0])

    var argv1: [3]*u8
    argv1[0] = c"./tee"
    argv1[1] = @path[0]
    argv1[2] = null
    var out: [1024]u8
    var n: i64 = 0
    exec_capture(c"./tee", @argv1[0], null, c"line1\n", 6, @out[0], 1024, @n)

    var argv2: [4]*u8
    argv2[0] = c"./tee"
    argv2[1] = c"-a"
    argv2[2] = @path[0]
    argv2[3] = null
    let exit_code: i32 = exec_capture(c"./tee", @argv2[0], null, c"line2\n", 6, @out[0], 1024, @n)

    var rd_buf: [64]u8
    let rd: i64 = read_file(@path[0], @rd_buf[0], 64)
    sys_unlink(@path[0])

    assert exit_code == 0, "tee -a should exit 0"
    assert rd == 12, "file should have 12 bytes after append"
    assert buf_eq(@rd_buf[0], c"line1\nline2\n", 12) == 1, "appended content mismatch"
    0

[[test]]
fn test_tee_no_files_passthrough() -> i32
    var argv: [2]*u8
    argv[0] = c"./tee"
    argv[1] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./tee", @argv[0], null, c"passthrough", 11, @out[0], 1024, @n)

    assert exit_code == 0, "tee should exit 0"
    assert n == 11, "stdout should be 11 bytes"
    assert buf_eq(@out[0], c"passthrough", 11) == 1, "passthrough mismatch"
    0
