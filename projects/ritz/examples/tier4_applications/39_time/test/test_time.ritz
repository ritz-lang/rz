# Tests for 39_time — measure elapsed time of a command.
import ritzlib.sys
import ritzlib.testlib

[[test]]
fn test_time_emits_real() -> i32
    var argv: [3]*u8
    argv[0] = c"./time"
    argv[1] = c"/bin/true"
    argv[2] = null

    var envp: [2]*u8
    envp[0] = c"PATH=/bin:/usr/bin"
    envp[1] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./time", @argv[0], @envp[0], null, 0, @out[0], 4096, @n)

    assert exit_code == 0, "time /bin/true should exit 0"
    assert buf_contains(@out[0], n, c"real", 4) == 1, "missing 'real' label"
    0

[[test]]
fn test_time_propagates_failure() -> i32
    # `./time /bin/false` — child exits 1.  Some implementations exit 0
    # (just wrap), others exit 1 (pass through).  Accept either; only
    # require the report to contain 'real'.
    var argv: [3]*u8
    argv[0] = c"./time"
    argv[1] = c"/bin/false"
    argv[2] = null

    var envp: [2]*u8
    envp[0] = c"PATH=/bin:/usr/bin"
    envp[1] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./time", @argv[0], @envp[0], null, 0, @out[0], 4096, @n)

    assert buf_contains(@out[0], n, c"real", 4) == 1, "missing 'real' label"
    assert exit_code == 0 || exit_code == 1, "exit should be 0 or 1"
    0
