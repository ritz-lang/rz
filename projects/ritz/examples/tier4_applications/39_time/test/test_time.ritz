# Tests for 39_time - measure elapsed time of a command
#
# Integration tests fork+exec ./time and verify it prints a 'real' timing
# line and propagates the child's exit code.

import ritzlib.sys
import ritzlib.io
import ritzlib.str

fn buf_eq(a: *u8, b: *u8, len: i64) -> i32
    var i: i64 = 0
    while i < len
        if *(a + i) != *(b + i)
            return 0
        i += 1
    return 1

fn buf_contains(hay: *u8, hay_len: i64, needle: *u8, needle_len: i64) -> i32
    if needle_len == 0
        return 1
    if needle_len > hay_len
        return 0
    var i: i64 = 0
    while i <= hay_len - needle_len
        if buf_eq(hay + i, needle, needle_len) == 1
            return 1
        i += 1
    return 0

fn time_exec(argv: **u8, envp: **u8, out_buf: *u8, out_len: *i64) -> i32
    var stdout_pipe: [2]i32
    if sys_pipe(@stdout_pipe[0]) < 0
        return -1
    let pid: i32 = sys_fork()
    if pid < 0
        sys_close(stdout_pipe[0])
        sys_close(stdout_pipe[1])
        return -2
    if pid == 0
        sys_dup2(stdout_pipe[1], 1)
        sys_dup2(stdout_pipe[1], 2)
        sys_close(stdout_pipe[0])
        sys_close(stdout_pipe[1])
        sys_execve(c"./time", argv, envp)
        sys_exit(127)
    sys_close(stdout_pipe[1])
    var total: i64 = 0
    while total < 4096
        let r: i64 = sys_read(stdout_pipe[0], out_buf + total, 4096 - total)
        if r <= 0
            break
        total += r
    sys_close(stdout_pipe[0])
    *out_len = total
    var status: i32 = 0
    sys_wait4(pid, @status, 0, null)
    return (status >> 8) & 0xFF

[[test]]
fn test_time_emits_real() -> i32
    # `./time /bin/true` should produce a "real" line in output
    var argv: [3]*u8
    argv[0] = c"./time"
    argv[1] = c"/bin/true"
    argv[2] = null

    var envp: [2]*u8
    envp[0] = c"PATH=/bin:/usr/bin"
    envp[1] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = time_exec(@argv[0], @envp[0], @out[0], @n)

    assert exit_code == 0, c"time /bin/true should exit 0"
    assert buf_contains(@out[0], n, c"real", 4) == 1, c"missing 'real' label"
    0

[[test]]
fn test_time_propagates_failure() -> i32
    # `./time /bin/false` — child exits 1, time wraps it but should still
    # emit the report.  Coreutils `time` exits with the child's code (1)
    # but some implementations exit 0.  Accept either; only require 'real'.
    var argv: [3]*u8
    argv[0] = c"./time"
    argv[1] = c"/bin/false"
    argv[2] = null

    var envp: [2]*u8
    envp[0] = c"PATH=/bin:/usr/bin"
    envp[1] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = time_exec(@argv[0], @envp[0], @out[0], @n)

    assert buf_contains(@out[0], n, c"real", 4) == 1, c"missing 'real' label"
    assert exit_code == 0 || exit_code == 1, c"exit should be 0 or 1"
    0
