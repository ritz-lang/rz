# Tests for 37_xargs — build and execute command lines from stdin.
import ritzlib.testlib

[[test]]
fn test_xargs_default_echo() -> i32
    var argv: [2]*u8
    argv[0] = c"./xargs"
    argv[1] = null
    var out: [1024]u8
    var n: i64 = 0
    var envp: [2]*u8
    envp[0] = c"PATH=/bin:/usr/bin"
    envp[1] = null
    let rc: i32 = exec_capture(c"./xargs", @argv[0], @envp[0], c"a b c\n", 6, @out[0], 1024, @n)
    assert rc == 0, "exit 0"
    # Default command is echo, so output should contain 'a b c'
    assert buf_contains(@out[0], n, c"a b c", 5) == 1, "should echo args"
    0

[[test]]
fn test_xargs_explicit_echo() -> i32
    var argv: [3]*u8
    argv[0] = c"./xargs"
    argv[1] = c"echo"
    argv[2] = null
    var envp: [2]*u8
    envp[0] = c"PATH=/bin:/usr/bin"
    envp[1] = null
    var out: [1024]u8
    var n: i64 = 0
    let rc: i32 = exec_capture(c"./xargs", @argv[0], @envp[0], c"hello world\n", 12, @out[0], 1024, @n)
    assert rc == 0, "exit 0"
    assert buf_contains(@out[0], n, c"hello world", 11) == 1, "echo passes through"
    0

[[test]]
fn test_xargs_n1_one_per_command() -> i32
    var argv: [4]*u8
    argv[0] = c"./xargs"
    argv[1] = c"-n1"
    argv[2] = c"echo"
    argv[3] = null
    var envp: [2]*u8
    envp[0] = c"PATH=/bin:/usr/bin"
    envp[1] = null
    var out: [1024]u8
    var n: i64 = 0
    let rc: i32 = exec_capture(c"./xargs", @argv[0], @envp[0], c"a b c\n", 6, @out[0], 1024, @n)
    assert rc == 0, "exit 0"
    # -n1 → one arg per echo invocation, so 3 lines.
    var nl: i64 = 0
    var i: i64 = 0
    while i < n
        if *(@out[0] + i) == 10
            nl += 1
        i += 1
    assert nl == 3, "expected 3 lines (one per arg)"
    0
