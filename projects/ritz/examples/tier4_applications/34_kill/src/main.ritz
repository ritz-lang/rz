# kill - send signals to processes
#
# Usage: kill [-SIGNAL] PID...
#        kill -l
#
# Send signals to processes by PID.
#
# Options:
#   -l           List all signal names
#   -SIGNAL      Signal to send (name or number)
#                e.g., -9, -KILL, -HUP, -TERM
#
# Examples:
#   kill 1234           # send SIGTERM to process 1234
#   kill -9 1234        # send SIGKILL to process 1234
#   kill -KILL 1234     # same as above
#   kill -HUP 1234 5678 # send SIGHUP to multiple processes
#   kill -l             # list all signals

# ============================================================================
# Standard library imports
# ============================================================================

import ritzlib.sys
import ritzlib.io
import ritzlib.str

# ============================================================================
# Signal name table
# ============================================================================

# Signal number to name mapping
# Index is signal number, value is name

fn get_signal_name(sig: i32) -> *u8
    if sig == 1
        return c"HUP"
    if sig == 2
        return c"INT"
    if sig == 3
        return c"QUIT"
    if sig == 4
        return c"ILL"
    if sig == 5
        return c"TRAP"
    if sig == 6
        return c"ABRT"
    if sig == 7
        return c"BUS"
    if sig == 8
        return c"FPE"
    if sig == 9
        return c"KILL"
    if sig == 10
        return c"USR1"
    if sig == 11
        return c"SEGV"
    if sig == 12
        return c"USR2"
    if sig == 13
        return c"PIPE"
    if sig == 14
        return c"ALRM"
    if sig == 15
        return c"TERM"
    if sig == 16
        return c"STKFLT"
    if sig == 17
        return c"CHLD"
    if sig == 18
        return c"CONT"
    if sig == 19
        return c"STOP"
    if sig == 20
        return c"TSTP"
    if sig == 21
        return c"TTIN"
    if sig == 22
        return c"TTOU"
    if sig == 23
        return c"URG"
    if sig == 24
        return c"XCPU"
    if sig == 25
        return c"XFSZ"
    if sig == 26
        return c"VTALRM"
    if sig == 27
        return c"PROF"
    if sig == 28
        return c"WINCH"
    if sig == 29
        return c"IO"
    if sig == 30
        return c"PWR"
    if sig == 31
        return c"SYS"
    return null

fn parse_signal_name(name: *u8) -> i32
    # Parse signal name (without SIG prefix) to number
    # Returns -1 if not found

    # Skip optional "SIG" prefix
    var n: *u8 = name
    if *n == 'S' and *(n+1) == 'I' and *(n+2) == 'G'  # "SIG"
        n += 3

    if streq(n, c"HUP") != 0
        return 1
    if streq(n, c"INT") != 0
        return 2
    if streq(n, c"QUIT") != 0
        return 3
    if streq(n, c"ILL") != 0
        return 4
    if streq(n, c"TRAP") != 0
        return 5
    if streq(n, c"ABRT") != 0
        return 6
    if streq(n, c"BUS") != 0
        return 7
    if streq(n, c"FPE") != 0
        return 8
    if streq(n, c"KILL") != 0
        return 9
    if streq(n, c"USR1") != 0
        return 10
    if streq(n, c"SEGV") != 0
        return 11
    if streq(n, c"USR2") != 0
        return 12
    if streq(n, c"PIPE") != 0
        return 13
    if streq(n, c"ALRM") != 0
        return 14
    if streq(n, c"TERM") != 0
        return 15
    if streq(n, c"STKFLT") != 0
        return 16
    if streq(n, c"CHLD") != 0
        return 17
    if streq(n, c"CONT") != 0
        return 18
    if streq(n, c"STOP") != 0
        return 19
    if streq(n, c"TSTP") != 0
        return 20
    if streq(n, c"TTIN") != 0
        return 21
    if streq(n, c"TTOU") != 0
        return 22
    if streq(n, c"URG") != 0
        return 23
    if streq(n, c"XCPU") != 0
        return 24
    if streq(n, c"XFSZ") != 0
        return 25
    if streq(n, c"VTALRM") != 0
        return 26
    if streq(n, c"PROF") != 0
        return 27
    if streq(n, c"WINCH") != 0
        return 28
    if streq(n, c"IO") != 0
        return 29
    if streq(n, c"PWR") != 0
        return 30
    if streq(n, c"SYS") != 0
        return 31

    return -1

# ============================================================================
# Helper functions
# ============================================================================

fn is_digit(c: u8) -> i32
    if c >= '0' and c <= '9'
        return 1
    return 0

fn is_all_digits(s: *u8) -> i32
    # Check if string is all digits (possibly with leading -)
    var p: *u8 = s
    if *p == '-'  # '-'
        p += 1
    if *p == 0
        return 0
    while *p != 0
        if is_digit(*p) == 0
            return 0
        p += 1
    return 1

fn print_usage()
    prints_cstr(c"Usage: kill [-SIGNAL] PID...\n")
    prints_cstr(c"       kill -l\n")
    prints_cstr(c"\n")
    prints_cstr(c"Send signals to processes.\n")
    prints_cstr(c"\n")
    prints_cstr(c"Options:\n")
    prints_cstr(c"  -l           List all signal names\n")
    prints_cstr(c"  -SIGNAL      Signal to send (name or number)\n")
    prints_cstr(c"               e.g., -9, -KILL, -HUP, -TERM\n")

fn list_signals()
    # List all signals in a format similar to GNU kill -l
    var sig: i32 = 1
    var col: i32 = 0
    while sig <= 31
        let name: *u8 = get_signal_name(sig)
        if name != null
            # Print signal number and name
            if sig < 10
                prints_cstr(c" ")
            print_int(sig as i64)
            prints_cstr(c") SIG")
            prints_cstr(name)

            col += 1
            if col >= 4
                print_char(10)  # newline
                col = 0
            else
                # Pad to column width (approx 16 chars)
                let name_len: i64 = strlen(name)
                var pad: i64 = 12 - name_len
                while pad > 0
                    print_char(32)  # space
                    pad -= 1
        sig += 1

    if col > 0
        print_char(10)  # final newline

fn parse_signal(arg: *u8) -> i32
    # Parse signal specification (after the leading -)
    # Returns signal number or -1 on error

    # Check if it's a number
    if is_all_digits(arg) != 0
        let sig: i64 = atoi(arg)
        # Signal 0 is special (check process existence)
        if sig >= 0 and sig <= 31
            return sig as i32
        return -1

    # Try to parse as signal name
    return parse_signal_name(arg)

# ============================================================================
# Main
# ============================================================================

fn main(argc: i32, argv: **u8, envp: **u8) -> i32
    if argc < 2
        print_usage()
        return 1

    var signal: i32 = SIGTERM  # default signal
    var first_pid_idx: i32 = 1
    var exit_code: i32 = 0

    # Check for -l (list signals)
    let arg1: *u8 = *(argv + 1)
    if streq(arg1, c"-l") != 0 or streq(arg1, c"--list") != 0
        list_signals()
        return 0

    # Check for --help
    if streq(arg1, c"--help") != 0
        print_usage()
        return 0

    # Check for signal specification
    if *arg1 == '-'  # '-'
        let sig_spec: *u8 = arg1 + 1

        # Not just "-" alone
        if *sig_spec != 0
            # Check if it looks like a signal (not a negative PID for now)
            # Signal specs: -9, -KILL, -SIGKILL, -HUP, etc.
            signal = parse_signal(sig_spec)
            if signal < 0
                eprints_cstr(c"kill: invalid signal specification '")
                eprints_cstr(sig_spec)
                eprints_cstr(c"'\n")
                return 1
            first_pid_idx = 2

    # Need at least one PID
    if first_pid_idx >= argc
        eprints_cstr(c"kill: missing PID\n")
        print_usage()
        return 1

    # Send signal to each PID
    var i: i32 = first_pid_idx
    while i < argc
        let pid_str: *u8 = *(argv + i)

        # Parse PID (can be negative for process groups)
        if is_all_digits(pid_str) == 0
            eprints_cstr(c"kill: invalid PID '")
            eprints_cstr(pid_str)
            eprints_cstr(c"'\n")
            exit_code = 1
            i += 1
            continue

        let pid: i64 = atoi(pid_str)

        # Send the signal
        let result: i32 = sys_kill(pid as i32, signal)

        if result < 0
            let err: i32 = 0 - result
            eprints_cstr(c"kill: (")
            eprint_int(pid)
            eprints_cstr(c") - ")

            if err == ESRCH
                eprints_cstr(c"No such process\n")
            else if err == EPERM
                eprints_cstr(c"Operation not permitted\n")
            else if err == EINVAL
                eprints_cstr(c"Invalid signal\n")
            else
                eprints_cstr(c"Error ")
                eprint_int(err as i64)
                eprints_cstr(c"\n")

            exit_code = 1

        i += 1

    return exit_code
