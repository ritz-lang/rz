# Tests for 34_kill — send signals to processes.
#
# Argv-parsing tests only — sending real signals would require fork+wait
# choreography that's not buying us much beyond what test.sh covers.
import ritzlib.sys
import ritzlib.testlib

[[test]]
fn test_kill_list_signals() -> i32
    var argv: [3]*u8
    argv[0] = c"./kill"
    argv[1] = c"-l"
    argv[2] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./kill", @argv[0], null, null, 0, @out[0], 4096, @n)

    assert exit_code == 0, "kill -l should exit 0"
    assert buf_contains(@out[0], n, c"SIGHUP", 6) == 1, "missing SIGHUP"
    assert buf_contains(@out[0], n, c"SIGTERM", 7) == 1, "missing SIGTERM"
    assert buf_contains(@out[0], n, c"SIGKILL", 7) == 1, "missing SIGKILL"
    0

[[test]]
fn test_kill_invalid_signal() -> i32
    var argv: [4]*u8
    argv[0] = c"./kill"
    argv[1] = c"-INVALID"
    argv[2] = c"1"
    argv[3] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./kill", @argv[0], null, null, 0, @out[0], 1024, @n)

    assert exit_code == 1, "kill -INVALID should exit 1"
    0

[[test]]
fn test_kill_invalid_pid() -> i32
    var argv: [4]*u8
    argv[0] = c"./kill"
    argv[1] = c"-TERM"
    argv[2] = c"abc"
    argv[3] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./kill", @argv[0], null, null, 0, @out[0], 1024, @n)

    assert exit_code == 1, "kill -TERM abc should exit 1"
    0

[[test]]
fn test_kill_missing_pid() -> i32
    var argv: [3]*u8
    argv[0] = c"./kill"
    argv[1] = c"-9"
    argv[2] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./kill", @argv[0], null, null, 0, @out[0], 1024, @n)

    assert exit_code == 1, "kill -9 (no pid) should exit 1"
    0
