# Tests for 34_kill - send signals to processes
#
# We focus on argv-parsing tests (kill -l, invalid args) since sending
# real signals would require fork+wait choreography that's not buying
# us much beyond what test.sh already covers.

import ritzlib.sys
import ritzlib.io
import ritzlib.str

fn buf_eq(a: *u8, b: *u8, len: i64) -> i32
    var i: i64 = 0
    while i < len
        if *(a + i) != *(b + i)
            return 0
        i += 1
    return 1

fn buf_contains(hay: *u8, hay_len: i64, needle: *u8, needle_len: i64) -> i32
    if needle_len == 0
        return 1
    if needle_len > hay_len
        return 0
    var i: i64 = 0
    while i <= hay_len - needle_len
        if buf_eq(hay + i, needle, needle_len) == 1
            return 1
        i += 1
    return 0

fn kill_exec(argv: **u8, out_buf: *u8, out_len: *i64) -> i32
    var stdout_pipe: [2]i32
    if sys_pipe(@stdout_pipe[0]) < 0
        return -1
    let pid: i32 = sys_fork()
    if pid < 0
        sys_close(stdout_pipe[0])
        sys_close(stdout_pipe[1])
        return -2
    if pid == 0
        sys_dup2(stdout_pipe[1], 1)
        sys_dup2(stdout_pipe[1], 2)
        sys_close(stdout_pipe[0])
        sys_close(stdout_pipe[1])
        sys_execve(c"./kill", argv, null)
        sys_exit(127)
    sys_close(stdout_pipe[1])
    var total: i64 = 0
    while total < 4096
        let r: i64 = sys_read(stdout_pipe[0], out_buf + total, 4096 - total)
        if r <= 0
            break
        total += r
    sys_close(stdout_pipe[0])
    *out_len = total
    var status: i32 = 0
    sys_wait4(pid, @status, 0, null)
    return (status >> 8) & 0xFF

[[test]]
fn test_kill_list_signals() -> i32
    # `./kill -l` should list signals (SIGHUP, SIGTERM, etc.) and exit 0
    var argv: [3]*u8
    argv[0] = c"./kill"
    argv[1] = c"-l"
    argv[2] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = kill_exec(@argv[0], @out[0], @n)

    assert exit_code == 0, c"kill -l should exit 0"
    assert buf_contains(@out[0], n, c"SIGHUP", 6) == 1, c"missing SIGHUP"
    assert buf_contains(@out[0], n, c"SIGTERM", 7) == 1, c"missing SIGTERM"
    assert buf_contains(@out[0], n, c"SIGKILL", 7) == 1, c"missing SIGKILL"
    0

[[test]]
fn test_kill_invalid_signal() -> i32
    # `./kill -INVALID 1` should reject the signal name
    var argv: [4]*u8
    argv[0] = c"./kill"
    argv[1] = c"-INVALID"
    argv[2] = c"1"
    argv[3] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = kill_exec(@argv[0], @out[0], @n)

    assert exit_code != 0, c"kill -INVALID should fail"
    0

[[test]]
fn test_kill_invalid_pid() -> i32
    # `./kill -TERM abc` should reject the non-numeric pid
    var argv: [4]*u8
    argv[0] = c"./kill"
    argv[1] = c"-TERM"
    argv[2] = c"abc"
    argv[3] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = kill_exec(@argv[0], @out[0], @n)

    assert exit_code != 0, c"kill -TERM abc should fail"
    0

[[test]]
fn test_kill_missing_pid() -> i32
    # `./kill -9` (no pid) should fail
    var argv: [3]*u8
    argv[0] = c"./kill"
    argv[1] = c"-9"
    argv[2] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = kill_exec(@argv[0], @out[0], @n)

    assert exit_code != 0, c"kill -9 (no pid) should fail"
    0
