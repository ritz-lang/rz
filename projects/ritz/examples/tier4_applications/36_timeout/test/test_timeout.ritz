# Tests for 36_timeout — run command with time limit.
#
# Standard exit codes:
#   124  child exceeded the timeout
#   127  child binary not found
#   N    pass-through of child's exit code on normal completion
import ritzlib.sys
import ritzlib.testlib

[[test]]
fn test_timeout_command_completes() -> i32
    var argv: [5]*u8
    argv[0] = c"./timeout"
    argv[1] = c"5"
    argv[2] = c"/bin/echo"
    argv[3] = c"hello"
    argv[4] = null

    var envp: [2]*u8
    envp[0] = c"PATH=/bin:/usr/bin"
    envp[1] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./timeout", @argv[0], @envp[0], null, 0, @out[0], 1024, @n)

    assert exit_code == 0, "timeout 5 echo should exit 0"
    assert buf_contains(@out[0], n, c"hello", 5) == 1, "missing 'hello'"
    0

[[test]]
fn test_timeout_child_times_out() -> i32
    var argv: [5]*u8
    argv[0] = c"./timeout"
    argv[1] = c"0.1"
    argv[2] = c"/bin/sleep"
    argv[3] = c"10"
    argv[4] = null

    var envp: [2]*u8
    envp[0] = c"PATH=/bin:/usr/bin"
    envp[1] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./timeout", @argv[0], @envp[0], null, 0, @out[0], 1024, @n)

    assert exit_code == 124, "timed-out child should exit 124"
    0

[[test]]
fn test_timeout_command_not_found() -> i32
    var argv: [4]*u8
    argv[0] = c"./timeout"
    argv[1] = c"1"
    argv[2] = c"nonexistent_command_xyzzy"
    argv[3] = null

    var envp: [2]*u8
    envp[0] = c"PATH=/bin:/usr/bin"
    envp[1] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./timeout", @argv[0], @envp[0], null, 0, @out[0], 1024, @n)

    assert exit_code == 127, "missing command should exit 127"
    0

[[test]]
fn test_timeout_preserves_child_exit() -> i32
    var argv: [4]*u8
    argv[0] = c"./timeout"
    argv[1] = c"5"
    argv[2] = c"/bin/false"
    argv[3] = null

    var envp: [2]*u8
    envp[0] = c"PATH=/bin:/usr/bin"
    envp[1] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./timeout", @argv[0], @envp[0], null, 0, @out[0], 1024, @n)

    assert exit_code == 1, "child's exit code 1 should pass through"
    0

[[test]]
fn test_timeout_zero_duration() -> i32
    var argv: [5]*u8
    argv[0] = c"./timeout"
    argv[1] = c"0"
    argv[2] = c"/bin/sleep"
    argv[3] = c"1"
    argv[4] = null

    var envp: [2]*u8
    envp[0] = c"PATH=/bin:/usr/bin"
    envp[1] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./timeout", @argv[0], @envp[0], null, 0, @out[0], 1024, @n)

    assert exit_code == 124, "timeout 0 should exit 124"
    0
