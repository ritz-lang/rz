# Tests for 36_timeout - run command with time limit
#
# Integration tests fork+exec ./timeout with various durations and child
# commands.  Verifies the standard exit codes:
#   124  child exceeded the timeout
#   127  child binary not found
#   N    pass-through of child's exit code on normal completion

import ritzlib.sys
import ritzlib.io
import ritzlib.str

fn buf_eq(a: *u8, b: *u8, len: i64) -> i32
    var i: i64 = 0
    while i < len
        if *(a + i) != *(b + i)
            return 0
        i += 1
    return 1

fn buf_contains(hay: *u8, hay_len: i64, needle: *u8, needle_len: i64) -> i32
    if needle_len == 0
        return 1
    if needle_len > hay_len
        return 0
    var i: i64 = 0
    while i <= hay_len - needle_len
        if buf_eq(hay + i, needle, needle_len) == 1
            return 1
        i += 1
    return 0

fn timeout_exec(argv: **u8, envp: **u8, out_buf: *u8, out_len: *i64) -> i32
    var stdout_pipe: [2]i32
    if sys_pipe(@stdout_pipe[0]) < 0
        return -1
    let pid: i32 = sys_fork()
    if pid < 0
        sys_close(stdout_pipe[0])
        sys_close(stdout_pipe[1])
        return -2
    if pid == 0
        sys_dup2(stdout_pipe[1], 1)
        sys_dup2(stdout_pipe[1], 2)
        sys_close(stdout_pipe[0])
        sys_close(stdout_pipe[1])
        sys_execve(c"./timeout", argv, envp)
        sys_exit(127)
    sys_close(stdout_pipe[1])
    var total: i64 = 0
    while total < 4096
        let r: i64 = sys_read(stdout_pipe[0], out_buf + total, 4096 - total)
        if r <= 0
            break
        total += r
    sys_close(stdout_pipe[0])
    *out_len = total
    var status: i32 = 0
    sys_wait4(pid, @status, 0, null)
    return (status >> 8) & 0xFF

[[test]]
fn test_timeout_command_completes() -> i32
    # `./timeout 5 /bin/echo hello` — should exit 0 and print "hello"
    var argv: [5]*u8
    argv[0] = c"./timeout"
    argv[1] = c"5"
    argv[2] = c"/bin/echo"
    argv[3] = c"hello"
    argv[4] = null

    var envp: [2]*u8
    envp[0] = c"PATH=/bin:/usr/bin"
    envp[1] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = timeout_exec(@argv[0], @envp[0], @out[0], @n)

    assert exit_code == 0, c"timeout 5 echo should exit 0"
    assert buf_contains(@out[0], n, c"hello", 5) == 1, c"missing 'hello'"
    0

[[test]]
fn test_timeout_child_times_out() -> i32
    # `./timeout 0.1 /bin/sleep 10` — should exit 124
    var argv: [5]*u8
    argv[0] = c"./timeout"
    argv[1] = c"0.1"
    argv[2] = c"/bin/sleep"
    argv[3] = c"10"
    argv[4] = null

    var envp: [2]*u8
    envp[0] = c"PATH=/bin:/usr/bin"
    envp[1] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = timeout_exec(@argv[0], @envp[0], @out[0], @n)

    assert exit_code == 124, c"timed-out child should exit 124"
    0

[[test]]
fn test_timeout_command_not_found() -> i32
    # `./timeout 1 nonexistent_command_xyzzy` — should exit 127
    var argv: [4]*u8
    argv[0] = c"./timeout"
    argv[1] = c"1"
    argv[2] = c"nonexistent_command_xyzzy"
    argv[3] = null

    var envp: [2]*u8
    envp[0] = c"PATH=/bin:/usr/bin"
    envp[1] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = timeout_exec(@argv[0], @envp[0], @out[0], @n)

    assert exit_code == 127, c"missing command should exit 127"
    0

[[test]]
fn test_timeout_preserves_child_exit() -> i32
    # `./timeout 5 /bin/false` — should exit 1 (child's code)
    var argv: [4]*u8
    argv[0] = c"./timeout"
    argv[1] = c"5"
    argv[2] = c"/bin/false"
    argv[3] = null

    var envp: [2]*u8
    envp[0] = c"PATH=/bin:/usr/bin"
    envp[1] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = timeout_exec(@argv[0], @envp[0], @out[0], @n)

    assert exit_code == 1, c"child's exit code 1 should pass through"
    0

[[test]]
fn test_timeout_zero_duration() -> i32
    # `./timeout 0 /bin/sleep 1` — should immediately time out (124)
    var argv: [5]*u8
    argv[0] = c"./timeout"
    argv[1] = c"0"
    argv[2] = c"/bin/sleep"
    argv[3] = c"1"
    argv[4] = null

    var envp: [2]*u8
    envp[0] = c"PATH=/bin:/usr/bin"
    envp[1] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = timeout_exec(@argv[0], @envp[0], @out[0], @n)

    assert exit_code == 124, c"timeout 0 should exit 124"
    0
