# Tests for 40_watch — periodic command runner.
#
# watch loops forever, so we only test the immediate-error path
# (invalid interval) and trust test.sh for the timeout-driven
# happy-path check (which can't be expressed cleanly in [[test]] form
# without a kill-after-N-seconds helper).

import ritzlib.testlib

[[test]]
fn test_watch_rejects_zero_interval() -> i32
    var argv: [5]*u8
    argv[0] = c"./watch"
    argv[1] = c"-n"
    argv[2] = c"0"
    argv[3] = c"echo"
    argv[4] = null

    var out: [1024]u8
    var n: i64 = 0
    let rc: i32 = exec_capture(c"./watch", @argv[0], null, null, 0, @out[0], 1024, @n)

    # `-n 0` should be rejected with a "at least 1 second" diagnostic
    # and a non-zero exit.
    assert rc != 0, "watch -n 0 should fail"
    assert buf_contains(@out[0], n, c"at least 1 second", 17) == 1, "should mention min interval"
    0
