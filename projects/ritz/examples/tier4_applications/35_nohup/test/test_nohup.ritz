# Tests for 35_nohup — run command immune to hangups.
import ritzlib.sys
import ritzlib.testlib

[[test]]
fn test_nohup_basic_execution() -> i32
    var argv: [4]*u8
    argv[0] = c"./nohup"
    argv[1] = c"/bin/echo"
    argv[2] = c"hello"
    argv[3] = null

    var envp: [2]*u8
    envp[0] = c"PATH=/bin:/usr/bin"
    envp[1] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./nohup", @argv[0], @envp[0], null, 0, @out[0], 1024, @n)

    assert exit_code == 0, "nohup echo should exit 0"
    assert buf_contains(@out[0], n, c"hello", 5) == 1, "missing 'hello' in output"
    0

[[test]]
fn test_nohup_exit_zero_passthrough() -> i32
    var argv: [3]*u8
    argv[0] = c"./nohup"
    argv[1] = c"/bin/true"
    argv[2] = null

    var envp: [2]*u8
    envp[0] = c"PATH=/bin:/usr/bin"
    envp[1] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./nohup", @argv[0], @envp[0], null, 0, @out[0], 1024, @n)

    assert exit_code == 0, "nohup /bin/true should exit 0"
    0

[[test]]
fn test_nohup_exit_nonzero_passthrough() -> i32
    var argv: [3]*u8
    argv[0] = c"./nohup"
    argv[1] = c"/bin/false"
    argv[2] = null

    var envp: [2]*u8
    envp[0] = c"PATH=/bin:/usr/bin"
    envp[1] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./nohup", @argv[0], @envp[0], null, 0, @out[0], 1024, @n)

    assert exit_code == 1, "nohup /bin/false should exit 1"
    0

[[test]]
fn test_nohup_missing_command() -> i32
    var argv: [2]*u8
    argv[0] = c"./nohup"
    argv[1] = null

    var envp: [2]*u8
    envp[0] = c"PATH=/bin:/usr/bin"
    envp[1] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./nohup", @argv[0], @envp[0], null, 0, @out[0], 1024, @n)

    assert exit_code == 125, "nohup (no args) should exit 125"
    0

[[test]]
fn test_nohup_command_not_found() -> i32
    var argv: [3]*u8
    argv[0] = c"./nohup"
    argv[1] = c"/nonexistent_xyzzy"
    argv[2] = null

    var envp: [2]*u8
    envp[0] = c"PATH=/bin:/usr/bin"
    envp[1] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./nohup", @argv[0], @envp[0], null, 0, @out[0], 1024, @n)

    assert exit_code == 127, "nohup <missing> should exit 127"
    0
