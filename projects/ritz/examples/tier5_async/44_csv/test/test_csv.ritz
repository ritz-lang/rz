# Tests for 44_csv — CSV parser/projector.
import ritzlib.testlib

[[test]]
fn test_csv_simple() -> i32
    var argv: [2]*u8
    argv[0] = c"./csv"
    argv[1] = null
    var out: [4096]u8
    var n: i64 = 0
    let rc: i32 = exec_capture(c"./csv", @argv[0], null, c"a,b,c\n1,2,3\n4,5,6\n", 18, @out[0], 4096, @n)
    assert rc == 0, "exit 0 on simple CSV"
    assert buf_contains(@out[0], n, c"1", 1) == 1, "output should contain values"
    0

[[test]]
fn test_csv_field_selection() -> i32
    var argv: [4]*u8
    argv[0] = c"./csv"
    argv[1] = c"-f"
    argv[2] = c"1,3"
    argv[3] = null
    var out: [4096]u8
    var n: i64 = 0
    let rc: i32 = exec_capture(c"./csv", @argv[0], null, c"a,b,c,d\n1,2,3,4\n", 16, @out[0], 4096, @n)
    assert rc == 0, "exit 0 on field selection"
    assert buf_contains(@out[0], n, c"1", 1) == 1, "should contain field 1"
    0
