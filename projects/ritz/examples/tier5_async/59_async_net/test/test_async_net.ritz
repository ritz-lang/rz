# Tests for 59_async_net — wraps the binary's self-test main().
#
# The binary runs internal test_socket_*/test_async_*/etc. and exits 0
# if all pass.  This [[test]] just fork+execs and asserts the exit code.

import ritzlib.testlib

[[test]]
fn test_async_net_self() -> i32
    var argv: [2]*u8
    argv[0] = c"./async_net_test"
    argv[1] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./async_net_test", @argv[0], null, null, 0, @out[0], 4096, @n)

    assert exit_code == 0, "async_net_test self-tests should exit 0"
    0
