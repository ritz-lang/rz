# Tests for 42_json — JSON parser/reformatter.
#
# Mirrors the test.sh scenarios via exec_capture with stdin.

import ritzlib.testlib

fn json_run(args: **u8, stdin_data: *u8, stdin_len: i64, out: *u8, n: *i64) -> i32
    return exec_capture(c"./json", args, null, stdin_data, stdin_len, out, 4096, n)

[[test]]
fn test_json_simple_object() -> i32
    var argv: [2]*u8
    argv[0] = c"./json"
    argv[1] = null
    var out: [4096]u8
    var n: i64 = 0
    let rc: i32 = json_run(@argv[0], c"{\"name\":\"test\"}", 15, @out[0], @n)
    assert rc == 0, "exit 0 on valid object"
    assert buf_contains(@out[0], n, c"\"name\"", 6) == 1, "should contain \"name\" key"
    0

[[test]]
fn test_json_array() -> i32
    var argv: [2]*u8
    argv[0] = c"./json"
    argv[1] = null
    var out: [4096]u8
    var n: i64 = 0
    let rc: i32 = json_run(@argv[0], c"[1, 2, 3]", 9, @out[0], @n)
    assert rc == 0, "exit 0 on valid array"
    assert buf_contains(@out[0], n, c"[", 1) == 1, "should contain ["
    0

[[test]]
fn test_json_invalid_rejected() -> i32
    var argv: [2]*u8
    argv[0] = c"./json"
    argv[1] = null
    var out: [4096]u8
    var n: i64 = 0
    let rc: i32 = json_run(@argv[0], c"{invalid}", 9, @out[0], @n)
    assert rc != 0, "invalid JSON should fail (non-zero exit)"
    0

[[test]]
fn test_json_compact_flag() -> i32
    var argv: [3]*u8
    argv[0] = c"./json"
    argv[1] = c"-c"
    argv[2] = null
    var out: [4096]u8
    var n: i64 = 0
    let rc: i32 = json_run(@argv[0], c"{\"a\": 1}", 8, @out[0], @n)
    assert rc == 0, "compact mode exit 0"
    # Compact form should be "{\"a\":1}" — no whitespace
    assert buf_contains(@out[0], n, c"{\"a\":1}", 7) == 1, "compact should remove whitespace"
    0
