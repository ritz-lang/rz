# json - JSON validator and pretty printer
#
# Usage: json [OPTIONS] [FILE]
#   Validates JSON and optionally pretty-prints it.
#
# Options:
#   -c, --compact     Output compact JSON (no whitespace)
#   -v, --validate    Validate only (no output)
#   -h, --help        Show help
#
# Examples:
#   echo '{"name":"test"}' | json           # Pretty print
#   json -c data.json                        # Compact output
#   json -v config.json                      # Validate only

# ============================================================================
# Standard library imports
# ============================================================================

import ritzlib.sys
import ritzlib.io
import ritzlib.str
import ritzlib.args
import ritzlib.gvec

# ============================================================================
# JSON Value Types
# ============================================================================

const JSON_NULL: i32 = 0
const JSON_BOOL: i32 = 1
const JSON_NUMBER: i32 = 2
const JSON_STRING: i32 = 3
const JSON_ARRAY: i32 = 4
const JSON_OBJECT: i32 = 5

# Maximum nesting depth
const MAX_DEPTH: i32 = 64

# ============================================================================
# JSON Parser structure
# ============================================================================

struct JsonParser
    data: *u8
    len: i64
    pos: i64
    depth: i32
    error: i32
    error_msg: *u8
    # Output buffer and formatting
    out: *Vec<u8>
    compact: i32

fn parser_init(p: *JsonParser, input: *u8, len: i64, out: *Vec<u8>, compact: i32) -> i32
    p.data = input
    p.len = len
    p.pos = 0
    p.depth = 0
    p.error = 0
    p.error_msg = c""
    p.out = out
    p.compact = compact
    return 0

fn peek(p: *JsonParser) -> u8
    if p.pos >= p.len
        return 0
    return *(p.data + p.pos)

fn advance(p: *JsonParser) -> u8
    if p.pos >= p.len
        return 0
    let c: u8 = *(p.data + p.pos)
    p.pos = p.pos + 1
    return c

fn skip_whitespace(p: *JsonParser) -> i32
    while p.pos < p.len
        let c: u8 = *(p.data + p.pos)
        if c != ' ' and c != '\t' and c != '\n' and c != '\r'
            break
        p.pos = p.pos + 1
    return 0

fn set_error(p: *JsonParser, msg: *u8) -> i32
    p.error = 1
    p.error_msg = msg
    return -1

fn expect(p: *JsonParser, c: u8) -> i32
    skip_whitespace(p)
    if peek(p) != c
        return set_error(p, c"unexpected character")
    advance(p)
    return 0

fn emit(p: *JsonParser, c: u8) -> i32
    vec_push<u8>(p.out, c)
    return 0

fn emit_str(p: *JsonParser, s: *u8) -> i32
    vec_push_str(p.out, s)
    return 0

fn write_indent(p: *JsonParser) -> i32
    if p.compact != 0
        return 0
    vec_push<u8>(p.out, '\n')  # newline
    for i in 0..(p.depth * 2)
        vec_push<u8>(p.out, ' ')  # space
    return 0

# ============================================================================
# Parsing functions
# ============================================================================

fn parse_string(p: *JsonParser) -> i32
    if peek(p) != 34  # '"'
        return set_error(p, c"expected string")

    emit(p, advance(p))  # Opening quote

    while p.pos < p.len
        let c: u8 = peek(p)

        if c == '"'  # End quote
            emit(p, advance(p))
            return 0

        if c == '\\'  # Backslash - escape sequence
            emit(p, advance(p))
            if p.pos >= p.len
                return set_error(p, c"unterminated string")
            let esc: u8 = advance(p)
            emit(p, esc)
            if esc == 117  # 'u' - unicode escape
                for i in 0..4
                    if p.pos >= p.len
                        return set_error(p, c"invalid unicode escape")
                    emit(p, advance(p))
        else if c < 32  # Control character
            return set_error(p, c"invalid control character in string")
        else
            emit(p, advance(p))

    return set_error(p, c"unterminated string")

fn parse_number(p: *JsonParser) -> i32
    var c: u8 = peek(p)

    # Optional minus sign
    if c == '-'  # '-'
        emit(p, advance(p))
        c = peek(p)

    # Integer part
    if c == '0'  # '0'
        emit(p, advance(p))
    else if c >= 49 and c <= '9'  # '1'-'9'
        while p.pos < p.len
            let d: u8 = peek(p)
            if d < '0' or d > '9'
                break
            emit(p, advance(p))
    else
        return set_error(p, c"invalid number")

    # Fractional part
    if peek(p) == '.'  # '.'
        emit(p, advance(p))
        if p.pos >= p.len
            return set_error(p, c"expected digit after decimal point")
        let d: u8 = peek(p)
        if d < '0' or d > '9'
            return set_error(p, c"expected digit after decimal point")
        while p.pos < p.len
            let d2: u8 = peek(p)
            if d2 < '0' or d2 > '9'
                break
            emit(p, advance(p))

    # Exponent part
    let e: u8 = peek(p)
    if e == 'e' or e == 69  # 'e' or 'E'
        emit(p, advance(p))
        let sign: u8 = peek(p)
        if sign == '+' or sign == '-'  # '+' or '-'
            emit(p, advance(p))
        if p.pos >= p.len
            return set_error(p, c"expected digit in exponent")
        let d: u8 = peek(p)
        if d < '0' or d > '9'
            return set_error(p, c"expected digit in exponent")
        while p.pos < p.len
            let d2: u8 = peek(p)
            if d2 < '0' or d2 > '9'
                break
            emit(p, advance(p))

    return 0

fn match_keyword(p: *JsonParser, keyword: *u8, len: i64) -> i32
    if p.pos + len > p.len
        return 0
    for i in 0..len
        if *(p.data + p.pos + i) != *(keyword + i)
            return 0
    p.pos = p.pos + len
    return 1

# Forward-style: parse_value needs parse_array/parse_object which need parse_value
# Solution: Use a dispatch approach with a recursive parse_value

fn parse_value(p: *JsonParser) -> i32
    skip_whitespace(p)
    let c: u8 = peek(p)

    if c == '"'  # '"' - string
        return parse_string(p)

    if c == '{'  # '{' - object
        # Inline object parsing to avoid forward reference
        if expect(p, 123) != 0
            return -1
        p.depth = p.depth + 1
        if p.depth > MAX_DEPTH
            return set_error(p, c"maximum nesting depth exceeded")
        emit(p, 123)  # '{'

        skip_whitespace(p)
        if peek(p) == '}'  # '}' - empty object
            advance(p)
            p.depth = p.depth - 1
            emit(p, 125)
            return 0

        var first: i32 = 1
        while p.error == 0
            if first == 0
                if expect(p, 44) != 0
                    return -1
                emit(p, 44)
            first = 0

            write_indent(p)

            # Key
            skip_whitespace(p)
            if parse_string(p) != 0
                return -1

            emit(p, 58)  # ':'
            if p.compact == 0
                emit(p, 32)  # space

            # Colon
            skip_whitespace(p)
            if expect(p, 58) != 0
                return -1

            # Value (recursive)
            skip_whitespace(p)
            if parse_value(p) != 0
                return -1

            skip_whitespace(p)
            if peek(p) == '}'
                break

        p.depth = p.depth - 1
        write_indent(p)

        if expect(p, 125) != 0
            return -1
        emit(p, 125)
        return 0

    if c == '['  # '[' - array
        # Inline array parsing
        if expect(p, 91) != 0
            return -1
        p.depth = p.depth + 1
        if p.depth > MAX_DEPTH
            return set_error(p, c"maximum nesting depth exceeded")
        emit(p, 91)  # '['

        skip_whitespace(p)
        if peek(p) == ']'  # ']' - empty array
            advance(p)
            p.depth = p.depth - 1
            emit(p, 93)
            return 0

        var first: i32 = 1
        while p.error == 0
            if first == 0
                if expect(p, 44) != 0
                    return -1
                emit(p, 44)
            first = 0

            write_indent(p)

            skip_whitespace(p)
            if parse_value(p) != 0
                return -1

            skip_whitespace(p)
            if peek(p) == ']'
                break

        p.depth = p.depth - 1
        write_indent(p)

        if expect(p, 93) != 0
            return -1
        emit(p, 93)
        return 0

    if c == 't'  # 't' - true
        if match_keyword(p, c"true", 4) != 0
            emit_str(p, c"true")
            return 0
        return set_error(p, c"invalid token")

    if c == 'f'  # 'f' - false
        if match_keyword(p, c"false", 5) != 0
            emit_str(p, c"false")
            return 0
        return set_error(p, c"invalid token")

    if c == 'n'  # 'n' - null
        if match_keyword(p, c"null", 4) != 0
            emit_str(p, c"null")
            return 0
        return set_error(p, c"invalid token")

    if c == '-' or (c >= '0' and c <= '9')  # '-' or digit
        return parse_number(p)

    if c == 0
        return set_error(p, c"unexpected end of input")

    return set_error(p, c"unexpected character")

# ============================================================================
# File reading
# ============================================================================

fn read_file(path: *u8, buf: *Vec<u8>) -> i32
    let fd: i32 = sys_open(path, 0)  # O_RDONLY
    if fd < 0
        return -1

    var tmp: [4096]u8
    while 1 == 1
        let n: i64 = sys_read(fd, &tmp[0], 4096)
        if n < 0
            sys_close(fd)
            return -1
        if n == 0
            break
        vec_push_bytes<u8>(buf, &tmp[0], n)

    sys_close(fd)
    return 0

fn read_stdin(buf: *Vec<u8>) -> i32
    var tmp: [4096]u8
    while 1 == 1
        let n: i64 = sys_read(0, &tmp[0], 4096)
        if n < 0
            return -1
        if n == 0
            break
        vec_push_bytes<u8>(buf, &tmp[0], n)
    return 0

# ============================================================================
# Main
# ============================================================================

fn main(argc: i32, argv: **u8) -> i32
    var argparser: ArgParser
    args_init(&argparser, c"json", c"JSON validator and pretty printer")
    args_flag(&argparser, 'c', c"compact", c"Output compact JSON (no whitespace)")
    args_flag(&argparser, 'v', c"validate", c"Validate only (no output)")
    args_positional(&argparser, c"FILE", c"JSON file to process (stdin if omitted)", 0, 1)

    if args_parse(&argparser, argc, argv) != 0
        return 1

    let compact: i32 = args_get_flag(&argparser, 'c')
    let validate_only: i32 = args_get_flag(&argparser, 'v')

    # Read input
    var input: Vec<u8> = vec_new<u8>()

    if argparser.positional_count > 0
        let path: *u8 = args_get_positional(&argparser, 0)
        if read_file(path, &input) != 0
            eprints("json: cannot read file: ")
            eprints(path)
            eprints("\n")
            return 1
    else
        if read_stdin(&input) != 0
            eprints("json: cannot read stdin\n")
            return 1

    # Null-terminate for safety
    vec_push<u8>(&input, 0)

    # Parse JSON
    var output: Vec<u8> = vec_new<u8>()
    var parser: JsonParser
    parser_init(&parser, input.data, input.len - 1, &output, compact)

    if parse_value(&parser) != 0
        eprints("json: ")
        eprints(parser.error_msg)
        eprints("\n")
        return 1

    # Check for trailing content
    skip_whitespace(&parser)
    if parser.pos < parser.len
        eprints("json: unexpected content after value\n")
        return 1

    # Output result
    if validate_only == 0
        sys_write(1, output.data, output.len)
        sys_write(1, c"\n", 1)

    # Drop is automatic via RAII
    return 0
