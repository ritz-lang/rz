# Tests for 43_toml — TOML parser.
import ritzlib.testlib

[[test]]
fn test_toml_simple_kv() -> i32
    var argv: [2]*u8
    argv[0] = c"./toml"
    argv[1] = null
    var out: [4096]u8
    var n: i64 = 0
    let rc: i32 = exec_capture(c"./toml", @argv[0], null, c"name = \"test\"\nversion = \"1.0\"", 29, @out[0], 4096, @n)
    assert rc == 0, "exit 0 on valid TOML"
    assert buf_contains(@out[0], n, c"name", 4) == 1, "output should contain key 'name'"
    0

[[test]]
fn test_toml_get_key() -> i32
    var argv: [4]*u8
    argv[0] = c"./toml"
    argv[1] = c"-g"
    argv[2] = c"name"
    argv[3] = null
    var out: [4096]u8
    var n: i64 = 0
    let rc: i32 = exec_capture(c"./toml", @argv[0], null, c"name = \"myapp\"\nversion = \"2.0\"", 30, @out[0], 4096, @n)
    assert rc == 0, "exit 0 on -g name"
    assert buf_contains(@out[0], n, c"myapp", 5) == 1, "output should contain value 'myapp'"
    0
