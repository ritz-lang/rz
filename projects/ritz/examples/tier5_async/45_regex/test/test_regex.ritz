# Tests for 45_regex — regex matcher (grep-like).
import ritzlib.testlib

[[test]]
fn test_regex_literal_match() -> i32
    var argv: [3]*u8
    argv[0] = c"./regex"
    argv[1] = c"hello"
    argv[2] = null
    var out: [4096]u8
    var n: i64 = 0
    let rc: i32 = exec_capture(c"./regex", @argv[0], null, c"hello\nworld\n", 12, @out[0], 4096, @n)
    assert rc == 0, "exit 0 on literal match"
    assert buf_contains(@out[0], n, c"hello", 5) == 1, "output should contain 'hello'"
    0

[[test]]
fn test_regex_dot_matches_any() -> i32
    var argv: [3]*u8
    argv[0] = c"./regex"
    argv[1] = c"ca."
    argv[2] = null
    var out: [4096]u8
    var n: i64 = 0
    let rc: i32 = exec_capture(c"./regex", @argv[0], null, c"cat\ncar\ncan\n", 12, @out[0], 4096, @n)
    assert rc == 0, "exit 0 on dot match"
    # All three lines should match
    var nl: i64 = 0
    var i: i64 = 0
    while i < n
        if *(@out[0] + i) == 10
            nl += 1
        i += 1
    assert nl == 3, "should match all 3 lines"
    0
