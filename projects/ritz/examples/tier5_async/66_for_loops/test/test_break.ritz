# Test that break works in for loops

import ritzlib.io

[[test]]
fn test_for_break() -> i32
    var sum: i32 = 0
    for i in 0..10
        if i == 5
            break
        sum += i
    # 0+1+2+3+4 = 10
    assert sum == 10
    0

[[test]]
fn test_for_continue() -> i32
    var sum: i32 = 0
    for i in 0..10
        if i % 2 == 0
            continue
        sum += i
    # 1+3+5+7+9 = 25
    assert sum == 25
    0
