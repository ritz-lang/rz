# Tests for the `heap` keyword
#
# The `heap` keyword allocates a value on the heap and returns a pointer:
#   let p = heap expr    // p is *T
#   *p = 100             // modify value
#   free(p as *u8)       // cleanup

import ritzlib.memory
import ritzlib.io

# Simple struct for testing
struct Point
    x: i64
    y: i64

fn point_new(x: i64, y: i64) -> Point
    return Point { x: x, y: y }

# ============================================================================
# Basic heap keyword tests
# ============================================================================

[[test]]
fn test_heap_i64() -> i32
    # heap allocates an i64 on the heap, returns *i64
    let p = heap 42
    assert p != null, "heap should return valid pointer"
    assert *p == 42, "value should be 42"
    free(p as *u8)
    0

[[test]]
fn test_heap_set() -> i32
    let p = heap 10
    assert *p == 10, "initial value"
    *p = 20
    assert *p == 20, "after set"
    free(p as *u8)
    0

[[test]]
fn test_heap_struct() -> i32
    let p = heap point_new(3, 4)
    assert p != null, "pointer should be valid"
    # Access through pointer with auto-deref
    assert p.x == 3, "x should be 3"
    assert p.y == 4, "y should be 4"
    free(p as *u8)
    0

[[test]]
fn test_heap_expression() -> i32
    # heap works with any expression - use parens for compound exprs
    let x = 10
    let y = 20
    let p = heap (x + y)
    assert *p == 30, "10 + 20 = 30"
    free(p as *u8)
    0

[[test]]
fn test_heap_modify_struct() -> i32
    let p = heap point_new(1, 2)
    # Modify via auto-deref
    p.x = 10
    p.y = 20
    assert p.x == 10, "modified x"
    assert p.y == 20, "modified y"
    free(p as *u8)
    0

# ============================================================================
# Main entry point
# ============================================================================

fn main() -> i32
    0
