import ritzlib.string
import ritzlib.io
import ritzlib.result

# Test that Result<String, i32> works correctly
fn create_greeting(name: *u8) -> Result<String, i32>
    if name == null
        return Err(1)
    var s: String = string_new()
    string_push_str(@s, c"Hello, ")
    string_push_str(@s, name)
    string_push(@s, '!' as u8)
    return Ok(s)

fn handle_ok(greeting: String) -> i32
    print_string(@greeting)
    prints("\n")
    string_drop(@greeting)
    0

fn handle_err(code: i32) -> i32
    prints("Error: ")
    print_int(code as i64)
    prints("\n")
    1

fn main() -> i32
    # Test Ok case
    var result: Result<String, i32> = create_greeting(c"World")
    match result
        Ok(greeting) => handle_ok(greeting)
        Err(code) => handle_err(code)
