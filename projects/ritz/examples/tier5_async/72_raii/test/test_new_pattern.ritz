# Tests for constructor patterns
#
# Ritz encourages initializing structs at declaration using constructor
# functions. This eliminates the period between declaration and init.
#
# Current pattern: typename_new() functions
# Future pattern: Type::new() static method calls

import ritzlib.memory
import ritzlib.str
import ritzlib.io

# Simple struct with constructor
struct Point
    x: i64
    y: i64

fn point_new(x: i64, y: i64) -> Point
    return Point { x: x, y: y }

fn point_origin() -> Point
    return Point { x: 0, y: 0 }

fn point_distance_squared(self: @Point) -> i64
    return self.x * self.x + self.y * self.y

# Struct with default values
struct Config
    debug: bool
    max_retries: i32
    timeout_ms: i64

fn config_new() -> Config
    return Config { debug: false, max_retries: 3, timeout_ms: 5000 }

fn config_debug_mode() -> Config
    return Config { debug: true, max_retries: 10, timeout_ms: 30000 }

# Struct wrapping a resource
struct Buffer
    data: *u8
    len: i64
    cap: i64

fn buffer_new(capacity: i64) -> Buffer
    let data = malloc(capacity)
    return Buffer { data: data, len: 0, cap: capacity }

fn buffer_with_data(src: *u8, len: i64) -> Buffer
    let data = malloc(len)
    memcpy(data, src, len)
    return Buffer { data: data, len: len, cap: len }

fn buffer_drop(self: @&Buffer)
    if self.data != null
        free(self.data)
    self.data = null
    self.len = 0
    self.cap = 0

[[test]]
fn test_point_new() -> i32
    var p = point_new(3, 4)
    assert p.x == 3, "x should be 3"
    assert p.y == 4, "y should be 4"
    0

[[test]]
fn test_point_origin() -> i32
    var p = point_origin()
    assert p.x == 0, "origin x should be 0"
    assert p.y == 0, "origin y should be 0"
    0

[[test]]
fn test_point_method() -> i32
    var p = point_new(3, 4)
    let d = point_distance_squared(&p)
    assert d == 25, "3^2 + 4^2 = 25"
    0

[[test]]
fn test_config_default() -> i32
    var cfg = config_new()
    assert not cfg.debug, "default debug should be false"
    assert cfg.max_retries == 3, "default retries should be 3"
    assert cfg.timeout_ms == 5000, "default timeout should be 5000"
    0

[[test]]
fn test_config_debug_mode() -> i32
    var cfg = config_debug_mode()
    assert cfg.debug, "debug mode should have debug=true"
    assert cfg.max_retries == 10, "debug mode retries should be 10"
    0

[[test]]
fn test_buffer_new() -> i32
    var buf = buffer_new(1024)
    assert buf.data != null, "buffer should be allocated"
    assert buf.len == 0, "new buffer should be empty"
    assert buf.cap == 1024, "capacity should be 1024"
    buffer_drop(&buf)
    0

[[test]]
fn test_buffer_with_data() -> i32
    let src = "hello"
    var buf = buffer_with_data(src, 5)
    assert buf.data != null, "buffer should be allocated"
    assert buf.len == 5, "length should be 5"
    assert *buf.data == 'h', "first byte should be 'h'"
    buffer_drop(&buf)
    0
