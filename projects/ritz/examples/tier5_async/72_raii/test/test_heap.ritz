# Tests for Heap<T> smart pointer and heap keyword
#
# Heap<T> is our smart pointer for heap allocation:
# - Allocates T on the heap
# - Automatic cleanup via Drop trait
# - Clear naming (not Rust's obscure "Box")
#
# The `heap` keyword provides sugar for Heap.new():
#   let p = heap point3d_new(1, 2, 3)
#   // equivalent to: let p = heap_new(point3d_new(1, 2, 3))
#
# Note: Type.method() static call syntax is a future feature.
# Currently we use typename_method() naming convention.

import ritzlib.memory
import ritzlib.box  # Current Box<T> - to be renamed/wrapped as Heap<T>
import ritzlib.io

# Test struct for heap allocation
struct Point3D
    x: i64
    y: i64
    z: i64

fn point3d_new(x: i64, y: i64, z: i64) -> Point3D
    return Point3D { x: x, y: y, z: z }

fn point3d_origin() -> Point3D
    return Point3D { x: 0, y: 0, z: 0 }

fn point3d_magnitude_squared(self: @Point3D) -> i64
    return self.x * self.x + self.y * self.y + self.z * self.z

# Currently using Box<T> - will be Heap<T> after rename

[[test]]
fn test_box_i64() -> i32
    var b: Box<i64> = box_new<i64>(42)
    assert b.valid() == 1, "box should be valid"
    assert b.get() == 42, "value should be 42"
    b.drop()
    0

[[test]]
fn test_box_set() -> i32
    var b: Box<i64> = box_new<i64>(10)
    assert b.get() == 10, "initial value"
    b.set(20)
    assert b.get() == 20, "after set"
    b.drop()
    0

[[test]]
fn test_box_pointer_access() -> i32
    var b: Box<i64> = box_new<i64>(100)
    let ptr = b.as_ptr()
    assert ptr != null, "pointer should be valid"
    assert *ptr == 100, "deref should give value"
    *ptr = 200
    assert b.get() == 200, "mutation via pointer"
    b.drop()
    0

# Future: Box<Point3D> (compound types in Box)
# This requires generic monomorphization to work correctly

[[test]]
fn test_stack_point3d() -> i32
    # For now, test Point3D on stack
    var p = point3d_new(1, 2, 3)
    assert p.x == 1, "x"
    assert p.y == 2, "y"
    assert p.z == 3, "z"
    assert point3d_magnitude_squared(&p) == 14, "1+4+9=14"
    0

