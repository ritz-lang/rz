# Tests for allocator trait (future)
#
# trait Allocator
#     fn alloc(self: @&Self, size: i64) -> *u8
#     fn free(self: @&Self, ptr: *u8)
#
# struct Arena implements Allocator
# struct GlobalAlloc implements Allocator (default)

[[test]]
fn test_arena_basic() -> i32
    # Arena already exists in memory.ritz
    var arena = arena_new(4096)
    assert arena_valid(&arena) == 1, "arena should be valid"

    let p1 = arena_alloc(&arena, 100)
    assert p1 != null, "first alloc"

    let p2 = arena_alloc(&arena, 200)
    assert p2 != null, "second alloc"

    # Different pointers
    assert p1 != p2, "different allocations"

    arena_destroy(&arena)
    0

[[test]]
fn test_arena_reset() -> i32
    var arena = arena_new(4096)

    let p1 = arena_alloc(&arena, 100)
    let used1 = arena_used(&arena)

    arena_reset(&arena)
    assert arena_used(&arena) == 0, "reset clears usage"

    let p2 = arena_alloc(&arena, 100)
    # After reset, p2 might equal p1 (reusing memory)

    arena_destroy(&arena)
    0

[[test]]
fn test_malloc_free() -> i32
    let p = malloc(256)
    assert p != null, "malloc should succeed"

    # Write some data
    *p = 42

    free(p)
    # p is now invalid - don't use
    0

[[test]]
fn test_calloc_zeros() -> i32
    let p = calloc(10, 8)  # 10 elements of 8 bytes
    assert p != null, "calloc should succeed"

    # Should be zeroed
    for i in 0..10
        let ptr = (p as i64 + i * 8) as *i64
        assert *ptr == 0, "should be zero"

    free(p)
    0
