# Tests for borrowing semantics
#
# Borrowing allows temporary access without ownership transfer:
# - @T: immutable borrow (can read, cannot modify)
# - @&T: mutable borrow (can read and modify)
# - Borrows don't extend the lifetime of the value
# - Original owner retains ownership and cleanup responsibility
#
# Note: Type.method() static call syntax is a future feature.
# Currently we use typename_method() naming convention.

import ritzlib.memory
import ritzlib.io

struct Data
    value: i64
    name: *u8

fn data_new(value: i64, name: *u8) -> Data
    return Data { value: value, name: name }

# Immutable borrow - can only read
fn read_value(d: @Data) -> i64
    return d.value

fn read_name(d: @Data) -> *u8
    return d.name

# Mutable borrow - can modify
fn set_value(d: @&Data, new_value: i64)
    d.value = new_value

fn increment(d: @&Data)
    d.value += 1

# Multiple immutable borrows are OK
fn sum_values(a: @Data, b: @Data) -> i64
    return a.value + b.value

[[test]]
fn test_immutable_borrow() -> i32
    var d = data_new(42, c"test")

    let v = read_value(&d)
    assert v == 42, c"should read 42"

    # d is still valid
    assert d.value == 42, c"original unchanged"
    0

[[test]]
fn test_mutable_borrow() -> i32
    var d = data_new(10, c"mutable")

    set_value(&d, 20)
    assert d.value == 20, c"should be modified"

    increment(&d)
    assert d.value == 21, c"should be incremented"
    0

[[test]]
fn test_multiple_immutable_borrows() -> i32
    var a = data_new(10, c"a")
    var b = data_new(20, c"b")

    let total = sum_values(&a, &b)
    assert total == 30, c"10 + 20 = 30"

    # Both still valid
    assert a.value == 10, c"a unchanged"
    assert b.value == 20, c"b unchanged"
    0

[[test]]
fn test_borrow_in_loop() -> i32
    var d = data_new(0, c"loop")

    for i in 0..5
        increment(&d)

    assert d.value == 5, c"incremented 5 times"
    0

# Borrowing array elements
struct IntArray
    data: *i64
    len: i64

fn int_array_new(len: i64) -> IntArray
    let data = malloc(len * 8) as *i64
    return IntArray { data: data, len: len }

fn int_array_get(self: @IntArray, index: i64) -> i64
    return *(self.data + index)

fn int_array_set(self: @&IntArray, index: i64, value: i64)
    *(self.data + index) = value

fn int_array_drop(self: @&IntArray)
    if self.data != null
        free(self.data as *u8)
    self.data = null
    self.len = 0

[[test]]
fn test_array_borrow() -> i32
    var arr = int_array_new(5)

    # Mutable borrow to set values
    for i in 0..5
        int_array_set(&arr, i, i * 10)

    # Immutable borrow to read
    assert int_array_get(&arr, 0) == 0, c"index 0"
    assert int_array_get(&arr, 2) == 20, c"index 2"
    assert int_array_get(&arr, 4) == 40, c"index 4"

    int_array_drop(&arr)
    0

# Self-borrow in methods
struct Counter2
    count: i64

fn counter2_new() -> Counter2
    return Counter2 { count: 0 }

fn counter2_get(self: @Counter2) -> i64
    return self.count

fn counter2_inc(self: @&Counter2)
    self.count += 1

fn counter2_add(self: @&Counter2, n: i64)
    self.count += n

[[test]]
fn test_method_borrows() -> i32
    var c = counter2_new()

    assert counter2_get(&c) == 0, c"initial"

    counter2_inc(&c)
    assert counter2_get(&c) == 1, c"after inc"

    counter2_add(&c, 10)
    assert counter2_get(&c) == 11, c"after add"
    0

# Borrow through pointer
fn get_via_ptr(p: *Data) -> i64
    return p.value

fn set_via_ptr(p: *Data, v: i64)
    p.value = v

[[test]]
fn test_pointer_access() -> i32
    var d = data_new(100, c"ptr")

    let ptr: *Data = &d
    assert get_via_ptr(ptr) == 100, c"read via ptr"

    set_via_ptr(ptr, 200)
    assert d.value == 200, c"modified via ptr"
    0

# Reborrowing - taking a reference from a reference
fn borrow_from_ref(d: @Data) -> i64
    # Can create another immutable borrow
    let v = read_value(d)
    return v

[[test]]
fn test_reborrow() -> i32
    var d = data_new(55, c"reborrow")
    let v = borrow_from_ref(&d)
    assert v == 55, c"reborrowed value"
    0
