# RAII (Resource Acquisition Is Initialization) Demo
#
# This example demonstrates the Ritz ownership and cleanup model:
# 1. Constructor functions - structs initialized at declaration
# 2. Drop trait - automatic cleanup at scope exit
# 3. Box<T> - smart pointer with automatic deallocation
# 4. Move semantics - ownership transfer
# 5. Borrowing - temporary references without ownership transfer
#
# Note: The .new() method call syntax (Type.new) is a future feature.
# Currently we use typename_method() naming convention.

import ritzlib.memory
import ritzlib.box
import ritzlib.io

# A simple resource that tracks its lifetime
struct Counter
    value: i64
    id: i64

# Constructor function (current pattern - will become Counter.new)
fn counter_new(id: i64, start: i64) -> Counter
    print(c"counter_new: id={id}, start={start}\n")
    return Counter { value: start, id: id }

fn counter_increment(self: @&Counter)
    self.value += 1

fn counter_get(self: @Counter) -> i64
    return self.value

# Drop implementation - called manually for now
# Will be automatic at scope exit once Drop trait is enforced
fn counter_drop(self: @&Counter)
    print(c"counter_drop: id={self.id}, final_value={self.value}\n")

fn demo_stack_raii()
    print(c"\n=== Stack RAII Demo ===\n")

    # Value created with constructor function
    var counter = counter_new(1, 0)

    counter_increment(&counter)
    counter_increment(&counter)
    counter_increment(&counter)

    print(c"Value after increments: {counter_get(&counter)}\n")

    # Manual cleanup - will be automatic once Drop trait is enforced
    counter_drop(&counter)

fn demo_box_raii()
    print(c"\n=== Box<T> RAII Demo ===\n")

    # Using Box<T> for heap allocation
    var boxed: Box<i64> = box_new<i64>(42)

    print(c"Boxed value: {boxed.get()}\n")

    boxed.set(100)
    print(c"After set: {boxed.get()}\n")

    # Manual cleanup - will be automatic once Drop trait is enforced
    boxed.drop()

fn demo_scope_cleanup()
    print(c"\n=== Scope Cleanup Demo ===\n")

    var outer = counter_new(10, 0)

    if true
        var inner = counter_new(20, 10)
        counter_increment(&inner)
        print(c"Inner value: {counter_get(&inner)}\n")
        # Manual cleanup at end of scope
        counter_drop(&inner)

    counter_increment(&outer)
    print(c"Outer value: {counter_get(&outer)}\n")
    # Manual cleanup at end of function
    counter_drop(&outer)

fn main() -> i32
    print(c"RAII Pattern Demonstrations\n")
    print(c"===========================\n")

    demo_stack_raii()
    demo_box_raii()
    demo_scope_cleanup()

    print(c"\n=== All demos complete ===\n")
    0
