# Tests for 46_markdown — Markdown to HTML converter.
import ritzlib.testlib

[[test]]
fn test_md_h1() -> i32
    var argv: [2]*u8
    argv[0] = c"./md"
    argv[1] = null
    var out: [4096]u8
    var n: i64 = 0
    let rc: i32 = exec_capture(c"./md", @argv[0], null, c"# Hello\n", 8, @out[0], 4096, @n)
    assert rc == 0, "exit 0"
    assert buf_contains(@out[0], n, c"<h1>Hello</h1>", 14) == 1, "h1 conversion"
    0

[[test]]
fn test_md_h2() -> i32
    var argv: [2]*u8
    argv[0] = c"./md"
    argv[1] = null
    var out: [4096]u8
    var n: i64 = 0
    let rc: i32 = exec_capture(c"./md", @argv[0], null, c"## Level 2\n", 11, @out[0], 4096, @n)
    assert rc == 0, "exit 0"
    assert buf_contains(@out[0], n, c"<h2>Level 2</h2>", 16) == 1, "h2 conversion"
    0

[[test]]
fn test_md_bold() -> i32
    var argv: [2]*u8
    argv[0] = c"./md"
    argv[1] = null
    var out: [4096]u8
    var n: i64 = 0
    let rc: i32 = exec_capture(c"./md", @argv[0], null, c"**bold**\n", 9, @out[0], 4096, @n)
    assert rc == 0, "exit 0"
    assert buf_contains(@out[0], n, c"<strong>bold</strong>", 21) == 1, "bold → <strong>"
    0

[[test]]
fn test_md_italic() -> i32
    var argv: [2]*u8
    argv[0] = c"./md"
    argv[1] = null
    var out: [4096]u8
    var n: i64 = 0
    let rc: i32 = exec_capture(c"./md", @argv[0], null, c"*italic*\n", 9, @out[0], 4096, @n)
    assert rc == 0, "exit 0"
    assert buf_contains(@out[0], n, c"<em>italic</em>", 15) == 1, "italic → <em>"
    0
