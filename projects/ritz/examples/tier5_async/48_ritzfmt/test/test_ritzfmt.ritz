# Tests for 48_ritzfmt — Ritz source formatter.
import ritzlib.testlib

[[test]]
fn test_ritzfmt_strips_trailing_whitespace() -> i32
    var argv: [2]*u8
    argv[0] = c"./ritzfmt"
    argv[1] = null
    var out: [4096]u8
    var n: i64 = 0
    # Input has trailing spaces on each line.
    let rc: i32 = exec_capture(c"./ritzfmt", @argv[0], null, c"fn foo()   \n    return 0  \n", 27, @out[0], 4096, @n)
    assert rc == 0, "exit 0"
    # Output should have "fn foo()\n" exactly (no trailing whitespace).
    assert buf_contains(@out[0], n, c"fn foo()\n", 9) == 1, "trailing whitespace stripped"
    0

[[test]]
fn test_ritzfmt_normalizes_blank_lines() -> i32
    var argv: [2]*u8
    argv[0] = c"./ritzfmt"
    argv[1] = null
    var out: [4096]u8
    var n: i64 = 0
    # 4 blank lines collapsed to ≤ 1.
    let rc: i32 = exec_capture(c"./ritzfmt", @argv[0], null, c"fn foo()\n\n\n\n    x\n", 18, @out[0], 4096, @n)
    assert rc == 0, "exit 0"
    # Count newlines — should be at most 4 (header + blank + body + trailing).
    var nl: i64 = 0
    var i: i64 = 0
    while i < n
        if *(@out[0] + i) == 10
            nl += 1
        i += 1
    assert nl <= 4, "blank lines should collapse to ≤ 4 newlines"
    0
