# Test string interpolation

[[test]]
fn test_simple_interp() -> i32
    let x: i32 = 42
    c"x = {x}\n"
    0

[[test]]
fn test_multiple_values() -> i32
    let a: i32 = 1
    let b: i32 = 2
    c"{a} + {b} = {a + b}\n"
    0

[[test]]
fn test_string_interp() -> i32
    let name = c"Ritz"
    c"Hello, {name}!\n"
    0

[[test]]
fn test_negative() -> i32
    let n: i32 = -123
    c"negative: {n}\n"
    0
