# Tests for 49_ritzgen — generator that consumes a .grammar file and
# emits a parser/lexer.  Tests use the bundled grammars/ritz.grammar.

import ritzlib.testlib

[[test]]
fn test_ritzgen_loads_grammar() -> i32
    var argv: [3]*u8
    argv[0] = c"./ritzgen"
    argv[1] = c"grammars/ritz.grammar"
    argv[2] = null

    var out: [16384]u8
    var n: i64 = 0
    let rc: i32 = exec_capture(c"./ritzgen", @argv[0], null, null, 0, @out[0], 16384, @n)
    assert rc == 0, "ritzgen <grammar> should exit 0"
    assert buf_contains(@out[0], n, c"token definitions", 17) == 1, "should report token count"
    assert buf_contains(@out[0], n, c"grammar rules", 13) == 1, "should report rule count"
    0
