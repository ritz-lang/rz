# ritzgen - Ritz Parser Generator
#
# Usage: ritzgen [OPTIONS] GRAMMAR_FILE [INPUT_FILE]
#
# Modes:
#   ritzgen grammar.ritz              # Generate lexer/parser code
#   ritzgen grammar.ritz input.ritz   # Lex input file, print tokens
#   ritzgen -t grammar.ritz dir/      # Test: lex all .ritz files in dir
#
# Options:
#   -t, --test      Test mode: lex files and report errors
#   -v, --verbose   Verbose output (show all tokens)
#   -o, --output    Output file for generated code
#
# Grammar file format:
#   %tokens         # Token definitions section
#   NAME = "lit"    # Literal token
#   NAME = /regex/  # Pattern token
#   %skip           # Mark following tokens as skip
#   %grammar        # Grammar rules (future)

import ritzlib.sys
import ritzlib.io
import ritzlib.str
import ritzlib.args
import ritzlib.vec
import ritzlib.fs

# =============================================================================
# Token types for the generated lexer
# =============================================================================

const TOK_EOF: i32 = 0
const TOK_ERROR: i32 = 1
const TOK_SKIP: i32 = 2      # Whitespace etc - to be skipped
const TOK_NEWLINE: i32 = 3
const TOK_INDENT: i32 = 4
const TOK_DEDENT: i32 = 5

# =============================================================================
# Token definition structure
# =============================================================================

struct TokenDef
    name: *u8           # Token name (e.g., "FN")
    name_len: i32
    pattern: *u8        # Pattern or literal
    pattern_len: i32
    is_literal: i32     # 1 if exact string, 0 if regex
    is_skip: i32        # 1 if should be skipped
    token_id: i32       # Assigned token ID

# Token definition storage (max 256 tokens)
struct TokenDefs
    defs: [256]TokenDef
    count: i32
    next_id: i32        # Next token ID to assign

# =============================================================================
# Grammar rule structures
# =============================================================================

# Symbol types in grammar rules
const SYM_TERMINAL: i32 = 0     # TOKEN (uppercase)
const SYM_NONTERMINAL: i32 = 1  # rule_name (lowercase)
const SYM_STAR: i32 = 2         # symbol* (zero or more)
const SYM_PLUS: i32 = 3         # symbol+ (one or more)
const SYM_OPTIONAL: i32 = 4     # symbol? (optional)
const SYM_GROUP: i32 = 5        # (...) grouping

# A symbol in a grammar alternative
struct GrammarSymbol
    kind: i32           # SYM_* constant
    name: *u8           # Symbol name (token or rule name)
    name_len: i32
    # For SYM_GROUP: contains nested alternatives
    group_alts: *GrammarAlt
    group_alt_count: i32

# An alternative (sequence of symbols)
struct GrammarAlt
    symbols: [16]GrammarSymbol   # Reduced from 32
    symbol_count: i32

# A grammar rule (name and alternatives)
struct GrammarRule
    name: *u8
    name_len: i32
    alts: [8]GrammarAlt          # Reduced from 16
    alt_count: i32

# Grammar storage
struct Grammar
    rules: [64]GrammarRule       # Reduced from 128
    rule_count: i32

# =============================================================================
# AST Node Definitions
# =============================================================================

# Expression kinds
const EXPR_INT: i32 = 1
const EXPR_STRING: i32 = 2
const EXPR_CHAR: i32 = 3
const EXPR_BOOL: i32 = 4
const EXPR_IDENT: i32 = 5
const EXPR_BINARY: i32 = 6
const EXPR_UNARY: i32 = 7
const EXPR_CALL: i32 = 8
const EXPR_INDEX: i32 = 9
const EXPR_FIELD: i32 = 10
const EXPR_CAST: i32 = 11
const EXPR_STRUCT_LIT: i32 = 12
const EXPR_ARRAY_LIT: i32 = 13

# Binary operators
const OP_ADD: i32 = 1
const OP_SUB: i32 = 2
const OP_MUL: i32 = 3
const OP_DIV: i32 = 4
const OP_MOD: i32 = 5
const OP_EQ: i32 = 6
const OP_NE: i32 = 7
const OP_LT: i32 = 8
const OP_GT: i32 = 9
const OP_LE: i32 = 10
const OP_GE: i32 = 11
const OP_AND: i32 = 12
const OP_OR: i32 = 13
const OP_BIT_AND: i32 = 14
const OP_BIT_OR: i32 = 15
const OP_BIT_XOR: i32 = 16
const OP_SHL: i32 = 17
const OP_SHR: i32 = 18

# Unary operators
const OP_NEG: i32 = 20
const OP_NOT: i32 = 21
const OP_DEREF: i32 = 22
const OP_ADDR: i32 = 23
const OP_BIT_NOT: i32 = 24

# Statement kinds
const STMT_LET: i32 = 1
const STMT_VAR: i32 = 2
const STMT_ASSIGN: i32 = 3
const STMT_RETURN: i32 = 4
const STMT_IF: i32 = 5
const STMT_WHILE: i32 = 6
const STMT_FOR: i32 = 7
const STMT_BREAK: i32 = 8
const STMT_CONTINUE: i32 = 9
const STMT_EXPR: i32 = 10

# Type kinds
const TYPE_I8: i32 = 1
const TYPE_I16: i32 = 2
const TYPE_I32: i32 = 3
const TYPE_I64: i32 = 4
const TYPE_U8: i32 = 5
const TYPE_U16: i32 = 6
const TYPE_U32: i32 = 7
const TYPE_U64: i32 = 8
const TYPE_BOOL: i32 = 9
const TYPE_PTR: i32 = 10
const TYPE_ARRAY: i32 = 11
const TYPE_NAMED: i32 = 12

# Type node
struct AstType
    kind: i32
    inner: *AstType          # For TYPE_PTR: pointee type
    array_size: i32          # For TYPE_ARRAY
    name: *u8                # For TYPE_NAMED
    name_len: i32

# Expression node
struct AstExpr
    kind: i32
    line: i32
    col: i32
    int_val: i64             # EXPR_INT
    str_ptr: *u8             # EXPR_STRING, EXPR_IDENT
    str_len: i32
    char_val: u8             # EXPR_CHAR
    bool_val: i32            # EXPR_BOOL
    op: i32                  # EXPR_BINARY, EXPR_UNARY
    left: *AstExpr
    right: *AstExpr
    operand: *AstExpr
    callee: *AstExpr         # EXPR_CALL
    args: *AstExpr           # Linked list
    base: *AstExpr           # EXPR_INDEX
    index: *AstExpr
    field_name: *u8          # EXPR_FIELD
    field_name_len: i32
    cast_type: *AstType      # EXPR_CAST
    next: *AstExpr           # Linked list

# Statement node
struct AstStmt
    kind: i32
    line: i32
    col: i32
    var_name: *u8            # STMT_LET, STMT_VAR
    var_name_len: i32
    var_type: *AstType
    var_init: *AstExpr
    assign_target: *AstExpr  # STMT_ASSIGN
    assign_value: *AstExpr
    return_value: *AstExpr   # STMT_RETURN
    if_cond: *AstExpr        # STMT_IF
    if_then: *AstStmt
    if_else: *AstStmt
    loop_cond: *AstExpr      # STMT_WHILE, STMT_FOR
    loop_body: *AstStmt
    loop_var: *u8
    loop_var_len: i32
    loop_iter: *AstExpr
    expr: *AstExpr           # STMT_EXPR
    next: *AstStmt           # Linked list

# Parameter node
struct AstParam
    name: *u8
    name_len: i32
    param_type: *AstType
    next: *AstParam

# Function definition
struct AstFnDef
    name: *u8
    name_len: i32
    params: *AstParam
    return_type: *AstType
    body: *AstStmt
    next: *AstFnDef

# Struct field
struct AstField
    name: *u8
    name_len: i32
    field_type: *AstType
    next: *AstField

# Struct definition
struct AstStructDef
    name: *u8
    name_len: i32
    fields: *AstField
    next: *AstStructDef

# Const definition
struct AstConstDef
    name: *u8
    name_len: i32
    const_type: *AstType
    value: *AstExpr
    next: *AstConstDef

# Import statement
struct AstImport
    path: *u8
    path_len: i32
    next: *AstImport

# Module (top-level)
struct AstModule
    imports: *AstImport
    constants: *AstConstDef
    structs: *AstStructDef
    functions: *AstFnDef

# AST Allocator
struct AstAlloc
    base: *u8
    offset: i64
    capacity: i64

fn ast_alloc_init(alloc: *AstAlloc, size: i64)
    alloc.base = sys_mmap(0, size, 3, 34, 0 - 1, 0) as *u8
    alloc.offset = 0
    alloc.capacity = size

fn ast_alloc(alloc: *AstAlloc, size: i64) -> *u8
    let aligned: i64 = (size + 7) / 8 * 8
    if alloc.offset + aligned > alloc.capacity
        return 0 as *u8
    let ptr: *u8 = alloc.base + alloc.offset
    alloc.offset = alloc.offset + aligned
    var i: i64 = 0
    while i < aligned
        *(ptr + i) = 0
        i = i + 1
    ptr

fn ast_alloc_free(alloc: *AstAlloc)
    sys_munmap(alloc.base as i64, alloc.capacity)

fn ast_new_expr(alloc: *AstAlloc, kind: i32) -> *AstExpr
    let e: *AstExpr = ast_alloc(alloc, 256) as *AstExpr
    e.kind = kind
    e

fn ast_new_stmt(alloc: *AstAlloc, kind: i32) -> *AstStmt
    let s: *AstStmt = ast_alloc(alloc, 256) as *AstStmt
    s.kind = kind
    s

fn ast_new_type(alloc: *AstAlloc, kind: i32) -> *AstType
    let t: *AstType = ast_alloc(alloc, 48) as *AstType
    t.kind = kind
    t

fn ast_new_fn(alloc: *AstAlloc) -> *AstFnDef
    ast_alloc(alloc, 64) as *AstFnDef

fn ast_new_param(alloc: *AstAlloc) -> *AstParam
    ast_alloc(alloc, 40) as *AstParam

fn ast_new_struct(alloc: *AstAlloc) -> *AstStructDef
    ast_alloc(alloc, 48) as *AstStructDef

fn ast_new_field(alloc: *AstAlloc) -> *AstField
    ast_alloc(alloc, 40) as *AstField

fn ast_new_const(alloc: *AstAlloc) -> *AstConstDef
    ast_alloc(alloc, 48) as *AstConstDef

fn ast_new_import(alloc: *AstAlloc) -> *AstImport
    ast_alloc(alloc, 32) as *AstImport

fn ast_new_module(alloc: *AstAlloc) -> *AstModule
    ast_alloc(alloc, 40) as *AstModule

# =============================================================================
# AST Printing (for debugging)
# =============================================================================

fn ast_print_indent(depth: i32)
    var i: i32 = 0
    while i < depth
        prints("  ")
        i = i + 1

fn ast_op_name(op: i32) -> *u8
    if op == OP_ADD
        return "+"
    else if op == OP_SUB
        return "-"
    else if op == OP_MUL
        return "*"
    else if op == OP_DIV
        return "/"
    else if op == OP_MOD
        return "%"
    else if op == OP_EQ
        return "=="
    else if op == OP_NE
        return "!="
    else if op == OP_LT
        return "<"
    else if op == OP_GT
        return ">"
    else if op == OP_LE
        return "<="
    else if op == OP_GE
        return ">="
    else if op == OP_AND
        return "&&"
    else if op == OP_OR
        return "||"
    else if op == OP_BIT_AND
        return "&"
    else if op == OP_BIT_OR
        return "|"
    else if op == OP_BIT_XOR
        return "^"
    else if op == OP_SHL
        return "<<"
    else if op == OP_SHR
        return ">>"
    else if op == OP_NEG
        return "-"
    else if op == OP_NOT
        return "!"
    else if op == OP_DEREF
        return "*"
    else if op == OP_ADDR
        return "&"
    else if op == OP_BIT_NOT
        return "~"
    "?"

fn ast_print_type(t: *AstType)
    if t == 0 as *AstType
        prints("void")
        return
    if t.kind == TYPE_I8
        prints("i8")
    else if t.kind == TYPE_I16
        prints("i16")
    else if t.kind == TYPE_I32
        prints("i32")
    else if t.kind == TYPE_I64
        prints("i64")
    else if t.kind == TYPE_U8
        prints("u8")
    else if t.kind == TYPE_U16
        prints("u16")
    else if t.kind == TYPE_U32
        prints("u32")
    else if t.kind == TYPE_U64
        prints("u64")
    else if t.kind == TYPE_BOOL
        prints("bool")
    else if t.kind == TYPE_PTR
        prints("*")
        ast_print_type(t.inner)
    else if t.kind == TYPE_ARRAY
        prints("[")
        print_int(t.array_size as i64)
        prints("]")
        ast_print_type(t.inner)
    else if t.kind == TYPE_NAMED
        sys_write(1, t.name, t.name_len as i64)

fn ast_print_expr(e: *AstExpr, depth: i32)
    if e == 0 as *AstExpr
        return
    ast_print_indent(depth)
    if e.kind == EXPR_INT
        prints("Int(")
        print_int(e.int_val)
        prints(")\n")
    else if e.kind == EXPR_STRING
        prints("String(\"")
        sys_write(1, e.str_ptr, e.str_len as i64)
        prints("\")\n")
    else if e.kind == EXPR_IDENT
        prints("Ident(")
        sys_write(1, e.str_ptr, e.str_len as i64)
        prints(")\n")
    else if e.kind == EXPR_BINARY
        prints("Binary(")
        prints(ast_op_name(e.op))
        prints(")\n")
        ast_print_expr(e.left, depth + 1)
        ast_print_expr(e.right, depth + 1)
    else if e.kind == EXPR_UNARY
        prints("Unary(")
        prints(ast_op_name(e.op))
        prints(")\n")
        ast_print_expr(e.operand, depth + 1)
    else if e.kind == EXPR_CALL
        prints("Call\n")
        ast_print_indent(depth + 1)
        prints("callee:\n")
        ast_print_expr(e.callee, depth + 2)
        var arg: *AstExpr = e.args
        if arg != 0 as *AstExpr
            ast_print_indent(depth + 1)
            prints("args:\n")
            while arg != 0 as *AstExpr
                ast_print_expr(arg, depth + 2)
                arg = arg.next
    else if e.kind == EXPR_INDEX
        prints("Index\n")
        ast_print_indent(depth + 1)
        prints("base:\n")
        ast_print_expr(e.base, depth + 2)
        ast_print_indent(depth + 1)
        prints("index:\n")
        ast_print_expr(e.index, depth + 2)
    else if e.kind == EXPR_FIELD
        prints("Field\n")
        ast_print_indent(depth + 1)
        prints("base:\n")
        ast_print_expr(e.base, depth + 2)
        ast_print_indent(depth + 1)
        prints("field: ")
        sys_write(1, e.str_ptr, e.str_len as i64)
        prints("\n")
    else if e.kind == EXPR_CAST
        prints("Cast\n")
        ast_print_indent(depth + 1)
        prints("expr:\n")
        ast_print_expr(e.operand, depth + 2)
        ast_print_indent(depth + 1)
        prints("as: ")
        ast_print_type(e.cast_type)
        prints("\n")
    else
        prints("Expr(kind=")
        print_int(e.kind as i64)
        prints(")\n")

fn ast_print_stmt(s: *AstStmt, depth: i32)
    if s == 0 as *AstStmt
        return
    ast_print_indent(depth)
    if s.kind == STMT_LET
        prints("Let(")
        sys_write(1, s.var_name, s.var_name_len as i64)
        prints(": ")
        ast_print_type(s.var_type)
        prints(")\n")
        if s.var_init != 0 as *AstExpr
            ast_print_expr(s.var_init, depth + 1)
    else if s.kind == STMT_VAR
        prints("Var(")
        sys_write(1, s.var_name, s.var_name_len as i64)
        prints(": ")
        ast_print_type(s.var_type)
        prints(")\n")
        if s.var_init != 0 as *AstExpr
            ast_print_expr(s.var_init, depth + 1)
    else if s.kind == STMT_RETURN
        prints("Return\n")
        if s.return_value != 0 as *AstExpr
            ast_print_expr(s.return_value, depth + 1)
    else if s.kind == STMT_IF
        prints("If\n")
        ast_print_indent(depth + 1)
        prints("cond:\n")
        ast_print_expr(s.if_cond, depth + 2)
        ast_print_indent(depth + 1)
        prints("then:\n")
        var st: *AstStmt = s.if_then
        while st != 0 as *AstStmt
            ast_print_stmt(st, depth + 2)
            st = st.next
        if s.if_else != 0 as *AstStmt
            ast_print_indent(depth + 1)
            prints("else:\n")
            var el: *AstStmt = s.if_else
            while el != 0 as *AstStmt
                ast_print_stmt(el, depth + 2)
                el = el.next
    else if s.kind == STMT_WHILE
        prints("While\n")
        ast_print_indent(depth + 1)
        prints("cond:\n")
        ast_print_expr(s.loop_cond, depth + 2)
        ast_print_indent(depth + 1)
        prints("body:\n")
        var st: *AstStmt = s.loop_body
        while st != 0 as *AstStmt
            ast_print_stmt(st, depth + 2)
            st = st.next
    else if s.kind == STMT_ASSIGN
        prints("Assign\n")
        ast_print_indent(depth + 1)
        prints("target:\n")
        ast_print_expr(s.assign_target, depth + 2)
        ast_print_indent(depth + 1)
        prints("value:\n")
        ast_print_expr(s.assign_value, depth + 2)
    else if s.kind == STMT_EXPR
        prints("ExprStmt\n")
        ast_print_expr(s.expr, depth + 1)
    else
        prints("Stmt(kind=")
        print_int(s.kind as i64)
        prints(")\n")

fn ast_print_fn(f: *AstFnDef, depth: i32)
    ast_print_indent(depth)
    prints("Function(")
    sys_write(1, f.name, f.name_len as i64)
    prints(")\n")
    var p: *AstParam = f.params
    while p != 0 as *AstParam
        ast_print_indent(depth + 1)
        prints("param: ")
        sys_write(1, p.name, p.name_len as i64)
        prints(": ")
        ast_print_type(p.param_type)
        prints("\n")
        p = p.next
    ast_print_indent(depth + 1)
    prints("returns: ")
    ast_print_type(f.return_type)
    prints("\n")
    if f.body != 0 as *AstStmt
        ast_print_indent(depth + 1)
        prints("body:\n")
        var s: *AstStmt = f.body
        while s != 0 as *AstStmt
            ast_print_stmt(s, depth + 2)
            s = s.next

fn ast_print_module(m: *AstModule)
    prints("Module:\n")
    var imp: *AstImport = m.imports
    while imp != 0 as *AstImport
        prints("  Import(")
        sys_write(1, imp.path, imp.path_len as i64)
        prints(")\n")
        imp = imp.next
    var c: *AstConstDef = m.constants
    while c != 0 as *AstConstDef
        prints("  Const(")
        sys_write(1, c.name, c.name_len as i64)
        prints(")\n")
        c = c.next
    var st: *AstStructDef = m.structs
    while st != 0 as *AstStructDef
        prints("  Struct(")
        sys_write(1, st.name, st.name_len as i64)
        prints(")\n")
        st = st.next
    var f: *AstFnDef = m.functions
    while f != 0 as *AstFnDef
        ast_print_fn(f, 1)
        f = f.next

# =============================================================================
# AST Parser - builds AST from tokens
# =============================================================================

struct AstParser
    tokens: *Token
    count: i32
    pos: i32
    alloc: *AstAlloc
    defs: *TokenDefs
    error: i32

fn ast_parser_init(p: *AstParser, tokens: *Token, count: i32, alloc: *AstAlloc, defs: *TokenDefs)
    p.tokens = tokens
    p.count = count
    p.pos = 0
    p.alloc = alloc
    p.defs = defs
    p.error = 0

fn ap_current(p: *AstParser) -> *Token
    if p.pos >= p.count
        return 0 as *Token
    &p.tokens[p.pos]

fn ap_peek(p: *AstParser) -> i32
    let tok: *Token = ap_current(p)
    if tok == 0 as *Token
        return TOK_EOF
    tok.kind

fn ap_advance(p: *AstParser)
    if p.pos < p.count
        p.pos = p.pos + 1

fn ap_expect(p: *AstParser, kind: i32) -> i32
    if ap_peek(p) == kind
        ap_advance(p)
        return 1
    0

fn ap_match_indent(p: *AstParser) -> i32
    if ap_peek(p) == TOK_INDENT
        ap_advance(p)
        return 1
    0

fn ap_match_dedent(p: *AstParser) -> i32
    if ap_peek(p) == TOK_DEDENT
        ap_advance(p)
        return 1
    0

fn ap_skip_newlines(p: *AstParser)
    while ap_peek(p) == TOK_NEWLINE
        ap_advance(p)

# Token kind lookup by name
fn ap_token_kind(p: *AstParser, name: *u8) -> i32
    var i: i32 = 0
    while i < p.defs.count
        if streq(p.defs.defs[i].name, name) != 0
            return p.defs.defs[i].token_id
        i = i + 1
    return 0 - 1

# Check if current token matches a name
fn ap_check(p: *AstParser, name: *u8) -> i32
    let expected: i32 = ap_token_kind(p, name)
    if expected < 0
        return 0
    if ap_peek(p) == expected
        return 1
    0

# Match and advance if current token matches name
fn ap_match(p: *AstParser, name: *u8) -> i32
    if ap_check(p, name) != 0
        ap_advance(p)
        return 1
    0

# Get current token text
fn ap_text(p: *AstParser) -> *u8
    let tok: *Token = ap_current(p)
    if tok == 0 as *Token
        return ""
    tok.start

fn ap_text_len(p: *AstParser) -> i32
    let tok: *Token = ap_current(p)
    if tok == 0 as *Token
        return 0
    tok.len

fn ap_line(p: *AstParser) -> i32
    let tok: *Token = ap_current(p)
    if tok == 0 as *Token
        return 0
    tok.line

fn ap_col(p: *AstParser) -> i32
    let tok: *Token = ap_current(p)
    if tok == 0 as *Token
        return 0
    tok.col

# Parse error helper
fn ap_error(p: *AstParser, msg: *u8)
    p.error = 1
    eprints("Parse error at line ")
    eprint_int(ap_line(p) as i64)
    eprints(", col ")
    eprint_int(ap_col(p) as i64)
    eprints(": ")
    eprints(msg)
    eprints("\n")

# Forward declarations conceptually - these will be mutually recursive
# parse_expr, parse_primary, parse_binary, etc.

# =============================================================================
# Type parsing
# =============================================================================

fn ap_parse_type(p: *AstParser) -> *AstType
    # Handle pointer types: *T
    if ap_match(p, "STAR") != 0
        let inner: *AstType = ap_parse_type(p)
        if inner == 0 as *AstType
            return 0 as *AstType
        let t: *AstType = ast_new_type(p.alloc, TYPE_PTR)
        t.inner = inner
        return t

    # Handle array types: [N]T
    if ap_match(p, "LBRACKET") != 0
        # Parse size
        if ap_check(p, "NUMBER") == 0
            ap_error(p, "Expected array size")
            return 0 as *AstType
        let size_str: *u8 = ap_text(p)
        let size: i32 = atoi(size_str) as i32
        ap_advance(p)
        if ap_match(p, "RBRACKET") == 0
            ap_error(p, "Expected ']'")
            return 0 as *AstType
        let elem: *AstType = ap_parse_type(p)
        if elem == 0 as *AstType
            return 0 as *AstType
        let t: *AstType = ast_new_type(p.alloc, TYPE_ARRAY)
        t.array_size = size
        t.inner = elem
        return t

    # Primitive types
    if ap_match(p, "I8") != 0
        return ast_new_type(p.alloc, TYPE_I8)
    if ap_match(p, "I16") != 0
        return ast_new_type(p.alloc, TYPE_I16)
    if ap_match(p, "I32") != 0
        return ast_new_type(p.alloc, TYPE_I32)
    if ap_match(p, "I64") != 0
        return ast_new_type(p.alloc, TYPE_I64)
    if ap_match(p, "U8") != 0
        return ast_new_type(p.alloc, TYPE_U8)
    if ap_match(p, "U16") != 0
        return ast_new_type(p.alloc, TYPE_U16)
    if ap_match(p, "U32") != 0
        return ast_new_type(p.alloc, TYPE_U32)
    if ap_match(p, "U64") != 0
        return ast_new_type(p.alloc, TYPE_U64)
    if ap_match(p, "BOOL") != 0
        return ast_new_type(p.alloc, TYPE_BOOL)

    # Named type (struct name, etc)
    if ap_check(p, "IDENT") != 0
        let t: *AstType = ast_new_type(p.alloc, TYPE_NAMED)
        t.name = ap_text(p)
        t.name_len = ap_text_len(p)
        ap_advance(p)
        return t

    ap_error(p, "Expected type")
    0 as *AstType

# =============================================================================
# Expression parsing
# =============================================================================

fn ap_parse_primary(p: *AstParser) -> *AstExpr
    let line: i32 = ap_line(p)
    let col: i32 = ap_col(p)

    # Integer literal
    if ap_check(p, "NUMBER") != 0
        let e: *AstExpr = ast_new_expr(p.alloc, EXPR_INT)
        e.line = line
        e.col = col
        e.int_val = atoi(ap_text(p))
        ap_advance(p)
        return e

    # String literal
    if ap_check(p, "STRING") != 0
        let e: *AstExpr = ast_new_expr(p.alloc, EXPR_STRING)
        e.line = line
        e.col = col
        # Skip quotes
        e.str_ptr = ap_text(p) + 1
        e.str_len = ap_text_len(p) - 2
        ap_advance(p)
        return e

    # Char literal
    if ap_check(p, "CHAR") != 0
        let e: *AstExpr = ast_new_expr(p.alloc, EXPR_CHAR)
        e.line = line
        e.col = col
        # Parse char value (skip quotes)
        let txt: *u8 = ap_text(p)
        if *(txt + 1) == 92  # backslash
            let c: u8 = *(txt + 2)
            if c == 110  # n
                e.char_val = 10
            else if c == 116  # t
                e.char_val = 9
            else if c == 114  # r
                e.char_val = 13
            else if c == 48  # 0
                e.char_val = 0
            else
                e.char_val = c
        else
            e.char_val = *(txt + 1)
        ap_advance(p)
        return e

    # Boolean literals
    if ap_match(p, "TRUE") != 0
        let e: *AstExpr = ast_new_expr(p.alloc, EXPR_BOOL)
        e.line = line
        e.col = col
        e.bool_val = 1
        return e
    if ap_match(p, "FALSE") != 0
        let e: *AstExpr = ast_new_expr(p.alloc, EXPR_BOOL)
        e.line = line
        e.col = col
        e.bool_val = 0
        return e

    # Identifier (variable or function call)
    if ap_check(p, "IDENT") != 0
        let e: *AstExpr = ast_new_expr(p.alloc, EXPR_IDENT)
        e.line = line
        e.col = col
        e.str_ptr = ap_text(p)
        e.str_len = ap_text_len(p)
        ap_advance(p)
        return e

    # Parenthesized expression
    if ap_match(p, "LPAREN") != 0
        let e: *AstExpr = ap_parse_expr(p)
        if e == 0 as *AstExpr
            return 0 as *AstExpr
        if ap_match(p, "RPAREN") == 0
            ap_error(p, "Expected ')'")
            return 0 as *AstExpr
        return e

    0 as *AstExpr

fn ap_parse_postfix(p: *AstParser) -> *AstExpr
    var e: *AstExpr = ap_parse_primary(p)
    if e == 0 as *AstExpr
        return 0 as *AstExpr

    while 1 == 1
        let line: i32 = ap_line(p)
        let col: i32 = ap_col(p)

        # Function call: expr(args)
        if ap_match(p, "LPAREN") != 0
            let call: *AstExpr = ast_new_expr(p.alloc, EXPR_CALL)
            call.line = line
            call.col = col
            call.callee = e

            # Parse arguments
            var args_head: *AstExpr = 0 as *AstExpr
            var args_tail: *AstExpr = 0 as *AstExpr
            if ap_check(p, "RPAREN") == 0
                while 1 == 1
                    let arg: *AstExpr = ap_parse_expr(p)
                    if arg == 0 as *AstExpr
                        return 0 as *AstExpr
                    if args_head == 0 as *AstExpr
                        args_head = arg
                        args_tail = arg
                    else
                        args_tail.next = arg
                        args_tail = arg
                    if ap_match(p, "COMMA") == 0
                        break

            if ap_match(p, "RPAREN") == 0
                ap_error(p, "Expected ')' after arguments")
                return 0 as *AstExpr
            call.args = args_head
            e = call

        # Array index: expr[index]
        else if ap_match(p, "LBRACKET") != 0
            let idx: *AstExpr = ast_new_expr(p.alloc, EXPR_INDEX)
            idx.line = line
            idx.col = col
            idx.base = e
            idx.index = ap_parse_expr(p)
            if idx.index == 0 as *AstExpr
                return 0 as *AstExpr
            if ap_match(p, "RBRACKET") == 0
                ap_error(p, "Expected ']'")
                return 0 as *AstExpr
            e = idx

        # Field access: expr.field
        else if ap_match(p, "DOT") != 0
            let field: *AstExpr = ast_new_expr(p.alloc, EXPR_FIELD)
            field.line = line
            field.col = col
            field.base = e
            if ap_check(p, "IDENT") == 0
                ap_error(p, "Expected field name")
                return 0 as *AstExpr
            field.field_name = ap_text(p)
            field.field_name_len = ap_text_len(p)
            ap_advance(p)
            e = field

        else
            break

    e

fn ap_parse_unary(p: *AstParser) -> *AstExpr
    let line: i32 = ap_line(p)
    let col: i32 = ap_col(p)

    # Unary minus
    if ap_match(p, "MINUS") != 0
        let e: *AstExpr = ast_new_expr(p.alloc, EXPR_UNARY)
        e.line = line
        e.col = col
        e.op = OP_NEG
        e.operand = ap_parse_unary(p)
        return e

    # Unary not
    if ap_match(p, "BANG") != 0
        let e: *AstExpr = ast_new_expr(p.alloc, EXPR_UNARY)
        e.line = line
        e.col = col
        e.op = OP_NOT
        e.operand = ap_parse_unary(p)
        return e

    # Dereference
    if ap_match(p, "STAR") != 0
        let e: *AstExpr = ast_new_expr(p.alloc, EXPR_UNARY)
        e.line = line
        e.col = col
        e.op = OP_DEREF
        e.operand = ap_parse_unary(p)
        return e

    # Address-of
    if ap_match(p, "AMP") != 0
        let e: *AstExpr = ast_new_expr(p.alloc, EXPR_UNARY)
        e.line = line
        e.col = col
        e.op = OP_ADDR
        e.operand = ap_parse_unary(p)
        return e

    # Bitwise not
    if ap_match(p, "TILDE") != 0
        let e: *AstExpr = ast_new_expr(p.alloc, EXPR_UNARY)
        e.line = line
        e.col = col
        e.op = OP_BIT_NOT
        e.operand = ap_parse_unary(p)
        return e

    ap_parse_postfix(p)

fn ap_parse_mul(p: *AstParser) -> *AstExpr
    var left: *AstExpr = ap_parse_unary(p)
    if left == 0 as *AstExpr
        return 0 as *AstExpr

    while 1 == 1
        let line: i32 = ap_line(p)
        let col: i32 = ap_col(p)
        var op: i32 = 0

        if ap_match(p, "STAR") != 0
            op = OP_MUL
        else if ap_match(p, "SLASH") != 0
            op = OP_DIV
        else if ap_match(p, "PERCENT") != 0
            op = OP_MOD
        else
            break

        let right: *AstExpr = ap_parse_unary(p)
        if right == 0 as *AstExpr
            return 0 as *AstExpr
        let e: *AstExpr = ast_new_expr(p.alloc, EXPR_BINARY)
        e.line = line
        e.col = col
        e.op = op
        e.left = left
        e.right = right
        left = e

    left

fn ap_parse_add(p: *AstParser) -> *AstExpr
    var left: *AstExpr = ap_parse_mul(p)
    if left == 0 as *AstExpr
        return 0 as *AstExpr

    while 1 == 1
        let line: i32 = ap_line(p)
        let col: i32 = ap_col(p)
        var op: i32 = 0

        if ap_match(p, "PLUS") != 0
            op = OP_ADD
        else if ap_match(p, "MINUS") != 0
            op = OP_SUB
        else
            break

        let right: *AstExpr = ap_parse_mul(p)
        if right == 0 as *AstExpr
            return 0 as *AstExpr
        let e: *AstExpr = ast_new_expr(p.alloc, EXPR_BINARY)
        e.line = line
        e.col = col
        e.op = op
        e.left = left
        e.right = right
        left = e

    left

fn ap_parse_shift(p: *AstParser) -> *AstExpr
    var left: *AstExpr = ap_parse_add(p)
    if left == 0 as *AstExpr
        return 0 as *AstExpr

    while 1 == 1
        let line: i32 = ap_line(p)
        let col: i32 = ap_col(p)
        var op: i32 = 0

        if ap_match(p, "SHL") != 0
            op = OP_SHL
        else if ap_match(p, "SHR") != 0
            op = OP_SHR
        else
            break

        let right: *AstExpr = ap_parse_add(p)
        if right == 0 as *AstExpr
            return 0 as *AstExpr
        let e: *AstExpr = ast_new_expr(p.alloc, EXPR_BINARY)
        e.line = line
        e.col = col
        e.op = op
        e.left = left
        e.right = right
        left = e

    left

fn ap_parse_cmp(p: *AstParser) -> *AstExpr
    var left: *AstExpr = ap_parse_shift(p)
    if left == 0 as *AstExpr
        return 0 as *AstExpr

    let line: i32 = ap_line(p)
    let col: i32 = ap_col(p)
    var op: i32 = 0

    if ap_match(p, "EQ") != 0
        op = OP_EQ
    else if ap_match(p, "NE") != 0
        op = OP_NE
    else if ap_match(p, "LE") != 0
        op = OP_LE
    else if ap_match(p, "GE") != 0
        op = OP_GE
    else if ap_match(p, "LT") != 0
        op = OP_LT
    else if ap_match(p, "GT") != 0
        op = OP_GT
    else
        return left

    let right: *AstExpr = ap_parse_shift(p)
    if right == 0 as *AstExpr
        return 0 as *AstExpr
    let e: *AstExpr = ast_new_expr(p.alloc, EXPR_BINARY)
    e.line = line
    e.col = col
    e.op = op
    e.left = left
    e.right = right
    e

fn ap_parse_bitand(p: *AstParser) -> *AstExpr
    var left: *AstExpr = ap_parse_cmp(p)
    if left == 0 as *AstExpr
        return 0 as *AstExpr

    while ap_match(p, "AMP") != 0
        let line: i32 = ap_line(p)
        let col: i32 = ap_col(p)
        let right: *AstExpr = ap_parse_cmp(p)
        if right == 0 as *AstExpr
            return 0 as *AstExpr
        let e: *AstExpr = ast_new_expr(p.alloc, EXPR_BINARY)
        e.line = line
        e.col = col
        e.op = OP_BIT_AND
        e.left = left
        e.right = right
        left = e

    left

fn ap_parse_bitxor(p: *AstParser) -> *AstExpr
    var left: *AstExpr = ap_parse_bitand(p)
    if left == 0 as *AstExpr
        return 0 as *AstExpr

    while ap_match(p, "CARET") != 0
        let line: i32 = ap_line(p)
        let col: i32 = ap_col(p)
        let right: *AstExpr = ap_parse_bitand(p)
        if right == 0 as *AstExpr
            return 0 as *AstExpr
        let e: *AstExpr = ast_new_expr(p.alloc, EXPR_BINARY)
        e.line = line
        e.col = col
        e.op = OP_BIT_XOR
        e.left = left
        e.right = right
        left = e

    left

fn ap_parse_bitor(p: *AstParser) -> *AstExpr
    var left: *AstExpr = ap_parse_bitxor(p)
    if left == 0 as *AstExpr
        return 0 as *AstExpr

    while ap_match(p, "PIPE") != 0
        let line: i32 = ap_line(p)
        let col: i32 = ap_col(p)
        let right: *AstExpr = ap_parse_bitxor(p)
        if right == 0 as *AstExpr
            return 0 as *AstExpr
        let e: *AstExpr = ast_new_expr(p.alloc, EXPR_BINARY)
        e.line = line
        e.col = col
        e.op = OP_BIT_OR
        e.left = left
        e.right = right
        left = e

    left

fn ap_parse_and(p: *AstParser) -> *AstExpr
    var left: *AstExpr = ap_parse_bitor(p)
    if left == 0 as *AstExpr
        return 0 as *AstExpr

    while ap_match(p, "AND") != 0
        let line: i32 = ap_line(p)
        let col: i32 = ap_col(p)
        let right: *AstExpr = ap_parse_bitor(p)
        if right == 0 as *AstExpr
            return 0 as *AstExpr
        let e: *AstExpr = ast_new_expr(p.alloc, EXPR_BINARY)
        e.line = line
        e.col = col
        e.op = OP_AND
        e.left = left
        e.right = right
        left = e

    left

fn ap_parse_or(p: *AstParser) -> *AstExpr
    var left: *AstExpr = ap_parse_and(p)
    if left == 0 as *AstExpr
        return 0 as *AstExpr

    while ap_match(p, "OR") != 0
        let line: i32 = ap_line(p)
        let col: i32 = ap_col(p)
        let right: *AstExpr = ap_parse_and(p)
        if right == 0 as *AstExpr
            return 0 as *AstExpr
        let e: *AstExpr = ast_new_expr(p.alloc, EXPR_BINARY)
        e.line = line
        e.col = col
        e.op = OP_OR
        e.left = left
        e.right = right
        left = e

    left

fn ap_parse_expr(p: *AstParser) -> *AstExpr
    # Handle 'as' casts at the top level
    var e: *AstExpr = ap_parse_or(p)
    if e == 0 as *AstExpr
        return 0 as *AstExpr

    if ap_match(p, "AS") != 0
        let cast: *AstExpr = ast_new_expr(p.alloc, EXPR_CAST)
        cast.line = e.line
        cast.col = e.col
        cast.operand = e
        cast.cast_type = ap_parse_type(p)
        if cast.cast_type == 0 as *AstType
            return 0 as *AstExpr
        return cast

    e

# =============================================================================
# Statement parsing
# =============================================================================

fn ap_parse_stmt(p: *AstParser) -> *AstStmt
    let line: i32 = ap_line(p)
    let col: i32 = ap_col(p)

    # let/var statement
    if ap_check(p, "LET") != 0 || ap_check(p, "VAR") != 0
        let is_let: i32 = ap_check(p, "LET")
        ap_advance(p)
        let s: *AstStmt = ast_new_stmt(p.alloc, STMT_LET)
        if is_let == 0
            s.kind = STMT_VAR
        s.line = line
        s.col = col

        if ap_check(p, "IDENT") == 0
            ap_error(p, "Expected variable name")
            return 0 as *AstStmt
        s.var_name = ap_text(p)
        s.var_name_len = ap_text_len(p)
        ap_advance(p)

        if ap_match(p, "COLON") != 0
            s.var_type = ap_parse_type(p)

        if ap_match(p, "ASSIGN") != 0
            s.var_init = ap_parse_expr(p)

        return s

    # return statement
    if ap_match(p, "RETURN") != 0
        let s: *AstStmt = ast_new_stmt(p.alloc, STMT_RETURN)
        s.line = line
        s.col = col
        # Check if there's an expression (not NEWLINE)
        if ap_peek(p) != TOK_NEWLINE && ap_peek(p) != TOK_EOF
            s.return_value = ap_parse_expr(p)
        return s

    # if statement
    if ap_match(p, "IF") != 0
        let s: *AstStmt = ast_new_stmt(p.alloc, STMT_IF)
        s.line = line
        s.col = col
        s.if_cond = ap_parse_expr(p)
        if s.if_cond == 0 as *AstExpr
            return 0 as *AstStmt
        # Skip NEWLINE and INDENT
        ap_skip_newlines(p)
        if ap_match_indent(p) == 0
            ap_error(p, "Expected indented block after if")
            return 0 as *AstStmt
        s.if_then = ap_parse_block(p)
        # Check for else
        ap_skip_newlines(p)
        if ap_match(p, "ELSE") != 0
            ap_skip_newlines(p)
            if ap_match(p, "IF") != 0
                # else if - parse as nested if
                p.pos = p.pos - 1  # back up to re-parse IF
                ap_advance(p)  # skip ELSE again
                # Actually parse the else branch as an if statement
                let elif_stmt: *AstStmt = ap_parse_stmt(p)
                s.if_else = elif_stmt
            else if ap_match_indent(p) != 0
                s.if_else = ap_parse_block(p)
        return s

    # while statement
    if ap_match(p, "WHILE") != 0
        let s: *AstStmt = ast_new_stmt(p.alloc, STMT_WHILE)
        s.line = line
        s.col = col
        s.loop_cond = ap_parse_expr(p)
        if s.loop_cond == 0 as *AstExpr
            return 0 as *AstStmt
        ap_skip_newlines(p)
        if ap_match_indent(p) == 0
            ap_error(p, "Expected indented block after while")
            return 0 as *AstStmt
        s.loop_body = ap_parse_block(p)
        return s

    # break
    if ap_match(p, "BREAK") != 0
        let s: *AstStmt = ast_new_stmt(p.alloc, STMT_BREAK)
        s.line = line
        s.col = col
        return s

    # continue
    if ap_match(p, "CONTINUE") != 0
        let s: *AstStmt = ast_new_stmt(p.alloc, STMT_CONTINUE)
        s.line = line
        s.col = col
        return s

    # Expression statement or assignment
    let expr: *AstExpr = ap_parse_expr(p)
    if expr == 0 as *AstExpr
        return 0 as *AstStmt

    # Check for assignment
    if ap_match(p, "ASSIGN") != 0
        let s: *AstStmt = ast_new_stmt(p.alloc, STMT_ASSIGN)
        s.line = line
        s.col = col
        s.assign_target = expr
        s.assign_value = ap_parse_expr(p)
        return s

    # Just an expression statement
    let s: *AstStmt = ast_new_stmt(p.alloc, STMT_EXPR)
    s.line = line
    s.col = col
    s.expr = expr
    s

fn ap_parse_block(p: *AstParser) -> *AstStmt
    var head: *AstStmt = 0 as *AstStmt
    var tail: *AstStmt = 0 as *AstStmt

    while 1 == 1
        ap_skip_newlines(p)
        let pk: i32 = ap_peek(p)
        if pk == TOK_DEDENT || pk == TOK_EOF
            break
        let s: *AstStmt = ap_parse_stmt(p)
        if s == 0 as *AstStmt
            # Statement failed - stop here
            break
        if head == 0 as *AstStmt
            head = s
            tail = s
        else
            tail.next = s
            tail = s
        # Don't skip newlines here - ap_parse_stmt should have consumed them

    # Consume DEDENT if present
    if ap_peek(p) == TOK_DEDENT
        ap_advance(p)

    head

# =============================================================================
# Function and module parsing
# =============================================================================

fn ap_parse_params(p: *AstParser) -> *AstParam
    var head: *AstParam = 0 as *AstParam
    var tail: *AstParam = 0 as *AstParam

    if ap_match(p, "RPAREN") != 0
        return 0 as *AstParam  # No params

    while 1 == 1
        if ap_check(p, "IDENT") == 0
            ap_error(p, "Expected parameter name")
            return 0 as *AstParam
        let param: *AstParam = ast_new_param(p.alloc)
        param.name = ap_text(p)
        param.name_len = ap_text_len(p)
        ap_advance(p)

        if ap_match(p, "COLON") == 0
            ap_error(p, "Expected ':' after parameter name")
            return 0 as *AstParam
        param.param_type = ap_parse_type(p)

        if head == 0 as *AstParam
            head = param
            tail = param
        else
            tail.next = param
            tail = param

        if ap_match(p, "COMMA") == 0
            break

    if ap_match(p, "RPAREN") == 0
        ap_error(p, "Expected ')' after parameters")
        return 0 as *AstParam

    head

fn ap_parse_fn(p: *AstParser) -> *AstFnDef
    if ap_match(p, "FN") == 0
        return 0 as *AstFnDef

    let fn_def: *AstFnDef = ast_new_fn(p.alloc)

    if ap_check(p, "IDENT") == 0
        ap_error(p, "Expected function name")
        return 0 as *AstFnDef
    fn_def.name = ap_text(p)
    fn_def.name_len = ap_text_len(p)
    ap_advance(p)

    if ap_match(p, "LPAREN") == 0
        ap_error(p, "Expected '(' after function name")
        return 0 as *AstFnDef

    fn_def.params = ap_parse_params(p)

    # Return type
    if ap_match(p, "ARROW") != 0
        fn_def.return_type = ap_parse_type(p)

    # Body
    ap_skip_newlines(p)
    if ap_match_indent(p) != 0
        fn_def.body = ap_parse_block(p)

    fn_def

fn ap_parse_module(p: *AstParser) -> *AstModule
    let module: *AstModule = ast_new_module(p.alloc)

    while ap_peek(p) != TOK_EOF
        ap_skip_newlines(p)
        if ap_peek(p) == TOK_EOF
            break

        # Import
        if ap_match(p, "IMPORT") != 0
            let imp: *AstImport = ast_new_import(p.alloc)
            # Parse import path: a.b.c
            var path_start: *u8 = ap_text(p)
            var path_len: i32 = 0
            while ap_check(p, "IDENT") != 0
                let tok: *Token = ap_current(p)
                if path_len == 0
                    path_start = tok.start
                path_len = (tok.start as i64 - path_start as i64) as i32 + tok.len
                ap_advance(p)
                if ap_match(p, "DOT") == 0
                    break
            imp.path = path_start
            imp.path_len = path_len
            # Add to imports list
            imp.next = module.imports
            module.imports = imp
            continue

        # Function definition
        if ap_check(p, "FN") != 0
            let fn_def: *AstFnDef = ap_parse_fn(p)
            if fn_def != 0 as *AstFnDef
                fn_def.next = module.functions
                module.functions = fn_def
            continue

        # Struct definition
        if ap_match(p, "STRUCT") != 0
            let st: *AstStructDef = ast_new_struct(p.alloc)
            if ap_check(p, "IDENT") == 0
                ap_error(p, "Expected struct name")
                continue
            st.name = ap_text(p)
            st.name_len = ap_text_len(p)
            ap_advance(p)
            ap_skip_newlines(p)
            # Parse fields
            if ap_match_indent(p) != 0
                var fields_head: *AstField = 0 as *AstField
                var fields_tail: *AstField = 0 as *AstField
                while ap_peek(p) != TOK_DEDENT && ap_peek(p) != TOK_EOF
                    ap_skip_newlines(p)
                    if ap_check(p, "IDENT") != 0
                        let field: *AstField = ast_new_field(p.alloc)
                        field.name = ap_text(p)
                        field.name_len = ap_text_len(p)
                        ap_advance(p)
                        if ap_match(p, "COLON") != 0
                            field.field_type = ap_parse_type(p)
                        if fields_head == 0 as *AstField
                            fields_head = field
                            fields_tail = field
                        else
                            fields_tail.next = field
                            fields_tail = field
                    ap_skip_newlines(p)
                ap_match_dedent(p)
                st.fields = fields_head
            st.next = module.structs
            module.structs = st
            continue

        # Const definition
        if ap_match(p, "CONST") != 0
            let c: *AstConstDef = ast_new_const(p.alloc)
            if ap_check(p, "IDENT") == 0
                ap_error(p, "Expected const name")
                continue
            c.name = ap_text(p)
            c.name_len = ap_text_len(p)
            ap_advance(p)
            if ap_match(p, "COLON") != 0
                c.const_type = ap_parse_type(p)
            if ap_match(p, "ASSIGN") != 0
                c.value = ap_parse_expr(p)
            c.next = module.constants
            module.constants = c
            continue

        # Skip unknown tokens
        ap_advance(p)

    module

# Parse file and print AST
fn parse_file_ast(path: *u8, defs: *TokenDefs, verbose: i32) -> i32
    # Read file
    var buf: ByteVec = bytevec_new()
    let fd: i32 = sys_open(path, 0)
    if fd < 0
        eprints("Cannot open: ")
        eprints(path)
        eprints("\n")
        return 1

    var chunk: [4096]u8
    while 1 == 1
        let n: i64 = sys_read(fd, &chunk[0], 4096)
        if n <= 0
            break
        bytevec_push_bytes(&buf, &chunk[0], n)
    sys_close(fd)

    # Lex file
    var lex: Lexer
    lexer_init(&lex, buf.data, buf.len, defs)

    # Collect all tokens
    var tokens: [8192]Token
    var token_count: i32 = 0
    while token_count < 8192
        var tok: Token
        lexer_next(&lex, &tok)
        tokens[token_count] = tok
        token_count = token_count + 1
        if tok.kind == TOK_EOF
            break

    # Initialize AST allocator
    var alloc: AstAlloc
    ast_alloc_init(&alloc, 1024 * 1024)  # 1MB

    # Parse
    var parser: AstParser
    ast_parser_init(&parser, &tokens[0], token_count, &alloc, defs)

    let module: *AstModule = ap_parse_module(&parser)

    if parser.error != 0
        eprints("Parse errors in: ")
        eprints(path)
        eprints("\n")
        bytevec_free(&buf)
        ast_alloc_free(&alloc)
        return 1

    # Print AST
    prints("AST for ")
    prints(path)
    prints(":\n")
    ast_print_module(module)

    bytevec_free(&buf)
    ast_alloc_free(&alloc)
    0

# =============================================================================
# Grammar file parser
# =============================================================================

struct GrammarParser
    input: *u8
    len: i64
    pos: i64
    line: i32
    col: i32
    in_skip_section: i32  # 1 if in %skip section

fn gp_init(gp: *GrammarParser, input: *u8, len: i64) -> i32
    gp.input = input
    gp.len = len
    gp.pos = 0
    gp.line = 1
    gp.col = 1
    gp.in_skip_section = 0
    return 0

fn gp_peek(gp: *GrammarParser) -> u8
    if gp.pos >= gp.len
        return 0
    return *(gp.input + gp.pos)

fn gp_advance(gp: *GrammarParser) -> u8
    if gp.pos >= gp.len
        return 0
    let c: u8 = *(gp.input + gp.pos)
    gp.pos = gp.pos + 1
    if c == 10
        gp.line = gp.line + 1
        gp.col = 1
    else
        gp.col = gp.col + 1
    return c

fn gp_skip_ws(gp: *GrammarParser) -> i32
    while gp.pos < gp.len
        let c: u8 = gp_peek(gp)
        if c == 32 || c == 9 || c == 13
            gp_advance(gp)
        else
            break
    return 0

fn gp_skip_line(gp: *GrammarParser) -> i32
    while gp.pos < gp.len && gp_peek(gp) != 10
        gp_advance(gp)
    if gp_peek(gp) == 10
        gp_advance(gp)
    return 0

fn gp_at_eol(gp: *GrammarParser) -> i32
    let c: u8 = gp_peek(gp)
    return (c == 10 || c == 0 || c == 35) as i32  # newline, EOF, or comment

fn is_alpha(c: u8) -> i32
    if c >= 65 && c <= 90
        return 1
    if c >= 97 && c <= 122
        return 1
    if c == 95
        return 1
    return 0

fn is_alnum(c: u8) -> i32
    if is_alpha(c) != 0
        return 1
    if c >= 48 && c <= 57
        return 1
    return 0

# Parse identifier (token name)
fn gp_parse_ident(gp: *GrammarParser, out: *u8, max_len: i32) -> i32
    var len: i32 = 0
    while gp.pos < gp.len && is_alnum(gp_peek(gp)) != 0
        if len < max_len - 1
            *(out + len) = gp_advance(gp)
            len = len + 1
        else
            gp_advance(gp)
    *(out + len) = 0
    return len

# Parse quoted string literal "..."
fn gp_parse_string(gp: *GrammarParser, out: *u8, max_len: i32) -> i32
    if gp_peek(gp) != 34  # '"'
        return 0 - 1
    gp_advance(gp)  # consume opening quote

    var len: i32 = 0
    while gp.pos < gp.len
        let c: u8 = gp_peek(gp)
        if c == 34  # closing quote
            gp_advance(gp)
            *(out + len) = 0
            return len
        if c == 92  # backslash
            gp_advance(gp)
            let ec: u8 = gp_advance(gp)
            if len < max_len - 1
                # Handle escape sequences
                if ec == 110  # \n
                    *(out + len) = 10
                else if ec == 116  # \t
                    *(out + len) = 9
                else if ec == 114  # \r
                    *(out + len) = 13
                else
                    *(out + len) = ec
                len = len + 1
        else
            if len < max_len - 1
                *(out + len) = gp_advance(gp)
                len = len + 1
            else
                gp_advance(gp)
    return 0 - 1  # Unterminated string

# Parse regex pattern /.../
fn gp_parse_regex(gp: *GrammarParser, out: *u8, max_len: i32) -> i32
    if gp_peek(gp) != 47  # '/'
        return 0 - 1
    gp_advance(gp)  # consume opening /

    var len: i32 = 0
    while gp.pos < gp.len
        let c: u8 = gp_peek(gp)
        if c == 47  # closing /
            gp_advance(gp)
            *(out + len) = 0
            return len
        if c == 92  # backslash - escape next char
            if len < max_len - 1
                *(out + len) = gp_advance(gp)
                len = len + 1
            else
                gp_advance(gp)
            if len < max_len - 1 && gp.pos < gp.len
                *(out + len) = gp_advance(gp)
                len = len + 1
            else if gp.pos < gp.len
                gp_advance(gp)
        else
            if len < max_len - 1
                *(out + len) = gp_advance(gp)
                len = len + 1
            else
                gp_advance(gp)
    return 0 - 1  # Unterminated regex

# Parse grammar file and populate token definitions
# Returns: 0 = success (no grammar section), 1 = success (hit %grammar), -1 = error
fn parse_grammar(gp: *GrammarParser, defs: *TokenDefs) -> i32
    defs.count = 0
    defs.next_id = 10  # Start user tokens at 10

    while gp.pos < gp.len
        gp_skip_ws(gp)
        let c: u8 = gp_peek(gp)

        # Skip empty lines and comments
        if c == 10
            gp_advance(gp)
            continue
        if c == 35  # '#'
            gp_skip_line(gp)
            continue
        if c == 0
            break

        # Check for directives
        if c == 37  # '%'
            gp_advance(gp)
            var directive: [32]u8
            let dlen: i32 = gp_parse_ident(gp, &directive[0], 32)

            # Check directive type
            if streq(&directive[0], "tokens") != 0
                gp.in_skip_section = 0
                gp_skip_line(gp)
                continue
            if streq(&directive[0], "skip") != 0
                gp.in_skip_section = 1
                gp_skip_line(gp)
                continue
            if streq(&directive[0], "grammar") != 0
                gp_skip_line(gp)
                return 1  # Signal that grammar section follows

            # Unknown directive - skip line
            gp_skip_line(gp)
            continue

        # Parse token definition: NAME = "literal" or NAME = /pattern/
        if is_alpha(c) != 0
            var name: [64]u8
            let nlen: i32 = gp_parse_ident(gp, &name[0], 64)

            gp_skip_ws(gp)

            # Expect '='
            if gp_peek(gp) != 61
                eprints("Error: expected '=' after token name\n")
                return 0 - 1
            gp_advance(gp)
            gp_skip_ws(gp)

            # Parse value (string or regex)
            var pattern: [256]u8
            var plen: i32 = 0
            var is_literal: i32 = 0

            if gp_peek(gp) == 34  # '"'
                plen = gp_parse_string(gp, &pattern[0], 256)
                is_literal = 1
            else if gp_peek(gp) == 47  # '/'
                plen = gp_parse_regex(gp, &pattern[0], 256)
                is_literal = 0
            else
                eprints("Error: expected string or regex after '='\n")
                return 0 - 1

            if plen < 0
                eprints("Error: unterminated string or regex\n")
                return 0 - 1

            # Add token definition
            if defs.count < 256
                let def: *TokenDef = &defs.defs[defs.count]

                # Copy name
                def.name = sys_mmap(0, (nlen + 1) as i64, 3, 34, 0 - 1, 0) as *u8
                memcpy(def.name, &name[0], (nlen + 1) as i64)
                def.name_len = nlen

                # Copy pattern
                def.pattern = sys_mmap(0, (plen + 1) as i64, 3, 34, 0 - 1, 0) as *u8
                memcpy(def.pattern, &pattern[0], (plen + 1) as i64)
                def.pattern_len = plen

                def.is_literal = is_literal
                def.is_skip = gp.in_skip_section
                def.token_id = defs.next_id
                defs.next_id = defs.next_id + 1
                defs.count = defs.count + 1

            gp_skip_line(gp)
            continue

        # Unknown line - skip
        gp_skip_line(gp)

    return 0

# =============================================================================
# Grammar rule parsing
# =============================================================================

# Check if a name is a terminal (all uppercase)
fn is_terminal_name(name: *u8, len: i32) -> i32
    var i: i32 = 0
    while i < len
        let c: u8 = *(name + i)
        # Must be uppercase letter or underscore or digit
        if c >= 65 && c <= 90  # A-Z
            i = i + 1
            continue
        if c == 95  # _
            i = i + 1
            continue
        if c >= 48 && c <= 57  # 0-9
            i = i + 1
            continue
        return 0  # Not a terminal
        i = i + 1
    return 1

# Parse a single symbol (terminal, nonterminal, or grouped expression)
fn gp_parse_symbol(gp: *GrammarParser, sym: *GrammarSymbol) -> i32
    gp_skip_ws(gp)

    let c: u8 = gp_peek(gp)

    # Handle grouping: (...)
    if c == 40  # '('
        gp_advance(gp)
        # TODO: Parse nested alternatives for groups
        # For now, skip to matching paren
        var depth: i32 = 1
        while gp.pos < gp.len && depth > 0
            let gc: u8 = gp_advance(gp)
            if gc == 40
                depth = depth + 1
            else if gc == 41
                depth = depth - 1
        sym.kind = SYM_GROUP
        sym.name = 0 as *u8
        sym.name_len = 0
        sym.group_alts = 0 as *GrammarAlt
        sym.group_alt_count = 0
        # Check for quantifier
        gp_skip_ws(gp)
        let qc: u8 = gp_peek(gp)
        if qc == 42  # '*'
            gp_advance(gp)
            sym.kind = SYM_STAR
        else if qc == 43  # '+'
            gp_advance(gp)
            sym.kind = SYM_PLUS
        else if qc == 63  # '?'
            gp_advance(gp)
            sym.kind = SYM_OPTIONAL
        return 1

    # Handle identifier (terminal or nonterminal)
    if is_alpha(c) != 0
        var name: [64]u8
        let nlen: i32 = gp_parse_ident(gp, &name[0], 64)

        # Allocate and copy name
        sym.name = sys_mmap(0, (nlen + 1) as i64, 3, 34, 0 - 1, 0) as *u8
        memcpy(sym.name, &name[0], (nlen + 1) as i64)
        sym.name_len = nlen
        sym.group_alts = 0 as *GrammarAlt
        sym.group_alt_count = 0

        # Determine if terminal or nonterminal
        if is_terminal_name(&name[0], nlen) != 0
            sym.kind = SYM_TERMINAL
        else
            sym.kind = SYM_NONTERMINAL

        # Check for quantifier
        gp_skip_ws(gp)
        let qc: u8 = gp_peek(gp)
        if qc == 42  # '*'
            gp_advance(gp)
            # Wrap in STAR: symbol becomes the base, kind becomes STAR
            let base_kind: i32 = sym.kind
            sym.kind = SYM_STAR
        else if qc == 43  # '+'
            gp_advance(gp)
            sym.kind = SYM_PLUS
        else if qc == 63  # '?'
            gp_advance(gp)
            sym.kind = SYM_OPTIONAL

        return 1

    return 0  # No symbol found

# Parse an alternative (sequence of symbols)
fn gp_parse_alt(gp: *GrammarParser, alt: *GrammarAlt) -> i32
    alt.symbol_count = 0

    while gp.pos < gp.len
        gp_skip_ws(gp)
        let c: u8 = gp_peek(gp)

        # Stop at end of alternative
        if c == 124 || c == 59 || c == 10 || c == 0  # '|', ';', newline, EOF
            break

        # Parse symbol
        if alt.symbol_count < 16
            var sym: GrammarSymbol
            if gp_parse_symbol(gp, &sym) != 0
                alt.symbols[alt.symbol_count] = sym
                alt.symbol_count = alt.symbol_count + 1
            else
                break
        else
            break

    return alt.symbol_count

# Parse a grammar rule (name and alternatives)
fn gp_parse_rule(gp: *GrammarParser, rule: *GrammarRule) -> i32
    gp_skip_ws(gp)

    # Parse rule name
    if is_alpha(gp_peek(gp)) == 0
        return 0

    var name: [64]u8
    let nlen: i32 = gp_parse_ident(gp, &name[0], 64)

    # Allocate and copy name
    rule.name = sys_mmap(0, (nlen + 1) as i64, 3, 34, 0 - 1, 0) as *u8
    memcpy(rule.name, &name[0], (nlen + 1) as i64)
    rule.name_len = nlen
    rule.alt_count = 0

    # Skip to ':'
    gp_skip_ws(gp)
    while gp.pos < gp.len && gp_peek(gp) == 10
        gp_advance(gp)
        gp_skip_ws(gp)

    if gp_peek(gp) != 58  # ':'
        return 0
    gp_advance(gp)

    # Parse alternatives
    while gp.pos < gp.len && rule.alt_count < 8
        gp_skip_ws(gp)

        # Skip newlines
        while gp_peek(gp) == 10
            gp_advance(gp)
            gp_skip_ws(gp)

        let c: u8 = gp_peek(gp)

        # End of rule
        if c == 59  # ';'
            gp_advance(gp)
            break

        # Skip leading '|' for alternatives after the first
        if c == 124  # '|'
            gp_advance(gp)
            gp_skip_ws(gp)

        # Parse alternative
        if gp_parse_alt(gp, &rule.alts[rule.alt_count]) > 0
            rule.alt_count = rule.alt_count + 1
        else
            break

    return 1

# Parse all grammar rules after %grammar directive
fn parse_grammar_rules(gp: *GrammarParser, grammar: *Grammar) -> i32
    grammar.rule_count = 0

    while gp.pos < gp.len
        gp_skip_ws(gp)

        # Skip newlines and comments
        let c: u8 = gp_peek(gp)
        if c == 10
            gp_advance(gp)
            continue
        if c == 35  # '#'
            gp_skip_line(gp)
            continue
        if c == 0
            break

        # Parse rule
        if is_alpha(c) != 0 && grammar.rule_count < 64
            if gp_parse_rule(gp, &grammar.rules[grammar.rule_count]) != 0
                grammar.rule_count = grammar.rule_count + 1
            else
                gp_skip_line(gp)
        else
            gp_skip_line(gp)

    return 0

# Print grammar for debugging
fn print_grammar(grammar: *Grammar)
    prints("\nGrammar rules (")
    print_int(grammar.rule_count as i64)
    prints("):\n")

    var i: i32 = 0
    while i < grammar.rule_count
        let rule: *GrammarRule = &grammar.rules[i]
        prints("  ")
        prints(rule.name)
        prints("\n")

        var j: i32 = 0
        while j < rule.alt_count
            let alt: *GrammarAlt = &rule.alts[j]
            prints("    ")
            if j == 0
                prints(": ")
            else
                prints("| ")

            var k: i32 = 0
            while k < alt.symbol_count
                let sym: *GrammarSymbol = &alt.symbols[k]
                if sym.name != 0 as *u8
                    prints(sym.name)
                else
                    prints("(...)")
                if sym.kind == SYM_STAR
                    prints("*")
                else if sym.kind == SYM_PLUS
                    prints("+")
                else if sym.kind == SYM_OPTIONAL
                    prints("?")
                prints(" ")
                k = k + 1
            prints("\n")
            j = j + 1
        prints("    ;\n")
        i = i + 1

# =============================================================================
# Parser generator - emits recursive descent parser in Ritz
# =============================================================================

struct CodeGen
    out: *ByteVec
    indent_level: i32
    defs: *TokenDefs
    grammar: *Grammar

fn cg_init(cg: *CodeGen, out: *ByteVec, defs: *TokenDefs, grammar: *Grammar)
    cg.out = out
    cg.indent_level = 0
    cg.defs = defs
    cg.grammar = grammar

fn cg_indent(cg: *CodeGen)
    var i: i32 = 0
    while i < cg.indent_level
        bytevec_push_bytes(cg.out, "    ", 4)
        i = i + 1

fn cg_emit(cg: *CodeGen, s: *u8)
    var i: i32 = 0
    while *(s + i) != 0
        i = i + 1
    bytevec_push_bytes(cg.out, s, i as i64)

fn cg_emit_line(cg: *CodeGen, s: *u8)
    cg_indent(cg)
    cg_emit(cg, s)
    bytevec_push(cg.out, 10)

fn cg_nl(cg: *CodeGen)
    bytevec_push(cg.out, 10)

fn cg_emit_int(cg: *CodeGen, n: i32)
    var buf: [20]u8
    var idx: i32 = 0
    var val: i32 = n
    if val < 0
        bytevec_push(cg.out, 45)  # '-'
        val = 0 - val
    if val == 0
        bytevec_push(cg.out, 48)  # '0'
        return
    while val > 0
        buf[idx] = (48 + (val % 10)) as u8
        val = val / 10
        idx = idx + 1
    while idx > 0
        idx = idx - 1
        bytevec_push(cg.out, buf[idx])

# Find a rule by name
fn find_rule(grammar: *Grammar, name: *u8, len: i32) -> *GrammarRule
    var i: i32 = 0
    while i < grammar.rule_count
        let rule: *GrammarRule = &grammar.rules[i]
        if rule.name_len == len
            var is_match: i32 = 1
            var j: i32 = 0
            while j < len
                if *(rule.name + j) != *(name + j)
                    is_match = 0
                    break
                j = j + 1
            if is_match != 0
                return rule
        i = i + 1
    return 0 as *GrammarRule

# Get token ID by name
fn get_token_id(defs: *TokenDefs, name: *u8, len: i32) -> i32
    var i: i32 = 0
    while i < defs.count
        let def: *TokenDef = &defs.defs[i]
        if def.name_len == len
            var is_match: i32 = 1
            var j: i32 = 0
            while j < len
                if *(def.name + j) != *(name + j)
                    is_match = 0
                    break
                j = j + 1
            if is_match != 0
                return def.token_id
        i = i + 1
    # Check built-in tokens
    if len == 6 && streq(name, "INDENT") != 0
        return TOK_INDENT
    if len == 6 && streq(name, "DEDENT") != 0
        return TOK_DEDENT
    if len == 7 && streq(name, "NEWLINE") != 0
        return TOK_NEWLINE
    if len == 3 && streq(name, "EOF") != 0
        return TOK_EOF
    return 0 - 1

# Emit parser header
fn emit_parser_header(cg: *CodeGen)
    cg_emit_line(cg, "# Generated by ritzgen - Ritz recursive descent parser")
    cg_emit_line(cg, "#")
    cg_emit_line(cg, "# This is auto-generated code. Do not edit.")
    cg_nl(cg)
    cg_emit_line(cg, "import ritzlib.sys")
    cg_emit_line(cg, "import ritzlib.io")
    cg_emit_line(cg, "import ritzlib.str")
    cg_emit_line(cg, "import ritzlib.vec")
    cg_nl(cg)
    cg_emit_line(cg, "# Token types")

    # Emit built-in token constants
    cg_emit_line(cg, "const TOK_EOF: i32 = 0")
    cg_emit_line(cg, "const TOK_ERROR: i32 = 1")
    cg_emit_line(cg, "const TOK_SKIP: i32 = 2")
    cg_emit_line(cg, "const TOK_NEWLINE: i32 = 3")
    cg_emit_line(cg, "const TOK_INDENT: i32 = 4")
    cg_emit_line(cg, "const TOK_DEDENT: i32 = 5")
    cg_nl(cg)

    # Emit user token constants
    var i: i32 = 0
    while i < cg.defs.count
        let def: *TokenDef = &cg.defs.defs[i]
        cg_indent(cg)
        cg_emit(cg, "const TOK_")
        cg_emit(cg, def.name)
        cg_emit(cg, ": i32 = ")
        cg_emit_int(cg, def.token_id)
        cg_nl(cg)
        i = i + 1

    cg_nl(cg)
    cg_emit_line(cg, "# Token structure")
    cg_emit_line(cg, "struct Token")
    cg.indent_level = cg.indent_level + 1
    cg_emit_line(cg, "kind: i32")
    cg_emit_line(cg, "start: *u8")
    cg_emit_line(cg, "len: i32")
    cg_emit_line(cg, "line: i32")
    cg_emit_line(cg, "col: i32")
    cg.indent_level = cg.indent_level - 1
    cg_nl(cg)

    cg_emit_line(cg, "# Parser state")
    cg_emit_line(cg, "struct Parser")
    cg.indent_level = cg.indent_level + 1
    cg_emit_line(cg, "tokens: *Token")
    cg_emit_line(cg, "token_count: i32")
    cg_emit_line(cg, "pos: i32")
    cg_emit_line(cg, "error: i32")
    cg_emit_line(cg, "error_msg: *u8")
    cg.indent_level = cg.indent_level - 1
    cg_nl(cg)

    cg_emit_line(cg, "fn parser_init(p: *Parser, tokens: *Token, count: i32)")
    cg.indent_level = cg.indent_level + 1
    cg_emit_line(cg, "p.tokens = tokens")
    cg_emit_line(cg, "p.token_count = count")
    cg_emit_line(cg, "p.pos = 0")
    cg_emit_line(cg, "p.error = 0")
    cg_emit_line(cg, "p.error_msg = 0 as *u8")
    cg.indent_level = cg.indent_level - 1
    cg_nl(cg)

    cg_emit_line(cg, "fn p_peek(p: *Parser) -> i32")
    cg.indent_level = cg.indent_level + 1
    cg_emit_line(cg, "if p.pos >= p.token_count")
    cg.indent_level = cg.indent_level + 1
    cg_emit_line(cg, "return TOK_EOF")
    cg.indent_level = cg.indent_level - 1
    cg_emit_line(cg, "return (p.tokens + p.pos).kind")
    cg.indent_level = cg.indent_level - 1
    cg_nl(cg)

    cg_emit_line(cg, "fn p_advance(p: *Parser) -> i32")
    cg.indent_level = cg.indent_level + 1
    cg_emit_line(cg, "let k: i32 = p_peek(p)")
    cg_emit_line(cg, "if p.pos < p.token_count")
    cg.indent_level = cg.indent_level + 1
    cg_emit_line(cg, "p.pos = p.pos + 1")
    cg.indent_level = cg.indent_level - 1
    cg_emit_line(cg, "return k")
    cg.indent_level = cg.indent_level - 1
    cg_nl(cg)

    cg_emit_line(cg, "fn p_expect(p: *Parser, kind: i32) -> i32")
    cg.indent_level = cg.indent_level + 1
    cg_emit_line(cg, "if p_peek(p) == kind")
    cg.indent_level = cg.indent_level + 1
    cg_emit_line(cg, "p_advance(p)")
    cg_emit_line(cg, "return 1")
    cg.indent_level = cg.indent_level - 1
    cg_emit_line(cg, "return 0")
    cg.indent_level = cg.indent_level - 1
    cg_nl(cg)

# Emit a parse function for a single rule
fn emit_rule_parser(cg: *CodeGen, rule: *GrammarRule)
    cg_indent(cg)
    cg_emit(cg, "fn parse_")
    cg_emit(cg, rule.name)
    cg_emit(cg, "(p: *Parser) -> i32")
    cg_nl(cg)
    cg.indent_level = cg.indent_level + 1

    # Save position for backtracking
    cg_emit_line(cg, "let start_pos: i32 = p.pos")
    cg_nl(cg)

    # Try each alternative
    var alt_idx: i32 = 0
    while alt_idx < rule.alt_count
        let alt: *GrammarAlt = &rule.alts[alt_idx]

        if alt_idx > 0
            cg_emit_line(cg, "# Try next alternative")
            cg_emit_line(cg, "p.pos = start_pos")
            cg_nl(cg)

        cg_indent(cg)
        cg_emit(cg, "# Alternative ")
        cg_emit_int(cg, alt_idx + 1)
        cg_nl(cg)

        # Generate code for each symbol in the alternative
        var sym_idx: i32 = 0
        var first_sym: i32 = 1
        while sym_idx < alt.symbol_count
            let sym: *GrammarSymbol = &alt.symbols[sym_idx]

            if sym.kind == SYM_TERMINAL
                let tok_id: i32 = get_token_id(cg.defs, sym.name, sym.name_len)
                if first_sym == 0
                    cg_emit_line(cg, "if p.error == 0")
                    cg.indent_level = cg.indent_level + 1
                cg_indent(cg)
                cg_emit(cg, "if p_expect(p, TOK_")
                cg_emit(cg, sym.name)
                cg_emit(cg, ") == 0")
                cg_nl(cg)
                cg.indent_level = cg.indent_level + 1
                if alt_idx < rule.alt_count - 1
                    cg_emit_line(cg, "p.pos = start_pos")
                else
                    cg_emit_line(cg, "p.error = 1")
                cg.indent_level = cg.indent_level - 1
                if first_sym == 0
                    cg.indent_level = cg.indent_level - 1

            else if sym.kind == SYM_NONTERMINAL
                if first_sym == 0
                    cg_emit_line(cg, "if p.error == 0")
                    cg.indent_level = cg.indent_level + 1
                cg_indent(cg)
                cg_emit(cg, "if parse_")
                cg_emit(cg, sym.name)
                cg_emit(cg, "(p) == 0")
                cg_nl(cg)
                cg.indent_level = cg.indent_level + 1
                if alt_idx < rule.alt_count - 1
                    cg_emit_line(cg, "p.pos = start_pos")
                else
                    cg_emit_line(cg, "p.error = 1")
                cg.indent_level = cg.indent_level - 1
                if first_sym == 0
                    cg.indent_level = cg.indent_level - 1

            else if sym.kind == SYM_STAR || sym.kind == SYM_PLUS || sym.kind == SYM_OPTIONAL
                # Handle quantified symbols
                if sym.kind == SYM_PLUS
                    # At least one required
                    if first_sym == 0
                        cg_emit_line(cg, "if p.error == 0")
                        cg.indent_level = cg.indent_level + 1
                    if is_terminal_name(sym.name, sym.name_len) != 0
                        cg_indent(cg)
                        cg_emit(cg, "if p_expect(p, TOK_")
                        cg_emit(cg, sym.name)
                        cg_emit(cg, ") == 0")
                        cg_nl(cg)
                        cg.indent_level = cg.indent_level + 1
                        if alt_idx < rule.alt_count - 1
                            cg_emit_line(cg, "p.pos = start_pos")
                        else
                            cg_emit_line(cg, "p.error = 1")
                        cg.indent_level = cg.indent_level - 1
                    else
                        cg_indent(cg)
                        cg_emit(cg, "if parse_")
                        cg_emit(cg, sym.name)
                        cg_emit(cg, "(p) == 0")
                        cg_nl(cg)
                        cg.indent_level = cg.indent_level + 1
                        if alt_idx < rule.alt_count - 1
                            cg_emit_line(cg, "p.pos = start_pos")
                        else
                            cg_emit_line(cg, "p.error = 1")
                        cg.indent_level = cg.indent_level - 1
                    if first_sym == 0
                        cg.indent_level = cg.indent_level - 1

                if sym.kind == SYM_STAR || sym.kind == SYM_PLUS
                    # Zero or more (after first for PLUS)
                    cg_emit_line(cg, "if p.error == 0")
                    cg.indent_level = cg.indent_level + 1
                    cg_emit_line(cg, "while 1 == 1")
                    cg.indent_level = cg.indent_level + 1
                    if is_terminal_name(sym.name, sym.name_len) != 0
                        cg_indent(cg)
                        cg_emit(cg, "if p_expect(p, TOK_")
                        cg_emit(cg, sym.name)
                        cg_emit(cg, ") == 0")
                        cg_nl(cg)
                        cg.indent_level = cg.indent_level + 1
                        cg_emit_line(cg, "break")
                        cg.indent_level = cg.indent_level - 1
                    else
                        cg_indent(cg)
                        cg_emit(cg, "if parse_")
                        cg_emit(cg, sym.name)
                        cg_emit(cg, "(p) == 0")
                        cg_nl(cg)
                        cg.indent_level = cg.indent_level + 1
                        cg_emit_line(cg, "break")
                        cg.indent_level = cg.indent_level - 1
                    cg.indent_level = cg.indent_level - 1
                    cg.indent_level = cg.indent_level - 1

                if sym.kind == SYM_OPTIONAL
                    # Optional - try but don't fail
                    cg_emit_line(cg, "if p.error == 0")
                    cg.indent_level = cg.indent_level + 1
                    if is_terminal_name(sym.name, sym.name_len) != 0
                        cg_indent(cg)
                        cg_emit(cg, "p_expect(p, TOK_")
                        cg_emit(cg, sym.name)
                        cg_emit(cg, ")")
                        cg_nl(cg)
                    else
                        cg_indent(cg)
                        cg_emit(cg, "parse_")
                        cg_emit(cg, sym.name)
                        cg_emit(cg, "(p)")
                        cg_nl(cg)
                    cg.indent_level = cg.indent_level - 1

            first_sym = 0
            sym_idx = sym_idx + 1

        # Check if this alternative succeeded
        if alt_idx < rule.alt_count - 1
            cg_emit_line(cg, "if p.pos > start_pos")
            cg.indent_level = cg.indent_level + 1
            cg_emit_line(cg, "return 1")
            cg.indent_level = cg.indent_level - 1
        cg_nl(cg)

        alt_idx = alt_idx + 1

    # Return success if we matched anything
    cg_emit_line(cg, "if p.error == 0")
    cg.indent_level = cg.indent_level + 1
    cg_emit_line(cg, "return 1")
    cg.indent_level = cg.indent_level - 1
    cg_emit_line(cg, "return 0")

    cg.indent_level = cg.indent_level - 1
    cg_nl(cg)

# Generate full parser
fn generate_parser(defs: *TokenDefs, grammar: *Grammar, out: *ByteVec)
    var cg: CodeGen
    cg_init(&cg, out, defs, grammar)

    # Emit header
    emit_parser_header(&cg)

    # Emit parse functions for each rule
    var i: i32 = 0
    while i < grammar.rule_count
        emit_rule_parser(&cg, &grammar.rules[i])
        i = i + 1

    # Emit main parse entry point
    cg_emit_line(&cg, "# Entry point - parse starting from first rule")
    if grammar.rule_count > 0
        cg_emit_line(&cg, "fn parse(tokens: *Token, count: i32) -> i32")
        cg.indent_level = cg.indent_level + 1
        cg_emit_line(&cg, "var p: Parser")
        cg_emit_line(&cg, "parser_init(&p, tokens, count)")
        cg_indent(&cg)
        cg_emit(&cg, "return parse_")
        cg_emit(&cg, grammar.rules[0].name)
        cg_emit(&cg, "(&p)")
        cg_nl(&cg)
        cg.indent_level = cg.indent_level - 1

# =============================================================================
# Generated lexer runtime
# =============================================================================

struct Token
    kind: i32
    start: *u8
    len: i32
    line: i32
    col: i32

struct Lexer
    input: *u8
    len: i64
    pos: i64
    line: i32
    col: i32
    defs: *TokenDefs
    # Indentation tracking
    indent_stack: [64]i32
    indent_depth: i32
    pending_dedents: i32
    at_line_start: i32

fn lexer_init(lex: *Lexer, input: *u8, len: i64, defs: *TokenDefs) -> i32
    lex.input = input
    lex.len = len
    lex.pos = 0
    lex.line = 1
    lex.col = 1
    lex.defs = defs
    lex.indent_stack[0] = 0
    lex.indent_depth = 0
    lex.pending_dedents = 0
    lex.at_line_start = 1
    return 0

fn lex_peek(lex: *Lexer) -> u8
    if lex.pos >= lex.len
        return 0
    return *(lex.input + lex.pos)

fn lex_advance(lex: *Lexer) -> u8
    if lex.pos >= lex.len
        return 0
    let c: u8 = *(lex.input + lex.pos)
    lex.pos = lex.pos + 1
    if c == 10
        lex.line = lex.line + 1
        lex.col = 1
    else
        lex.col = lex.col + 1
    return c

# Try to match a literal string at current position
fn try_match_literal(lex: *Lexer, pattern: *u8, plen: i32) -> i32
    if lex.pos + plen as i64 > lex.len
        return 0

    var i: i32 = 0
    while i < plen
        if *(lex.input + lex.pos + i as i64) != *(pattern + i)
            return 0
        i = i + 1

    # For keywords, check that next char is not alphanumeric
    if plen > 0 && is_alpha(*pattern) != 0
        if lex.pos + plen as i64 < lex.len
            let next: u8 = *(lex.input + lex.pos + plen as i64)
            if is_alnum(next) != 0
                return 0

    return 1

# Try to match a string literal "..." at current position
# Returns match length or 0 if no match
fn try_match_string(lex: *Lexer) -> i32
    if lex.pos >= lex.len
        return 0
    if *(lex.input + lex.pos) != 34  # '"'
        return 0

    var i: i64 = 1  # skip opening quote
    while lex.pos + i < lex.len
        let c: u8 = *(lex.input + lex.pos + i)
        if c == 34  # closing quote
            return (i + 1) as i32  # include both quotes
        if c == 92  # backslash - skip next char
            i = i + 1
            if lex.pos + i < lex.len
                i = i + 1
        else if c == 10  # newline - unterminated string
            return 0
        else
            i = i + 1
    return 0  # unterminated

# Try to match a char literal '.' at current position
# Returns match length or 0 if no match
fn try_match_char(lex: *Lexer) -> i32
    if lex.pos >= lex.len
        return 0
    if *(lex.input + lex.pos) != 39  # '\''
        return 0

    var i: i64 = 1  # skip opening quote
    if lex.pos + i >= lex.len
        return 0

    let c: u8 = *(lex.input + lex.pos + i)
    if c == 92  # backslash escape
        i = i + 2  # skip escape sequence
    else
        i = i + 1  # skip char

    if lex.pos + i < lex.len && *(lex.input + lex.pos + i) == 39  # closing quote
        return (i + 1) as i32
    return 0

# Try to match a regex pattern at current position
# Returns match length or 0 if no match
fn try_match_pattern(lex: *Lexer, pattern: *u8, plen: i32) -> i32
    # Handle special patterns with dedicated matchers
    # STRING pattern: "([^"\\]|\\.)*"
    if plen >= 5 && *pattern == 34  # starts with "
        return try_match_string(lex)
    # CHAR pattern: '([^'\\]|\\.)'
    if plen >= 5 && *pattern == 39  # starts with '
        return try_match_char(lex)

    # Simplified pattern matching:
    # [a-zA-Z_]  - character class
    # [0-9]      - digit class
    # *          - zero or more of previous
    # +          - one or more of previous
    # ?          - optional
    # .          - any character
    # (...)      - grouping (basic)
    # |          - alternation (basic)

    let start: i64 = lex.pos
    var pp: i32 = 0  # pattern position
    var matched: i64 = 0  # total chars matched

    while pp < plen
        let pc: u8 = *(pattern + pp)

        if pc == 91  # '[' - character class
            pp = pp + 1
            var negated: i32 = 0
            if pp < plen && *(pattern + pp) == 94  # '^'
                negated = 1
                pp = pp + 1

            var char_matched: i32 = 0
            var curr_char: u8 = 0
            if start + matched < lex.len
                curr_char = *(lex.input + start + matched)

            while pp < plen && *(pattern + pp) != 93  # ']'
                let cc: u8 = *(pattern + pp)

                # Check for range a-z
                if pp + 2 < plen && *(pattern + pp + 1) == 45  # '-'
                    let lo: u8 = cc
                    let hi: u8 = *(pattern + pp + 2)
                    if curr_char >= lo && curr_char <= hi
                        char_matched = 1
                    pp = pp + 3
                else
                    if curr_char == cc
                        char_matched = 1
                    pp = pp + 1

            if pp < plen
                pp = pp + 1  # skip ']'

            if negated != 0
                char_matched = (char_matched == 0) as i32

            # Check for quantifier
            var min_match: i32 = 1
            var max_match: i32 = 1
            if pp < plen
                let quant: u8 = *(pattern + pp)
                if quant == 42  # '*'
                    min_match = 0
                    max_match = 999999
                    pp = pp + 1
                else if quant == 43  # '+'
                    min_match = 1
                    max_match = 999999
                    pp = pp + 1
                else if quant == 63  # '?'
                    min_match = 0
                    max_match = 1
                    pp = pp + 1

            if char_matched != 0
                matched = matched + 1
                # Continue matching for * or +
                if max_match > 1
                    while start + matched < lex.len
                        let nc: u8 = *(lex.input + start + matched)
                        # Re-check character class (simplified - need to re-parse class)
                        # For now, handle common cases
                        var nc_matched: i32 = 0

                        # Quick check: is alphanumeric or underscore
                        if is_alnum(nc) != 0 && negated == 0
                            nc_matched = 1
                        else if negated != 0 && is_alnum(nc) == 0 && nc != 10
                            nc_matched = 1

                        if nc_matched == 0
                            break
                        matched = matched + 1
            else if min_match > 0
                return 0  # Required match failed

        else if pc == 40  # '(' - grouping for alternation
            # Handle string patterns like /"([^"\\]|\\.)*"/
            # This is simplified - just handle the quoted string case
            pp = pp + 1
            # Skip to closing paren for now (simplified)
            var depth: i32 = 1
            while pp < plen && depth > 0
                if *(pattern + pp) == 40
                    depth = depth + 1
                else if *(pattern + pp) == 41
                    depth = depth - 1
                pp = pp + 1

            # Check for quantifier
            if pp < plen && *(pattern + pp) == 42  # '*'
                pp = pp + 1

        else if pc == 46  # '.' - any character
            pp = pp + 1
            if start + matched < lex.len
                matched = matched + 1
            else
                return 0

        else if pc == 92  # '\' - escape
            pp = pp + 1
            if pp < plen
                let ec: u8 = *(pattern + pp)
                var expected: u8 = ec
                if ec == 110
                    expected = 10  # \n
                else if ec == 116
                    expected = 9   # \t
                else if ec == 114
                    expected = 13  # \r

                if start + matched < lex.len && *(lex.input + start + matched) == expected
                    matched = matched + 1
                    pp = pp + 1
                else
                    return 0
        else
            # Literal character
            if start + matched < lex.len && *(lex.input + start + matched) == pc
                matched = matched + 1
                pp = pp + 1
            else
                return 0

    return matched as i32

# Get next token
fn lexer_next(lex: *Lexer, tok: *Token) -> i32
    # Handle pending dedents
    if lex.pending_dedents > 0
        lex.pending_dedents = lex.pending_dedents - 1
        tok.kind = TOK_DEDENT
        tok.start = lex.input + lex.pos
        tok.len = 0
        tok.line = lex.line
        tok.col = lex.col
        return 0

    # Handle indentation at start of line
    if lex.at_line_start != 0
        lex.at_line_start = 0

        # Count leading spaces
        var spaces: i32 = 0
        while lex.pos < lex.len
            let c: u8 = lex_peek(lex)
            if c == 32
                spaces = spaces + 1
                lex_advance(lex)
            else if c == 9
                spaces = spaces + 4
                lex_advance(lex)
            else
                break

        # Skip blank lines and comments
        let c: u8 = lex_peek(lex)
        if c == 10 || c == 35  # newline or comment
            # Blank line - don't change indentation
            if c == 35
                while lex.pos < lex.len && lex_peek(lex) != 10
                    lex_advance(lex)
            if lex_peek(lex) == 10
                lex_advance(lex)
            lex.at_line_start = 1
            tok.kind = TOK_NEWLINE
            tok.start = lex.input + lex.pos - 1
            tok.len = 1
            tok.line = lex.line - 1
            tok.col = 1
            return 0

        if c == 0
            # EOF - emit dedents
            while lex.indent_depth > 0
                lex.indent_depth = lex.indent_depth - 1
                lex.pending_dedents = lex.pending_dedents + 1
            if lex.pending_dedents > 0
                return lexer_next(lex, tok)
            tok.kind = TOK_EOF
            tok.start = lex.input + lex.pos
            tok.len = 0
            tok.line = lex.line
            tok.col = lex.col
            return 0

        # Compare with current indentation
        let current_indent: i32 = lex.indent_stack[lex.indent_depth]

        if spaces > current_indent
            # Indent
            lex.indent_depth = lex.indent_depth + 1
            lex.indent_stack[lex.indent_depth] = spaces
            tok.kind = TOK_INDENT
            tok.start = lex.input + lex.pos
            tok.len = 0
            tok.line = lex.line
            tok.col = 1
            return 0
        else if spaces < current_indent
            # Dedent(s)
            while lex.indent_depth > 0 && lex.indent_stack[lex.indent_depth] > spaces
                lex.indent_depth = lex.indent_depth - 1
                lex.pending_dedents = lex.pending_dedents + 1
            if lex.pending_dedents > 0
                return lexer_next(lex, tok)

    # Skip whitespace (not newlines)
    while lex.pos < lex.len
        let c: u8 = lex_peek(lex)
        if c == 32 || c == 9 || c == 13
            lex_advance(lex)
        else
            break

    # Check for EOF
    if lex.pos >= lex.len
        # Emit remaining dedents
        while lex.indent_depth > 0
            lex.indent_depth = lex.indent_depth - 1
            lex.pending_dedents = lex.pending_dedents + 1
        if lex.pending_dedents > 0
            return lexer_next(lex, tok)
        tok.kind = TOK_EOF
        tok.start = lex.input + lex.pos
        tok.len = 0
        tok.line = lex.line
        tok.col = lex.col
        return 0

    # Check for comment
    if lex_peek(lex) == 35  # '#'
        let start: i64 = lex.pos
        while lex.pos < lex.len && lex_peek(lex) != 10
            lex_advance(lex)
        # Skip comments by recursing
        return lexer_next(lex, tok)

    # Check for newline
    if lex_peek(lex) == 10
        let start: i64 = lex.pos
        lex_advance(lex)
        lex.at_line_start = 1
        tok.kind = TOK_NEWLINE
        tok.start = lex.input + start
        tok.len = 1
        tok.line = lex.line - 1
        tok.col = lex.col
        return 0

    # Try to match tokens from definitions
    let start_pos: i64 = lex.pos
    let start_line: i32 = lex.line
    let start_col: i32 = lex.col

    var best_match: i32 = 0
    var best_len: i32 = 0
    var best_is_skip: i32 = 0

    var i: i32 = 0
    while i < lex.defs.count
        let def: *TokenDef = &lex.defs.defs[i]
        var match_len: i32 = 0

        if def.is_literal != 0
            if try_match_literal(lex, def.pattern, def.pattern_len) != 0
                match_len = def.pattern_len
        else
            match_len = try_match_pattern(lex, def.pattern, def.pattern_len)

        # Take longest match (or first if equal - keywords before idents)
        if match_len > best_len
            best_match = def.token_id
            best_len = match_len
            best_is_skip = def.is_skip

        i = i + 1

    if best_len > 0
        # Advance past matched token
        var j: i32 = 0
        while j < best_len
            lex_advance(lex)
            j = j + 1

        # Skip tokens marked as skip
        if best_is_skip != 0
            return lexer_next(lex, tok)

        tok.kind = best_match
        tok.start = lex.input + start_pos
        tok.len = best_len
        tok.line = start_line
        tok.col = start_col
        return 0

    # No match - error token
    tok.kind = TOK_ERROR
    tok.start = lex.input + start_pos
    tok.len = 1
    tok.line = start_line
    tok.col = start_col
    lex_advance(lex)
    return 0

# =============================================================================
# Token name lookup
# =============================================================================

fn get_token_name(defs: *TokenDefs, kind: i32, buf: *u8, max_len: i32) -> i32
    if kind == TOK_EOF
        strcpy(buf, "EOF")
        return 3
    if kind == TOK_ERROR
        strcpy(buf, "ERROR")
        return 5
    if kind == TOK_SKIP
        strcpy(buf, "SKIP")
        return 4
    if kind == TOK_NEWLINE
        strcpy(buf, "NEWLINE")
        return 7
    if kind == TOK_INDENT
        strcpy(buf, "INDENT")
        return 6
    if kind == TOK_DEDENT
        strcpy(buf, "DEDENT")
        return 6

    var i: i32 = 0
    while i < defs.count
        if defs.defs[i].token_id == kind
            let len: i32 = defs.defs[i].name_len
            if len < max_len
                memcpy(buf, defs.defs[i].name, (len + 1) as i64)
                return len
        i = i + 1

    strcpy(buf, "???")
    return 3

# =============================================================================
# File testing
# =============================================================================

fn test_file(path: *u8, defs: *TokenDefs, verbose: i32) -> i32
    # Read file
    var buf: ByteVec = bytevec_new()
    let fd: i32 = sys_open(path, 0)
    if fd < 0
        eprints("Cannot open: ")
        eprints(path)
        eprints("\n")
        return 0 - 1

    var chunk: [4096]u8
    while 1 == 1
        let n: i64 = sys_read(fd, &chunk[0], 4096)
        if n <= 0
            break
        bytevec_push_bytes(&buf, &chunk[0], n)
    sys_close(fd)

    # Lex file
    var lex: Lexer
    lexer_init(&lex, buf.data, buf.len, defs)

    var tok: Token
    var error_count: i32 = 0
    var token_count: i32 = 0

    while 1 == 1
        lexer_next(&lex, &tok)
        token_count = token_count + 1

        if verbose != 0
            var name: [64]u8
            get_token_name(defs, tok.kind, &name[0], 64)

            # Print token info
            print_int(tok.line as i64)
            prints(":")
            print_int(tok.col as i64)
            prints(" ")
            prints(&name[0])

            if tok.len > 0 && tok.kind != TOK_NEWLINE
                prints(" '")
                sys_write(1, tok.start, tok.len as i64)
                prints("'")
            prints("\n")

        if tok.kind == TOK_ERROR
            error_count = error_count + 1
            if verbose == 0
                eprints(path)
                eprints(":")
                eprint_int(tok.line as i64)
                eprints(":")
                eprint_int(tok.col as i64)
                eprints(": error: unexpected character '")
                sys_write(2, tok.start, 1)
                eprints("'\n")

        if tok.kind == TOK_EOF
            break

    bytevec_free(&buf)

    if error_count == 0
        if verbose == 0
            prints(path)
            prints(": OK (")
            print_int(token_count as i64)
            prints(" tokens)\n")
        return 0
    else
        eprints(path)
        eprints(": ")
        eprint_int(error_count as i64)
        eprints(" errors\n")
        return error_count

# Test all .ritz files in a directory
fn test_directory(dir: *u8, defs: *TokenDefs, verbose: i32) -> i32
    var total_files: i32 = 0
    var failed_files: i32 = 0

    # Use find to list .ritz files
    var entries: [256]*u8
    var entry_count: i32 = 0

    # Read directory entries
    let dfd: i32 = sys_open(dir, 65536)  # O_RDONLY | O_DIRECTORY
    if dfd < 0
        eprints("Cannot open directory: ")
        eprints(dir)
        eprints("\n")
        return 0 - 1

    # TODO: proper directory traversal
    # For now, just test specific paths
    sys_close(dfd)

    prints("Directory testing not fully implemented yet\n")
    prints("Use: ritzgen grammar.ritz file.ritz\n")

    return 0

# =============================================================================
# Main
# =============================================================================

fn main(argc: i32, argv: **u8) -> i32
    var argparser: ArgParser
    args_init(&argparser, "ritzgen", "Ritz Parser Generator")
    args_flag(&argparser, 't', "test", "Test mode: lex files and report errors")
    args_flag(&argparser, 'v', "verbose", "Verbose output (show all tokens)")
    args_flag(&argparser, 'g', "generate", "Generate parser code")
    args_flag(&argparser, 'a', "ast", "Parse input and print AST")
    args_option(&argparser, 'o', "output", "FILE", "Output file for generated code", "")
    # Single positional def: GRAMMAR [INPUT...]
    # First arg is grammar, rest are input files
    args_positional(&argparser, "GRAMMAR [INPUT...]", "Grammar file and optional input files", 1, 100)

    if args_parse(&argparser, argc, argv) != 0
        return 1

    let test_mode: i32 = args_get_flag(&argparser, 't')
    let verbose: i32 = args_get_flag(&argparser, 'v')
    let generate: i32 = args_get_flag(&argparser, 'g')
    let ast_mode: i32 = args_get_flag(&argparser, 'a')

    # Read grammar file
    let grammar_path: *u8 = args_get_positional(&argparser, 0)

    var grammar_buf: ByteVec = bytevec_new()
    let gfd: i32 = sys_open(grammar_path, 0)
    if gfd < 0
        eprints("Cannot open grammar file: ")
        eprints(grammar_path)
        eprints("\n")
        return 1

    var chunk: [4096]u8
    while 1 == 1
        let n: i64 = sys_read(gfd, &chunk[0], 4096)
        if n <= 0
            break
        bytevec_push_bytes(&grammar_buf, &chunk[0], n)
    sys_close(gfd)

    # Parse grammar
    var gp: GrammarParser
    gp_init(&gp, grammar_buf.data, grammar_buf.len)

    var defs: TokenDefs
    let parse_result: i32 = parse_grammar(&gp, &defs)
    if parse_result < 0
        eprints("Failed to parse grammar file\n")
        bytevec_free(&grammar_buf)
        return 1

    prints("Loaded ")
    print_int(defs.count as i64)
    prints(" token definitions\n")

    # Parse grammar rules if %grammar section present
    var grammar: Grammar
    grammar.rule_count = 0
    if parse_result == 1
        parse_grammar_rules(&gp, &grammar)
        prints("Parsed ")
        print_int(grammar.rule_count as i64)
        prints(" grammar rules\n")
        if verbose != 0
            print_grammar(&grammar)

    # Generate parser code if requested
    if generate != 0 && grammar.rule_count > 0
        var code: ByteVec = bytevec_new()
        generate_parser(&defs, &grammar, &code)
        prints("\n# === Generated Parser ===\n\n")
        sys_write(1, code.data, code.len)
        bytevec_free(&code)
        bytevec_free(&grammar_buf)
        return 0

    # AST mode: parse input files and print AST
    if ast_mode != 0 && argparser.positional_count > 1
        var i: i32 = 1
        var errors: i32 = 0
        while i < argparser.positional_count
            let input_path: *u8 = args_get_positional(&argparser, i)
            let result: i32 = parse_file_ast(input_path, &defs, verbose)
            if result != 0
                errors = errors + 1
            i = i + 1
        bytevec_free(&grammar_buf)
        if errors > 0
            return 1
        return 0

    # Process input files
    if argparser.positional_count > 1
        var i: i32 = 1
        var errors: i32 = 0
        while i < argparser.positional_count
            let input_path: *u8 = args_get_positional(&argparser, i)
            let result: i32 = test_file(input_path, &defs, verbose)
            if result != 0
                errors = errors + 1
            i = i + 1

        bytevec_free(&grammar_buf)
        if errors > 0
            return 1
        return 0

    # No input files - just show loaded tokens
    prints("\nToken definitions:\n")
    var i: i32 = 0
    while i < defs.count
        let def: *TokenDef = &defs.defs[i]
        prints("  ")
        print_int(def.token_id as i64)
        prints(": ")
        prints(def.name)
        prints(" = ")
        if def.is_literal != 0
            prints("\"")
            prints(def.pattern)
            prints("\"")
        else
            prints("/")
            prints(def.pattern)
            prints("/")
        if def.is_skip != 0
            prints(" (skip)")
        prints("\n")
        i = i + 1

    bytevec_free(&grammar_buf)
    return 0
