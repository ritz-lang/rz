# Tests for 65_async_main — wraps the binary's self-test main().
#
# Each of these tier 5 examples runs internal test_* functions from main()
# and exits 0 if all pass.  This [[test]] just fork+execs the binary and
# asserts the exit code; the actual assertions live inside the binary.

import ritzlib.testlib

[[test]]
fn test_async_main_self() -> i32
    var argv: [2]*u8
    argv[0] = c"./async_main"
    argv[1] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./async_main", @argv[0], null, null, 0, @out[0], 4096, @n)

    assert exit_code == 0, "async_main self-tests should exit 0"
    0
