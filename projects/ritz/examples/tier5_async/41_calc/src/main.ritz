# calc - Expression evaluator
#
# Usage: calc [EXPRESSION]
#   Evaluates a mathematical expression and prints the result.
#
# Supported operators: + - * / % ( )
# Supports integer arithmetic only.
#
# Examples:
#   calc "2 + 3"           # 5
#   calc "10 * (2 + 3)"    # 50
#   calc "100 / 4 - 5"     # 20
#   calc "(1 + 2) * (3 + 4)"  # 21

# ============================================================================
# Standard library imports
# ============================================================================

import ritzlib.sys
import ritzlib.io
import ritzlib.str
import ritzlib.args

# ============================================================================
# Parser (combined lexer + parser state)
# ============================================================================

# Token types
const TOK_EOF: i32 = 0
const TOK_NUM: i32 = 1
const TOK_PLUS: i32 = 2
const TOK_MINUS: i32 = 3
const TOK_STAR: i32 = 4
const TOK_SLASH: i32 = 5
const TOK_PERCENT: i32 = 6
const TOK_LPAREN: i32 = 7
const TOK_RPAREN: i32 = 8
const TOK_ERROR: i32 = 9

struct Parser
    # Input buffer
    data: *u8
    len: i64
    pos: i64
    # Current token
    tok_type: i32
    tok_value: i64
    # Error flag
    error: i32

fn parser_init(p: *Parser, input: *u8) -> i32
    p.data = input
    p.len = strlen(input)
    p.pos = 0
    p.tok_type = TOK_EOF
    p.tok_value = 0
    p.error = 0
    next_token(p)
    return 0

fn peek_char(p: *Parser) -> u8
    if p.pos >= p.len
        return 0
    return *(p.data + p.pos)

fn advance_char(p: *Parser) -> u8
    if p.pos >= p.len
        return 0
    let c: u8 = *(p.data + p.pos)
    p.pos = p.pos + 1
    return c

fn skip_whitespace(p: *Parser) -> i32
    while p.pos < p.len
        let c: u8 = *(p.data + p.pos)
        if c != ' ' and c != '\t' and c != '\n' and c != '\r'
            break
        p.pos = p.pos + 1
    return 0

fn next_token(p: *Parser) -> i32
    skip_whitespace(p)

    if p.pos >= p.len
        p.tok_type = TOK_EOF
        p.tok_value = 0
        return 0

    let c: u8 = peek_char(p)

    # Number
    if c >= '0' and c <= '9'
        var value: i64 = 0
        while p.pos < p.len
            let d: u8 = *(p.data + p.pos)
            if d < '0' or d > '9'
                break
            value = value * 10 + (d - '0') as i64
            p.pos = p.pos + 1
        p.tok_type = TOK_NUM
        p.tok_value = value
        return 0

    advance_char(p)

    if c == '+'
        p.tok_type = TOK_PLUS
        return 0
    if c == '-'
        p.tok_type = TOK_MINUS
        return 0
    if c == '*'
        p.tok_type = TOK_STAR
        return 0
    if c == '/'
        p.tok_type = TOK_SLASH
        return 0
    if c == '%'
        p.tok_type = TOK_PERCENT
        return 0
    if c == '('
        p.tok_type = TOK_LPAREN
        return 0
    if c == ')'
        p.tok_type = TOK_RPAREN
        return 0

    p.tok_type = TOK_ERROR
    return -1

fn expect_token(p: *Parser, tok_type: i32) -> i32
    if p.tok_type != tok_type
        p.error = 1
        return -1
    next_token(p)
    return 0

fn get_precedence(tok_type: i32) -> i32
    if tok_type == TOK_PLUS or tok_type == TOK_MINUS
        return 1
    if tok_type == TOK_STAR or tok_type == TOK_SLASH or tok_type == TOK_PERCENT
        return 2
    return 0

fn parse_primary(p: *Parser) -> i64
    let tok: i32 = p.tok_type

    if tok == TOK_NUM
        let val: i64 = p.tok_value
        next_token(p)
        return val

    if tok == TOK_LPAREN
        next_token(p)
        let val: i64 = parse_expr(p, 0)
        if expect_token(p, TOK_RPAREN) != 0
            eprints("calc: missing ')'\n")
            return 0
        return val

    if tok == TOK_MINUS
        next_token(p)
        return 0 - parse_primary(p)

    if tok == TOK_PLUS
        next_token(p)
        return parse_primary(p)

    p.error = 1
    eprints("calc: unexpected token\n")
    return 0

fn parse_expr(p: *Parser, min_prec: i32) -> i64
    var left: i64 = parse_primary(p)

    while p.error == 0
        let op: i32 = p.tok_type
        let prec: i32 = get_precedence(op)

        if prec == 0 or prec <= min_prec
            break

        next_token(p)
        let right: i64 = parse_expr(p, prec)

        if op == TOK_PLUS
            left += right
        else if op == TOK_MINUS
            left -= right
        else if op == TOK_STAR
            left *= right
        else if op == TOK_SLASH
            if right == 0
                eprints("calc: division by zero\n")
                p.error = 1
                return 0
            left /= right
        else if op == TOK_PERCENT
            if right == 0
                eprints("calc: modulo by zero\n")
                p.error = 1
                return 0
            left = left % right

    return left

# ============================================================================
# Main
# ============================================================================

fn main(argc: i32, argv: **u8) -> i32
    var argparser: ArgParser
    args_init(&argparser, "calc", "Evaluate a mathematical expression")
    args_positional(&argparser, "EXPRESSION", "Mathematical expression to evaluate", 1, 1)

    if args_parse(&argparser, argc, argv) != 0
        return 1

    let expr: *u8 = args_get_positional(&argparser, 0)

    var p: Parser
    parser_init(&p, expr)

    let result: i64 = parse_expr(&p, 0)

    if p.error != 0
        return 1

    if p.tok_type != TOK_EOF
        eprints("calc: unexpected characters after expression\n")
        return 1

    print_int(result)
    print_char(10)

    return 0
