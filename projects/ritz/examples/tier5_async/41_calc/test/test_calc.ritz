# Tests for 41_calc — expression evaluator.
#
# Each test runs ./calc with one argv expression and asserts the
# exact stdout (calc prints `<result>\n`).  Mirrors the scenarios in
# test.sh but written so an assertion failure points at the specific
# scenario instead of just exiting 1.

import ritzlib.testlib

# Run ./calc <expr> and capture stdout.  Returns exit code.
fn calc_run(expr: *u8, out_buf: *u8, out_len: *i64) -> i32
    var argv: [3]*u8
    argv[0] = c"./calc"
    argv[1] = expr
    argv[2] = null
    return exec_capture(c"./calc", @argv[0], null, null, 0, out_buf, 64, out_len)

# Run ./calc -- <expr> (escapes leading minus).
fn calc_run_dashdash(expr: *u8, out_buf: *u8, out_len: *i64) -> i32
    var argv: [4]*u8
    argv[0] = c"./calc"
    argv[1] = c"--"
    argv[2] = expr
    argv[3] = null
    return exec_capture(c"./calc", @argv[0], null, null, 0, out_buf, 64, out_len)

[[test]]
fn test_calc_addition() -> i32
    var out: [64]u8
    var n: i64 = 0
    assert calc_run(c"2 + 3", @out[0], @n) == 0, "calc 2+3 should exit 0"
    assert n == 2, "expected 2 bytes (5\\n)"
    assert buf_eq(@out[0], c"5\n", 2) == 1, "2+3 != 5"
    0

[[test]]
fn test_calc_subtraction() -> i32
    var out: [64]u8
    var n: i64 = 0
    assert calc_run(c"10 - 4", @out[0], @n) == 0, "exit 0"
    assert buf_eq(@out[0], c"6\n", 2) == 1, "10-4 != 6"
    0

[[test]]
fn test_calc_multiplication() -> i32
    var out: [64]u8
    var n: i64 = 0
    assert calc_run(c"3 * 7", @out[0], @n) == 0, "exit 0"
    assert buf_eq(@out[0], c"21\n", 3) == 1, "3*7 != 21"
    0

[[test]]
fn test_calc_division() -> i32
    var out: [64]u8
    var n: i64 = 0
    assert calc_run(c"20 / 4", @out[0], @n) == 0, "exit 0"
    assert buf_eq(@out[0], c"5\n", 2) == 1, "20/4 != 5"
    0

[[test]]
fn test_calc_modulo() -> i32
    var out: [64]u8
    var n: i64 = 0
    assert calc_run(c"17 % 5", @out[0], @n) == 0, "exit 0"
    assert buf_eq(@out[0], c"2\n", 2) == 1, "17%5 != 2"
    0

[[test]]
fn test_calc_precedence() -> i32
    var out: [64]u8
    var n: i64 = 0
    assert calc_run(c"2 + 3 * 4", @out[0], @n) == 0, "exit 0"
    assert buf_eq(@out[0], c"14\n", 3) == 1, "expected 14 (precedence)"
    0

[[test]]
fn test_calc_parens() -> i32
    var out: [64]u8
    var n: i64 = 0
    assert calc_run(c"(2 + 3) * 4", @out[0], @n) == 0, "exit 0"
    assert buf_eq(@out[0], c"20\n", 3) == 1, "expected 20 (parens override)"
    0

[[test]]
fn test_calc_nested_parens() -> i32
    var out: [64]u8
    var n: i64 = 0
    assert calc_run(c"((1 + 2) * (3 + 4))", @out[0], @n) == 0, "exit 0"
    assert buf_eq(@out[0], c"21\n", 3) == 1, "expected 21"
    0

[[test]]
fn test_calc_unary_minus() -> i32
    # `--` stops option parsing so calc sees `-5` as the expression.
    var out: [64]u8
    var n: i64 = 0
    assert calc_run_dashdash(c"-5", @out[0], @n) == 0, "exit 0"
    assert buf_eq(@out[0], c"-5\n", 3) == 1, "expected -5"
    0

[[test]]
fn test_calc_large_numbers() -> i32
    var out: [64]u8
    var n: i64 = 0
    assert calc_run(c"1000 + 2000", @out[0], @n) == 0, "exit 0"
    assert buf_eq(@out[0], c"3000\n", 5) == 1, "expected 3000"
    0
