# examples/60_echo_server/main.ritz - TCP echo server with io_uring
#
# A simple TCP echo server using io_uring for efficient I/O.
# This demonstrates the io_uring-based networking capabilities of Ritz.
#
# Note: This uses runtime_* functions which are io_uring-backed but
# synchronous wrappers (not async/await syntax). True async/await
# with proper state machines will be implemented in Phase 12 (Valet).
#
# Usage: ./echo_server [port]
# Default port: 8080

import ritzlib.sys
import ritzlib.io
import ritzlib.uring
import ritzlib.async_runtime
import ritzlib.async_net

# ============================================================================
# Echo server implementation
# ============================================================================

# Handle a single client connection - read data and echo it back
fn handle_client(rt: *Runtime, client_fd: i32) -> i32
    var buf: [4096]u8
    var total_bytes: i64 = 0

    # Read/write loop
    loop
        # Read from client via io_uring
        let n: i64 = runtime_recv(rt, client_fd, @buf[0], 4096)

        if n <= 0
            # Connection closed or error
            break

        # Echo back via io_uring
        let written: i64 = runtime_send(rt, client_fd, @buf[0], n as i32)
        if written < 0
            break

        total_bytes += n

    sys_close(client_fd)
    return total_bytes as i32

# Run the echo server
fn run_server(port: i32) -> i32
    prints("Starting echo server on port ")
    print_int(port as i64)
    prints("...\n")

    # Initialize async runtime
    var rt: Runtime
    let ret_init: i32 = runtime_init(@rt)
    if ret_init < 0
        prints("Failed to initialize runtime\n")
        return 1

    # Create server socket
    let server_fd: i32 = tcp_socket()
    if server_fd < 0
        prints("Failed to create socket\n")
        runtime_destroy(@rt)
        return 1

    # Set socket options
    set_reuseaddr(server_fd)

    # Bind to all interfaces
    let ret_bind: i32 = tcp_bind(server_fd, inaddr_any(), port)
    if ret_bind < 0
        prints("Failed to bind to port ")
        print_int(port as i64)
        prints("\n")
        sys_close(server_fd)
        runtime_destroy(@rt)
        return 1

    # Start listening
    let ret_listen: i32 = tcp_listen(server_fd, 128)
    if ret_listen < 0
        prints("Failed to listen\n")
        sys_close(server_fd)
        runtime_destroy(@rt)
        return 1

    prints("Server listening on 0.0.0.0:")
    print_int(port as i64)
    prints("\n")
    prints("Press Ctrl+C to stop\n\n")

    # Accept loop - handle one client at a time for now
    var client_count: i32 = 0
    loop
        # Accept via io_uring
        let client_fd: i32 = runtime_accept(@rt, server_fd)
        if client_fd < 0
            prints("Accept failed\n")
            continue

        client_count += 1
        prints("Client ")
        print_int(client_count as i64)
        prints(" connected\n")

        # Handle client (blocking for now - could fork for concurrency)
        let bytes_echoed: i32 = handle_client(@rt, client_fd)

        prints("Client ")
        print_int(client_count as i64)
        prints(" disconnected, echoed ")
        print_int(bytes_echoed as i64)
        prints(" bytes\n")

    sys_close(server_fd)
    runtime_destroy(@rt)
    return 0

# ============================================================================
# Test mode - run server briefly and have client connect
# ============================================================================

fn test_echo_server() -> i32
    prints("test_echo_server... ")

    # Initialize runtime
    var rt: Runtime
    let ret_init: i32 = runtime_init(@rt)
    if ret_init < 0
        prints("FAIL: runtime init\n")
        return 1

    # Create server
    let server_fd: i32 = tcp_socket()
    set_reuseaddr(server_fd)

    let port: i32 = 9878
    let lh: i32 = localhost()
    tcp_bind(server_fd, lh, port)
    tcp_listen(server_fd, 1)

    # Fork - child is client, parent is server
    let pid: i32 = sys_fork()

    if pid == 0
        # Child: client
        # Small delay
        var ts: [16]u8
        let ts_ptr: *i64 = @ts[0] as *i64
        *ts_ptr = 0
        *(ts_ptr + 1) = 10000000
        sys_nanosleep(@ts[0] as *i64, null)

        let client_fd: i32 = tcp_socket()
        let ret: i32 = tcp_connect(client_fd, lh, port)
        if ret < 0
            sys_exit(1)

        # Send test data
        var send_buf: [32]u8
        send_buf[0] = 72   # H
        send_buf[1] = 101  # e
        send_buf[2] = 108  # l
        send_buf[3] = 108  # l
        send_buf[4] = 111  # o
        sys_write(client_fd, @send_buf[0], 5)

        # Read echo
        var recv_buf: [32]u8
        let n: i64 = sys_read(client_fd, @recv_buf[0], 32)

        sys_close(client_fd)

        # Verify echo
        if n != 5
            sys_exit(2)
        if recv_buf[0] != 72
            sys_exit(3)
        if recv_buf[4] != 111
            sys_exit(4)

        sys_exit(0)
    else
        # Parent: server
        # Accept one client
        let client_fd: i32 = runtime_accept(@rt, server_fd)
        if client_fd < 0
            prints("FAIL: accept\n")
            sys_close(server_fd)
            runtime_destroy(@rt)
            return 1

        # Echo one message
        var buf: [64]u8
        let n: i64 = runtime_recv(@rt, client_fd, @buf[0], 64)
        if n > 0
            runtime_send(@rt, client_fd, @buf[0], n as i32)

        sys_close(client_fd)

        # Wait for child
        var status: i32 = 0
        sys_wait4(pid, @status, 0, null)

        # Check child exit status
        let exit_code: i32 = (status >> 8) & 255
        if exit_code != 0
            prints("FAIL: client exit code ")
            print_int(exit_code as i64)
            prints("\n")
            sys_close(server_fd)
            runtime_destroy(@rt)
            return 1

    sys_close(server_fd)
    runtime_destroy(@rt)
    prints("OK\n")
    return 0

fn test_multiple_messages() -> i32
    prints("test_multiple_messages... ")

    var rt: Runtime
    runtime_init(@rt)

    let server_fd: i32 = tcp_socket()
    set_reuseaddr(server_fd)

    let port: i32 = 9879
    let lh: i32 = localhost()
    tcp_bind(server_fd, lh, port)
    tcp_listen(server_fd, 1)

    let pid: i32 = sys_fork()

    if pid == 0
        # Child: client - send multiple messages
        var ts: [16]u8
        let ts_ptr: *i64 = @ts[0] as *i64
        *ts_ptr = 0
        *(ts_ptr + 1) = 10000000
        sys_nanosleep(@ts[0] as *i64, null)

        let client_fd: i32 = tcp_socket()
        tcp_connect(client_fd, lh, port)

        var i: i32 = 0
        while i < 5
            # Send message
            var send_buf: [8]u8
            send_buf[0] = (65 + i) as u8  # A, B, C, D, E
            send_buf[1] = 10              # newline
            sys_write(client_fd, @send_buf[0], 2)

            # Read echo
            var recv_buf: [8]u8
            sys_read(client_fd, @recv_buf[0], 2)

            # Verify
            if recv_buf[0] != send_buf[0]
                sys_exit(i + 1)

            i += 1

        sys_close(client_fd)
        sys_exit(0)
    else
        # Parent: server - echo multiple messages
        let client_fd: i32 = runtime_accept(@rt, server_fd)

        var i: i32 = 0
        while i < 5
            var buf: [8]u8
            let n: i64 = runtime_recv(@rt, client_fd, @buf[0], 8)
            if n > 0
                runtime_send(@rt, client_fd, @buf[0], n as i32)
            i += 1

        sys_close(client_fd)

        var status: i32 = 0
        sys_wait4(pid, @status, 0, null)

        let exit_code: i32 = (status >> 8) & 255
        if exit_code != 0
            prints("FAIL: client exit ")
            print_int(exit_code as i64)
            prints("\n")
            sys_close(server_fd)
            runtime_destroy(@rt)
            return 1

    sys_close(server_fd)
    runtime_destroy(@rt)
    prints("OK\n")
    return 0

fn test_large_data() -> i32
    prints("test_large_data... ")

    var rt: Runtime
    runtime_init(@rt)

    let server_fd: i32 = tcp_socket()
    set_reuseaddr(server_fd)

    let port: i32 = 9880
    let lh: i32 = localhost()
    tcp_bind(server_fd, lh, port)
    tcp_listen(server_fd, 1)

    let pid: i32 = sys_fork()

    if pid == 0
        # Child: client - send 1KB of data
        var ts: [16]u8
        let ts_ptr: *i64 = @ts[0] as *i64
        *ts_ptr = 0
        *(ts_ptr + 1) = 10000000
        sys_nanosleep(@ts[0] as *i64, null)

        let client_fd: i32 = tcp_socket()
        tcp_connect(client_fd, lh, port)

        # Send 1KB of pattern data
        var send_buf: [1024]u8
        var i: i32 = 0
        while i < 1024
            send_buf[i] = (i % 256) as u8
            i += 1

        sys_write(client_fd, @send_buf[0], 1024)

        # Read echo
        var recv_buf: [1024]u8
        var total: i64 = 0
        while total < 1024
            let n: i64 = sys_read(client_fd, @recv_buf[0] + total, 1024 - total)
            if n <= 0
                break
            total += n

        sys_close(client_fd)

        # Verify
        if total != 1024
            sys_exit(1)

        i = 0
        while i < 1024
            if recv_buf[i] != send_buf[i]
                sys_exit(2)
            i += 1

        sys_exit(0)
    else
        # Parent: server
        let client_fd: i32 = runtime_accept(@rt, server_fd)

        # Echo all data
        var buf: [4096]u8
        var total: i64 = 0
        while total < 1024
            let n: i64 = runtime_recv(@rt, client_fd, @buf[0], 4096)
            if n <= 0
                break
            runtime_send(@rt, client_fd, @buf[0], n as i32)
            total += n

        sys_close(client_fd)

        var status: i32 = 0
        sys_wait4(pid, @status, 0, null)

        let exit_code: i32 = (status >> 8) & 255
        if exit_code != 0
            prints("FAIL: exit ")
            print_int(exit_code as i64)
            prints("\n")
            sys_close(server_fd)
            runtime_destroy(@rt)
            return 1

    sys_close(server_fd)
    runtime_destroy(@rt)
    prints("OK\n")
    return 0

# ============================================================================
# Main
# ============================================================================

fn main() -> i32
    # Run tests
    var failures: i32 = 0

    failures += test_echo_server()
    failures += test_multiple_messages()
    failures += test_large_data()

    if failures > 0
        prints("\n")
        print_int(failures as i64)
        prints(" test(s) failed\n")
        return 1

    prints("\nAll echo server tests passed!\n")
    return 0
