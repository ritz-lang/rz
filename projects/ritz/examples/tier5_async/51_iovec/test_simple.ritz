# Simple iovec test - all in one file

import ritzlib.sys
import ritzlib.io

# iovec structure (matches Linux struct iovec)
struct Iovec
    base: *u8
    len: u64

fn main() -> i32
    prints("=== Simple IoVec Test ===\n\n")

    # Create array of iovecs
    var iovecs: [4]Iovec

    # Point directly to static strings (zero-copy!)
    let s1 = "HTTP/1.1 200 OK\r\n"
    let s2 = "Content-Length: 13\r\n"
    let s3 = "\r\n"
    let s4 = "Hello, World!"

    iovecs[0].base = s1
    iovecs[0].len = 17

    iovecs[1].base = s2
    iovecs[1].len = 20

    iovecs[2].base = s3
    iovecs[2].len = 2

    iovecs[3].base = s4
    iovecs[3].len = 13

    # Write all at once using writev
    prints("Response:\n---\n")
    let written = sys_writev(1, &iovecs[0] as *u8, 4)
    prints("\n---\n")

    prints("Total bytes written: ")
    print_int(written)
    prints("\n")

    return 0
