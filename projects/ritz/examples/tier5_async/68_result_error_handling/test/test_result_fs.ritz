# Tests for Result-based filesystem functions
import ritzlib.sys
import ritzlib.fs
import ritzlib.string
import ritzlib.result

[[test]]
fn test_write_and_read_file() -> i32
    var path: String = string_from("/tmp/ritz_test_rw.txt")
    var content: String = string_from("Hello, Result!")

    # Write file
    var w_res: Result<i64, i32> = write_file_string(&path, &content)
    if result_is_err<i64, i32>(&w_res) == 1
        string_drop(&path)
        string_drop(&content)
        return 1

    # Read it back
    var read_content: String = string_new()
    let r_err: i32 = read_file_string(&path, &read_content)
    if r_err != 0
        unlink_string(&path)
        string_drop(&path)
        string_drop(&content)
        string_drop(&read_content)
        return 2

    # Verify content matches
    let matches: i32 = string_eq(&read_content, &content)
    string_drop(&read_content)
    unlink_string(&path)
    string_drop(&path)
    string_drop(&content)
    if matches == 1
        return 0
    return 3

[[test]]
fn test_read_nonexistent_file() -> i32
    var path: String = string_from("/tmp/does_not_exist_xyz123.txt")
    var content: String = string_new()
    let err: i32 = read_file_string(&path, &content)
    string_drop(&path)
    string_drop(&content)

    # Should fail
    if err != 0
        return 0
    return 1

[[test]]
fn test_mkdir_and_rmdir() -> i32
    var path: String = string_from("/tmp/ritz_test_dir")

    # Create directory
    let mk_err: i32 = mkdir_string(&path, 493)  # 0755 octal = 493 decimal
    if mk_err != 0
        string_drop(&path)
        return 1

    # Verify it exists
    if is_directory_string(&path) != 1
        string_drop(&path)
        return 2

    # Remove it
    let rm_err: i32 = rmdir_string(&path)
    if rm_err != 0
        string_drop(&path)
        return 3

    # Verify it's gone
    if path_exists_string(&path) == 1
        string_drop(&path)
        return 4

    string_drop(&path)
    return 0

[[test]]
fn test_copy_file() -> i32
    var src: String = string_from("/tmp/ritz_test_src.txt")
    var dst: String = string_from("/tmp/ritz_test_dst.txt")
    var content: String = string_from("Content to copy")

    # Create source file
    write_file_string(&src, &content)

    # Copy it
    var cp_res: Result<i64, i32> = copy_file_string(&src, &dst, 420)  # 0644 octal = 420 decimal
    if result_is_err<i64, i32>(&cp_res) == 1
        unlink_string(&src)
        string_drop(&src)
        string_drop(&dst)
        string_drop(&content)
        return 1

    # Read destination and verify
    var dst_content: String = string_new()
    let rd_err: i32 = read_file_string(&dst, &dst_content)
    if rd_err != 0
        unlink_string(&src)
        unlink_string(&dst)
        string_drop(&src)
        string_drop(&dst)
        string_drop(&content)
        string_drop(&dst_content)
        return 2

    let matches: i32 = string_eq(&dst_content, &content)
    string_drop(&dst_content)
    unlink_string(&src)
    unlink_string(&dst)
    string_drop(&src)
    string_drop(&dst)
    string_drop(&content)
    if matches == 1
        return 0
    return 3

fn main() -> i32
    return 0
