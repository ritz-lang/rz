# Tests for type inference

[[test]]
fn test_integer_inference() -> i32
    let x = 42
    let y = 10
    let z = x + y
    assert z == 52, "integer arithmetic should work"
    0

[[test]]
fn test_bool_inference() -> i32
    let t = true
    let f = false
    assert t, "true should be true"
    assert not f, "false should be false"
    0

[[test]]
fn test_char_inference() -> i32
    let ch = 'X'
    assert ch == 88, "char should be ASCII value"
    0

[[test]]
fn test_string_inference() -> i32
    let s = "hello"
    # String literals are *u8, check first char
    assert *s == 'h', "string should start with h"
    0

[[test]]
fn test_cast_inference() -> i32
    let x = 1000 as i32
    let y = 2000 as i32
    let sum = x + y
    assert sum == 3000, "cast values should add correctly"
    0

[[test]]
fn test_comparison_inference() -> i32
    let a = 10
    let b = 20
    let lt = a < b
    let gt = a > b
    let eq = a == b
    assert lt, "10 < 20"
    assert not gt, "not 10 > 20"
    assert not eq, "not 10 == 20"
    0

[[test]]
fn test_mixed_arithmetic() -> i32
    let base = 100
    let factor = 3
    let result = base * factor + 50
    assert result == 350, "mixed arithmetic"
    0
