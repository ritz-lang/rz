# Tests for 22_mkdir — create directories.
#
# Helpers (buf_eq, make_sandbox_path, exec_capture) live in ritzlib.testlib;
# see docs/TESTING.md for the canonical template.

import ritzlib.sys
import ritzlib.testlib

[[test]]
fn test_mkdir_creates_directory() -> i32
    var path: [128]u8
    make_sandbox_path(@path[0], c"mkdir", c"one")
    sys_rmdir(@path[0])  # best-effort prior cleanup

    var argv: [3]*u8
    argv[0] = c"./mkdir"
    argv[1] = @path[0]
    argv[2] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./mkdir", @argv[0], null, null, 0, @out[0], 1024, @n)

    var st: Stat
    let stat_rc: i32 = sys_stat2(@path[0], @st)
    sys_rmdir(@path[0])

    assert exit_code == 0, "mkdir <new> should exit 0"
    assert stat_rc == 0, "directory should exist after mkdir"
    0

[[test]]
fn test_mkdir_existing_dir_errors() -> i32
    var path: [128]u8
    make_sandbox_path(@path[0], c"mkdir", c"exists")
    sys_rmdir(@path[0])

    if sys_mkdir(@path[0], 493) < 0
        assert 0 == 1, "setup: could not create existing dir"

    var argv: [3]*u8
    argv[0] = c"./mkdir"
    argv[1] = @path[0]
    argv[2] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./mkdir", @argv[0], null, null, 0, @out[0], 1024, @n)
    sys_rmdir(@path[0])

    assert exit_code == 1, "mkdir of existing dir should exit 1 without -p"
    0

[[test]]
fn test_mkdir_creates_sibling() -> i32
    var path: [128]u8
    make_sandbox_path(@path[0], c"mkdir", c"two")
    sys_rmdir(@path[0])

    var argv: [3]*u8
    argv[0] = c"./mkdir"
    argv[1] = @path[0]
    argv[2] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./mkdir", @argv[0], null, null, 0, @out[0], 1024, @n)

    var st: Stat
    let stat_rc: i32 = sys_stat2(@path[0], @st)
    sys_rmdir(@path[0])

    assert exit_code == 0, "mkdir sibling should exit 0"
    assert stat_rc == 0, "sibling directory should exist"
    0
