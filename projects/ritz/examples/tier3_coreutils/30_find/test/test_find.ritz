# Tests for 30_find — directory traversal.
import ritzlib.sys
import ritzlib.testlib

# Build path "<root>/<seg>" into dst, returns length.
fn join_path(dst: *u8, root: *u8, root_len: i64, seg: *u8) -> i64
    var i: i64 = 0
    while i < root_len
        *(dst + i) = *(root + i)
        i += 1
    *(dst + i) = '/' as u8
    i += 1
    var k: i64 = 0
    while *(seg + k) != 0
        *(dst + i) = *(seg + k)
        i += 1
        k += 1
    *(dst + i) = 0
    return i

[[test]]
fn test_find_lists_tree() -> i32
    # Build $T/a (file), $T/b (dir), $T/b/c (file), $T/b/d (file)
    var root: [128]u8
    let rlen: i64 = make_sandbox_path(@root[0], c"find", c"tree")
    sys_rmdir(@root[0])
    if sys_mkdir(@root[0], 493) < 0
        assert 0 == 1, "setup: root"

    var path_a: [192]u8
    var path_b: [192]u8
    var path_c: [192]u8
    var path_d: [192]u8
    join_path(@path_a[0], @root[0], rlen, c"a")
    let blen: i64 = join_path(@path_b[0], @root[0], rlen, c"b")
    join_path(@path_c[0], @path_b[0], blen, c"c")
    join_path(@path_d[0], @path_b[0], blen, c"d")

    sys_mkdir(@path_b[0], 493)
    write_file(@path_a[0], c"", 0)
    write_file(@path_c[0], c"", 0)
    write_file(@path_d[0], c"", 0)

    var argv: [3]*u8
    argv[0] = c"./find"
    argv[1] = @root[0]
    argv[2] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./find", @argv[0], null, null, 0, @out[0], 4096, @n)

    sys_unlink(@path_a[0])
    sys_unlink(@path_c[0])
    sys_unlink(@path_d[0])
    sys_rmdir(@path_b[0])
    sys_rmdir(@root[0])

    assert exit_code == 0, "find <tree> should exit 0"
    assert buf_contains(@out[0], n, @root[0], rlen) == 1, "missing root in output"
    assert buf_contains(@out[0], n, @path_a[0], cstr_len(@path_a[0])) == 1, "missing a"
    assert buf_contains(@out[0], n, @path_b[0], blen) == 1, "missing b"
    assert buf_contains(@out[0], n, @path_c[0], cstr_len(@path_c[0])) == 1, "missing b/c"
    assert buf_contains(@out[0], n, @path_d[0], cstr_len(@path_d[0])) == 1, "missing b/d"
    0

[[test]]
fn test_find_empty_dir() -> i32
    var path: [128]u8
    let plen: i64 = make_sandbox_path(@path[0], c"find", c"empty")
    sys_rmdir(@path[0])
    if sys_mkdir(@path[0], 493) < 0
        assert 0 == 1, "setup: empty"

    var argv: [3]*u8
    argv[0] = c"./find"
    argv[1] = @path[0]
    argv[2] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./find", @argv[0], null, null, 0, @out[0], 4096, @n)
    sys_rmdir(@path[0])

    assert exit_code == 0, "find <empty> should exit 0"
    assert buf_contains(@out[0], n, @path[0], plen) == 1, "empty-dir find should emit the dir"
    0
