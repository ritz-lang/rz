# Tests for 27_stat - file info
#
# Integration tests fork+exec ./stat against a sandbox under /tmp/.

import ritzlib.sys
import ritzlib.io
import ritzlib.str

fn buf_eq(a: *u8, b: *u8, len: i64) -> i32
    var i: i64 = 0
    while i < len
        if *(a + i) != *(b + i)
            return 0
        i += 1
    return 1

fn buf_contains(hay: *u8, hay_len: i64, needle: *u8, needle_len: i64) -> i32
    if needle_len == 0
        return 1
    if needle_len > hay_len
        return 0
    var i: i64 = 0
    while i <= hay_len - needle_len
        if buf_eq(hay + i, needle, needle_len) == 1
            return 1
        i += 1
    return 0

fn cstr_len(s: *u8) -> i64
    var n: i64 = 0
    while *(s + n) != 0
        n += 1
    return n

fn make_sandbox_path(dst: *u8, suffix: *u8) -> i64
    let prefix: *u8 = c"/tmp/ritz_stat_"
    var i: i64 = 0
    while *(prefix + i) != 0
        *(dst + i) = *(prefix + i)
        i += 1
    var n: i32 = sys_getpid()
    var d_buf: [16]u8
    var d_len: i32 = 0
    if n == 0
        d_buf[0] = '0'
        d_len = 1
    else
        while n > 0
            d_buf[d_len] = ((n % 10) + 48) as u8
            n = n / 10
            d_len += 1
    var j: i32 = 0
    while j < d_len
        *(dst + i) = d_buf[d_len - 1 - j]
        i += 1
        j += 1
    *(dst + i) = '_' as u8
    i += 1
    var k: i64 = 0
    while *(suffix + k) != 0
        *(dst + i) = *(suffix + k)
        i += 1
        k += 1
    *(dst + i) = 0
    return i

fn write_file(path: *u8, content: *u8, len: i64) -> i32
    let fd: i32 = sys_open3(path, O_WRONLY + O_CREAT + O_TRUNC, 384)
    if fd < 0
        return -1
    if len > 0
        sys_write(fd, content, len)
    sys_close(fd)
    return 0

fn stat_exec(argv: **u8, out_buf: *u8, out_len: *i64) -> i32
    var stdout_pipe: [2]i32
    if sys_pipe(@stdout_pipe[0]) < 0
        return -1
    let pid: i32 = sys_fork()
    if pid < 0
        sys_close(stdout_pipe[0])
        sys_close(stdout_pipe[1])
        return -2
    if pid == 0
        sys_dup2(stdout_pipe[1], 1)
        sys_dup2(stdout_pipe[1], 2)
        sys_close(stdout_pipe[0])
        sys_close(stdout_pipe[1])
        sys_execve(c"./stat", argv, null)
        sys_exit(127)
    sys_close(stdout_pipe[1])
    var total: i64 = 0
    while total < 4096
        let r: i64 = sys_read(stdout_pipe[0], out_buf + total, 4096 - total)
        if r <= 0
            break
        total += r
    sys_close(stdout_pipe[0])
    *out_len = total
    var status: i32 = 0
    sys_wait4(pid, @status, 0, null)
    return (status >> 8) & 0xFF

[[test]]
fn test_stat_regular_file() -> i32
    var path: [128]u8
    let plen: i64 = make_sandbox_path(@path[0], c"f")
    sys_unlink(@path[0])
    if write_file(@path[0], c"xyz\n", 4) < 0
        assert 0 == 1, c"setup: file"

    var argv: [3]*u8
    argv[0] = c"./stat"
    argv[1] = @path[0]
    argv[2] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = stat_exec(@argv[0], @out[0], @n)
    sys_unlink(@path[0])

    assert exit_code == 0, c"stat <file> should exit 0"
    assert buf_contains(@out[0], n, c"File:", 5) == 1, c"missing 'File:' label"
    assert buf_contains(@out[0], n, @path[0], plen) == 1, c"missing path"
    assert buf_contains(@out[0], n, c"Size: 4", 7) == 1, c"missing 'Size: 4'"
    0

[[test]]
fn test_stat_directory() -> i32
    var path: [128]u8
    make_sandbox_path(@path[0], c"d")
    sys_rmdir(@path[0])
    if sys_mkdir(@path[0], 493) < 0
        assert 0 == 1, c"setup: dir"

    var argv: [3]*u8
    argv[0] = c"./stat"
    argv[1] = @path[0]
    argv[2] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = stat_exec(@argv[0], @out[0], @n)
    sys_rmdir(@path[0])

    assert exit_code == 0, c"stat <dir> should exit 0"
    assert buf_contains(@out[0], n, c"directory", 9) == 1, c"missing 'directory' label"
    0

[[test]]
fn test_stat_missing_errors() -> i32
    var path: [128]u8
    make_sandbox_path(@path[0], c"nope")
    sys_unlink(@path[0])

    var argv: [3]*u8
    argv[0] = c"./stat"
    argv[1] = @path[0]
    argv[2] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = stat_exec(@argv[0], @out[0], @n)

    assert exit_code != 0, c"stat of missing file should fail"
    0
