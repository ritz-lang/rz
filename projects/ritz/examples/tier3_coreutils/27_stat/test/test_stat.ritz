# Tests for 27_stat — file info.
import ritzlib.sys
import ritzlib.testlib

[[test]]
fn test_stat_regular_file() -> i32
    var path: [128]u8
    let plen: i64 = make_sandbox_path(@path[0], c"stat", c"f")
    sys_unlink(@path[0])
    if write_file(@path[0], c"xyz\n", 4) < 0
        assert 0 == 1, "setup: file"

    var argv: [3]*u8
    argv[0] = c"./stat"
    argv[1] = @path[0]
    argv[2] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./stat", @argv[0], null, null, 0, @out[0], 4096, @n)
    sys_unlink(@path[0])

    assert exit_code == 0, "stat <file> should exit 0"
    assert buf_contains(@out[0], n, c"File:", 5) == 1, "missing 'File:' label"
    assert buf_contains(@out[0], n, @path[0], plen) == 1, "missing path"
    assert buf_contains(@out[0], n, c"Size: 4", 7) == 1, "missing 'Size: 4'"
    0

[[test]]
fn test_stat_directory() -> i32
    var path: [128]u8
    make_sandbox_path(@path[0], c"stat", c"d")
    sys_rmdir(@path[0])
    if sys_mkdir(@path[0], 493) < 0
        assert 0 == 1, "setup: dir"

    var argv: [3]*u8
    argv[0] = c"./stat"
    argv[1] = @path[0]
    argv[2] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./stat", @argv[0], null, null, 0, @out[0], 4096, @n)
    sys_rmdir(@path[0])

    assert exit_code == 0, "stat <dir> should exit 0"
    assert buf_contains(@out[0], n, c"directory", 9) == 1, "missing 'directory' label"
    0

[[test]]
fn test_stat_missing_errors() -> i32
    var path: [128]u8
    make_sandbox_path(@path[0], c"stat", c"nope")
    sys_unlink(@path[0])

    var argv: [3]*u8
    argv[0] = c"./stat"
    argv[1] = @path[0]
    argv[2] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./stat", @argv[0], null, null, 0, @out[0], 4096, @n)

    assert exit_code == 1, "stat of missing file should exit 1"
    0
