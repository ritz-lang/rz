# Tests for 24_cp - copy files
#
# Integration tests fork+exec ./cp against a sandbox under /tmp/.

import ritzlib.sys
import ritzlib.io
import ritzlib.str

fn buf_eq(a: *u8, b: *u8, len: i64) -> i32
    var i: i64 = 0
    while i < len
        if *(a + i) != *(b + i)
            return 0
        i += 1
    return 1

fn make_sandbox_path(dst: *u8, suffix: *u8) -> i64
    let prefix: *u8 = c"/tmp/ritz_cp_"
    var i: i64 = 0
    while *(prefix + i) != 0
        *(dst + i) = *(prefix + i)
        i += 1
    var n: i32 = sys_getpid()
    var d_buf: [16]u8
    var d_len: i32 = 0
    if n == 0
        d_buf[0] = '0'
        d_len = 1
    else
        while n > 0
            d_buf[d_len] = ((n % 10) + 48) as u8
            n = n / 10
            d_len += 1
    var j: i32 = 0
    while j < d_len
        *(dst + i) = d_buf[d_len - 1 - j]
        i += 1
        j += 1
    *(dst + i) = '_' as u8
    i += 1
    var k: i64 = 0
    while *(suffix + k) != 0
        *(dst + i) = *(suffix + k)
        i += 1
        k += 1
    *(dst + i) = 0
    return i

fn write_file(path: *u8, content: *u8, len: i64) -> i32
    let fd: i32 = sys_open3(path, O_WRONLY + O_CREAT + O_TRUNC, 384)
    if fd < 0
        return -1
    if len > 0
        sys_write(fd, content, len)
    sys_close(fd)
    return 0

# Read up to max bytes of file at path into buf, returns byte count or -1.
fn read_file(path: *u8, buf: *u8, max: i64) -> i64
    let fd: i32 = sys_open(path, O_RDONLY)
    if fd < 0
        return -1
    var total: i64 = 0
    while total < max
        let r: i64 = sys_read(fd, buf + total, max - total)
        if r <= 0
            break
        total += r
    sys_close(fd)
    return total

fn cp_exec(argv: **u8, out_buf: *u8, out_len: *i64) -> i32
    var stdout_pipe: [2]i32
    if sys_pipe(@stdout_pipe[0]) < 0
        return -1
    let pid: i32 = sys_fork()
    if pid < 0
        sys_close(stdout_pipe[0])
        sys_close(stdout_pipe[1])
        return -2
    if pid == 0
        sys_dup2(stdout_pipe[1], 1)
        sys_dup2(stdout_pipe[1], 2)
        sys_close(stdout_pipe[0])
        sys_close(stdout_pipe[1])
        sys_execve(c"./cp", argv, null)
        sys_exit(127)
    sys_close(stdout_pipe[1])
    var total: i64 = 0
    while total < 1024
        let r: i64 = sys_read(stdout_pipe[0], out_buf + total, 1024 - total)
        if r <= 0
            break
        total += r
    sys_close(stdout_pipe[0])
    *out_len = total
    var status: i32 = 0
    sys_wait4(pid, @status, 0, null)
    return (status >> 8) & 0xFF

[[test]]
fn test_cp_empty_file() -> i32
    var src: [128]u8
    var dst: [128]u8
    make_sandbox_path(@src[0], c"empty1")
    make_sandbox_path(@dst[0], c"empty2")
    sys_unlink(@src[0])
    sys_unlink(@dst[0])
    if write_file(@src[0], c"", 0) < 0
        assert 0 == 1, c"setup: empty src"

    var argv: [4]*u8
    argv[0] = c"./cp"
    argv[1] = @src[0]
    argv[2] = @dst[0]
    argv[3] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = cp_exec(@argv[0], @out[0], @n)

    var st: Stat
    let stat_rc: i32 = sys_stat2(@dst[0], @st)
    let dst_size: i64 = st.st_size
    sys_unlink(@src[0])
    sys_unlink(@dst[0])

    assert exit_code == 0, c"cp empty should exit 0"
    assert stat_rc == 0, c"dst should exist after cp"
    assert dst_size == 0, c"dst should be empty"
    0

[[test]]
fn test_cp_copies_content() -> i32
    var src: [128]u8
    var dst: [128]u8
    make_sandbox_path(@src[0], c"src1")
    make_sandbox_path(@dst[0], c"dst1")
    sys_unlink(@src[0])
    sys_unlink(@dst[0])
    if write_file(@src[0], c"hello world\n", 12) < 0
        assert 0 == 1, c"setup: src"

    var argv: [4]*u8
    argv[0] = c"./cp"
    argv[1] = @src[0]
    argv[2] = @dst[0]
    argv[3] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = cp_exec(@argv[0], @out[0], @n)

    var rd_buf: [64]u8
    let rd: i64 = read_file(@dst[0], @rd_buf[0], 64)
    sys_unlink(@src[0])
    sys_unlink(@dst[0])

    assert exit_code == 0, c"cp content should exit 0"
    assert rd == 12, c"dst should have 12 bytes"
    assert buf_eq(@rd_buf[0], c"hello world\n", 12) == 1, c"content mismatch"
    0

[[test]]
fn test_cp_overwrites_dest() -> i32
    var src: [128]u8
    var dst: [128]u8
    make_sandbox_path(@src[0], c"src2")
    make_sandbox_path(@dst[0], c"dst2")
    sys_unlink(@src[0])
    sys_unlink(@dst[0])
    if write_file(@dst[0], c"old content\n", 12) < 0
        assert 0 == 1, c"setup: old dst"
    if write_file(@src[0], c"new content\n", 12) < 0
        assert 0 == 1, c"setup: new src"

    var argv: [4]*u8
    argv[0] = c"./cp"
    argv[1] = @src[0]
    argv[2] = @dst[0]
    argv[3] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = cp_exec(@argv[0], @out[0], @n)

    var rd_buf: [64]u8
    let rd: i64 = read_file(@dst[0], @rd_buf[0], 64)
    sys_unlink(@src[0])
    sys_unlink(@dst[0])

    assert exit_code == 0, c"cp overwrite should exit 0"
    assert rd == 12, c"dst should have 12 bytes"
    assert buf_eq(@rd_buf[0], c"new content\n", 12) == 1, c"new content not present"
    0
