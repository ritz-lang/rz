# Tests for 24_cp — copy files.
import ritzlib.sys
import ritzlib.testlib

[[test]]
fn test_cp_empty_file() -> i32
    var src: [128]u8
    var dst: [128]u8
    make_sandbox_path(@src[0], c"cp", c"empty1")
    make_sandbox_path(@dst[0], c"cp", c"empty2")
    sys_unlink(@src[0])
    sys_unlink(@dst[0])
    if write_file(@src[0], c"", 0) < 0
        assert 0 == 1, "setup: empty src"

    var argv: [4]*u8
    argv[0] = c"./cp"
    argv[1] = @src[0]
    argv[2] = @dst[0]
    argv[3] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./cp", @argv[0], null, null, 0, @out[0], 1024, @n)

    var st: Stat
    let stat_rc: i32 = sys_stat2(@dst[0], @st)
    let dst_size: i64 = st.st_size
    sys_unlink(@src[0])
    sys_unlink(@dst[0])

    assert exit_code == 0, "cp empty should exit 0"
    assert stat_rc == 0, "dst should exist after cp"
    assert dst_size == 0, "dst should be empty"
    0

[[test]]
fn test_cp_copies_content() -> i32
    var src: [128]u8
    var dst: [128]u8
    make_sandbox_path(@src[0], c"cp", c"src1")
    make_sandbox_path(@dst[0], c"cp", c"dst1")
    sys_unlink(@src[0])
    sys_unlink(@dst[0])
    if write_file(@src[0], c"hello world\n", 12) < 0
        assert 0 == 1, "setup: src"

    var argv: [4]*u8
    argv[0] = c"./cp"
    argv[1] = @src[0]
    argv[2] = @dst[0]
    argv[3] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./cp", @argv[0], null, null, 0, @out[0], 1024, @n)

    var rd_buf: [64]u8
    let rd: i64 = read_file(@dst[0], @rd_buf[0], 64)
    sys_unlink(@src[0])
    sys_unlink(@dst[0])

    assert exit_code == 0, "cp content should exit 0"
    assert rd == 12, "dst should have 12 bytes"
    assert buf_eq(@rd_buf[0], c"hello world\n", 12) == 1, "content mismatch"
    0

[[test]]
fn test_cp_overwrites_dest() -> i32
    var src: [128]u8
    var dst: [128]u8
    make_sandbox_path(@src[0], c"cp", c"src2")
    make_sandbox_path(@dst[0], c"cp", c"dst2")
    sys_unlink(@src[0])
    sys_unlink(@dst[0])
    if write_file(@dst[0], c"old content\n", 12) < 0
        assert 0 == 1, "setup: old dst"
    if write_file(@src[0], c"new content\n", 12) < 0
        assert 0 == 1, "setup: new src"

    var argv: [4]*u8
    argv[0] = c"./cp"
    argv[1] = @src[0]
    argv[2] = @dst[0]
    argv[3] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./cp", @argv[0], null, null, 0, @out[0], 1024, @n)

    var rd_buf: [64]u8
    let rd: i64 = read_file(@dst[0], @rd_buf[0], 64)
    sys_unlink(@src[0])
    sys_unlink(@dst[0])

    assert exit_code == 0, "cp overwrite should exit 0"
    assert rd == 12, "dst should have 12 bytes"
    assert buf_eq(@rd_buf[0], c"new content\n", 12) == 1, "new content not present"
    0
