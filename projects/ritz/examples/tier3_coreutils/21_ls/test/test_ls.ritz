# Tests for 21_ls — list directory contents.
#
# Helpers (exec_capture, buf_contains, make_sandbox_path) live in
# ritzlib.testlib; see docs/TESTING.md for the canonical template.

import ritzlib.sys
import ritzlib.testlib

[[test]]
fn test_ls_lists_current_dir() -> i32
    var argv: [3]*u8
    argv[0] = c"./ls"
    argv[1] = c"."
    argv[2] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./ls", @argv[0], null, null, 0, @out[0], 4096, @n)

    assert exit_code == 0, "ls . should exit 0"
    assert n > 0, "ls . should produce output"
    # cwd contains a 'src' directory (build.py runs from the example dir)
    assert buf_contains(@out[0], n, c"src", 3) == 1, "expected 'src' in output"
    0

[[test]]
fn test_ls_long_listing() -> i32
    var argv: [4]*u8
    argv[0] = c"./ls"
    argv[1] = c"-l"
    argv[2] = c"."
    argv[3] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./ls", @argv[0], null, null, 0, @out[0], 4096, @n)

    assert exit_code == 0, "ls -l . should exit 0"
    assert buf_contains(@out[0], n, c"drwx", 4) == 1, "expected 'drwx' in -l output"
    0

[[test]]
fn test_ls_one_per_line() -> i32
    var argv: [4]*u8
    argv[0] = c"./ls"
    argv[1] = c"-1"
    argv[2] = c"."
    argv[3] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./ls", @argv[0], null, null, 0, @out[0], 4096, @n)

    assert exit_code == 0, "ls -1 . should exit 0"
    var i: i64 = 0
    var nl: i64 = 0
    while i < n
        if *(@out[0] + i) == 10
            nl += 1
        i += 1
    assert nl >= 2, "expected >= 2 lines in -1 output"
    0

[[test]]
fn test_ls_multiple_paths() -> i32
    var argv: [4]*u8
    argv[0] = c"./ls"
    argv[1] = c"."
    argv[2] = c".."
    argv[3] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./ls", @argv[0], null, null, 0, @out[0], 4096, @n)

    assert exit_code == 0, "ls . .. should exit 0"
    assert buf_contains(@out[0], n, c"src", 3) == 1, "expected 'src' in output"
    0

[[test]]
fn test_ls_classify_marks_dirs() -> i32
    var path: [128]u8
    let plen: i64 = make_sandbox_path(@path[0], c"ls", c"F")

    # Best-effort cleanup of any prior leak.  If the dir has children we
    # won't be able to rmdir it; the mkdir below will fail loudly via the
    # setup assert.  (A future testlib helper for "wipe and recreate"
    # would handle this more gracefully.)
    sys_rmdir(@path[0])
    if sys_mkdir(@path[0], 493) < 0  # 0o755
        assert 0 == 1, "could not create sandbox"

    var subdir: [192]u8
    var k: i64 = 0
    while k < plen
        subdir[k] = path[k]
        k += 1
    subdir[k] = '/' as u8
    subdir[k + 1] = 's' as u8
    subdir[k + 2] = 'u' as u8
    subdir[k + 3] = 'b' as u8
    subdir[k + 4] = 0
    sys_mkdir(@subdir[0], 493)

    var argv: [4]*u8
    argv[0] = c"./ls"
    argv[1] = c"-F"
    argv[2] = @path[0]
    argv[3] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./ls", @argv[0], null, null, 0, @out[0], 4096, @n)

    sys_rmdir(@subdir[0])
    sys_rmdir(@path[0])

    assert exit_code == 0, "ls -F <sandbox> should exit 0"
    assert buf_contains(@out[0], n, c"sub/", 4) == 1, "expected 'sub/' in -F output"
    0
