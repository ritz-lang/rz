# Tests for 28_chmod — change file mode.
#
# Verifies the actual perm bits via sys_stat2 + 0o777 mask, not just the
# binary's exit code.
import ritzlib.sys
import ritzlib.testlib

# Read the file's permission bits (0o777 mask) via stat.
fn read_perms(path: *u8) -> i32
    var st: Stat
    if sys_stat2(path, @st) != 0
        return -1
    return st.st_mode & 0x1FF  # 0o777

[[test]]
fn test_chmod_755() -> i32
    var path: [128]u8
    make_sandbox_path(@path[0], c"chmod", c"f755")
    sys_unlink(@path[0])
    if write_file(@path[0], c"", 0) < 0
        assert 0 == 1, "setup: file"

    var argv: [4]*u8
    argv[0] = c"./chmod"
    argv[1] = c"755"
    argv[2] = @path[0]
    argv[3] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./chmod", @argv[0], null, null, 0, @out[0], 1024, @n)
    let perms: i32 = read_perms(@path[0])
    sys_unlink(@path[0])

    assert exit_code == 0, "chmod 755 should exit 0"
    assert perms == 0x1ED, "perms should be 0o755"  # 0o755 = 493 = 0x1ED
    0

[[test]]
fn test_chmod_600() -> i32
    var path: [128]u8
    make_sandbox_path(@path[0], c"chmod", c"f600")
    sys_unlink(@path[0])
    if write_file(@path[0], c"", 0) < 0
        assert 0 == 1, "setup: file"

    var argv: [4]*u8
    argv[0] = c"./chmod"
    argv[1] = c"600"
    argv[2] = @path[0]
    argv[3] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./chmod", @argv[0], null, null, 0, @out[0], 1024, @n)
    let perms: i32 = read_perms(@path[0])
    sys_unlink(@path[0])

    assert exit_code == 0, "chmod 600 should exit 0"
    assert perms == 0x180, "perms should be 0o600"  # 0o600 = 384 = 0x180
    0

[[test]]
fn test_chmod_644() -> i32
    var path: [128]u8
    make_sandbox_path(@path[0], c"chmod", c"f644")
    sys_unlink(@path[0])
    if write_file(@path[0], c"", 0) < 0
        assert 0 == 1, "setup: file"

    var argv: [4]*u8
    argv[0] = c"./chmod"
    argv[1] = c"644"
    argv[2] = @path[0]
    argv[3] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./chmod", @argv[0], null, null, 0, @out[0], 1024, @n)
    let perms: i32 = read_perms(@path[0])
    sys_unlink(@path[0])

    assert exit_code == 0, "chmod 644 should exit 0"
    assert perms == 0x1A4, "perms should be 0o644"  # 0o644 = 420 = 0x1A4
    0
