# Tests for 23_rm — remove files.
import ritzlib.sys
import ritzlib.testlib

[[test]]
fn test_rm_removes_existing_file() -> i32
    var path: [128]u8
    make_sandbox_path(@path[0], c"rm", c"a")
    sys_unlink(@path[0])
    if write_file(@path[0], c"", 0) < 0
        assert 0 == 1, "setup: could not create file"

    var argv: [3]*u8
    argv[0] = c"./rm"
    argv[1] = @path[0]
    argv[2] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./rm", @argv[0], null, null, 0, @out[0], 1024, @n)

    var st: Stat
    let stat_rc: i32 = sys_stat2(@path[0], @st)
    if stat_rc == 0
        sys_unlink(@path[0])

    assert exit_code == 0, "rm <existing> should exit 0"
    assert stat_rc != 0, "file should not exist after rm"
    0

[[test]]
fn test_rm_removes_multiple() -> i32
    var path1: [128]u8
    var path2: [128]u8
    var path3: [128]u8
    make_sandbox_path(@path1[0], c"rm", c"x")
    make_sandbox_path(@path2[0], c"rm", c"y")
    make_sandbox_path(@path3[0], c"rm", c"z")
    sys_unlink(@path1[0])
    sys_unlink(@path2[0])
    sys_unlink(@path3[0])
    if write_file(@path1[0], c"", 0) < 0
        assert 0 == 1, "setup: x"
    if write_file(@path2[0], c"", 0) < 0
        assert 0 == 1, "setup: y"
    if write_file(@path3[0], c"", 0) < 0
        assert 0 == 1, "setup: z"

    var argv: [5]*u8
    argv[0] = c"./rm"
    argv[1] = @path1[0]
    argv[2] = @path2[0]
    argv[3] = @path3[0]
    argv[4] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./rm", @argv[0], null, null, 0, @out[0], 1024, @n)

    var st: Stat
    let stat1: i32 = sys_stat2(@path1[0], @st)
    let stat2: i32 = sys_stat2(@path2[0], @st)
    let stat3: i32 = sys_stat2(@path3[0], @st)
    sys_unlink(@path1[0])
    sys_unlink(@path2[0])
    sys_unlink(@path3[0])

    assert exit_code == 0, "rm of 3 files should exit 0"
    assert stat1 != 0, "x should be gone"
    assert stat2 != 0, "y should be gone"
    assert stat3 != 0, "z should be gone"
    0

[[test]]
fn test_rm_nonexistent_errors() -> i32
    var path: [128]u8
    make_sandbox_path(@path[0], c"rm", c"never")
    sys_unlink(@path[0])

    var argv: [3]*u8
    argv[0] = c"./rm"
    argv[1] = @path[0]
    argv[2] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./rm", @argv[0], null, null, 0, @out[0], 1024, @n)

    assert exit_code != 0, "rm of nonexistent file should fail (no -f)"
    0
