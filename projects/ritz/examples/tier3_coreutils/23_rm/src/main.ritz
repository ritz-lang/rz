# rm - remove files or directories
#
# Usage: rm [OPTIONS] FILE...
#   Remove FILE(s).
#
# Options:
#   -r, -R    remove directories and their contents recursively
#   -f        ignore nonexistent files, never prompt
#   -d        remove empty directories
#   -v        verbose: print each file as it's removed

import ritzlib.sys
import ritzlib.io
import ritzlib.str
import ritzlib.strview
import ritzlib.string
import ritzlib.fs
import ritzlib.args

# ============================================================================
# Options
# ============================================================================

struct RmOptions
    recursive: i32   # -r/-R
    force: i32       # -f
    dir: i32         # -d (remove empty directories)
    verbose: i32     # -v

# ============================================================================
# Diagnostic helpers — see 24_cp for the rationale.
#
# Bare-string ("...") arguments are StrViews (length-tagged, no NUL,
# zero-copy).  *u8 is reserved for runtime path data from argv/syscalls.
# Each helper returns 1 (rm's error exit code) so call sites can `return
# rm_err2(...)` directly.
# ============================================================================

fn rm_err2(prefix: StrView, path: *u8, suffix: StrView) -> i32
    var s: String = string_from_strview(@prefix)
    string_push_str(@s, path)
    string_push_strview(@s, suffix)
    eprintln_string(@s)
    string_drop(@s)
    return 1

fn rm_print2(prefix: StrView, path: *u8, suffix: StrView)
    var s: String = string_from_strview(@prefix)
    string_push_str(@s, path)
    string_push_strview(@s, suffix)
    println_string(@s)
    string_drop(@s)

# ============================================================================
# Removal functions
# ============================================================================

fn remove_file(path: *u8, opts: *RmOptions) -> i32
    let result: i32 = sys_unlink(path)
    if result != 0
        if opts.force == 0
            rm_err2("rm: cannot remove '", path, "'")
        return result

    if opts.verbose != 0
        rm_print2("removed '", path, "'")

    return 0

fn remove_dir_recursive(path: *u8, opts: *RmOptions) -> i32
    let fd: i32 = sys_open(path, O_DIRECTORY)
    if fd < 0
        if opts.force == 0
            rm_err2("rm: cannot open directory '", path, "'")
        return 1

    var result: i32 = 0
    var buf: [8192]u8

    loop
        let nread: i64 = sys_getdents64(fd, @buf[0], 8192)
        if nread <= 0
            break

        var pos: i64 = 0
        while pos < nread
            let entry: *u8 = @buf[0] + pos
            let reclen: i32 = dirent_get_reclen(entry)
            let name: *u8 = dirent_get_name(entry)

            # Skip . and ..
            if streq(name, c".") == 0 and streq(name, c"..") == 0
                var child_path: [4096]u8
                path_join(path, name, @child_path[0])

                if is_directory(@child_path[0]) != 0
                    let r: i32 = remove_dir_recursive(@child_path[0], opts)
                    if r != 0
                        result = 1
                else
                    let r: i32 = remove_file(@child_path[0], opts)
                    if r != 0
                        result = 1

            pos += reclen as i64

    sys_close(fd)

    # Now remove the empty directory
    let r: i32 = sys_rmdir(path)
    if r != 0
        if opts.force == 0
            rm_err2("rm: cannot remove directory '", path, "'")
        return 1

    if opts.verbose != 0
        rm_print2("removed directory '", path, "'")

    return result

fn remove_path(path: *u8, opts: *RmOptions) -> i32
    # Check if path exists
    if path_exists(path) == 0
        if opts.force == 0
            return rm_err2("rm: cannot remove '", path, "': No such file or directory")
        return 0  # -f ignores nonexistent

    # Check if it's a directory
    if is_directory(path) != 0
        if opts.recursive != 0
            return remove_dir_recursive(path, opts)
        else if opts.dir != 0
            # Try to remove empty directory
            let r: i32 = sys_rmdir(path)
            if r != 0
                return rm_err2("rm: cannot remove '", path, "': Is a directory")
            if opts.verbose != 0
                rm_print2("removed directory '", path, "'")
            return 0
        else
            return rm_err2("rm: cannot remove '", path, "': Is a directory")

    return remove_file(path, opts)

# ============================================================================
# Main
# ============================================================================

fn main(argc: i32, argv: **u8) -> i32
    var parser: ArgParser
    args_init(@parser, c"rm", c"Remove files or directories")

    args_flag(@parser, 'r', c"recursive", c"Remove directories and their contents recursively")
    args_flag(@parser, 'R', null, c"Remove directories and their contents recursively")
    args_flag(@parser, 'f', c"force", c"Ignore nonexistent files, never prompt")
    args_flag(@parser, 'd', c"dir", c"Remove empty directories")
    args_flag(@parser, 'v', c"verbose", c"Print each file as it's removed")

    args_positional(@parser, c"FILE", c"Files or directories to remove", 1, -1)

    if args_parse(@parser, argc, argv) != 0
        return 1

    var opts: RmOptions
    opts.recursive = args_get_flag(@parser, 'r') | args_get_flag(@parser, 'R')
    opts.force = args_get_flag(@parser, 'f')
    opts.dir = args_get_flag(@parser, 'd')
    opts.verbose = args_get_flag(@parser, 'v')

    var result: i32 = 0
    for i in 0..parser.positional_count
        let path: *u8 = args_get_positional(@parser, i)
        let r: i32 = remove_path(path, @opts)
        if r != 0
            result = 1

    return result
