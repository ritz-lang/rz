# Tests for 29_du — disk usage.
import ritzlib.sys
import ritzlib.testlib

[[test]]
fn test_du_empty_dir() -> i32
    var path: [128]u8
    let plen: i64 = make_sandbox_path(@path[0], c"du", c"empty")
    sys_rmdir(@path[0])
    if sys_mkdir(@path[0], 493) < 0
        assert 0 == 1, "setup: empty dir"

    var argv: [3]*u8
    argv[0] = c"./du"
    argv[1] = @path[0]
    argv[2] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./du", @argv[0], null, null, 0, @out[0], 4096, @n)
    sys_rmdir(@path[0])

    assert exit_code == 0, "du <empty dir> should exit 0"
    assert n > 0, "du should produce output"
    assert buf_contains(@out[0], n, @path[0], plen) == 1, "output should mention path"
    0

[[test]]
fn test_du_nonempty_tree() -> i32
    var root: [128]u8
    let rlen: i64 = make_sandbox_path(@root[0], c"du", c"nest")
    sys_rmdir(@root[0])
    if sys_mkdir(@root[0], 493) < 0
        assert 0 == 1, "setup: root"

    # root/a/
    var a_dir: [192]u8
    var i: i64 = 0
    while i < rlen
        a_dir[i] = root[i]
        i += 1
    a_dir[i] = '/' as u8
    a_dir[i + 1] = 'a' as u8
    a_dir[i + 2] = 0
    sys_mkdir(@a_dir[0], 493)

    # root/a/file
    var a_file: [256]u8
    i = 0
    while *(@a_dir[0] + i) != 0
        a_file[i] = *(@a_dir[0] + i)
        i += 1
    a_file[i] = '/' as u8
    a_file[i + 1] = 'f' as u8
    a_file[i + 2] = 0
    write_file(@a_file[0], c"data\n", 5)

    var argv: [3]*u8
    argv[0] = c"./du"
    argv[1] = @root[0]
    argv[2] = null

    var out: [4096]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./du", @argv[0], null, null, 0, @out[0], 4096, @n)

    sys_unlink(@a_file[0])
    sys_rmdir(@a_dir[0])
    sys_rmdir(@root[0])

    assert exit_code == 0, "du <tree> should exit 0"
    assert buf_contains(@out[0], n, @root[0], rlen) == 1, "output should mention root"
    0
