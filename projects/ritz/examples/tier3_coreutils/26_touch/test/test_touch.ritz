# Tests for 26_touch — create/update file timestamps.
import ritzlib.sys
import ritzlib.testlib

[[test]]
fn test_touch_creates_new_file() -> i32
    var path: [128]u8
    make_sandbox_path(@path[0], c"touch", c"new")
    sys_unlink(@path[0])

    var argv: [3]*u8
    argv[0] = c"./touch"
    argv[1] = @path[0]
    argv[2] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./touch", @argv[0], null, null, 0, @out[0], 1024, @n)

    var st: Stat
    let stat_rc: i32 = sys_stat2(@path[0], @st)
    let size: i64 = st.st_size
    sys_unlink(@path[0])

    assert exit_code == 0, "touch new file should exit 0"
    assert stat_rc == 0, "file should exist"
    assert size == 0, "new file should be empty"
    0

[[test]]
fn test_touch_preserves_content() -> i32
    var path: [128]u8
    make_sandbox_path(@path[0], c"touch", c"existing")
    sys_unlink(@path[0])
    if write_file(@path[0], c"keep me\n", 8) < 0
        assert 0 == 1, "setup: write existing"

    var argv: [3]*u8
    argv[0] = c"./touch"
    argv[1] = @path[0]
    argv[2] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./touch", @argv[0], null, null, 0, @out[0], 1024, @n)

    var rd_buf: [32]u8
    let rd: i64 = read_file(@path[0], @rd_buf[0], 32)
    sys_unlink(@path[0])

    assert exit_code == 0, "touch existing should exit 0"
    assert rd == 8, "content length unchanged"
    assert buf_eq(@rd_buf[0], c"keep me\n", 8) == 1, "content preserved"
    0

[[test]]
fn test_touch_multiple_files() -> i32
    var p1: [128]u8
    var p2: [128]u8
    var p3: [128]u8
    make_sandbox_path(@p1[0], c"touch", c"m_a")
    make_sandbox_path(@p2[0], c"touch", c"m_b")
    make_sandbox_path(@p3[0], c"touch", c"m_c")
    sys_unlink(@p1[0])
    sys_unlink(@p2[0])
    sys_unlink(@p3[0])

    var argv: [5]*u8
    argv[0] = c"./touch"
    argv[1] = @p1[0]
    argv[2] = @p2[0]
    argv[3] = @p3[0]
    argv[4] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./touch", @argv[0], null, null, 0, @out[0], 1024, @n)

    var st: Stat
    let stat1: i32 = sys_stat2(@p1[0], @st)
    let stat2: i32 = sys_stat2(@p2[0], @st)
    let stat3: i32 = sys_stat2(@p3[0], @st)
    sys_unlink(@p1[0])
    sys_unlink(@p2[0])
    sys_unlink(@p3[0])

    assert exit_code == 0, "touch multi should exit 0"
    assert stat1 == 0, "a should exist"
    assert stat2 == 0, "b should exist"
    assert stat3 == 0, "c should exist"
    0
