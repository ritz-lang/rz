# Tests for 26_touch - create/update file timestamps
#
# Integration tests fork+exec ./touch against a sandbox under /tmp/.

import ritzlib.sys
import ritzlib.io
import ritzlib.str

fn buf_eq(a: *u8, b: *u8, len: i64) -> i32
    var i: i64 = 0
    while i < len
        if *(a + i) != *(b + i)
            return 0
        i += 1
    return 1

fn make_sandbox_path(dst: *u8, suffix: *u8) -> i64
    let prefix: *u8 = c"/tmp/ritz_touch_"
    var i: i64 = 0
    while *(prefix + i) != 0
        *(dst + i) = *(prefix + i)
        i += 1
    var n: i32 = sys_getpid()
    var d_buf: [16]u8
    var d_len: i32 = 0
    if n == 0
        d_buf[0] = '0'
        d_len = 1
    else
        while n > 0
            d_buf[d_len] = ((n % 10) + 48) as u8
            n = n / 10
            d_len += 1
    var j: i32 = 0
    while j < d_len
        *(dst + i) = d_buf[d_len - 1 - j]
        i += 1
        j += 1
    *(dst + i) = '_' as u8
    i += 1
    var k: i64 = 0
    while *(suffix + k) != 0
        *(dst + i) = *(suffix + k)
        i += 1
        k += 1
    *(dst + i) = 0
    return i

fn write_file(path: *u8, content: *u8, len: i64) -> i32
    let fd: i32 = sys_open3(path, O_WRONLY + O_CREAT + O_TRUNC, 384)
    if fd < 0
        return -1
    if len > 0
        sys_write(fd, content, len)
    sys_close(fd)
    return 0

fn read_file(path: *u8, buf: *u8, max: i64) -> i64
    let fd: i32 = sys_open(path, O_RDONLY)
    if fd < 0
        return -1
    var total: i64 = 0
    while total < max
        let r: i64 = sys_read(fd, buf + total, max - total)
        if r <= 0
            break
        total += r
    sys_close(fd)
    return total

fn touch_exec(argv: **u8, out_buf: *u8, out_len: *i64) -> i32
    var stdout_pipe: [2]i32
    if sys_pipe(@stdout_pipe[0]) < 0
        return -1
    let pid: i32 = sys_fork()
    if pid < 0
        sys_close(stdout_pipe[0])
        sys_close(stdout_pipe[1])
        return -2
    if pid == 0
        sys_dup2(stdout_pipe[1], 1)
        sys_dup2(stdout_pipe[1], 2)
        sys_close(stdout_pipe[0])
        sys_close(stdout_pipe[1])
        sys_execve(c"./touch", argv, null)
        sys_exit(127)
    sys_close(stdout_pipe[1])
    var total: i64 = 0
    while total < 1024
        let r: i64 = sys_read(stdout_pipe[0], out_buf + total, 1024 - total)
        if r <= 0
            break
        total += r
    sys_close(stdout_pipe[0])
    *out_len = total
    var status: i32 = 0
    sys_wait4(pid, @status, 0, null)
    return (status >> 8) & 0xFF

[[test]]
fn test_touch_creates_new_file() -> i32
    var path: [128]u8
    make_sandbox_path(@path[0], c"new")
    sys_unlink(@path[0])

    var argv: [3]*u8
    argv[0] = c"./touch"
    argv[1] = @path[0]
    argv[2] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = touch_exec(@argv[0], @out[0], @n)

    var st: Stat
    let stat_rc: i32 = sys_stat2(@path[0], @st)
    let size: i64 = st.st_size
    sys_unlink(@path[0])

    assert exit_code == 0, c"touch new file should exit 0"
    assert stat_rc == 0, c"file should exist"
    assert size == 0, c"new file should be empty"
    0

[[test]]
fn test_touch_preserves_content() -> i32
    var path: [128]u8
    make_sandbox_path(@path[0], c"existing")
    sys_unlink(@path[0])
    if write_file(@path[0], c"keep me\n", 8) < 0
        assert 0 == 1, c"setup: write existing"

    var argv: [3]*u8
    argv[0] = c"./touch"
    argv[1] = @path[0]
    argv[2] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = touch_exec(@argv[0], @out[0], @n)

    var rd_buf: [32]u8
    let rd: i64 = read_file(@path[0], @rd_buf[0], 32)
    sys_unlink(@path[0])

    assert exit_code == 0, c"touch existing should exit 0"
    assert rd == 8, c"content length unchanged"
    assert buf_eq(@rd_buf[0], c"keep me\n", 8) == 1, c"content preserved"
    0

[[test]]
fn test_touch_multiple_files() -> i32
    var p1: [128]u8
    var p2: [128]u8
    var p3: [128]u8
    make_sandbox_path(@p1[0], c"m_a")
    make_sandbox_path(@p2[0], c"m_b")
    make_sandbox_path(@p3[0], c"m_c")
    sys_unlink(@p1[0])
    sys_unlink(@p2[0])
    sys_unlink(@p3[0])

    var argv: [5]*u8
    argv[0] = c"./touch"
    argv[1] = @p1[0]
    argv[2] = @p2[0]
    argv[3] = @p3[0]
    argv[4] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = touch_exec(@argv[0], @out[0], @n)

    var st: Stat
    let stat1: i32 = sys_stat2(@p1[0], @st)
    let stat2: i32 = sys_stat2(@p2[0], @st)
    let stat3: i32 = sys_stat2(@p3[0], @st)
    sys_unlink(@p1[0])
    sys_unlink(@p2[0])
    sys_unlink(@p3[0])

    assert exit_code == 0, c"touch multi should exit 0"
    assert stat1 == 0, c"a should exist"
    assert stat2 == 0, c"b should exist"
    assert stat3 == 0, c"c should exist"
    0
