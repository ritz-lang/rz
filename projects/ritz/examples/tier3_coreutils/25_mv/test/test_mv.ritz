# Tests for 25_mv — rename/move files.
import ritzlib.sys
import ritzlib.testlib

[[test]]
fn test_mv_renames_within_dir() -> i32
    var a: [128]u8
    var b: [128]u8
    make_sandbox_path(@a[0], c"mv", c"a")
    make_sandbox_path(@b[0], c"mv", c"b")
    sys_unlink(@a[0])
    sys_unlink(@b[0])
    if write_file(@a[0], c"payload\n", 8) < 0
        assert 0 == 1, "setup: a"

    var argv: [4]*u8
    argv[0] = c"./mv"
    argv[1] = @a[0]
    argv[2] = @b[0]
    argv[3] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./mv", @argv[0], null, null, 0, @out[0], 1024, @n)

    var st: Stat
    let stat_a: i32 = sys_stat2(@a[0], @st)
    var rd_buf: [32]u8
    let rd: i64 = read_file(@b[0], @rd_buf[0], 32)
    sys_unlink(@a[0])
    sys_unlink(@b[0])

    assert exit_code == 0, "mv a b should exit 0"
    assert stat_a != 0, "a should be gone"
    assert rd == 8, "b should have 8 bytes"
    assert buf_eq(@rd_buf[0], c"payload\n", 8) == 1, "payload mismatch"
    0

[[test]]
fn test_mv_between_subdirs() -> i32
    var d1: [128]u8
    var d2: [128]u8
    let d1len: i64 = make_sandbox_path(@d1[0], c"mv", c"d1")
    let d2len: i64 = make_sandbox_path(@d2[0], c"mv", c"d2")
    sys_rmdir(@d1[0])
    sys_rmdir(@d2[0])
    if sys_mkdir(@d1[0], 493) < 0
        assert 0 == 1, "setup: d1"
    if sys_mkdir(@d2[0], 493) < 0
        sys_rmdir(@d1[0])
        assert 0 == 1, "setup: d2"

    var src: [192]u8
    var dst: [192]u8
    var i: i64 = 0
    while i < d1len
        src[i] = d1[i]
        i += 1
    src[i] = '/' as u8
    src[i + 1] = 'f' as u8
    src[i + 2] = 0
    i = 0
    while i < d2len
        dst[i] = d2[i]
        i += 1
    dst[i] = '/' as u8
    dst[i + 1] = 'f' as u8
    dst[i + 2] = 0

    if write_file(@src[0], c"x", 1) < 0
        sys_rmdir(@d1[0])
        sys_rmdir(@d2[0])
        assert 0 == 1, "setup: src file"

    var argv: [4]*u8
    argv[0] = c"./mv"
    argv[1] = @src[0]
    argv[2] = @dst[0]
    argv[3] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./mv", @argv[0], null, null, 0, @out[0], 1024, @n)

    var st: Stat
    let stat_src: i32 = sys_stat2(@src[0], @st)
    let stat_dst: i32 = sys_stat2(@dst[0], @st)
    sys_unlink(@src[0])
    sys_unlink(@dst[0])
    sys_rmdir(@d1[0])
    sys_rmdir(@d2[0])

    assert exit_code == 0, "mv across dirs should exit 0"
    assert stat_src != 0, "src should be gone"
    assert stat_dst == 0, "dst should exist"
    0

[[test]]
fn test_mv_missing_source_errors() -> i32
    var src: [128]u8
    var dst: [128]u8
    make_sandbox_path(@src[0], c"mv", c"never")
    make_sandbox_path(@dst[0], c"mv", c"target")
    sys_unlink(@src[0])
    sys_unlink(@dst[0])

    var argv: [4]*u8
    argv[0] = c"./mv"
    argv[1] = @src[0]
    argv[2] = @dst[0]
    argv[3] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./mv", @argv[0], null, null, 0, @out[0], 1024, @n)
    sys_unlink(@dst[0])

    assert exit_code != 0, "mv of missing source should fail"
    0
