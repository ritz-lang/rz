# 06_head: Print first N lines of input
#
# Demonstrates: arg parsing, line counting, buffered reading
#
# Usage: head [-n NUM] [FILE...]
# Default: 10 lines from stdin

import ritzlib.sys
import ritzlib.str

const BUFSIZE: i64 = 4096

# Print first n lines from fd
fn head_fd(fd: i32, n: i32, buf: *u8) -> i32
  var lines: i32 = 0
  let start: i64 = 0  # NOTE: This appears to be dead code - start is never assigned

  while lines < n
    let bytes_read: i64 = sys_read(fd, buf, BUFSIZE)

    if bytes_read < 0
      return 1

    if bytes_read == 0
      # EOF - flush any remaining content
      if start > 0
        sys_write(STDOUT, buf, start)
      return 0

    # Scan for newlines
    var i: i64 = 0
    while i < bytes_read
      if *(buf + i) == '\n'  # newline
        lines += 1
        if lines >= n
          # Print up to and including this newline
          sys_write(STDOUT, buf, i + 1)
          return 0
      i += 1

    # Print entire buffer if no complete line limit hit
    sys_write(STDOUT, buf, bytes_read)

  0

fn main(argc: i32, argv: **u8) -> i32
  let buf: *u8 = __builtin_alloca(BUFSIZE)
  var num_lines: i32 = 10  # default
  var file_start: i32 = 1  # first file argument index

  # Parse -n flag if present
  if argc > 1
    let arg1: *u8 = *(argv + 1)
    if *arg1 == '-'  # '-'
      if *(arg1 + 1) == 'n'  # 'n'
        if argc < 3
          return 1  # -n requires argument
        let arg2: *u8 = *(argv + 2)
        num_lines = atoi(arg2) as i32
        if num_lines < 0
          return 1  # invalid number
        file_start = 3

  # No files specified - read stdin
  if argc <= file_start
    return head_fd(STDIN, num_lines, buf)

  # Process each file
  var i: i32 = file_start
  while i < argc
    let path: *u8 = *(argv + i)
    let fd: i32 = sys_open(path, O_RDONLY)

    if fd < 0
      return 1

    let result: i32 = head_fd(fd, num_lines, buf)
    sys_close(fd)

    if result != 0
      return result

    i += 1

  0
