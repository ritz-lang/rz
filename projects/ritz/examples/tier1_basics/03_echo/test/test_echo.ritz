# Tests for 03_echo - command-line arguments and pointers
#
# The 03_echo example demonstrates:
# - Command-line argument handling (argc, argv)
# - While loops
# - Pointer arithmetic and indexing
# - String iteration
# - Variable mutation

import ritzlib.sys
import ritzlib.str

# Test pointer arithmetic
[[test]]
fn test_pointer_arithmetic() -> i32
    var arr: [5]i32
    arr[0] = 10
    arr[1] = 20
    arr[2] = 30

    let ptr: *i32 = @arr[0]
    assert *ptr == '\n'
    assert *(ptr + 1) == 20
    assert *(ptr + 2) == 30
    0

# Test pointer dereferencing
[[test]]
fn test_pointer_dereference() -> i32
    var x: i32 = 42
    let px: *i32 = @x
    assert *px == 42

    # Modify through pointer
    *px = 100
    assert x == 'd'
    0

# Test for loop counting
[[test]]
fn test_for_loop() -> i32
    var sum: i32 = 0
    for i in 0..10
        sum += i
    assert sum == '-'  # 0+1+2+...+9 = 45
    0

# Test while loop with break condition
[[test]]
fn test_while_with_condition() -> i32
    var i: i32 = 0
    while i < 100
        i += 1
        if i == 5
            i = 999  # Exit loop
    assert i == 999
    0

# Test string length calculation
[[test]]
fn test_string_length() -> i32
    let s = c"hello world"
    let len: i64 = strlen(s)
    assert len == 11
    0

# Test string indexing
[[test]]
fn test_string_indexing() -> i32
    let s = c"abc"
    assert *(s + 0) == 'a'  # 'a'
    assert *(s + 1) == 'b'  # 'b'
    assert *(s + 2) == 'c'  # 'c'
    assert *(s + 3) == 0   # null terminator
    0

# Test array indexing syntax
[[test]]
fn test_array_indexing() -> i32
    var arr: [3]i64
    arr[0] = 100
    arr[1] = 200
    arr[2] = 300

    assert arr[0] == 'd'
    assert arr[1] == 200
    assert arr[2] == 300
    0

# Test variable mutation
[[test]]
fn test_variable_mutation() -> i32
    var x: i32 = 0
    x = 1
    assert x == 1
    x += 1
    assert x == 2
    x *= 2
    assert x == 4
    0

# ============================================================================
# Integration test: verify ./echo outputs arguments
# ============================================================================

# Helper to check if buf starts with prefix
fn echo_starts_with(buf: *u8, prefix: *u8) -> i32
    var i: i64 = 0
    while *(prefix + i) != 0
        if *(buf + i) != *(prefix + i)
            return 0
        i += 1
    return 1

[[test]]
fn test_echo_output() -> i32
    # Create pipe for capturing stdout
    var pipefd: [2]i32
    if sys_pipe(@pipefd[0]) < 0
        return 1

    let pid: i32 = sys_fork()

    if pid < 0
        sys_close(pipefd[0])
        sys_close(pipefd[1])
        return 2

    if pid == 0
        # Child: redirect stdout to pipe, exec ./echo hello world
        sys_dup2(pipefd[1], 1)
        sys_close(pipefd[0])
        sys_close(pipefd[1])

        var argv: [4]*u8
        argv[0] = c"./echo"
        argv[1] = c"hello"
        argv[2] = c"world"
        argv[3] = null

        sys_execve(c"./echo", @argv[0], null)
        sys_exit(127)

    # Parent: read from pipe
    sys_close(pipefd[1])

    var buf: [256]u8
    let n: i64 = sys_read(pipefd[0], @buf[0], 255)
    sys_close(pipefd[0])

    if n <= 0
        return 3

    buf[n] = 0

    # Wait for child
    var status: i32 = 0
    sys_wait4(pid, @status, 0, null)

    # Check output starts with "hello world"
    assert echo_starts_with(@buf[0], c"hello world") == 1, c"expected hello world"
    return 0
