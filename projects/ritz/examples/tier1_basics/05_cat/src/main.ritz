# 05_cat: Concatenate and print files
#
# Demonstrates:
# - Const declarations
# - Multiple syscalls (open, read, write, close)
# - File descriptor handling
# - Error checking on syscall returns
# - Buffer-based I/O with stack allocation
# - Multiple function definitions
#
# Usage:
#   ./cat              # Read from stdin
#   ./cat file.txt     # Print file contents
#   ./cat a.txt b.txt  # Concatenate multiple files

import ritzlib.sys

const BUF_SIZE: i64 = 4096

# Cat a single file descriptor to stdout
# Returns 0 on success, 1 on error
fn cat_fd(fd: i32, buf: *u8) -> i32
  var n: i64 = 1

  while n > 0
    n = sys_read(fd, buf, BUF_SIZE)
    if n < 0
      return 1
    if n > 0
      let written = sys_write(STDOUT, buf, n)
      if written < 0
        return 1

  0

fn main(argc: i32, argv: **u8) -> i32
  # Allocate buffer on stack
  var buf: *u8 = __builtin_alloca(BUF_SIZE)

  # No args: read from stdin
  if argc == 1
    return cat_fd(STDIN, buf)

  # Process each file argument
  var i: i32 = 1
  while i < argc
    let path = argv[i]
    var fd: i32 = sys_open(path, O_RDONLY)

    if fd < 0
      return 1

    let result = cat_fd(fd, buf)
    sys_close(fd)

    if result != 0
      return result

    i += 1

  0
