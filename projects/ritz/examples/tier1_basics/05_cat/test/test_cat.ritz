# Tests for 05_cat - file I/O and syscalls
#
# The 05_cat example demonstrates:
# - Const declarations
# - Multiple syscalls (open, read, write, close)
# - File descriptor handling
# - Error checking on syscall returns
# - Buffer-based I/O with stack allocation
# - Multiple function definitions

import ritzlib.sys
import ritzlib.str
import ritzlib.memory

# Test let/var declaration
[[test]]
fn test_let_value() -> i32
    let value: i32 = 42
    assert value == 42
    0

# Test variable expression
[[test]]
fn test_var_expression() -> i32
    var size: i64 = 1024
    let double_size: i64 = size * 2
    assert double_size == 2048
    0

# Test buffer allocation with malloc
[[test]]
fn test_buffer_alloc() -> i32
    let buf: *u8 = malloc(256)
    assert buf != null

    # Can write to buffer
    *buf = 65  # 'A'
    *(buf + 1) = 66  # 'B'
    *(buf + 2) = 0

    assert *buf == 'A'
    assert *(buf + 1) == 66

    free(buf)
    0

# Test memset
[[test]]
fn test_memset() -> i32
    var buf: [16]u8
    memset(&buf[0], 42, 16)

    for i in 0..16
        assert buf[i] == 42
    0

# Test memcpy
[[test]]
fn test_memcpy() -> i32
    let src = "hello"
    var dst: [16]u8

    memcpy(&dst[0], src, 6)  # Include null terminator

    assert dst[0] == 104  # 'h'
    assert dst[1] == 'e'  # 'e'
    assert dst[2] == 108  # 'l'
    assert dst[3] == 108  # 'l'
    assert dst[4] == 111  # 'o'
    assert dst[5] == 0
    0

# Test string comparison
[[test]]
fn test_streq() -> i32
    assert streq("hello", "hello") == 1
    assert streq("hello", "world") == 0
    assert streq("abc", "abcd") == 0
    assert streq("", "") == 1
    0

# Test strlen
[[test]]
fn test_strlen() -> i32
    assert strlen("") == 0
    assert strlen("a") == 1
    assert strlen("hello") == 5
    assert strlen("hello world") == 11
    0

# Test syscall write to /dev/null
[[test]]
fn test_write_devnull() -> i32
    let fd: i32 = sys_open("/dev/null", O_WRONLY)
    if fd < 0
        return 1

    let msg = "test message"
    let written: i64 = sys_write(fd, msg, 12)
    sys_close(fd)

    assert written == 12
    0

# Test syscall read from /dev/zero
[[test]]
fn test_read_devzero() -> i32
    let fd: i32 = sys_open("/dev/zero", O_RDONLY)
    if fd < 0
        return 1

    var buf: [16]u8
    let n: i64 = sys_read(fd, &buf[0], 16)
    sys_close(fd)

    assert n == 16
    # /dev/zero returns all zeros
    for i in 0..16
        assert buf[i] == 0
    0

# Test file open/close cycle
[[test]]
fn test_open_close() -> i32
    let fd: i32 = sys_open("/dev/null", O_RDONLY)
    assert fd >= 0

    let result: i32 = sys_close(fd)
    assert result == 0
    0

# Test invalid file returns error
[[test]]
fn test_open_invalid() -> i32
    let fd: i32 = sys_open("/nonexistent/path/file", O_RDONLY)
    assert fd < 0
    0

# ============================================================================
# Integration test: verify ./cat reads and outputs file content
# ============================================================================

# Helper to check if buf starts with prefix
fn cat_starts_with(buf: *u8, prefix: *u8) -> i32
    var i: i64 = 0
    while *(prefix + i) != 0
        if *(buf + i) != *(prefix + i)
            return 0
        i += 1
    return 1

[[test]]
fn test_cat_file() -> i32
    # Create a test file
    let path: *u8 = c"/tmp/ritz_test_cat_integration.txt"
    let test_content: *u8 = c"test content for cat"

    let fd_w: i32 = sys_open3(path, O_WRONLY + O_CREAT + O_TRUNC, 420)
    if fd_w < 0
        return 1
    sys_write(fd_w, test_content, 20)
    sys_close(fd_w)

    # Create pipe for capturing output
    var pipefd: [2]i32
    if sys_pipe(&pipefd[0]) < 0
        return 2

    let pid: i32 = sys_fork()
    if pid < 0
        sys_close(pipefd[0])
        sys_close(pipefd[1])
        return 3

    if pid == 0
        # Child: redirect stdout, exec ./cat
        sys_dup2(pipefd[1], 1)
        sys_close(pipefd[0])
        sys_close(pipefd[1])

        var argv: [3]*u8
        argv[0] = c"./cat"
        argv[1] = path
        argv[2] = null

        sys_execve(c"./cat", &argv[0], null)
        sys_exit(127)

    # Parent: read output
    sys_close(pipefd[1])

    var buf: [256]u8
    let n: i64 = sys_read(pipefd[0], &buf[0], 255)
    sys_close(pipefd[0])

    var status: i32 = 0
    sys_wait4(pid, &status, 0, null)

    # Cleanup
    sys_unlink(path)

    if n <= 0
        return 4

    buf[n] = 0
    assert cat_starts_with(&buf[0], c"test content") == 1, "expected test content"
    return 0
