# Tests for 02_exitcode - return values and exit codes
#
# The 02_exitcode example demonstrates:
# - Return type annotation on functions
# - Integer literals
# - Return statement vs trailing expression
# - Variable assignment and retrieval

import ritzlib.sys

# Test explicit return statement
[[test]]
fn test_explicit_return() -> i32
    let x: i32 = explicit_return()
    assert x == 42
    0

fn explicit_return() -> i32
    return 42

# Test trailing expression return
[[test]]
fn test_trailing_expression_return() -> i32
    let x: i32 = trailing_return()
    assert x == 'c'
    0

fn trailing_return() -> i32
    99

# Test that return short-circuits
[[test]]
fn test_early_return() -> i32
    let x: i32 = early_return()
    assert x == 1
    0

fn early_return() -> i32
    if 1 == 1
        return 1
    return 2

# Test return with local variable
[[test]]
fn test_return_variable() -> i32
    let x: i32 = return_variable()
    assert x == '{'
    0

fn return_variable() -> i32
    let value: i32 = 123
    return value

# Test negative return value
[[test]]
fn test_negative_return() -> i32
    let x: i32 = negative_return()
    assert x == -5
    0

fn negative_return() -> i32
    return 0 - 5

# Test zero return
[[test]]
fn test_zero_return() -> i32
    let x: i32 = zero_return()
    assert x == 0
    0

fn zero_return() -> i32
    0

# Test return from nested block
[[test]]
fn test_nested_return() -> i32
    let x: i32 = nested_return(10)
    assert x == 20
    0

fn nested_return(n: i32) -> i32
    if n > 5
        if n > 8
            return n * 2
        return n + 5
    return n

# ============================================================================
# Integration test: verify ./exitcode returns code 42
# ============================================================================

[[test]]
fn test_exitcode_output() -> i32
    let pid: i32 = sys_fork()

    if pid < 0
        return 1  # fork failed

    if pid == 0
        # Child: exec ./exitcode
        var argv: [2]*u8
        argv[0] = c"./exitcode"
        argv[1] = null
        sys_execve(c"./exitcode", @argv[0], null)
        sys_exit(127)  # exec failed

    # Parent: wait for child
    var status: i32 = 0
    sys_wait4(pid, @status, 0, null)

    # Extract exit code: (status >> 8) & 0xff
    let code: i32 = (status / 256) % 256
    assert code == 42, c"expected exit code 42"
    return 0
