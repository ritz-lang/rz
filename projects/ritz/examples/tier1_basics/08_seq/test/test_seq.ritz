# Tests for 08_seq - number sequences
#
# The 08_seq example demonstrates:
# - Range iteration
# - Number formatting (itoa)
# - Argument parsing for ranges
# - Negative and positive increments

import ritzlib.sys
import ritzlib.str
import ritzlib.io

# Test itoa basic
[[test]]
fn test_itoa_basic() -> i32
    var buf: [32]u8
    itoa(0, @buf[0])
    assert streq(@buf[0], c"0") == 1

    itoa(42, @buf[0])
    assert streq(@buf[0], c"42") == 1

    itoa(123, @buf[0])
    assert streq(@buf[0], c"123") == 1
    0

# Test itoa negative
[[test]]
fn test_itoa_negative() -> i32
    var buf: [32]u8
    itoa(-1, @buf[0])
    assert streq(@buf[0], c"-1") == 1

    itoa(-42, @buf[0])
    assert streq(@buf[0], c"-42") == 1

    itoa(-999, @buf[0])
    assert streq(@buf[0], c"-999") == 1
    0

# Test itoa large numbers
[[test]]
fn test_itoa_large() -> i32
    var buf: [32]u8
    itoa(1000000, @buf[0])
    assert streq(@buf[0], c"1000000") == 1

    itoa(2147483647, @buf[0])  # max i32
    assert streq(@buf[0], c"2147483647") == 1
    0

# Test sequence generation (ascending)
[[test]]
fn test_seq_ascending() -> i32
    var sum: i64 = 0
    var n: i64 = 1
    while n <= 5
        sum += n
        n += 1
    assert sum == 15  # 1+2+3+4+5
    0

# Test sequence generation (descending)
[[test]]
fn test_seq_descending() -> i32
    var sum: i64 = 0
    var n: i64 = 5
    while n >= 1
        sum += n
        n -= 1
    assert sum == 15
    0

# Test sequence with custom increment
[[test]]
fn test_seq_increment() -> i32
    # Count 2, 4, 6, 8, 10
    var count: i32 = 0
    var n: i64 = 2
    while n <= 10
        count += 1
        n += 2
    assert count == 5
    0

# Test sequence with negative increment
[[test]]
fn test_seq_negative_increment() -> i32
    # Count 10, 8, 6, 4, 2
    var count: i32 = 0
    var n: i64 = 10
    while n >= 2
        count += 1
        n -= 2
    assert count == 5
    0

# Test empty sequence (start > end with positive increment)
[[test]]
fn test_seq_empty() -> i32
    var count: i32 = 0
    var n: i64 = 10
    while n <= 5
        count += 1
        n += 1
    assert count == 0
    0

# Test single element sequence
[[test]]
fn test_seq_single() -> i32
    var count: i32 = 0
    var n: i64 = 5
    while n <= 5
        count += 1
        n += 1
    assert count == 1
    0

# Test atoi roundtrip with itoa
[[test]]
fn test_roundtrip() -> i32
    var buf: [32]u8

    itoa(12345, @buf[0])
    let parsed: i64 = atoi(@buf[0])
    assert parsed == 12345

    itoa(-9999, @buf[0])
    let parsed2: i64 = atoi(@buf[0])
    assert parsed2 == -9999
    0

# ============================================================================
# Integration test: verify ./seq outputs correct sequence
# ============================================================================

fn seq_starts_with(buf: *u8, prefix: *u8) -> i32
    var i: i64 = 0
    while *(prefix + i) != 0
        if *(buf + i) != *(prefix + i)
            return 0
        i += 1
    return 1

[[test]]
fn test_seq_output() -> i32
    var pipefd: [2]i32
    if sys_pipe(@pipefd[0]) < 0
        return 1

    let pid: i32 = sys_fork()
    if pid < 0
        sys_close(pipefd[0])
        sys_close(pipefd[1])
        return 2

    if pid == 0
        sys_dup2(pipefd[1], 1)
        sys_close(pipefd[0])
        sys_close(pipefd[1])

        var argv: [3]*u8
        argv[0] = c"./seq"
        argv[1] = c"5"
        argv[2] = null

        sys_execve(c"./seq", @argv[0], null)
        sys_exit(127)

    sys_close(pipefd[1])

    var buf: [256]u8
    let n: i64 = sys_read(pipefd[0], @buf[0], 255)
    sys_close(pipefd[0])

    var status: i32 = 0
    sys_wait4(pid, @status, 0, null)

    if n <= 0
        return 3

    buf[n] = 0
    # seq 5 should output "1\n2\n3\n4\n5\n"
    assert seq_starts_with(@buf[0], c"1\n2\n3\n4\n5") == 1, c"expected 1 through 5"
    return 0
