# Tests for 04_true_false - boolean logic and conditionals
#
# The 04_true_false example demonstrates:
# - Boolean values (0 and 1)
# - Comparison operators
# - If expressions
# - Logical operators ( and, ||, !)

import ritzlib.sys

# Test boolean true (1)
[[test]]
fn test_true_value() -> i32
    let t: i32 = 1
    assert t == 1
    assert t != 0
    0

# Test boolean false (0)
[[test]]
fn test_false_value() -> i32
    let f: i32 = 0
    assert f == 0
    assert f != 1
    0

# Test comparison operators
[[test]]
fn test_comparisons() -> i32
    assert 5 > 3
    assert 3 < 5
    assert 5 >= 5
    assert 5 <= 5
    assert 5 >= 4
    assert 5 <= 6
    assert 5 == 5
    assert 5 != 4
    0

# Test if-else
[[test]]
fn test_if_else() -> i32
    var result: i32 = 0
    if 1 == 1
        result = 10
    else
        result = 20
    assert result == '\n'

    if 1 == 2
        result = 30
    else
        result = 40
    assert result == 40
    0

# Test nested if
[[test]]
fn test_nested_if() -> i32
    let x: i32 = classify(15)
    assert x == 2

    let y: i32 = classify(5)
    assert y == 1

    let z: i32 = classify(0)
    assert z == 0
    0

fn classify(n: i32) -> i32
    if n > 10
        return 2
    else if n > 0
        return 1
    else
        return 0

# Test logical AND
[[test]]
fn test_logical_and() -> i32
    assert (1 == 1) and (2 == 2)
    let f: i32 = (1 == 1) and (2 == 3)
    assert f == 0
    0

# Test logical OR
[[test]]
fn test_logical_or() -> i32
    assert (1 == 1) or (2 == 3)
    assert (1 == 2) or (2 == 2)
    let f: i32 = (1 == 2) or (2 == 3)
    assert f == 0
    0

# Test logical NOT
[[test]]
fn test_logical_not() -> i32
    assert !(1 == 2)
    let f: i32 = !(1 == 1)
    assert f == 0
    0

# Test complex boolean expressions
[[test]]
fn test_complex_boolean() -> i32
    let a: i32 = 5
    let b: i32 = 10
    let c: i32 = 15

    # a < b < c
    assert (a < b) and (b < c)

    # a > b OR b > c
    let f: i32 = (a > b) or (b > c)
    assert f == 0

    # NOT (a > b) is true
    assert !(a > b)
    0

# Test conditional expression in if
[[test]]
fn test_conditional_if() -> i32
    var result: i32 = 0

    # Test AND in condition - both true
    if (1 == 1) and (2 == 2)
        result = 1
    assert result == 1

    # Test AND in condition - first false
    result = 0
    if (1 == 2) and (2 == 2)
        result = 1
    assert result == 0

    # Test OR in condition - first true
    result = 0
    if (1 == 1) or (2 == 3)
        result = 1
    assert result == 1

    # Test OR in condition - both false
    result = 0
    if (1 == 2) or (2 == 3)
        result = 1
    assert result == 0
    0

# ============================================================================
# Integration tests: verify ./true exits 0, ./false exits 1
# ============================================================================

[[test]]
fn test_true_exit_code() -> i32
    let pid: i32 = sys_fork()

    if pid < 0
        return 1

    if pid == 0
        var argv: [2]*u8
        argv[0] = c"./true"
        argv[1] = null
        sys_execve(c"./true", @argv[0], null)
        sys_exit(127)

    var status: i32 = 0
    sys_wait4(pid, @status, 0, null)

    let code: i32 = (status / 256) % 256
    assert code == 0, c"true should exit 0"
    return 0

[[test]]
fn test_false_exit_code() -> i32
    let pid: i32 = sys_fork()

    if pid < 0
        return 1

    if pid == 0
        var argv: [2]*u8
        argv[0] = c"./false"
        argv[1] = null
        sys_execve(c"./false", @argv[0], null)
        sys_exit(127)

    var status: i32 = 0
    sys_wait4(pid, @status, 0, null)

    let code: i32 = (status / 256) % 256
    assert code == 1, c"false should exit 1"
    return 0
