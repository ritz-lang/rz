# 09_yes: Repeatedly output a string
#
# Demonstrates: infinite loops, buffered output
#
# Usage: yes [STRING]
# Outputs STRING (default "y") forever

import ritzlib.sys
import ritzlib.str

const BUFSIZE: i64 = 8192

fn main(argc: i32, argv: **u8) -> i32
  let buf: *u8 = __builtin_alloca(BUFSIZE)
  var msg: *u8 = null
  var len: i64 = 0

  # Default message
  if argc == 1
    *(buf + 0) = 121  # 'y'
    *(buf + 1) = 10   # '\n'
    len = 2
  else
    # Use provided argument
    msg = *(argv + 1)
    len = strlen(msg)
    # Copy message to buffer
    var i: i64 = 0
    while i < len
      *(buf + i) = *(msg + i)
      i += 1
    *(buf + len) = 10  # Add newline
    len += 1

  # Fill buffer with repeated copies for efficiency
  var filled: i64 = len
  while filled + len <= BUFSIZE
    var i: i64 = 0
    while i < len
      *(buf + filled) = *(buf + i)
      filled += 1
      i += 1

  # Infinite loop - write buffer repeatedly
  while 1 == 1
    let written: i64 = sys_write(STDOUT, buf, filled)
    if written < 0
      return 1

  0
