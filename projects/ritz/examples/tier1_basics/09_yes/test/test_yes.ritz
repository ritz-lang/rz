# Tests for 09_yes - buffered output
#
# The 09_yes example demonstrates:
# - Buffer filling for efficient I/O
# - String repetition
# - Infinite loop patterns
# - Character manipulation

import ritzlib.sys
import ritzlib.str
import ritzlib.memory

# Test buffer fill with repeated pattern
[[test]]
fn test_fill_buffer_pattern() -> i32
    let buf: *u8 = malloc(16)
    let pattern = c"ab"
    let pattern_len: i64 = 2

    fill_buffer(buf, 16, pattern, pattern_len)

    # Should be "abababababababab"
    assert *buf == 'a'         # 'a'
    assert *(buf + 1) == 'b'   # 'b'
    assert *(buf + 2) == 'a'   # 'a'
    assert *(buf + 3) == 'b'   # 'b'
    assert *(buf + 14) == 'a'  # 'a'
    assert *(buf + 15) == 'b'  # 'b'

    free(buf)
    0

fn fill_buffer(buf: *u8, buf_size: i64, pattern: *u8, pattern_len: i64)
    for i in 0..buf_size
        *(buf + i) = *(pattern + (i % pattern_len))

# Test single character fill
[[test]]
fn test_fill_single_char() -> i32
    let buf: *u8 = malloc(8)
    memset(buf, 121, 8)  # 'y'

    for i in 0..8
        assert *(buf + i) == 121

    free(buf)
    0

# Test string copy into buffer
[[test]]
fn test_copy_to_buffer() -> i32
    let buf: *u8 = malloc(32)
    let msg1 = c"hello\n"
    let len: i64 = strlen(msg1)

    let msg2 = c"hello\n"
    memcpy(buf, msg2, len)
    assert *buf == 104        # 'h'
    assert *(buf + 5) == '\n'   # '\n'

    free(buf)
    0

# Test buffer capacity calculation
[[test]]
fn test_repetitions_in_buffer() -> i32
    let buf_size: i64 = 100
    let msg_len: i64 = 7  # "hello\n" + terminator overhead

    let reps: i64 = buf_size / msg_len
    assert reps == 14
    0

# Test newline appending
[[test]]
fn test_append_newline() -> i32
    let buf: *u8 = malloc(16)
    let msg1 = c"test"
    let len: i64 = strlen(msg1)

    let msg2 = c"test"
    memcpy(buf, msg2, len)
    *(buf + len) = 10  # newline

    assert *buf == 't'        # 't'
    assert *(buf + 1) == 'e'  # 'e'
    assert *(buf + 2) == 115  # 's'
    assert *(buf + 3) == 't'  # 't'
    assert *(buf + 4) == '\n'   # '\n'

    free(buf)
    0

# Test repeated copy efficiency
[[test]]
fn test_repeated_copy() -> i32
    let buf: *u8 = malloc(64)
    let pattern = c"y\n"
    let pattern_len: i64 = 2

    # Copy pattern multiple times
    var filled: i64 = 0
    while filled + pattern_len <= 64
        memcpy(buf + filled, pattern, pattern_len)
        filled += pattern_len

    assert filled == '@'
    assert *buf == 121         # 'y'
    assert *(buf + 1) == '\n'    # '\n'
    assert *(buf + 62) == 121  # 'y'
    assert *(buf + 63) == '\n'   # '\n'

    free(buf)
    0

# Test default "y" message
[[test]]
fn test_default_message() -> i32
    let buf: *u8 = malloc(2)
    *buf = 121        # 'y'
    *(buf + 1) = 10   # '\n'

    assert *buf == 121
    assert *(buf + 1) == '\n'

    free(buf)
    0

# Test character codes
[[test]]
fn test_char_codes() -> i32
    assert 121 == 121  # 'y'
    assert 10 == '\n'    # '\n'
    assert 32 == ' '    # ' '
    0

# ============================================================================
# Integration test: verify ./yes outputs repeated lines
# ============================================================================

fn yes_starts_with(buf: *u8, prefix: *u8) -> i32
    var i: i64 = 0
    while *(prefix + i) != 0
        if *(buf + i) != *(prefix + i)
            return 0
        i += 1
    return 1

[[test]]
fn test_yes_output() -> i32
    # Create pipe for capturing output
    var pipefd: [2]i32
    if sys_pipe(@pipefd[0]) < 0
        return 1

    let pid: i32 = sys_fork()
    if pid < 0
        sys_close(pipefd[0])
        sys_close(pipefd[1])
        return 2

    if pid == 0
        sys_dup2(pipefd[1], 1)
        sys_close(pipefd[0])
        sys_close(pipefd[1])

        var argv: [2]*u8
        argv[0] = c"./yes"
        argv[1] = null

        sys_execve(c"./yes", @argv[0], null)
        sys_exit(127)

    sys_close(pipefd[1])

    # Read a small amount (yes outputs infinitely)
    var out: [32]u8
    let n: i64 = sys_read(pipefd[0], @out[0], 31)
    sys_close(pipefd[0])

    # Kill the child since it runs forever
    sys_kill(pid, 9)  # SIGKILL
    var status: i32 = 0
    sys_wait4(pid, @status, 0, null)

    if n <= 0
        return 3

    out[n] = 0
    # yes should output "y\ny\ny\n..."
    assert yes_starts_with(@out[0], c"y\ny\ny\n") == 1, c"expected y y y"
    return 0
