# Tests for 14_uniq — collapse adjacent duplicate lines.
import ritzlib.testlib

fn uniq_run(flag: *u8, stdin_content: *u8, stdin_len: i64, out_buf: *u8, out_len: *i64) -> i32
    var argv: [3]*u8
    argv[0] = c"./uniq"
    if flag != null
        argv[1] = flag
        argv[2] = null
    else
        argv[1] = null
    return exec_capture(c"./uniq", @argv[0], null, stdin_content, stdin_len, out_buf, 1024, out_len)

[[test]]
fn test_uniq_default_dedupe_adjacent() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = uniq_run(null, c"a\na\nb\nb\nb\nc\n", 12, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n == 6, "expected 6 bytes"
    assert buf_eq(@out[0], c"a\nb\nc\n", 6) == 1, "default dedupe failed"
    0

[[test]]
fn test_uniq_dash_d_only_dupes() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = uniq_run(c"-d", c"a\na\nb\nb\nb\nc\n", 12, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n == 4, "expected 4 bytes"
    assert buf_eq(@out[0], c"a\nb\n", 4) == 1, "-d should emit only repeated lines"
    0

[[test]]
fn test_uniq_dash_u_only_uniques() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = uniq_run(c"-u", c"a\na\nb\nb\nb\nc\n", 12, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n == 2, "expected 2 bytes (c\\n)"
    assert buf_eq(@out[0], c"c\n", 2) == 1, "-u should emit only unique lines"
    0

[[test]]
fn test_uniq_empty_input() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = uniq_run(null, c"", 0, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n == 0, "empty in → empty out"
    0

[[test]]
fn test_uniq_all_identical_collapses() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = uniq_run(null, c"x\nx\nx\nx\n", 8, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n == 2, "expected 2 bytes (x\\n)"
    assert buf_eq(@out[0], c"x\n", 2) == 1, "4 identical → 1 line"
    0
