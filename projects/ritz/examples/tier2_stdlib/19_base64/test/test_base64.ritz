# Tests for 19_base64 — base64 encode stdin.
import ritzlib.testlib

fn base64_run(stdin_content: *u8, stdin_len: i64, out_buf: *u8, out_len: *i64) -> i32
    var argv: [2]*u8
    argv[0] = c"./base64"
    argv[1] = null
    return exec_capture(c"./base64", @argv[0], null, stdin_content, stdin_len, out_buf, 1024, out_len)

[[test]]
fn test_base64_encode_hello() -> i32
    # Classic vector — "hello\n" → "aGVsbG8K".
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = base64_run(c"hello\n", 6, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n >= 8, "expected at least 8 bytes (aGVsbG8K)"
    assert buf_eq(@out[0], c"aGVsbG8K", 8) == 1, "base64 hello mismatch"
    0

[[test]]
fn test_base64_encode_empty() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = base64_run(c"", 0, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n == 0, "empty in → empty out"
    0

[[test]]
fn test_base64_encode_one_byte() -> i32
    # 'A' (1 byte) → "QQ==" (double-pad)
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = base64_run(c"A", 1, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n >= 4, "expected at least 4 bytes (QQ==)"
    assert buf_eq(@out[0], c"QQ==", 4) == 1, "single-byte encoding failed"
    0

[[test]]
fn test_base64_encode_two_bytes() -> i32
    # 'AB' → "QUI=" (single-pad)
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = base64_run(c"AB", 2, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n >= 4, "expected at least 4 bytes (QUI=)"
    assert buf_eq(@out[0], c"QUI=", 4) == 1, "two-byte encoding failed"
    0

[[test]]
fn test_base64_encode_three_bytes() -> i32
    # 'ABC' → "QUJD" (no padding)
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = base64_run(c"ABC", 3, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n >= 4, "expected at least 4 bytes"
    assert buf_eq(@out[0], c"QUJD", 4) == 1, "three-byte encoding failed"
    0
