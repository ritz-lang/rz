# Tests for 15_cut — extract a field by delimiter.
import ritzlib.testlib

fn cut_run(delim: *u8, field: *u8, stdin_content: *u8, stdin_len: i64, out_buf: *u8, out_len: *i64) -> i32
    var argv: [6]*u8
    argv[0] = c"./cut"
    argv[1] = c"-d"
    argv[2] = delim
    argv[3] = c"-f"
    argv[4] = field
    argv[5] = null
    return exec_capture(c"./cut", @argv[0], null, stdin_content, stdin_len, out_buf, 1024, out_len)

[[test]]
fn test_cut_field_2() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = cut_run(c",", c"2", c"a,b,c\nd,e,f\n", 12, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n == 4, "expected 4 bytes (b\\ne\\n)"
    assert buf_eq(@out[0], c"b\ne\n", 4) == 1, "field 2 extraction failed"
    0

[[test]]
fn test_cut_field_1() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = cut_run(c",", c"1", c"a,b,c\nd,e,f\n", 12, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n == 4, "expected 4 bytes (a\\nd\\n)"
    assert buf_eq(@out[0], c"a\nd\n", 4) == 1, "field 1 extraction failed"
    0

[[test]]
fn test_cut_field_3() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = cut_run(c",", c"3", c"a,b,c\nd,e,f\n", 12, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n == 4, "expected 4 bytes (c\\nf\\n)"
    assert buf_eq(@out[0], c"c\nf\n", 4) == 1, "field 3 extraction failed"
    0

[[test]]
fn test_cut_empty_input() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = cut_run(c",", c"1", c"", 0, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n == 0, "empty input → empty output"
    0
