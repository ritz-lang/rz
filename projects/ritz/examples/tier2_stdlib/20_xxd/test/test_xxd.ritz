# Tests for 20_xxd — hex dump.
import ritzlib.testlib

fn xxd_run(stdin_content: *u8, stdin_len: i64, out_buf: *u8, out_len: *i64) -> i32
    var argv: [2]*u8
    argv[0] = c"./xxd"
    argv[1] = null
    return exec_capture(c"./xxd", @argv[0], null, stdin_content, stdin_len, out_buf, 1024, out_len)

[[test]]
fn test_xxd_hi_dump() -> i32
    # 'hi\n' is 3 bytes (0x68 0x69 0x0a).  Assert hex digits + ASCII + offset.
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = xxd_run(c"hi\n", 3, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n > 0, "expected output"
    assert buf_contains(@out[0], n, c"6869", 4) == 1, "missing 6869 hex"
    assert buf_contains(@out[0], n, c"0a", 2) == 1, "missing 0a hex"
    assert buf_contains(@out[0], n, c"hi", 2) == 1, "missing 'hi' ASCII"
    assert buf_contains(@out[0], n, c"00000000", 8) == 1, "missing offset prefix"
    0

[[test]]
fn test_xxd_empty_input() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = xxd_run(c"", 0, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n == 0, "empty in → empty out"
    0

[[test]]
fn test_xxd_single_char() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = xxd_run(c"A", 1, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n > 0, "expected output"
    assert buf_contains(@out[0], n, c"41", 2) == 1, "missing 41 hex"
    0
