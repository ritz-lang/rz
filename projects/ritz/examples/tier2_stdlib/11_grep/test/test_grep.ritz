# Tests for 11_grep — fixed-string substring search.
#
# Unit tests cover the substring-matching primitives that grep relies on
# (Span<u8>, span_contains).  Integration tests fork+exec ./grep via
# ritzlib.testlib.exec_capture and assert on captured stdout + exit code.

import ritzlib.span
import ritzlib.testlib

# ============================================================================
# Unit tests — Span<u8> and substring match primitives
# ============================================================================

[[test]]
fn test_span_from_cstr_len() -> i32
    let s: Span<u8> = span_from_cstr(c"hello")
    assert s.len == 5
    0

[[test]]
fn test_span_contains_basic() -> i32
    var hay: Span<u8> = span_from_cstr(c"apple")
    var needle: Span<u8> = span_from_cstr(c"app")
    assert span_contains(@hay, @needle) == 1
    0

[[test]]
fn test_span_contains_no_match() -> i32
    var hay: Span<u8> = span_from_cstr(c"apple")
    var needle: Span<u8> = span_from_cstr(c"xyz")
    assert span_contains(@hay, @needle) == 0
    0

[[test]]
fn test_span_contains_empty_needle() -> i32
    # Empty pattern should always match (matches grep semantics)
    var hay: Span<u8> = span_from_cstr(c"abc")
    var needle: Span<u8> = span_from_cstr(c"")
    assert span_contains(@hay, @needle) == 1
    0

[[test]]
fn test_span_contains_at_end() -> i32
    var hay: Span<u8> = span_from_cstr(c"banana")
    var needle: Span<u8> = span_from_cstr(c"ana")
    assert span_contains(@hay, @needle) == 1
    0

# ============================================================================
# Integration tests — fork+exec ./grep with stdin
# ============================================================================

[[test]]
fn test_grep_basic_match() -> i32
    var argv: [3]*u8
    argv[0] = c"./grep"
    argv[1] = c"ap"
    argv[2] = null

    var out: [1024]u8
    var n: i64 = 0
    let stdin: *u8 = c"apple\nbanana\napricot\ncherry\n"
    let exit_code: i32 = exec_capture(c"./grep", @argv[0], null, stdin, 28, @out[0], 1024, @n)

    assert exit_code == 0, "exit code should be 0 (match found)"
    assert n == 14, "expected 14 bytes (apple\\napricot\\n)"
    assert buf_eq(@out[0], c"apple\napricot\n", 14) == 1, "output mismatch"
    0

[[test]]
fn test_grep_no_match() -> i32
    var argv: [3]*u8
    argv[0] = c"./grep"
    argv[1] = c"xyz"
    argv[2] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./grep", @argv[0], null, c"one\ntwo\n", 8, @out[0], 1024, @n)

    assert exit_code == 1, "exit code should be 1 (no match)"
    assert n == 0, "output should be empty"
    0

[[test]]
fn test_grep_empty_pattern_matches_all() -> i32
    var argv: [3]*u8
    argv[0] = c"./grep"
    argv[1] = c""
    argv[2] = null

    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = exec_capture(c"./grep", @argv[0], null, c"a\nb\nc\n", 6, @out[0], 1024, @n)

    assert exit_code == 0, "empty pattern should match everything"
    assert n == 6, "expected 6 bytes back"
    assert buf_eq(@out[0], c"a\nb\nc\n", 6) == 1, "output mismatch"
    0
