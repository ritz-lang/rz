# Tests for 16_tr — translate or delete characters.
import ritzlib.testlib

fn tr_run(set1: *u8, set2: *u8, stdin_content: *u8, stdin_len: i64, out_buf: *u8, out_len: *i64) -> i32
    var argv: [4]*u8
    argv[0] = c"./tr"
    argv[1] = set1
    argv[2] = set2
    argv[3] = null
    return exec_capture(c"./tr", @argv[0], null, stdin_content, stdin_len, out_buf, 1024, out_len)

[[test]]
fn test_tr_lowercase_to_uppercase() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = tr_run(c"a-z", c"A-Z", c"Hello World\n", 12, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n == 12, "length should be preserved"
    assert buf_eq(@out[0], c"HELLO WORLD\n", 12) == 1, "lowercase→uppercase failed"
    0

[[test]]
fn test_tr_uppercase_to_lowercase() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = tr_run(c"A-Z", c"a-z", c"Hello World\n", 12, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert buf_eq(@out[0], c"hello world\n", 12) == 1, "uppercase→lowercase failed"
    0

[[test]]
fn test_tr_single_char() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = tr_run(c"b", c"Z", c"abc\n", 4, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert buf_eq(@out[0], c"aZc\n", 4) == 1, "single-char translation failed"
    0

[[test]]
fn test_tr_empty_input() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = tr_run(c"a", c"b", c"", 0, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n == 0, "empty input → empty output"
    0

[[test]]
fn test_tr_identity() -> i32
    # set1 == set2 should leave content unchanged
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = tr_run(c"a-z", c"a-z", c"hello\n", 6, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert buf_eq(@out[0], c"hello\n", 6) == 1, "identity translation failed"
    0
