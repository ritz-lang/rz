# Tests for 18_nl — number lines (default format: 5-space-padded number, tab, content).
import ritzlib.testlib

fn nl_run(stdin_content: *u8, stdin_len: i64, out_buf: *u8, out_len: *i64) -> i32
    var argv: [2]*u8
    argv[0] = c"./nl"
    argv[1] = null
    return exec_capture(c"./nl", @argv[0], null, stdin_content, stdin_len, out_buf, 1024, out_len)

[[test]]
fn test_nl_basic_three_lines() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = nl_run(c"first\nsecond\nthird\n", 19, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    let expected: *u8 = c"     1\tfirst\n     2\tsecond\n     3\tthird\n"
    assert n == 40, "expected 40 bytes"
    assert buf_eq(@out[0], expected, 40) == 1, "basic numbering failed"
    0

[[test]]
fn test_nl_single_line() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = nl_run(c"only\n", 5, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    let expected: *u8 = c"     1\tonly\n"
    assert n == 12, "expected 12 bytes"
    assert buf_eq(@out[0], expected, 12) == 1, "single-line numbering failed"
    0

[[test]]
fn test_nl_empty_input() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = nl_run(c"", 0, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n == 0, "empty in → empty out"
    0
