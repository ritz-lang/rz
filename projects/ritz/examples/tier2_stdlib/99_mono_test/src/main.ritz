# Test monomorphization of imported generic functions

import ritzlib.gvec

fn main() -> i32
    # Test: Call vec_new<u8> from imported module
    var v: Vec<u8> = vec_new<u8>()

    # Verify it works
    if vec_len<u8>(@v) == 0
        prints_cstr(c"OK: vec_len works\n")

    vec_drop<u8>(@v)
    0

fn prints_cstr(s: *u8)
    var len: i64 = 0
    while *(s + len) != 0
        len += 1
    sys_write(1, s, len)

extern fn sys_write(fd: i32, buf: *u8, count: i64) -> i64
