# Tests for 12_tac — reverse line order.  tac takes no args.
import ritzlib.testlib

fn tac_run(stdin_content: *u8, stdin_len: i64, out_buf: *u8, out_len: *i64) -> i32
    var argv: [2]*u8
    argv[0] = c"./tac"
    argv[1] = null
    return exec_capture(c"./tac", @argv[0], null, stdin_content, stdin_len, out_buf, 1024, out_len)

[[test]]
fn test_tac_basic_reverse() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = tac_run(c"1\n2\n3\n", 6, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n == 6, "expected 6 bytes back"
    assert buf_eq(@out[0], c"3\n2\n1\n", 6) == 1, "reversed output mismatch"
    0

[[test]]
fn test_tac_single_line() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = tac_run(c"only\n", 5, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n == 5, "single line should be roundtripped"
    assert buf_eq(@out[0], c"only\n", 5) == 1, "single-line content mismatch"
    0

[[test]]
fn test_tac_empty_input() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = tac_run(c"", 0, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n == 0, "empty input → empty output"
    0

[[test]]
fn test_tac_five_lines() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = tac_run(c"a\nb\nc\nd\ne\n", 10, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n == 10, "expected 10 bytes back"
    assert buf_eq(@out[0], c"e\nd\nc\nb\na\n", 10) == 1, "5-line reverse mismatch"
    0
