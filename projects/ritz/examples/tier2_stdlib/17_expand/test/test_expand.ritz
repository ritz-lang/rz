# Tests for 17_expand — convert tabs to spaces (default 8-column tab stops).
import ritzlib.testlib

fn expand_run(stdin_content: *u8, stdin_len: i64, out_buf: *u8, out_len: *i64) -> i32
    var argv: [2]*u8
    argv[0] = c"./expand"
    argv[1] = null
    return exec_capture(c"./expand", @argv[0], null, stdin_content, stdin_len, out_buf, 1024, out_len)

[[test]]
fn test_expand_single_tab() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = expand_run(c"a\tb\n", 4, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n == 10, "expected 10 bytes (a + 7 spaces + b + \\n)"
    assert buf_eq(@out[0], c"a       b\n", 10) == 1, "single tab expansion failed"
    0

[[test]]
fn test_expand_multiple_tabs() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = expand_run(c"a\tb\tc\n", 6, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n == 18, "expected 18 bytes"
    assert buf_eq(@out[0], c"a       b       c\n", 18) == 1, "multiple tab expansion failed"
    0

[[test]]
fn test_expand_no_tabs_identity() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = expand_run(c"hello world\n", 12, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert buf_eq(@out[0], c"hello world\n", 12) == 1, "no-tabs identity failed"
    0

[[test]]
fn test_expand_empty_input() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = expand_run(c"", 0, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n == 0, "empty in → empty out"
    0
