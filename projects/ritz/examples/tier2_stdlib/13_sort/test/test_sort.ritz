# Tests for 13_sort — sort lines.  No args.
import ritzlib.testlib

fn sort_run(stdin_content: *u8, stdin_len: i64, out_buf: *u8, out_len: *i64) -> i32
    var argv: [2]*u8
    argv[0] = c"./sort"
    argv[1] = null
    return exec_capture(c"./sort", @argv[0], null, stdin_content, stdin_len, out_buf, 1024, out_len)

[[test]]
fn test_sort_basic_alpha() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = sort_run(c"c\na\nb\n", 6, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n == 6, "expected 6 bytes"
    assert buf_eq(@out[0], c"a\nb\nc\n", 6) == 1, "basic alpha sort failed"
    0

[[test]]
fn test_sort_idempotent() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = sort_run(c"a\nb\nc\n", 6, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert buf_eq(@out[0], c"a\nb\nc\n", 6) == 1, "already-sorted should be idempotent"
    0

[[test]]
fn test_sort_reverse_input() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = sort_run(c"z\ny\nx\n", 6, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert buf_eq(@out[0], c"x\ny\nz\n", 6) == 1, "reverse input should sort"
    0

[[test]]
fn test_sort_empty_input() -> i32
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = sort_run(c"", 0, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n == 0, "empty input → empty output"
    0

[[test]]
fn test_sort_duplicates_preserved() -> i32
    # Without -u, duplicates remain.
    var out: [1024]u8
    var n: i64 = 0
    let exit_code: i32 = sort_run(c"b\na\na\nb\n", 8, @out[0], @n)
    assert exit_code == 0, "exit code should be 0"
    assert n == 8, "expected 8 bytes (4 lines)"
    assert buf_eq(@out[0], c"a\na\nb\nb\n", 8) == 1, "duplicates should be preserved"
    0
