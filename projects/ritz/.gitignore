# Python
__pycache__/
*.py[cod]
*.so
.pytest_cache/

# Build artifacts
build/
target/
*.o
*.s
*.ll
*.bc
.build/
.regression/
t_build/
build_test/
tmp*/

# Runtime: ignore built objects, but track source .ll files
runtime/*.o
!runtime/*.x86_64.ll

# Build cache
.ritz-cache/

# Compiled binaries (keep named examples in examples/)
/cmp
/cmp2
/test_*
ritz1/ritz1
ritz1/ritz1.prev
ritz1/*.ritz
ritz1/test_bin
ritz1/test.err
ritz1/archive/
!/ritz1/src/*.ritz
!/ritz1/test/*.ritz

# Test binaries
examples/*/test_bin
examples/test_bin
examples/test.ritz
examples/test_crash.ritz
examples/test_import/
tests/import_test/

# Test directories
!test/
test/dual_compiler/.build/

# Temp ritzlib test dirs
ritzlib/tests/tmp*/

# Example binaries (built from source)
# Tier 1
examples/*/hello
examples/*/exitcode
examples/*/echo
examples/*/true
examples/*/false
examples/*/cat
examples/*/head
examples/*/wc
examples/*/seq
examples/*/yes
examples/*/sleep
