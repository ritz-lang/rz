examples/*/ls
examples/*/mkdir
examples/*/rm
examples/*/cp
examples/*/mv
examples/*/touch
examples/*/stat
examples/*/chmod
examples/*/du
examples/*/find
examples/*/grep
examples/*/tac
examples/*/sort
examples/*/uniq
examples/*/cut
examples/*/tr
examples/*/expand
examples/*/nl
examples/*/base64
examples/*/xxd
# Tier 4
examples/*/env
examples/*/which
examples/*/printenv
examples/*/tee
examples/*/kill
examples/*/xargs
examples/*/time
examples/*/nohup
examples/*/watch
examples/*/timeout

