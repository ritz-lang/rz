# tests/float_test.ritz - Test float literal support

import ritzlib.sys

# Float constants
const PI: f64 = 3.14159265359
const NEGATIVE: f64 = -2.5
const SMALL: f64 = 0.001

fn main() -> i64
    # Float literals
    var x: f64 = 1.5
    var y: f64 = 2.5

    # Arithmetic operations
    let sum: f64 = x + y
    let diff: f64 = y - x
    let prod: f64 = x * y
    let quot: f64 = y / x

    # Using constant
    var area: f64 = PI * 2.0 * 2.0

    # Comparisons
    if x < y
        # OK
        x = x
    else
        return 1

    if y > x
        # OK
        x = x
    else
        return 2

    if x == 1.5
        # OK
        x = x
    else
        return 3

    # Negation
    let neg_x: f64 = -x
    if neg_x < 0.0
        # OK
        x = x
    else
        return 4

    # All tests passed
    return 0
