# Test file for tuple type support (Issue #94)

fn test_basic_tuple() -> i32
    let t: (i32, i32) = (1, 2)
    let a: i32 = t.0
    let b: i32 = t.1
    if a == 1 and b == 2
        return 0
    return 1

fn test_tuple_addition() -> i32
    let t: (i32, i32) = (10, 20)
    let sum: i32 = t.0 + t.1
    if sum == 30
        return 0
    return 1

fn test_mixed_tuple() -> i32
    let t: (i32, i64, i32) = (1, 100, 3)
    let a: i32 = t.0
    let b: i64 = t.1
    let c: i32 = t.2
    if a == 1 and b == 100 and c == 3
        return 0
    return 1

fn test_single_element_tuple() -> i32
    let t: (i32,) = (42,)
    if t.0 == 42
        return 0
    return 1

fn main() -> i32
    var failures: i32 = 0

    failures = failures + test_basic_tuple()
    failures = failures + test_tuple_addition()
    failures = failures + test_mixed_tuple()
    failures = failures + test_single_element_tuple()

    return failures
