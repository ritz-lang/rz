# Test closures / anonymous functions

import ritzlib.io

# Test 1: Basic closure without capture
fn apply(f: fn(i32) -> i32, x: i32) -> i32
    return f(x)

# Test 2: Higher-order function with closure
fn map_int(arr: *i32, len: i32, f: fn(i32) -> i32, out: *i32)
    for i in 0..len
        *(out + i) = f(*(arr + i))

fn main() -> i32
    # Test basic closure
    let double: fn(i32) -> i32 = |x| x * 2
    let result = apply(double, 21)
    if result == 42
        prints("closure basic: PASS\n")
    else
        prints("closure basic: FAIL\n")
        return 1
    
    # Test closure in higher-order function
    let add_one: fn(i32) -> i32 = |x| x + 1
    var arr: [3]i32
    arr[0] = 10
    arr[1] = 20
    arr[2] = 30
    var out: [3]i32
    map_int(@arr[0], 3, add_one, @out[0])
    
    if out[0] == 11 and out[1] == 21 and out[2] == 31
        prints("closure map: PASS\n")
    else
        prints("closure map: FAIL\n")
        return 1
    
    prints("All closure tests passed!\n")
    0
