# Test closures with variable capture

import ritzlib.io

fn apply(f: fn(i32) -> i32, x: i32) -> i32
    return f(x)

fn main() -> i32
    # Test closure with capture
    let multiplier: i32 = 10
    let scale: fn(i32) -> i32 = |x| x * multiplier
    
    let result = apply(scale, 5)
    if result == 50
        prints("closure capture: PASS\n")
    else
        prints("closure capture: FAIL\n")
        return 1
    
    # Test nested capture
    let a: i32 = 2
    let b: i32 = 3
    let combine: fn(i32) -> i32 = |x| x * a + b
    
    let result2 = apply(combine, 10)
    if result2 == 23  # 10 * 2 + 3
        prints("closure multi-capture: PASS\n")
    else
        prints("closure multi-capture: FAIL\n")
        return 1
    
    prints("All capture tests passed!\n")
    0
