# Test the ? operator with Result

import ritzlib.io
import ritzlib.result

fn might_fail(succeed: i32) -> Result<i64, i64>
    if succeed != 0
        return Ok(42)
    return Err(-1)

fn use_try_op(succeed: i32) -> Result<i64, i64>
    let value = might_fail(succeed)?
    return Ok(value + 1)

fn main() -> i32
    let r1 = use_try_op(1)
    match r1
        Ok(v) => prints("? success: PASS\n")
        Err(e) => prints("? success: FAIL\n")
    
    let r2 = use_try_op(0)
    match r2
        Ok(v) => prints("? error: FAIL\n")
        Err(e) => prints("? error: PASS\n")
    
    0
