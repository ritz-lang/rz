# Test dyn Trait - trait objects for runtime polymorphism

import ritzlib.io

trait Animal
    fn speak(self: *Self) -> i64
    fn name(self: *Self) -> i64

struct Dog
    age: i64

struct Cat
    lives: i64

impl Animal for Dog
    fn speak(self: *Self) -> i64
        prints("Woof!\n")
        return 1
    
    fn name(self: *Self) -> i64
        prints("Dog\n")
        return 2

impl Animal for Cat
    fn speak(self: *Self) -> i64
        prints("Meow!\n")
        return 3
    
    fn name(self: *Self) -> i64
        prints("Cat\n")
        return 4

fn main() -> i32
    var dog = Dog { age: 5 }
    var cat = Cat { lives: 9 }
    
    # Static dispatch (works today)
    Dog_speak(&dog)
    Cat_speak(&cat)
    
    prints("Static dispatch works!\n")
    0
