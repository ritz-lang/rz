# Tests for unsafe blocks
# Unsafe blocks allow raw pointer operations

import ritzlib.sys

# ============================================================================
# Basic unsafe block tests
# ============================================================================

[[test]]
fn test_unsafe_block_basic() -> i32
    # Unsafe block allows raw pointer operations
    var x: i32 = 42
    unsafe
        let ptr: *i32 = @x
        let val: i32 = *ptr
        assert val == 42
    0

[[test]]
fn test_unsafe_block_write() -> i32
    # Unsafe block can write through pointers
    var x: i32 = 0
    unsafe
        let ptr: *mut i32 = @x
        *ptr = 99
    assert x == 99
    0

[[test]]
fn test_unsafe_nested() -> i32
    # Nested unsafe blocks (outer unsafe is sufficient)
    var x: i32 = 10
    unsafe
        let ptr: *mut i32 = @x
        unsafe
            *ptr = 20
        assert *ptr == 20
    assert x == 20
    0

[[test]]
fn test_unsafe_with_control_flow() -> i32
    # Unsafe blocks with control flow
    var sum: i32 = 0
    var arr: [3]i32 = [1, 2, 3]

    unsafe
        let ptr: *i32 = @arr[0]
        var i: i32 = 0
        while i < 3
            # Pointer arithmetic in unsafe
            sum += *(ptr + i)
            i += 1

    assert sum == 6
    0

# ============================================================================
# Unsafe with functions
# ============================================================================

fn unsafe_helper(ptr: *i32)
    # This function body is implicitly safe
    # We can receive pointers as params, just can't deref without unsafe
    unsafe
        *ptr = 123

[[test]]
fn test_unsafe_in_function() -> i32
    var x: i32 = 0
    unsafe_helper(@x)
    assert x == 123
    0
