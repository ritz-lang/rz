# Test: Negated character class [^x] - should create two ranges
# Bug: thompson_range doesn't validate that lo <= hi

const SYS_WRITE: i64 = 1
const STDERR: i32 = 2

fn sys_write(fd: i32, buf: *i8, count: i64) -> i64
  syscall3(SYS_WRITE, fd as i64, buf as i64, count)

fn print_msg(msg: *i8)
  var len: i32 = 0
  while *(msg + len) != 0
    len = len + 1
  sys_write(STDERR, msg, len as i64)

fn print_int(val: i32)
  # Print a simple integer
  var buf: [16]i8 = [0; 16]
  var pos: i32 = 14
  var n: i32 = val
  var negative: i32 = 0

  if n < 0
    negative = 1
    n = 0 - n

  if n == 0
    buf[pos] = 48  # '0'
    pos = pos - 1
  else
    while n > 0
      buf[pos] = 48 + (n % 10)
      n = n / 10
      pos = pos - 1

  if negative == 1
    buf[pos] = 45  # '-'
    pos = pos - 1

  sys_write(STDERR, @buf[pos + 1], (14 - pos) as i64)

fn main() -> i32
  var states: [512]NFAState
  var trans: [1024]Transition
  var nfa: NFA

  nfa_init(@nfa, @states[0], @trans[0])

  print_msg(c"Test: thompson_range validation\n")

  # Test 1: Valid range [a-z] (97-122)
  print_msg(c"  Creating range [a-z] (97-122)...\n")
  let valid_frag: NFAFragment = thompson_range(@nfa, 97, 122)
  print_msg(c"    Start: ")
  print_int(valid_frag.start)
  print_msg(c", End: ")
  print_int(valid_frag.end)
  print_msg(c"\n")

  # Test 2: Single char range [a-a] (97-97)
  print_msg(c"  Creating range [a-a] (97-97)...\n")
  let single_frag: NFAFragment = thompson_range(@nfa, 97, 97)
  print_msg(c"    Start: ")
  print_int(single_frag.start)
  print_msg(c", End: ")
  print_int(single_frag.end)
  print_msg(c"\n")

  # Test 3: INVALID range (lo > hi) - THIS IS THE BUG!
  # When [^x] is x=0, we get range(0, -1) which is invalid
  print_msg(c"  Creating INVALID range [0 to -1]...\n")
  print_msg(c"    lo=0, hi=-1\n")
  let invalid_frag: NFAFragment = thompson_range(@nfa, 0, -1)
  print_msg(c"    Start: ")
  print_int(invalid_frag.start)
  print_msg(c", End: ")
  print_int(invalid_frag.end)
  print_msg(c"\n")

  # Check the transition that was created
  print_msg(c"    Checking transition...\n")
  let trans_ptr: *Transition = nfa.transitions + (nfa.trans_count - 1)
  print_msg(c"      kind: ")
  print_int(trans_ptr.kind)
  print_msg(c" (should be 1 for TR_RANGE)\n")
  print_msg(c"      char_lo: ")
  print_int(trans_ptr.char_lo)
  print_msg(c"\n")
  print_msg(c"      char_hi: ")
  print_int(trans_ptr.char_hi)
  print_msg(c"\n")

  print_msg(c"\n✓ Test completed (demonstrates the invalid range bug)\n")
  0
