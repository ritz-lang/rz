# Test the NFA lexer setup
# Dependencies: all lexer components must be compiled together

fn main() -> i32
  # Allocate storage
  var states: [256]NFAState
  var trans: [512]Transition
  var patterns: [64]TokenPattern
  var nfa_storage: NFA
  var lex: Lexer

  # Setup lexer
  setup_lexer(@lex, @nfa_storage, @patterns, @states, @trans)

  # Test source
  let src: *i8 = "fn main() -> i32\n  return 42\n"
  let len: i32 = 30

  # Set source in lexer
  lex.src = src
  lex.len = len

  # Get first token
  let tok: Token = lexer_next(@lex)

  # Should be TOK_FN (20)
  if tok.kind == TOK_FN
    return 0  # Success!

  1  # Failure
