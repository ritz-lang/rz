# Test for-loop implementation
#
# Expected output:
# 0
# 1
# 2
# 3
# 4
# done

import ritzlib.sys

fn print_int(n: i64)
    # Simple print for small positive integers
    if n == 0
        sys_write(1, c"0\n", 2)
    else
        var buf: [20]u8
        var i: i32 = 19
        var num: i64 = n
        buf[i] = '\n' as u8
        i = i - 1
        while num > 0
            buf[i] = ('0' as i64 + num % 10) as u8
            num = num / 10
            i = i - 1
        i = i + 1
        sys_write(1, @buf[i], (20 - i) as i64)

fn main() -> i32
    for i in 0..5
        print_int(i)
    sys_write(1, c"done\n", 5)
    0
