# System constants and syscall wrappers for ritz1
# Linux x86_64 syscall ABI

# Standard file descriptors
const STDIN: i32 = 0
const STDOUT: i32 = 1
const STDERR: i32 = 2

# Syscall numbers (x86_64 Linux)
const SYS_READ: i64 = 0
const SYS_WRITE: i64 = 1
const SYS_EXIT: i64 = 60

# Write to a file descriptor
# Returns number of bytes written, or negative on error
fn sys_write(fd: i32, buf: *i8, len: i64) -> i64
  syscall3(SYS_WRITE, fd as i64, buf as i64, len)

# Read from a file descriptor
# Returns number of bytes read, or negative on error
fn sys_read(fd: i32, buf: *i8, len: i64) -> i64
  syscall3(SYS_READ, fd as i64, buf as i64, len)

# Exit the program with a status code
fn sys_exit(status: i32) -> i64
  syscall1(SYS_EXIT, status as i64)
