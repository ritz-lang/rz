# Test: String literal pattern [^"]*
# This is the actual pattern that hangs

const SYS_WRITE: i64 = 1
const STDERR: i32 = 2

fn sys_write(fd: i32, buf: *i8, count: i64) -> i64
  syscall3(SYS_WRITE, fd as i64, buf as i64, count)

fn print_msg(msg: *i8)
  var len: i32 = 0
  while *(msg + len) != 0
    len = len + 1
  sys_write(STDERR, msg, len as i64)

fn main() -> i32
  var states: [512]NFAState
  var trans: [1024]Transition
  var nfa: NFA

  nfa_init(@nfa, @states, @trans)
  
  print_msg(c"Test: String pattern with quote [^\"]...\n")
  let pattern: *i8 = c"[^\"]"
  let frag: NFAFragment = regex_parse(pattern, 5, @nfa)
  thompson_accept(@nfa, frag, 10)
  print_msg(c"  [^\"] compiled successfully!\n")
  
  print_msg(c"\nTest: String pattern with star [^\"]*...\n")
  let pattern2: *i8 = c"[^\"]*"
  print_msg(c"  About to parse...\n")
  let frag2: NFAFragment = regex_parse(pattern2, 6, @nfa)
  print_msg(c"  Parsed! About to accept...\n")
  thompson_accept(@nfa, frag2, 11)
  print_msg(c"  Accepted!\n")
  
  print_msg(c"\nAll tests passed!\n")
  0
