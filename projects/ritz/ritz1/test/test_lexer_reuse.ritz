# Test: Does reusing the same lexer cause the bug?

const SYS_WRITE: i64 = 1
const STDERR: i32 = 2

fn sys_write(fd: i32, buf: *i8, count: i64) -> i64
  syscall3(SYS_WRITE, fd as i64, buf as i64, count)

fn print_msg(msg: *i8)
  var len: i32 = 0
  while *(msg + len) != 0
    len = len + 1
  sys_write(STDERR, msg, len)

fn main() -> i32
  var states: [256]NFAState
  var trans: [512]Transition
  var patterns: [64]TokenPattern
  var nfa_storage: NFA
  var lex: Lexer

  nfa_init(@nfa_storage, @states, @trans)
  lexer_init(@lex, 0, 0, @nfa_storage, @patterns)

  print_msg(c"Testing REUSED lexer with multiple tokens...\n")

  lexer_add_pattern(@lex, "[a-zA-Z_][a-zA-Z0-9_]*", TOK_IDENT, 0)
  lexer_add_pattern(@lex, "(", TOK_LPAREN, 1)
  lexer_add_pattern(@lex, ")", TOK_RPAREN, 1)
  lexer_add_pattern(@lex, " ", TOK_SKIP, 1)
  lexer_finalize(@lex)

  lex.src = c"main()"
  lex.len = 6
  lex.pos = 0

  print_msg(c"\nCalling lexer_next() three times on same source:\n")

  var tok: Token = lexer_next(@lex)
  print_msg(c"  Token 1 kind: ")
  if tok.kind == TOK_IDENT
    print_msg(c"TOK_IDENT\n")
  else
    print_msg(c"ERROR\n")
    return 1

  tok = lexer_next(@lex)
  print_msg(c"  Token 2 kind: ")
  if tok.kind == TOK_LPAREN
    print_msg(c"TOK_LPAREN\n")
  else
    print_msg(c"ERROR\n")
    return 1

  tok = lexer_next(@lex)
  print_msg(c"  Token 3 kind: ")
  if tok.kind == TOK_RPAREN
    print_msg(c"TOK_RPAREN\n")
  else
    print_msg(c"ERROR\n")
    return 1

  print_msg(c"\nTest PASSED - reusing lexer works!\n")
  0
