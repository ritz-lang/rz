# Test struct assignment to verify next pointer initialization
# Returns 0 if all tests pass, non-zero error code otherwise

struct SimpleNode
  value: i32
  next: *SimpleNode

fn create_node_inline(v: i32) -> SimpleNode
  SimpleNode {
    value: v,
    next: 0
  }

fn main() -> i32
  # Test 1: Direct struct literal return
  let node1: SimpleNode = create_node_inline(42)
  if node1.next != 0
    return 10  # Error code 10: node1.next is not null

  # Test 2: Struct assignment via pointer (THE CRITICAL TEST)
  let s: *SimpleNode = __builtin_alloca(128)
  *s = create_node_inline(99)

  # Check if value was set correctly
  if s.value != 99
    return 20  # Error code 20: value not set correctly

  # Check if next pointer is null (THIS IS THE BUG WE'RE TRACKING)
  if s.next != 0
    return 30  # Error code 30: next pointer not null after assignment

  # Test 3: Explicitly set next to 0 after assignment
  s.next = 0
  if s.next != 0
    return 40  # Error code 40: next pointer not null even after explicit set

  # All tests passed
  0
