# Auto-extracted from emitter_expr.ritz — CALL + METHOD codegen.

import ast
import emitter_core
import emitter_expr


# =============================================================================
# Method-dispatch helpers (ported from ritz0 Wave-1 commit 0278a27).
#
# Runs before the regular impl-table lookup so missing UFCS wrappers don't
# block obvious intrinsic patterns. Mirrors the dispatch chain from the
# holy-fuck-wip branch — StrView builtins, Vec/Span/StrView .len(), and a
# UFCS fallback that rewrites `v.method(args)` -> `vec_method$T(&v, args)`
# (similarly for Span$T, StrView) when the monomorphized wrapper exists.
# =============================================================================

fn starts_with(name: *u8, len: i32, prefix: *u8, prefix_len: i32) -> i32
    if len < prefix_len
        return 0
    for i in 0..prefix_len
        if *(name + i) != *(prefix + i)
            return 0
    1

# StrView.as_bytes() -> Span<u8> — bypasses the missing StrView_as_bytes impl
# Returns -1 if not applicable, else the LLVM register holding the Span<u8>.
# recv_is_ptr_of_ptr = 1 when the stack slot holds a pointer value (receiver is *StrView);
# 0 when the stack slot is the struct itself.
fn try_emit_strview_as_bytes(s: *EmitterState, e: *Expr, type_name: *u8, type_name_len: i32, receiver_reg: i32, recv_is_ptr_of_ptr: i32) -> i32
    # Must be "StrView"
    if name_eq(type_name, type_name_len, c"StrView", 7) == 0
        return -1
    # Method must be "as_bytes"
    if name_eq(e.ident_ptr, e.ident_len, c"as_bytes", 8) == 0
        return -1
    # No args
    if e.args != null
        return -1

    # If the receiver is *StrView (pointer), dereference once to get ptr-to-struct.
    var struct_ptr: i32 = receiver_reg
    if recv_is_ptr_of_ptr == 1
        let loaded: i32 = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, loaded)
        emit_str(s, c" = load ptr, ptr ")
        emit_reg(s, receiver_reg)
        emit_str(s, c"\n")
        struct_ptr = loaded

    # Load %StrView from the receiver pointer
    let sv: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, sv)
    emit_str(s, c" = load %StrView, ptr ")
    emit_reg(s, struct_ptr)
    emit_str(s, c"\n")

    # Extract the ptr and len fields
    let ptr_reg: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, ptr_reg)
    emit_str(s, c" = extractvalue %StrView ")
    emit_reg(s, sv)
    emit_str(s, c", 0\n")

    let len_reg: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, len_reg)
    emit_str(s, c" = extractvalue %StrView ")
    emit_reg(s, sv)
    emit_str(s, c", 1\n")

    # Build the %Span$u8 { ptr, i64 } value inline
    let span1: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, span1)
    emit_str(s, c" = insertvalue %Span$u8 undef, ptr ")
    emit_reg(s, ptr_reg)
    emit_str(s, c", 0\n")

    let span2: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, span2)
    emit_str(s, c" = insertvalue %Span$u8 ")
    emit_reg(s, span1)
    emit_str(s, c", i64 ")
    emit_reg(s, len_reg)
    emit_str(s, c", 1\n")
    return span2

# Vec/Span/StrView .len() — load the len field (index 1) directly.
# Returns -1 if not applicable, else the register holding an i64 length.
# recv_is_ptr_of_ptr = 1 when the stack slot holds a pointer value (receiver is
# *Vec<T> etc.); 0 when the stack slot *is* the struct.
fn try_emit_len_builtin(s: *EmitterState, e: *Expr, type_name: *u8, type_name_len: i32, receiver_reg: i32, recv_is_ptr_of_ptr: i32) -> i32
    # Must be .len() with no args
    if name_eq(e.ident_ptr, e.ident_len, c"len", 3) == 0
        return -1
    if e.args != null
        return -1

    # Type must be Vec$T, Span$T, or StrView
    var matched: i32 = 0
    if starts_with(type_name, type_name_len, c"Vec$", 4) == 1
        matched = 1
    else if starts_with(type_name, type_name_len, c"Span$", 5) == 1
        matched = 1
    else if name_eq(type_name, type_name_len, c"StrView", 7) == 1
        matched = 1
    if matched == 0
        return -1

    # If the receiver is a pointer, load the stack slot to get the actual struct pointer.
    var struct_ptr: i32 = receiver_reg
    if recv_is_ptr_of_ptr == 1
        let loaded: i32 = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, loaded)
        emit_str(s, c" = load ptr, ptr ")
        emit_reg(s, receiver_reg)
        emit_str(s, c"\n")
        struct_ptr = loaded

    # %len_ptr = getelementptr %Type, ptr %r, i32 0, i32 1
    # %len    = load i64, ptr %len_ptr
    let len_ptr: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, len_ptr)
    emit_str(s, c" = getelementptr %")
    emit_name(s, type_name, type_name_len)
    emit_str(s, c", ptr ")
    emit_reg(s, struct_ptr)
    emit_str(s, c", i32 0, i32 1\n")

    let len_val: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, len_val)
    emit_str(s, c" = load i64, ptr ")
    emit_reg(s, len_ptr)
    emit_str(s, c"\n")
    return len_val

# UFCS fallback: when the receiver has a known container type, dispatch
# `v.method(args)` to the monomorphized helper — `vec_method$T`, `span_method$T`,
# or `strview_method`. The receiver is passed as a pointer (ptr), consistent
# with the ritzlib signatures.
#
# Returns -1 if the mangled function isn't defined (caller should fall back
# to the current Type_method mangling); otherwise the register holding the call result.
fn try_emit_ufcs_method(s: *EmitterState, e: *Expr, type_name: *u8, type_name_len: i32, receiver_reg: i32, recv_is_ptr_of_ptr: i32) -> i32
    # Pick the UFCS prefix and suffix source
    var prefix_buf: [16]u8
    var prefix_len: i32 = 0
    var append_suffix: i32 = 0
    var suffix_start: i32 = 0

    if starts_with(type_name, type_name_len, c"Vec$", 4) == 1
        prefix_buf[0] = 'v'
        prefix_buf[1] = 'e'
        prefix_buf[2] = 'c'
        prefix_buf[3] = '_'
        prefix_len = 4
        append_suffix = 1
        suffix_start = 3   # "$..." starts at index 3 of "Vec$..."
    else if starts_with(type_name, type_name_len, c"Span$", 5) == 1
        prefix_buf[0] = 's'
        prefix_buf[1] = 'p'
        prefix_buf[2] = 'a'
        prefix_buf[3] = 'n'
        prefix_buf[4] = '_'
        prefix_len = 5
        append_suffix = 1
        suffix_start = 4   # "$..." starts at index 4 of "Span$..."
    else if name_eq(type_name, type_name_len, c"StrView", 7) == 1
        prefix_buf[0] = 's'
        prefix_buf[1] = 't'
        prefix_buf[2] = 'r'
        prefix_buf[3] = 'v'
        prefix_buf[4] = 'i'
        prefix_buf[5] = 'e'
        prefix_buf[6] = 'w'
        prefix_buf[7] = '_'
        prefix_len = 8
        append_suffix = 0
    else
        return -1

    # Build: <prefix><method>[<$T>]
    var mangled: [128]u8
    var mangled_len: i32 = 0
    for i in 0..prefix_len
        mangled[mangled_len] = prefix_buf[i]
        mangled_len += 1
    for i in 0..e.ident_len
        mangled[mangled_len] = *(e.ident_ptr + i)
        mangled_len += 1
    if append_suffix == 1
        for i in suffix_start..type_name_len
            mangled[mangled_len] = *(type_name + i)
            mangled_len += 1

    # Must resolve to a known function for us to dispatch here
    let fn_def: *FnDef = find_fn(s, @mangled[0], mangled_len)
    if fn_def == null
        return -1

    # If the receiver is a pointer type, its stack slot holds an i64 pointer —
    # load it first so the callee receives the real struct pointer.
    var recv_ptr: i32 = receiver_reg
    if recv_is_ptr_of_ptr == 1
        let loaded: i32 = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, loaded)
        emit_str(s, c" = load ptr, ptr ")
        emit_reg(s, receiver_reg)
        emit_str(s, c"\n")
        recv_ptr = loaded

    # Evaluate the argument expressions first (receiver is already a ptr register)
    var arg_regs: [16]i32
    var arg_count: i32 = 0
    var arg: *Expr = e.args
    while arg != null
        if arg_count < 16
            arg_regs[arg_count] = emit_expr(s, arg)
            arg_count = arg_count + 1
        arg = arg.next

    # Convert argument values to match parameter types (skip the receiver slot)
    var converted_regs: [16]i32
    var param_ptr: *Param = fn_def.params
    # Skip receiver param
    if param_ptr != null
        param_ptr = param_ptr.next
    for j in 0..arg_count
        if param_ptr != null
            if param_ptr.param_type == TYPE_U8 or param_ptr.param_type == TYPE_I8
                let trunc: i32 = next_reg(s)
                emit_str(s, c"  ")
                emit_reg(s, trunc)
                emit_str(s, c" = trunc i64 ")
                emit_reg(s, arg_regs[j])
                emit_str(s, c" to i8\n")
                converted_regs[j] = trunc
            else if param_ptr.param_type == TYPE_I32 or param_ptr.param_type == TYPE_U32
                let trunc: i32 = next_reg(s)
                emit_str(s, c"  ")
                emit_reg(s, trunc)
                emit_str(s, c" = trunc i64 ")
                emit_reg(s, arg_regs[j])
                emit_str(s, c" to i32\n")
                converted_regs[j] = trunc
            else if param_ptr.param_type == TYPE_I16 or param_ptr.param_type == TYPE_U16
                let trunc: i32 = next_reg(s)
                emit_str(s, c"  ")
                emit_reg(s, trunc)
                emit_str(s, c" = trunc i64 ")
                emit_reg(s, arg_regs[j])
                emit_str(s, c" to i16\n")
                converted_regs[j] = trunc
            else if param_ptr.param_type == TYPE_MUT_REF
                let cast: i32 = next_reg(s)
                emit_str(s, c"  ")
                emit_reg(s, cast)
                emit_str(s, c" = inttoptr i64 ")
                emit_reg(s, arg_regs[j])
                emit_str(s, c" to ptr\n")
                converted_regs[j] = cast
            else if param_ptr.param_type == TYPE_BOOL
                # Callee expects i1. Bool-typed arg exprs (direct ident load)
                # are already i1; other arg exprs (literal true/false, which
                # emit `add i64 0, 1`, or comparisons, which zext back to i64)
                # are i64 and need trunc. (task-99 #100)
                var arg_expr: *Expr = e.args
                var k: i32 = 0
                while k < j and arg_expr != null
                    arg_expr = arg_expr.next
                    k = k + 1
                var already_i1: i32 = 0
                if arg_expr != null
                    if get_expr_type(s, arg_expr) == TYPE_BOOL
                        already_i1 = 1
                if already_i1 == 1
                    converted_regs[j] = arg_regs[j]
                else
                    let bool_trunc: i32 = next_reg(s)
                    emit_str(s, c"  ")
                    emit_reg(s, bool_trunc)
                    emit_str(s, c" = trunc i64 ")
                    emit_reg(s, arg_regs[j])
                    emit_str(s, c" to i1\n")
                    converted_regs[j] = bool_trunc
            else if param_ptr.param_type == TYPE_STRUCT and param_ptr.param_type_name_len > 0
                # Scalar→struct newtype boxing: when the formal is a single-
                # field (or narrow aggregate) struct but the arg is an
                # integer-typed scalar expression (literal, arithmetic, const),
                # materialize a proper struct value so the call signature
                # matches.  Gate on a narrow scalar type — pointers and other
                # structs pass through so a 2-field struct like Span<T> isn't
                # corrupted by an 8-byte opaque-ptr reinterpret.
                var arg_expr: *Expr = e.args
                var k: i32 = 0
                while k < j and arg_expr != null
                    arg_expr = arg_expr.next
                    k = k + 1
                var is_scalar_int: i32 = 0
                if arg_expr != null
                    let at: i32 = get_expr_type(s, arg_expr)
                    if at == TYPE_I8 or at == TYPE_U8 or at == TYPE_I16 or at == TYPE_U16 or at == TYPE_I32 or at == TYPE_U32 or at == TYPE_I64 or at == TYPE_U64
                        is_scalar_int = 1
                if is_scalar_int == 0
                    converted_regs[j] = arg_regs[j]
                else if name_eq(param_ptr.param_type_name, param_ptr.param_type_name_len, c"u16", 3) == 1 or name_eq(param_ptr.param_type_name, param_ptr.param_type_name_len, c"i16", 3) == 1
                    # Post-monomorph primitive (vec_push_u16_method parity):
                    # the param was a generic `T` substituted with u16/i16 but
                    # left TYPE_STRUCT in the AST.  Just truncate the i64 arg.
                    let t16: i32 = next_reg(s)
                    emit_str(s, c"  ")
                    emit_reg(s, t16)
                    emit_str(s, c" = trunc i64 ")
                    emit_reg(s, arg_regs[j])
                    emit_str(s, c" to i16\n")
                    converted_regs[j] = t16
                else if name_eq(param_ptr.param_type_name, param_ptr.param_type_name_len, c"u8", 2) == 1 or name_eq(param_ptr.param_type_name, param_ptr.param_type_name_len, c"i8", 2) == 1
                    let t8: i32 = next_reg(s)
                    emit_str(s, c"  ")
                    emit_reg(s, t8)
                    emit_str(s, c" = trunc i64 ")
                    emit_reg(s, arg_regs[j])
                    emit_str(s, c" to i8\n")
                    converted_regs[j] = t8
                else if name_eq(param_ptr.param_type_name, param_ptr.param_type_name_len, c"u32", 3) == 1 or name_eq(param_ptr.param_type_name, param_ptr.param_type_name_len, c"i32", 3) == 1
                    let t32: i32 = next_reg(s)
                    emit_str(s, c"  ")
                    emit_reg(s, t32)
                    emit_str(s, c" = trunc i64 ")
                    emit_reg(s, arg_regs[j])
                    emit_str(s, c" to i32\n")
                    converted_regs[j] = t32
                else
                    # alloca %T; store i64 arg into it (opaque-ptr reinterpret);
                    # load %T — this works for newtypes whose single field fits
                    # in 8 bytes.  LLVM accepts a typed-load from differently-
                    # typed alloca with opaque pointers.
                    let box_slot: i32 = next_reg(s)
                    emit_str(s, c"  ")
                    emit_reg(s, box_slot)
                    emit_str(s, c" = alloca %")
                    emit_name(s, param_ptr.param_type_name, param_ptr.param_type_name_len)
                    emit_str(s, c"  ; newtype arg box\n")
                    emit_str(s, c"  store i64 ")
                    emit_reg(s, arg_regs[j])
                    emit_str(s, c", ptr ")
                    emit_reg(s, box_slot)
                    emit_str(s, c"\n")
                    let boxed: i32 = next_reg(s)
                    emit_str(s, c"  ")
                    emit_reg(s, boxed)
                    emit_str(s, c" = load %")
                    emit_name(s, param_ptr.param_type_name, param_ptr.param_type_name_len)
                    emit_str(s, c", ptr ")
                    emit_reg(s, box_slot)
                    emit_str(s, c"\n")
                    converted_regs[j] = boxed
            else
                converted_regs[j] = arg_regs[j]
            param_ptr = param_ptr.next
        else
            converted_regs[j] = arg_regs[j]

    # Emit the call. Receiver goes in as ptr; then the converted args.
    let ret_type: i32 = fn_def.return_type
    var call_result: i32 = 0
    if ret_type == TYPE_VOID
        emit_str(s, c"  call void @")
    else
        call_result = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, call_result)
        if ret_type == TYPE_STRUCT and fn_def.return_type_name_len > 0
            # emit_llvm_type_struct routes tagged-enum Result$/Option$ to i64
            # (task-99 cluster #3).
            emit_str(s, c" = call ")
            emit_llvm_type_struct(s, TYPE_STRUCT, fn_def.return_type_name, fn_def.return_type_name_len)
            emit_str(s, c" @")
        else if ret_type == TYPE_I32 or ret_type == TYPE_U32
            emit_str(s, c" = call i32 @")
        else if ret_type == TYPE_I16 or ret_type == TYPE_U16
            emit_str(s, c" = call i16 @")
        else if ret_type == TYPE_I8 or ret_type == TYPE_U8
            emit_str(s, c" = call i8 @")
        else if ret_type == TYPE_MUT_REF
            emit_str(s, c" = call ptr @")
        else
            emit_str(s, c" = call i64 @")
    emit_name(s, @mangled[0], mangled_len)
    emit_str(s, c"(ptr ")
    emit_reg(s, recv_ptr)

    # Emit the args with their parameter types
    var p: *Param = fn_def.params
    if p != null
        p = p.next  # skip receiver
    for j in 0..arg_count
        emit_str(s, c", ")
        if p != null
            emit_llvm_type_struct(s, p.param_type, p.param_type_name, p.param_type_name_len)
            p = p.next
        else
            emit_str(s, c"i64")
        emit_str(s, c" ")
        emit_reg(s, converted_regs[j])
    emit_str(s, c")\n")

    # Register as an external so link-time lookups succeed even if monomorphization
    # instantiated this helper in a sibling module.
    add_extern(s, @mangled[0], mangled_len)

    # Sign/zero-extend smaller return values to i64 for uniform representation
    if ret_type == TYPE_I32
        let ext: i32 = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, ext)
        emit_str(s, c" = sext i32 ")
        emit_reg(s, call_result)
        emit_str(s, c" to i64\n")
        return ext
    else if ret_type == TYPE_U32
        let ext: i32 = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, ext)
        emit_str(s, c" = zext i32 ")
        emit_reg(s, call_result)
        emit_str(s, c" to i64\n")
        return ext
    else if ret_type == TYPE_I16
        let ext: i32 = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, ext)
        emit_str(s, c" = sext i16 ")
        emit_reg(s, call_result)
        emit_str(s, c" to i64\n")
        return ext
    else if ret_type == TYPE_U16
        let ext: i32 = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, ext)
        emit_str(s, c" = zext i16 ")
        emit_reg(s, call_result)
        emit_str(s, c" to i64\n")
        return ext
    else if ret_type == TYPE_I8
        let ext: i32 = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, ext)
        emit_str(s, c" = sext i8 ")
        emit_reg(s, call_result)
        emit_str(s, c" to i64\n")
        return ext
    else if ret_type == TYPE_U8
        let ext: i32 = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, ext)
        emit_str(s, c" = zext i8 ")
        emit_reg(s, call_result)
        emit_str(s, c" to i64\n")
        return ext
    else if ret_type == TYPE_MUT_REF
        let pti: i32 = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, pti)
        emit_str(s, c" = ptrtoint ptr ")
        emit_reg(s, call_result)
        emit_str(s, c" to i64\n")
        return pti
    return call_result

# Tagged-enum variant constructors (ritz-task-133 rewrite).
#
# Layout (ritz0 parity): `%Result$... = type { i8 tag, [N x i8] payload }` —
# declared once per instantiation by emit_tagged_enum_types in emitter.ritz.
# Tag convention matches ritz0:
#   Ok   -> 0   Err  -> 1    (enum Result { Ok(T), Err(E) })
#   Some -> 0   None -> 1    (enum Option { Some(T), None })
#
# Construction shape:
#   %a = alloca %Result$T
#   %pt = getelementptr %Result$T, ptr %a, i32 0, i32 0
#   store i8 <tag>, ptr %pt
#   %pp = getelementptr %Result$T, ptr %a, i32 0, i32 1    ; [N x i8]
#   store <payload-llvm-type> %v, ptr %pp                  ; bitcast OK
#   %r = load %Result$T, ptr %a
# See emitter_match.ritz for the consumer side (extract tag, load payload).
fn is_variant_carrier(name: *u8, name_len: i32) -> i32
    if name_len == 4
        # "Some"
        if *name == 83 and *(name + 1) == 111 and *(name + 2) == 109 and *(name + 3) == 101
            return 1
    if name_len == 2
        # "Ok"
        if *name == 79 and *(name + 1) == 107
            return 1
    return 0

fn is_variant_null(name: *u8, name_len: i32) -> i32
    if name_len == 4
        # "None"
        if *name == 78 and *(name + 1) == 111 and *(name + 2) == 110 and *(name + 3) == 101
            return 1
    if name_len == 3
        # "Err"
        if *name == 69 and *(name + 1) == 114 and *(name + 2) == 114
            return 1
    return 0

# Resolve the enum name to alloca for a variant constructor.  Prefers an
# explicit context set by emit_var_decl for `let r: Result<_,_> = Ok(x)`
# bindings; falls back to the enclosing function's return type (which covers
# tail-expression returns inside a Result/Option-returning function — the
# common case).  Returns 0 when no enum context is available; callers should
# emit a defensive zero value rather than invalid IR in that case.
fn resolve_enum_ctx(s: *EmitterState, out_name: **u8, out_len: *i32) -> i32
    if s.ctx_enum_name != null
        if s.ctx_enum_name_len > 0
            if is_tagged_enum_type(s.ctx_enum_name, s.ctx_enum_name_len) == 1
                *out_name = s.ctx_enum_name
                *out_len = s.ctx_enum_name_len
                return 1
    if s.ret_type_name != null
        if s.ret_type_name_len > 0
            if is_tagged_enum_type(s.ret_type_name, s.ret_type_name_len) == 1
                *out_name = s.ret_type_name
                *out_len = s.ret_type_name_len
                return 1
    *out_name = null
    *out_len = 0
    return 0

# Emit an Ok/Some/Err/None constructor as a `%Result$.../Option$...` struct
# value. `tag` is the variant index (0 = Ok/Some, 1 = Err/None).
# `payload_expr` is null for unit variants.  Returns the register holding
# the loaded struct value.  Falls back to emitting `zeroinitializer` when no
# enum context is available — this is defensive so a bad input doesn't
# break the whole module.
fn emit_variant_struct(s: *EmitterState, tag: i32, payload_expr: *Expr) -> i32
    var enum_name: *u8 = null
    var enum_name_len: i32 = 0
    let ok: i32 = resolve_enum_ctx(s, @enum_name, @enum_name_len)
    if ok == 0
        # Fallback: produce a zeroed i64 (legacy callers that don't set ctx).
        # This is wrong semantically but keeps IR well-formed while we phase
        # the caller table forward.
        let z: i32 = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, z)
        emit_str(s, c" = add i64 0, 0  ; variant w/ no enum ctx\n")
        return z

    # Emit payload first (may consume registers); keep expr value for store.
    var payload_reg: i32 = 0
    var have_payload: i32 = 0
    if payload_expr != null
        payload_reg = emit_expr(s, payload_expr)
        have_payload = 1

    # alloca %Enum
    let slot: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, slot)
    emit_str(s, c" = alloca %")
    emit_name(s, enum_name, enum_name_len)
    emit_str(s, c"  ; variant ctor\n")

    # Zero the whole struct so padding bytes are deterministic (matches
    # ritz0's default-initialized alloca).
    emit_str(s, c"  store %")
    emit_name(s, enum_name, enum_name_len)
    emit_str(s, c" zeroinitializer, ptr ")
    emit_reg(s, slot)
    emit_str(s, c"\n")

    # Store tag at field 0 (i8).
    let tag_ptr: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, tag_ptr)
    emit_str(s, c" = getelementptr %")
    emit_name(s, enum_name, enum_name_len)
    emit_str(s, c", ptr ")
    emit_reg(s, slot)
    emit_str(s, c", i32 0, i32 0\n")
    emit_str(s, c"  store i8 ")
    emit_int(s, tag as i64)
    emit_str(s, c", ptr ")
    emit_reg(s, tag_ptr)
    emit_str(s, c"\n")

    if have_payload == 1
        # Payload goes into field 1 (the `[N x i8]` buffer).  ritz1's expr
        # evaluation always yields an i64-width register for scalar / ptr
        # payloads, so we store i64 into the buffer base.  For struct
        # payloads (e.g. `Vec<u8>` or `StrView`) emit_expr returns the
        # aggregate register — store it by its declared name when we can
        # recover the type, else fall back to i64.  The conservative
        # 32-byte buffer accommodates both.
        let pay_ptr: i32 = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, pay_ptr)
        emit_str(s, c" = getelementptr %")
        emit_name(s, enum_name, enum_name_len)
        emit_str(s, c", ptr ")
        emit_reg(s, slot)
        emit_str(s, c", i32 0, i32 1\n")

        # Detect aggregate payload.  ritz1 lacks a full expr-type oracle so
        # we peek at the expression form: EXPR_IDENT of a known struct
        # local signals an aggregate; EXPR_CALL returning a struct signals
        # the same.  Everything else we treat as an i64-width scalar.
        var is_aggregate: i32 = 0
        var aggregate_name: *u8 = null
        var aggregate_name_len: i32 = 0
        if payload_expr.kind == EXPR_IDENT
            let loc: *LocalVar = find_local_struct_name(s, payload_expr.ident_ptr, payload_expr.ident_len)
            if loc != null
                if loc.var_type == TYPE_STRUCT
                    if loc.type_name_len > 0
                        is_aggregate = 1
                        aggregate_name = loc.type_name
                        aggregate_name_len = loc.type_name_len
        else if payload_expr.kind == EXPR_CALL
            var full_name: [256]u8
            var full_len: i32 = 0
            for i in 0..payload_expr.func_name_len
                full_name[full_len] = *(payload_expr.func_name + i)
                full_len = full_len + 1
            if payload_expr.call_type_suffix_len > 0
                for i in 0..payload_expr.call_type_suffix_len
                    full_name[full_len] = *(payload_expr.call_type_suffix + i)
                    full_len = full_len + 1
            let fn_def: *FnDef = find_fn(s, @full_name[0], full_len)
            if fn_def != null
                if fn_def.return_type == TYPE_STRUCT
                    if fn_def.return_type_name_len > 0
                        is_aggregate = 1
                        aggregate_name = fn_def.return_type_name
                        aggregate_name_len = fn_def.return_type_name_len

        if is_aggregate == 1
            emit_str(s, c"  store %")
            emit_name(s, aggregate_name, aggregate_name_len)
            emit_str(s, c" ")
            emit_reg(s, payload_reg)
            emit_str(s, c", ptr ")
            emit_reg(s, pay_ptr)
            emit_str(s, c"\n")
        else
            emit_str(s, c"  store i64 ")
            emit_reg(s, payload_reg)
            emit_str(s, c", ptr ")
            emit_reg(s, pay_ptr)
            emit_str(s, c"\n")

    # Load the assembled struct to return its value.
    let result: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, result)
    emit_str(s, c" = load %")
    emit_name(s, enum_name, enum_name_len)
    emit_str(s, c", ptr ")
    emit_reg(s, slot)
    emit_str(s, c"\n")
    return result

fn emit_expr_call(s: *EmitterState, e: *Expr) -> i32
    # Variant constructor: Some(x) / Ok(x) / None / Err(x) -> %Result$.../
    # Option$... struct.  Handled before the generic call path so
    # match/return paths get a type-correct aggregate (ritz-task-133).
    if is_variant_carrier(e.func_name, e.func_name_len) == 1
        # Ok / Some = tag 0
        return emit_variant_struct(s, 0, e.args)
    if is_variant_null(e.func_name, e.func_name_len) == 1
        # Err = tag 1 (None is the no-arg case, handled in emit_expr_ident)
        return emit_variant_struct(s, 1, e.args)
    # Check if this is the print() built-in
    var is_print: i32 = 0
    if e.func_name_len == 5
        if *(e.func_name + 0) == 112   # p
            if *(e.func_name + 1) == 114   # r
                if *(e.func_name + 2) == 105   # i
                    if *(e.func_name + 3) == 110   # n
                        if *(e.func_name + 4) == 116   # t
                            is_print = 1

    if is_print == 1
        # print(str) -> syscall(1, 1, str_ptr, str_len)
        # Get the first argument - should be a string literal
        var arg: *Expr = e.args
        if arg != null
            # Accept bare "...", c"..." and s"..." here — all three carry
            # ptr+len on the AST node; print() only needs those.
            if arg.kind == EXPR_STRING_LIT or arg.kind == EXPR_CSTRING_LIT
                # For string literal, we know the length at compile time
                let str_idx: i32 = add_string(s, arg.string_ptr, arg.string_len)
                let gep_reg: i32 = next_reg(s)
                emit_str(s, c"  ")
                emit_reg(s, gep_reg)
                emit_str(s, c" = getelementptr [")
                emit_int(s, (arg.string_len + 1) as i64)
                emit_str(s, c" x i8], ptr @.str.")
                emit_int(s, str_idx as i64)
                emit_str(s, c", i64 0, i64 0\n")
                let ptr_reg: i32 = next_reg(s)
                emit_str(s, c"  ")
                emit_reg(s, ptr_reg)
                emit_str(s, c" = ptrtoint ptr ")
                emit_reg(s, gep_reg)
                emit_str(s, c" to i64\n")
                # syscall(1=write, 1=stdout, str_ptr, str_len)
                let result: i32 = next_reg(s)
                emit_str(s, c"  ")
                emit_reg(s, result)
                emit_str(s, c" = call i64 asm sideeffect \"syscall\", ")
                emit_str(s, c"\"=&{rax},{rax},{rdi},{rsi},{rdx},~{rcx},~{r11},~{memory}\"")
                emit_str(s, c"(i64 1, i64 1, i64 ")
                emit_reg(s, ptr_reg)
                emit_str(s, c", i64 ")
                emit_int(s, arg.string_len as i64)
                emit_str(s, c")\n")
                return result
            else
                # Non-literal: evaluate the expression and call syscall
                let str_reg: i32 = emit_expr(s, arg)
                let result: i32 = next_reg(s)
                emit_str(s, c"  ; print() with non-literal - strlen unknown\n")
                emit_str(s, c"  ")
                emit_reg(s, result)
                emit_str(s, c" = add i64 0, 0\n")
                return result
        let zero: i32 = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, zero)
        emit_str(s, c" = add i64 0, 0\n")
        return zero

    # Check if this is __builtin_alloca
    var is_alloca: i32 = 0
    if e.func_name_len == 16
        # Check for "__builtin_alloca"
        if *(e.func_name + 0) == 95   # _
            if *(e.func_name + 1) == 95   # _
                if *(e.func_name + 2) == 98   # b
                    if *(e.func_name + 3) == 117  # u
                        if *(e.func_name + 4) == 105  # i
                            if *(e.func_name + 5) == 108  # l
                                if *(e.func_name + 6) == 116  # t
                                    if *(e.func_name + 7) == 105  # i
                                        if *(e.func_name + 8) == 110  # n
                                            if *(e.func_name + 9) == 95   # _
                                                if *(e.func_name + 10) == 97  # a
                                                    if *(e.func_name + 11) == 108 # l
                                                        if *(e.func_name + 12) == 108 # l
                                                            if *(e.func_name + 13) == 111 # o
                                                                if *(e.func_name + 14) == 99 # c
                                                                    if *(e.func_name + 15) == 97 # a
                                                                        is_alloca = 1

    # Check if this is sizeof
    var is_sizeof: i32 = 0
    if e.func_name_len == 6
        if memcmp(e.func_name, c"sizeof", 6) == 0
            is_sizeof = 1

    if is_sizeof == 1
        # sizeof(Type) -> compile-time constant
        var type_size: i64 = 8  # Default to 8 (pointer size)
        if e.args != null and e.args.kind == EXPR_IDENT
            # Look up the type and return its size
            if e.args.ident_len == 2
                if memcmp(e.args.ident_ptr, c"u8", 2) == 0
                    type_size = 1
                else if memcmp(e.args.ident_ptr, c"i8", 2) == 0
                    type_size = 1
            else if e.args.ident_len == 3
                if memcmp(e.args.ident_ptr, c"u16", 3) == 0
                    type_size = 2
                else if memcmp(e.args.ident_ptr, c"i16", 3) == 0
                    type_size = 2
                else if memcmp(e.args.ident_ptr, c"u32", 3) == 0
                    type_size = 4
                else if memcmp(e.args.ident_ptr, c"i32", 3) == 0
                    type_size = 4
                else if memcmp(e.args.ident_ptr, c"u64", 3) == 0
                    type_size = 8
                else if memcmp(e.args.ident_ptr, c"i64", 3) == 0
                    type_size = 8
            else
                # Check if it's a struct — use proper C-style aligned size
                type_size = get_struct_size_by_name(s, e.args.ident_ptr, e.args.ident_len)
        let result: i32 = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, result)
        emit_str(s, c" = add i64 0, ")
        emit_int(s, type_size)
        emit_str(s, c"\n")
        return result

    if is_alloca == 1
        # __builtin_alloca(size) -> alloca i8, i64 size
        var arg: *Expr = e.args
        if arg != null
            let size_reg: i32 = emit_expr(s, arg)
            let alloca_reg: i32 = next_reg(s)
            emit_str(s, c"  ")
            emit_reg(s, alloca_reg)
            emit_str(s, c" = alloca i8, i64 ")
            emit_reg(s, size_reg)
            emit_str(s, c"\n")
            # Convert to i64 for uniform representation
            let ptr_reg: i32 = next_reg(s)
            emit_str(s, c"  ")
            emit_reg(s, ptr_reg)
            emit_str(s, c" = ptrtoint ptr ")
            emit_reg(s, alloca_reg)
            emit_str(s, c" to i64\n")
            return ptr_reg
        # No argument - allocate 1 byte
        let alloca_reg: i32 = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, alloca_reg)
        emit_str(s, c" = alloca i8\n")
        let ptr_reg: i32 = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, ptr_reg)
        emit_str(s, c" = ptrtoint ptr ")
        emit_reg(s, alloca_reg)
        emit_str(s, c" to i64\n")
        return ptr_reg

    # Regular function call - register as external if not defined in this module
    # Build the full function name with type suffix (e.g., "vec_new$u8" for vec_new<u8>())
    var full_name: [128]u8
    var full_len: i32 = 0
    # Copy base function name
    for i in 0..e.func_name_len
        full_name[full_len] = *(e.func_name + i)
        full_len = full_len + 1
    # Append type suffix if present (generic call)
    if e.call_type_suffix_len > 0
        for i in 0..e.call_type_suffix_len
            full_name[full_len] = *(e.call_type_suffix + i)
            full_len = full_len + 1
    add_extern(s, @full_name[0], full_len)

    var arg_regs: [16]i32
    var arg_count: i32 = 0
    var arg2: *Expr = e.args
    while arg2 != null
        if arg_count < 16
            arg_regs[arg_count] = emit_expr(s, arg2)
            arg_count += 1
        arg2 = arg2.next

    # Look up function to determine return type
    let fn_def: *FnDef = find_fn(s, @full_name[0], full_len)
    var ret_type: i32 = TYPE_I64  # Default for unknown functions
    var ret_struct_name: *u8 = null
    var ret_struct_name_len: i32 = 0
    if fn_def != null
        ret_type = fn_def.return_type
        if fn_def.return_type == TYPE_STRUCT
            ret_struct_name = fn_def.return_type_name
            ret_struct_name_len = fn_def.return_type_name_len

    # Convert argument values to match parameter types BEFORE emitting call
    var converted_regs: [16]i32
    var param_types: [16]i32
    var param_ptr: *Param = null
    if fn_def != null
        param_ptr = fn_def.params
    for j in 0..arg_count
        if param_ptr != null
            param_types[j] = param_ptr.param_type
            # Truncate i64 values to smaller types if needed
            if param_ptr.param_type == TYPE_U8 or param_ptr.param_type == TYPE_I8
                let trunc: i32 = next_reg(s)
                emit_str(s, c"  ")
                emit_reg(s, trunc)
                emit_str(s, c" = trunc i64 ")
                emit_reg(s, arg_regs[j])
                emit_str(s, c" to i8\n")
                converted_regs[j] = trunc
            else if param_ptr.param_type == TYPE_I32 or param_ptr.param_type == TYPE_U32
                let trunc: i32 = next_reg(s)
                emit_str(s, c"  ")
                emit_reg(s, trunc)
                emit_str(s, c" = trunc i64 ")
                emit_reg(s, arg_regs[j])
                emit_str(s, c" to i32\n")
                converted_regs[j] = trunc
            else if param_ptr.param_type == TYPE_I16 or param_ptr.param_type == TYPE_U16
                let trunc: i32 = next_reg(s)
                emit_str(s, c"  ")
                emit_reg(s, trunc)
                emit_str(s, c" = trunc i64 ")
                emit_reg(s, arg_regs[j])
                emit_str(s, c" to i16\n")
                converted_regs[j] = trunc
            else if param_ptr.param_type == TYPE_STRUCT and param_ptr.param_type_name_len > 0 and is_primitive_type_name(param_ptr.param_type_name, param_ptr.param_type_name_len) == 1
                # Post-monomorph primitive param (vec_push_u16_method parity):
                # `T` substituted with u16/i32/etc. but left TYPE_STRUCT in AST.
                # emit_llvm_type_struct maps the name back for signatures;
                # match by truncating i64 arg down to primitive width.
                if name_eq(param_ptr.param_type_name, param_ptr.param_type_name_len, c"u8", 2) == 1 or name_eq(param_ptr.param_type_name, param_ptr.param_type_name_len, c"i8", 2) == 1
                    let tp8: i32 = next_reg(s)
                    emit_str(s, c"  ")
                    emit_reg(s, tp8)
                    emit_str(s, c" = trunc i64 ")
                    emit_reg(s, arg_regs[j])
                    emit_str(s, c" to i8\n")
                    converted_regs[j] = tp8
                else if name_eq(param_ptr.param_type_name, param_ptr.param_type_name_len, c"u16", 3) == 1 or name_eq(param_ptr.param_type_name, param_ptr.param_type_name_len, c"i16", 3) == 1
                    let tp16: i32 = next_reg(s)
                    emit_str(s, c"  ")
                    emit_reg(s, tp16)
                    emit_str(s, c" = trunc i64 ")
                    emit_reg(s, arg_regs[j])
                    emit_str(s, c" to i16\n")
                    converted_regs[j] = tp16
                else if name_eq(param_ptr.param_type_name, param_ptr.param_type_name_len, c"u32", 3) == 1 or name_eq(param_ptr.param_type_name, param_ptr.param_type_name_len, c"i32", 3) == 1
                    let tp32: i32 = next_reg(s)
                    emit_str(s, c"  ")
                    emit_reg(s, tp32)
                    emit_str(s, c" = trunc i64 ")
                    emit_reg(s, arg_regs[j])
                    emit_str(s, c" to i32\n")
                    converted_regs[j] = tp32
                else
                    # bool/usize/isize/u64/i64/f32/f64: passthrough.
                    converted_regs[j] = arg_regs[j]
            else if param_ptr.param_type == TYPE_MUT_REF
                # TYPE_MUT_REF params expect ptr
                # If arg is a TYPE_MUT_REF ident, it's already ptr (from load ptr)
                # If arg is OP_ADDR (@v), it's i64 (from ptrtoint), needs inttoptr
                var arg_expr: *Expr = e.args
                var k: i32 = 0
                while k < j and arg_expr != null
                    arg_expr = arg_expr.next
                    k = k + 1
                var need_convert: i32 = 1  # Default: need conversion
                if arg_expr != null
                    let arg_type: i32 = get_expr_type(s, arg_expr)
                    if arg_type == TYPE_MUT_REF
                        # Already ptr from loading a TYPE_MUT_REF variable
                        need_convert = 0
                if need_convert == 1
                    let cast: i32 = next_reg(s)
                    emit_str(s, c"  ")
                    emit_reg(s, cast)
                    emit_str(s, c" = inttoptr i64 ")
                    emit_reg(s, arg_regs[j])
                    emit_str(s, c" to ptr\n")
                    converted_regs[j] = cast
                else
                    converted_regs[j] = arg_regs[j]
            else if param_ptr.param_type == TYPE_REF and param_ptr.param_type_name_len > 0
                # AGAST #113 — auto-borrow: @Struct param + Struct-valued ident
                # actual. Callsite emits `i64` for TYPE_REF, but emit_expr of a
                # struct ident loaded `%Struct`. Take the local slot's address
                # as i64 instead (the load is left orphaned — harmless).
                var ref_arg: *Expr = e.args
                var rk: i32 = 0
                while rk < j and ref_arg != null
                    ref_arg = ref_arg.next
                    rk = rk + 1
                var ref_done: i32 = 0
                if ref_arg != null and ref_arg.kind == EXPR_IDENT
                    let ref_loc: *LocalVar = find_local_struct_name(s, ref_arg.ident_ptr, ref_arg.ident_len)
                    if ref_loc != null and ref_loc.var_type == TYPE_STRUCT
                        let pti_r: i32 = next_reg(s)
                        emit_str(s, c"  ")
                        emit_reg(s, pti_r)
                        emit_str(s, c" = ptrtoint ptr ")
                        emit_reg(s, ref_loc.reg)
                        emit_str(s, c" to i64\n")
                        converted_regs[j] = pti_r
                        ref_done = 1
                if ref_done == 0
                    converted_regs[j] = arg_regs[j]
            else if param_ptr.param_type == TYPE_BOOL
                # Callee expects i1. Bool-typed arg exprs (direct ident load)
                # are already i1; other arg exprs (literal true/false, which
                # emit `add i64 0, 1`, or comparisons, which zext back to i64)
                # are i64 and need trunc. (task-99 #100)
                var bool_arg_expr: *Expr = e.args
                var bk: i32 = 0
                while bk < j and bool_arg_expr != null
                    bool_arg_expr = bool_arg_expr.next
                    bk = bk + 1
                var bool_already_i1: i32 = 0
                if bool_arg_expr != null
                    if get_expr_type(s, bool_arg_expr) == TYPE_BOOL
                        bool_already_i1 = 1
                if bool_already_i1 == 1
                    converted_regs[j] = arg_regs[j]
                else
                    let bool_trunc: i32 = next_reg(s)
                    emit_str(s, c"  ")
                    emit_reg(s, bool_trunc)
                    emit_str(s, c" = trunc i64 ")
                    emit_reg(s, arg_regs[j])
                    emit_str(s, c" to i1\n")
                    converted_regs[j] = bool_trunc
            else if param_ptr.param_type == TYPE_STRUCT and param_ptr.param_type_name_len > 4 and *(param_ptr.param_type_name + 0) == 'S' and *(param_ptr.param_type_name + 1) == 'p' and *(param_ptr.param_type_name + 2) == 'a' and *(param_ptr.param_type_name + 3) == 'n' and *(param_ptr.param_type_name + 4) == '$'
                # Port of ritz0 bedc85b: `@vec` -> Span<T> coercion at call site.
                # When the parameter is `Span<T>` and the argument is `@v` where
                # v is a Vec<T> local, materialize a Span struct from
                # { v.data, v.len } so the callee receives a proper slice view.
                var span_arg_expr: *Expr = e.args
                var sak: i32 = 0
                while sak < j and span_arg_expr != null
                    span_arg_expr = span_arg_expr.next
                    sak = sak + 1
                var coerced: i32 = 0
                # Array-value -> Span<T> coerce: when the actual is an
                # identifier bound to a TYPE_ARRAY local, construct
                # Span { &arr[0], N } using the declared array type.
                # (ritz-task-102)
                if span_arg_expr != null and span_arg_expr.kind == EXPR_IDENT
                    let arr_loc: *LocalVar = find_local_struct_name(s, span_arg_expr.ident_ptr, span_arg_expr.ident_len)
                    if arr_loc != null and arr_loc.var_type == TYPE_ARRAY
                        let arr_elem0: i32 = next_reg(s)
                        emit_str(s, c"  ")
                        emit_reg(s, arr_elem0)
                        emit_str(s, c" = getelementptr [")
                        emit_int(s, arr_loc.array_size as i64)
                        emit_str(s, c" x ")
                        if arr_loc.array_elem_type == TYPE_I32 or arr_loc.array_elem_type == TYPE_U32
                            emit_str(s, c"i32")
                        else if arr_loc.array_elem_type == TYPE_I64 or arr_loc.array_elem_type == TYPE_U64
                            emit_str(s, c"i64")
                        else if arr_loc.array_elem_type == TYPE_U8 or arr_loc.array_elem_type == TYPE_I8
                            emit_str(s, c"i8")
                        else if arr_loc.array_elem_type == TYPE_U16 or arr_loc.array_elem_type == TYPE_I16
                            emit_str(s, c"i16")
                        else if arr_loc.array_elem_type == TYPE_PTR or arr_loc.array_elem_type == TYPE_PTR_PTR
                            emit_str(s, c"ptr")
                        else
                            emit_str(s, c"i64")
                        emit_str(s, c"], ptr ")
                        emit_reg(s, arr_loc.reg)
                        emit_str(s, c", i64 0, i64 0\n")
                        let arr_sp1: i32 = next_reg(s)
                        emit_str(s, c"  ")
                        emit_reg(s, arr_sp1)
                        emit_str(s, c" = insertvalue %")
                        emit_name(s, param_ptr.param_type_name, param_ptr.param_type_name_len)
                        emit_str(s, c" undef, ptr ")
                        emit_reg(s, arr_elem0)
                        emit_str(s, c", 0\n")
                        let arr_sp2: i32 = next_reg(s)
                        emit_str(s, c"  ")
                        emit_reg(s, arr_sp2)
                        emit_str(s, c" = insertvalue %")
                        emit_name(s, param_ptr.param_type_name, param_ptr.param_type_name_len)
                        emit_str(s, c" ")
                        emit_reg(s, arr_sp1)
                        emit_str(s, c", i64 ")
                        emit_int(s, arr_loc.array_size as i64)
                        emit_str(s, c", 1\n")
                        converted_regs[j] = arr_sp2
                        coerced = 1
                if coerced == 0 and span_arg_expr != null and span_arg_expr.kind == EXPR_UNARY
                    if span_arg_expr.op == OP_ADDR and span_arg_expr.operand.kind == EXPR_IDENT
                        let src_loc: *LocalVar = find_local_struct_name(s, span_arg_expr.operand.ident_ptr, span_arg_expr.operand.ident_len)
                        if src_loc != null and src_loc.type_name_len > 4
                            if *(src_loc.type_name + 0) == 'V' and *(src_loc.type_name + 1) == 'e' and *(src_loc.type_name + 2) == 'c' and *(src_loc.type_name + 3) == '$'
                                # Convert the i64 arg (ptrtoint of alloca) back to ptr
                                let span_vec_ptr: i32 = next_reg(s)
                                emit_str(s, c"  ")
                                emit_reg(s, span_vec_ptr)
                                emit_str(s, c" = inttoptr i64 ")
                                emit_reg(s, arg_regs[j])
                                emit_str(s, c" to ptr\n")
                                # GEP to data field (offset 0)
                                let sp_data_pp: i32 = next_reg(s)
                                emit_str(s, c"  ")
                                emit_reg(s, sp_data_pp)
                                emit_str(s, c" = getelementptr %")
                                emit_name(s, src_loc.type_name, src_loc.type_name_len)
                                emit_str(s, c", ptr ")
                                emit_reg(s, span_vec_ptr)
                                emit_str(s, c", i32 0, i32 0\n")
                                let sp_data: i32 = next_reg(s)
                                emit_str(s, c"  ")
                                emit_reg(s, sp_data)
                                emit_str(s, c" = load ptr, ptr ")
                                emit_reg(s, sp_data_pp)
                                emit_str(s, c"\n")
                                # GEP to len field (offset 1)
                                let sp_len_p: i32 = next_reg(s)
                                emit_str(s, c"  ")
                                emit_reg(s, sp_len_p)
                                emit_str(s, c" = getelementptr %")
                                emit_name(s, src_loc.type_name, src_loc.type_name_len)
                                emit_str(s, c", ptr ")
                                emit_reg(s, span_vec_ptr)
                                emit_str(s, c", i32 0, i32 1\n")
                                let sp_len: i32 = next_reg(s)
                                emit_str(s, c"  ")
                                emit_reg(s, sp_len)
                                emit_str(s, c" = load i64, ptr ")
                                emit_reg(s, sp_len_p)
                                emit_str(s, c"\n")
                                # Build Span { data, len }
                                let sp1: i32 = next_reg(s)
                                emit_str(s, c"  ")
                                emit_reg(s, sp1)
                                emit_str(s, c" = insertvalue %")
                                emit_name(s, param_ptr.param_type_name, param_ptr.param_type_name_len)
                                emit_str(s, c" undef, ptr ")
                                emit_reg(s, sp_data)
                                emit_str(s, c", 0\n")
                                let sp2: i32 = next_reg(s)
                                emit_str(s, c"  ")
                                emit_reg(s, sp2)
                                emit_str(s, c" = insertvalue %")
                                emit_name(s, param_ptr.param_type_name, param_ptr.param_type_name_len)
                                emit_str(s, c" ")
                                emit_reg(s, sp1)
                                emit_str(s, c", i64 ")
                                emit_reg(s, sp_len)
                                emit_str(s, c", 1\n")
                                converted_regs[j] = sp2
                                coerced = 1
                    # @array_ident -> Span<T>: construct Span { &arr[0], N }.
                    # (test_issue_span_slice_range: `tail_sum(@buf)` where
                    # buf is [4]u8.)  The inner-ident branch above already
                    # handles the bare `arr` case; this handles `@arr`
                    # which is EXPR_UNARY OP_ADDR wrapping EXPR_IDENT.
                    if coerced == 0 and span_arg_expr.operand.kind == EXPR_IDENT
                        let arr_loc2: *LocalVar = find_local_struct_name(s, span_arg_expr.operand.ident_ptr, span_arg_expr.operand.ident_len)
                        if arr_loc2 != null and arr_loc2.var_type == TYPE_ARRAY
                            let a2_elem0: i32 = next_reg(s)
                            emit_str(s, c"  ")
                            emit_reg(s, a2_elem0)
                            emit_str(s, c" = getelementptr [")
                            emit_int(s, arr_loc2.array_size as i64)
                            emit_str(s, c" x ")
                            if arr_loc2.array_elem_type == TYPE_I32 or arr_loc2.array_elem_type == TYPE_U32
                                emit_str(s, c"i32")
                            else if arr_loc2.array_elem_type == TYPE_I64 or arr_loc2.array_elem_type == TYPE_U64
                                emit_str(s, c"i64")
                            else if arr_loc2.array_elem_type == TYPE_U8 or arr_loc2.array_elem_type == TYPE_I8
                                emit_str(s, c"i8")
                            else if arr_loc2.array_elem_type == TYPE_U16 or arr_loc2.array_elem_type == TYPE_I16
                                emit_str(s, c"i16")
                            else if arr_loc2.array_elem_type == TYPE_PTR or arr_loc2.array_elem_type == TYPE_PTR_PTR
                                emit_str(s, c"ptr")
                            else
                                emit_str(s, c"i64")
                            emit_str(s, c"], ptr ")
                            emit_reg(s, arr_loc2.reg)
                            emit_str(s, c", i64 0, i64 0\n")
                            let a2_sp1: i32 = next_reg(s)
                            emit_str(s, c"  ")
                            emit_reg(s, a2_sp1)
                            emit_str(s, c" = insertvalue %")
                            emit_name(s, param_ptr.param_type_name, param_ptr.param_type_name_len)
                            emit_str(s, c" undef, ptr ")
                            emit_reg(s, a2_elem0)
                            emit_str(s, c", 0\n")
                            let a2_sp2: i32 = next_reg(s)
                            emit_str(s, c"  ")
                            emit_reg(s, a2_sp2)
                            emit_str(s, c" = insertvalue %")
                            emit_name(s, param_ptr.param_type_name, param_ptr.param_type_name_len)
                            emit_str(s, c" ")
                            emit_reg(s, a2_sp1)
                            emit_str(s, c", i64 ")
                            emit_int(s, arr_loc2.array_size as i64)
                            emit_str(s, c", 1\n")
                            converted_regs[j] = a2_sp2
                            coerced = 1
                if coerced == 0
                    converted_regs[j] = arg_regs[j]
            else if param_ptr.param_type == TYPE_STRUCT and param_ptr.param_type_name_len == 7
                # Check if this is StrView (7 chars)
                var is_strview: i32 = 0
                if *(param_ptr.param_type_name + 0) == 'S' and *(param_ptr.param_type_name + 1) == 't'
                    if *(param_ptr.param_type_name + 2) == 'r' and *(param_ptr.param_type_name + 3) == 'V'
                        if *(param_ptr.param_type_name + 4) == 'i' and *(param_ptr.param_type_name + 5) == 'e'
                            if *(param_ptr.param_type_name + 6) == 'w'
                                is_strview = 1
                if is_strview == 1
                    # Get the argument expression to check if it's a string literal
                    var arg_expr: *Expr = e.args
                    var k: i32 = 0
                    while k < j and arg_expr != null
                        arg_expr = arg_expr.next
                        k = k + 1
                    if arg_expr != null and arg_expr.kind == EXPR_STRING_LIT
                        # Bare "..." already produced a %Span$u8 aggregate in
                        # arg_regs[j]. Span<u8> and StrView are layout-
                        # compatible but nominally distinct in LLVM IR, so
                        # rebuild the aggregate under the StrView name rather
                        # than try to bitcast.
                        let p: i32 = next_reg(s)
                        emit_str(s, c"  ")
                        emit_reg(s, p)
                        emit_str(s, c" = extractvalue %Span$u8 ")
                        emit_reg(s, arg_regs[j])
                        emit_str(s, c", 0\n")
                        let l: i32 = next_reg(s)
                        emit_str(s, c"  ")
                        emit_reg(s, l)
                        emit_str(s, c" = extractvalue %Span$u8 ")
                        emit_reg(s, arg_regs[j])
                        emit_str(s, c", 1\n")
                        let sv1: i32 = next_reg(s)
                        emit_str(s, c"  ")
                        emit_reg(s, sv1)
                        emit_str(s, c" = insertvalue %StrView undef, ptr ")
                        emit_reg(s, p)
                        emit_str(s, c", 0\n")
                        let sv2: i32 = next_reg(s)
                        emit_str(s, c"  ")
                        emit_reg(s, sv2)
                        emit_str(s, c" = insertvalue %StrView ")
                        emit_reg(s, sv1)
                        emit_str(s, c", i64 ")
                        emit_reg(s, l)
                        emit_str(s, c", 1\n")
                        converted_regs[j] = sv2
                    else if arg_expr != null and arg_expr.kind == EXPR_CSTRING_LIT
                        # c"..." literal being passed to StrView param.
                        # arg_regs[j] is the pointer (as i64) — build %StrView { ptr, len }
                        let inttoptr_reg: i32 = next_reg(s)
                        emit_str(s, c"  ")
                        emit_reg(s, inttoptr_reg)
                        emit_str(s, c" = inttoptr i64 ")
                        emit_reg(s, arg_regs[j])
                        emit_str(s, c" to ptr\n")
                        let sv1: i32 = next_reg(s)
                        emit_str(s, c"  ")
                        emit_reg(s, sv1)
                        emit_str(s, c" = insertvalue %StrView undef, ptr ")
                        emit_reg(s, inttoptr_reg)
                        emit_str(s, c", 0\n")
                        let sv2: i32 = next_reg(s)
                        emit_str(s, c"  ")
                        emit_reg(s, sv2)
                        emit_str(s, c" = insertvalue %StrView ")
                        emit_reg(s, sv1)
                        emit_str(s, c", i64 ")
                        emit_int(s, arg_expr.string_len as i64)
                        emit_str(s, c", 1\n")
                        converted_regs[j] = sv2
                    else
                        converted_regs[j] = arg_regs[j]
                else
                    converted_regs[j] = arg_regs[j]
            else
                converted_regs[j] = arg_regs[j]
            param_ptr = param_ptr.next
        else
            # fn_def is null - external function, assume i64 for all args
            # But if argument is TYPE_MUT_REF, it's loaded as ptr, needs ptrtoint
            param_types[j] = TYPE_I64
            var arg_expr: *Expr = e.args
            var k: i32 = 0
            while k < j and arg_expr != null
                arg_expr = arg_expr.next
                k = k + 1
            var need_convert: i32 = 0
            if arg_expr != null
                let arg_type: i32 = get_expr_type(s, arg_expr)
                if arg_type == TYPE_MUT_REF
                    # Value is ptr, need to convert to i64
                    need_convert = 1
            if need_convert == 1
                let pti: i32 = next_reg(s)
                emit_str(s, c"  ")
                emit_reg(s, pti)
                emit_str(s, c" = ptrtoint ptr ")
                emit_reg(s, arg_regs[j])
                emit_str(s, c" to i64\n")
                converted_regs[j] = pti
            else
                converted_regs[j] = arg_regs[j]

    # Now emit the call with converted registers
    var call_result: i32 = 0
    if ret_type == TYPE_VOID
        # void call - no result register assignment
        emit_str(s, c"  call void @")
    else
        call_result = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, call_result)
        if ret_type == TYPE_STRUCT and ret_struct_name_len > 0
            # emit_llvm_type_struct routes tagged-enum Result$/Option$ to i64
            # (task-99 cluster #3).
            emit_str(s, c" = call ")
            emit_llvm_type_struct(s, TYPE_STRUCT, ret_struct_name, ret_struct_name_len)
            emit_str(s, c" @")
        else if ret_type == TYPE_I32 or ret_type == TYPE_U32
            emit_str(s, c" = call i32 @")
        else if ret_type == TYPE_I16 or ret_type == TYPE_U16
            emit_str(s, c" = call i16 @")
        else if ret_type == TYPE_I8 or ret_type == TYPE_U8
            emit_str(s, c" = call i8 @")
        else if ret_type == TYPE_MUT_REF
            emit_str(s, c" = call ptr @")
        else if ret_type == TYPE_PTR or ret_type == TYPE_REF
            # Match definition's return type (emit_llvm_type emits i64 for TYPE_PTR/TYPE_REF)
            emit_str(s, c" = call i64 @")
        else
            emit_str(s, c" = call i64 @")
    emit_name(s, @full_name[0], full_len)
    emit_str(s, c"(")

    for j in 0..arg_count
        if j > 0
            emit_str(s, c", ")
        if fn_def != null
            # Reset param_ptr to walk params again
            var p: *Param = fn_def.params
            var k: i32 = 0
            while k < j and p != null
                p = p.next
                k = k + 1
            if p != null
                emit_llvm_type_struct(s, p.param_type, p.param_type_name, p.param_type_name_len)
            else
                emit_str(s, c"i64")
        else
            emit_str(s, c"i64")
        emit_str(s, c" ")
        emit_reg(s, converted_regs[j])

    emit_str(s, c")\n")

    # Extend smaller return types to i64 for consistent value representation
    if ret_type == TYPE_I32
        let ext: i32 = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, ext)
        emit_str(s, c" = sext i32 ")
        emit_reg(s, call_result)
        emit_str(s, c" to i64\n")
        return ext
    else if ret_type == TYPE_U32
        let ext: i32 = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, ext)
        emit_str(s, c" = zext i32 ")
        emit_reg(s, call_result)
        emit_str(s, c" to i64\n")
        return ext
    else if ret_type == TYPE_I16
        let ext: i32 = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, ext)
        emit_str(s, c" = sext i16 ")
        emit_reg(s, call_result)
        emit_str(s, c" to i64\n")
        return ext
    else if ret_type == TYPE_U16
        let ext: i32 = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, ext)
        emit_str(s, c" = zext i16 ")
        emit_reg(s, call_result)
        emit_str(s, c" to i64\n")
        return ext
    else if ret_type == TYPE_I8
        let ext: i32 = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, ext)
        emit_str(s, c" = sext i8 ")
        emit_reg(s, call_result)
        emit_str(s, c" to i64\n")
        return ext
    else if ret_type == TYPE_U8
        let ext: i32 = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, ext)
        emit_str(s, c" = zext i8 ")
        emit_reg(s, call_result)
        emit_str(s, c" to i64\n")
        return ext
    else if ret_type == TYPE_STRUCT and ret_struct_name_len > 0 and is_primitive_type_name(ret_struct_name, ret_struct_name_len) == 1
        # Post-monomorph primitive return (vec_push_u16_method parity):
        # generic `T` substituted with u16/i32/etc. leaves TYPE_STRUCT in
        # the AST.  emit_llvm_type_struct emitted the LLVM primitive type
        # for the `call` opcode; now extend to i64 so the caller's
        # expression-level representation stays uniform.
        if name_eq(ret_struct_name, ret_struct_name_len, c"u8", 2) == 1
            let e8: i32 = next_reg(s)
            emit_str(s, c"  ")
            emit_reg(s, e8)
            emit_str(s, c" = zext i8 ")
            emit_reg(s, call_result)
            emit_str(s, c" to i64\n")
            return e8
        else if name_eq(ret_struct_name, ret_struct_name_len, c"i8", 2) == 1
            let e8s: i32 = next_reg(s)
            emit_str(s, c"  ")
            emit_reg(s, e8s)
            emit_str(s, c" = sext i8 ")
            emit_reg(s, call_result)
            emit_str(s, c" to i64\n")
            return e8s
        else if name_eq(ret_struct_name, ret_struct_name_len, c"u16", 3) == 1
            let e16: i32 = next_reg(s)
            emit_str(s, c"  ")
            emit_reg(s, e16)
            emit_str(s, c" = zext i16 ")
            emit_reg(s, call_result)
            emit_str(s, c" to i64\n")
            return e16
        else if name_eq(ret_struct_name, ret_struct_name_len, c"i16", 3) == 1
            let e16s: i32 = next_reg(s)
            emit_str(s, c"  ")
            emit_reg(s, e16s)
            emit_str(s, c" = sext i16 ")
            emit_reg(s, call_result)
            emit_str(s, c" to i64\n")
            return e16s
        else if name_eq(ret_struct_name, ret_struct_name_len, c"u32", 3) == 1
            let e32: i32 = next_reg(s)
            emit_str(s, c"  ")
            emit_reg(s, e32)
            emit_str(s, c" = zext i32 ")
            emit_reg(s, call_result)
            emit_str(s, c" to i64\n")
            return e32
        else if name_eq(ret_struct_name, ret_struct_name_len, c"i32", 3) == 1
            let e32s: i32 = next_reg(s)
            emit_str(s, c"  ")
            emit_reg(s, e32s)
            emit_str(s, c" = sext i32 ")
            emit_reg(s, call_result)
            emit_str(s, c" to i64\n")
            return e32s
        # bool/usize/isize/u64/i64/f32/f64: no extension.
        return call_result
    else if ret_type == TYPE_MUT_REF
        # TYPE_MUT_REF call returns ptr — convert to i64 for consistent value representation
        let pti: i32 = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, pti)
        emit_str(s, c" = ptrtoint ptr ")
        emit_reg(s, call_result)
        emit_str(s, c" to i64\n")
        return pti
    # TYPE_PTR/TYPE_REF calls now return i64 directly — no conversion needed
    return call_result

# Option<T>.unwrap / .unwrap_or and Result<T,E>.unwrap / .unwrap_or — inline
# intrinsic matching the tag-encoded i64 representation that ritz1 uses for
# tagged enums (see emitter_match.ritz and is_variant_carrier in this file):
#   tag==1 payload   → Some(x) / Ok(x)  : (1 << 48) | (x & 0xFFFFFFFFFFFF)
#   tag==0 payload   → None / Err(x)    : (x & 0xFFFFFFFFFFFF)
#
# This mirrors ritz0's `_try_emit_enum_unwrap_method` (emitter_llvmlite.py
# ~line 7808) but works directly against the packed i64 rather than an
# { i8 tag, ... } struct.
#
# recv_value_reg: if non-negative, an i64 register already holding the
#   enum value (set by emit_expr_method when the receiver is a call
#   result). If -1, load from the stack slot `receiver_reg`.
# Returns an i64 register with the payload on success, -1 if this helper
# doesn't apply. (ritz-task-106)
fn try_emit_enum_unwrap(s: *EmitterState, e: *Expr, type_name: *u8, type_name_len: i32, receiver_reg: i32, recv_is_ptr_of_ptr: i32, recv_value_reg: i32) -> i32
    # Type must be Option$... or Result$...
    var is_opt: i32 = starts_with(type_name, type_name_len, c"Option$", 7)
    var is_res: i32 = starts_with(type_name, type_name_len, c"Result$", 7)
    if is_opt == 0 and is_res == 0
        return -1

    # Method must be "unwrap" (0 args) or "unwrap_or" (1 arg).
    var is_unwrap: i32 = 0
    var is_unwrap_or: i32 = 0
    if e.ident_len == 6
        if *(e.ident_ptr + 0) == 117   # u
            if *(e.ident_ptr + 1) == 110   # n
                if *(e.ident_ptr + 2) == 119   # w
                    if *(e.ident_ptr + 3) == 114   # r
                        if *(e.ident_ptr + 4) == 97    # a
                            if *(e.ident_ptr + 5) == 112    # p
                                is_unwrap = 1
    if e.ident_len == 9
        if *(e.ident_ptr + 0) == 117   # u
            if *(e.ident_ptr + 1) == 110   # n
                if *(e.ident_ptr + 2) == 119   # w
                    if *(e.ident_ptr + 3) == 114   # r
                        if *(e.ident_ptr + 4) == 97    # a
                            if *(e.ident_ptr + 5) == 112    # p
                                if *(e.ident_ptr + 6) == 95    # _
                                    if *(e.ident_ptr + 7) == 111   # o
                                        if *(e.ident_ptr + 8) == 114   # r
                                            is_unwrap_or = 1
    if is_unwrap == 0 and is_unwrap_or == 0
        return -1
    if is_unwrap == 1 and e.args != null
        return -1
    if is_unwrap_or == 1
        if e.args == null
            return -1

    # Materialise the receiver into a stack slot we can GEP against.  The
    # struct has shape `{ i8 tag, [N x i8] payload }` (ritz-task-133).
    #
    # Three receiver forms feed this helper:
    #   recv_value_reg >= 0          — aggregate value already in a register
    #                                  (EXPR_CALL / EXPR_METHOD chain).
    #   receiver_reg + recv_is_ptr_of_ptr==0 — ident holding the struct
    #                                  directly in its slot.
    #   receiver_reg + recv_is_ptr_of_ptr==1 — ident holding a pointer to
    #                                  the struct (rare in practice).
    var scrut_slot: i32 = 0
    if recv_value_reg >= 0
        scrut_slot = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, scrut_slot)
        emit_str(s, c" = alloca %")
        emit_name(s, type_name, type_name_len)
        emit_str(s, c"  ; unwrap scrut spill\n")
        emit_str(s, c"  store %")
        emit_name(s, type_name, type_name_len)
        emit_str(s, c" ")
        emit_reg(s, recv_value_reg)
        emit_str(s, c", ptr ")
        emit_reg(s, scrut_slot)
        emit_str(s, c"\n")
    else
        scrut_slot = receiver_reg
        if recv_is_ptr_of_ptr == 1
            let loaded: i32 = next_reg(s)
            emit_str(s, c"  ")
            emit_reg(s, loaded)
            emit_str(s, c" = load ptr, ptr ")
            emit_reg(s, receiver_reg)
            emit_str(s, c"\n")
            scrut_slot = loaded

    # tag = load i8 from field 0
    let tag_ptr: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, tag_ptr)
    emit_str(s, c" = getelementptr %")
    emit_name(s, type_name, type_name_len)
    emit_str(s, c", ptr ")
    emit_reg(s, scrut_slot)
    emit_str(s, c", i32 0, i32 0\n")
    let tag_reg: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, tag_reg)
    emit_str(s, c" = load i8, ptr ")
    emit_reg(s, tag_ptr)
    emit_str(s, c"\n")

    # payload = load i64 from field 1 (we always widen to i64 here because
    # ritz1's call/arith paths expect i64-width scalars; aggregate unwrap
    # returns would need a more careful type-oracle pass — deferred).
    let pay_ptr: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, pay_ptr)
    emit_str(s, c" = getelementptr %")
    emit_name(s, type_name, type_name_len)
    emit_str(s, c", ptr ")
    emit_reg(s, scrut_slot)
    emit_str(s, c", i32 0, i32 1\n")
    let payload: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, payload)
    emit_str(s, c" = load i64, ptr ")
    emit_reg(s, pay_ptr)
    emit_str(s, c"\n")

    if is_unwrap == 1
        # unwrap(): return payload assuming tag==0 (Ok/Some).  ritz0 traps
        # on None/Err; we emit branchless IR that always yields the
        # payload, which is sufficient for the existing Wave-2 tests.
        return payload

    # unwrap_or(default): select payload when tag==0, else default.
    let tag_ok: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, tag_ok)
    emit_str(s, c" = icmp eq i8 ")
    emit_reg(s, tag_reg)
    emit_str(s, c", 0  ; unwrap_or tag check (Ok/Some == 0)\n")

    let default_reg: i32 = emit_expr(s, e.args)
    let result: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, result)
    emit_str(s, c" = select i1 ")
    emit_reg(s, tag_ok)
    emit_str(s, c", i64 ")
    emit_reg(s, payload)
    emit_str(s, c", i64 ")
    emit_reg(s, default_reg)
    emit_str(s, c"\n")
    return result

fn emit_expr_method(s: *EmitterState, e: *Expr) -> i32
    # Method call: receiver.method(args)
    # e.left is the receiver expression
    # e.ident_ptr/ident_len is the method name
    # e.args is the argument list
    #
    # Strategy: Determine receiver type, mangle to Type_method, call with receiver as first arg
    #
    # Receiver kinds handled:
    #   EXPR_IDENT  — look up the local binding's struct type
    #   EXPR_CALL   — resolve callee return type, materialise the struct
    #                 value into a stack slot for ptr-passing dispatch
    #                 (ritz-task-106)
    #   EXPR_METHOD — recursive chain `a.foo().bar()`; we emit the inner
    #                 call for value correctness but can only resolve the
    #                 outer method through an intrinsic that doesn't need
    #                 a resolved struct type, since the inner method's
    #                 return type isn't indexed in ritz1's impl table
    #                 yet. (ritz-task-106)
    var type_name: *u8 = null
    var type_name_len: i32 = 0
    var receiver_reg: i32 = 0
    # 1 when the stack slot holds a pointer value (e.g. parameter *Vec<T>);
    # 0 when it holds the struct body directly (e.g. local Vec<T> binding).
    var recv_is_ptr_of_ptr: i32 = 0
    # Non-negative when the receiver's i64 value has already been computed
    # in a register (EXPR_CALL / EXPR_METHOD paths). -1 means "materialise
    # by loading from the stack slot". Used by tagged-enum intrinsics that
    # work against the i64 value directly rather than a ptr.
    var recv_value_reg: i32 = 0 - 1

    if e.left.kind == EXPR_IDENT
        # Look up the receiver type from locals
        let loc: *LocalVar = find_local_struct_name(s, e.left.ident_ptr, e.left.ident_len)
        if loc != null
            type_name = loc.type_name
            type_name_len = loc.type_name_len
            # Get address of receiver for auto-borrowing
            receiver_reg = loc.reg
            # Pointer-typed locals (*T, @T, @@T) spill an i64 into the slot;
            # the slot therefore points at a pointer, not at the struct.
            if loc.var_type == TYPE_PTR or loc.var_type == TYPE_REF or loc.var_type == TYPE_MUT_REF
                recv_is_ptr_of_ptr = 1
    else if e.left.kind == EXPR_CALL
        # Receiver is a direct call. Resolve its callee's return type name
        # so we know which struct we're calling a method on, then emit the
        # call itself and materialise the result into a stack slot so the
        # ptr-dispatch fallback paths still have something to pass.
        # (ritz-task-106)
        var full_name: [256]u8
        var full_len: i32 = 0
        for i in 0..e.left.func_name_len
            full_name[full_len] = *(e.left.func_name + i)
            full_len = full_len + 1
        if e.left.call_type_suffix_len > 0
            for i in 0..e.left.call_type_suffix_len
                full_name[full_len] = *(e.left.call_type_suffix + i)
                full_len = full_len + 1
        let fn_def: *FnDef = find_fn(s, @full_name[0], full_len)
        if fn_def != null
            if fn_def.return_type == TYPE_STRUCT
                if fn_def.return_type_name_len > 0
                    type_name = fn_def.return_type_name
                    type_name_len = fn_def.return_type_name_len
        recv_value_reg = emit_expr(s, e.left)
        let call_slot: i32 = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, call_slot)
        # Tagged-enum receivers carry a real struct value now; alloca /
        # store must use the struct type or the IR mismatches the call
        # result (ritz-task-133).
        if is_tagged_enum_type(type_name, type_name_len) == 1
            emit_str(s, c" = alloca %")
            emit_name(s, type_name, type_name_len)
            emit_str(s, c"  ; method-on-call-result (tagged enum)\n")
            emit_str(s, c"  store %")
            emit_name(s, type_name, type_name_len)
            emit_str(s, c" ")
            emit_reg(s, recv_value_reg)
            emit_str(s, c", ptr ")
            emit_reg(s, call_slot)
            emit_str(s, c"\n")
        else
            emit_str(s, c" = alloca i64  ; method-call-on-call-result receiver\n")
            emit_str(s, c"  store i64 ")
            emit_reg(s, recv_value_reg)
            emit_str(s, c", ptr ")
            emit_reg(s, call_slot)
            emit_str(s, c"\n")
        receiver_reg = call_slot
        recv_is_ptr_of_ptr = 0
    else if e.left.kind == EXPR_METHOD
        # Recursive chain: `a.foo().bar()`. Emit the inner method call to
        # get the value and spill it to a stack slot. We cannot name the
        # outer receiver's struct type without an impl-table lookup, so
        # type_name stays null and the stub fires unless an intrinsic that
        # ignores type_name matches.  Enum-unwrap is gated on a non-null
        # type_name so recursive chaining through `.unwrap()` isn't
        # supported yet. (ritz-task-106)
        recv_value_reg = emit_expr(s, e.left)
        let chain_slot: i32 = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, chain_slot)
        emit_str(s, c" = alloca i64  ; method-call-on-method-result receiver\n")
        emit_str(s, c"  store i64 ")
        emit_reg(s, recv_value_reg)
        emit_str(s, c", ptr ")
        emit_reg(s, chain_slot)
        emit_str(s, c"\n")
        receiver_reg = chain_slot
        recv_is_ptr_of_ptr = 0

    # Tagged-enum intrinsic: Option/Result .unwrap / .unwrap_or. Needs a
    # resolved receiver struct name to know it's a tagged enum; runs
    # before the cannot-determine-receiver-type stub so EXPR_CALL
    # receivers with Option$/Result$ returns resolve cleanly without
    # needing ritzlib unwrap helpers that don't exist. (ritz-task-106)
    if type_name != null
        if type_name_len > 0
            let enum_unwrap: i32 = try_emit_enum_unwrap(s, e, type_name, type_name_len, receiver_reg, recv_is_ptr_of_ptr, recv_value_reg)
            if enum_unwrap >= 0
                return enum_unwrap

    if type_name == null or type_name_len == 0
        emit_str(s, c"  ; ERROR: cannot determine receiver type for method call\n")
        let zero: i32 = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, zero)
        emit_str(s, c" = add i64 0, 0\n")
        return zero

    # Built-in method dispatchers (run BEFORE the default Type_method mangling).
    # Mirrors ritz0's Wave-1 dispatch chain — catches obvious intrinsic patterns
    # that ritz1 doesn't have impl-table entries for.

    # StrView.as_bytes() -> inline Span<u8>
    let sv_bytes: i32 = try_emit_strview_as_bytes(s, e, type_name, type_name_len, receiver_reg, recv_is_ptr_of_ptr)
    if sv_bytes >= 0
        return sv_bytes

    # Vec/Span/StrView .len() -> direct field load
    let len_val: i32 = try_emit_len_builtin(s, e, type_name, type_name_len, receiver_reg, recv_is_ptr_of_ptr)
    if len_val >= 0
        return len_val

    # UFCS dispatch: v.method(args) -> vec_method$T(&v, args)
    let ufcs: i32 = try_emit_ufcs_method(s, e, type_name, type_name_len, receiver_reg, recv_is_ptr_of_ptr)
    if ufcs >= 0
        return ufcs

    # Fallback: Build mangled function name: Type_method
    # Emit: call <rt> @Type_method(ptr %receiver, args...)
    #
    # AGAST #113 — walk the impl blocks to find the method's FnDef so we can
    # coerce struct-ref args (auto-borrow) and narrow non-i64 return values.
    # Without the FnDef, fall back to the pre-#113 `call i64 @...(i64 ...)`.
    var mfn: *FnDef = null
    var ib_it: *ImplBlock = s.module.impls
    while ib_it != null and mfn == null
        if ib_it.type_name_len == type_name_len
            var ib_match: i32 = 1
            for i in 0..type_name_len
                if *(ib_it.type_name + i) != *(type_name + i)
                    ib_match = 0
            if ib_match == 1
                var mm: *FnDef = ib_it.methods
                while mm != null and mfn == null
                    if mm.name_len == e.ident_len
                        var name_match: i32 = 1
                        for i in 0..e.ident_len
                            if *(mm.name + i) != *(e.ident_ptr + i)
                                name_match = 0
                        if name_match == 1
                            mfn = mm
                    mm = mm.next
        ib_it = ib_it.next

    # First, evaluate all arguments and collect their registers
    var arg_regs: [16]i32
    var conv_regs: [16]i32
    var arg_count: i32 = 0
    var arg: *Expr = e.args
    while arg != null
        arg_regs[arg_count] = emit_expr(s, arg)
        conv_regs[arg_count] = arg_regs[arg_count]
        arg_count = arg_count + 1
        arg = arg.next

    # Arg coerce — walk params (skip self) and auto-borrow struct-ref args.
    var mp: *Param = null
    if mfn != null
        mp = mfn.params
        if mp != null
            mp = mp.next
    for j in 0..arg_count
        if mp != null
            if mp.param_type == TYPE_REF and mp.param_type_name_len > 0
                var mae: *Expr = e.args
                var mk: i32 = 0
                while mk < j and mae != null
                    mae = mae.next
                    mk = mk + 1
                if mae != null and mae.kind == EXPR_IDENT
                    let mloc: *LocalVar = find_local_struct_name(s, mae.ident_ptr, mae.ident_len)
                    if mloc != null and mloc.var_type == TYPE_STRUCT
                        let pti_m: i32 = next_reg(s)
                        emit_str(s, c"  ")
                        emit_reg(s, pti_m)
                        emit_str(s, c" = ptrtoint ptr ")
                        emit_reg(s, mloc.reg)
                        emit_str(s, c" to i64\n")
                        conv_regs[j] = pti_m
            else if mp.param_type == TYPE_STRUCT and mp.param_type_name_len > 0
                # Scalar→struct newtype boxing (mirrors the plain-call path).
                # Gate on a narrow scalar type — pointers and other structs
                # pass through so 2-field structs like Span<T> aren't
                # corrupted by the 8-byte opaque-ptr reinterpret.
                var mae2: *Expr = e.args
                var mk2: i32 = 0
                while mk2 < j and mae2 != null
                    mae2 = mae2.next
                    mk2 = mk2 + 1
                var is_scalar_int2: i32 = 0
                if mae2 != null
                    let at2: i32 = get_expr_type(s, mae2)
                    if at2 == TYPE_I8 or at2 == TYPE_U8 or at2 == TYPE_I16 or at2 == TYPE_U16 or at2 == TYPE_I32 or at2 == TYPE_U32 or at2 == TYPE_I64 or at2 == TYPE_U64
                        is_scalar_int2 = 1
                if is_scalar_int2 == 1
                    let box_slot2: i32 = next_reg(s)
                    emit_str(s, c"  ")
                    emit_reg(s, box_slot2)
                    emit_str(s, c" = alloca %")
                    emit_name(s, mp.param_type_name, mp.param_type_name_len)
                    emit_str(s, c"  ; newtype arg box\n")
                    emit_str(s, c"  store i64 ")
                    emit_reg(s, arg_regs[j])
                    emit_str(s, c", ptr ")
                    emit_reg(s, box_slot2)
                    emit_str(s, c"\n")
                    let boxed2: i32 = next_reg(s)
                    emit_str(s, c"  ")
                    emit_reg(s, boxed2)
                    emit_str(s, c" = load %")
                    emit_name(s, mp.param_type_name, mp.param_type_name_len)
                    emit_str(s, c", ptr ")
                    emit_reg(s, box_slot2)
                    emit_str(s, c"\n")
                    conv_regs[j] = boxed2
            mp = mp.next

    var rtype: i32 = TYPE_I64
    if mfn != null
        rtype = mfn.return_type

    # Emit the call with the correct return type keyword.
    let result: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, result)
    if rtype == TYPE_BOOL
        emit_str(s, c" = call i1 @")
    else if rtype == TYPE_I32 or rtype == TYPE_U32
        emit_str(s, c" = call i32 @")
    else if rtype == TYPE_I16 or rtype == TYPE_U16
        emit_str(s, c" = call i16 @")
    else if rtype == TYPE_I8 or rtype == TYPE_U8
        emit_str(s, c" = call i8 @")
    else
        emit_str(s, c" = call i64 @")
    emit_name(s, type_name, type_name_len)
    emit_str(s, c"_")
    emit_name(s, e.ident_ptr, e.ident_len)
    emit_str(s, c"(ptr ")
    emit_reg(s, receiver_reg)

    # Emit args with formal types (or i64 fallback when fn_def missing).
    var mp2: *Param = null
    if mfn != null
        mp2 = mfn.params
        if mp2 != null
            mp2 = mp2.next
    for j in 0..arg_count
        emit_str(s, c", ")
        if mp2 != null
            emit_llvm_type_struct(s, mp2.param_type, mp2.param_type_name, mp2.param_type_name_len)
            mp2 = mp2.next
        else
            emit_str(s, c"i64")
        emit_str(s, c" ")
        emit_reg(s, conv_regs[j])
    emit_str(s, c")\n")

    # Add method to extern declarations (uses malloc for stable name storage).
    # When mfn is non-null the method is defined in this module, so emitting
    # an extern `declare i64 @...` would conflict with the `define <rt> @...`
    # local body — skip it.
    if mfn == null
        add_method_extern(s, type_name, type_name_len, e.ident_ptr, e.ident_len)

    # Return narrow — extend smaller returns back to i64 so consumers see i64.
    var nw_op: *u8 = null
    if rtype == TYPE_BOOL
        nw_op = c" = zext i1 "
    else if rtype == TYPE_I32
        nw_op = c" = sext i32 "
    else if rtype == TYPE_U32
        nw_op = c" = zext i32 "
    else if rtype == TYPE_I16
        nw_op = c" = sext i16 "
    else if rtype == TYPE_U16
        nw_op = c" = zext i16 "
    else if rtype == TYPE_I8
        nw_op = c" = sext i8 "
    else if rtype == TYPE_U8
        nw_op = c" = zext i8 "
    if nw_op != null
        let ext: i32 = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, ext)
        emit_str(s, nw_op)
        emit_reg(s, result)
        emit_str(s, c" to i64\n")
        return ext

    return result

