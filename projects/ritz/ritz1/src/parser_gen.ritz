    p.pos = start_pos
    p.error = 0

    # Alternative 3
    var result_1: Token
    var result_2: *Expr

    result_1 = p_current_token(p)
    if p_expect(p, TOK_LT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_2 = parse_add_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return  binary_op_new(p, OP_LT, result_2, null) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 4
    var result_1: Token
    var result_2: *Expr

    result_1 = p_current_token(p)
    if p_expect(p, TOK_LE) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_2 = parse_add_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return  binary_op_new(p, OP_LE, result_2, null) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 5
    var result_1: Token
    var result_2: *Expr

    result_1 = p_current_token(p)
    if p_expect(p, TOK_GT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_2 = parse_add_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return  binary_op_new(p, OP_GT, result_2, null) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 6
    var result_1: Token
    var result_2: *Expr

    result_1 = p_current_token(p)
    if p_expect(p, TOK_GE) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_2 = parse_add_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return  binary_op_new(p, OP_GE, result_2, null) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 7

    if p.error == 0
        return  null 

    if p.error == 0
        return null
    return null

fn parse_add_expr(p: *Parser) -> *Expr
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: *Expr
    var result_2: *BinaryOp

    result_1 = parse_mul_expr(p)
    if p.error == 0
        result_2 = parse_add_tail(p)
    if p.error == 0
        return  apply_binary_opt_p(p, result_1, result_2) 

    if p.error == 0
        return null
    return null

fn parse_add_tail(p: *Parser) -> *BinaryOp
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: *Expr
    var result_3: *BinaryOp

    result_1 = p_current_token(p)
    if p_expect(p, TOK_PLUS) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_2 = parse_mul_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_3 = parse_add_tail(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return  binary_op_new(p, OP_ADD, result_2, result_3) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_1: Token
    var result_2: *Expr
    var result_3: *BinaryOp

    result_1 = p_current_token(p)
    if p_expect(p, TOK_MINUS) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_2 = parse_mul_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_3 = parse_add_tail(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return  binary_op_new(p, OP_SUB, result_2, result_3) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 3

    if p.error == 0
        return  null 

    if p.error == 0
        return null
    return null

fn parse_mul_expr(p: *Parser) -> *Expr
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: *Expr
    var result_2: *BinaryOp

    result_1 = parse_cast_expr(p)
    if p.error == 0
        result_2 = parse_mul_tail(p)
    if p.error == 0
        return  apply_binary_opt_p(p, result_1, result_2) 

    if p.error == 0
        return null
    return null

fn parse_mul_tail(p: *Parser) -> *BinaryOp
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: *Expr
    var result_3: *BinaryOp

    result_1 = p_current_token(p)
    if p_expect(p, TOK_STAR) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_2 = parse_cast_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_3 = parse_mul_tail(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return  binary_op_new(p, OP_MUL, result_2, result_3) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_1: Token
    var result_2: *Expr
    var result_3: *BinaryOp

    result_1 = p_current_token(p)
    if p_expect(p, TOK_SLASH) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_2 = parse_cast_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_3 = parse_mul_tail(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return  binary_op_new(p, OP_DIV, result_2, result_3) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 3
    var result_1: Token
    var result_2: *Expr
    var result_3: *BinaryOp

    result_1 = p_current_token(p)
    if p_expect(p, TOK_PERCENT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_2 = parse_cast_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_3 = parse_mul_tail(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return  binary_op_new(p, OP_MOD, result_2, result_3) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 4

    if p.error == 0
        return  null 

    if p.error == 0
        return null
    return null

fn parse_cast_expr(p: *Parser) -> *Expr
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: *Expr
    var result_2: *CastTail

    result_1 = parse_unary_expr(p)
    if p.error == 0
        result_2 = parse_cast_tail(p)
    if p.error == 0
        return  apply_cast_tail(p, result_1, result_2) 

    if p.error == 0
        return null
    return null

fn parse_cast_tail(p: *Parser) -> *CastTail
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: i32
    var result_3: *CastTail

    result_1 = p_current_token(p)
    if p_expect(p, TOK_AS) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_2 = parse_type_spec(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_3 = parse_cast_tail(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return  cast_tail_new(p, result_2, result_3) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2

    if p.error == 0
        return  null 

    if p.error == 0
        return null
    return null

fn parse_unary_expr(p: *Parser) -> *Expr
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: *Expr

    result_1 = p_current_token(p)
    if p_expect(p, TOK_MINUS) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_2 = parse_unary_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return  expr_unary(p, OP_NEG, result_2, result_1.line, result_1.col) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_1: Token
    var result_2: *Expr

    result_1 = p_current_token(p)
    if p_expect(p, TOK_BANG) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_2 = parse_unary_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return  expr_unary(p, OP_NOT, result_2, result_1.line, result_1.col) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 3
    var result_1: Token
    var result_2: *Expr

    result_1 = p_current_token(p)
    if p_expect(p, TOK_TILDE) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_2 = parse_unary_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return  expr_unary(p, OP_BIT_NOT, result_2, result_1.line, result_1.col) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 4
    var result_1: Token
    var result_2: *Expr

    result_1 = p_current_token(p)
    if p_expect(p, TOK_STAR) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_2 = parse_unary_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return  expr_unary(p, OP_DEREF, result_2, result_1.line, result_1.col) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 5
    var result_1: *Expr

    result_1 = parse_addr_expr(p)
    if p.error == 0
        return  result_1 

    if p.error == 0
        return null
    return null

fn parse_addr_expr(p: *Parser) -> *Expr
    let start_pos: i32 = p.pos

    # Alternative 1: @ address-of (RERITZ syntax)
    var result_at_1: Token
    var result_at_2: *Expr

    result_at_1 = p_current_token(p)
    if p_expect(p, TOK_AT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_at_2 = parse_addr_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return  expr_unary(p, OP_ADDR, result_at_2, result_at_1.line, result_at_1.col)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2: & address-of (legacy, still supported for bootstrap)
    var result_1: Token
    var result_2: *Expr

    result_1 = p_current_token(p)
    if p_expect(p, TOK_AMP) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_2 = parse_addr_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return  expr_unary(p, OP_ADDR, result_2, result_1.line, result_1.col)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 3: postfix expression
    var result_3: *Expr

    result_3 = parse_postfix_expr(p)
    if p.error == 0
        return  result_3 

    if p.error == 0
        return null
    return null

fn parse_postfix_expr(p: *Parser) -> *Expr
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: *Expr
    var result_2: *PostfixOp

    result_1 = parse_primary_expr(p)
    if p.error == 0
        result_2 = parse_postfix_ops(p)
    if p.error == 0
        return  apply_postfix_p(p, result_1, result_2) 

    if p.error == 0
        return null
    return null

fn parse_postfix_ops(p: *Parser) -> *PostfixOp
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: *PostfixOp
    var result_2: *PostfixOp

    result_1 = parse_postfix_op(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        result_2 = parse_postfix_ops(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return  postfix_link(result_1, result_2) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2

    if p.error == 0
        return  null 

    if p.error == 0
        return null
    return null

fn parse_postfix_op(p: *Parser) -> *PostfixOp
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: Token
    var result_3: Token
    var result_4: Token
    var result_5: *Expr
    var result_6: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_LT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_2 = parse_type_name(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_3 = p_current_token(p)
        if p_expect(p, TOK_GT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_4 = p_current_token(p)
        if p_expect(p, TOK_LPAREN) == 0
            p.error = 1
            p.pos = start_pos
    result_5 = null
    if p.error == 0
        result_5 = parse_args(p)  # optional
        p.error = 0
    if p.error == 0
        result_6 = p_current_token(p)
        if p_expect(p, TOK_RPAREN) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return  postfix_generic_call(p, result_2, result_5) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_1: Token
    var result_2: *Expr
    var result_3: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_LPAREN) == 0
        p.error = 1
        p.pos = start_pos
    result_2 = null
    if p.error == 0
        result_2 = parse_args(p)  # optional
        p.error = 0
    if p.error == 0
        result_3 = p_current_token(p)
        if p_expect(p, TOK_RPAREN) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return  postfix_call(p, result_2) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 3
    var result_1: Token
    var result_2: *Expr
    var result_3: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_LBRACKET) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_2 = parse_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_3 = p_current_token(p)
        if p_expect(p, TOK_RBRACKET) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return  postfix_index(p, result_2) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 4
    var result_1: Token
    var result_2: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_DOT) == 0
        p.error = 1
    if p.error == 0
        result_2 = p_current_token(p)
        if p_expect(p, TOK_IDENT) == 0
            p.error = 1
    if p.error == 0
        return  postfix_member(p, result_2.start, result_2.len) 

    if p.error == 0
        return null
    return null

fn parse_args(p: *Parser) -> *Expr
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: *Expr
    var result_2: Token
    var result_3: *Expr

    result_1 = parse_expr(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        result_2 = p_current_token(p)
        if p_expect(p, TOK_COMMA) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_3 = parse_args(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return  expr_link(result_1, result_3) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_1: *Expr

    result_1 = parse_expr(p)
    if p.error == 0
        return  result_1 

    if p.error == 0
        return null
    return null

fn parse_primary_expr(p: *Parser) -> *Expr
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_NUMBER) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return  expr_int(p, parse_int(result_1.start, result_1.len), result_1.line, result_1.col) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_1: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_STRING) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return  expr_string(p, result_1) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 3
    var result_1: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_CHAR) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return  expr_char(p, result_1) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 4
    var result_1: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_NIL) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return  expr_nil(p, result_1.line, result_1.col) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 5: IDENT LT type_spec GT struct_lit (generic struct literal)
    var result_1: Token
    var result_2: Token
    var result_3: i32
    var result_4: Token
    var result_5: *StructLit

    result_1 = p_current_token(p)
    if p_expect(p, TOK_IDENT) == 0
        p.error = 1
    if p.error == 0
        result_2 = p_current_token(p)
        if p_expect(p, TOK_LT) == 0
            p.error = 1
    if p.error == 0
        result_3 = parse_type_spec(p)
    if p.error == 0
        result_4 = p_current_token(p)
        if p_expect(p, TOK_GT) == 0
            p.error = 1
    if p.error == 0
        result_5 = parse_struct_lit(p)
        if result_5 == null
            p.error = 1
    if p.error == 0
        return generic_struct_lit(p, result_1, result_3, result_5)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 6: IDENT struct_lit? (identifier or struct literal)
    var result_1: Token
    var result_2: *StructLit

    result_1 = p_current_token(p)
    if p_expect(p, TOK_IDENT) == 0
        p.error = 1
        p.pos = start_pos
    result_2 = null
    if p.error == 0
        result_2 = parse_struct_lit(p)  # optional
        p.error = 0
    if p.error == 0
        return  ident_or_struct(p, result_1, result_2) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 7: LPAREN expr RPAREN
    var result_1: Token
    var result_2: *Expr
    var result_3: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_LPAREN) == 0
        p.error = 1
    if p.error == 0
        result_2 = parse_expr(p)
    if p.error == 0
        result_3 = p_current_token(p)
        if p_expect(p, TOK_RPAREN) == 0
            p.error = 1
    if p.error == 0
        return  result_2 

    if p.error == 0
        return null
    return null

fn parse_struct_lit(p: *Parser) -> *StructLit
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: *FieldInit
    var result_3: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_LBRACE) == 0
        p.error = 1
    if p.error == 0
        result_2 = parse_field_inits(p)
    if p.error == 0
        result_3 = p_current_token(p)
        if p_expect(p, TOK_RBRACE) == 0
            p.error = 1
    if p.error == 0
        return  result_2 

    if p.error == 0
        return null
    return null

fn parse_field_inits(p: *Parser) -> *FieldInit
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: *FieldInit
    var result_2: Token
    var result_3: *FieldInit

    result_1 = parse_field_init(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        result_2 = p_current_token(p)
        if p_expect(p, TOK_COMMA) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_3 = parse_field_inits(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return  field_init_link(result_1, result_3) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_1: *FieldInit

    result_1 = parse_field_init(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        return  result_1 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 3

    if p.error == 0
        return  null 

    if p.error == 0
        return null
    return null

fn parse_field_init(p: *Parser) -> *FieldInit
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: Token
    var result_3: *Expr

    result_1 = p_current_token(p)
    if p_expect(p, TOK_IDENT) == 0
        p.error = 1
    if p.error == 0
        result_2 = p_current_token(p)
        if p_expect(p, TOK_COLON) == 0
            p.error = 1
    if p.error == 0
        result_3 = parse_expr(p)
    if p.error == 0
        return  field_init_new(p, result_1.start, result_1.len, result_3) 

    if p.error == 0
        return null
    return null

fn parse_generic_params(p: *Parser) -> *TypeParam
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: *TypeParam
    var result_3: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_LT) == 0
        p.error = 1
    if p.error == 0
        result_2 = parse_type_param_list(p)
    if p.error == 0
        result_3 = p_current_token(p)
        if p_expect(p, TOK_GT) == 0
            p.error = 1
    if p.error == 0
        return  result_2 

    if p.error == 0
        return null
    return null

fn parse_type_param_list(p: *Parser) -> *TypeParam
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: Token
    var result_3: *TypeParam

    result_1 = p_current_token(p)
    if p_expect(p, TOK_IDENT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_2 = p_current_token(p)
        if p_expect(p, TOK_COMMA) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_3 = parse_type_param_list(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return  type_param_link(type_param_new(p, result_1.start, result_1.len), result_3) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_1: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_IDENT) == 0
        p.error = 1
    if p.error == 0
        return  type_param_new(p, result_1.start, result_1.len) 

    if p.error == 0
        return null
    return null

fn parse_impl_block(p: *Parser) -> *ImplBlock
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: *TypeParam
    var result_3: Token
    var result_4: Token
    var result_5: Token
    var result_6: Token
    var result_7: Token
    var result_8: *FnDef
    var result_9: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_IMPL) == 0
        p.error = 1
        p.pos = start_pos
    result_2 = null
    if p.error == 0
        result_2 = parse_generic_params(p)  # optional
        p.error = 0
    if p.error == 0
        result_3 = p_current_token(p)
        if p_expect(p, TOK_IDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_4 = p_current_token(p)
        if p_expect(p, TOK_FOR) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_5 = p_current_token(p)
        if p_expect(p, TOK_IDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_6 = p_current_token(p)
        if p_expect(p, TOK_NEWLINE) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_7 = p_current_token(p)
        if p_expect(p, TOK_INDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_8 = parse_impl_methods(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_9 = p_current_token(p)
        if p_expect(p, TOK_DEDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return  impl_block_new(p, result_3.start, result_3.len, result_5.start, result_5.len, result_2, result_8) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_1: Token
    var result_2: *TypeParam
    var result_3: Token
    var result_4: Token
    var result_5: Token
    var result_6: *FnDef
    var result_7: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_IMPL) == 0
        p.error = 1
    result_2 = null
    if p.error == 0
        result_2 = parse_generic_params(p)  # optional
        p.error = 0
    if p.error == 0
        result_3 = p_current_token(p)
        if p_expect(p, TOK_IDENT) == 0
            p.error = 1
    if p.error == 0
        result_4 = p_current_token(p)
        if p_expect(p, TOK_NEWLINE) == 0
            p.error = 1
    if p.error == 0
        result_5 = p_current_token(p)
        if p_expect(p, TOK_INDENT) == 0
            p.error = 1
    if p.error == 0
        result_6 = parse_impl_methods(p)
    if p.error == 0
        result_7 = p_current_token(p)
        if p_expect(p, TOK_DEDENT) == 0
            p.error = 1
    if p.error == 0
        return  impl_block_new(p, null, 0, result_3.start, result_3.len, result_2, result_6) 

    if p.error == 0
        return null
    return null

fn parse_impl_methods(p: *Parser) -> *FnDef
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: *FnDef
    var result_2: *FnDef

    result_1 = parse_fn_def(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        result_2 = parse_impl_methods(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return  fn_link(result_1, result_2) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2

    if p.error == 0
        return  null 

    if p.error == 0
        return null
    return null

# Entry point - parse starting from first rule
fn parse(tokens: *Token, count: i32, arena_ptr: *u8) -> *Module
    var p: Parser
    parser_init(@p, tokens, count, arena_ptr)
    return parse_module(@p)
