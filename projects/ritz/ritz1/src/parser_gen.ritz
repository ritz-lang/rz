    result_a3_1 = p_current_token(p)
    if p_expect(p, TOK_IDENT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return pattern_ident_or_wildcard(p, result_a3_1.start, result_a3_1.len)

    if p.error == 0
        return null
    return null

