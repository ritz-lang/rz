fn parse_addr_expr(p: *Parser) -> *Expr
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: Token
    var result_a1_2: Token
    var result_a1_3: *Expr

    result_a1_1 = p_current_token(p)
    if p_expect(p, TOK_AT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a1_2 = p_current_token(p)
        if p_expect(p, TOK_AMP) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a1_3 = parse_addr_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return expr_unary(p, OP_ADDR_MUT, result_a1_3, result_a1_1.line, result_a1_1.col)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_a2_1: Token
    var result_a2_2: *Expr

    result_a2_1 = p_current_token(p)
    if p_expect(p, TOK_AT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a2_2 = parse_addr_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return expr_unary(p, OP_ADDR, result_a2_2, result_a2_1.line, result_a2_1.col)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 3
    var result_a3_1: *Expr

    result_a3_1 = parse_postfix_expr(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        return result_a3_1

    if p.error == 0
        return null
    return null

fn parse_postfix_expr(p: *Parser) -> *Expr
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: *Expr
    var result_2: *PostfixOp

    result_1 = parse_primary_expr(p)
    if p.error == 0
        result_2 = parse_postfix_ops(p)
    if p.error == 0
        return apply_postfix_p(p, result_1, result_2)

    if p.error == 0
        return null
    return null

fn parse_postfix_ops(p: *Parser) -> *PostfixOp
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: *PostfixOp
    var result_a1_2: *PostfixOp

    result_a1_1 = parse_postfix_op(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        result_a1_2 = parse_postfix_ops(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return postfix_link(result_a1_1, result_a1_2)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    if p.error == 0
        return null

    if p.error == 0
        return null
    return null

fn parse_postfix_op(p: *Parser) -> *PostfixOp
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: Token
    var result_a1_2: Token
    var result_a1_3: Token
    var result_a1_4: Token
    var result_a1_5: *Expr
    var result_a1_6: Token

    result_a1_1 = p_current_token(p)
    if p_expect(p, TOK_LT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a1_2 = parse_type_name(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_a1_3 = p_current_token(p)
        if p_expect(p, TOK_GT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a1_4 = p_current_token(p)
        if p_expect(p, TOK_LPAREN) == 0
            p.error = 1
            p.pos = start_pos
    result_a1_5 = null
    if p.error == 0
        result_a1_5 = parse_args(p)  # optional
        p.error = 0
    if p.error == 0
        result_a1_6 = p_current_token(p)
        if p_expect(p, TOK_RPAREN) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return postfix_generic_call(p, result_a1_2, result_a1_5)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_a2_1: Token
    var result_a2_2: *Expr
    var result_a2_3: Token

    result_a2_1 = p_current_token(p)
    if p_expect(p, TOK_LPAREN) == 0
        p.error = 1
        p.pos = start_pos
    result_a2_2 = null
    if p.error == 0
        result_a2_2 = parse_args(p)  # optional
        p.error = 0
    if p.error == 0
        result_a2_3 = p_current_token(p)
        if p_expect(p, TOK_RPAREN) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return postfix_call(p, result_a2_2)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 3
    var result_a3_1: Token
    var result_a3_2: *Expr
    var result_a3_3: Token
    var result_a3_4: *Expr
    var result_a3_5: Token

    result_a3_1 = p_current_token(p)
    if p_expect(p, TOK_LBRACKET) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a3_2 = parse_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_a3_3 = p_current_token(p)
        if p_expect(p, TOK_DOTDOT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a3_4 = parse_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_a3_5 = p_current_token(p)
        if p_expect(p, TOK_RBRACKET) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return postfix_range_index(p, result_a3_2, result_a3_4)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 4
    var result_a4_1: Token
    var result_a4_2: *Expr
    var result_a4_3: Token

    result_a4_1 = p_current_token(p)
    if p_expect(p, TOK_LBRACKET) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a4_2 = parse_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_a4_3 = p_current_token(p)
        if p_expect(p, TOK_RBRACKET) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return postfix_index(p, result_a4_2)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 5
    var result_a5_1: Token
    var result_a5_2: Token

    result_a5_1 = p_current_token(p)
    if p_expect(p, TOK_DOT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a5_2 = p_current_token(p)
        if p_expect(p, TOK_IDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return postfix_member(p, result_a5_2.start, result_a5_2.len)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 6
    var result_a6_1: Token

    result_a6_1 = p_current_token(p)
    if p_expect(p, TOK_QUESTION) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return postfix_try_new(p)

    if p.error == 0
        return null
    return null

fn parse_args(p: *Parser) -> *Expr
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: *Expr
    var result_a1_2: Token
    var result_a1_3: *Expr

