        result_a3_2 = parse_unary_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return expr_unary(p, OP_BIT_NOT, result_a3_2, result_a3_1.line, result_a3_1.col)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 4
    var result_a4_1: Token
    var result_a4_2: *Expr

    result_a4_1 = p_current_token(p)
    if p_expect(p, TOK_STAR) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a4_2 = parse_unary_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return expr_unary(p, OP_DEREF, result_a4_2, result_a4_1.line, result_a4_1.col)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 5
    var result_a5_1: *Expr

    result_a5_1 = parse_addr_expr(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        return result_a5_1

    if p.error == 0
        return null
    return null

fn parse_addr_expr(p: *Parser) -> *Expr
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: Token
    var result_a1_2: Token
    var result_a1_3: *Expr

    result_a1_1 = p_current_token(p)
    if p_expect(p, TOK_AT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a1_2 = p_current_token(p)
        if p_expect(p, TOK_AMP) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a1_3 = parse_addr_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return expr_unary(p, OP_ADDR_MUT, result_a1_3, result_a1_1.line, result_a1_1.col)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_a2_1: Token
    var result_a2_2: *Expr

    result_a2_1 = p_current_token(p)
    if p_expect(p, TOK_AT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a2_2 = parse_addr_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return expr_unary(p, OP_ADDR, result_a2_2, result_a2_1.line, result_a2_1.col)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 3
    var result_a3_1: *Expr

    result_a3_1 = parse_postfix_expr(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        return result_a3_1

    if p.error == 0
        return null
    return null

fn parse_postfix_expr(p: *Parser) -> *Expr
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: *Expr
    var result_2: *PostfixOp

    result_1 = parse_primary_expr(p)
    if p.error == 0
        result_2 = parse_postfix_ops(p)
    if p.error == 0
        return apply_postfix_p(p, result_1, result_2)

    if p.error == 0
        return null
    return null

fn parse_postfix_ops(p: *Parser) -> *PostfixOp
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: *PostfixOp
    var result_a1_2: *PostfixOp

    result_a1_1 = parse_postfix_op(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        result_a1_2 = parse_postfix_ops(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return postfix_link(result_a1_1, result_a1_2)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    if p.error == 0
        return null

    if p.error == 0
        return null
    return null

fn parse_postfix_op(p: *Parser) -> *PostfixOp
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: Token
    var result_a1_2: Token
    var result_a1_3: Token
    var result_a1_4: Token
    var result_a1_5: *Expr
    var result_a1_6: Token

    result_a1_1 = p_current_token(p)
    if p_expect(p, TOK_LT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a1_2 = parse_type_name(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_a1_3 = p_current_token(p)
        if p_expect(p, TOK_GT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a1_4 = p_current_token(p)
        if p_expect(p, TOK_LPAREN) == 0
            p.error = 1
            p.pos = start_pos
    result_a1_5 = null
    if p.error == 0
        result_a1_5 = parse_args(p)  # optional
        p.error = 0
    if p.error == 0
        result_a1_6 = p_current_token(p)
        if p_expect(p, TOK_RPAREN) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return postfix_generic_call(p, result_a1_2, result_a1_5)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_a2_1: Token
    var result_a2_2: *Expr
    var result_a2_3: Token

    result_a2_1 = p_current_token(p)
    if p_expect(p, TOK_LPAREN) == 0
        p.error = 1
        p.pos = start_pos
    result_a2_2 = null
    if p.error == 0
        result_a2_2 = parse_args(p)  # optional
        p.error = 0
    if p.error == 0
        result_a2_3 = p_current_token(p)
        if p_expect(p, TOK_RPAREN) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return postfix_call(p, result_a2_2)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 3
    # Index: `[ expr ]` OR range-index: `[ expr .. expr ]`
    # Range-index builds an EXPR_RANGE node (kind=14, left=lo, right=hi) and
    # wraps it in a POSTFIX_INDEX so emit_expr_index can lower it to a slice.
    var result_a3_1: Token
    var result_a3_2: *Expr
    var result_a3_3: Token
    var result_a3_hi: *Expr
    var is_range: i32 = 0

    result_a3_1 = p_current_token(p)
    if p_expect(p, TOK_LBRACKET) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a3_2 = parse_expr(p)
        if p.error != 0
            p.pos = start_pos
    # Range-index: `.. expr` between `[` and `]`
    if p.error == 0
        if p_peek(p) == TOK_DOTDOT
            p_advance(p)
            result_a3_hi = parse_expr(p)
            if p.error != 0
                p.pos = start_pos
            else
                is_range = 1
    if p.error == 0
        result_a3_3 = p_current_token(p)
        if p_expect(p, TOK_RBRACKET) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        if is_range == 1
            # Build EXPR_RANGE { left: lo, right: hi } inline — keeps the AST
            # helper surface unchanged (ast_helpers.ritz isn't in this lane).
            let r: *Expr = parser_alloc(p, 128) as *Expr
            r.kind = EXPR_RANGE
            r.span = result_a3_2.span
            r.left = result_a3_2
            r.right = result_a3_hi
            r.next = null
            return postfix_index(p, r)
        return postfix_index(p, result_a3_2)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 4
    var result_a4_1: Token
    var result_a4_2: Token

    result_a4_1 = p_current_token(p)
    if p_expect(p, TOK_DOT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a4_2 = p_current_token(p)
        if p_expect(p, TOK_IDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return postfix_member(p, result_a4_2.start, result_a4_2.len)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 5 (AGAST #134): try operator `?`.
    # Emits a POSTFIX_TRY op which apply_postfix_p wraps in an EXPR_TRY
    # node around the running postfix result. Kept inline (no new
    # ast_helpers surface) since it's a one-field op — mirrors the
    # EXPR_RANGE inline-alloc pattern in Alternative 3.
    var result_a5_1: Token
    result_a5_1 = p_current_token(p)
    if p_expect(p, TOK_QUESTION) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        let op: *PostfixOp = parser_alloc(p, 64) as *PostfixOp
        op.kind = POSTFIX_TRY
        op.next = null
        return op

    if p.error == 0
        return null
    return null

fn parse_args(p: *Parser) -> *Expr
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: *Expr
    var result_a1_2: Token
    var result_a1_3: *Expr

    result_a1_1 = parse_expr(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        result_a1_2 = p_current_token(p)
        if p_expect(p, TOK_COMMA) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a1_3 = parse_args(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return expr_link(result_a1_1, result_a1_3)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_a2_1: *Expr

    result_a2_1 = parse_expr(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        return result_a2_1

    if p.error == 0
        return null
    return null

fn parse_primary_expr(p: *Parser) -> *Expr
    let start_pos: i32 = p.pos

    # Alternative -1 (ritz-task-87): bool literals true/false.
    # ritz1's existing parser had no rule for TOK_TRUE / TOK_FALSE, so any
    # `let b: bool = true` or `pick(true)` silently dropped the enclosing fn.
    # Map them to i64 1 / 0 — the surrounding type system treats bools
    # uniformly as i64 at the expression level.
    if p_peek(p) == TOK_TRUE
        let tt: Token = p_current_token(p)
        p_advance(p)
        return expr_int(p, 1, tt.line, tt.col)
    if p_peek(p) == TOK_FALSE
        let ft: Token = p_current_token(p)
        p_advance(p)
        return expr_int(p, 0, ft.line, ft.col)

    # `self` as expression (task-99 cluster #1). The lexer tokenizes `self`
    # as TOK_SELF; treat it as an ordinary ident so the impl-method body's
    # `self.n` / `self.foo()` / bare `self` all resolve against the local
    # registered by emit_impl_method.
    if p_peek(p) == TOK_SELF
        let st: Token = p_current_token(p)
        p_advance(p)
        return expr_ident(p, st.start, st.len, st.line, st.col)

    # Alternative 0 (ritz-task-87): match as expression
    # Allows `let x = match scrut \n INDENT arms DEDENT`.
    # We reuse the stmt_match helper's structure via expr_match which stores
    # scrutinee in `left` and arm list in `args`. Only try this when the
    # next token is `match` to avoid stealing the start_pos from other alts.
    # After DEDENT we proactively inject a synthetic "stmt end" by NOT
    # consuming the outer NEWLINE (there isn't one) — the caller's
    # NEWLINE-expect should be skipped when it sees a block-expression;
    # we handle that on the parse_let side via `p.block_expr_tail` style flag.
    # Simpler approach: consume DEDENT only if the *following* token is
    # clearly the start of the next statement; otherwise leave DEDENT for
    # the outer block parser to consume.
    if p_peek(p) == TOK_MATCH
        var m_tok: Token
        var m_scrut: *Expr
        var m_arms: *MatchArm
        m_tok = p_current_token(p)
        p_advance(p)  # consume `match`
        m_scrut = parse_expr(p)
        if p.error == 0
            if p_expect(p, TOK_NEWLINE) == 0
                p.error = 1
        if p.error == 0
            if p_expect(p, TOK_INDENT) == 0
                p.error = 1
        if p.error == 0
            m_arms = parse_match_arms(p)
        if p.error == 0
            if p_expect(p, TOK_DEDENT) == 0
                p.error = 1
        if p.error == 0
            return expr_match(p, m_scrut, m_arms, m_tok.line, m_tok.col)
        p.pos = start_pos
        p.error = 0

    # Alternative 1
    var result_a1_1: Token

    result_a1_1 = p_current_token(p)
    if p_expect(p, TOK_NUMBER) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        # AGAST #107: trim optional typed integer-literal suffix before
        # parse_int so `0u8` / `123u16` / `0usize` produce the correct value.
        return expr_int(p, parse_int(result_a1_1.start, int_lit_len(result_a1_1.start, result_a1_1.len)), result_a1_1.line, result_a1_1.col)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2: regular string "..."
    var result_a2_1: Token

    result_a2_1 = p_current_token(p)
    if p_expect(p, TOK_STRING) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return expr_string(p, result_a2_1)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2b: c-string c"..."
    var result_a2b_1: Token

    result_a2b_1 = p_current_token(p)
    if p_expect(p, TOK_CSTRING) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return expr_string(p, result_a2b_1)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2c (s-string s"...") was removed in AGAST #98 — bare "..."
    # handles the same case via StrView.

    # Alternative 3
    var result_a3_1: Token

    result_a3_1 = p_current_token(p)
    if p_expect(p, TOK_CHAR) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return expr_char(p, result_a3_1)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 4
    var result_a4_1: Token

    result_a4_1 = p_current_token(p)
    if p_expect(p, TOK_NIL) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return expr_nil(p, result_a4_1.line, result_a4_1.col)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 5
    var result_a5_1: Token

    result_a5_1 = p_current_token(p)
    if p_expect(p, TOK_NULL) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return expr_nil(p, result_a5_1.line, result_a5_1.col)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 6
    var result_a6_1: Token
    var result_a6_2: Token
    var result_a6_3: i32
    var result_a6_4: Token
    var result_a6_5: *StructLit

    result_a6_1 = p_current_token(p)
    if p_expect(p, TOK_IDENT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a6_2 = p_current_token(p)
        if p_expect(p, TOK_LT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a6_3 = parse_type_spec(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_a6_4 = p_current_token(p)
        if p_expect(p, TOK_GT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a6_5 = parse_struct_lit(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return generic_struct_lit(p, result_a6_1, result_a6_3, result_a6_5)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 7
    var result_a7_1: Token
    var result_a7_2: *StructLit

    result_a7_1 = p_current_token(p)
    if p_expect(p, TOK_IDENT) == 0
        p.error = 1
        p.pos = start_pos
    result_a7_2 = null
    if p.error == 0
        result_a7_2 = parse_struct_lit(p)  # optional
        p.error = 0
    if p.error == 0
        return ident_or_struct(p, result_a7_1, result_a7_2)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 8
    var result_a8_1: Token
    var result_a8_2: *Expr
    var result_a8_3: Token

    result_a8_1 = p_current_token(p)
    if p_expect(p, TOK_LPAREN) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a8_2 = parse_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_a8_3 = p_current_token(p)
        if p_expect(p, TOK_RPAREN) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return result_a8_2

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 9: array literal `[e1, e2, ...]`
    # Stored as EXPR_ARRAY_LIT with elements as a linked list in `args`.
    # Element parsing reuses `parse_args` (comma-separated expression list).
    var result_a9_1: Token
    var result_a9_2: *Expr
    var result_a9_3: Token

    result_a9_1 = p_current_token(p)
    if p_expect(p, TOK_LBRACKET) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a9_2 = parse_args(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_a9_3 = p_current_token(p)
        if p_expect(p, TOK_RBRACKET) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return expr_array(p, result_a9_2, result_a9_1.line, result_a9_1.col)

    if p.error == 0
        return null
    return null

fn parse_struct_lit(p: *Parser) -> *StructLit
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: *FieldInit
    var result_3: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_LBRACE) == 0
        p.error = 1
    if p.error == 0
        result_2 = parse_field_inits(p)
    if p.error == 0
        result_3 = p_current_token(p)
        if p_expect(p, TOK_RBRACE) == 0
            p.error = 1
    if p.error == 0
        return result_2

    if p.error == 0
        return null
    return null

fn parse_field_inits(p: *Parser) -> *FieldInit
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: *FieldInit
    var result_a1_2: Token
    var result_a1_3: *FieldInit

    result_a1_1 = parse_field_init(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        result_a1_2 = p_current_token(p)
        if p_expect(p, TOK_COMMA) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a1_3 = parse_field_inits(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return field_init_link(result_a1_1, result_a1_3)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_a2_1: *FieldInit

    result_a2_1 = parse_field_init(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        return result_a2_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 3
    if p.error == 0
        return null

    if p.error == 0
        return null
    return null

fn parse_field_init(p: *Parser) -> *FieldInit
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: Token
    var result_3: *Expr

    result_1 = p_current_token(p)
    if p_expect(p, TOK_IDENT) == 0
        p.error = 1
    if p.error == 0
        result_2 = p_current_token(p)
        if p_expect(p, TOK_COLON) == 0
            p.error = 1
    if p.error == 0
        result_3 = parse_expr(p)
    if p.error == 0
        return field_init_new(p, result_1.start, result_1.len, result_3)

    if p.error == 0
        return null
    return null

fn parse_generic_params(p: *Parser) -> *TypeParam
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: *TypeParam
    var result_3: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_LT) == 0
        p.error = 1
    if p.error == 0
        result_2 = parse_type_param_list(p)
    if p.error == 0
        result_3 = p_current_token(p)
        if p_expect(p, TOK_GT) == 0
            p.error = 1
    if p.error == 0
        return result_2

    if p.error == 0
        return null
    return null

fn parse_type_param_list(p: *Parser) -> *TypeParam
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: Token
    var result_a1_2: Token
    var result_a1_3: *TypeParam

    result_a1_1 = p_current_token(p)
    if p_expect(p, TOK_IDENT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a1_2 = p_current_token(p)
        if p_expect(p, TOK_COMMA) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a1_3 = parse_type_param_list(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return type_param_link(type_param_new(p, result_a1_1.start, result_a1_1.len), result_a1_3)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_a2_1: Token

    result_a2_1 = p_current_token(p)
    if p_expect(p, TOK_IDENT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return type_param_new(p, result_a2_1.start, result_a2_1.len)

    if p.error == 0
        return null
    return null

fn parse_impl_block(p: *Parser) -> *ImplBlock
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: Token
    var result_a1_2: *TypeParam
    var result_a1_3: Token
    var result_a1_4: Token
    var result_a1_5: Token
    var result_a1_6: Token
    var result_a1_7: Token
    var result_a1_8: *FnDef
    var result_a1_9: Token

    result_a1_1 = p_current_token(p)
    if p_expect(p, TOK_IMPL) == 0
        p.error = 1
        p.pos = start_pos
    result_a1_2 = null
    if p.error == 0
        result_a1_2 = parse_generic_params(p)  # optional
        p.error = 0
    if p.error == 0
        result_a1_3 = p_current_token(p)
        if p_expect(p, TOK_IDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a1_4 = p_current_token(p)
        if p_expect(p, TOK_FOR) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a1_5 = p_current_token(p)
        if p_expect(p, TOK_IDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a1_6 = p_current_token(p)
        if p_expect(p, TOK_NEWLINE) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a1_7 = p_current_token(p)
        if p_expect(p, TOK_INDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a1_8 = parse_impl_methods(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_a1_9 = p_current_token(p)
        if p_expect(p, TOK_DEDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return impl_block_new(p, result_a1_3.start, result_a1_3.len, result_a1_5.start, result_a1_5.len, result_a1_2, result_a1_8)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_a2_1: Token
    var result_a2_2: *TypeParam
    var result_a2_3: Token
    var result_a2_4: Token
    var result_a2_5: Token
    var result_a2_6: *FnDef
    var result_a2_7: Token

    result_a2_1 = p_current_token(p)
    if p_expect(p, TOK_IMPL) == 0
        p.error = 1
        p.pos = start_pos
    result_a2_2 = null
    if p.error == 0
        result_a2_2 = parse_generic_params(p)  # optional
        p.error = 0
    if p.error == 0
        result_a2_3 = p_current_token(p)
        if p_expect(p, TOK_IDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a2_4 = p_current_token(p)
        if p_expect(p, TOK_NEWLINE) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a2_5 = p_current_token(p)
        if p_expect(p, TOK_INDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a2_6 = parse_impl_methods(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_a2_7 = p_current_token(p)
        if p_expect(p, TOK_DEDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return impl_block_new(p, null, 0, result_a2_3.start, result_a2_3.len, result_a2_2, result_a2_6)

    if p.error == 0
        return null
    return null

fn parse_impl_methods(p: *Parser) -> *FnDef
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: *FnDef
    var result_a1_2: *FnDef

    result_a1_1 = parse_fn_def(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        result_a1_2 = parse_impl_methods(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return fn_link(result_a1_1, result_a1_2)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    if p.error == 0
        return null

    if p.error == 0
        return null
    return null

# =============================================================================
# Match parsing (added for ritz-task-87)
# =============================================================================
#
# Grammar:
#   match_stmt : MATCH expr NEWLINE INDENT match_arms DEDENT
#   match_arms : match_arm+
#   match_arm  : pattern FAT_ARROW arm_body NEWLINE
#   pattern    : NUMBER
#              | '_'         (wildcard)
#              | IDENT       (binding / unit variant)
#              | IDENT '(' inner ')'  (variant with payload)
#   inner      : '_' | IDENT
#   arm_body   : expr | PASS
#
# Design notes:
#   - Pattern kinds + data are flattened into MatchArm (see ast.ritz).
#   - `pass` is handled as a no-op arm body (emitter produces default i64 0).
#   - Only what the 2 test_issue_match_*.ritz + 1 custom test need — no
#     nested patterns, no guards, no range patterns.

fn parse_match_stmt(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    var tok_match: Token
    var scrutinee: *Expr
    var arms: *MatchArm

    tok_match = p_current_token(p)
    if p_expect(p, TOK_MATCH) == 0
        p.error = 1
        p.pos = start_pos
        return null
    if p.error == 0
        scrutinee = parse_expr(p)
        if p.error != 0
            p.pos = start_pos
            return null
    if p.error == 0
        if p_expect(p, TOK_NEWLINE) == 0
            p.error = 1
            p.pos = start_pos
            return null
    if p.error == 0
        if p_expect(p, TOK_INDENT) == 0
            p.error = 1
            p.pos = start_pos
            return null
    if p.error == 0
        arms = parse_match_arms(p)
        if p.error != 0
            p.pos = start_pos
            return null
    if p.error == 0
        if p_expect(p, TOK_DEDENT) == 0
            p.error = 1
            p.pos = start_pos
            return null
    if p.error == 0
        return stmt_match(p, scrutinee, arms, tok_match.line, tok_match.col)
    return null

# match_arms: one or more arms
# Iterative implementation — recursive version destroyed `first` when the
# second arm failed because the recursive call's start_pos rewind undid it.
fn parse_match_arms(p: *Parser) -> *MatchArm
    var first: *MatchArm = parse_match_arm(p)
    if p.error != 0
        return null
    var curr: *MatchArm = first
    while 1 == 1
        let save: i32 = p.pos
        let saved_err: i32 = p.error
        let next_arm: *MatchArm = parse_match_arm(p)
        if p.error != 0
            # No more arms — rewind exactly to after the last good arm
            p.pos = save
            p.error = saved_err
            break
        curr.next = next_arm
        curr = next_arm
    return first

# match_arm: pattern FAT_ARROW arm_body NEWLINE
fn parse_match_arm(p: *Parser) -> *MatchArm
    let start_pos: i32 = p.pos
    var arm: *MatchArm

    # Parse pattern. We allocate the arm upfront and fill pattern fields.
    arm = parse_pattern(p)
    if p.error != 0
        p.pos = start_pos
        p.error = 1
        return null
    if arm == null
        p.pos = start_pos
        p.error = 1
        return null

    # Expect FAT_ARROW
    if p_expect(p, TOK_FAT_ARROW) == 0
        p.error = 1
        p.pos = start_pos
        return null

    # arm_body: either `pass` (as an IDENT) or expression
    # `pass` is not its own keyword in ritz1's lexer — it surfaces as TOK_IDENT.
    let body_tok: Token = p_current_token(p)
    var is_pass: i32 = 0
    if body_tok.kind == TOK_IDENT and body_tok.len == 4
        # Check for "pass" literal: 'p'=112, 'a'=97, 's'=115, 's'=115
        if *body_tok.start == 112 and *(body_tok.start + 1) == 97
            if *(body_tok.start + 2) == 115 and *(body_tok.start + 3) == 115
                is_pass = 1
    if is_pass == 1
        p_advance(p)  # consume `pass`
        match_arm_set_body(arm, null, 1)
    else
        let body: *Expr = parse_expr(p)
        if p.error != 0
            p.pos = start_pos
            return null
        match_arm_set_body(arm, body, 0)

    # Consume trailing newline
    if p_expect(p, TOK_NEWLINE) == 0
        p.error = 1
        p.pos = start_pos
        return null
    return arm

# pattern: NUMBER | '_' | IDENT | IDENT '(' inner ')'
# Returns a MatchArm with the pattern fields filled (body unset).
fn parse_pattern(p: *Parser) -> *MatchArm
    let tok: Token = p_current_token(p)

    # Integer literal pattern
    if tok.kind == TOK_NUMBER
        p_advance(p)
        # AGAST #107: strip typed-suffix before parsing digit value.
        return match_arm_int(p, parse_int(tok.start, int_lit_len(tok.start, tok.len)))

    # Negative integer literal pattern: `-NUMBER`
    if tok.kind == TOK_MINUS
        p_advance(p)
        let num: Token = p_current_token(p)
        if num.kind == TOK_NUMBER
            p_advance(p)
            return match_arm_int(p, 0 - parse_int(num.start, int_lit_len(num.start, num.len)))
        p.error = 1
        return null

    # Identifier-based patterns (wildcard `_`, binding, variant)
    if tok.kind == TOK_IDENT
        p_advance(p)
        # Check for wildcard: single-char ident '_'
        if tok.len == 1 and *tok.start == 95  # '_'
            return match_arm_wildcard(p)
        # Check for variant: IDENT LPAREN inner RPAREN
        if p_peek(p) == TOK_LPAREN
            p_advance(p)  # consume `(`
            let inner_tok: Token = p_current_token(p)
            var inner_kind: i32 = 0
            var inner_name: *u8 = null
            var inner_len: i32 = 0
            if inner_tok.kind == TOK_IDENT
                p_advance(p)
                if inner_tok.len == 1 and *inner_tok.start == 95  # '_'
                    inner_kind = PAT_WILDCARD
                else
                    inner_kind = PAT_IDENT
                    inner_name = inner_tok.start
                    inner_len = inner_tok.len
            else
                p.error = 1
                return null
            if p_expect(p, TOK_RPAREN) == 0
                p.error = 1
                return null
            return match_arm_variant(p, tok.start, tok.len, inner_kind, inner_name, inner_len)
        # Plain ident pattern — binding or unit variant (None, etc.)
        return match_arm_ident(p, tok.start, tok.len)

    p.error = 1
    return null

# =============================================================================
# Enum declaration parsing (minimal skip)
# =============================================================================
#
# ritz1 doesn't yet model enums in its AST — but ritzlib/result.ritz and
# ritzlib/option.ritz use `enum Name<T> ... variants`. Without at least a
# consume-and-skip parser here, parse_item bails at the first `enum` token
# and the rest of the module silently drops. We consume the syntax but
# discard the payload; variant constructors are handled as opaque calls
# (or special-cased by the emitter for Some/Ok/None/Err).
#
# Grammar consumed:
#   [ 'pub' ] enum IDENT [ '<' ... '>' ]
#       INDENT (IDENT [ '(' ... ')' ] NEWLINE)+ DEDENT

fn parse_enum_def(p: *Parser) -> i32
    let start_pos: i32 = p.pos

    # Optional `pub` prefix
    if p_peek(p) == TOK_PUB
        p_advance(p)

    if p_expect(p, TOK_ENUM) == 0
        p.error = 1
        p.pos = start_pos
        return 0
    if p_expect(p, TOK_IDENT) == 0
        p.error = 1
        p.pos = start_pos
        return 0
    # Optional <T, ...>
    if p_peek(p) == TOK_LT
        p_advance(p)
        # Consume until matching '>'
        var depth: i32 = 1
        while depth > 0
            let k: i32 = p_peek(p)
            if k == TOK_LT
                depth = depth + 1
            else if k == TOK_GT
                depth = depth - 1
            else if k == TOK_EOF
                p.error = 1
                p.pos = start_pos
                return 0
            p_advance(p)
    if p_expect(p, TOK_NEWLINE) == 0
        p.error = 1
        p.pos = start_pos
        return 0
    if p_expect(p, TOK_INDENT) == 0
        p.error = 1
        p.pos = start_pos
        return 0
    # Consume variant lines until DEDENT
    while p_peek(p) != TOK_DEDENT and p_peek(p) != TOK_EOF
        # Variant name
        if p_peek(p) != TOK_IDENT
            # Skip unexpected token gracefully
            p_advance(p)
        else
            p_advance(p)
            # Optional (type, ...)
            if p_peek(p) == TOK_LPAREN
                var depth2: i32 = 1
                p_advance(p)
                while depth2 > 0
                    let k: i32 = p_peek(p)
                    if k == TOK_LPAREN
                        depth2 = depth2 + 1
                    else if k == TOK_RPAREN
                        depth2 = depth2 - 1
                    else if k == TOK_EOF
                        p.error = 1
                        p.pos = start_pos
                        return 0
                    p_advance(p)
            # Consume trailing newline (optional — tolerate missing)
            if p_peek(p) == TOK_NEWLINE
                p_advance(p)
    if p_expect(p, TOK_DEDENT) == 0
        p.error = 1
        p.pos = start_pos
        return 0
    return 1

