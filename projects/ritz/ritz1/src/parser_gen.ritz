    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: Token

    result_a1_1 = p_current_token(p)
    if p_expect(p, TOK_PLUS_EQ) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return OP_ADD

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_a2_1: Token

    result_a2_1 = p_current_token(p)
    if p_expect(p, TOK_MINUS_EQ) == 0
        p.error = 1
        p.pos = start_pos
