fn parse_pattern(p: *Parser) -> *MatchArm
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: Token

    result_a1_1 = p_current_token(p)
    if p_expect(p, TOK_NUMBER) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return pattern_lit_int(p, result_a1_1.start, result_a1_1.len)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
