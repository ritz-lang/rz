        result_a2_2 = p_current_token(p)
        if p_expect(p, TOK_LPAREN) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a2_3 = p_current_token(p)
        if p_expect(p, TOK_IDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a2_4 = p_current_token(p)
        if p_expect(p, TOK_RPAREN) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return pattern_variant_inner(p, result_a2_1.start, result_a2_1.len, result_a2_3.start, result_a2_3.len)

    # Try next alternative
