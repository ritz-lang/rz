    if p.error == 0
        result_4 = p_current_token(p)
        if p_expect(p, TOK_NEWLINE) == 0
            p.error = 1
    if p.error == 0
        return match_arm_set_body_or_pass(result_1, result_3)

    if p.error == 0
        return null
