fn parse_block(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: Token
    var result_3: *Stmt
    var result_4: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_NEWLINE) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_2 = p_current_token(p)
        if p_expect(p, TOK_INDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_3 = parse_stmts(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_4 = p_current_token(p)
        if p_expect(p, TOK_DEDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return  result_3 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_1: *Stmt

    result_1 = parse_stmt(p)
    if p.error == 0
        return  result_1 

    if p.error == 0
        return null
    return null

fn parse_stmts(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: *Stmt
    var result_2: *Stmt

    result_1 = parse_stmt(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        result_2 = parse_stmts(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return  stmt_link(result_1, result_2) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2

    if p.error == 0
        return  null 

    if p.error == 0
        return null
    return null

fn parse_stmt(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: *Stmt

    result_1 = parse_let_stmt(p)
    if p.error != 0
        p.pos = start_pos
    if p.pos > start_pos
        return result_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_1: *Stmt

    result_1 = parse_var_stmt(p)
    if p.error != 0
        p.pos = start_pos
    if p.pos > start_pos
        return result_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 3
    var result_1: *Stmt

    result_1 = parse_return_stmt(p)
    if p.error != 0
        p.pos = start_pos
    if p.pos > start_pos
        return result_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 4
    var result_1: *Stmt

    result_1 = parse_if_stmt(p)
    if p.error != 0
        p.pos = start_pos
    if p.pos > start_pos
        return result_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 5
    var result_1: *Stmt

    result_1 = parse_control_stmt(p)
    if p.error != 0
        p.pos = start_pos
    if p.pos > start_pos
        return result_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 6
    var result_1: *Stmt

    result_1 = parse_assign_stmt(p)
    if p.error != 0
        p.pos = start_pos
    if p.pos > start_pos
        return result_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 7
    var result_1: *Stmt

    result_1 = parse_expr_stmt(p)

    if p.error == 0
        return result_1
    return null

fn parse_control_stmt(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: *Stmt

    result_1 = parse_while_stmt(p)
    if p.error != 0
        p.pos = start_pos
    if p.pos > start_pos
        return result_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_1: *Stmt

    result_1 = parse_break_stmt(p)
    if p.error != 0
        p.pos = start_pos
    if p.pos > start_pos
        return result_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 3
    var result_1: *Stmt

    result_1 = parse_continue_stmt(p)

    if p.error == 0
        return result_1
    return null

fn parse_let_stmt(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: Token
    var result_3: Token
    var result_4: i32
    var result_5: Token
    var result_6: *Expr
    var result_7: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_LET) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_2 = p_current_token(p)
        if p_expect(p, TOK_IDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_3 = p_current_token(p)
        if p_expect(p, TOK_COLON) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_4 = parse_type_spec(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_5 = p_current_token(p)
        if p_expect(p, TOK_ASSIGN) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_6 = parse_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_7 = p_current_token(p)
        if p_expect(p, TOK_NEWLINE) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return  stmt_var_decl(p, result_2.start, result_2.len, result_4, result_6, result_1.line, result_1.col) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_1: Token
    var result_2: Token
    var result_3: Token
    var result_4: *Expr
    var result_5: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_LET) == 0
        p.error = 1
    if p.error == 0
        result_2 = p_current_token(p)
        if p_expect(p, TOK_IDENT) == 0
            p.error = 1
    if p.error == 0
        result_3 = p_current_token(p)
        if p_expect(p, TOK_ASSIGN) == 0
            p.error = 1
    if p.error == 0
        result_4 = parse_expr(p)
    if p.error == 0
        result_5 = p_current_token(p)
        if p_expect(p, TOK_NEWLINE) == 0
            p.error = 1
    if p.error == 0
        return  stmt_var_decl(p, result_2.start, result_2.len, 0, result_4, result_1.line, result_1.col) 

    if p.error == 0
        return null
    return null

fn parse_var_stmt(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: Token
    var result_3: Token
    var result_4: i32
    var result_5: Token
    var result_6: *Expr
    var result_7: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_VAR) == 0
