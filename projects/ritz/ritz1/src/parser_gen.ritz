            p.pos = start_pos
    if p.error == 0
        result_a12_3 = parse_type_spec(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return type_mut_ref(p, result_a12_3)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 13
