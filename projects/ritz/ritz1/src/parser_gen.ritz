fn parse_match_arm(p: *Parser) -> *MatchArm
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: *MatchArm
    var result_2: Token
    var result_3: *Expr
    var result_4: Token

    result_1 = parse_pattern(p)
    if p.error == 0
        result_2 = p_current_token(p)
