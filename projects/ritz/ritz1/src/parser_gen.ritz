    var result_a13_2: i32

    result_a13_1 = p_current_token(p)
    if p_expect(p, TOK_AT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a13_2 = parse_type_spec(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return type_ref(p, result_a13_2)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 14
    var result_a14_1: Token
    var result_a14_2: Token
    var result_a14_3: i32
    var result_a14_4: Token

    result_a14_1 = p_current_token(p)
    if p_expect(p, TOK_IDENT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a14_2 = p_current_token(p)
        if p_expect(p, TOK_LT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a14_3 = parse_type_spec(p)
        if p.error != 0
            p.pos = start_pos
    # Tolerate multi-arg generics (e.g. Result<T, E>) by consuming any
    # extra `, T2, T3...` after the first type arg. Only the first arg
    # is used for name mangling — extras are ignored (ritz-task-87 skip).
    if p.error == 0
        while p_peek(p) == TOK_COMMA
            p_advance(p)  # consume `,`
            let _extra: i32 = parse_type_spec(p)
            if p.error != 0
                p.pos = start_pos
                break
    if p.error == 0
        result_a14_4 = p_current_token(p)
        if p_expect(p, TOK_GT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return type_generic(p, result_a14_1.start, result_a14_1.len, result_a14_3)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 15
    var result_a15_1: Token

    result_a15_1 = p_current_token(p)
    if p_expect(p, TOK_IDENT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return type_named(p, result_a15_1.start, result_a15_1.len)

    if p.error == 0
        return 0
    return 0

fn parse_type_name(p: *Parser) -> Token
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: Token

    result_a1_1 = p_current_token(p)
    if p_expect(p, TOK_I8) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return result_a1_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_a2_1: Token

    result_a2_1 = p_current_token(p)
    if p_expect(p, TOK_I32) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return result_a2_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 3
    var result_a3_1: Token

    result_a3_1 = p_current_token(p)
    if p_expect(p, TOK_I64) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return result_a3_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 4
    var result_a4_1: Token

    result_a4_1 = p_current_token(p)
    if p_expect(p, TOK_U8) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return result_a4_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 5
    var result_a5_1: Token

    result_a5_1 = p_current_token(p)
    if p_expect(p, TOK_U64) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return result_a5_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 6
    var result_a6_1: Token

    result_a6_1 = p_current_token(p)
    if p_expect(p, TOK_BOOL) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return result_a6_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # AGAST #111: missing alternatives for TOK_I16/TOK_U16/TOK_U32.
    # Without these, `vec_new<u16>()` silently fails — u8/i32/u64 work because
    # their tokens are in the list above. Adding as new alternatives (copy of
    # the TOK_I8/TOK_I32/... pattern) fixes `<u16>`, `<i16>`, `<u32>` in
    # generic call type args.
    # Alternative 7 (TOK_I16)
    var result_a7b_1: Token

    result_a7b_1 = p_current_token(p)
    if p_expect(p, TOK_I16) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return result_a7b_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 8 (TOK_U16)
    var result_a8_1: Token

    result_a8_1 = p_current_token(p)
    if p_expect(p, TOK_U16) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return result_a8_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 9 (TOK_U32)
    var result_a9_1: Token

    result_a9_1 = p_current_token(p)
    if p_expect(p, TOK_U32) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return result_a9_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 10 (TOK_IDENT)
    var result_a10_1: Token

    result_a10_1 = p_current_token(p)
    if p_expect(p, TOK_IDENT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return result_a10_1

    if p.error == 0
        return p_current_token(p)
    return p_current_token(p)

fn parse_block(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: Token
    var result_a1_2: Token
    var result_a1_3: *Stmt
    var result_a1_4: Token

    result_a1_1 = p_current_token(p)
    if p_expect(p, TOK_NEWLINE) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a1_2 = p_current_token(p)
        if p_expect(p, TOK_INDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a1_3 = parse_stmts(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_a1_4 = p_current_token(p)
        if p_expect(p, TOK_DEDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return result_a1_3

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_a2_1: *Stmt

    result_a2_1 = parse_stmt(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        return result_a2_1

    if p.error == 0
        return null
    return null

fn parse_stmts(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: *Stmt
    var result_a1_2: *Stmt

    result_a1_1 = parse_stmt(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        result_a1_2 = parse_stmts(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return stmt_link(result_a1_1, result_a1_2)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    if p.error == 0
        return null

    if p.error == 0
        return null
    return null

fn parse_stmt(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: *Stmt

    result_a1_1 = parse_let_stmt(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        return result_a1_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_a2_1: *Stmt

    result_a2_1 = parse_var_stmt(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        return result_a2_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 3
    var result_a3_1: *Stmt

    result_a3_1 = parse_return_stmt(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        return result_a3_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 4
    var result_a4_1: *Stmt

    result_a4_1 = parse_if_stmt(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        return result_a4_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 5
    var result_a5_1: *Stmt

    result_a5_1 = parse_control_stmt(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        return result_a5_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 6
    var result_a6_1: *Stmt

    result_a6_1 = parse_assign_stmt(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        return result_a6_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 7
    var result_a7_1: *Stmt

    result_a7_1 = parse_expr_stmt(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        return result_a7_1

    if p.error == 0
        return null
    return null

fn parse_control_stmt(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: *Stmt

    result_a1_1 = parse_while_stmt(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        return result_a1_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_a2_1: *Stmt

    result_a2_1 = parse_for_stmt(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        return result_a2_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 3
    var result_a3_1: *Stmt

    result_a3_1 = parse_loop_stmt(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        return result_a3_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 4
    var result_a4_1: *Stmt

    result_a4_1 = parse_break_stmt(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        return result_a4_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 5
    var result_a5_1: *Stmt

    result_a5_1 = parse_continue_stmt(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        return result_a5_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 6: match stmt (added for ritz-task-87)
    var result_a6_1: *Stmt

    result_a6_1 = parse_match_stmt(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        return result_a6_1

    if p.error == 0
        return null
    return null

fn parse_let_stmt(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: Token
    var result_a1_2: Token
    var result_a1_3: Token
    var result_a1_4: i32
    var result_a1_5: Token
    var result_a1_6: *Expr
    var result_a1_7: Token

    result_a1_1 = p_current_token(p)
    if p_expect(p, TOK_LET) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a1_2 = p_current_token(p)
        if p_expect(p, TOK_IDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a1_3 = p_current_token(p)
        if p_expect(p, TOK_COLON) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a1_4 = parse_var_type(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_a1_5 = p_current_token(p)
        if p_expect(p, TOK_ASSIGN) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a1_6 = parse_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        # NEWLINE is optional when the RHS was a block-expression (match), since
        # match_expr already consumed its trailing DEDENT instead of NEWLINE
        # (ritz-task-87).
        result_a1_7 = p_current_token(p)
        if result_a1_6 != null and result_a1_6.kind == EXPR_MATCH
            # Tolerate missing NEWLINE after match expression.
            if p_peek(p) == TOK_NEWLINE
                p_advance(p)
        else
            if p_expect(p, TOK_NEWLINE) == 0
                p.error = 1
                p.pos = start_pos
    if p.error == 0
        return stmt_var_decl(p, result_a1_2.start, result_a1_2.len, result_a1_4, result_a1_6, result_a1_1.line, result_a1_1.col)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_a2_1: Token
    var result_a2_2: Token
    var result_a2_3: Token
    var result_a2_4: *Expr
    var result_a2_5: Token

    result_a2_1 = p_current_token(p)
    if p_expect(p, TOK_LET) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a2_2 = p_current_token(p)
        if p_expect(p, TOK_IDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a2_3 = p_current_token(p)
        if p_expect(p, TOK_ASSIGN) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a2_4 = parse_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        # Same optional-NEWLINE treatment for match-expression RHS.
        result_a2_5 = p_current_token(p)
        if result_a2_4 != null and result_a2_4.kind == EXPR_MATCH
            if p_peek(p) == TOK_NEWLINE
                p_advance(p)
        else
            if p_expect(p, TOK_NEWLINE) == 0
                p.error = 1
                p.pos = start_pos
    if p.error == 0
        return stmt_var_decl(p, result_a2_2.start, result_a2_2.len, 0, result_a2_4, result_a2_1.line, result_a2_1.col)

    if p.error == 0
        return null
    return null

fn parse_var_stmt(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: Token
    var result_a1_2: Token
    var result_a1_3: Token
    var result_a1_4: i32
    var result_a1_5: Token
    var result_a1_6: *Expr
    var result_a1_7: Token

    result_a1_1 = p_current_token(p)
    if p_expect(p, TOK_VAR) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a1_2 = p_current_token(p)
        if p_expect(p, TOK_IDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a1_3 = p_current_token(p)
        if p_expect(p, TOK_COLON) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a1_4 = parse_var_type(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_a1_5 = p_current_token(p)
        if p_expect(p, TOK_ASSIGN) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a1_6 = parse_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_a1_7 = p_current_token(p)
        if p_expect(p, TOK_NEWLINE) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return stmt_var_decl(p, result_a1_2.start, result_a1_2.len, result_a1_4, result_a1_6, result_a1_1.line, result_a1_1.col)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_a2_1: Token
    var result_a2_2: Token
    var result_a2_3: Token
    var result_a2_4: i32
    var result_a2_5: Token

    result_a2_1 = p_current_token(p)
    if p_expect(p, TOK_VAR) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a2_2 = p_current_token(p)
        if p_expect(p, TOK_IDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a2_3 = p_current_token(p)
        if p_expect(p, TOK_COLON) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a2_4 = parse_type_spec(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_a2_5 = p_current_token(p)
        if p_expect(p, TOK_NEWLINE) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return stmt_var_decl(p, result_a2_2.start, result_a2_2.len, result_a2_4, null, result_a2_1.line, result_a2_1.col)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 3: var IDENT = expr NEWLINE (type inferred)
    var result_a3_1: Token
    var result_a3_2: Token
    var result_a3_3: Token
    var result_a3_4: *Expr
    var result_a3_5: Token

    result_a3_1 = p_current_token(p)
    if p_expect(p, TOK_VAR) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a3_2 = p_current_token(p)
        if p_expect(p, TOK_IDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a3_3 = p_current_token(p)
        if p_expect(p, TOK_ASSIGN) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a3_4 = parse_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_a3_5 = p_current_token(p)
        if p_expect(p, TOK_NEWLINE) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return stmt_var_decl(p, result_a3_2.start, result_a3_2.len, 0, result_a3_4, result_a3_1.line, result_a3_1.col)

    if p.error == 0
        return null
    return null

fn parse_var_type(p: *Parser) -> i32
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: i32

    result_1 = parse_type_spec(p)
    if p.error == 0
        return capture_var_type(p, result_1)

    if p.error == 0
        return 0
    return 0

fn parse_return_stmt(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: Token
    var result_a1_2: *Expr
    var result_a1_3: Token

    result_a1_1 = p_current_token(p)
    if p_expect(p, TOK_RETURN) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a1_2 = parse_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_a1_3 = p_current_token(p)
        if p_expect(p, TOK_NEWLINE) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return stmt_return(p, result_a1_2, result_a1_1.line, result_a1_1.col)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_a2_1: Token
    var result_a2_2: Token

    result_a2_1 = p_current_token(p)
    if p_expect(p, TOK_RETURN) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a2_2 = p_current_token(p)
        if p_expect(p, TOK_NEWLINE) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return stmt_return(p, null, result_a2_1.line, result_a2_1.col)

    if p.error == 0
        return null
    return null

fn parse_if_stmt(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: *Expr
    var result_3: *Stmt
    var result_4: *Stmt

    result_1 = p_current_token(p)
    if p_expect(p, TOK_IF) == 0
        p.error = 1
    if p.error == 0
        result_2 = parse_expr(p)
    if p.error == 0
        result_3 = parse_block(p)
    if p.error == 0
        result_4 = parse_else_clause(p)
    if p.error == 0
        return stmt_if(p, result_2, result_3, result_4, result_1.line, result_1.col)

    if p.error == 0
        return null
    return null

fn parse_else_clause(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: Token
    var result_a1_2: *Stmt

    result_a1_1 = p_current_token(p)
    if p_expect(p, TOK_ELSE) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a1_2 = parse_block(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return result_a1_2

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    if p.error == 0
        return null

    if p.error == 0
        return null
    return null

fn parse_while_stmt(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: *Expr
    var result_3: *Stmt

    result_1 = p_current_token(p)
    if p_expect(p, TOK_WHILE) == 0
        p.error = 1
    if p.error == 0
        result_2 = parse_expr(p)
    if p.error == 0
        result_3 = parse_block(p)
    if p.error == 0
        return stmt_while(p, result_2, result_3, result_1.line, result_1.col)

    if p.error == 0
        return null
    return null

fn parse_for_stmt(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Two shapes:
    #   for IDENT in expr .. expr block   (range)
    #   for IDENT in expr block           (iterable; for_end = null)
    var result_1: Token
    var result_2: Token
    var result_3: Token
    var result_4: *Expr
    var result_6: *Expr
    var result_7: *Stmt

    result_6 = null

    result_1 = p_current_token(p)
    if p_expect(p, TOK_FOR) == 0
        p.error = 1
    if p.error == 0
        result_2 = p_current_token(p)
        if p_expect(p, TOK_IDENT) == 0
            p.error = 1
    if p.error == 0
        result_3 = p_current_token(p)
        if p_expect(p, TOK_IN) == 0
            p.error = 1
    if p.error == 0
        result_4 = parse_expr(p)
    # Optional `.. endExpr` — absent means iterable form (for_end stays null).
    if p.error == 0
        if p_peek(p) == TOK_DOTDOT
            p_advance(p)
            result_6 = parse_expr(p)
    if p.error == 0
        result_7 = parse_block(p)
    if p.error == 0
        return stmt_for(p, result_2.start, result_2.len, result_4, result_6, result_7, result_1.line, result_1.col)

    if p.error == 0
        return null
    return null

fn parse_loop_stmt(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: *Stmt

    result_1 = p_current_token(p)
    if p_expect(p, TOK_LOOP) == 0
        p.error = 1
    if p.error == 0
        result_2 = parse_block(p)
    if p.error == 0
        return stmt_loop(p, result_2, result_1.line, result_1.col)

    if p.error == 0
        return null
    return null

fn parse_break_stmt(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_BREAK) == 0
        p.error = 1
    if p.error == 0
        result_2 = p_current_token(p)
        if p_expect(p, TOK_NEWLINE) == 0
            p.error = 1
    if p.error == 0
        return stmt_break(p, result_1.line, result_1.col)

    if p.error == 0
        return null
    return null

fn parse_continue_stmt(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_CONTINUE) == 0
        p.error = 1
    if p.error == 0
        result_2 = p_current_token(p)
        if p_expect(p, TOK_NEWLINE) == 0
            p.error = 1
    if p.error == 0
        return stmt_continue(p, result_1.line, result_1.col)

    if p.error == 0
        return null
    return null

fn parse_assign_stmt(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: Token
    var result_a1_2: Token
    var result_a1_3: *Expr
    var result_a1_4: Token

    result_a1_1 = p_current_token(p)
    if p_expect(p, TOK_IDENT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a1_2 = p_current_token(p)
        if p_expect(p, TOK_ASSIGN) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a1_3 = parse_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_a1_4 = p_current_token(p)
        if p_expect(p, TOK_NEWLINE) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return stmt_assign_name(p, result_a1_1.start, result_a1_1.len, result_a1_3, result_a1_1.line, result_a1_1.col)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_a2_1: Token
    var result_a2_2: i32
    var result_a2_3: *Expr
    var result_a2_4: Token

    result_a2_1 = p_current_token(p)
    if p_expect(p, TOK_IDENT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a2_2 = parse_compound_op(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_a2_3 = parse_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_a2_4 = p_current_token(p)
        if p_expect(p, TOK_NEWLINE) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return stmt_compound_assign(p, result_a2_1.start, result_a2_1.len, result_a2_2, result_a2_3, result_a2_1.line, result_a2_1.col)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 3
    var result_a3_1: Token
    var result_a3_2: Token
    var result_a3_3: *Expr
    var result_a3_4: Token
    var result_a3_5: Token
    var result_a3_6: *Expr
    var result_a3_7: Token

    result_a3_1 = p_current_token(p)
    if p_expect(p, TOK_IDENT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a3_2 = p_current_token(p)
        if p_expect(p, TOK_LBRACKET) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a3_3 = parse_expr(p)
        if p.error != 0
