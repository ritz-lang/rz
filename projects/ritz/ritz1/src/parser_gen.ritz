        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_3 = parse_or_tail(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return  binary_op_new(p, OP_OR, result_2, result_3) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2

    if p.error == 0
        return  null 

    if p.error == 0
        return null
    return null

