    p.error = 0

    # Alternative 3
    var result_a3_1: Token

    result_a3_1 = p_current_token(p)
    if p_expect(p, TOK_STAR_EQ) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return OP_MUL

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 4
    var result_a4_1: Token

    result_a4_1 = p_current_token(p)
    if p_expect(p, TOK_SLASH_EQ) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return OP_DIV

    if p.error == 0
        return 0
    return 0

fn parse_expr_stmt(p: *Parser) -> *Stmt
