            p.pos = start_pos
    if p.error == 0
        return expr_match(p, result_a16_2, result_a16_5, result_a16_1.line, result_a16_1.col)

    if p.error == 0
        return null
    return null

fn parse_struct_lit(p: *Parser) -> *StructLit
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: *FieldInit
    var result_3: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_LBRACE) == 0
        p.error = 1
    if p.error == 0
        result_2 = parse_field_inits(p)
    if p.error == 0
        result_3 = p_current_token(p)
        if p_expect(p, TOK_RBRACE) == 0
            p.error = 1
    if p.error == 0
        return result_2

    if p.error == 0
        return null
    return null

fn parse_field_inits(p: *Parser) -> *FieldInit
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: *FieldInit
    var result_a1_2: Token
    var result_a1_3: *FieldInit

    result_a1_1 = parse_field_init(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        result_a1_2 = p_current_token(p)
        if p_expect(p, TOK_COMMA) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a1_3 = parse_field_inits(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return field_init_link(result_a1_1, result_a1_3)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_a2_1: *FieldInit

    result_a2_1 = parse_field_init(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        return result_a2_1

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 3
    if p.error == 0
        return null

    if p.error == 0
        return null
    return null

fn parse_field_init(p: *Parser) -> *FieldInit
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: Token
    var result_3: *Expr

    result_1 = p_current_token(p)
    if p_expect(p, TOK_IDENT) == 0
        p.error = 1
    if p.error == 0
        result_2 = p_current_token(p)
        if p_expect(p, TOK_COLON) == 0
            p.error = 1
    if p.error == 0
        result_3 = parse_expr(p)
    if p.error == 0
        return field_init_new(p, result_1.start, result_1.len, result_3)

    if p.error == 0
        return null
    return null

fn parse_generic_params(p: *Parser) -> *TypeParam
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: *TypeParam
    var result_3: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_LT) == 0
        p.error = 1
    if p.error == 0
        result_2 = parse_type_param_list(p)
    if p.error == 0
        result_3 = p_current_token(p)
        if p_expect(p, TOK_GT) == 0
            p.error = 1
    if p.error == 0
        return result_2

    if p.error == 0
        return null
    return null

fn parse_type_param_list(p: *Parser) -> *TypeParam
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: Token
    var result_a1_2: Token
    var result_a1_3: *TypeParam

    result_a1_1 = p_current_token(p)
    if p_expect(p, TOK_IDENT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_a1_2 = p_current_token(p)
        if p_expect(p, TOK_COMMA) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a1_3 = parse_type_param_list(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return type_param_link(type_param_new(p, result_a1_1.start, result_a1_1.len), result_a1_3)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_a2_1: Token

    result_a2_1 = p_current_token(p)
    if p_expect(p, TOK_IDENT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        return type_param_new(p, result_a2_1.start, result_a2_1.len)

    if p.error == 0
        return null
    return null

fn parse_impl_block(p: *Parser) -> *ImplBlock
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: Token
    var result_a1_2: *TypeParam
    var result_a1_3: Token
    var result_a1_4: Token
    var result_a1_5: Token
    var result_a1_6: Token
    var result_a1_7: Token
    var result_a1_8: *FnDef
    var result_a1_9: Token

    result_a1_1 = p_current_token(p)
    if p_expect(p, TOK_IMPL) == 0
        p.error = 1
        p.pos = start_pos
    result_a1_2 = null
    if p.error == 0
        result_a1_2 = parse_generic_params(p)  # optional
        p.error = 0
    if p.error == 0
        result_a1_3 = p_current_token(p)
        if p_expect(p, TOK_IDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a1_4 = p_current_token(p)
        if p_expect(p, TOK_FOR) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a1_5 = p_current_token(p)
        if p_expect(p, TOK_IDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a1_6 = p_current_token(p)
        if p_expect(p, TOK_NEWLINE) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a1_7 = p_current_token(p)
        if p_expect(p, TOK_INDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a1_8 = parse_impl_methods(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_a1_9 = p_current_token(p)
        if p_expect(p, TOK_DEDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return impl_block_new(p, result_a1_3.start, result_a1_3.len, result_a1_5.start, result_a1_5.len, result_a1_2, result_a1_8)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_a2_1: Token
    var result_a2_2: *TypeParam
    var result_a2_3: Token
    var result_a2_4: Token
    var result_a2_5: Token
    var result_a2_6: *FnDef
    var result_a2_7: Token

    result_a2_1 = p_current_token(p)
    if p_expect(p, TOK_IMPL) == 0
        p.error = 1
        p.pos = start_pos
    result_a2_2 = null
    if p.error == 0
        result_a2_2 = parse_generic_params(p)  # optional
        p.error = 0
    if p.error == 0
        result_a2_3 = p_current_token(p)
        if p_expect(p, TOK_IDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a2_4 = p_current_token(p)
        if p_expect(p, TOK_NEWLINE) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a2_5 = p_current_token(p)
        if p_expect(p, TOK_INDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_a2_6 = parse_impl_methods(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_a2_7 = p_current_token(p)
        if p_expect(p, TOK_DEDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return impl_block_new(p, null, 0, result_a2_3.start, result_a2_3.len, result_a2_2, result_a2_6)

    if p.error == 0
        return null
    return null

fn parse_impl_methods(p: *Parser) -> *FnDef
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_a1_1: *FnDef
    var result_a1_2: *FnDef

    result_a1_1 = parse_fn_def(p)
    if p.error != 0
        p.pos = start_pos
    if p.error == 0
        result_a1_2 = parse_impl_methods(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return fn_link(result_a1_1, result_a1_2)

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    if p.error == 0
        return null

    if p.error == 0
        return null
    return null

