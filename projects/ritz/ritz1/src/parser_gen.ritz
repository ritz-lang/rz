        p.pos = start_pos
    if p.error == 0
        result_2 = p_current_token(p)
        if p_expect(p, TOK_IDENT) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_3 = p_current_token(p)
        if p_expect(p, TOK_COLON) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_4 = parse_type_spec(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_5 = p_current_token(p)
        if p_expect(p, TOK_ASSIGN) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_6 = parse_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_7 = p_current_token(p)
        if p_expect(p, TOK_NEWLINE) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return  stmt_var_decl(p, result_2.start, result_2.len, result_4, result_6, result_1.line, result_1.col) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_1: Token
    var result_2: Token
    var result_3: Token
    var result_4: i32
    var result_5: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_VAR) == 0
        p.error = 1
    if p.error == 0
        result_2 = p_current_token(p)
        if p_expect(p, TOK_IDENT) == 0
            p.error = 1
    if p.error == 0
        result_3 = p_current_token(p)
        if p_expect(p, TOK_COLON) == 0
            p.error = 1
    if p.error == 0
        result_4 = parse_type_spec(p)
    if p.error == 0
        result_5 = p_current_token(p)
        if p_expect(p, TOK_NEWLINE) == 0
            p.error = 1
    if p.error == 0
        return  stmt_var_decl(p, result_2.start, result_2.len, result_4, null, result_1.line, result_1.col) 

    if p.error == 0
        return null
    return null

fn parse_return_stmt(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: *Expr
    var result_3: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_RETURN) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_2 = parse_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_3 = p_current_token(p)
        if p_expect(p, TOK_NEWLINE) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return  stmt_return(p, result_2, result_1.line, result_1.col) 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2
    var result_1: Token
    var result_2: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_RETURN) == 0
        p.error = 1
    if p.error == 0
        result_2 = p_current_token(p)
        if p_expect(p, TOK_NEWLINE) == 0
            p.error = 1
    if p.error == 0
        return  stmt_return(p, null, result_1.line, result_1.col) 

    if p.error == 0
        return null
    return null

fn parse_if_stmt(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: *Expr
    var result_3: *Stmt
    var result_4: *Stmt

    result_1 = p_current_token(p)
    if p_expect(p, TOK_IF) == 0
        p.error = 1
    if p.error == 0
        result_2 = parse_expr(p)
    if p.error == 0
        result_3 = parse_block(p)
    if p.error == 0
        result_4 = parse_else_clause(p)
    if p.error == 0
        return  stmt_if(p, result_2, result_3, result_4, result_1.line, result_1.col) 

    if p.error == 0
        return null
    return null

fn parse_else_clause(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: *Stmt

    result_1 = p_current_token(p)
    if p_expect(p, TOK_ELSE) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_2 = parse_block(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        return  result_2 

    # Try next alternative
    p.pos = start_pos
    p.error = 0

    # Alternative 2

    if p.error == 0
        return  null 

    if p.error == 0
        return null
    return null

fn parse_while_stmt(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: *Expr
    var result_3: *Stmt

    result_1 = p_current_token(p)
    if p_expect(p, TOK_WHILE) == 0
        p.error = 1
    if p.error == 0
        result_2 = parse_expr(p)
    if p.error == 0
        result_3 = parse_block(p)
    if p.error == 0
        return  stmt_while(p, result_2, result_3, result_1.line, result_1.col) 

    if p.error == 0
        return null
    return null

fn parse_break_stmt(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_BREAK) == 0
        p.error = 1
    if p.error == 0
        result_2 = p_current_token(p)
        if p_expect(p, TOK_NEWLINE) == 0
            p.error = 1
    if p.error == 0
        return  stmt_break(p, result_1.line, result_1.col) 

    if p.error == 0
        return null
    return null

fn parse_continue_stmt(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_CONTINUE) == 0
        p.error = 1
    if p.error == 0
        result_2 = p_current_token(p)
        if p_expect(p, TOK_NEWLINE) == 0
            p.error = 1
    if p.error == 0
        return  stmt_continue(p, result_1.line, result_1.col) 

    if p.error == 0
        return null
    return null

fn parse_assign_stmt(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: Token
    var result_2: Token
    var result_3: *Expr
    var result_4: Token

    result_1 = p_current_token(p)
    if p_expect(p, TOK_IDENT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_2 = p_current_token(p)
        if p_expect(p, TOK_ASSIGN) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        result_3 = parse_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_4 = p_current_token(p)
        if p_expect(p, TOK_NEWLINE) == 0
            p.error = 1
            p.pos = start_pos
    if p.error == 0
        return  stmt_assign_name(p, result_1.start, result_1.len, result_3, result_1.line, result_1.col)

    # Try next alternative: Compound assignment name op= val
    p.pos = start_pos
    p.error = 0

    # Alternative 1b: name += value (and other compound operators)
    var result_ca1_1: Token
    var result_ca1_2: Token
    var result_ca1_3: *Expr
    var result_ca1_4: Token

    result_ca1_1 = p_current_token(p)
    if p_expect(p, TOK_IDENT) == 0
        p.error = 1
        p.pos = start_pos
    if p.error == 0
        result_ca1_2 = p_current_token(p)
        if is_compound_assign_tok(result_ca1_2.kind) == 0
            p.error = 1
            p.pos = start_pos
        else
            p.pos = p.pos + 1
    if p.error == 0
        result_ca1_3 = parse_expr(p)
        if p.error != 0
            p.pos = start_pos
    if p.error == 0
        result_ca1_4 = p_current_token(p)
