fn parse_expr_stmt(p: *Parser) -> *Stmt
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: *Expr
    var result_2: Token

    result_1 = parse_expr(p)
    if p.error == 0
        result_2 = p_current_token(p)
        if p_expect(p, TOK_NEWLINE) == 0
            p.error = 1
    if p.error == 0
        return  stmt_expr(p, result_1, result_1.span.line, result_1.span.col) 

    if p.error == 0
        return null
    return null

fn parse_expr(p: *Parser) -> *Expr
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: *Expr

    result_1 = parse_or_expr(p)

    if p.error == 0
        return result_1
    return null

fn parse_or_expr(p: *Parser) -> *Expr
    let start_pos: i32 = p.pos

    # Alternative 1
    var result_1: *Expr
    var result_2: *BinaryOp

    result_1 = parse_and_expr(p)
    if p.error == 0
        result_2 = parse_or_tail(p)
    if p.error == 0
        return  apply_binary_opt_p(p, result_1, result_2) 

    if p.error == 0
        return null
    return null

fn parse_or_tail(p: *Parser) -> *BinaryOp
    let start_pos: i32 = p.pos

