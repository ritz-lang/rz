# ritz1/src/emit_min.ritz - Minimal LLVM IR Emitter
#
# A simple emitter for ritz1 bootstrap.
# Supports the core language features needed for self-hosting.

import ast
import tokens_gen

# =============================================================================
# IR Buffer - Simple string builder
# =============================================================================

struct IRBuf
  data: *i8
  len: i32
  cap: i32

fn irbuf_init(b: *IRBuf, data: *i8, cap: i32)
    b.data = data
    b.len = 0
    b.cap = cap

fn irbuf_put_byte(b: *IRBuf, ch: i32)
    if b.len < b.cap
        *(b.data + b.len) = ch as i8
        b.len = b.len + 1

fn irbuf_put_str(b: *IRBuf, s: *u8, slen: i32)
    for i in 0..slen
        irbuf_put_byte(b, (*(s + i)) as i32)

fn irbuf_put_cstr(b: *IRBuf, s: *u8)
    var i: i32 = 0
    while *(s + i) != 0
        irbuf_put_byte(b, (*(s + i)) as i32)
        i = i + 1

fn irbuf_put_int(b: *IRBuf, n: i64)
    if n < 0
        irbuf_put_byte(b, 45)  # '-'
        irbuf_put_int(b, 0 - n)
        return
    if n == 0
        irbuf_put_byte(b, 48)  # '0'
        return
    var digits: [20]i8 = [0; 20]
    var count: i32 = 0
    var val: i64 = n
    while val > 0
        digits[count] = (48 + (val % 10)) as i8
        val = val / 10
        count = count + 1
    # Output in reverse
    var j: i32 = count - 1
    while j >= 0
        irbuf_put_byte(b, digits[j] as i32)
        j = j - 1

fn irbuf_newline(b: *IRBuf)
    irbuf_put_byte(b, 10)  # '\n'

# Helper to compare strings (for constant detection)
fn str_eq(a: *u8, b: *u8, len: i32) -> i32
    for i in 0..len
        if *(a + i) != *(b + i)
            return 0
    return 1

# =============================================================================
# Minimal Emitter
# =============================================================================

struct MinEmitter
    b: IRBuf
    next_reg: i32
    next_str: i32
    next_label: i32
    returned: i32           # 1 if we've emitted a return statement
    last_expr_reg: i32      # Register of last evaluated expression (for implicit return)
    last_expr_type: i32     # Type of last evaluated expression (for call arguments)
    # String constants for deferred emission
    str_ptrs: [64]*u8
    str_lens: [64]i32
    str_count: i32
    # Local variable tracking (name -> alloca register)
    var_names: [64]*u8
    var_lens: [64]i32
    var_regs: [64]i32
    var_types: [64]i32
    var_count: i32

pub fn emit_init(e: *MinEmitter, buf: *i8, cap: i32)
    irbuf_init(@e.b, buf, cap)
    e.next_reg = 1
    e.next_str = 0
    e.next_label = 0
    e.returned = 0
    e.last_expr_reg = 0
    e.last_expr_type = TYPE_I64
    e.str_count = 0
    e.var_count = 0

fn emit_fresh_reg(e: *MinEmitter) -> i32
    let r: i32 = e.next_reg
    e.next_reg = r + 1
    r

fn emit_add_string(e: *MinEmitter, ptr: *u8, len: i32) -> i32
    let id: i32 = e.str_count
    e.str_ptrs[id] = ptr
    e.str_lens[id] = len
    e.str_count = id + 1
    id

fn emit_fresh_label(e: *MinEmitter) -> i32
    let l: i32 = e.next_label
    e.next_label = l + 1
    l

# Add a local variable and return its alloca register
fn emit_add_var(e: *MinEmitter, name: *u8, name_len: i32, reg: i32, var_type: i32)
    let id: i32 = e.var_count
    e.var_names[id] = name
    e.var_lens[id] = name_len
    e.var_regs[id] = reg
    e.var_types[id] = var_type
    e.var_count = id + 1

# Look up a local variable, return alloca register or -1 if not found
fn emit_lookup_var(e: *MinEmitter, name: *u8, name_len: i32) -> i32
    for i in 0..e.var_count
        if e.var_lens[i] == name_len
            var found: i32 = 1
            for j in 0..name_len
                if *(e.var_names[i] + j) != *(name + j)
                    found = 0
                    break
            if found == 1
                return e.var_regs[i]
    return 0 - 1  # Not found

# Get type of a local variable
fn emit_var_type(e: *MinEmitter, name: *u8, name_len: i32) -> i32
    for i in 0..e.var_count
        if e.var_lens[i] == name_len
            var found: i32 = 1
            for j in 0..name_len
                if *(e.var_names[i] + j) != *(name + j)
                    found = 0
                    break
            if found == 1
                return e.var_types[i]
    return TYPE_I64  # Default

# Clear local variables (for function reset)
fn emit_clear_vars(e: *MinEmitter)
    e.var_count = 0

# Emit LLVM type for a Ritz type kind
fn emit_type(e: *MinEmitter, ty: i32)
    if ty == TYPE_VOID
        irbuf_put_cstr(@e.b, c"void")
    else if ty == TYPE_I8
        irbuf_put_cstr(@e.b, c"i8")
    else if ty == TYPE_I16
        irbuf_put_cstr(@e.b, c"i16")
    else if ty == TYPE_I32
        irbuf_put_cstr(@e.b, c"i32")
    else if ty == TYPE_I64
        irbuf_put_cstr(@e.b, c"i64")
    else if ty == TYPE_U8
        irbuf_put_cstr(@e.b, c"i8")
    else if ty == TYPE_U16
        irbuf_put_cstr(@e.b, c"i16")
    else if ty == TYPE_U32
        irbuf_put_cstr(@e.b, c"i32")
    else if ty == TYPE_U64
        irbuf_put_cstr(@e.b, c"i64")
    else if ty == TYPE_BOOL
        irbuf_put_cstr(@e.b, c"i1")
    else if ty == TYPE_PTR or ty == TYPE_PTR_PTR or ty == TYPE_REF or ty == TYPE_MUT_REF
        irbuf_put_cstr(@e.b, c"ptr")
    else
        # Default to i64 for unknown types
        irbuf_put_cstr(@e.b, c"i64")

# Emit normalized type for function signatures (i64 for all integers, ptr for pointers)
fn emit_sig_type(e: *MinEmitter, ty: i32)
    if ty == TYPE_VOID
        irbuf_put_cstr(@e.b, c"void")
    else if ty == TYPE_PTR or ty == TYPE_PTR_PTR or ty == TYPE_REF or ty == TYPE_MUT_REF
        irbuf_put_cstr(@e.b, c"ptr")
    else
        # All integer types become i64 for uniform calling convention
        irbuf_put_cstr(@e.b, c"i64")

# Emit all deferred string constants
fn emit_strings(e: *MinEmitter)
    for i in 0..e.str_count
        # @.str.N = private constant [len+1 x i8] c"...\00"
        irbuf_put_cstr(@e.b, c"@.str.")
        irbuf_put_int(@e.b, i as i64)
        irbuf_put_cstr(@e.b, c" = private constant [")
        irbuf_put_int(@e.b, (e.str_lens[i] + 1) as i64)
        irbuf_put_cstr(@e.b, c" x i8] c\"")
        # Emit string bytes, escaping special characters
        let ptr: *u8 = e.str_ptrs[i]
        let len: i32 = e.str_lens[i]
        for j in 0..len
            let ch: u8 = *(ptr + j)
            if ch == 10        # \n
                irbuf_put_cstr(@e.b, c"\\0A")
            else if ch == 13   # \r
                irbuf_put_cstr(@e.b, c"\\0D")
            else if ch == 9    # \t
                irbuf_put_cstr(@e.b, c"\\09")
            else if ch == 0    # \0
                irbuf_put_cstr(@e.b, c"\\00")
            else if ch == 34   # "
                irbuf_put_cstr(@e.b, c"\\22")
            else if ch == 92   # \
                irbuf_put_cstr(@e.b, c"\\5C")
            else
                irbuf_put_byte(@e.b, ch as i32)
        irbuf_put_cstr(@e.b, c"\\00\"")
        irbuf_newline(@e.b)

# =============================================================================
# Expression Emission
# =============================================================================

# Helper to determine if an expression evaluates to a pointer type
fn expr_is_ptr(e: *MinEmitter, expr: *Expr) -> i32
    if expr == null
        return 0
    if expr.kind == EXPR_STRING_LIT
        return 1  # String literals are pointers
    if expr.kind == EXPR_IDENT
        # Look up the variable type
        let var_ty: i32 = emit_var_type(e, expr.ident_ptr, expr.ident_len)
        if var_ty == TYPE_PTR or var_ty == TYPE_PTR_PTR or var_ty == TYPE_REF or var_ty == TYPE_MUT_REF
            return 1
    return 0

# Returns the register number where the result is stored
fn emit_expr(e: *MinEmitter, expr: *Expr) -> i32
    if expr == null
        return 0

    if expr.kind == EXPR_INT_LIT
        let r: i32 = emit_fresh_reg(e)
        irbuf_put_cstr(@e.b, c"  %")
        irbuf_put_int(@e.b, r as i64)
        irbuf_put_cstr(@e.b, c" = add i64 0, ")
        irbuf_put_int(@e.b, expr.int_val)
        irbuf_newline(@e.b)
        return r

    if expr.kind == EXPR_STRING_LIT
        let str_id: i32 = emit_add_string(e, expr.string_ptr, expr.string_len)
        let r: i32 = emit_fresh_reg(e)
        irbuf_put_cstr(@e.b, c"  %")
        irbuf_put_int(@e.b, r as i64)
        irbuf_put_cstr(@e.b, c" = getelementptr [")
        irbuf_put_int(@e.b, (expr.string_len + 1) as i64)
        irbuf_put_cstr(@e.b, c" x i8], ptr @.str.")
        irbuf_put_int(@e.b, str_id as i64)
        irbuf_put_cstr(@e.b, c", i64 0, i64 0")
        irbuf_newline(@e.b)
        e.last_expr_type = TYPE_PTR  # String literals are pointers
        return r

    if expr.kind == EXPR_IDENT
        # Check for well-known constants first
        if expr.ident_len == 5
            if str_eq(expr.ident_ptr, c"STDIN", 5)
                let r: i32 = emit_fresh_reg(e)
                irbuf_put_cstr(@e.b, c"  %")
                irbuf_put_int(@e.b, r as i64)
                irbuf_put_cstr(@e.b, c" = add i64 0, 0")
                irbuf_newline(@e.b)
                e.last_expr_type = TYPE_I64
                return r
        if expr.ident_len == 6
            if str_eq(expr.ident_ptr, c"STDOUT", 6)
                let r: i32 = emit_fresh_reg(e)
                irbuf_put_cstr(@e.b, c"  %")
                irbuf_put_int(@e.b, r as i64)
                irbuf_put_cstr(@e.b, c" = add i64 0, 1")
                irbuf_newline(@e.b)
                e.last_expr_type = TYPE_I64
                return r
            if str_eq(expr.ident_ptr, c"STDERR", 6)
                let r: i32 = emit_fresh_reg(e)
                irbuf_put_cstr(@e.b, c"  %")
                irbuf_put_int(@e.b, r as i64)
                irbuf_put_cstr(@e.b, c" = add i64 0, 2")
                irbuf_newline(@e.b)
                e.last_expr_type = TYPE_I64
                return r

        # Load variable value and extend to i64 for uniform arithmetic
        let var_reg: i32 = emit_lookup_var(e, expr.ident_ptr, expr.ident_len)
        if var_reg >= 0
            let var_ty: i32 = emit_var_type(e, expr.ident_ptr, expr.ident_len)
            let load_r: i32 = emit_fresh_reg(e)
            irbuf_put_cstr(@e.b, c"  %")
            irbuf_put_int(@e.b, load_r as i64)
            irbuf_put_cstr(@e.b, c" = load ")
            emit_type(e, var_ty)
            irbuf_put_cstr(@e.b, c", ptr %")
            irbuf_put_int(@e.b, var_reg as i64)
            irbuf_newline(@e.b)
            # If not i64 or pointer type, extend to i64 for uniform arithmetic
            if var_ty != TYPE_I64 and var_ty != TYPE_U64 and var_ty != TYPE_PTR and var_ty != TYPE_PTR_PTR
                let ext_r: i32 = emit_fresh_reg(e)
                irbuf_put_cstr(@e.b, c"  %")
                irbuf_put_int(@e.b, ext_r as i64)
                irbuf_put_cstr(@e.b, c" = sext ")
                emit_type(e, var_ty)
                irbuf_put_cstr(@e.b, c" %")
                irbuf_put_int(@e.b, load_r as i64)
                irbuf_put_cstr(@e.b, c" to i64")
                irbuf_newline(@e.b)
                e.last_expr_type = TYPE_I64
                return ext_r
            # Set last_expr_type based on variable type
            if var_ty == TYPE_PTR or var_ty == TYPE_PTR_PTR
                e.last_expr_type = TYPE_PTR
            else
                e.last_expr_type = TYPE_I64
            return load_r
        # Unknown identifier - might be a global or parameter
        e.last_expr_type = TYPE_I64
        return 0

    if expr.kind == EXPR_BINARY
        let left_reg: i32 = emit_expr(e, expr.left)
        let right_reg: i32 = emit_expr(e, expr.right)
        let r: i32 = emit_fresh_reg(e)
        irbuf_put_cstr(@e.b, c"  %")
        irbuf_put_int(@e.b, r as i64)
        irbuf_put_cstr(@e.b, c" = ")
        # Emit operation
        if expr.op == OP_ADD
            irbuf_put_cstr(@e.b, c"add i64 %")
        else if expr.op == OP_SUB
            irbuf_put_cstr(@e.b, c"sub i64 %")
        else if expr.op == OP_MUL
            irbuf_put_cstr(@e.b, c"mul i64 %")
        else if expr.op == OP_DIV
            irbuf_put_cstr(@e.b, c"sdiv i64 %")
        else if expr.op == OP_MOD
            irbuf_put_cstr(@e.b, c"srem i64 %")
        else if expr.op == OP_EQ
            irbuf_put_cstr(@e.b, c"icmp eq i64 %")
        else if expr.op == OP_NE
            irbuf_put_cstr(@e.b, c"icmp ne i64 %")
        else if expr.op == OP_LT
            irbuf_put_cstr(@e.b, c"icmp slt i64 %")
        else if expr.op == OP_GT
            irbuf_put_cstr(@e.b, c"icmp sgt i64 %")
        else if expr.op == OP_LE
            irbuf_put_cstr(@e.b, c"icmp sle i64 %")
        else if expr.op == OP_GE
            irbuf_put_cstr(@e.b, c"icmp sge i64 %")
        else if expr.op == OP_BIT_AND
            irbuf_put_cstr(@e.b, c"and i64 %")
        else if expr.op == OP_BIT_OR
            irbuf_put_cstr(@e.b, c"or i64 %")
        else if expr.op == OP_BIT_XOR
            irbuf_put_cstr(@e.b, c"xor i64 %")
        else
            # Default to add
            irbuf_put_cstr(@e.b, c"add i64 %")
        irbuf_put_int(@e.b, left_reg as i64)
        irbuf_put_cstr(@e.b, c", %")
        irbuf_put_int(@e.b, right_reg as i64)
        irbuf_newline(@e.b)
        return r

    if expr.kind == EXPR_CAST
        # Type cast: expr as Type
        # For i32 -> i64: sext; for larger to smaller: trunc; for same size: just pass through
        # For now, simplify: i64 is our universal type, so just return the operand reg
        let operand_reg: i32 = emit_expr(e, expr.left)
        # Since we use i64 uniformly, casts are mostly no-ops
        # The expression has already been extended to i64 by emit_expr
        return operand_reg

    if expr.kind == EXPR_UNARY
        let operand_reg: i32 = emit_expr(e, expr.operand)
        let r: i32 = emit_fresh_reg(e)
        irbuf_put_cstr(@e.b, c"  %")
        irbuf_put_int(@e.b, r as i64)
        irbuf_put_cstr(@e.b, c" = ")
        if expr.op == OP_NEG or expr.op == UOP_NEG
            irbuf_put_cstr(@e.b, c"sub i64 0, %")
            irbuf_put_int(@e.b, operand_reg as i64)
        else if expr.op == OP_NOT or expr.op == UOP_NOT
            irbuf_put_cstr(@e.b, c"xor i1 1, %")
            irbuf_put_int(@e.b, operand_reg as i64)
        else if expr.op == OP_BIT_NOT or expr.op == UOP_BIT_NOT
            irbuf_put_cstr(@e.b, c"xor i64 -1, %")
            irbuf_put_int(@e.b, operand_reg as i64)
        else if expr.op == OP_DEREF or expr.op == UOP_DEREF
            irbuf_put_cstr(@e.b, c"load i64, ptr %")
            irbuf_put_int(@e.b, operand_reg as i64)
        else
            # Default - just copy
            irbuf_put_cstr(@e.b, c"add i64 0, %")
            irbuf_put_int(@e.b, operand_reg as i64)
        irbuf_newline(@e.b)
        return r

    if expr.kind == EXPR_CALL
        # Emit call - for now just "print" builtin
        if expr.func_name_len == 5
            # Check if it's "print"
            let n: *u8 = expr.func_name
            if *n == 112 and *(n+1) == 114 and *(n+2) == 105 and *(n+3) == 110 and *(n+4) == 116
                # print(str) - emit syscall write
                let arg_reg: i32 = emit_expr(e, expr.args)
                # strlen call to get length
                let len_reg: i32 = emit_fresh_reg(e)
                irbuf_put_cstr(@e.b, c"  %")
                irbuf_put_int(@e.b, len_reg as i64)
                irbuf_put_cstr(@e.b, c" = call i64 @strlen(ptr %")
                irbuf_put_int(@e.b, arg_reg as i64)
                irbuf_put_cstr(@e.b, c")")
                irbuf_newline(@e.b)
                # syscall3(1, 1, ptr, len) - write to stdout
                let r: i32 = emit_fresh_reg(e)
                irbuf_put_cstr(@e.b, c"  %")
                irbuf_put_int(@e.b, r as i64)
                irbuf_put_cstr(@e.b, c" = call i64 @syscall3(i64 1, i64 1, ptr %")
                irbuf_put_int(@e.b, arg_reg as i64)
                irbuf_put_cstr(@e.b, c", i64 %")
                irbuf_put_int(@e.b, len_reg as i64)
                irbuf_put_cstr(@e.b, c")")
                irbuf_newline(@e.b)
                return r
        # Generic function call - emit arguments and track types
        var arg_regs: [16]i32 = [0; 16]
        var arg_is_ptr: [16]i32 = [0; 16]
        var arg_count: i32 = 0
        var arg: *Expr = expr.args
        while arg != null and arg_count < 16
            arg_is_ptr[arg_count] = expr_is_ptr(e, arg)
            arg_regs[arg_count] = emit_expr(e, arg)
            arg_count = arg_count + 1
            arg = arg.next
        # Emit call
        let r: i32 = emit_fresh_reg(e)
        irbuf_put_cstr(@e.b, c"  %")
        irbuf_put_int(@e.b, r as i64)
        irbuf_put_cstr(@e.b, c" = call i64 @")
        irbuf_put_str(@e.b, expr.func_name, expr.func_name_len)
        irbuf_put_cstr(@e.b, c"(")
        for i in 0..arg_count
            if i > 0
                irbuf_put_cstr(@e.b, c", ")
            if arg_is_ptr[i] == 1
                irbuf_put_cstr(@e.b, c"ptr %")
            else
                irbuf_put_cstr(@e.b, c"i64 %")
            irbuf_put_int(@e.b, arg_regs[i] as i64)
        irbuf_put_cstr(@e.b, c")")
        irbuf_newline(@e.b)
        return r

    if expr.kind == EXPR_INDEX
        # Array/pointer indexing: base[index]
        # Check if base is a double pointer (e.g., argv: **u8)
        var is_ptr_ptr: i32 = 0
        if expr.left != null and expr.left.kind == EXPR_IDENT
            let base_ty: i32 = emit_var_type(e, expr.left.ident_ptr, expr.left.ident_len)
            if base_ty == TYPE_PTR_PTR
                is_ptr_ptr = 1
        # Emit base pointer expression
        let base_reg: i32 = emit_expr(e, expr.left)
        # Emit index expression
        let idx_reg: i32 = emit_expr(e, expr.right)
        if is_ptr_ptr == 1
            # Double pointer: getelementptr ptr, ptr %base, i64 %idx
            # Each element is a pointer (8 bytes on x86_64)
            let gep_reg: i32 = emit_fresh_reg(e)
            irbuf_put_cstr(@e.b, c"  %")
            irbuf_put_int(@e.b, gep_reg as i64)
            irbuf_put_cstr(@e.b, c" = getelementptr ptr, ptr %")
            irbuf_put_int(@e.b, base_reg as i64)
            irbuf_put_cstr(@e.b, c", i64 %")
            irbuf_put_int(@e.b, idx_reg as i64)
            irbuf_newline(@e.b)
            # Load the pointer
            let load_reg: i32 = emit_fresh_reg(e)
            irbuf_put_cstr(@e.b, c"  %")
            irbuf_put_int(@e.b, load_reg as i64)
            irbuf_put_cstr(@e.b, c" = load ptr, ptr %")
            irbuf_put_int(@e.b, gep_reg as i64)
            irbuf_newline(@e.b)
            # Set last_expr_type to indicate this is a pointer result
            e.last_expr_type = TYPE_PTR
            return load_reg
        else
            # Single pointer to bytes: getelementptr i8, ptr %base, i64 %idx
            let gep_reg: i32 = emit_fresh_reg(e)
            irbuf_put_cstr(@e.b, c"  %")
            irbuf_put_int(@e.b, gep_reg as i64)
            irbuf_put_cstr(@e.b, c" = getelementptr i8, ptr %")
            irbuf_put_int(@e.b, base_reg as i64)
            irbuf_put_cstr(@e.b, c", i64 %")
            irbuf_put_int(@e.b, idx_reg as i64)
            irbuf_newline(@e.b)
            # Load the byte and zero-extend to i64
            let load_reg: i32 = emit_fresh_reg(e)
            irbuf_put_cstr(@e.b, c"  %")
            irbuf_put_int(@e.b, load_reg as i64)
            irbuf_put_cstr(@e.b, c" = load i8, ptr %")
            irbuf_put_int(@e.b, gep_reg as i64)
            irbuf_newline(@e.b)
            let ext_reg: i32 = emit_fresh_reg(e)
            irbuf_put_cstr(@e.b, c"  %")
            irbuf_put_int(@e.b, ext_reg as i64)
            irbuf_put_cstr(@e.b, c" = zext i8 %")
            irbuf_put_int(@e.b, load_reg as i64)
            irbuf_put_cstr(@e.b, c" to i64")
            irbuf_newline(@e.b)
            e.last_expr_type = TYPE_I64
            return ext_reg

    0  # Fallback

# =============================================================================
# Statement Emission
# =============================================================================

fn emit_stmt(e: *MinEmitter, stmt: *Stmt)
    if stmt == null
        return

    if stmt.kind == STMT_VAR_DECL
        # For type inference: if we have an init expression but no explicit type,
        # we need to evaluate the expression to determine the type.
        # This is stored in e.last_expr_type after calling emit_expr.
        var actual_type: i32 = stmt.var_type

        if stmt.var_init != null
            # Reset and evaluate to get expression type
            e.last_expr_type = TYPE_I64
            let init_val: i32 = emit_expr(e, stmt.var_init)

            # If declared type is default TYPE_I64 but expression yields pointer, use ptr
            if stmt.var_type == TYPE_I64 and (e.last_expr_type == TYPE_PTR or e.last_expr_type == TYPE_PTR_PTR)
                actual_type = TYPE_PTR

            # Now emit alloca with correct type
            let r: i32 = emit_fresh_reg(e)
            irbuf_put_cstr(@e.b, c"  %")
            irbuf_put_int(@e.b, r as i64)
            irbuf_put_cstr(@e.b, c" = alloca ")
            emit_type(e, actual_type)
            irbuf_newline(@e.b)
            # Track the variable
            emit_add_var(e, stmt.var_name, stmt.var_name_len, r, actual_type)

            # Now emit store with the init value we already computed
            var store_reg: i32 = init_val
            if actual_type != TYPE_I64 and actual_type != TYPE_U64 and actual_type != TYPE_PTR and actual_type != TYPE_PTR_PTR
                store_reg = emit_fresh_reg(e)
                irbuf_put_cstr(@e.b, c"  %")
                irbuf_put_int(@e.b, store_reg as i64)
                irbuf_put_cstr(@e.b, c" = trunc i64 %")
                irbuf_put_int(@e.b, init_val as i64)
                irbuf_put_cstr(@e.b, c" to ")
                emit_type(e, actual_type)
                irbuf_newline(@e.b)
            irbuf_put_cstr(@e.b, c"  store ")
            emit_type(e, actual_type)
            irbuf_put_cstr(@e.b, c" %")
            irbuf_put_int(@e.b, store_reg as i64)
            irbuf_put_cstr(@e.b, c", ptr %")
            irbuf_put_int(@e.b, r as i64)
            irbuf_newline(@e.b)
        else
            # No init expression - just allocate with declared type
            let r: i32 = emit_fresh_reg(e)
            irbuf_put_cstr(@e.b, c"  %")
            irbuf_put_int(@e.b, r as i64)
            irbuf_put_cstr(@e.b, c" = alloca ")
            emit_type(e, stmt.var_type)
            irbuf_newline(@e.b)
            # Track the variable
            emit_add_var(e, stmt.var_name, stmt.var_name_len, r, stmt.var_type)
        emit_stmt(e, stmt.next)
        return

    if stmt.kind == STMT_ASSIGN
        # Find the variable
        let var_reg: i32 = emit_lookup_var(e, stmt.assign_target, stmt.assign_target_len)
        if var_reg >= 0
            let val_reg: i32 = emit_expr(e, stmt.assign_value)
            let var_ty: i32 = emit_var_type(e, stmt.assign_target, stmt.assign_target_len)
            # Truncate from i64 to var type if needed
            var store_reg: i32 = val_reg
            if var_ty != TYPE_I64 and var_ty != TYPE_U64 and var_ty != TYPE_PTR
                store_reg = emit_fresh_reg(e)
                irbuf_put_cstr(@e.b, c"  %")
                irbuf_put_int(@e.b, store_reg as i64)
                irbuf_put_cstr(@e.b, c" = trunc i64 %")
                irbuf_put_int(@e.b, val_reg as i64)
                irbuf_put_cstr(@e.b, c" to ")
                emit_type(e, var_ty)
                irbuf_newline(@e.b)
            irbuf_put_cstr(@e.b, c"  store ")
            emit_type(e, var_ty)
            irbuf_put_cstr(@e.b, c" %")
            irbuf_put_int(@e.b, store_reg as i64)
            irbuf_put_cstr(@e.b, c", ptr %")
            irbuf_put_int(@e.b, var_reg as i64)
            irbuf_newline(@e.b)
        emit_stmt(e, stmt.next)
        return

    if stmt.kind == STMT_IF
        let cond_reg: i32 = emit_expr(e, stmt.if_cond)
        let then_label: i32 = emit_fresh_label(e)
        let else_label: i32 = emit_fresh_label(e)
        let end_label: i32 = emit_fresh_label(e)
        # Branch
        irbuf_put_cstr(@e.b, c"  br i1 %")
        irbuf_put_int(@e.b, cond_reg as i64)
        irbuf_put_cstr(@e.b, c", label %L")
        irbuf_put_int(@e.b, then_label as i64)
        irbuf_put_cstr(@e.b, c", label %L")
        if stmt.if_else != null
            irbuf_put_int(@e.b, else_label as i64)
        else
            irbuf_put_int(@e.b, end_label as i64)
        irbuf_newline(@e.b)
        # Then block
        irbuf_put_cstr(@e.b, c"L")
        irbuf_put_int(@e.b, then_label as i64)
        irbuf_put_cstr(@e.b, c":")
        irbuf_newline(@e.b)
        let saved_last: i32 = e.last_expr_reg
        emit_stmt(e, stmt.if_then)
        let then_result: i32 = e.last_expr_reg
        irbuf_put_cstr(@e.b, c"  br label %L")
        irbuf_put_int(@e.b, end_label as i64)
        irbuf_newline(@e.b)
        # Else block (if present)
        var else_result: i32 = 0
        if stmt.if_else != null
            irbuf_put_cstr(@e.b, c"L")
            irbuf_put_int(@e.b, else_label as i64)
            irbuf_put_cstr(@e.b, c":")
            irbuf_newline(@e.b)
            e.last_expr_reg = saved_last
            emit_stmt(e, stmt.if_else)
            else_result = e.last_expr_reg
            irbuf_put_cstr(@e.b, c"  br label %L")
            irbuf_put_int(@e.b, end_label as i64)
            irbuf_newline(@e.b)
        # End label
        irbuf_put_cstr(@e.b, c"L")
        irbuf_put_int(@e.b, end_label as i64)
        irbuf_put_cstr(@e.b, c":")
        irbuf_newline(@e.b)
        # If both branches produce values, emit a phi node
        if stmt.if_else != null and then_result > 0 and else_result > 0
            let phi_reg: i32 = emit_fresh_reg(e)
            irbuf_put_cstr(@e.b, c"  %")
            irbuf_put_int(@e.b, phi_reg as i64)
            irbuf_put_cstr(@e.b, c" = phi i64 [ %")
            irbuf_put_int(@e.b, then_result as i64)
            irbuf_put_cstr(@e.b, c", %L")
            irbuf_put_int(@e.b, then_label as i64)
            irbuf_put_cstr(@e.b, c" ], [ %")
            irbuf_put_int(@e.b, else_result as i64)
            irbuf_put_cstr(@e.b, c", %L")
            irbuf_put_int(@e.b, else_label as i64)
            irbuf_put_cstr(@e.b, c" ]")
            irbuf_newline(@e.b)
            e.last_expr_reg = phi_reg
        else if then_result > 0
            e.last_expr_reg = then_result
        emit_stmt(e, stmt.next)
        return

    if stmt.kind == STMT_WHILE
        let cond_label: i32 = emit_fresh_label(e)
        let body_label: i32 = emit_fresh_label(e)
        let end_label: i32 = emit_fresh_label(e)
        # Jump to condition check
        irbuf_put_cstr(@e.b, c"  br label %L")
        irbuf_put_int(@e.b, cond_label as i64)
        irbuf_newline(@e.b)
        # Condition block
        irbuf_put_cstr(@e.b, c"L")
        irbuf_put_int(@e.b, cond_label as i64)
        irbuf_put_cstr(@e.b, c":")
        irbuf_newline(@e.b)
        let cond_reg: i32 = emit_expr(e, stmt.while_cond)
        irbuf_put_cstr(@e.b, c"  br i1 %")
        irbuf_put_int(@e.b, cond_reg as i64)
        irbuf_put_cstr(@e.b, c", label %L")
        irbuf_put_int(@e.b, body_label as i64)
        irbuf_put_cstr(@e.b, c", label %L")
        irbuf_put_int(@e.b, end_label as i64)
        irbuf_newline(@e.b)
        # Body block
        irbuf_put_cstr(@e.b, c"L")
        irbuf_put_int(@e.b, body_label as i64)
        irbuf_put_cstr(@e.b, c":")
        irbuf_newline(@e.b)
        emit_stmt(e, stmt.while_body)
        irbuf_put_cstr(@e.b, c"  br label %L")
        irbuf_put_int(@e.b, cond_label as i64)
        irbuf_newline(@e.b)
        # End label
        irbuf_put_cstr(@e.b, c"L")
        irbuf_put_int(@e.b, end_label as i64)
        irbuf_put_cstr(@e.b, c":")
        irbuf_newline(@e.b)
        emit_stmt(e, stmt.next)
        return

    if stmt.kind == STMT_EXPR
        let r: i32 = emit_expr(e, stmt.expr)
        e.last_expr_reg = r  # Track for implicit return
        emit_stmt(e, stmt.next)
        return

    if stmt.kind == STMT_RETURN
        e.returned = 1
        if stmt.return_value != null
            let r: i32 = emit_expr(e, stmt.return_value)
            irbuf_put_cstr(@e.b, c"  ret i64 %")
            irbuf_put_int(@e.b, r as i64)
            irbuf_newline(@e.b)
        else
            irbuf_put_cstr(@e.b, c"  ret void")
            irbuf_newline(@e.b)
        # Don't emit next - return terminates
        return

    # Fallback - emit next statement
    emit_stmt(e, stmt.next)

# =============================================================================
# Function Emission
# =============================================================================

fn emit_function(e: *MinEmitter, f: *FnDef)
    if f == null
        return

    # Reset state for new function
    e.next_reg = 1
    e.next_label = 0
    e.returned = 0
    e.last_expr_reg = 0
    emit_clear_vars(e)

    # Emit function signature - use i64 for all integer types for uniform calling convention
    irbuf_put_cstr(@e.b, c"define ")
    emit_sig_type(e, f.return_type)
    irbuf_put_cstr(@e.b, c" @")
    irbuf_put_str(@e.b, f.name, f.name_len)
    irbuf_put_cstr(@e.b, c"(")

    # Emit parameters (all integers become i64)
    var param: *Param = f.params
    var first: i32 = 1
    while param != null
        if first == 0
            irbuf_put_cstr(@e.b, c", ")
        emit_sig_type(e, param.param_type)
        irbuf_put_cstr(@e.b, c" %p.")
        irbuf_put_str(@e.b, param.name, param.name_len)
        first = 0
        param = param.next

    irbuf_put_cstr(@e.b, c") {")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"entry:")
    irbuf_newline(@e.b)

    # Allocate stack space for parameters and copy them
    # Use proper types for pointer parameters
    param = f.params
    while param != null
        let r: i32 = emit_fresh_reg(e)
        irbuf_put_cstr(@e.b, c"  %")
        irbuf_put_int(@e.b, r as i64)
        irbuf_put_cstr(@e.b, c" = alloca ")
        emit_sig_type(e, param.param_type)
        irbuf_newline(@e.b)
        # Store parameter value
        irbuf_put_cstr(@e.b, c"  store ")
        emit_sig_type(e, param.param_type)
        irbuf_put_cstr(@e.b, c" %p.")
        irbuf_put_str(@e.b, param.name, param.name_len)
        irbuf_put_cstr(@e.b, c", ptr %")
        irbuf_put_int(@e.b, r as i64)
        irbuf_newline(@e.b)
        # Track the variable with its actual type
        emit_add_var(e, param.name, param.name_len, r, param.param_type)
        param = param.next

    # Emit body statements
    emit_stmt(e, f.body)

    # If no explicit return, add a default or use last expression
    if e.returned == 0
        if f.return_type == TYPE_VOID
            irbuf_put_cstr(@e.b, c"  ret void")
            irbuf_newline(@e.b)
        else if e.last_expr_reg > 0
            # Use the last expression's value for implicit return
            # All integer returns are i64 now (from emit_sig_type)
            irbuf_put_cstr(@e.b, c"  ret i64 %")
            irbuf_put_int(@e.b, e.last_expr_reg as i64)
            irbuf_newline(@e.b)
        else
            # No last expression, return 0 as i64
            irbuf_put_cstr(@e.b, c"  ret i64 0")
            irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"}")
    irbuf_newline(@e.b)
    irbuf_newline(@e.b)

    # Emit next function
    emit_function(e, f.next)

# =============================================================================
# Module Emission
# =============================================================================

pub fn emit_module(e: *MinEmitter, m: *Module)
    # Module header
    irbuf_put_cstr(@e.b, c"; ModuleID = 'ritz1'")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"target triple = \"x86_64-unknown-linux-gnu\"")
    irbuf_newline(@e.b)
    irbuf_newline(@e.b)

    # Helper functions
    # strlen implementation
    irbuf_put_cstr(@e.b, c"define i64 @strlen(ptr %s) {")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"entry:")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"  br label %loop")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"loop:")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"  %i = phi i64 [ 0, %entry ], [ %next, %loop ]")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"  %ptr = getelementptr i8, ptr %s, i64 %i")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"  %c = load i8, ptr %ptr")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"  %done = icmp eq i8 %c, 0")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"  %next = add i64 %i, 1")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"  br i1 %done, label %exit, label %loop")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"exit:")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"  ret i64 %i")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"}")
    irbuf_newline(@e.b)
    irbuf_newline(@e.b)

    # syscall3 for print builtin
    irbuf_put_cstr(@e.b, c"define i64 @syscall3(i64 %n, i64 %a1, ptr %a2, i64 %a3) {")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"  %ret = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},{rsi},{rdx}\"(i64 %n, i64 %a1, ptr %a2, i64 %a3)")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"  ret i64 %ret")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"}")
    irbuf_newline(@e.b)
    irbuf_newline(@e.b)

    # Syscall wrappers using inline asm
    irbuf_put_cstr(@e.b, c"; Syscall implementations")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"define i64 @sys_read(i32 %fd, ptr %buf, i64 %count) {")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"  %fd64 = sext i32 %fd to i64")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"  %ret = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},{rsi},{rdx}\"(i64 0, i64 %fd64, ptr %buf, i64 %count)")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"  ret i64 %ret")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"}")
    irbuf_newline(@e.b)
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"define i64 @sys_write(i32 %fd, ptr %buf, i64 %count) {")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"  %fd64 = sext i32 %fd to i64")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"  %ret = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},{rsi},{rdx}\"(i64 1, i64 %fd64, ptr %buf, i64 %count)")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"  ret i64 %ret")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"}")
    irbuf_newline(@e.b)
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"define i32 @sys_open(ptr %path, i32 %flags, i32 %mode) {")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"  %flags64 = sext i32 %flags to i64")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"  %mode64 = sext i32 %mode to i64")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"  %ret = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},{rsi},{rdx}\"(i64 2, ptr %path, i64 %flags64, i64 %mode64)")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"  %ret32 = trunc i64 %ret to i32")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"  ret i32 %ret32")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"}")
    irbuf_newline(@e.b)
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"define i32 @sys_close(i32 %fd) {")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"  %fd64 = sext i32 %fd to i64")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"  %ret = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi}\"(i64 3, i64 %fd64)")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"  %ret32 = trunc i64 %ret to i32")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"  ret i32 %ret32")
    irbuf_newline(@e.b)
    irbuf_put_cstr(@e.b, c"}")
    irbuf_newline(@e.b)
    irbuf_newline(@e.b)

    # Emit functions
    emit_function(e, m.functions)

    # Emit deferred string constants
    emit_strings(e)

    # NOTE: Entry point (_start) is NOT emitted here.
    # When linking, use an external runtime .o file (e.g., ritz_start.x86_64.o)
    # that provides _start and calls main(argc, argv).
    # This allows ritz1-compiled code to be linked with -nostdlib.

# =============================================================================
# Access functions
# =============================================================================

pub fn emit_get_output(e: *MinEmitter) -> *i8
    e.b.data

pub fn emit_get_len(e: *MinEmitter) -> i32
    e.b.len
