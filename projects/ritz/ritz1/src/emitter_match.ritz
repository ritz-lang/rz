# ritz1/src/emitter_match.ritz - Match expression/statement lowering
#
# Added in ritz-task-87. Lowers `match scrutinee \n PATTERN => BODY ...`
# to a linear if-else-if chain in LLVM IR.
#
# Design notes:
# - Scrutinee is evaluated once into a register (i64).
# - Each arm emits:
#     match_test:  icmp eq i64 %scrut, <literal>   (or tag comparison for variants)
#                  br i1 %cond, label %match_body_N, label %match_next_N
#     match_body_N:
#                  ... arm body emitted ...
#                  br label %match_end
#     match_next_N: (next arm's test, or fallthrough to end)
# - Wildcard/ident arms unconditionally branch to their body (effectively
#   the catch-all / default). Once we emit an unconditional arm, later
#   arms become dead code (emitted but unreachable).
# - `pass` arms emit a zero value for their body result.
# - Match result is collected via phi over (arm_body_result, arm_exit_label)
#   pairs so `let x = match ...` works.
#
# Variant patterns (Some(v) / None / Ok(v) / Err(_)) use a tag convention:
#   Some(x) / Ok(x) -> high 16 bits = 1, low 48 bits = x
#   None / Err(x)   -> high 16 bits = 0
# Encoded via simple bitwise ops so we don't need an enum-type system yet.
# See emit_variant_constructor_call in emitter_expr_call.ritz for the
# producer side of this convention.

import ritzlib.sys
import ritzlib.io
import ritzlib.str
import ritzlib.gvec
import ritzlib.memory

import ast
import ast_helpers
import tokens_gen
import emitter_core
import emitter_expr

# Phi result tracking during emit_match.
# We need to collect (value_reg, exit_label) pairs across all non-pass arms
# so we can emit a terminating phi at the match.end label.
# Using a fixed-size array; MAX_MATCH_ARMS is plenty for real match stmts.
const MAX_MATCH_ARMS: i32 = 64

struct MatchResult
    values: [64]i32   # register numbers holding each arm's result
    labels: [64]i32   # exit label numbers for each arm's result
    count: i32

# Check if a variant name denotes the "Some/Ok" (tagged) side of its enum.
# Returns 1 if tag should be 1, 0 otherwise.
# Heuristic: names "Some", "Ok" are the carrier variants; "None", "Err"
# are the null variants. Any other variant currently defaults to tag 0
# (which makes arbitrary enum matching equivalent to "match anything").
fn variant_is_tag_one(name: *u8, len: i32) -> i32
    if len == 4
        # "Some"
        if *name == 83 and *(name + 1) == 111 and *(name + 2) == 109 and *(name + 3) == 101
            return 1
    if len == 2
        # "Ok"
        if *name == 79 and *(name + 1) == 107
            return 1
    return 0

# Emit a check for the scrutinee being of a given variant against the
# struct layout `{ i8 tag, [N x i8] payload }` (ritz-task-133 parity with
# ritz0).  `slot_reg` is a pointer to the scrutinee struct (the match
# prelude spills the scrutinee value into an alloca once).  `enum_name`
# is the `%Result$.../Option$...` type name used to GEP.  `tag_one == 1`
# checks for the carrier variant (Ok / Some); 0 checks for the null
# variant (Err / None).  ritz0 tag convention: Ok=0 Err=1 Some=0 None=1,
# so carrier <=> tag==0.
# User-enum variant check: load the tag byte and compare against an
# arbitrary i8 tag value (instead of the tagged-enum 0/1 binary check).
# Used when the scrutinee's enum is a parser-tracked user enum (Shade,
# etc.) and the match arm names a specific variant by index.
fn emit_variant_tag_check_eq(s: *EmitterState, slot_reg: i32, enum_name: *u8, enum_name_len: i32, tag_value: i32) -> i32
    let tag_ptr: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, tag_ptr)
    emit_str(s, c" = getelementptr %")
    emit_name(s, enum_name, enum_name_len)
    emit_str(s, c", ptr ")
    emit_reg(s, slot_reg)
    emit_str(s, c", i32 0, i32 0\n")
    let tag_reg: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, tag_reg)
    emit_str(s, c" = load i8, ptr ")
    emit_reg(s, tag_ptr)
    emit_str(s, c"\n")
    let cmp_reg: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, cmp_reg)
    emit_str(s, c" = icmp eq i8 ")
    emit_reg(s, tag_reg)
    emit_str(s, c", ")
    emit_int(s, tag_value as i64)
    emit_str(s, c"\n")
    return cmp_reg

fn emit_variant_tag_check(s: *EmitterState, slot_reg: i32, enum_name: *u8, enum_name_len: i32, tag_one: i32) -> i32
    let tag_ptr: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, tag_ptr)
    emit_str(s, c" = getelementptr %")
    emit_name(s, enum_name, enum_name_len)
    emit_str(s, c", ptr ")
    emit_reg(s, slot_reg)
    emit_str(s, c", i32 0, i32 0\n")
    let tag_reg: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, tag_reg)
    emit_str(s, c" = load i8, ptr ")
    emit_reg(s, tag_ptr)
    emit_str(s, c"\n")
    let cmp_reg: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, cmp_reg)
    if tag_one == 1
        # carrier (Ok/Some) → tag == 0
        emit_str(s, c" = icmp eq i8 ")
    else
        # null (Err/None) → tag != 0
        emit_str(s, c" = icmp ne i8 ")
    emit_reg(s, tag_reg)
    emit_str(s, c", 0\n")
    return cmp_reg

# Extract the variant payload as an i64 (the common scalar case).  Payload
# sits at field 1 (the `[N x i8]` buffer).  Callers widen to i64 because
# ritz1's downstream arithmetic / call paths operate on i64 registers.
fn emit_variant_payload(s: *EmitterState, slot_reg: i32, enum_name: *u8, enum_name_len: i32) -> i32
    let pay_ptr: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, pay_ptr)
    emit_str(s, c" = getelementptr %")
    emit_name(s, enum_name, enum_name_len)
    emit_str(s, c", ptr ")
    emit_reg(s, slot_reg)
    emit_str(s, c", i32 0, i32 1\n")
    let r: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, r)
    emit_str(s, c" = load i64, ptr ")
    emit_reg(s, pay_ptr)
    emit_str(s, c"\n")
    return r

# Scalar-scrutinee fallback (non-enum `match x on int`).
fn emit_variant_tag_check_i64(s: *EmitterState, scrut_reg: i32, tag_one: i32) -> i32
    # Legacy packed-i64 path retained only for non-enum match.  In practice
    # ritz1 code only uses `match` on Result/Option + integers; this branch
    # covers the latter.  Returns a conservative always-false for "variant"
    # patterns against a scalar scrutinee.
    let r: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, r)
    emit_str(s, c" = icmp eq i64 ")
    emit_reg(s, scrut_reg)
    emit_str(s, c", 0\n")
    if tag_one == 1
        return r
    let inv: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, inv)
    emit_str(s, c" = xor i1 ")
    emit_reg(s, r)
    emit_str(s, c", true\n")
    return inv

# Emit match body, returning (result_reg, exit_label) via MatchResult slot.
# For PAT_VARIANT arms with PAT_IDENT inner (e.g. `Ok(v) => v`), the inner
# name is bound to the extracted payload for the duration of the arm body,
# then popped via local_count rollback. (task-99 #105)
fn emit_match_arm_body(s: *EmitterState, arm: *MatchArm, scrut_reg: i32, scrut_slot: i32, enum_name: *u8, enum_name_len: i32, result: *MatchResult, arm_index: i32, end_label: i32)
    # Save local_count so arm-scoped bindings get popped after the body.
    let saved_local_count: i32 = s.local_count

    # Bind variant payload to inner pattern name on `Constructor(binding)`.
    if arm.pattern_kind == PAT_VARIANT
        if arm.pattern_inner_kind == PAT_IDENT
            if arm.pattern_inner_name_len > 0
                var is_wildcard: i32 = 0
                if arm.pattern_inner_name_len == 1
                    if *arm.pattern_inner_name == 95   # '_'
                        is_wildcard = 1
                if is_wildcard == 0
                    var payload_reg: i32 = 0
                    if scrut_slot != 0 and enum_name != null and enum_name_len > 0
                        payload_reg = emit_variant_payload(s, scrut_slot, enum_name, enum_name_len)
                    else
                        # Non-enum scrutinee (shouldn't reach here in practice).
                        payload_reg = scrut_reg
                    let alloca_reg: i32 = next_reg(s)
                    emit_str(s, c"  ")
                    emit_reg(s, alloca_reg)
                    emit_str(s, c" = alloca i64  ; match payload bind\n")
                    emit_str(s, c"  store i64 ")
                    emit_reg(s, payload_reg)
                    emit_str(s, c", ptr ")
                    emit_reg(s, alloca_reg)
                    emit_str(s, c"\n")
                    add_local(s, arm.pattern_inner_name, arm.pattern_inner_name_len, alloca_reg, TYPE_I64)

    var body_reg: i32 = 0
    if arm.is_pass == 1
        body_reg = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, body_reg)
        emit_str(s, c" = add i64 0, 0  ; match arm: pass\n")
    else if arm.body != null
        body_reg = emit_expr(s, arm.body)
    else
        body_reg = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, body_reg)
        emit_str(s, c" = add i64 0, 0  ; match arm: null body\n")

    s.local_count = saved_local_count

    let exit_label: i32 = s.current_label
    if arm_index < MAX_MATCH_ARMS
        result.values[arm_index] = body_reg
        result.labels[arm_index] = exit_label
        if arm_index + 1 > result.count
            result.count = arm_index + 1

    emit_str(s, c"  br label %")
    emit_label(s, end_label)
    emit_str(s, c"\n")

# Emit one arm's condition + body.  `scrut_slot` is an alloca holding the
# scrutinee struct (when enum_name is non-null), or 0 for scalar scrutinees.
fn emit_match_arm(s: *EmitterState, arm: *MatchArm, scrut_reg: i32, scrut_slot: i32, enum_name: *u8, enum_name_len: i32, result: *MatchResult, arm_index: i32, end_label: i32)
    let body_label: i32 = next_label(s)
    let next_label_id: i32 = next_label(s)

    var cond_reg: i32 = 0
    var always_true: i32 = 0
    let is_enum_match: i32 = (enum_name != null) and (enum_name_len > 0)

    if arm.pattern_kind == PAT_INT_LIT
        cond_reg = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, cond_reg)
        emit_str(s, c" = icmp eq i64 ")
        emit_reg(s, scrut_reg)
        emit_str(s, c", ")
        emit_int(s, arm.pattern_int)
        emit_str(s, c"\n")
    else if arm.pattern_kind == PAT_WILDCARD
        always_true = 1
    else if arm.pattern_kind == PAT_IDENT
        # Ident pattern — unit variant (None/Err/Light/Dark) or a binding.
        # First try the user-enum tracker so user-declared variants resolve
        # to their proper tag index; fall back to None/Err special-casing
        # for tagged enums; otherwise treat as a binding (always_true).
        if is_enum_match == 1 and is_enum_type(enum_name, enum_name_len) == 1
            let user_idx: i32 = enum_variant_index(enum_name, enum_name_len, arm.pattern_name, arm.pattern_name_len)
            if user_idx >= 0
                cond_reg = emit_variant_tag_check_eq(s, scrut_slot, enum_name, enum_name_len, user_idx)
        if cond_reg == 0 and arm.pattern_name_len == 4
            if *arm.pattern_name == 78 and *(arm.pattern_name + 1) == 111
                if *(arm.pattern_name + 2) == 110 and *(arm.pattern_name + 3) == 101
                    # "None": null variant → tag != 0
                    if is_enum_match == 1
                        cond_reg = emit_variant_tag_check(s, scrut_slot, enum_name, enum_name_len, 0)
                    else
                        cond_reg = emit_variant_tag_check_i64(s, scrut_reg, 0)
        if cond_reg == 0
            always_true = 1
    else if arm.pattern_kind == PAT_VARIANT
        # User-declared enum: look up the variant's tag index from the
        # parser's enum tracker (Shade.Light=0, Shade.Dark=1).  Falls back
        # to the binary Some/Ok-vs-None/Err mapping for tagged enums.
        if is_enum_match == 1 and is_enum_type(enum_name, enum_name_len) == 1
            let user_idx: i32 = enum_variant_index(enum_name, enum_name_len, arm.pattern_name, arm.pattern_name_len)
            if user_idx >= 0
                cond_reg = emit_variant_tag_check_eq(s, scrut_slot, enum_name, enum_name_len, user_idx)
            else
                always_true = 1
        else
            let tag_one: i32 = variant_is_tag_one(arm.pattern_name, arm.pattern_name_len)
            if is_enum_match == 1
                cond_reg = emit_variant_tag_check(s, scrut_slot, enum_name, enum_name_len, tag_one)
            else
                cond_reg = emit_variant_tag_check_i64(s, scrut_reg, tag_one)
    else
        always_true = 1

    if always_true == 1
        emit_str(s, c"  br label %")
        emit_label(s, body_label)
        emit_str(s, c"\n")
    else
        emit_str(s, c"  br i1 ")
        emit_reg(s, cond_reg)
        emit_str(s, c", label %")
        emit_label(s, body_label)
        emit_str(s, c", label %")
        emit_label(s, next_label_id)
        emit_str(s, c"\n")

    emit_label(s, body_label)
    emit_str(s, c":\n")
    s.current_label = body_label
    emit_match_arm_body(s, arm, scrut_reg, scrut_slot, enum_name, enum_name_len, result, arm_index, end_label)

    emit_label(s, next_label_id)
    emit_str(s, c":\n")
    s.current_label = next_label_id

# Resolve the scrutinee's enum struct type name by peeking at the AST:
#   * EXPR_IDENT   -> local's recorded struct type
#   * EXPR_CALL    -> callee's return struct type (by name)
#   * EXPR_UNARY*  -> unwrap deref (match *res) and recurse
# Returns 1 with (out_name, out_len) filled, 0 otherwise.
fn resolve_scrutinee_enum(s: *EmitterState, scr: *Expr, out_name: **u8, out_len: *i32) -> i32
    if scr.kind == EXPR_IDENT
        let loc: *LocalVar = find_local_struct_name(s, scr.ident_ptr, scr.ident_len)
        if loc != null
            if loc.type_name_len > 0
                if is_tagged_enum_type(loc.type_name, loc.type_name_len) == 1
                    *out_name = loc.type_name
                    *out_len = loc.type_name_len
                    return 1
                # Also recognize user-declared enums (Shade, etc.) via the
                # parser's per-enum tracker.  Their layout is `{ i8 tag }`
                # (no payload) so match logic uses the same tag-byte GEP.
                if is_enum_type(loc.type_name, loc.type_name_len) == 1
                    *out_name = loc.type_name
                    *out_len = loc.type_name_len
                    return 1
    else if scr.kind == EXPR_CALL
        var full_name: [256]u8
        var full_len: i32 = 0
        for i in 0..scr.func_name_len
            full_name[full_len] = *(scr.func_name + i)
            full_len = full_len + 1
        if scr.call_type_suffix_len > 0
            for i in 0..scr.call_type_suffix_len
                full_name[full_len] = *(scr.call_type_suffix + i)
                full_len = full_len + 1
        let fd: *FnDef = find_fn(s, @full_name[0], full_len)
        if fd != null
            if fd.return_type == TYPE_STRUCT
                if fd.return_type_name_len > 0
                    if is_tagged_enum_type(fd.return_type_name, fd.return_type_name_len) == 1
                        *out_name = fd.return_type_name
                        *out_len = fd.return_type_name_len
                        return 1
                    if is_enum_type(fd.return_type_name, fd.return_type_name_len) == 1
                        *out_name = fd.return_type_name
                        *out_len = fd.return_type_name_len
                        return 1
    else if scr.kind == EXPR_UNARY
        if scr.op == OP_DEREF
            return resolve_scrutinee_enum(s, scr.operand, out_name, out_len)
    *out_name = null
    *out_len = 0
    return 0

# Main entry: emit a match construct. Returns the phi register holding
# the match's result value (or 0 if no arms contribute).
fn emit_match(s: *EmitterState, scrutinee: *Expr, arms: *MatchArm) -> i32
    # Detect whether the scrutinee is a tagged-enum struct; if so, spill
    # it into an alloca once so every arm can GEP the same pointer.
    var enum_name: *u8 = null
    var enum_name_len: i32 = 0
    let is_enum: i32 = resolve_scrutinee_enum(s, scrutinee, @enum_name, @enum_name_len)

    # Evaluate scrutinee
    let scrut_reg: i32 = emit_expr(s, scrutinee)
    var scrut_slot: i32 = 0
    if is_enum == 1
        scrut_slot = next_reg(s)
        emit_str(s, c"  ")
        emit_reg(s, scrut_slot)
        emit_str(s, c" = alloca %")
        emit_name(s, enum_name, enum_name_len)
        emit_str(s, c"  ; match scrut spill\n")
        emit_str(s, c"  store %")
        emit_name(s, enum_name, enum_name_len)
        emit_str(s, c" ")
        emit_reg(s, scrut_reg)
        emit_str(s, c", ptr ")
        emit_reg(s, scrut_slot)
        emit_str(s, c"\n")

    let end_label: i32 = next_label(s)
    var result: MatchResult
    result.count = 0

    var arm: *MatchArm = arms
    var idx: i32 = 0
    while arm != null
        emit_match_arm(s, arm, scrut_reg, scrut_slot, enum_name, enum_name_len, @result, idx, end_label)
        arm = arm.next
        idx = idx + 1

    # Current block is the last "next" block — it has no matching arm, so
    # fall through to match end with a default value. This is the
    # non-exhaustive safety net.
    let fallthrough_reg: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, fallthrough_reg)
    emit_str(s, c" = add i64 0, 0  ; match: non-exhaustive fallthrough\n")
    let fallthrough_label: i32 = s.current_label
    emit_str(s, c"  br label %")
    emit_label(s, end_label)
    emit_str(s, c"\n")

    # End block with phi over all arm results + fallthrough
    emit_label(s, end_label)
    emit_str(s, c":\n")
    s.current_label = end_label

    # Emit phi: ( arm_result, arm_exit_label ) for each recorded arm,
    # plus ( fallthrough_reg, fallthrough_label ) at the end.
    if result.count == 0
        # No arms — return fallthrough value
        return fallthrough_reg

    let phi_reg: i32 = next_reg(s)
    emit_str(s, c"  ")
    emit_reg(s, phi_reg)
    emit_str(s, c" = phi i64 ")
    var i: i32 = 0
    while i < result.count
        if i > 0
            emit_str(s, c", ")
        emit_str(s, c"[ ")
        emit_reg(s, result.values[i])
        emit_str(s, c", %")
        emit_label(s, result.labels[i])
        emit_str(s, c" ]")
        i = i + 1
    # Add fallthrough entry
    emit_str(s, c", [ ")
    emit_reg(s, fallthrough_reg)
    emit_str(s, c", %")
    emit_label(s, fallthrough_label)
    emit_str(s, c" ]\n")
    return phi_reg
