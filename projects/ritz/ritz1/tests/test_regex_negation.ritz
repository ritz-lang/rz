# Test regex negation patterns
import nfa
import regex

[[test]]
fn test_negated_class_simple() -> i32
  # Test [^a] - should match 'b' but not 'a'
  var nfa_states: [256]NFAState = [NFAState { id: 0, is_accept: 0, token_type: 0 }; 256]
  var nfa_trans: [512]Transition = [Transition { kind: 0, char_lo: 0, char_hi: 0, from_state: 0, to_state: 0 }; 512]
  var nfa_obj: NFA = NFA { states: @nfa_states[0], state_count: 0, transitions: @nfa_trans[0], trans_count: 0, start_state: 0 }

  # Parse [^a]
  let pattern: *i8 = "[^a]"
  let frag: NFAFragment = regex_parse(pattern, 4, @nfa_obj)
  thompson_accept(@nfa_obj, frag, 1)

  # Test: should match 'b'
  let test_b: *i8 = "b"
  assert nfa_accepts(@nfa_obj, test_b, 1) == 1, "Should match 'b'"

  # Test: should NOT match 'a'
  let test_a: *i8 = "a"
  assert nfa_accepts(@nfa_obj, test_a, 1) == 0, "Should NOT match 'a'"

  0

[[test]]
fn test_negated_class_quote() -> i32
  # Test [^"] - should match 'a' but not '"'
  var nfa_states: [256]NFAState = [NFAState { id: 0, is_accept: 0, token_type: 0 }; 256]
  var nfa_trans: [512]Transition = [Transition { kind: 0, char_lo: 0, char_hi: 0, from_state: 0, to_state: 0 }; 512]
  var nfa_obj: NFA = NFA { states: @nfa_states[0], state_count: 0, transitions: @nfa_trans[0], trans_count: 0, start_state: 0 }

  # Parse [^"]
  let pattern: *i8 = "[^\"]"
  let frag: NFAFragment = regex_parse(pattern, 4, @nfa_obj)
  thompson_accept(@nfa_obj, frag, 1)

  # Test: should match 'a'
  let test_a: *i8 = "a"
  assert nfa_accepts(@nfa_obj, test_a, 1) == 1, "Should match 'a'"

  # Test: should NOT match '"'
  let test_quote: *i8 = "\""
  assert nfa_accepts(@nfa_obj, test_quote, 1) == 0, "Should NOT match quote"

  0

[[test]]
fn test_string_pattern() -> i32
  # Test full string pattern: "[^"]*"
  var nfa_states: [256]NFAState = [NFAState { id: 0, is_accept: 0, token_type: 0 }; 256]
  var nfa_trans: [512]Transition = [Transition { kind: 0, char_lo: 0, char_hi: 0, from_state: 0, to_state: 0 }; 512]
  var nfa_obj: NFA = NFA { states: @nfa_states[0], state_count: 0, transitions: @nfa_trans[0], trans_count: 0, start_state: 0 }

  # Parse "a"
  let pattern: *i8 = "\"a\""
  let frag: NFAFragment = regex_parse(pattern, 3, @nfa_obj)
  thompson_accept(@nfa_obj, frag, 1)

  # Test: should match "a"
  let test: *i8 = "\"a\""
  assert nfa_accepts(@nfa_obj, test, 3) == 1, "Should match quoted string"

  0
