# ritz1/ir/simple_codegen.ritz - Simple Code Generator for A/B Testing
#
# Minimal code generator that:
# 1. Parses a Ritz file (using ritz0's parser output as input)
# 2. Generates LLVM IR text using ir_builder
# 3. Writes IR to file
#
# Design: Instead of reimplementing the parser in Ritz, we'll use a simpler
# approach for initial A/B testing:
# - Take a simplified AST representation as input (JSON-like)
# - Generate IR from that representation
# - This lets us validate IR generation correctness before tackling full parsing

import mem
import types
import ir_builder

# =============================================================================
# Simple AST Representation
# =============================================================================
#
# For A/B testing, we'll start with a minimal subset:
# - Single main() function
# - Integer return value
# - No parameters
#
# Example input representation:
# fn main() -> i32 { return 42 }

struct SimpleFunction
  name: *i8        # Function name
  name_len: i32
  ret_type: i32    # TY_* constant
  body_value: i64  # For simple return statements

fn codegen_simple_function(b: *IRBuilder, func: *SimpleFunction) -> i32
  # Emit function header
  ir_emit_fn_start_len(b, func.name, func.name_len, func.ret_type)
  ir_emit_fn_header_end(b)

  # Emit return statement
  ir_emit_ret_imm(b, func.ret_type, func.body_value)

  # Emit function end
  ir_emit_fn_end(b)
  0

# =============================================================================
# Simple Module Generation
# =============================================================================

fn codegen_simple_module(arena: *Arena, module_name: *i8, func: *SimpleFunction) -> *i8
  # Create IR builder
  let b: *IRBuilder = ir_builder_new(arena, 8192)

  # Emit module header
  ir_emit_module_header(b, module_name)

  # Emit function
  codegen_simple_function(b, func)

  # Emit _start wrapper
  ir_emit_fn_start(b, "_start", TY_VOID)
  ir_emit_fn_header_end(b)

  # Call main and use result as exit code
  let call_id: i32 = ir_fresh_id(b)
  ir_emit_call_start(b, call_id, func.ret_type, "main")
  ir_emit_call_end(b)

  # Exit syscall (60 on x86_64 Linux)
  let exit_asm: *i8 = "syscall"
  let exit_constraints: *i8 = "={rax},{rax},{rdi},~{rcx},~{r11}"
  ir_put_indent(b)
  ir_put(b, "call void asm sideeffect \"")
  ir_put(b, exit_asm)
  ir_put(b, "\", \"")
  ir_put(b, exit_constraints)
  ir_put(b, "\"(i64 60, ")
  ir_emit_type(b, func.ret_type)
  ir_put(b, " %")
  ir_put_int(b, call_id as i64)
  ir_put(b, ")")
  ir_newline(b)

  ir_put_indent(b)
  ir_put(b, "unreachable")
  ir_newline(b)

  ir_emit_fn_end(b)

  # Emit module footer
  ir_emit_module_footer(b)

  # Return output
  ir_builder_get_output(b)

# =============================================================================
# Example Usage (for testing)
# =============================================================================

[[test]]
fn test_codegen_simple_main()
  let arena_buf: *i8 = __builtin_alloca(16384) as *i8
  var arena: Arena = Arena { base: arena_buf, size: 16384, used: 0 }

  var func: SimpleFunction = SimpleFunction {
    name: "main",
    name_len: 4,
    ret_type: TY_I32,
    body_value: 42
  }

  let output: *i8 = codegen_simple_module(@arena, "test_module", @func)

  # Verify output contains expected elements
  assert str_contains(output, "define i32 @main()") == 1, "should have main function"
  assert str_contains(output, "ret i32 42") == 1, "should return 42"
  assert str_contains(output, "define void @_start()") == 1, "should have _start"
  assert str_contains(output, "call i32 @main()") == 1, "should call main from _start"

# Helper function from test_ir_builder.ritz
fn str_contains(haystack: *i8, needle: *i8) -> i32
  var h: i32 = 0
  while *(haystack + h) != 0
    var n: i32 = 0
    var matched: i32 = 1
    while *(needle + n) != 0
      let ch: i32 = *(haystack + h + n) as i32 & 255
      let cn: i32 = *(needle + n) as i32 & 255
      if ch != cn
        matched = 0
      n = n + 1
    if matched == 1
      return 1
    h = h + 1
  0
