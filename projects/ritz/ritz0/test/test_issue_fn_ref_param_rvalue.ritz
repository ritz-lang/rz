# Regression: ref params should accept rvalue temporaries via auto-spill.

struct S
    n: i32

impl S
    fn clone_self(self) -> S
        self

fn use_ref(s: @S) -> i32
    s.n

[[test]]
fn test_ref_param_rvalue_methodcall() -> i32
    let a = S { n: 9 }
    if use_ref(a.clone_self()) == 9
        0
    else
        1
