# Regression: ritz1 must accept primitive type tokens (i32, i64, u8, …) as
# expression idents inside `sizeof(...)`.  Before AGAST #174 the grammar's
# `primary_expr` only accepted IDENT, so `sizeof(i32)` failed to parse and
# the surrounding function was silently dropped from the emitted IR.  The
# downstream symptom was a `ret %Option$ %.X` / i64 type mismatch in
# mausoleum's concurrent_bench because the parser-dropped `buffer_pool_new`
# was replaced by a default-typed `declare i64 @buffer_pool_new(...)`
# extern, then called from `buffer_pool_default` which DID emit with the
# correct `%Option$` return type.
import ritzlib.memory

fn alloc_size_i32(count: i64) -> i64
    return count * sizeof(i32)

fn alloc_size_i64(count: i64) -> i64
    return count * sizeof(i64)

fn alloc_size_u8(count: i64) -> i64
    return count * sizeof(u8)

fn alloc_size_u16(count: i64) -> i64
    return count * sizeof(u16)

fn alloc_size_u32(count: i64) -> i64
    return count * sizeof(u32)

fn alloc_size_u64(count: i64) -> i64
    return count * sizeof(u64)

[[test]]
fn test_sizeof_primitive() -> i32
    if alloc_size_i32(10) != 40
        return 1
    if alloc_size_i64(10) != 80
        return 2
    if alloc_size_u8(10) != 10
        return 3
    if alloc_size_u16(10) != 20
        return 4
    if alloc_size_u32(10) != 40
        return 5
    if alloc_size_u64(10) != 80
        return 6
    return 0
