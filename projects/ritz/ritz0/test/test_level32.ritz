# test_level32.ritz - Implicit deref for Box<T>
#
# Tests that Box<T> types can be accessed directly with field syntax:
#   b.field instead of box_get<T>(@b).field
#
# This is "smart pointer" behavior - the box is automatically dereferenced.

import ritzlib.box
import ritzlib.memory

struct Point
    x: i32
    y: i32

struct Rectangle
    origin: Point
    width: i32
    height: i32

# ============================================================================
# Basic implicit deref
# ============================================================================

[[test]]
fn test_box_point_deref() -> i32
    var pt: Point = Point { x: 10, y: 20 }
    var b: Box<Point> = box_new<Point>(pt)

    # Implicit deref: b.x should work like (*b.ptr).x
    assert b.x == 10, "b.x should be 10"
    assert b.y == 20, "b.y should be 20"

    box_drop<Point>(@b)
    0

[[test]]
fn test_box_modify_through_deref() -> i32
    var pt: Point = Point { x: 1, y: 2 }
    var b: Box<Point> = box_new<Point>(pt)

    # Get pointer and modify via traditional method
    let ptr: *Point = box_as_ptr<Point>(@b)
    ptr.x = 100

    # Verify via implicit deref
    assert b.x == 100, "b.x should be 100 after modification"

    box_drop<Point>(@b)
    0

# ============================================================================
# Nested struct access
# ============================================================================

[[test]]
fn test_box_nested_field() -> i32
    var origin: Point = Point { x: 5, y: 10 }
    var rect: Rectangle = Rectangle { origin: origin, width: 100, height: 50 }
    var b: Box<Rectangle> = box_new<Rectangle>(rect)

    # Access nested fields through box
    assert b.width == 100, "b.width should be 100"
    assert b.height == 50, "b.height should be 50"

    # Access nested struct field (b.origin.x)
    # Note: This requires chained deref support
    # For now, just test direct fields

    box_drop<Rectangle>(@b)
    0

# ============================================================================
# Box to pointer comparison
# ============================================================================

[[test]]
fn test_box_vs_ptr_access() -> i32
    var pt: Point = Point { x: 42, y: 84 }
    var b: Box<Point> = box_new<Point>(pt)

    # Traditional pointer access
    let ptr: *Point = box_as_ptr<Point>(@b)
    let via_ptr: i32 = ptr.x

    # Implicit deref access
    let via_box: i32 = b.x

    assert via_ptr == via_box, "ptr.x and b.x should be equal"

    box_drop<Point>(@b)
    0

