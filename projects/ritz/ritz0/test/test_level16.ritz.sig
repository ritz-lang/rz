{
  "source_hash": "eecb3c5375b7921e",
  "functions": {
    "test_char_literal_basic": {
      "hash": "cdfb20b981abc810",
      "ir": "define internal i32 @\"test_char_literal_basic\"() !dbg !17\n{\nentry:\n  %\".2\" = trunc i64 65 to i8 , !dbg !29\n  %\".3\" = icmp eq i8 65, %\".2\" , !dbg !29\n  br i1 %\".3\", label %\"assert.pass\", label %\"assert.fail\", !dbg !29\nassert.pass:\n  %\".7\" = trunc i64 122 to i8 , !dbg !31\n  %\".8\" = icmp eq i8 122, %\".7\" , !dbg !31\n  br i1 %\".8\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !31\nassert.fail:\n  %\".5\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !29\n  unreachable\nassert.pass.1:\n  %\".12\" = trunc i64 48 to i8 , !dbg !33\n  %\".13\" = icmp eq i8 48, %\".12\" , !dbg !33\n  br i1 %\".13\", label %\"assert.pass.2\", label %\"assert.fail.2\", !dbg !33\nassert.fail.1:\n  %\".10\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !31\n  unreachable\nassert.pass.2:\n  %\".17\" = trunc i64 10 to i8 , !dbg !35\n  %\".18\" = icmp eq i8 10, %\".17\" , !dbg !35\n  br i1 %\".18\", label %\"assert.pass.3\", label %\"assert.fail.3\", !dbg !35\nassert.fail.2:\n  %\".15\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !33\n  unreachable\nassert.pass.3:\n  %\".22\" = trunc i64 0 to i32 , !dbg !36\n  ret i32 %\".22\", !dbg !36\nassert.fail.3:\n  %\".20\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !35\n  unreachable\n}"
    },
    "test_char_comparison": {
      "hash": "c23275a4f0e3df18",
      "ir": "define internal i32 @\"test_char_comparison\"() !dbg !18\n{\nentry:\n  %\".2\" = icmp ult i8 65, 66 , !dbg !39\n  br i1 %\".2\", label %\"assert.pass\", label %\"assert.fail\", !dbg !39\nassert.pass:\n  %\".6\" = icmp ugt i8 66, 65 , !dbg !40\n  br i1 %\".6\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !40\nassert.fail:\n  %\".4\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !39\n  unreachable\nassert.pass.1:\n  %\".10\" = icmp ule i8 65, 65 , !dbg !41\n  br i1 %\".10\", label %\"assert.pass.2\", label %\"assert.fail.2\", !dbg !41\nassert.fail.1:\n  %\".8\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !40\n  unreachable\nassert.pass.2:\n  %\".14\" = icmp uge i8 66, 65 , !dbg !42\n  br i1 %\".14\", label %\"assert.pass.3\", label %\"assert.fail.3\", !dbg !42\nassert.fail.2:\n  %\".12\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !41\n  unreachable\nassert.pass.3:\n  %\".18\" = trunc i64 0 to i32 , !dbg !43\n  ret i32 %\".18\", !dbg !43\nassert.fail.3:\n  %\".16\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !42\n  unreachable\n}"
    },
    "test_unsigned_high_values": {
      "hash": "0b51246b3bc9176f",
      "ir": "define internal i32 @\"test_unsigned_high_values\"() !dbg !19\n{\nentry:\n  %\".2\" = trunc i64 200 to i8 , !dbg !44\n  %\".3\" = trunc i64 100 to i8 , !dbg !45\n  %\".4\" = icmp ugt i8 %\".2\", %\".3\" , !dbg !46\n  br i1 %\".4\", label %\"assert.pass\", label %\"assert.fail\", !dbg !46\nassert.pass:\n  %\".8\" = icmp ult i8 %\".3\", %\".2\" , !dbg !47\n  br i1 %\".8\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !47\nassert.fail:\n  %\".6\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !46\n  unreachable\nassert.pass.1:\n  %\".12\" = icmp uge i8 %\".2\", %\".3\" , !dbg !48\n  br i1 %\".12\", label %\"assert.pass.2\", label %\"assert.fail.2\", !dbg !48\nassert.fail.1:\n  %\".10\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !47\n  unreachable\nassert.pass.2:\n  %\".16\" = icmp ule i8 %\".3\", %\".2\" , !dbg !49\n  br i1 %\".16\", label %\"assert.pass.3\", label %\"assert.fail.3\", !dbg !49\nassert.fail.2:\n  %\".14\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !48\n  unreachable\nassert.pass.3:\n  %\".20\" = trunc i64 0 to i32 , !dbg !50\n  ret i32 %\".20\", !dbg !50\nassert.fail.3:\n  %\".18\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !49\n  unreachable\n}"
    },
    "test_unsigned_boundary": {
      "hash": "f6ad9b3b66452453",
      "ir": "define internal i32 @\"test_unsigned_boundary\"() !dbg !20\n{\nentry:\n  %\".2\" = trunc i64 127 to i8 , !dbg !51\n  %\".3\" = trunc i64 128 to i8 , !dbg !52\n  %\".4\" = icmp ugt i8 %\".3\", %\".2\" , !dbg !53\n  br i1 %\".4\", label %\"assert.pass\", label %\"assert.fail\", !dbg !53\nassert.pass:\n  %\".8\" = icmp ult i8 %\".2\", %\".3\" , !dbg !54\n  br i1 %\".8\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !54\nassert.fail:\n  %\".6\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !53\n  unreachable\nassert.pass.1:\n  %\".12\" = trunc i64 0 to i32 , !dbg !55\n  ret i32 %\".12\", !dbg !55\nassert.fail.1:\n  %\".10\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !54\n  unreachable\n}"
    },
    "test_unsigned_max": {
      "hash": "ee0165f8a48b229b",
      "ir": "define internal i32 @\"test_unsigned_max\"() !dbg !21\n{\nentry:\n  %\".2\" = trunc i64 255 to i8 , !dbg !56\n  %\".3\" = trunc i64 0 to i8 , !dbg !57\n  %\".4\" = trunc i64 127 to i8 , !dbg !58\n  %\".5\" = icmp ugt i8 %\".2\", %\".3\" , !dbg !59\n  br i1 %\".5\", label %\"assert.pass\", label %\"assert.fail\", !dbg !59\nassert.pass:\n  %\".9\" = icmp ugt i8 %\".2\", %\".4\" , !dbg !60\n  br i1 %\".9\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !60\nassert.fail:\n  %\".7\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !59\n  unreachable\nassert.pass.1:\n  %\".13\" = icmp uge i8 %\".2\", %\".2\" , !dbg !61\n  br i1 %\".13\", label %\"assert.pass.2\", label %\"assert.fail.2\", !dbg !61\nassert.fail.1:\n  %\".11\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !60\n  unreachable\nassert.pass.2:\n  %\".17\" = icmp ult i8 %\".3\", %\".2\" , !dbg !62\n  br i1 %\".17\", label %\"assert.pass.3\", label %\"assert.fail.3\", !dbg !62\nassert.fail.2:\n  %\".15\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !61\n  unreachable\nassert.pass.3:\n  %\".21\" = icmp ule i8 %\".3\", %\".3\" , !dbg !63\n  br i1 %\".21\", label %\"assert.pass.4\", label %\"assert.fail.4\", !dbg !63\nassert.fail.3:\n  %\".19\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !62\n  unreachable\nassert.pass.4:\n  %\".25\" = trunc i64 0 to i32 , !dbg !64\n  ret i32 %\".25\", !dbg !64\nassert.fail.4:\n  %\".23\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !63\n  unreachable\n}"
    },
    "test_u8_division": {
      "hash": "2a071f97e25c0230",
      "ir": "define internal i32 @\"test_u8_division\"() !dbg !22\n{\nentry:\n  %\".2\" = trunc i64 200 to i8 , !dbg !65\n  %\".3\" = trunc i64 10 to i8 , !dbg !66\n  %\".4\" = udiv i8 %\".2\", %\".3\", !dbg !67\n  %\".5\" = trunc i64 20 to i8 , !dbg !68\n  %\".6\" = icmp eq i8 %\".4\", %\".5\" , !dbg !68\n  br i1 %\".6\", label %\"assert.pass\", label %\"assert.fail\", !dbg !68\nassert.pass:\n  %\".10\" = trunc i64 0 to i32 , !dbg !69\n  ret i32 %\".10\", !dbg !69\nassert.fail:\n  %\".8\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !68\n  unreachable\n}"
    },
    "test_u8_modulo": {
      "hash": "10886b9001f5588e",
      "ir": "define internal i32 @\"test_u8_modulo\"() !dbg !23\n{\nentry:\n  %\".2\" = trunc i64 200 to i8 , !dbg !70\n  %\".3\" = trunc i64 30 to i8 , !dbg !71\n  %\".4\" = urem i8 %\".2\", %\".3\", !dbg !72\n  %\".5\" = trunc i64 20 to i8 , !dbg !73\n  %\".6\" = icmp eq i8 %\".4\", %\".5\" , !dbg !73\n  br i1 %\".6\", label %\"assert.pass\", label %\"assert.fail\", !dbg !73\nassert.pass:\n  %\".10\" = trunc i64 0 to i32 , !dbg !74\n  ret i32 %\".10\", !dbg !74\nassert.fail:\n  %\".8\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !73\n  unreachable\n}"
    },
    "test_char_equality": {
      "hash": "e09b0b632c9485a8",
      "ir": "define internal i32 @\"test_char_equality\"() !dbg !24\n{\nentry:\n  %\".2\" = icmp eq i8 88, 88 , !dbg !78\n  br i1 %\".2\", label %\"assert.pass\", label %\"assert.fail\", !dbg !78\nassert.pass:\n  %\".6\" = icmp ne i8 88, 89 , !dbg !79\n  br i1 %\".6\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !79\nassert.fail:\n  %\".4\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !78\n  unreachable\nassert.pass.1:\n  %\".10\" = trunc i64 0 to i32 , !dbg !80\n  ret i32 %\".10\", !dbg !80\nassert.fail.1:\n  %\".8\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !79\n  unreachable\n}"
    },
    "test_mixed_signed_unsigned": {
      "hash": "b51bb26553d95b71",
      "ir": "define internal i32 @\"test_mixed_signed_unsigned\"() !dbg !25\n{\nentry:\n  %\".2\" = trunc i64 200 to i8 , !dbg !81\n  %\".3\" = trunc i64 50 to i8 , !dbg !82\n  %\".4\" = zext i8 %\".2\" to i64 , !dbg !83\n  %\".5\" = trunc i64 %\".4\" to i32 , !dbg !83\n  %\".6\" = sext i8 %\".3\" to i64 , !dbg !84\n  %\".7\" = trunc i64 %\".6\" to i32 , !dbg !84\n  %\".8\" = sext i32 %\".5\" to i64 , !dbg !85\n  %\".9\" = icmp eq i64 %\".8\", 200 , !dbg !85\n  br i1 %\".9\", label %\"assert.pass\", label %\"assert.fail\", !dbg !85\nassert.pass:\n  %\".13\" = sext i32 %\".7\" to i64 , !dbg !86\n  %\".14\" = icmp eq i64 %\".13\", 50 , !dbg !86\n  br i1 %\".14\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !86\nassert.fail:\n  %\".11\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !85\n  unreachable\nassert.pass.1:\n  %\".18\" = trunc i64 0 to i32 , !dbg !87\n  ret i32 %\".18\", !dbg !87\nassert.fail.1:\n  %\".16\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !86\n  unreachable\n}"
    },
    "test_u64_large_values": {
      "hash": "448ebf2d748b121a",
      "ir": "define internal i32 @\"test_u64_large_values\"() !dbg !26\n{\nentry:\n  %\".2\" = icmp ugt i64 10000000000000000000, 1 , !dbg !90\n  br i1 %\".2\", label %\"assert.pass\", label %\"assert.fail\", !dbg !90\nassert.pass:\n  %\".6\" = icmp ult i64 1, 10000000000000000000 , !dbg !91\n  br i1 %\".6\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !91\nassert.fail:\n  %\".4\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !90\n  unreachable\nassert.pass.1:\n  %\".10\" = trunc i64 0 to i32 , !dbg !92\n  ret i32 %\".10\", !dbg !92\nassert.fail.1:\n  %\".8\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !91\n  unreachable\n}"
    },
    "main": {
      "hash": "fd5854211d009d90",
      "ir": "define i32 @\"main\"() !dbg !27\n{\nentry:\n  %\".2\" = trunc i64 0 to i32 , !dbg !93\n  ret i32 %\".2\", !dbg !93\n}"
    }
  },
  "imports": []
}
