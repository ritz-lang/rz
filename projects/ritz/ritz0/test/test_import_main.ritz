# test_import_main.ritz - Test import system
# Tests importing structs, constants, and functions from another file

import test_import_lib

[[test]]
fn test_import_struct() -> i32
  # Can use Point struct from imported file
  var p: Point = Point { x: 10, y: 20 }
  assert p.x == 10, c"Point.x should be 10"
  assert p.y == 20, c"Point.y should be 20"
  0

[[test]]
fn test_import_const() -> i32
  # Can use constants from imported file
  assert ORIGIN_X == 0, c"ORIGIN_X should be 0"
  assert ORIGIN_Y == 0, c"ORIGIN_Y should be 0"
  0

[[test]]
fn test_import_function() -> i32
  # Can call functions from imported file
  var p: Point = Point { x: 3, y: 4 }
  let sum: i32 = point_sum(@p)
  assert sum == 7, c"point_sum should return 7"
  0

[[test]]
fn test_import_function_returns_struct() -> i32
  # Can call functions that return structs
  var a: Point = Point { x: 1, y: 2 }
  var b: Point = Point { x: 3, y: 4 }
  var result: Point = add_points(@a, @b)
  assert result.x == 4, c"result.x should be 4"
  assert result.y == 6, c"result.y should be 6"
  0
