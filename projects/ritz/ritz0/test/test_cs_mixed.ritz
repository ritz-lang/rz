# Test mixed c"..." and s"..." literals in one file.
#
# AGAST #89 / CS1 regression: the lexer already differentiated c"..." and
# s"..." tokens, but ritz1's parser previously collapsed both into a single
# EXPR_STRING_LIT which the emitter typed as *u8 — breaking s"..." → Span<u8>.
# This file exercises both prefixes in the same module to verify the parser
# dispatches on the token kind and the emitter types each one correctly
# (c -> *u8, s -> Span<u8>).

# Local cstrlen so this test doesn't depend on ritzlib.str's strlen variant.
fn cstrlen(p: *u8) -> i64
    var i: i64 = 0
    while *(p + i) != 0
        i = i + 1
    i

[[test]]
fn test_both_prefixes_same_file() -> i32
    let c_ptr: *u8 = c"hi"
    let sv: Span<u8> = "hi"

    # c"..." is a raw null-terminated *u8
    assert cstrlen(c_ptr) == 2
    assert *c_ptr == 104        # 'h'
    assert *(c_ptr + 1) == 105  # 'i'
    assert *(c_ptr + 2) == 0    # NUL terminator

    # s"..." is emitted as Span<u8> — just ensure the declaration compiles.
    let sv_copy: Span<u8> = sv
    0

[[test]]
fn test_prefixes_independent_values() -> i32
    # Same text, different prefixes — each flows through its own AST node.
    let a: *u8 = c"abc"
    let b: Span<u8> = "abc"
    assert cstrlen(a) == 3
    0

[[test]]
fn test_multiple_cstrings() -> i32
    let a: *u8 = c"foo"
    let b: *u8 = c"quux"
    assert cstrlen(a) == 3
    assert cstrlen(b) == 4
    0

[[test]]
fn test_cstring_still_null_terminated() -> i32
    # Regression: CS1 must not drop the NUL on c"..." literals.
    let s: *u8 = c"abc"
    assert *(s + 3) == 0
    0
