# Test level 25: Traits and Impl Blocks
#
# Tests for trait definitions, impl blocks, and method dispatch
# With monomorphization - no vtables, compile-time resolution

# ============================================================================
# Simple struct for testing
# ============================================================================

struct Point
    x: i32
    y: i32

struct Rectangle
    width: i32
    height: i32

# ============================================================================
# Trait definition
# ============================================================================

trait Describable
    fn describe(self: *Self) -> i32

# ============================================================================
# Test: Basic impl block (inherent methods)
# ============================================================================

impl Point
    fn new(x: i32, y: i32) -> Point
        return Point { x: x, y: y }

    fn sum(self: *Point) -> i32
        return self.x + self.y

[[test]]
fn test_inherent_method()
    let p: Point = Point { x: 10, y: 20 }
    let result: i32 = p.sum()
    assert result == 30

# ============================================================================
# Test: Static method call (no self)
# ============================================================================

[[test]]
fn test_static_method()
    # Call Point_new directly since we don't have static method syntax yet
    let p: Point = Point_new(5, 7)
    assert p.x == 5
    assert p.y == 7

# ============================================================================
# Test: Impl block for trait
# ============================================================================

impl Describable for Point
    fn describe(self: *Point) -> i32
        return self.x * 100 + self.y

impl Describable for Rectangle
    fn describe(self: *Rectangle) -> i32
        return self.width * self.height

[[test]]
fn test_trait_impl()
    let p: Point = Point { x: 3, y: 7 }
    let r: Rectangle = Rectangle { width: 4, height: 5 }

    let pd: i32 = p.describe()
    let rd: i32 = r.describe()

    assert pd == 307  # 3 * 100 + 7
    assert rd == 20   # 4 * 5

# ============================================================================
# Test: Method on mutable variable
# ============================================================================

impl Point
    fn double(self: *Point) -> i32
        self.x = self.x * 2
        self.y = self.y * 2
        return self.x + self.y

[[test]]
fn test_method_mutates()
    var p: Point = Point { x: 5, y: 3 }
    let result: i32 = p.double()
    assert result == 16  # (5*2) + (3*2) = 16
    assert p.x == 10
    assert p.y == 6

# ============================================================================
# Test: Multiple methods in impl block
# ============================================================================

impl Rectangle
    fn area(self: *Rectangle) -> i32
        return self.width * self.height

    fn perimeter(self: *Rectangle) -> i32
        return 2 * (self.width + self.height)

[[test]]
fn test_multiple_methods()
    let r: Rectangle = Rectangle { width: 6, height: 4 }
    assert r.area() == 24
    assert r.perimeter() == 20

# ============================================================================
# Test: Method returning self type
# ============================================================================

impl Point
    fn origin() -> Point
        return Point { x: 0, y: 0 }

    fn move_by(self: *Point, dx: i32, dy: i32) -> Point
        return Point { x: self.x + dx, y: self.y + dy }

[[test]]
fn test_method_returns_struct()
    let p: Point = Point { x: 1, y: 2 }
    let p2: Point = p.move_by(10, 20)
    assert p2.x == 11
    assert p2.y == 22
    # Original unchanged
    assert p.x == 1
    assert p.y == 2

# ============================================================================
# Test: Call method on pointer
# ============================================================================

fn modify_point(p: *Point) -> i32
    return p.sum()

[[test]]
fn test_method_on_pointer()
    var p: Point = Point { x: 100, y: 200 }
    let result: i32 = modify_point(@p)
    assert result == 300

# ============================================================================
# Test: Trait with multiple methods
# ============================================================================

trait Shape
    fn area(self: *Self) -> i32
    fn perimeter(self: *Self) -> i32

struct Square
    side: i32

impl Shape for Square
    fn area(self: *Square) -> i32
        return self.side * self.side

    fn perimeter(self: *Square) -> i32
        return 4 * self.side

[[test]]
fn test_trait_multiple_methods()
    let s: Square = Square { side: 5 }
    assert s.area() == 25
    assert s.perimeter() == 20

# ============================================================================
# Main function to run tests manually
# ============================================================================

fn main() -> i32
    0
