# Test level 30: Generic impl blocks
#
# Tests impl<T> Trait for Type<T> syntax and monomorphization.
# Features tested:
# - Generic impl block parsing
# - Monomorphization of generic impl blocks
# - Trait method calls on specialized types

import ritzlib.sys
import ritzlib.io
import ritzlib.memory

# ============================================================================
# A simple generic wrapper type
# ============================================================================

struct Wrapper<T>
    value: T
    dropped: i32  # Flag to track if drop was called

# ============================================================================
# Trait definition
# ============================================================================

trait Describable
    fn describe(self: *Self) -> i32

# ============================================================================
# Generic impl block
# ============================================================================

impl<T> Describable for Wrapper<T>
    fn describe(self: *Wrapper<T>) -> i32
        # Return 42 to indicate the method was called
        return 42

# ============================================================================
# Tests
# ============================================================================

[[test]]
fn test_wrapper_i32_describe() -> i32
    var w: Wrapper<i32> = Wrapper<i32> { value: 100, dropped: 0 }
    # Use method call syntax instead of mangled name
    let result: i32 = w.describe()
    assert result == 42, "describe should return 42"
    return 0

[[test]]
fn test_wrapper_i64_describe() -> i32
    var w: Wrapper<i64> = Wrapper<i64> { value: 999, dropped: 0 }
    # Use method call syntax instead of mangled name
    let result: i32 = w.describe()
    assert result == 42, "describe should return 42"
    return 0

# ============================================================================
# Main entry point
# ============================================================================

fn main() -> i32
    prints("Test level 30: Generic impl blocks\n")

    test_wrapper_i32_describe()
    test_wrapper_i64_describe()

    prints("All generic impl tests passed!\n")
    return 0
