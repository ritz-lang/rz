# Regression: @Vec<T> should coerce to Span<T> for function parameters.
import ritzlib.gvec

fn consume_span(data: Span<u8>) -> i32
    if data.len > 0
        1
    else
        0

fn pipeline() -> i32
    var v = vec_new<u8>()
    v.push(42)
    consume_span(@v)

[[test]]
fn test_vec_borrow_to_span_param() -> i32
    if pipeline() == 1
        0
    else
        1
