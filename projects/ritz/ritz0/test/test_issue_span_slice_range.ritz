# Regression: index with range should lower to slice, including Span<T>.

fn tail_sum(data: Span<u8>) -> i32
    let tail = data[1..3]
    (tail[0] as i32) + (tail[1] as i32)

[[test]]
fn test_span_slice_range_index() -> i32
    let buf: [4]u8 = [2, 4, 6, 8]
    if tail_sum(@buf) == 10
        0
    else
        1
