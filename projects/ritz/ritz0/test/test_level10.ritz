# Test Level 10: Algorithms and comprehensive function tests
#
# Features tested:
# - Iterative vs recursive implementations
# - More complex control flow
# - Nested loops
# - Algorithm correctness

# Recursive fibonacci (already in level3, but included for comparison)
fn fib_recursive(n: i32) -> i32
  if n < 2
    n
  else
    fib_recursive(n - 1) + fib_recursive(n - 2)

# Iterative fibonacci - more efficient
fn fib_iterative(n: i32) -> i32
  if n < 2
    return n
  var a: i32 = 0
  var b: i32 = 1
  var i: i32 = 2
  while i <= n
    let temp: i32 = a + b
    a = b
    b = temp
    i = i + 1
  b

# Factorial - recursive
fn factorial_recursive(n: i32) -> i32
  if n <= 1
    1
  else
    n * factorial_recursive(n - 1)

# Factorial - iterative
fn factorial_iterative(n: i32) -> i32
  var result: i32 = 1
  var i: i32 = 2
  while i <= n
    result = result * i
    i = i + 1
  result

# GCD using Euclidean algorithm
fn gcd(a: i32, b: i32) -> i32
  var x: i32 = a
  var y: i32 = b
  while y != 0
    let temp: i32 = y
    y = x - (x / y) * y  # x % y
    x = temp
  x

# Integer square root (floor)
fn isqrt(n: i32) -> i32
  if n < 2
    return n
  var x: i32 = n
  var y: i32 = (x + 1) / 2
  while y < x
    x = y
    y = (x + n / x) / 2
  x

# Power function (x^n for non-negative n)
fn power(base: i32, exp: i32) -> i32
  var result: i32 = 1
  var i: i32 = 0
  while i < exp
    result = result * base
    i = i + 1
  result

# Sum of array (tests array + loop interaction) - prefixed to avoid conflict
fn l10_sum_array(arr: *i32, len: i32) -> i32
  var sum: i32 = 0
  var i: i32 = 0
  while i < len
    sum = sum + *(arr + i)
    i = i + 1
  sum

# Find max in array
fn max_array(arr: *i32, len: i32) -> i32
  var max: i32 = *arr
  var i: i32 = 1
  while i < len
    if *(arr + i) > max
      max = *(arr + i)
    i = i + 1
  max

# ===== TESTS =====

[[test]]
fn test_fib_recursive_basic() -> i32
  assert fib_recursive(0) == 0
  assert fib_recursive(1) == 1
  assert fib_recursive(2) == 1
  assert fib_recursive(3) == 2
  assert fib_recursive(4) == 3
  assert fib_recursive(5) == 5
  0

[[test]]
fn test_fib_iterative_basic() -> i32
  assert fib_iterative(0) == 0
  assert fib_iterative(1) == 1
  assert fib_iterative(2) == 1
  assert fib_iterative(3) == 2
  assert fib_iterative(4) == 3
  assert fib_iterative(5) == 5
  0

[[test]]
fn test_fib_larger() -> i32
  # Both should produce same results
  assert fib_recursive(10) == 55
  assert fib_iterative(10) == 55
  assert fib_recursive(12) == 144
  assert fib_iterative(12) == 144
  0

[[test]]
fn test_fib_equivalence() -> i32
  # Verify both implementations match
  var i: i32 = 0
  while i < 15
    assert fib_recursive(i) == fib_iterative(i)
    i = i + 1
  0

[[test]]
fn test_factorial_recursive() -> i32
  assert factorial_recursive(0) == 1
  assert factorial_recursive(1) == 1
  assert factorial_recursive(5) == 120
  assert factorial_recursive(7) == 5040
  0

[[test]]
fn test_factorial_iterative() -> i32
  assert factorial_iterative(0) == 1
  assert factorial_iterative(1) == 1
  assert factorial_iterative(5) == 120
  assert factorial_iterative(7) == 5040
  0

[[test]]
fn test_factorial_equivalence() -> i32
  var i: i32 = 0
  while i < 10
    assert factorial_recursive(i) == factorial_iterative(i)
    i = i + 1
  0

[[test]]
fn test_gcd() -> i32
  assert gcd(48, 18) == 6
  assert gcd(18, 48) == 6
  assert gcd(100, 25) == 25
  assert gcd(17, 13) == 1
  assert gcd(12, 12) == 12
  0

[[test]]
fn test_isqrt() -> i32
  assert isqrt(0) == 0
  assert isqrt(1) == 1
  assert isqrt(4) == 2
  assert isqrt(9) == 3
  assert isqrt(16) == 4
  assert isqrt(15) == 3
  assert isqrt(17) == 4
  assert isqrt(100) == 10
  0

[[test]]
fn test_power() -> i32
  assert power(2, 0) == 1
  assert power(2, 1) == 2
  assert power(2, 8) == 256
  assert power(3, 4) == 81
  assert power(10, 3) == 1000
  0

[[test]]
fn test_sum_array() -> i32
  var arr: [5]i32 = [1, 2, 3, 4, 5]
  assert l10_sum_array(@arr[0], 5) == 15
  0

[[test]]
fn test_max_array() -> i32
  var arr: [5]i32 = [3, 7, 2, 9, 4]
  assert max_array(@arr[0], 5) == 9
  0

[[test]]
fn test_nested_loops() -> i32
  # Sum of multiplication table entries
  var sum: i32 = 0
  var i: i32 = 1
  while i <= 5
    var j: i32 = 1
    while j <= 5
      sum = sum + i * j
      j = j + 1
    i = i + 1
  # Sum should be (1+2+3+4+5)^2 = 15^2 = 225
  assert sum == 225
  0
