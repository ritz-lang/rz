# Test AES-NI hardware crypto intrinsics
#
# AES-NI (Advanced Encryption Standard New Instructions) provides hardware
# acceleration for AES encryption/decryption operations.
#
# Required for cryptosec TLS 1.3 library (ritz#119).
#
# NOTE: This test requires CPU support for AES-NI (Intel since Westmere 2010).

# ============================================================================
# AES-NI: Advanced Encryption Standard New Instructions
# ============================================================================

[[test]]
fn test_aesenc_basic() -> i32
    # Test one round of AES encryption
    # aesenc(state: v4i32, key: v4i32) -> v4i32
    var state: [4]i32
    var key: [4]i32

    # Initialize with known test vector
    state[0] = 0x00010203 as i32
    state[1] = 0x04050607 as i32
    state[2] = 0x08090a0b as i32
    state[3] = 0x0c0d0e0f as i32

    key[0] = 0x10111213 as i32
    key[1] = 0x14151617 as i32
    key[2] = 0x18191a1b as i32
    key[3] = 0x1c1d1e1f as i32

    let s: v4i32 = simd_loadu(@state[0])
    let k: v4i32 = simd_loadu(@key[0])

    # Perform one AES round
    let result: v4i32 = aesenc(s, k)

    # Store result
    var out: [4]i32
    simd_storeu(@out[0], result)

    # Verify we got a transformed result (not input)
    if out[0] == state[0] and out[1] == state[1]
        return 1  # Should have changed

    0

[[test]]
fn test_aesenclast_basic() -> i32
    # Test final round of AES encryption
    # aesenclast(state: v4i32, key: v4i32) -> v4i32
    var state: [4]i32
    var key: [4]i32

    state[0] = 0x00010203 as i32
    state[1] = 0x04050607 as i32
    state[2] = 0x08090a0b as i32
    state[3] = 0x0c0d0e0f as i32

    key[0] = 0x10111213 as i32
    key[1] = 0x14151617 as i32
    key[2] = 0x18191a1b as i32
    key[3] = 0x1c1d1e1f as i32

    let s: v4i32 = simd_loadu(@state[0])
    let k: v4i32 = simd_loadu(@key[0])

    # Perform final AES round
    let result: v4i32 = aesenclast(s, k)

    var out: [4]i32
    simd_storeu(@out[0], result)

    # Verify transformation
    if out[0] == state[0] and out[1] == state[1]
        return 1

    0

[[test]]
fn test_aesdec_basic() -> i32
    # Test one round of AES decryption
    # aesdec(state: v4i32, key: v4i32) -> v4i32
    var state: [4]i32
    var key: [4]i32

    state[0] = 0x00010203 as i32
    state[1] = 0x04050607 as i32
    state[2] = 0x08090a0b as i32
    state[3] = 0x0c0d0e0f as i32

    key[0] = 0x10111213 as i32
    key[1] = 0x14151617 as i32
    key[2] = 0x18191a1b as i32
    key[3] = 0x1c1d1e1f as i32

    let s: v4i32 = simd_loadu(@state[0])
    let k: v4i32 = simd_loadu(@key[0])

    # Perform one AES decryption round
    let result: v4i32 = aesdec(s, k)

    var out: [4]i32
    simd_storeu(@out[0], result)

    if out[0] == state[0] and out[1] == state[1]
        return 1

    0

[[test]]
fn test_aesdeclast_basic() -> i32
    # Test final round of AES decryption
    # aesdeclast(state: v4i32, key: v4i32) -> v4i32
    var state: [4]i32
    var key: [4]i32

    state[0] = 0x00010203 as i32
    state[1] = 0x04050607 as i32
    state[2] = 0x08090a0b as i32
    state[3] = 0x0c0d0e0f as i32

    key[0] = 0x10111213 as i32
    key[1] = 0x14151617 as i32
    key[2] = 0x18191a1b as i32
    key[3] = 0x1c1d1e1f as i32

    let s: v4i32 = simd_loadu(@state[0])
    let k: v4i32 = simd_loadu(@key[0])

    let result: v4i32 = aesdeclast(s, k)

    var out: [4]i32
    simd_storeu(@out[0], result)

    if out[0] == state[0] and out[1] == state[1]
        return 1

    0

[[test]]
fn test_aesimc_basic() -> i32
    # Test AES Inverse MixColumns (for decryption key schedule)
    # aesimc(key: v4i32) -> v4i32
    var key: [4]i32

    key[0] = 0x10111213 as i32
    key[1] = 0x14151617 as i32
    key[2] = 0x18191a1b as i32
    key[3] = 0x1c1d1e1f as i32

    let k: v4i32 = simd_loadu(@key[0])

    # Apply Inverse MixColumns
    let result: v4i32 = aesimc(k)

    var out: [4]i32
    simd_storeu(@out[0], result)

    # Should transform the key
    if out[0] == key[0] and out[1] == key[1] and out[2] == key[2] and out[3] == key[3]
        return 1

    0

[[test]]
fn test_aes_encrypt_decrypt_roundtrip() -> i32
    # Verify that encrypt followed by decrypt returns original
    # This is a sanity check - not cryptographically meaningful without proper key schedule
    var state: [4]i32
    var key: [4]i32

    state[0] = 0xdeadbeef as i32
    state[1] = 0xcafebabe as i32
    state[2] = 0x12345678 as i32
    state[3] = 0x9abcdef0 as i32

    key[0] = 0x00000000 as i32
    key[1] = 0x00000000 as i32
    key[2] = 0x00000000 as i32
    key[3] = 0x00000000 as i32

    let s: v4i32 = simd_loadu(@state[0])
    let k: v4i32 = simd_loadu(@key[0])

    # Single round encrypt then decrypt (with zero key, this is reversible)
    let encrypted: v4i32 = aesenc(s, k)
    # Note: Full AES requires aesimc on key for decrypt, but single round with zero key works
    let decrypted: v4i32 = aesdec(encrypted, k)

    # Result won't match original without proper inverse - just verify it doesn't crash
    var out: [4]i32
    simd_storeu(@out[0], decrypted)

    0

fn main() -> i32
    0
