# Test Level 11: File I/O operations
#
# Features tested:
# - open/close syscalls
# - read/write syscalls
# - File creation and deletion
# - Buffer manipulation
#
# Note: These tests use /tmp for temporary files

# Syscall wrappers - prefixed to avoid conflict with sys.ritz
fn l11_read(fd: i32, buf: *i8, count: i64) -> i64
  syscall3(0, fd, buf, count)

fn l11_write(fd: i32, buf: *i8, count: i64) -> i64
  syscall3(1, fd, buf, count)

fn l11_open(path: *i8, flags: i32, mode: i32) -> i32
  let result: i64 = syscall3(2, path, flags, mode)
  result as i32

fn l11_close(fd: i32) -> i32
  let result: i64 = syscall1(3, fd)
  result as i32

fn l11_unlink(path: *i8) -> i32
  let result: i64 = syscall1(87, path)
  result as i32

# Constants
const O_RDONLY: i32 = 0
const O_WRONLY: i32 = 1
const O_RDWR: i32 = 2
const O_CREAT: i32 = 64
const O_TRUNC: i32 = 512

# String length - prefixed to avoid conflict with str.ritz
fn l11_strlen(s: *i8) -> i64
  var len: i64 = 0
  while *(s + len) != 0
    len = len + 1
  len

# Compare strings (first n bytes)
fn strncmp(a: *i8, b: *i8, n: i64) -> i32
  var i: i64 = 0
  while i < n
    let ca: i32 = *(a + i) as i32
    let cb: i32 = *(b + i) as i32
    if ca != cb
      return ca - cb
    if ca == 0
      return 0
    i = i + 1
  0

# ===== TESTS =====

[[test]]
fn test_open_close() -> i32
  # Open /dev/null - should succeed
  let fd: i32 = l11_open(c"/dev/null", O_RDONLY, 0)
  assert fd >= 0
  let ret: i32 = l11_close(fd)
  assert ret == 0
  0

[[test]]
fn test_write_to_devnull() -> i32
  let fd: i32 = l11_open(c"/dev/null", O_WRONLY, 0)
  assert fd >= 0
  let msg: *i8 = c"test data"
  let n: i64 = l11_write(fd, msg, 9)
  assert n == 9
  l11_close(fd)
  0

[[test]]
fn test_read_from_devzero() -> i32
  let fd: i32 = l11_open(c"/dev/zero", O_RDONLY, 0)
  assert fd >= 0
  var buf: [16]i8 = [0; 16]
  # Put some non-zero data first
  buf[0] = 42
  buf[1] = 99
  # Read zeros
  let n: i64 = l11_read(fd, @buf[0], 16)
  assert n == 16
  # Should all be zero now
  assert buf[0] == 0
  assert buf[1] == 0
  assert buf[15] == 0
  l11_close(fd)
  0

[[test]]
fn test_create_write_read_file() -> i32
  # Create temp file
  let path: *i8 = c"/tmp/ritz_test_11a.txt"

  # Write to file
  let fd_w: i32 = l11_open(path, O_WRONLY + O_CREAT + O_TRUNC, 420)  # 0644
  assert fd_w >= 0
  let msg: *i8 = c"Hello, Ritz!"
  let written: i64 = l11_write(fd_w, msg, 12)
  assert written == 12
  l11_close(fd_w)

  # Read it back
  let fd_r: i32 = l11_open(path, O_RDONLY, 0)
  assert fd_r >= 0
  var buf: [32]i8 = [0; 32]
  let read_len: i64 = l11_read(fd_r, @buf[0], 32)
  assert read_len == 12
  l11_close(fd_r)

  # Verify content
  assert strncmp(@buf[0], msg, 12) == 0

  # Cleanup
  l11_unlink(path)
  0

[[test]]
fn test_file_not_found() -> i32
  # Opening non-existent file should fail
  let fd: i32 = l11_open(c"/tmp/nonexistent_ritz_test_xyz.txt", O_RDONLY, 0)
  assert fd < 0  # -ENOENT
  0

[[test]]
fn test_write_multiple_chunks() -> i32
  let path: *i8 = c"/tmp/ritz_test_11b.txt"

  # Write in chunks
  let fd: i32 = l11_open(path, O_WRONLY + O_CREAT + O_TRUNC, 420)
  assert fd >= 0

  l11_write(fd, c"AAA", 3)
  l11_write(fd, c"BBB", 3)
  l11_write(fd, c"CCC", 3)
  l11_close(fd)

  # Read back
  let fd_r: i32 = l11_open(path, O_RDONLY, 0)
  var buf: [16]i8 = [0; 16]
  let n: i64 = l11_read(fd_r, @buf[0], 16)
  l11_close(fd_r)

  assert n == 9
  assert strncmp(@buf[0], c"AAABBBCCC", 9) == 0

  l11_unlink(path)
  0

[[test]]
fn test_large_buffer() -> i32
  let path: *i8 = c"/tmp/ritz_test_11c.txt"

  # Create file with 256 'X' characters
  var buf: [256]i8 = [88; 256]  # 88 = 'X'

  let fd_w: i32 = l11_open(path, O_WRONLY + O_CREAT + O_TRUNC, 420)
  assert fd_w >= 0
  let written: i64 = l11_write(fd_w, @buf[0], 256)
  assert written == 256
  l11_close(fd_w)

  # Read it back
  var buf2: [256]i8 = [0; 256]
  let fd_r: i32 = l11_open(path, O_RDONLY, 0)
  let read_len: i64 = l11_read(fd_r, @buf2[0], 256)
  l11_close(fd_r)

  assert read_len == 256

  # Verify all bytes
  var i: i64 = 0
  while i < 256
    assert buf2[i] == 88
    i = i + 1

  l11_unlink(path)
  0
