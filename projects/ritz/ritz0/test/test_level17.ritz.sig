{
  "source_hash": "8e8b14c46c8d41cc",
  "functions": {
    "test_for_basic_sum": {
      "hash": "c3149167ed643db7",
      "ir": "define internal i32 @\"test_for_basic_sum\"() !dbg !17\n{\nentry:\n  %\"sum.addr\" = alloca i64, !dbg !24\n  %\"i\" = alloca i64, !dbg !27\n  store i64 0, i64* %\"sum.addr\", !dbg !24\n  call void @\"llvm.dbg.declare\"(metadata i64* %\"sum.addr\", metadata !25, metadata !7), !dbg !26\n  store i64 0, i64* %\"i\", !dbg !27\n  br label %\"for.cond\", !dbg !27\nfor.cond:\n  %\".6\" = load i64, i64* %\"i\", !dbg !27\n  %\".7\" = icmp slt i64 %\".6\", 5 , !dbg !27\n  br i1 %\".7\", label %\"for.body\", label %\"for.end\", !dbg !27\nfor.body:\n  %\".9\" = load i64, i64* %\"sum.addr\", !dbg !28\n  %\".10\" = load i64, i64* %\"i\", !dbg !28\n  %\".11\" = add i64 %\".9\", %\".10\", !dbg !28\n  store i64 %\".11\", i64* %\"sum.addr\", !dbg !28\n  br label %\"for.incr\", !dbg !28\nfor.incr:\n  %\".14\" = load i64, i64* %\"i\", !dbg !28\n  %\".15\" = add i64 %\".14\", 1, !dbg !28\n  store i64 %\".15\", i64* %\"i\", !dbg !28\n  br label %\"for.cond\", !dbg !28\nfor.end:\n  %\".18\" = load i64, i64* %\"sum.addr\", !dbg !29\n  %\".19\" = icmp eq i64 %\".18\", 10 , !dbg !29\n  br i1 %\".19\", label %\"assert.pass\", label %\"assert.fail\", !dbg !29\nassert.pass:\n  ret i32 0, !dbg !29\nassert.fail:\n  %\".21\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !29\n  unreachable\n}"
    },
    "test_for_with_break": {
      "hash": "54026638105ca0c5",
      "ir": "define internal i32 @\"test_for_with_break\"() !dbg !18\n{\nentry:\n  %\"count.addr\" = alloca i64, !dbg !30\n  %\"j\" = alloca i64, !dbg !33\n  store i64 0, i64* %\"count.addr\", !dbg !30\n  call void @\"llvm.dbg.declare\"(metadata i64* %\"count.addr\", metadata !31, metadata !7), !dbg !32\n  store i64 0, i64* %\"j\", !dbg !33\n  br label %\"for.cond\", !dbg !33\nfor.cond:\n  %\".6\" = load i64, i64* %\"j\", !dbg !33\n  %\".7\" = icmp slt i64 %\".6\", 100 , !dbg !33\n  br i1 %\".7\", label %\"for.body\", label %\"for.end\", !dbg !33\nfor.body:\n  %\".9\" = load i64, i64* %\"count.addr\", !dbg !34\n  %\".10\" = add i64 %\".9\", 1, !dbg !34\n  store i64 %\".10\", i64* %\"count.addr\", !dbg !34\n  %\".12\" = load i64, i64* %\"j\", !dbg !34\n  %\".13\" = icmp eq i64 %\".12\", 5 , !dbg !34\n  br i1 %\".13\", label %\"if.then\", label %\"if.end\", !dbg !34\nfor.incr:\n  %\".17\" = load i64, i64* %\"j\", !dbg !35\n  %\".18\" = add i64 %\".17\", 1, !dbg !35\n  store i64 %\".18\", i64* %\"j\", !dbg !35\n  br label %\"for.cond\", !dbg !35\nfor.end:\n  %\".21\" = load i64, i64* %\"count.addr\", !dbg !36\n  %\".22\" = icmp eq i64 %\".21\", 6 , !dbg !36\n  br i1 %\".22\", label %\"assert.pass\", label %\"assert.fail\", !dbg !36\nif.then:\n  br label %\"for.end\", !dbg !35\nif.end:\n  br label %\"for.incr\", !dbg !35\nassert.pass:\n  ret i32 0, !dbg !36\nassert.fail:\n  %\".24\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !36\n  unreachable\n}"
    },
    "test_for_with_continue": {
      "hash": "afbf8d8cbf35e6ce",
      "ir": "define internal i32 @\"test_for_with_continue\"() !dbg !19\n{\nentry:\n  %\"even_sum.addr\" = alloca i64, !dbg !37\n  %\"k\" = alloca i64, !dbg !40\n  store i64 0, i64* %\"even_sum.addr\", !dbg !37\n  call void @\"llvm.dbg.declare\"(metadata i64* %\"even_sum.addr\", metadata !38, metadata !7), !dbg !39\n  store i64 0, i64* %\"k\", !dbg !40\n  br label %\"for.cond\", !dbg !40\nfor.cond:\n  %\".6\" = load i64, i64* %\"k\", !dbg !40\n  %\".7\" = icmp slt i64 %\".6\", 10 , !dbg !40\n  br i1 %\".7\", label %\"for.body\", label %\"for.end\", !dbg !40\nfor.body:\n  %\".9\" = load i64, i64* %\"k\", !dbg !41\n  %\".10\" = srem i64 %\".9\", 2, !dbg !41\n  %\".11\" = icmp ne i64 %\".10\", 0 , !dbg !41\n  br i1 %\".11\", label %\"if.then\", label %\"if.end\", !dbg !41\nfor.incr:\n  %\".19\" = load i64, i64* %\"k\", !dbg !43\n  %\".20\" = add i64 %\".19\", 1, !dbg !43\n  store i64 %\".20\", i64* %\"k\", !dbg !43\n  br label %\"for.cond\", !dbg !43\nfor.end:\n  %\".23\" = load i64, i64* %\"even_sum.addr\", !dbg !44\n  %\".24\" = icmp eq i64 %\".23\", 20 , !dbg !44\n  br i1 %\".24\", label %\"assert.pass\", label %\"assert.fail\", !dbg !44\nif.then:\n  br label %\"for.incr\", !dbg !42\nif.end:\n  %\".14\" = load i64, i64* %\"even_sum.addr\", !dbg !43\n  %\".15\" = load i64, i64* %\"k\", !dbg !43\n  %\".16\" = add i64 %\".14\", %\".15\", !dbg !43\n  store i64 %\".16\", i64* %\"even_sum.addr\", !dbg !43\n  br label %\"for.incr\", !dbg !43\nassert.pass:\n  ret i32 0, !dbg !44\nassert.fail:\n  %\".26\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !44\n  unreachable\n}"
    },
    "test_for_nested": {
      "hash": "529ede96be30da8a",
      "ir": "define internal i32 @\"test_for_nested\"() !dbg !20\n{\nentry:\n  %\"product.addr\" = alloca i64, !dbg !45\n  %\"a\" = alloca i64, !dbg !48\n  %\"b\" = alloca i64, !dbg !49\n  store i64 0, i64* %\"product.addr\", !dbg !45\n  call void @\"llvm.dbg.declare\"(metadata i64* %\"product.addr\", metadata !46, metadata !7), !dbg !47\n  store i64 0, i64* %\"a\", !dbg !48\n  br label %\"for.cond\", !dbg !48\nfor.cond:\n  %\".6\" = load i64, i64* %\"a\", !dbg !48\n  %\".7\" = icmp slt i64 %\".6\", 3 , !dbg !48\n  br i1 %\".7\", label %\"for.body\", label %\"for.end\", !dbg !48\nfor.body:\n  store i64 0, i64* %\"b\", !dbg !49\n  br label %\"for.cond.1\", !dbg !49\nfor.incr:\n  %\".23\" = load i64, i64* %\"a\", !dbg !50\n  %\".24\" = add i64 %\".23\", 1, !dbg !50\n  store i64 %\".24\", i64* %\"a\", !dbg !50\n  br label %\"for.cond\", !dbg !50\nfor.end:\n  %\".27\" = load i64, i64* %\"product.addr\", !dbg !51\n  %\".28\" = icmp eq i64 %\".27\", 12 , !dbg !51\n  br i1 %\".28\", label %\"assert.pass\", label %\"assert.fail\", !dbg !51\nfor.cond.1:\n  %\".11\" = load i64, i64* %\"b\", !dbg !49\n  %\".12\" = icmp slt i64 %\".11\", 4 , !dbg !49\n  br i1 %\".12\", label %\"for.body.1\", label %\"for.end.1\", !dbg !49\nfor.body.1:\n  %\".14\" = load i64, i64* %\"product.addr\", !dbg !50\n  %\".15\" = add i64 %\".14\", 1, !dbg !50\n  store i64 %\".15\", i64* %\"product.addr\", !dbg !50\n  br label %\"for.incr.1\", !dbg !50\nfor.incr.1:\n  %\".18\" = load i64, i64* %\"b\", !dbg !50\n  %\".19\" = add i64 %\".18\", 1, !dbg !50\n  store i64 %\".19\", i64* %\"b\", !dbg !50\n  br label %\"for.cond.1\", !dbg !50\nfor.end.1:\n  br label %\"for.incr\", !dbg !50\nassert.pass:\n  ret i32 0, !dbg !51\nassert.fail:\n  %\".30\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !51\n  unreachable\n}"
    },
    "test_for_empty_range": {
      "hash": "71d2e32aaad778a0",
      "ir": "define internal i32 @\"test_for_empty_range\"() !dbg !21\n{\nentry:\n  %\"count.addr\" = alloca i64, !dbg !52\n  %\"i\" = alloca i64, !dbg !55\n  store i64 0, i64* %\"count.addr\", !dbg !52\n  call void @\"llvm.dbg.declare\"(metadata i64* %\"count.addr\", metadata !53, metadata !7), !dbg !54\n  store i64 5, i64* %\"i\", !dbg !55\n  br label %\"for.cond\", !dbg !55\nfor.cond:\n  %\".6\" = load i64, i64* %\"i\", !dbg !55\n  %\".7\" = icmp slt i64 %\".6\", 5 , !dbg !55\n  br i1 %\".7\", label %\"for.body\", label %\"for.end\", !dbg !55\nfor.body:\n  %\".9\" = load i64, i64* %\"count.addr\", !dbg !56\n  %\".10\" = add i64 %\".9\", 1, !dbg !56\n  store i64 %\".10\", i64* %\"count.addr\", !dbg !56\n  br label %\"for.incr\", !dbg !56\nfor.incr:\n  %\".13\" = load i64, i64* %\"i\", !dbg !56\n  %\".14\" = add i64 %\".13\", 1, !dbg !56\n  store i64 %\".14\", i64* %\"i\", !dbg !56\n  br label %\"for.cond\", !dbg !56\nfor.end:\n  %\".17\" = load i64, i64* %\"count.addr\", !dbg !57\n  %\".18\" = icmp eq i64 %\".17\", 0 , !dbg !57\n  br i1 %\".18\", label %\"assert.pass\", label %\"assert.fail\", !dbg !57\nassert.pass:\n  ret i32 0, !dbg !57\nassert.fail:\n  %\".20\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !57\n  unreachable\n}"
    },
    "test_for_single_iteration": {
      "hash": "6543fc747f819493",
      "ir": "define internal i32 @\"test_for_single_iteration\"() !dbg !22\n{\nentry:\n  %\"count.addr\" = alloca i64, !dbg !58\n  %\"i\" = alloca i64, !dbg !61\n  store i64 0, i64* %\"count.addr\", !dbg !58\n  call void @\"llvm.dbg.declare\"(metadata i64* %\"count.addr\", metadata !59, metadata !7), !dbg !60\n  store i64 0, i64* %\"i\", !dbg !61\n  br label %\"for.cond\", !dbg !61\nfor.cond:\n  %\".6\" = load i64, i64* %\"i\", !dbg !61\n  %\".7\" = icmp slt i64 %\".6\", 1 , !dbg !61\n  br i1 %\".7\", label %\"for.body\", label %\"for.end\", !dbg !61\nfor.body:\n  %\".9\" = load i64, i64* %\"count.addr\", !dbg !62\n  %\".10\" = add i64 %\".9\", 1, !dbg !62\n  store i64 %\".10\", i64* %\"count.addr\", !dbg !62\n  br label %\"for.incr\", !dbg !62\nfor.incr:\n  %\".13\" = load i64, i64* %\"i\", !dbg !62\n  %\".14\" = add i64 %\".13\", 1, !dbg !62\n  store i64 %\".14\", i64* %\"i\", !dbg !62\n  br label %\"for.cond\", !dbg !62\nfor.end:\n  %\".17\" = load i64, i64* %\"count.addr\", !dbg !63\n  %\".18\" = icmp eq i64 %\".17\", 1 , !dbg !63\n  br i1 %\".18\", label %\"assert.pass\", label %\"assert.fail\", !dbg !63\nassert.pass:\n  ret i32 0, !dbg !63\nassert.fail:\n  %\".20\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !63\n  unreachable\n}"
    },
    "test_for_variable_bounds": {
      "hash": "c9329604714153d5",
      "ir": "define internal i32 @\"test_for_variable_bounds\"() !dbg !23\n{\nentry:\n  %\"sum.addr\" = alloca i64, !dbg !66\n  %\"i\" = alloca i64, !dbg !69\n  store i64 0, i64* %\"sum.addr\", !dbg !66\n  call void @\"llvm.dbg.declare\"(metadata i64* %\"sum.addr\", metadata !67, metadata !7), !dbg !68\n  store i64 2, i64* %\"i\", !dbg !69\n  br label %\"for.cond\", !dbg !69\nfor.cond:\n  %\".6\" = load i64, i64* %\"i\", !dbg !69\n  %\".7\" = icmp slt i64 %\".6\", 5 , !dbg !69\n  br i1 %\".7\", label %\"for.body\", label %\"for.end\", !dbg !69\nfor.body:\n  %\".9\" = load i64, i64* %\"sum.addr\", !dbg !70\n  %\".10\" = load i64, i64* %\"i\", !dbg !70\n  %\".11\" = add i64 %\".9\", %\".10\", !dbg !70\n  store i64 %\".11\", i64* %\"sum.addr\", !dbg !70\n  br label %\"for.incr\", !dbg !70\nfor.incr:\n  %\".14\" = load i64, i64* %\"i\", !dbg !70\n  %\".15\" = add i64 %\".14\", 1, !dbg !70\n  store i64 %\".15\", i64* %\"i\", !dbg !70\n  br label %\"for.cond\", !dbg !70\nfor.end:\n  %\".18\" = load i64, i64* %\"sum.addr\", !dbg !71\n  %\".19\" = icmp eq i64 %\".18\", 9 , !dbg !71\n  br i1 %\".19\", label %\"assert.pass\", label %\"assert.fail\", !dbg !71\nassert.pass:\n  ret i32 0, !dbg !71\nassert.fail:\n  %\".21\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !71\n  unreachable\n}"
    }
  },
  "imports": []
}
