# AGAST #189 regression: scalar `const FOO: StrView = "..."` declarations,
# when passed by value into a function expecting `s: StrView`, must be
# lowered as a `%StrView = type { ptr, i64 }` aggregate at the call site.
#
# Symptom (mausoleum/storage build_path call): ritz1 emitted the const as
# `%r = add i64 0, 0` and then the call site fed an i64 into a `%StrView`
# parameter slot, producing an LLVM type-mismatch verifier error.
#
# Sister test to test_issue_const_strview_array.ritz which covers
# `[N]StrView` const arrays (the named-const scalar shape was missed).

import ritzlib.strview

const NAME: StrView = "hello"
const PATH: StrView = "/data.m7m"

# Mirrors mausoleum/storage.ritz `build_path(suffix: StrView, ...)`: a
# struct-typed by-value StrView parameter received from a const at the call
# site.  We do not field-access inside the body to keep the test independent
# of unrelated by-value-StrView shape work; the call signature alone is
# enough to drive the original IR-verifier failure (`%StrView` param slot
# being fed an `i64` register).
fn takes_strview_byval(s: StrView, drop_arg: i64) -> i64
    return drop_arg

[[test]]
fn test_const_strview_arg_by_value() -> i32
    # The original mausoleum failure: passing a `const NAME: StrView = "..."`
    # by value to a parameter typed `s: StrView` must lower the call-site
    # arg as a `%StrView` aggregate, not `i64`.
    let r: i64 = takes_strview_byval(NAME, 7)
    if r != 7
        return 1
    let r2: i64 = takes_strview_byval(PATH, 9)
    if r2 != 9
        return 2
    return 0
