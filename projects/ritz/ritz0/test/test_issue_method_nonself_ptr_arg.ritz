# Regression: method non-self pointer params should auto-borrow addressable args.

struct Pair
    n: i32

impl Pair
    fn eq_ptr(self, other: @Pair) -> bool
        self.n == other.n

[[test]]
fn test_method_nonself_ptr_arg_autoborrow() -> i32
    let a = Pair { n: 5 }
    if a.eq_ptr(a)
        0
    else
        1
