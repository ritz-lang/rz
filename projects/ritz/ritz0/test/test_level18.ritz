# Test level 18: Environment access via 3-argument main
#
# Tests that main can receive envp as a third argument

import ritzlib.sys
import ritzlib.io
import ritzlib.str
import ritzlib.env

# ============================================================================
# Test: 3-argument main receives envp
# ============================================================================

fn main(argc: i32, argv: **u8, envp: **u8) -> i32
    # Test that envp is not null
    if envp == null
        eprints("FAIL: envp is null\n")
        return 1

    # Count environment variables using env module
    let count: i32 = env_count(envp)

    # There should be at least a few environment variables
    if count < 1
        eprints("FAIL: no environment variables found\n")
        return 1

    prints("Environment variable count: ")
    print_int(count as i64)
    print_char(10)

    # Try to find PATH using getenv
    let path_value: *u8 = getenv(envp, c"PATH")
    if path_value != null
        prints("Found PATH: ")
        prints(path_value)
        print_char(10)
    else
        eprints("WARN: PATH not found in environment\n")
        # Not a failure - some minimal environments might not have PATH

    prints("OK: envp works\n")
    return 0
