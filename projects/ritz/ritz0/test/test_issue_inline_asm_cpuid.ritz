# Regression: cpuid_raw inline-asm intrinsic (AGAST #185).
#
# ritz0 emits inline asm at the call site for `cpuid_raw`; ritz1 used to
# leave the call as an unresolved external `@cpuid_raw`, breaking links
# for cryptosec → valet.  Both compilers must now produce a runnable
# binary that executes CPUID and reads back a sane vendor leaf result.
#
# Leaf 0 is universally safe on every x86_64 CPU — it returns the
# maximum supported leaf (≥ 1 in practice, ≥ 4 on anything modern) in
# EAX and the vendor string in EBX:EDX:ECX.

[[test]]
fn test_cpuid_raw_leaf0() -> i32
    var eax: i32 = 0
    var ebx: i32 = 0
    var ecx: i32 = 0
    var edx: i32 = 0

    cpuid_raw(0, 0, @eax, @ebx, @ecx, @edx)

    # EAX must report a max-leaf >= 1 (true on every x86_64 since 1995).
    if eax < 1
        return 1

    # Vendor string occupies EBX:EDX:ECX — at least one register must be
    # nonzero on real silicon.  All-zero would mean cpuid never ran.
    if ebx == 0 and ecx == 0 and edx == 0
        return 2

    0
