# Test level 24: Tagged Unions and Pattern Matching
#
# Tests for TypeScript-style tagged unions with pattern matching

# ============================================================================
# Type definitions
# ============================================================================

# Simple union of two primitive types
type IntOrBool = i64 | bool

# Union with pointer type
type IntOrStr = i32 | *u8

# Union with multiple types
type Value = i64 | *u8 | bool

# ============================================================================
# Test: Basic union creation with i64
# ============================================================================

[[test]]
fn test_union_int()
    let x: IntOrBool = 42 as IntOrBool
    let result: i64 = match x
        i64 => x as i64
        bool => 0
    assert result == 42

# ============================================================================
# Test: Basic union creation with bool
# ============================================================================

[[test]]
fn test_union_bool()
    let x: IntOrBool = true as IntOrBool
    let result: i64 = match x
        i64 => 0
        bool => 1
    assert result == 1

# ============================================================================
# Test: Match returns correct branch value
# ============================================================================

[[test]]
fn test_match_branches()
    let a: IntOrBool = 100 as IntOrBool
    let b: IntOrBool = false as IntOrBool

    let r1: i64 = match a
        i64 => 1
        bool => 2
    assert r1 == 1

    let r2: i64 = match b
        i64 => 1
        bool => 2
    assert r2 == 2

# ============================================================================
# Test: Union with pointer type (string)
# ============================================================================

[[test]]
fn test_union_pointer()
    let msg: *u8 = c"hello"
    let x: IntOrStr = msg as IntOrStr
    let result: i32 = match x
        i32 => 0
        *u8 => 1
    assert result == 1

# ============================================================================
# Test: Extract value from union via cast
# ============================================================================

[[test]]
fn test_union_extract_int()
    let x: IntOrBool = 99 as IntOrBool
    let result: i64 = match x
        i64 => x as i64
        bool => -1
    assert result == 99

# ============================================================================
# Test: Three-variant union
# ============================================================================

[[test]]
fn test_three_variant_union()
    let v1: Value = 42 as Value
    let v2: Value = c"test" as Value
    let v3: Value = true as Value

    let r1: i64 = match v1
        i64 => 1
        *u8 => 2
        bool => 3
    assert r1 == 1

    let r2: i64 = match v2
        i64 => 1
        *u8 => 2
        bool => 3
    assert r2 == 2

    let r3: i64 = match v3
        i64 => 1
        *u8 => 2
        bool => 3
    assert r3 == 3

# ============================================================================
# Test: Union in function return
# ============================================================================

fn make_int_union(val: i64) -> IntOrBool
    return val as IntOrBool

fn make_bool_union(val: bool) -> IntOrBool
    return val as IntOrBool

[[test]]
fn test_union_from_function()
    let x: IntOrBool = make_int_union(123)
    let y: IntOrBool = make_bool_union(true)

    let rx: i64 = match x
        i64 => x as i64
        bool => -1
    assert rx == 123

    let ry: i64 = match y
        i64 => -1
        bool => 1
    assert ry == 1

# ============================================================================
# Test: Union as function parameter
# ============================================================================

fn is_truthy(v: IntOrBool) -> bool
    return match v
        i64 => (v as i64) != 0
        bool => v as bool

[[test]]
fn test_union_as_parameter()
    let a: IntOrBool = 42 as IntOrBool
    let b: IntOrBool = 0 as IntOrBool
    let c: IntOrBool = true as IntOrBool
    let d: IntOrBool = false as IntOrBool

    assert is_truthy(a) == true
    assert is_truthy(b) == false
    assert is_truthy(c) == true
    assert is_truthy(d) == false

# ============================================================================
# Test: Mutable union variable
# ============================================================================

[[test]]
fn test_mutable_union()
    var x: IntOrBool = 10 as IntOrBool

    let r1: i64 = match x
        i64 => x as i64
        bool => -1
    assert r1 == 10

    # Reassign to different variant
    x = true as IntOrBool

    let r2: i64 = match x
        i64 => 0
        bool => 1
    assert r2 == 1
