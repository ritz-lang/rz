# Regression: match on Option<u32> should resolve enum type reliably.
import ritzlib.result

fn pick(flag: bool) -> Option<u32>
    if flag
        Some(42 as u32)
    else
        None

[[test]]
fn test_match_option_u32() -> i32
    let a = pick(true)
    let b = pick(false)
    let x = match a
        Some(v) => v as i32
        None => 0
    let y = match b
        Some(v) => v as i32
        None => 7
    if x == 42 and y == 7
        0
    else
        1
