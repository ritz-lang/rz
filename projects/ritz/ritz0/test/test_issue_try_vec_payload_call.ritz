# Regression: `?` on Result<Vec<T>, E> must preserve Vec payload type for downstream calls.
import ritzlib.result
import ritzlib.gvec

fn read_bytes() -> Result<Vec<u8>, StrView>
    var data = vec_new<u8>()
    data.push(1)
    Ok(data)

fn parse_bytes(data:= Vec<u8>) -> Result<i32, StrView>
    Ok(7)

fn pipeline() -> Result<i32, StrView>
    let data = read_bytes()?
    let parsed = parse_bytes(data)?
    Ok(parsed)

[[test]]
fn test_try_vec_payload_then_call() -> i32
    let out = pipeline()
    if out.is_ok()
        0
    else
        1
