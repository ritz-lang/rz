# Regression: explicit generic function calls should resolve monomorphized names.
import ritzlib.gvec

[[test]]
fn test_generic_call_resolution() -> i32
    var v = vec_new<i32>()
    vec_push<i32>(@v, 1)
    vec_push<i32>(@v, 2)
    vec_clear<i32>(@v)
    if vec_len<i32>(@v) == 0
        0
    else
        1
