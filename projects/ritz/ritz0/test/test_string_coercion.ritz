# Test String → *u8 implicit coercion (Issue #89 Phase 2)
#
# Features tested:
# - String variable passed to function expecting *u8
# - Coercion calls string_as_ptr() automatically
# - Works with ritzlib.string functions

import ritzlib.string

# Helper: count string length via *u8 pointer
fn strlen_ptr(s: *u8) -> i64
    var i: i64 = 0
    while *(s + i) != 0
        i = i + 1
    i

# Helper: compare *u8 string with expected
fn streq_ptr(a: *u8, b: *u8) -> i32
    var i: i64 = 0
    while *(a + i) != 0 and *(b + i) != 0
        if *(a + i) != *(b + i)
            return 0
        i = i + 1
    if *(a + i) != *(b + i)
        return 0
    1

[[test]]
fn test_string_var_to_ptr() -> i64
    # Create a String
    var s: String = string_from(c"hello")
    # Pass String to function expecting *u8
    # Compiler should call string_as_ptr automatically
    let len: i64 = strlen_ptr(s)
    assert len == 5
    0

[[test]]
fn test_string_content_via_coercion() -> i64
    var s: String = string_from(c"world")
    # The coerced *u8 should point to the string data
    assert streq_ptr(s, c"world") == 1
    0

[[test]]
fn test_modified_string_coercion() -> i64
    var s: String = string_from(c"hi")
    string_push(@s, ' ')
    string_push_str(@s, c"there")
    # After modification, coercion should still work
    assert strlen_ptr(s) == 8
    assert streq_ptr(s, c"hi there") == 1
    0
