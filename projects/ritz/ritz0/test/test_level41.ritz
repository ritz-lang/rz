# Test level 41: defer statement
#
# Tests the defer statement which registers cleanup code to run
# when the enclosing scope exits. Multiple defers execute in LIFO order.
#
# This is a compile-time transformation — no runtime overhead.

import ritzlib.sys

# ============================================================================
# Global counter for tracking defer execution order
# ============================================================================

var counter: i64 = 0
var trace_0: i64 = 0
var trace_1: i64 = 0
var trace_2: i64 = 0
var trace_3: i64 = 0
var trace_idx: i64 = 0

pub fn trace_push(val: i64) -> i32
    if trace_idx == 0
        trace_0 = val
    else if trace_idx == 1
        trace_1 = val
    else if trace_idx == 2
        trace_2 = val
    else
        trace_3 = val
    trace_idx = trace_idx + 1
    0

pub fn reset_trace() -> i32
    counter = 0
    trace_idx = 0
    trace_0 = 0
    trace_1 = 0
    trace_2 = 0
    trace_3 = 0
    0

# ============================================================================
# Test: Basic defer executes at scope exit
# ============================================================================

[[test]]
fn test_defer_basic() -> i32
    reset_trace()
    counter = 0
    defer counter = 99
    counter = 1
    # At end of function, defer sets counter to 99
    # But we check counter BEFORE defer runs — it should be 1 here
    # Actually, defer runs at scope exit, so the return value is
    # evaluated first, then defer runs. But if we return 0 and
    # then check counter externally... for simplicity, test inline:
    0
    # defer fires here, counter becomes 99

# ============================================================================
# Test: LIFO order — last defer runs first
# ============================================================================

[[test]]
fn test_defer_lifo_order() -> i32
    reset_trace()
    defer trace_push(1)    # Runs third (registered first)
    defer trace_push(2)    # Runs second
    defer trace_push(3)    # Runs first (registered last)
    0
    # At scope exit: trace_push(3), trace_push(2), trace_push(1)
    # trace = [3, 2, 1]

# We need a way to check the trace AFTER the deferred code runs.
# Since defer runs at scope exit, we can't check in the same function.
# Use a wrapper pattern:

pub fn do_lifo() -> i32
    defer trace_push(1)
    defer trace_push(2)
    defer trace_push(3)
    0

[[test]]
fn test_defer_lifo_check() -> i32
    reset_trace()
    do_lifo()
    # After do_lifo returns, defers have executed
    assert trace_0 == 3, "first defer to run should be last registered"
    assert trace_1 == 2, "second defer to run"
    assert trace_2 == 1, "third defer to run should be first registered"
    0

# ============================================================================
# Test: Defer runs on early return
# ============================================================================

pub fn do_early_return(x: i32) -> i32
    defer counter = 42
    if x > 0
        return 1    # Early return — defer still runs
    return 0

[[test]]
fn test_defer_early_return() -> i32
    reset_trace()
    do_early_return(1)
    assert counter == 42, "defer should run even on early return"
    0

# ============================================================================
# Test: Defer captures variable by reference
# ============================================================================

pub fn do_capture_by_ref() -> i32
    var x: i64 = 10
    defer counter = x   # Captures x by reference
    x = 20               # Modify x AFTER defer registration
    0

[[test]]
fn test_defer_captures_by_ref() -> i32
    reset_trace()
    do_capture_by_ref()
    # x was 20 when defer ran (captures by reference, not by value)
    assert counter == 20, "defer should capture by reference"
    0

# ============================================================================
# Test: Multiple defers with function calls
# ============================================================================

pub fn cleanup_a() -> i32
    trace_push(10)
    0

pub fn cleanup_b() -> i32
    trace_push(20)
    0

pub fn do_multi_defer() -> i32
    defer cleanup_a()
    defer cleanup_b()
    0

[[test]]
fn test_defer_function_calls() -> i32
    reset_trace()
    do_multi_defer()
    # LIFO: cleanup_b runs first, then cleanup_a
    assert trace_0 == 20, "cleanup_b should run first (LIFO)"
    assert trace_1 == 10, "cleanup_a should run second"
    0

# ============================================================================
# Test: Defer with simple assignment
# ============================================================================

[[test]]
fn test_defer_simple() -> i32
    counter = 0
    defer counter = 100
    assert counter == 0, "counter should be 0 before scope exit"
    0
    # defer fires here — but we already returned

# Entry point
fn main() -> i32
    0
