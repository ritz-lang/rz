# Regression: pointer-typed parameters should stay as pointer values when forwarded.

struct Node
    v: i32

fn read_node(n: @Node) -> i32
    n.v

fn forward(n: @Node) -> i32
    read_node(n)

[[test]]
fn test_ptr_param_forwarding() -> i32
    let n = Node { v: 11 }
    if forward(@n) == 11
        0
    else
        1
