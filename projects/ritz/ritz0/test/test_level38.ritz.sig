  "functions": {
    "test_const_array_simple": {
      "hash": "8c4148eec8c06890",
      "ir": "define internal i32 @\"test_const_array_simple\"() !dbg !17\n{\nentry:\n  %\".2\" = getelementptr [4 x i8], [4 x i8]* @\"SMALL\", i32 0, i64 0 , !dbg !26\n  %\".3\" = load i8, i8* %\".2\", !dbg !26\n  %\".4\" = zext i8 %\".3\" to i64 , !dbg !26\n  %\".5\" = icmp ne i64 %\".4\", 99 , !dbg !26\n  br i1 %\".5\", label %\"if.then\", label %\"if.end\", !dbg !26\nif.then:\n  %\".7\" = trunc i64 1 to i32 , !dbg !27\n  ret i32 %\".7\", !dbg !27\nif.end:\n  %\".9\" = getelementptr [4 x i8], [4 x i8]* @\"SMALL\", i32 0, i64 1 , !dbg !28\n  %\".10\" = load i8, i8* %\".9\", !dbg !28\n  %\".11\" = zext i8 %\".10\" to i64 , !dbg !28\n  %\".12\" = icmp ne i64 %\".11\", 124 , !dbg !28\n  br i1 %\".12\", label %\"if.then.1\", label %\"if.end.1\", !dbg !28\nif.then.1:\n  %\".14\" = trunc i64 2 to i32 , !dbg !29\n  ret i32 %\".14\", !dbg !29\nif.end.1:\n  %\".16\" = getelementptr [4 x i8], [4 x i8]* @\"SMALL\", i32 0, i64 2 , !dbg !30\n  %\".17\" = load i8, i8* %\".16\", !dbg !30\n  %\".18\" = zext i8 %\".17\" to i64 , !dbg !30\n  %\".19\" = icmp ne i64 %\".18\", 119 , !dbg !30\n  br i1 %\".19\", label %\"if.then.2\", label %\"if.end.2\", !dbg !30\nif.then.2:\n  %\".21\" = trunc i64 3 to i32 , !dbg !31\n  ret i32 %\".21\", !dbg !31\nif.end.2:\n  %\".23\" = getelementptr [4 x i8], [4 x i8]* @\"SMALL\", i32 0, i64 3 , !dbg !32\n  %\".24\" = load i8, i8* %\".23\", !dbg !32\n  %\".25\" = zext i8 %\".24\" to i64 , !dbg !32\n  %\".26\" = icmp ne i64 %\".25\", 123 , !dbg !32\n  br i1 %\".26\", label %\"if.then.3\", label %\"if.end.3\", !dbg !32\nif.then.3:\n  %\".28\" = trunc i64 4 to i32 , !dbg !33\n  ret i32 %\".28\", !dbg !33\nif.end.3:\n  %\".30\" = trunc i64 0 to i32 , !dbg !34\n  ret i32 %\".30\", !dbg !34\n}"
    },
    "test_const_array_fill": {
      "hash": "2a4af363e271f2e9",
      "ir": "define internal i32 @\"test_const_array_fill\"() !dbg !18\n{\nentry:\n  %\"i\" = alloca i64, !dbg !35\n  store i64 0, i64* %\"i\", !dbg !35\n  br label %\"for.cond\", !dbg !35\nfor.cond:\n  %\".4\" = load i64, i64* %\"i\", !dbg !35\n  %\".5\" = icmp slt i64 %\".4\", 8 , !dbg !35\n  br i1 %\".5\", label %\"for.body\", label %\"for.end\", !dbg !35\nfor.body:\n  %\".7\" = load i64, i64* %\"i\", !dbg !35\n  %\".8\" = getelementptr [8 x i8], [8 x i8]* @\"ZEROS\", i32 0, i64 %\".7\" , !dbg !35\n  %\".9\" = load i8, i8* %\".8\", !dbg !35\n  %\".10\" = zext i8 %\".9\" to i64 , !dbg !35\n  %\".11\" = icmp ne i64 %\".10\", 0 , !dbg !35\n  br i1 %\".11\", label %\"if.then\", label %\"if.end\", !dbg !35\nfor.incr:\n  %\".16\" = load i64, i64* %\"i\", !dbg !36\n  %\".17\" = add i64 %\".16\", 1, !dbg !36\n  store i64 %\".17\", i64* %\"i\", !dbg !36\n  br label %\"for.cond\", !dbg !36\nfor.end:\n  %\".20\" = trunc i64 0 to i32 , !dbg !37\n  ret i32 %\".20\", !dbg !37\nif.then:\n  %\".13\" = trunc i64 1 to i32 , !dbg !36\n  ret i32 %\".13\", !dbg !36\nif.end:\n  br label %\"for.incr\", !dbg !36\n}"
    },
    "test_const_array_signed": {
      "hash": "aaf61534bc3001a1",
      "ir": "define internal i32 @\"test_const_array_signed\"() !dbg !19\n{\nentry:\n  %\".2\" = getelementptr [4 x i32], [4 x i32]* @\"SIGNED\", i32 0, i64 0 , !dbg !38\n  %\".3\" = load i32, i32* %\".2\", !dbg !38\n  %\".4\" = sext i32 %\".3\" to i64 , !dbg !38\n  %\".5\" = icmp ne i64 %\".4\", 1 , !dbg !38\n  br i1 %\".5\", label %\"if.then\", label %\"if.end\", !dbg !38\nif.then:\n  %\".7\" = trunc i64 1 to i32 , !dbg !39\n  ret i32 %\".7\", !dbg !39\nif.end:\n  %\".9\" = getelementptr [4 x i32], [4 x i32]* @\"SIGNED\", i32 0, i64 1 , !dbg !40\n  %\".10\" = load i32, i32* %\".9\", !dbg !40\n  %\".11\" = sub i64 0, 2, !dbg !40\n  %\".12\" = sext i32 %\".10\" to i64 , !dbg !40\n  %\".13\" = icmp ne i64 %\".12\", %\".11\" , !dbg !40\n  br i1 %\".13\", label %\"if.then.1\", label %\"if.end.1\", !dbg !40\nif.then.1:\n  %\".15\" = trunc i64 2 to i32 , !dbg !41\n  ret i32 %\".15\", !dbg !41\nif.end.1:\n  %\".17\" = getelementptr [4 x i32], [4 x i32]* @\"SIGNED\", i32 0, i64 2 , !dbg !42\n  %\".18\" = load i32, i32* %\".17\", !dbg !42\n  %\".19\" = sext i32 %\".18\" to i64 , !dbg !42\n  %\".20\" = icmp ne i64 %\".19\", 3 , !dbg !42\n  br i1 %\".20\", label %\"if.then.2\", label %\"if.end.2\", !dbg !42\nif.then.2:\n  %\".22\" = trunc i64 3 to i32 , !dbg !43\n  ret i32 %\".22\", !dbg !43\nif.end.2:\n  %\".24\" = getelementptr [4 x i32], [4 x i32]* @\"SIGNED\", i32 0, i64 3 , !dbg !44\n  %\".25\" = load i32, i32* %\".24\", !dbg !44\n  %\".26\" = sub i64 0, 4, !dbg !44\n  %\".27\" = sext i32 %\".25\" to i64 , !dbg !44\n  %\".28\" = icmp ne i64 %\".27\", %\".26\" , !dbg !44\n  br i1 %\".28\", label %\"if.then.3\", label %\"if.end.3\", !dbg !44\nif.then.3:\n  %\".30\" = trunc i64 4 to i32 , !dbg !45\n  ret i32 %\".30\", !dbg !45\nif.end.3:\n  %\".32\" = trunc i64 0 to i32 , !dbg !46\n  ret i32 %\".32\", !dbg !46\n}"
    },
    "test_const_array_multiline": {
      "hash": "85a5733588b98009",
      "ir": "define internal i32 @\"test_const_array_multiline\"() !dbg !20\n{\nentry:\n  %\".2\" = getelementptr [8 x i8], [8 x i8]* @\"MULTILINE\", i32 0, i64 0 , !dbg !47\n  %\".3\" = load i8, i8* %\".2\", !dbg !47\n  %\".4\" = zext i8 %\".3\" to i64 , !dbg !47\n  %\".5\" = icmp ne i64 %\".4\", 1 , !dbg !47\n  br i1 %\".5\", label %\"if.then\", label %\"if.end\", !dbg !47\nif.then:\n  %\".7\" = trunc i64 1 to i32 , !dbg !48\n  ret i32 %\".7\", !dbg !48\nif.end:\n  %\".9\" = getelementptr [8 x i8], [8 x i8]* @\"MULTILINE\", i32 0, i64 7 , !dbg !49\n  %\".10\" = load i8, i8* %\".9\", !dbg !49\n  %\".11\" = zext i8 %\".10\" to i64 , !dbg !49\n  %\".12\" = icmp ne i64 %\".11\", 8 , !dbg !49\n  br i1 %\".12\", label %\"if.then.1\", label %\"if.end.1\", !dbg !49\nif.then.1:\n  %\".14\" = trunc i64 2 to i32 , !dbg !50\n  ret i32 %\".14\", !dbg !50\nif.end.1:\n  %\".16\" = trunc i64 0 to i32 , !dbg !51\n  ret i32 %\".16\", !dbg !51\n}"
    },
    "test_const_array_sbox_sample": {
      "hash": "d0dffce8b6c04c94",
      "ir": "define internal i32 @\"test_const_array_sbox_sample\"() !dbg !21\n{\nentry:\n  %\".2\" = getelementptr [16 x i8], [16 x i8]* @\"SBOX_SAMPLE\", i32 0, i64 0 , !dbg !52\n  %\".3\" = load i8, i8* %\".2\", !dbg !52\n  %\".4\" = zext i8 %\".3\" to i64 , !dbg !52\n  %\".5\" = icmp ne i64 %\".4\", 99 , !dbg !52\n  br i1 %\".5\", label %\"if.then\", label %\"if.end\", !dbg !52\nif.then:\n  %\".7\" = trunc i64 1 to i32 , !dbg !53\n  ret i32 %\".7\", !dbg !53\nif.end:\n  %\".9\" = getelementptr [16 x i8], [16 x i8]* @\"SBOX_SAMPLE\", i32 0, i64 8 , !dbg !54\n  %\".10\" = load i8, i8* %\".9\", !dbg !54\n  %\".11\" = zext i8 %\".10\" to i64 , !dbg !54\n  %\".12\" = icmp ne i64 %\".11\", 48 , !dbg !54\n  br i1 %\".12\", label %\"if.then.1\", label %\"if.end.1\", !dbg !54\nif.then.1:\n  %\".14\" = trunc i64 2 to i32 , !dbg !55\n  ret i32 %\".14\", !dbg !55\nif.end.1:\n  %\".16\" = getelementptr [16 x i8], [16 x i8]* @\"SBOX_SAMPLE\", i32 0, i64 15 , !dbg !56\n  %\".17\" = load i8, i8* %\".16\", !dbg !56\n  %\".18\" = zext i8 %\".17\" to i64 , !dbg !56\n  %\".19\" = icmp ne i64 %\".18\", 118 , !dbg !56\n  br i1 %\".19\", label %\"if.then.2\", label %\"if.end.2\", !dbg !56\nif.then.2:\n  %\".21\" = trunc i64 3 to i32 , !dbg !57\n  ret i32 %\".21\", !dbg !57\nif.end.2:\n  %\".23\" = trunc i64 0 to i32 , !dbg !58\n  ret i32 %\".23\", !dbg !58\n}"
    },
    "test_const_array_index_variable": {
      "hash": "79f138bde489432e",
      "ir": "define internal i32 @\"test_const_array_index_variable\"() !dbg !22\n{\nentry:\n  %\"idx.addr\" = alloca i32, !dbg !59\n  %\".2\" = trunc i64 2 to i32 , !dbg !59\n  store i32 %\".2\", i32* %\"idx.addr\", !dbg !59\n  call void @\"llvm.dbg.declare\"(metadata i32* %\"idx.addr\", metadata !60, metadata !7), !dbg !61\n  %\".5\" = load i32, i32* %\"idx.addr\", !dbg !62\n  %\".6\" = getelementptr [4 x i8], [4 x i8]* @\"SMALL\", i32 0, i32 %\".5\" , !dbg !62\n  %\".7\" = load i8, i8* %\".6\", !dbg !62\n  %\".8\" = zext i8 %\".7\" to i64 , !dbg !62\n  %\".9\" = icmp ne i64 %\".8\", 119 , !dbg !62\n  br i1 %\".9\", label %\"if.then\", label %\"if.end\", !dbg !62\nif.then:\n  %\".11\" = trunc i64 1 to i32 , !dbg !63\n  ret i32 %\".11\", !dbg !63\nif.end:\n  %\".13\" = trunc i64 0 to i32 , !dbg !64\n  store i32 %\".13\", i32* %\"idx.addr\", !dbg !64\n  %\".15\" = load i32, i32* %\"idx.addr\", !dbg !65\n  %\".16\" = getelementptr [16 x i8], [16 x i8]* @\"SBOX_SAMPLE\", i32 0, i32 %\".15\" , !dbg !65\n  %\".17\" = load i8, i8* %\".16\", !dbg !65\n  %\".18\" = zext i8 %\".17\" to i64 , !dbg !65\n  %\".19\" = icmp ne i64 %\".18\", 99 , !dbg !65\n  br i1 %\".19\", label %\"if.then.1\", label %\"if.end.1\", !dbg !65\nif.then.1:\n  %\".21\" = trunc i64 2 to i32 , !dbg !66\n  ret i32 %\".21\", !dbg !66\nif.end.1:\n  %\".23\" = trunc i64 0 to i32 , !dbg !67\n  ret i32 %\".23\", !dbg !67\n}"
    },
    "sbox_lookup": {
      "hash": "50017ead27b671d1",
      "ir": "define internal i8 @\"sbox_lookup\"(i8 %\"i.arg\") !dbg !23\n{\nentry:\n  %\"i\" = alloca i8\n  store i8 %\"i.arg\", i8* %\"i\"\n  call void @\"llvm.dbg.declare\"(metadata i8* %\"i\", metadata !68, metadata !7), !dbg !69\n  %\".5\" = load i8, i8* %\"i\", !dbg !70\n  %\".6\" = zext i8 %\".5\" to i64 , !dbg !70\n  %\".7\" = getelementptr [16 x i8], [16 x i8]* @\"SBOX_SAMPLE\", i32 0, i64 %\".6\" , !dbg !70\n  %\".8\" = load i8, i8* %\".7\", !dbg !70\n  ret i8 %\".8\", !dbg !70\n}"
    },
    "test_const_array_in_function": {
      "hash": "a3b476e7236710e8",
      "ir": "define internal i32 @\"test_const_array_in_function\"() !dbg !24\n{\nentry:\n  %\".2\" = trunc i64 0 to i8 , !dbg !71\n  %\".3\" = call i8 @\"sbox_lookup\"(i8 %\".2\"), !dbg !71\n  %\".4\" = sext i8 %\".3\" to i64 , !dbg !71\n  %\".5\" = icmp ne i64 %\".4\", 99 , !dbg !71\n  br i1 %\".5\", label %\"if.then\", label %\"if.end\", !dbg !71\nif.then:\n  %\".7\" = trunc i64 1 to i32 , !dbg !72\n  ret i32 %\".7\", !dbg !72\nif.end:\n  %\".9\" = trunc i64 15 to i8 , !dbg !73\n  %\".10\" = call i8 @\"sbox_lookup\"(i8 %\".9\"), !dbg !73\n  %\".11\" = sext i8 %\".10\" to i64 , !dbg !73\n  %\".12\" = icmp ne i64 %\".11\", 118 , !dbg !73\n  br i1 %\".12\", label %\"if.then.1\", label %\"if.end.1\", !dbg !73\nif.then.1:\n  %\".14\" = trunc i64 2 to i32 , !dbg !74\n  ret i32 %\".14\", !dbg !74\nif.end.1:\n  %\".16\" = trunc i64 0 to i32 , !dbg !75\n  ret i32 %\".16\", !dbg !75\n}"
    },
