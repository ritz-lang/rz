# Regression / parity test for ritz-task-87 (match patterns on ritz1).
#
# Exercises the 3 pattern kinds the brief asked for:
#   - integer literal arm
#   - wildcard arm (_)
#   - variant-with-payload arm (Some(v) / Ok(v))
#
# This must compile on ritz0, ritz1, and ritz1_selfhosted.
# Runtime correctness is only enforced on ritz0 (via pytest); ritz1 uses
# a simplified tag-encoded representation for Option/Result so the
# runtime test value will match.

import ritzlib.result

fn classify(n: i32) -> i32
    # Integer-literal match + wildcard fallback.
    match n
        0 => 100
        1 => 101
        2 => 102
        _ => 999

fn pick_some(flag: bool) -> Option<i32>
    if flag
        Some(42)
    else
        None

fn extract_or_zero(opt: Option<i32>) -> i32
    # Variant-with-payload arm (Some(v)) + unit variant arm (None).
    match opt
        Some(v) => v
        None => 0

[[test]]
fn test_match_custom_87_literal() -> i32
    # Int-literal + wildcard arms
    if classify(0) == 100 and classify(1) == 101 and classify(5) == 999
        0
    else
        1

[[test]]
fn test_match_custom_87_variant() -> i32
    # Variant arms
    let a: Option<i32> = pick_some(true)
    let b: Option<i32> = pick_some(false)
    if extract_or_zero(a) == 42 and extract_or_zero(b) == 0
        0
    else
        1
