# test_level31.ritz - Test automatic Drop (RAII)
#
# Tests that Drop is called automatically when variables go out of scope.

import ritzlib.string
import ritzlib.gvec
import ritzlib.box

# ============================================================================
# Test automatic Drop for String
# ============================================================================

[[test]]
fn test_string_auto_drop() -> i32
    # String should be dropped automatically at end of function
    var s: String = string_from("hello world")
    # No explicit drop call - should be automatic
    0

[[test]]
fn test_string_auto_drop_with_return() -> i32
    var s: String = string_from("testing return")
    if 1 == 1
        return 0  # String should be dropped before return
    0

# ============================================================================
# Test automatic Drop for Vec<T>
# ============================================================================

[[test]]
fn test_vec_auto_drop() -> i32
    var v: Vec<i32> = vec_new<i32>()
    vec_push<i32>(&v, 42)
    vec_push<i32>(&v, 100)
    # No explicit drop - should be automatic
    0

[[test]]
fn test_vec_auto_drop_with_data() -> i32
    var v: Vec<i64> = vec_with_cap<i64>(10)
    var i: i64 = 0
    while i < 10
        vec_push<i64>(&v, i * 2)
        i = i + 1
    # Verify data is correct
    if vec_get<i64>(&v, 5) != 10
        return 1
    # Vec should be dropped automatically
    0

# ============================================================================
# Test automatic Drop for Box<T>
# ============================================================================

[[test]]
fn test_box_auto_drop() -> i32
    var b: Box<i32> = box_new<i32>(42)
    if box_get<i32>(&b) != 42
        return 1
    # No explicit drop - should be automatic
    0

[[test]]
fn test_box_auto_drop_large() -> i32
    # Test with larger allocations
    var b1: Box<i64> = box_new<i64>(1000000)
    var b2: Box<i64> = box_new<i64>(2000000)
    var b3: Box<i64> = box_new<i64>(3000000)
    if box_get<i64>(&b1) != 1000000
        return 1
    if box_get<i64>(&b2) != 2000000
        return 2
    if box_get<i64>(&b3) != 3000000
        return 3
    # All three boxes should be dropped automatically
    0

# ============================================================================
# Test multiple variables with Drop
# ============================================================================

[[test]]
fn test_multiple_drops() -> i32
    var s1: String = string_from("first")
    var s2: String = string_from("second")
    var v: Vec<i32> = vec_new<i32>()
    vec_push<i32>(&v, 1)
    var b: Box<i64> = box_new<i64>(999)
    # All should be dropped in reverse order: b, v, s2, s1
    0

[[test]]
fn test_drop_order() -> i32
    # Variables should be dropped in reverse declaration order
    var first: String = string_from("first")
    var second: String = string_from("second")
    var third: String = string_from("third")
    # Drop order should be: third, second, first
    0
