# test_level33.ritz - HashMap tests
#
# Tests the HashMapI64 implementation with i64 keys and values.

import ritzlib.hashmap
import ritzlib.hash
import ritzlib.eq

# ============================================================================
# Basic HashMapI64 tests
# ============================================================================

[[test]]
fn test_hashmap_new() -> i32
    var m: HashMapI64 = hashmap_i64_new()
    assert hashmap_i64_len(@m) == 0, c"new map should be empty"
    assert hashmap_i64_is_empty(@m) == 1, c"new map should be empty"
    hashmap_i64_drop(@m)
    0

[[test]]
fn test_hashmap_insert_get() -> i32
    var m: HashMapI64 = hashmap_i64_new()

    hashmap_i64_insert(@m, 42, 100)
    assert hashmap_i64_len(@m) == 1, c"len should be 1"

    let val: i64 = hashmap_i64_get(@m, 42)
    assert val == 100, c"value should be 100"

    hashmap_i64_drop(@m)
    0

[[test]]
fn test_hashmap_contains() -> i32
    var m: HashMapI64 = hashmap_i64_new()

    assert hashmap_i64_contains(@m, 42) == 0, c"should not contain 42"

    hashmap_i64_insert(@m, 42, 100)
    assert hashmap_i64_contains(@m, 42) == 1, c"should contain 42"
    assert hashmap_i64_contains(@m, 43) == 0, c"should not contain 43"

    hashmap_i64_drop(@m)
    0

[[test]]
fn test_hashmap_update() -> i32
    var m: HashMapI64 = hashmap_i64_new()

    hashmap_i64_insert(@m, 42, 100)
    assert hashmap_i64_get(@m, 42) == 100, c"initial value"

    hashmap_i64_insert(@m, 42, 200)
    assert hashmap_i64_get(@m, 42) == 200, c"updated value"
    assert hashmap_i64_len(@m) == 1, c"len should still be 1"

    hashmap_i64_drop(@m)
    0

[[test]]
fn test_hashmap_multiple_keys() -> i32
    var m: HashMapI64 = hashmap_i64_new()

    hashmap_i64_insert(@m, 1, 10)
    hashmap_i64_insert(@m, 2, 20)
    hashmap_i64_insert(@m, 3, 30)

    assert hashmap_i64_len(@m) == 3, c"len should be 3"
    assert hashmap_i64_get(@m, 1) == 10, c"key 1"
    assert hashmap_i64_get(@m, 2) == 20, c"key 2"
    assert hashmap_i64_get(@m, 3) == 30, c"key 3"

    hashmap_i64_drop(@m)
    0

[[test]]
fn test_hashmap_remove() -> i32
    var m: HashMapI64 = hashmap_i64_new()

    hashmap_i64_insert(@m, 42, 100)
    assert hashmap_i64_contains(@m, 42) == 1, c"should contain 42"

    let removed: i32 = hashmap_i64_remove(@m, 42)
    assert removed == 1, c"should return 1 on successful remove"
    assert hashmap_i64_contains(@m, 42) == 0, c"should not contain 42 after remove"
    assert hashmap_i64_len(@m) == 0, c"len should be 0"

    hashmap_i64_drop(@m)
    0

[[test]]
fn test_hashmap_remove_not_found() -> i32
    var m: HashMapI64 = hashmap_i64_new()

    let removed: i32 = hashmap_i64_remove(@m, 42)
    assert removed == 0, c"should return 0 when key not found"

    hashmap_i64_drop(@m)
    0

[[test]]
fn test_hashmap_many_keys() -> i32
    var m: HashMapI64 = hashmap_i64_new()

    # Insert 50 keys
    var i: i64 = 0
    while i < 50
        hashmap_i64_insert(@m, i, i * 10)
        i = i + 1

    assert hashmap_i64_len(@m) == 50, c"len should be 50"

    # Verify all keys
    i = 0
    while i < 50
        let val: i64 = hashmap_i64_get(@m, i)
        if val != i * 10
            return 1  # Fail
        i = i + 1

    hashmap_i64_drop(@m)
    0

[[test]]
fn test_hashmap_grow() -> i32
    # Start with small capacity
    var m: HashMapI64 = hashmap_i64_with_cap(4)
    assert hashmap_i64_cap(@m) == 16, c"min cap is 16"

    # Insert enough to trigger growth
    var i: i64 = 0
    while i < 20
        hashmap_i64_insert(@m, i, i * 2)
        i = i + 1

    assert hashmap_i64_len(@m) == 20, c"len should be 20"

    # Verify all values still correct after growth
    i = 0
    while i < 20
        if hashmap_i64_get(@m, i) != i * 2
            return 1
        i = i + 1

    hashmap_i64_drop(@m)
    0

[[test]]
fn test_hashmap_collision() -> i32
    # Test keys that might collide (multiples of capacity)
    var m: HashMapI64 = hashmap_i64_with_cap(16)

    # These keys will hash to similar positions
    hashmap_i64_insert(@m, 0, 100)
    hashmap_i64_insert(@m, 16, 200)
    hashmap_i64_insert(@m, 32, 300)

    assert hashmap_i64_get(@m, 0) == 100, c"key 0"
    assert hashmap_i64_get(@m, 16) == 200, c"key 16"
    assert hashmap_i64_get(@m, 32) == 300, c"key 32"

    hashmap_i64_drop(@m)
    0

# ============================================================================
# Syntax sugar tests: m[key] for get, m[key] = value for insert
# ============================================================================

[[test]]
fn test_hashmap_index_get() -> i32
    # Test m[key] syntax for getting values
    var m: HashMapI64 = hashmap_i64_new()

    hashmap_i64_insert(@m, 10, 100)
    hashmap_i64_insert(@m, 20, 200)

    # Use index syntax: m[key] -> hashmap_i64_get(@m, key)
    let val1: i64 = m[10]
    let val2: i64 = m[20]

    assert val1 == 100, c"m[10] should be 100"
    assert val2 == 200, c"m[20] should be 200"

    # Not found returns 0
    let val3: i64 = m[999]
    assert val3 == 0, c"m[999] should be 0 (not found)"

    hashmap_i64_drop(@m)
    0

[[test]]
fn test_hashmap_index_set() -> i32
    # Test m[key] = value syntax for insertion
    var m: HashMapI64 = hashmap_i64_new()

    # Use index assignment syntax: m[key] = val -> hashmap_i64_insert(@m, key, val)
    m[10] = 100
    m[20] = 200
    m[30] = 300

    assert hashmap_i64_len(@m) == 3, c"len should be 3"
    assert m[10] == 100, c"m[10] should be 100"
    assert m[20] == 200, c"m[20] should be 200"
    assert m[30] == 300, c"m[30] should be 300"

    # Update via index assignment
    m[20] = 999
    assert m[20] == 999, c"m[20] should be updated to 999"
    assert hashmap_i64_len(@m) == 3, c"len should still be 3"

    hashmap_i64_drop(@m)
    0

[[test]]
fn test_hashmap_index_mixed() -> i32
    # Test mixing index syntax with regular function calls
    var m: HashMapI64 = hashmap_i64_new()

    # Insert via syntax sugar
    m[1] = 10
    m[2] = 20

    # Read via function
    assert hashmap_i64_get(@m, 1) == 10, c"get via function"

    # Insert via function
    hashmap_i64_insert(@m, 3, 30)

    # Read via syntax sugar
    assert m[3] == 30, c"get via index"

    hashmap_i64_drop(@m)
    0
