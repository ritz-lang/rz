      "ir": "define internal i32 @\"test_forward_call_simple\"() !dbg !17\n{\nentry:\n  %\".2\" = call i32 @\"helper_later\"(), !dbg !34\n  %\".3\" = sext i32 %\".2\" to i64 , !dbg !35\n  %\".4\" = icmp eq i64 %\".3\", 42 , !dbg !35\n  br i1 %\".4\", label %\"assert.pass\", label %\"assert.fail\", !dbg !35\nassert.pass:\n  %\".8\" = trunc i64 0 to i32 , !dbg !36\n  ret i32 %\".8\", !dbg !36\nassert.fail:\n  %\".6\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !35\n  unreachable\n}"
