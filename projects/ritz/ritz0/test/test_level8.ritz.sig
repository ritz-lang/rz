      "ir": "define internal i32 @\"is_even\"(i32 %\"n.arg\") !dbg !22\n{\nentry:\n  %\"n\" = alloca i32\n  store i32 %\"n.arg\", i32* %\"n\"\n  call void @\"llvm.dbg.declare\"(metadata i32* %\"n\", metadata !54, metadata !7), !dbg !55\n  %\".5\" = load i32, i32* %\"n\", !dbg !56\n  %\".6\" = sext i32 %\".5\" to i64 , !dbg !56\n  %\".7\" = icmp eq i64 %\".6\", 0 , !dbg !56\n  br i1 %\".7\", label %\"if.then\", label %\"if.end\", !dbg !56\nif.then:\n  %\".9\" = trunc i64 1 to i32 , !dbg !57\n  ret i32 %\".9\", !dbg !57\nif.end:\n  %\".11\" = load i32, i32* %\"n\", !dbg !58\n  %\".12\" = sext i32 %\".11\" to i64 , !dbg !58\n  %\".13\" = sub i64 %\".12\", 1, !dbg !58\n  %\".14\" = trunc i64 %\".13\" to i32 , !dbg !58\n  %\".15\" = call i32 @\"is_odd\"(i32 %\".14\"), !dbg !58\n  ret i32 %\".15\", !dbg !58\n}"
    },
