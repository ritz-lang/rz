    "add_later": {
      "hash": "50f4db2730a2eda3",
      "ir": "define internal i32 @\"add_later\"(i32 %\"a.arg\", i32 %\"b.arg\") !dbg !20\n{\nentry:\n  %\"a\" = alloca i32\n  store i32 %\"a.arg\", i32* %\"a\"\n  call void @\"llvm.dbg.declare\"(metadata i32* %\"a\", metadata !41, metadata !7), !dbg !42\n  %\"b\" = alloca i32\n  store i32 %\"b.arg\", i32* %\"b\"\n  call void @\"llvm.dbg.declare\"(metadata i32* %\"b\", metadata !43, metadata !7), !dbg !42\n  %\".8\" = load i32, i32* %\"a\", !dbg !44\n  %\".9\" = load i32, i32* %\"b\", !dbg !44\n  %\".10\" = add i32 %\".8\", %\".9\", !dbg !44\n  ret i32 %\".10\", !dbg !44\n}"
    },
    "test_mutual_recursion_even_odd": {
      "hash": "d636d10f16dad961",
      "ir": "define internal i32 @\"test_mutual_recursion_even_odd\"() !dbg !21\n{\nentry:\n  %\".2\" = trunc i64 0 to i32 , !dbg !45\n  %\".3\" = call i32 @\"is_even\"(i32 %\".2\"), !dbg !45\n  %\".4\" = sext i32 %\".3\" to i64 , !dbg !45\n  %\".5\" = icmp eq i64 %\".4\", 1 , !dbg !45\n  br i1 %\".5\", label %\"assert.pass\", label %\"assert.fail\", !dbg !45\nassert.pass:\n  %\".9\" = trunc i64 1 to i32 , !dbg !46\n  %\".10\" = call i32 @\"is_even\"(i32 %\".9\"), !dbg !46\n  %\".11\" = sext i32 %\".10\" to i64 , !dbg !46\n  %\".12\" = icmp eq i64 %\".11\", 0 , !dbg !46\n  br i1 %\".12\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !46\nassert.fail:\n  %\".7\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !45\n  unreachable\nassert.pass.1:\n  %\".16\" = trunc i64 2 to i32 , !dbg !47\n  %\".17\" = call i32 @\"is_even\"(i32 %\".16\"), !dbg !47\n  %\".18\" = sext i32 %\".17\" to i64 , !dbg !47\n  %\".19\" = icmp eq i64 %\".18\", 1 , !dbg !47\n  br i1 %\".19\", label %\"assert.pass.2\", label %\"assert.fail.2\", !dbg !47\nassert.fail.1:\n  %\".14\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !46\n  unreachable\nassert.pass.2:\n  %\".23\" = trunc i64 3 to i32 , !dbg !48\n  %\".24\" = call i32 @\"is_even\"(i32 %\".23\"), !dbg !48\n  %\".25\" = sext i32 %\".24\" to i64 , !dbg !48\n  %\".26\" = icmp eq i64 %\".25\", 0 , !dbg !48\n  br i1 %\".26\", label %\"assert.pass.3\", label %\"assert.fail.3\", !dbg !48\nassert.fail.2:\n  %\".21\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !47\n  unreachable\nassert.pass.3:\n  %\".30\" = trunc i64 10 to i32 , !dbg !49\n  %\".31\" = call i32 @\"is_even\"(i32 %\".30\"), !dbg !49\n  %\".32\" = sext i32 %\".31\" to i64 , !dbg !49\n  %\".33\" = icmp eq i64 %\".32\", 1 , !dbg !49\n  br i1 %\".33\", label %\"assert.pass.4\", label %\"assert.fail.4\", !dbg !49\nassert.fail.3:\n  %\".28\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !48\n  unreachable\nassert.pass.4:\n  %\".37\" = trunc i64 0 to i32 , !dbg !50\n  %\".38\" = call i32 @\"is_odd\"(i32 %\".37\"), !dbg !50\n  %\".39\" = sext i32 %\".38\" to i64 , !dbg !50\n  %\".40\" = icmp eq i64 %\".39\", 0 , !dbg !50\n  br i1 %\".40\", label %\"assert.pass.5\", label %\"assert.fail.5\", !dbg !50\nassert.fail.4:\n  %\".35\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !49\n  unreachable\nassert.pass.5:\n  %\".44\" = trunc i64 1 to i32 , !dbg !51\n  %\".45\" = call i32 @\"is_odd\"(i32 %\".44\"), !dbg !51\n  %\".46\" = sext i32 %\".45\" to i64 , !dbg !51\n  %\".47\" = icmp eq i64 %\".46\", 1 , !dbg !51\n  br i1 %\".47\", label %\"assert.pass.6\", label %\"assert.fail.6\", !dbg !51\nassert.fail.5:\n  %\".42\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !50\n  unreachable\nassert.pass.6:\n  %\".51\" = trunc i64 5 to i32 , !dbg !52\n  %\".52\" = call i32 @\"is_odd\"(i32 %\".51\"), !dbg !52\n  %\".53\" = sext i32 %\".52\" to i64 , !dbg !52\n  %\".54\" = icmp eq i64 %\".53\", 1 , !dbg !52\n  br i1 %\".54\", label %\"assert.pass.7\", label %\"assert.fail.7\", !dbg !52\nassert.fail.6:\n  %\".49\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !51\n  unreachable\nassert.pass.7:\n  %\".58\" = trunc i64 0 to i32 , !dbg !53\n  ret i32 %\".58\", !dbg !53\nassert.fail.7:\n  %\".56\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !52\n  unreachable\n}"
    },
