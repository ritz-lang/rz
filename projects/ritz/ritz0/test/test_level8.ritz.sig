    "test_forward_with_struct": {
      "hash": "66492f89adc9268a",
      "ir": "define internal i32 @\"test_forward_with_struct\"() !dbg !29\n{\nentry:\n  %\".2\" = call i32 @\"get_struct_value\"(), !dbg !79\n  %\".3\" = sext i32 %\".2\" to i64 , !dbg !80\n  %\".4\" = icmp eq i64 %\".3\", 123 , !dbg !80\n  br i1 %\".4\", label %\"assert.pass\", label %\"assert.fail\", !dbg !80\nassert.pass:\n  %\".8\" = trunc i64 0 to i32 , !dbg !81\n  ret i32 %\".8\", !dbg !81\nassert.fail:\n  %\".6\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !80\n  unreachable\n}"
