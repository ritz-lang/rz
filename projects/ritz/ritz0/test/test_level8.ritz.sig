    "test_deref_assign_after_if": {
      "hash": "42680282bb208fe2",
      "ir": "define internal i32 @\"test_deref_assign_after_if\"() !dbg !32\n{\nentry:\n  %\"buf.addr\" = alloca i8*, !dbg !85\n  %\".2\" = alloca i8, i32 10, !dbg !85\n  %\"len.addr\" = alloca i64, !dbg !89\n  store i8* %\".2\", i8** %\"buf.addr\", !dbg !85\n  call void @\"llvm.dbg.declare\"(metadata i8** %\"buf.addr\", metadata !87, metadata !7), !dbg !88\n  store i64 0, i64* %\"len.addr\", !dbg !89\n  call void @\"llvm.dbg.declare\"(metadata i64* %\"len.addr\", metadata !90, metadata !7), !dbg !91\n  %\".7\" = load i64, i64* %\"len.addr\", !dbg !92\n  %\".8\" = icmp sge i64 %\".7\", 10 , !dbg !92\n  br i1 %\".8\", label %\"if.then\", label %\"if.end\", !dbg !92\nif.then:\n  %\".10\" = sub i64 0, 1, !dbg !93\n  %\".11\" = trunc i64 %\".10\" to i32 , !dbg !93\n  ret i32 %\".11\", !dbg !93\nif.end:\n  %\".13\" = trunc i64 65 to i8 , !dbg !94\n  %\".14\" = load i8*, i8** %\"buf.addr\", !dbg !94\n  %\".15\" = load i64, i64* %\"len.addr\", !dbg !94\n  %\".16\" = getelementptr i8, i8* %\".14\", i64 %\".15\" , !dbg !94\n  store i8 %\".13\", i8* %\".16\", !dbg !94\n  %\".18\" = load i64, i64* %\"len.addr\", !dbg !95\n  %\".19\" = add i64 %\".18\", 1, !dbg !95\n  store i64 %\".19\", i64* %\"len.addr\", !dbg !95\n  %\".21\" = load i64, i64* %\"len.addr\", !dbg !96\n  %\".22\" = icmp eq i64 %\".21\", 1 , !dbg !96\n  br i1 %\".22\", label %\"assert.pass\", label %\"assert.fail\", !dbg !96\nassert.pass:\n  %\".26\" = load i8*, i8** %\"buf.addr\", !dbg !97\n  %\".27\" = getelementptr i8, i8* %\".26\", i64 0 , !dbg !97\n  %\".28\" = load i8, i8* %\".27\", !dbg !97\n  %\".29\" = sext i8 %\".28\" to i64 , !dbg !97\n  %\".30\" = icmp eq i64 %\".29\", 65 , !dbg !97\n  br i1 %\".30\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !97\nassert.fail:\n  %\".24\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !96\n  unreachable\nassert.pass.1:\n  %\".34\" = trunc i64 0 to i32 , !dbg !98\n  ret i32 %\".34\", !dbg !98\nassert.fail.1:\n  %\".32\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !97\n  unreachable\n}"
    },
    "test_deref_assign_after_match_style_if": {
      "hash": "712710e24be52d79",
      "ir": "define internal i32 @\"test_deref_assign_after_match_style_if\"() !dbg !33\n{\nentry:\n  %\"buf.addr\" = alloca i8*, !dbg !99\n  %\".2\" = alloca i8, i32 10, !dbg !99\n  %\"idx.addr\" = alloca i64, !dbg !102\n  store i8* %\".2\", i8** %\"buf.addr\", !dbg !99\n  call void @\"llvm.dbg.declare\"(metadata i8** %\"buf.addr\", metadata !100, metadata !7), !dbg !101\n  store i64 0, i64* %\"idx.addr\", !dbg !102\n  call void @\"llvm.dbg.declare\"(metadata i64* %\"idx.addr\", metadata !103, metadata !7), !dbg !104\n  %\".7\" = load i64, i64* %\"idx.addr\", !dbg !105\n  %\".8\" = icmp slt i64 %\".7\", 0 , !dbg !105\n  br i1 %\".8\", label %\"if.then\", label %\"if.else\", !dbg !105\nif.then:\n  store i64 0, i64* %\"idx.addr\", !dbg !106\n  br label %\"if.end\", !dbg !107\nif.else:\n  store i64 1, i64* %\"idx.addr\", !dbg !107\n  br label %\"if.end\", !dbg !107\nif.end:\n  %\".14\" = trunc i64 66 to i8 , !dbg !108\n  %\".15\" = load i8*, i8** %\"buf.addr\", !dbg !108\n  %\".16\" = load i64, i64* %\"idx.addr\", !dbg !108\n  %\".17\" = getelementptr i8, i8* %\".15\", i64 %\".16\" , !dbg !108\n  store i8 %\".14\", i8* %\".17\", !dbg !108\n  %\".19\" = load i8*, i8** %\"buf.addr\", !dbg !109\n  %\".20\" = getelementptr i8, i8* %\".19\", i64 1 , !dbg !109\n  %\".21\" = load i8, i8* %\".20\", !dbg !109\n  %\".22\" = sext i8 %\".21\" to i64 , !dbg !109\n  %\".23\" = icmp eq i64 %\".22\", 66 , !dbg !109\n  br i1 %\".23\", label %\"assert.pass\", label %\"assert.fail\", !dbg !109\nassert.pass:\n  %\".27\" = trunc i64 0 to i32 , !dbg !110\n  ret i32 %\".27\", !dbg !110\nassert.fail:\n  %\".25\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !109\n  unreachable\n}"
    }
  },
