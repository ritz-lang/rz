      "ir": "define internal i32 @\"is_odd\"(i32 %\"n.arg\") !dbg !23\n{\nentry:\n  %\"n\" = alloca i32\n  store i32 %\"n.arg\", i32* %\"n\"\n  call void @\"llvm.dbg.declare\"(metadata i32* %\"n\", metadata !59, metadata !7), !dbg !60\n  %\".5\" = load i32, i32* %\"n\", !dbg !61\n  %\".6\" = sext i32 %\".5\" to i64 , !dbg !61\n  %\".7\" = icmp eq i64 %\".6\", 0 , !dbg !61\n  br i1 %\".7\", label %\"if.then\", label %\"if.end\", !dbg !61\nif.then:\n  %\".9\" = trunc i64 0 to i32 , !dbg !62\n  ret i32 %\".9\", !dbg !62\nif.end:\n  %\".11\" = load i32, i32* %\"n\", !dbg !63\n  %\".12\" = sext i32 %\".11\" to i64 , !dbg !63\n  %\".13\" = sub i64 %\".12\", 1, !dbg !63\n  %\".14\" = trunc i64 %\".13\" to i32 , !dbg !63\n  %\".15\" = call i32 @\"is_even\"(i32 %\".14\"), !dbg !63\n  ret i32 %\".15\", !dbg !63\n}"
    },
    "test_chain_forward_calls": {
      "hash": "34a4ef9cfc5feeb0",
      "ir": "define internal i32 @\"test_chain_forward_calls\"() !dbg !24\n{\nentry:\n  %\".2\" = trunc i64 10 to i32 , !dbg !64\n  %\".3\" = call i32 @\"chain_a\"(i32 %\".2\"), !dbg !64\n  %\".4\" = sext i32 %\".3\" to i64 , !dbg !65\n  %\".5\" = icmp eq i64 %\".4\", 40 , !dbg !65\n  br i1 %\".5\", label %\"assert.pass\", label %\"assert.fail\", !dbg !65\nassert.pass:\n  %\".9\" = trunc i64 0 to i32 , !dbg !66\n  ret i32 %\".9\", !dbg !66\nassert.fail:\n  %\".7\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !65\n  unreachable\n}"
