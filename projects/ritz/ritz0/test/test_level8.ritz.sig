    "chain_a": {
      "hash": "bf121238945d2a1b",
      "ir": "define internal i32 @\"chain_a\"(i32 %\"x.arg\") !dbg !25\n{\nentry:\n  %\"x\" = alloca i32\n  store i32 %\"x.arg\", i32* %\"x\"\n  call void @\"llvm.dbg.declare\"(metadata i32* %\"x\", metadata !67, metadata !7), !dbg !68\n  %\".5\" = load i32, i32* %\"x\", !dbg !69\n  %\".6\" = call i32 @\"chain_b\"(i32 %\".5\"), !dbg !69\n  %\".7\" = sext i32 %\".6\" to i64 , !dbg !69\n  %\".8\" = add i64 %\".7\", 10, !dbg !69\n  %\".9\" = trunc i64 %\".8\" to i32 , !dbg !69\n  ret i32 %\".9\", !dbg !69\n}"
