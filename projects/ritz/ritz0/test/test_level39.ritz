# Test: Closures and Lambda Expressions
# Issue: ritz-lang/ritz#121

# Basic closure without captures - should work
[[test]]
fn test_closure_no_capture() -> i32
    let f: fn(i32) -> i32 = |x| x * 2
    if f(5) != 10
        return 1
    if f(0) != 0
        return 2
    return 0

# Lambda expression with explicit types
[[test]]
fn test_lambda_explicit() -> i32
    let add: fn(i32, i32) -> i32 = fn(a: i32, b: i32) -> i32 a + b
    if add(3, 4) != 7
        return 1
    return 0

# Closure passed as function argument
fn apply(f: fn(i32) -> i32, x: i32) -> i32
    return f(x)

[[test]]
fn test_closure_as_arg() -> i32
    let double: fn(i32) -> i32 = |x| x * 2
    if apply(double, 21) != 42
        return 1
    return 0

# Multiple closures
[[test]]
fn test_multiple_closures() -> i32
    let inc: fn(i32) -> i32 = |x| x + 1
    let dec: fn(i32) -> i32 = |x| x - 1
    if inc(5) != 6
        return 1
    if dec(5) != 4
        return 2
    return 0

# Closure with boolean
[[test]]
fn test_closure_bool() -> i32
    let is_positive: fn(i32) -> bool = |x| x > 0
    if is_positive(5) == false
        return 1
    if is_positive(-5) == true
        return 2
    if is_positive(0) == true
        return 3
    return 0

fn main() -> i32
    return 0
