    "test_shift_combined": {
      "hash": "2e5b2bb30fc2b402",
      "ir": "define internal i32 @\"test_shift_combined\"() !dbg !21\n{\nentry:\n  %\"x.addr\" = alloca i32, !dbg !82\n  %\"y.addr\" = alloca i32, !dbg !88\n  %\".2\" = shl i64 1, 8, !dbg !82\n  %\".3\" = ashr i64 %\".2\", 8, !dbg !82\n  %\".4\" = trunc i64 %\".3\" to i32 , !dbg !82\n  store i32 %\".4\", i32* %\"x.addr\", !dbg !82\n  call void @\"llvm.dbg.declare\"(metadata i32* %\"x.addr\", metadata !83, metadata !7), !dbg !84\n  %\".7\" = load i32, i32* %\"x.addr\", !dbg !85\n  %\".8\" = sext i32 %\".7\" to i64 , !dbg !85\n  %\".9\" = icmp eq i64 %\".8\", 1 , !dbg !85\n  br i1 %\".9\", label %\"assert.pass\", label %\"assert.fail\", !dbg !85\nassert.pass:\n  %\".13\" = shl i64 1, 4, !dbg !86\n  %\".14\" = shl i64 1, 2, !dbg !86\n  %\".15\" = add i64 %\".13\", %\".14\", !dbg !86\n  %\".16\" = trunc i64 %\".15\" to i32 , !dbg !86\n  store i32 %\".16\", i32* %\"x.addr\", !dbg !86\n  %\".18\" = load i32, i32* %\"x.addr\", !dbg !87\n  %\".19\" = sext i32 %\".18\" to i64 , !dbg !87\n  %\".20\" = icmp eq i64 %\".19\", 20 , !dbg !87\n  br i1 %\".20\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !87\nassert.fail:\n  %\".11\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !85\n  unreachable\nassert.pass.1:\n  %\".24\" = trunc i64 43981 to i32 , !dbg !88\n  store i32 %\".24\", i32* %\"y.addr\", !dbg !88\n  call void @\"llvm.dbg.declare\"(metadata i32* %\"y.addr\", metadata !89, metadata !7), !dbg !90\n  %\".27\" = load i32, i32* %\"y.addr\", !dbg !91\n  %\".28\" = sext i32 %\".27\" to i64 , !dbg !91\n  %\".29\" = ashr i64 %\".28\", 8, !dbg !91\n  %\".30\" = trunc i64 %\".29\" to i32 , !dbg !91\n  store i32 %\".30\", i32* %\"x.addr\", !dbg !91\n  %\".32\" = load i32, i32* %\"x.addr\", !dbg !92\n  %\".33\" = sext i32 %\".32\" to i64 , !dbg !92\n  %\".34\" = icmp sgt i64 %\".33\", 0 , !dbg !92\n  br i1 %\".34\", label %\"assert.pass.2\", label %\"assert.fail.2\", !dbg !92\nassert.fail.1:\n  %\".22\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !87\n  unreachable\nassert.pass.2:\n  %\".38\" = load i32, i32* %\"x.addr\", !dbg !93\n  %\".39\" = sext i32 %\".38\" to i64 , !dbg !93\n  %\".40\" = icmp slt i64 %\".39\", 256 , !dbg !93\n  br i1 %\".40\", label %\"assert.pass.3\", label %\"assert.fail.3\", !dbg !93\nassert.fail.2:\n  %\".36\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !92\n  unreachable\nassert.pass.3:\n  %\".44\" = trunc i64 0 to i32 , !dbg !94\n  ret i32 %\".44\", !dbg !94\nassert.fail.3:\n  %\".42\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !93\n  unreachable\n}"
    },
