    "test_left_shift_larger": {
      "hash": "cdc2607a8175f37e",
      "ir": "define internal i32 @\"test_left_shift_larger\"() !dbg !18\n{\nentry:\n  %\"x.addr\" = alloca i32, !dbg !51\n  %\".2\" = shl i64 1, 10, !dbg !51\n  %\".3\" = trunc i64 %\".2\" to i32 , !dbg !51\n  store i32 %\".3\", i32* %\"x.addr\", !dbg !51\n  call void @\"llvm.dbg.declare\"(metadata i32* %\"x.addr\", metadata !52, metadata !7), !dbg !53\n  %\".6\" = load i32, i32* %\"x.addr\", !dbg !54\n  %\".7\" = sext i32 %\".6\" to i64 , !dbg !54\n  %\".8\" = icmp eq i64 %\".7\", 1024 , !dbg !54\n  br i1 %\".8\", label %\"assert.pass\", label %\"assert.fail\", !dbg !54\nassert.pass:\n  %\".12\" = shl i64 3, 4, !dbg !55\n  %\".13\" = trunc i64 %\".12\" to i32 , !dbg !55\n  store i32 %\".13\", i32* %\"x.addr\", !dbg !55\n  %\".15\" = load i32, i32* %\"x.addr\", !dbg !56\n  %\".16\" = sext i32 %\".15\" to i64 , !dbg !56\n  %\".17\" = icmp eq i64 %\".16\", 48 , !dbg !56\n  br i1 %\".17\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !56\nassert.fail:\n  %\".10\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !54\n  unreachable\nassert.pass.1:\n  %\".21\" = shl i64 255, 8, !dbg !57\n  %\".22\" = trunc i64 %\".21\" to i32 , !dbg !57\n  store i32 %\".22\", i32* %\"x.addr\", !dbg !57\n  %\".24\" = load i32, i32* %\"x.addr\", !dbg !58\n  %\".25\" = sext i32 %\".24\" to i64 , !dbg !58\n  %\".26\" = icmp eq i64 %\".25\", 65280 , !dbg !58\n  br i1 %\".26\", label %\"assert.pass.2\", label %\"assert.fail.2\", !dbg !58\nassert.fail.1:\n  %\".19\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !56\n  unreachable\nassert.pass.2:\n  %\".30\" = trunc i64 0 to i32 , !dbg !59\n  ret i32 %\".30\", !dbg !59\nassert.fail.2:\n  %\".28\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !58\n  unreachable\n}"
    },
    "test_right_shift_basic": {
      "hash": "a78a378baa7b6388",
      "ir": "define internal i32 @\"test_right_shift_basic\"() !dbg !19\n{\nentry:\n  %\"x.addr\" = alloca i32, !dbg !60\n  %\".2\" = ashr i64 8, 0, !dbg !60\n  %\".3\" = trunc i64 %\".2\" to i32 , !dbg !60\n  store i32 %\".3\", i32* %\"x.addr\", !dbg !60\n  call void @\"llvm.dbg.declare\"(metadata i32* %\"x.addr\", metadata !61, metadata !7), !dbg !62\n  %\".6\" = load i32, i32* %\"x.addr\", !dbg !63\n  %\".7\" = sext i32 %\".6\" to i64 , !dbg !63\n  %\".8\" = icmp eq i64 %\".7\", 8 , !dbg !63\n  br i1 %\".8\", label %\"assert.pass\", label %\"assert.fail\", !dbg !63\nassert.pass:\n  %\".12\" = ashr i64 8, 1, !dbg !64\n  %\".13\" = trunc i64 %\".12\" to i32 , !dbg !64\n  store i32 %\".13\", i32* %\"x.addr\", !dbg !64\n  %\".15\" = load i32, i32* %\"x.addr\", !dbg !65\n  %\".16\" = sext i32 %\".15\" to i64 , !dbg !65\n  %\".17\" = icmp eq i64 %\".16\", 4 , !dbg !65\n  br i1 %\".17\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !65\nassert.fail:\n  %\".10\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !63\n  unreachable\nassert.pass.1:\n  %\".21\" = ashr i64 8, 2, !dbg !66\n  %\".22\" = trunc i64 %\".21\" to i32 , !dbg !66\n  store i32 %\".22\", i32* %\"x.addr\", !dbg !66\n  %\".24\" = load i32, i32* %\"x.addr\", !dbg !67\n  %\".25\" = sext i32 %\".24\" to i64 , !dbg !67\n  %\".26\" = icmp eq i64 %\".25\", 2 , !dbg !67\n  br i1 %\".26\", label %\"assert.pass.2\", label %\"assert.fail.2\", !dbg !67\nassert.fail.1:\n  %\".19\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !65\n  unreachable\nassert.pass.2:\n  %\".30\" = ashr i64 8, 3, !dbg !68\n  %\".31\" = trunc i64 %\".30\" to i32 , !dbg !68\n  store i32 %\".31\", i32* %\"x.addr\", !dbg !68\n  %\".33\" = load i32, i32* %\"x.addr\", !dbg !69\n  %\".34\" = sext i32 %\".33\" to i64 , !dbg !69\n  %\".35\" = icmp eq i64 %\".34\", 1 , !dbg !69\n  br i1 %\".35\", label %\"assert.pass.3\", label %\"assert.fail.3\", !dbg !69\nassert.fail.2:\n  %\".28\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !67\n  unreachable\nassert.pass.3:\n  %\".39\" = ashr i64 8, 4, !dbg !70\n  %\".40\" = trunc i64 %\".39\" to i32 , !dbg !70\n  store i32 %\".40\", i32* %\"x.addr\", !dbg !70\n  %\".42\" = load i32, i32* %\"x.addr\", !dbg !71\n  %\".43\" = sext i32 %\".42\" to i64 , !dbg !71\n  %\".44\" = icmp eq i64 %\".43\", 0 , !dbg !71\n  br i1 %\".44\", label %\"assert.pass.4\", label %\"assert.fail.4\", !dbg !71\nassert.fail.3:\n  %\".37\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !69\n  unreachable\nassert.pass.4:\n  %\".48\" = trunc i64 0 to i32 , !dbg !72\n  ret i32 %\".48\", !dbg !72\nassert.fail.4:\n  %\".46\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !71\n  unreachable\n}"
    },
    "test_right_shift_larger": {
      "hash": "80484e02664b67d6",
      "ir": "define internal i32 @\"test_right_shift_larger\"() !dbg !20\n{\nentry:\n  %\"x.addr\" = alloca i32, !dbg !73\n  %\".2\" = ashr i64 1024, 10, !dbg !73\n  %\".3\" = trunc i64 %\".2\" to i32 , !dbg !73\n  store i32 %\".3\", i32* %\"x.addr\", !dbg !73\n  call void @\"llvm.dbg.declare\"(metadata i32* %\"x.addr\", metadata !74, metadata !7), !dbg !75\n  %\".6\" = load i32, i32* %\"x.addr\", !dbg !76\n  %\".7\" = sext i32 %\".6\" to i64 , !dbg !76\n  %\".8\" = icmp eq i64 %\".7\", 1 , !dbg !76\n  br i1 %\".8\", label %\"assert.pass\", label %\"assert.fail\", !dbg !76\nassert.pass:\n  %\".12\" = ashr i64 65280, 8, !dbg !77\n  %\".13\" = trunc i64 %\".12\" to i32 , !dbg !77\n  store i32 %\".13\", i32* %\"x.addr\", !dbg !77\n  %\".15\" = load i32, i32* %\"x.addr\", !dbg !78\n  %\".16\" = sext i32 %\".15\" to i64 , !dbg !78\n  %\".17\" = icmp eq i64 %\".16\", 255 , !dbg !78\n  br i1 %\".17\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !78\nassert.fail:\n  %\".10\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !76\n  unreachable\nassert.pass.1:\n  %\".21\" = ashr i64 48, 4, !dbg !79\n  %\".22\" = trunc i64 %\".21\" to i32 , !dbg !79\n  store i32 %\".22\", i32* %\"x.addr\", !dbg !79\n  %\".24\" = load i32, i32* %\"x.addr\", !dbg !80\n  %\".25\" = sext i32 %\".24\" to i64 , !dbg !80\n  %\".26\" = icmp eq i64 %\".25\", 3 , !dbg !80\n  br i1 %\".26\", label %\"assert.pass.2\", label %\"assert.fail.2\", !dbg !80\nassert.fail.1:\n  %\".19\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !78\n  unreachable\nassert.pass.2:\n  %\".30\" = trunc i64 0 to i32 , !dbg !81\n  ret i32 %\".30\", !dbg !81\nassert.fail.2:\n  %\".28\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !80\n  unreachable\n}"
