      "hash": "21b695985af4c9c9",
      "ir": "define internal i32 @\"test_shift_i64\"() !dbg !22\n{\nentry:\n  %\"x.addr\" = alloca i64, !dbg !95\n  %\"y.addr\" = alloca i64, !dbg !99\n  %\".2\" = shl i64 1, 32, !dbg !95\n  store i64 %\".2\", i64* %\"x.addr\", !dbg !95\n  call void @\"llvm.dbg.declare\"(metadata i64* %\"x.addr\", metadata !96, metadata !7), !dbg !97\n  %\".5\" = load i64, i64* %\"x.addr\", !dbg !98\n  %\".6\" = icmp sgt i64 %\".5\", 0 , !dbg !98\n  br i1 %\".6\", label %\"assert.pass\", label %\"assert.fail\", !dbg !98\nassert.pass:\n  %\".10\" = load i64, i64* %\"x.addr\", !dbg !99\n  %\".11\" = ashr i64 %\".10\", 32, !dbg !99\n  store i64 %\".11\", i64* %\"y.addr\", !dbg !99\n  call void @\"llvm.dbg.declare\"(metadata i64* %\"y.addr\", metadata !100, metadata !7), !dbg !101\n  %\".14\" = load i64, i64* %\"y.addr\", !dbg !102\n  %\".15\" = icmp eq i64 %\".14\", 1 , !dbg !102\n  br i1 %\".15\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !102\nassert.fail:\n  %\".8\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !98\n  unreachable\nassert.pass.1:\n  %\".19\" = trunc i64 0 to i32 , !dbg !103\n  ret i32 %\".19\", !dbg !103\nassert.fail.1:\n  %\".17\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !102\n  unreachable\n}"
