    "test_left_shift_basic": {
      "hash": "b5aff36abd3ace29",
      "ir": "define internal i32 @\"test_left_shift_basic\"() !dbg !17\n{\nentry:\n  %\"x.addr\" = alloca i32, !dbg !38\n  %\".2\" = shl i64 1, 0, !dbg !38\n  %\".3\" = trunc i64 %\".2\" to i32 , !dbg !38\n  store i32 %\".3\", i32* %\"x.addr\", !dbg !38\n  call void @\"llvm.dbg.declare\"(metadata i32* %\"x.addr\", metadata !39, metadata !7), !dbg !40\n  %\".6\" = load i32, i32* %\"x.addr\", !dbg !41\n  %\".7\" = sext i32 %\".6\" to i64 , !dbg !41\n  %\".8\" = icmp eq i64 %\".7\", 1 , !dbg !41\n  br i1 %\".8\", label %\"assert.pass\", label %\"assert.fail\", !dbg !41\nassert.pass:\n  %\".12\" = shl i64 1, 1, !dbg !42\n  %\".13\" = trunc i64 %\".12\" to i32 , !dbg !42\n  store i32 %\".13\", i32* %\"x.addr\", !dbg !42\n  %\".15\" = load i32, i32* %\"x.addr\", !dbg !43\n  %\".16\" = sext i32 %\".15\" to i64 , !dbg !43\n  %\".17\" = icmp eq i64 %\".16\", 2 , !dbg !43\n  br i1 %\".17\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !43\nassert.fail:\n  %\".10\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !41\n  unreachable\nassert.pass.1:\n  %\".21\" = shl i64 1, 2, !dbg !44\n  %\".22\" = trunc i64 %\".21\" to i32 , !dbg !44\n  store i32 %\".22\", i32* %\"x.addr\", !dbg !44\n  %\".24\" = load i32, i32* %\"x.addr\", !dbg !45\n  %\".25\" = sext i32 %\".24\" to i64 , !dbg !45\n  %\".26\" = icmp eq i64 %\".25\", 4 , !dbg !45\n  br i1 %\".26\", label %\"assert.pass.2\", label %\"assert.fail.2\", !dbg !45\nassert.fail.1:\n  %\".19\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !43\n  unreachable\nassert.pass.2:\n  %\".30\" = shl i64 1, 3, !dbg !46\n  %\".31\" = trunc i64 %\".30\" to i32 , !dbg !46\n  store i32 %\".31\", i32* %\"x.addr\", !dbg !46\n  %\".33\" = load i32, i32* %\"x.addr\", !dbg !47\n  %\".34\" = sext i32 %\".33\" to i64 , !dbg !47\n  %\".35\" = icmp eq i64 %\".34\", 8 , !dbg !47\n  br i1 %\".35\", label %\"assert.pass.3\", label %\"assert.fail.3\", !dbg !47\nassert.fail.2:\n  %\".28\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !45\n  unreachable\nassert.pass.3:\n  %\".39\" = shl i64 1, 4, !dbg !48\n  %\".40\" = trunc i64 %\".39\" to i32 , !dbg !48\n  store i32 %\".40\", i32* %\"x.addr\", !dbg !48\n  %\".42\" = load i32, i32* %\"x.addr\", !dbg !49\n  %\".43\" = sext i32 %\".42\" to i64 , !dbg !49\n  %\".44\" = icmp eq i64 %\".43\", 16 , !dbg !49\n  br i1 %\".44\", label %\"assert.pass.4\", label %\"assert.fail.4\", !dbg !49\nassert.fail.3:\n  %\".37\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !47\n  unreachable\nassert.pass.4:\n  %\".48\" = trunc i64 0 to i32 , !dbg !50\n  ret i32 %\".48\", !dbg !50\nassert.fail.4:\n  %\".46\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !49\n  unreachable\n}"
