# Regression: `[expr; N]` array-fill literal.
#
# ritz0 supports it; ritz1 was silently dropping enclosing functions when
# the parser hit this construct (AGAST #178).  squeeze/cryptosec and
# valet rely on this for inflate/sbox table init.

fn fill_value() -> i32
    7

[[test]]
fn test_array_fill_literal() -> i32
    let zeros: [4]u8 = [0; 4]
    if zeros[0] != 0 as u8
        return 1
    if zeros[3] != 0 as u8
        return 2

    let negs: [3]i32 = [-1; 3]
    if negs[0] != -1
        return 3
    if negs[2] != -1
        return 4

    let calls: [2]i32 = [fill_value(); 2]
    if calls[0] != 7
        return 5
    if calls[1] != 7
        return 6

    0
