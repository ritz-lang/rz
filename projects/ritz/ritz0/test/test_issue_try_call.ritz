# Regression: `?` should work on regular function calls returning Result.
import ritzlib.result

fn get_value() -> Result<i32, i32>
    Ok(7)

fn add_one_with_try() -> Result<i32, i32>
    let v = get_value()?
    Ok(v + 1)

[[test]]
fn test_try_on_call_expr() -> i32
    let out = add_one_with_try()
    if out.is_ok()
        0
    else
        1
