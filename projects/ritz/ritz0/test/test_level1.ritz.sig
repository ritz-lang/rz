{
  "source_hash": "dcf980572fe6a035",
  "functions": {
    "test_equality": {
      "hash": "909af9da62657600",
      "ir": "define internal i32 @\"test_equality\"() !dbg !17\n{\nentry:\n  %\".2\" = icmp eq i64 1, 1 , !dbg !29\n  br i1 %\".2\", label %\"assert.pass\", label %\"assert.fail\", !dbg !29\nassert.pass:\n  %\".6\" = icmp eq i64 42, 42 , !dbg !30\n  br i1 %\".6\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !30\nassert.fail:\n  %\".4\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !29\n  unreachable\nassert.pass.1:\n  %\".10\" = icmp eq i64 0, 0 , !dbg !31\n  br i1 %\".10\", label %\"assert.pass.2\", label %\"assert.fail.2\", !dbg !31\nassert.fail.1:\n  %\".8\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !30\n  unreachable\nassert.pass.2:\n  %\".14\" = trunc i64 0 to i32 , !dbg !32\n  ret i32 %\".14\", !dbg !32\nassert.fail.2:\n  %\".12\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !31\n  unreachable\n}"
    },
    "test_inequality": {
      "hash": "052cf4dffd5d58b2",
      "ir": "define internal i32 @\"test_inequality\"() !dbg !18\n{\nentry:\n  %\".2\" = icmp ne i64 1, 2 , !dbg !33\n  br i1 %\".2\", label %\"assert.pass\", label %\"assert.fail\", !dbg !33\nassert.pass:\n  %\".6\" = icmp ne i64 0, 1 , !dbg !34\n  br i1 %\".6\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !34\nassert.fail:\n  %\".4\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !33\n  unreachable\nassert.pass.1:\n  %\".10\" = icmp ne i64 100, 99 , !dbg !35\n  br i1 %\".10\", label %\"assert.pass.2\", label %\"assert.fail.2\", !dbg !35\nassert.fail.1:\n  %\".8\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !34\n  unreachable\nassert.pass.2:\n  %\".14\" = trunc i64 0 to i32 , !dbg !36\n  ret i32 %\".14\", !dbg !36\nassert.fail.2:\n  %\".12\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !35\n  unreachable\n}"
    },
    "test_less_than": {
      "hash": "d22e02d1089e0a18",
      "ir": "define internal i32 @\"test_less_than\"() !dbg !19\n{\nentry:\n  %\".2\" = icmp slt i64 1, 2 , !dbg !37\n  br i1 %\".2\", label %\"assert.pass\", label %\"assert.fail\", !dbg !37\nassert.pass:\n  %\".6\" = icmp slt i64 0, 1 , !dbg !38\n  br i1 %\".6\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !38\nassert.fail:\n  %\".4\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !37\n  unreachable\nassert.pass.1:\n  %\".10\" = icmp slt i64 99, 100 , !dbg !39\n  br i1 %\".10\", label %\"assert.pass.2\", label %\"assert.fail.2\", !dbg !39\nassert.fail.1:\n  %\".8\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !38\n  unreachable\nassert.pass.2:\n  %\".14\" = trunc i64 0 to i32 , !dbg !40\n  ret i32 %\".14\", !dbg !40\nassert.fail.2:\n  %\".12\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !39\n  unreachable\n}"
    },
    "test_greater_than": {
      "hash": "e5a9852692f3ae27",
      "ir": "define internal i32 @\"test_greater_than\"() !dbg !20\n{\nentry:\n  %\".2\" = icmp sgt i64 2, 1 , !dbg !41\n  br i1 %\".2\", label %\"assert.pass\", label %\"assert.fail\", !dbg !41\nassert.pass:\n  %\".6\" = icmp sgt i64 1, 0 , !dbg !42\n  br i1 %\".6\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !42\nassert.fail:\n  %\".4\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !41\n  unreachable\nassert.pass.1:\n  %\".10\" = icmp sgt i64 100, 99 , !dbg !43\n  br i1 %\".10\", label %\"assert.pass.2\", label %\"assert.fail.2\", !dbg !43\nassert.fail.1:\n  %\".8\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !42\n  unreachable\nassert.pass.2:\n  %\".14\" = trunc i64 0 to i32 , !dbg !44\n  ret i32 %\".14\", !dbg !44\nassert.fail.2:\n  %\".12\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !43\n  unreachable\n}"
    },
    "test_less_equal": {
      "hash": "b6870a9aaec42a4c",
      "ir": "define internal i32 @\"test_less_equal\"() !dbg !21\n{\nentry:\n  %\".2\" = icmp sle i64 1, 1 , !dbg !45\n  br i1 %\".2\", label %\"assert.pass\", label %\"assert.fail\", !dbg !45\nassert.pass:\n  %\".6\" = icmp sle i64 1, 2 , !dbg !46\n  br i1 %\".6\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !46\nassert.fail:\n  %\".4\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !45\n  unreachable\nassert.pass.1:\n  %\".10\" = icmp sle i64 0, 0 , !dbg !47\n  br i1 %\".10\", label %\"assert.pass.2\", label %\"assert.fail.2\", !dbg !47\nassert.fail.1:\n  %\".8\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !46\n  unreachable\nassert.pass.2:\n  %\".14\" = trunc i64 0 to i32 , !dbg !48\n  ret i32 %\".14\", !dbg !48\nassert.fail.2:\n  %\".12\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !47\n  unreachable\n}"
    },
    "test_greater_equal": {
      "hash": "5e3734b26b51c8f9",
      "ir": "define internal i32 @\"test_greater_equal\"() !dbg !22\n{\nentry:\n  %\".2\" = icmp sge i64 1, 1 , !dbg !49\n  br i1 %\".2\", label %\"assert.pass\", label %\"assert.fail\", !dbg !49\nassert.pass:\n  %\".6\" = icmp sge i64 2, 1 , !dbg !50\n  br i1 %\".6\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !50\nassert.fail:\n  %\".4\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !49\n  unreachable\nassert.pass.1:\n  %\".10\" = icmp sge i64 1, 0 , !dbg !51\n  br i1 %\".10\", label %\"assert.pass.2\", label %\"assert.fail.2\", !dbg !51\nassert.fail.1:\n  %\".8\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !50\n  unreachable\nassert.pass.2:\n  %\".14\" = trunc i64 0 to i32 , !dbg !52\n  ret i32 %\".14\", !dbg !52\nassert.fail.2:\n  %\".12\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !51\n  unreachable\n}"
    },
    "test_l1_addition": {
      "hash": "19a31574e0d1f18d",
      "ir": "define internal i32 @\"test_l1_addition\"() !dbg !23\n{\nentry:\n  %\".2\" = add i64 1, 1, !dbg !53\n  %\".3\" = icmp eq i64 %\".2\", 2 , !dbg !53\n  br i1 %\".3\", label %\"assert.pass\", label %\"assert.fail\", !dbg !53\nassert.pass:\n  %\".7\" = add i64 0, 0, !dbg !54\n  %\".8\" = icmp eq i64 %\".7\", 0 , !dbg !54\n  br i1 %\".8\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !54\nassert.fail:\n  %\".5\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !53\n  unreachable\nassert.pass.1:\n  %\".12\" = add i64 10, 20, !dbg !55\n  %\".13\" = icmp eq i64 %\".12\", 30 , !dbg !55\n  br i1 %\".13\", label %\"assert.pass.2\", label %\"assert.fail.2\", !dbg !55\nassert.fail.1:\n  %\".10\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !54\n  unreachable\nassert.pass.2:\n  %\".17\" = trunc i64 0 to i32 , !dbg !56\n  ret i32 %\".17\", !dbg !56\nassert.fail.2:\n  %\".15\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !55\n  unreachable\n}"
    },
    "test_subtraction": {
      "hash": "3cbe76e90abd093d",
      "ir": "define internal i32 @\"test_subtraction\"() !dbg !24\n{\nentry:\n  %\".2\" = sub i64 2, 1, !dbg !57\n  %\".3\" = icmp eq i64 %\".2\", 1 , !dbg !57\n  br i1 %\".3\", label %\"assert.pass\", label %\"assert.fail\", !dbg !57\nassert.pass:\n  %\".7\" = sub i64 10, 5, !dbg !58\n  %\".8\" = icmp eq i64 %\".7\", 5 , !dbg !58\n  br i1 %\".8\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !58\nassert.fail:\n  %\".5\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !57\n  unreachable\nassert.pass.1:\n  %\".12\" = sub i64 100, 100, !dbg !59\n  %\".13\" = icmp eq i64 %\".12\", 0 , !dbg !59\n  br i1 %\".13\", label %\"assert.pass.2\", label %\"assert.fail.2\", !dbg !59\nassert.fail.1:\n  %\".10\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !58\n  unreachable\nassert.pass.2:\n  %\".17\" = trunc i64 0 to i32 , !dbg !60\n  ret i32 %\".17\", !dbg !60\nassert.fail.2:\n  %\".15\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !59\n  unreachable\n}"
    },
    "test_multiplication": {
      "hash": "f25a6392de8dbd7f",
      "ir": "define internal i32 @\"test_multiplication\"() !dbg !25\n{\nentry:\n  %\".2\" = mul i64 2, 3, !dbg !61\n  %\".3\" = icmp eq i64 %\".2\", 6 , !dbg !61\n  br i1 %\".3\", label %\"assert.pass\", label %\"assert.fail\", !dbg !61\nassert.pass:\n  %\".7\" = mul i64 10, 10, !dbg !62\n  %\".8\" = icmp eq i64 %\".7\", 100 , !dbg !62\n  br i1 %\".8\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !62\nassert.fail:\n  %\".5\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !61\n  unreachable\nassert.pass.1:\n  %\".12\" = mul i64 1, 0, !dbg !63\n  %\".13\" = icmp eq i64 %\".12\", 0 , !dbg !63\n  br i1 %\".13\", label %\"assert.pass.2\", label %\"assert.fail.2\", !dbg !63\nassert.fail.1:\n  %\".10\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !62\n  unreachable\nassert.pass.2:\n  %\".17\" = trunc i64 0 to i32 , !dbg !64\n  ret i32 %\".17\", !dbg !64\nassert.fail.2:\n  %\".15\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !63\n  unreachable\n}"
    },
    "test_division": {
      "hash": "283d04a27ce543dc",
      "ir": "define internal i32 @\"test_division\"() !dbg !26\n{\nentry:\n  %\".2\" = sdiv i64 6, 2, !dbg !65\n  %\".3\" = icmp eq i64 %\".2\", 3 , !dbg !65\n  br i1 %\".3\", label %\"assert.pass\", label %\"assert.fail\", !dbg !65\nassert.pass:\n  %\".7\" = sdiv i64 10, 5, !dbg !66\n  %\".8\" = icmp eq i64 %\".7\", 2 , !dbg !66\n  br i1 %\".8\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !66\nassert.fail:\n  %\".5\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !65\n  unreachable\nassert.pass.1:\n  %\".12\" = sdiv i64 100, 10, !dbg !67\n  %\".13\" = icmp eq i64 %\".12\", 10 , !dbg !67\n  br i1 %\".13\", label %\"assert.pass.2\", label %\"assert.fail.2\", !dbg !67\nassert.fail.1:\n  %\".10\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !66\n  unreachable\nassert.pass.2:\n  %\".17\" = trunc i64 0 to i32 , !dbg !68\n  ret i32 %\".17\", !dbg !68\nassert.fail.2:\n  %\".15\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !67\n  unreachable\n}"
    },
    "test_combined_arithmetic": {
      "hash": "3b9f99e7575edae0",
      "ir": "define internal i32 @\"test_combined_arithmetic\"() !dbg !27\n{\nentry:\n  %\".2\" = mul i64 3, 4, !dbg !69\n  %\".3\" = add i64 2, %\".2\", !dbg !69\n  %\".4\" = icmp eq i64 %\".3\", 14 , !dbg !69\n  br i1 %\".4\", label %\"assert.pass\", label %\"assert.fail\", !dbg !69\nassert.pass:\n  %\".8\" = mul i64 2, 3, !dbg !70\n  %\".9\" = sub i64 10, %\".8\", !dbg !70\n  %\".10\" = icmp eq i64 %\".9\", 4 , !dbg !70\n  br i1 %\".10\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !70\nassert.fail:\n  %\".6\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !69\n  unreachable\nassert.pass.1:\n  %\".14\" = trunc i64 0 to i32 , !dbg !71\n  ret i32 %\".14\", !dbg !71\nassert.fail.1:\n  %\".12\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !70\n  unreachable\n}"
    },
    "test_parentheses": {
      "hash": "d4d480c72676f138",
      "ir": "define internal i32 @\"test_parentheses\"() !dbg !28\n{\nentry:\n  %\".2\" = add i64 2, 3, !dbg !72\n  %\".3\" = mul i64 %\".2\", 4, !dbg !72\n  %\".4\" = icmp eq i64 %\".3\", 20 , !dbg !72\n  br i1 %\".4\", label %\"assert.pass\", label %\"assert.fail\", !dbg !72\nassert.pass:\n  %\".8\" = sub i64 10, 2, !dbg !73\n  %\".9\" = mul i64 %\".8\", 3, !dbg !73\n  %\".10\" = icmp eq i64 %\".9\", 24 , !dbg !73\n  br i1 %\".10\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !73\nassert.fail:\n  %\".6\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !72\n  unreachable\nassert.pass.1:\n  %\".14\" = trunc i64 0 to i32 , !dbg !74\n  ret i32 %\".14\", !dbg !74\nassert.fail.1:\n  %\".12\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !73\n  unreachable\n}"
    }
  },
  "imports": []
}
