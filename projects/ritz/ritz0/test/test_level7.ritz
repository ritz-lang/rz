# Test Level 7: Cast Operator and Array Fill
#
# Features tested:
# - Cast operator (as)
# - Array fill syntax [value; count]
# - Pointer casting for struct access

struct Point
  x: i32
  y: i32

# ============================================================================
# Cast Operator Tests
# ============================================================================

[[test]]
fn test_cast_int_to_int() -> i32
  # Cast between integer types
  let a: i64 = 42
  let b: i32 = a as i32
  assert b == 42
  0

[[test]]
fn test_cast_i32_to_i64() -> i32
  # Widening cast
  let a: i32 = 100
  let b: i64 = a as i64
  assert b == 100
  0

[[test]]
fn test_cast_ptr_to_ptr() -> i32
  # Cast between pointer types
  var val: i32 = 99
  let ptr: *i32 = @val
  let generic: *i8 = ptr as *i8
  let back: *i32 = generic as *i32
  assert *back == 99
  0

[[test]]
fn test_cast_struct_ptr() -> i32
  # Cast generic pointer to struct pointer
  var pt: Point = Point { x: 10, y: 20 }
  let ptr: *Point = @pt
  let generic: *i8 = ptr as *i8
  let typed: *Point = generic as *Point
  assert typed.x == 10
  assert typed.y == 20
  0

[[test]]
fn test_cast_precedence() -> i32
  # Cast has high precedence
  let a: i64 = 5
  let b: i32 = a as i32 + 3
  assert b == 8
  0

# ============================================================================
# Array Fill Tests
# ============================================================================

[[test]]
fn test_array_fill_zeros() -> i32
  # Fill array with zeros
  var arr: [8]i32 = [0; 8]
  assert arr[0] == 0
  assert arr[7] == 0
  0

[[test]]
fn test_array_fill_value() -> i32
  # Fill array with non-zero value
  var arr: [5]i32 = [42; 5]
  assert arr[0] == 42
  assert arr[2] == 42
  assert arr[4] == 42
  0

[[test]]
fn test_array_fill_sum() -> i32
  # Verify all elements via sum
  var arr: [4]i32 = [10; 4]
  let sum: i32 = arr[0] + arr[1] + arr[2] + arr[3]
  assert sum == 40
  0

[[test]]
fn test_array_fill_modify() -> i32
  # Fill then modify individual elements
  var arr: [3]i32 = [1; 3]
  arr[1] = 99
  assert arr[0] == 1
  assert arr[1] == 99
  assert arr[2] == 1
  0

[[test]]
fn test_array_fill_small() -> i32
  # Minimal fill (single element)
  var arr: [1]i32 = [7; 1]
  assert arr[0] == 7
  0

