# Test level 19: Bit shift operators (<< and >>)
#
# Tests left shift and right shift operators

import ritzlib.sys
import ritzlib.io

# ============================================================================
# Test: Left shift (<<)
# ============================================================================

[[test]]
fn test_left_shift_basic() -> i32
    # 1 << 0 = 1
    var x: i32 = 1 << 0
    assert x == 1, c"1 << 0 should be 1"

    # 1 << 1 = 2
    x = 1 << 1
    assert x == 2, c"1 << 1 should be 2"

    # 1 << 2 = 4
    x = 1 << 2
    assert x == 4, c"1 << 2 should be 4"

    # 1 << 3 = 8
    x = 1 << 3
    assert x == 8, c"1 << 3 should be 8"

    # 1 << 4 = 16
    x = 1 << 4
    assert x == 16, c"1 << 4 should be 16"

    return 0

[[test]]
fn test_left_shift_larger() -> i32
    # 1 << 10 = 1024
    var x: i32 = 1 << 10
    assert x == 1024, c"1 << 10 should be 1024"

    # 3 << 4 = 48 (binary: 11 -> 110000)
    x = 3 << 4
    assert x == 48, c"3 << 4 should be 48"

    # 0xFF << 8 = 0xFF00 = 65280
    x = 255 << 8
    assert x == 65280, c"255 << 8 should be 65280"

    return 0

# ============================================================================
# Test: Right shift (>>)
# ============================================================================

[[test]]
fn test_right_shift_basic() -> i32
    # 8 >> 0 = 8
    var x: i32 = 8 >> 0
    assert x == 8, c"8 >> 0 should be 8"

    # 8 >> 1 = 4
    x = 8 >> 1
    assert x == 4, c"8 >> 1 should be 4"

    # 8 >> 2 = 2
    x = 8 >> 2
    assert x == 2, c"8 >> 2 should be 2"

    # 8 >> 3 = 1
    x = 8 >> 3
    assert x == 1, c"8 >> 3 should be 1"

    # 8 >> 4 = 0
    x = 8 >> 4
    assert x == 0, c"8 >> 4 should be 0"

    return 0

[[test]]
fn test_right_shift_larger() -> i32
    # 1024 >> 10 = 1
    var x: i32 = 1024 >> 10
    assert x == 1, c"1024 >> 10 should be 1"

    # 65280 >> 8 = 255
    x = 65280 >> 8
    assert x == 255, c"65280 >> 8 should be 255"

    # 48 >> 4 = 3
    x = 48 >> 4
    assert x == 3, c"48 >> 4 should be 3"

    return 0

# ============================================================================
# Test: Combined operations
# ============================================================================

[[test]]
fn test_shift_combined() -> i32
    # Round-trip: (1 << 8) >> 8 = 1
    var x: i32 = (1 << 8) >> 8
    assert x == 1, c"(1 << 8) >> 8 should be 1"

    # Combined with other operators
    # (1 << 4) + (1 << 2) = 16 + 4 = 20
    x = (1 << 4) + (1 << 2)
    assert x == 20, c"(1 << 4) + (1 << 2) should be 20"

    # Bit masking: 0xABCD & 0xFF = 0xCD (205)
    # (0xABCD >> 8) & 0xFF = 0xAB (171)
    var y: i32 = 43981  # 0xABCD
    x = (y >> 8)
    # Just check it's not 0 and is reasonable
    assert x > 0, c"43981 >> 8 should be positive"
    assert x < 256, c"43981 >> 8 should be < 256"

    return 0

# ============================================================================
# Test: 64-bit shifts
# ============================================================================

[[test]]
fn test_shift_i64() -> i32
    # Large value that requires i64
    var x: i64 = 1 as i64 << 32
    # 2^32 = 4294967296
    assert x > 0, c"1 << 32 should be positive"

    # Shift back down
    var y: i64 = x >> 32
    assert y == 1, c"(1 << 32) >> 32 should be 1"

    return 0

# ============================================================================
# Main entry point
# ============================================================================

fn main() -> i32
    prints("Test level 19: Bit shift operators\n")
    prints("OK\n")
    return 0
