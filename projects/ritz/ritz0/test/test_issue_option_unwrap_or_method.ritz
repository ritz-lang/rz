import ritzlib.option

fn maybe_val(flag: bool) -> Option<i32>
    if flag
        Some(7)
    else
        None

[[test]]
fn test_option_unwrap_or_method() -> i32
    let a = maybe_val(true).unwrap_or(1)
    let b = maybe_val(false).unwrap_or(1)
    if a == 7 and b == 1
        0
    else
        1
