# AGAST #179: `@x.forward[i].member` over a struct field of type **Foo
# emitted `inttoptr i64 %.0 to ptr` — undef SSA reference.
#
# Shape: addr-of(MEMBER over INDEX over MEMBER over IDENT) where the
# innermost field is **Foo (pointer-to-pointer), e.g. tome.ritz's
# ZSetNode.forward field used in zset_compare(@x.forward[i].member, ...).
#
# Pre-fix: emit_member_ptr's EXPR_INDEX-with-MEMBER-base only handled
# TYPE_ARRAY-of-struct, so the **Foo case fell through to "; ERROR:
# unhandled EXPR_MEMBER" and the OP_ADDR branch hit "; ERROR: cannot
# take address" — the call-site reused undef %.0 for the i64 arg.
#
# Fix: extend emit_member_ptr to handle TYPE_PTR_PTR-with-named-pointee
# (load ptr → GEP by ptr stride → load ptr → GEP into struct), AND
# route addr-of-EXPR_MEMBER through emit_member_ptr as a fallback.
#
# Compile-only smoke test — building this file with ritz1 used to fail
# with `error: use of undefined value '%.0'` during LLVM verification.

struct Inner
    score: i64
    member: i64

struct Outer
    forward: **Inner
    pad: i64

# Address-of through the failing chain — was emitting `inttoptr i64 %.0`.
fn addr_chain_member(o: *Outer, i: i32) -> i64
    @o.forward[i].member

# Value access through the same chain — was emitting wrong byte-stride
# fallback (load i8 instead of load ptr); the emit_member_ptr fix also
# unlocks this path.
fn read_chain_score(o: *Outer, i: i32) -> i64
    o.forward[i].score

[[test]]
fn test_addr_of_chain_ptr_ptr_member() -> i32
    # Compile-only smoke test: if we got here, the emitter produced a
    # valid LLVM module for addr_chain_member and read_chain_score.
    # Pre-fix, ritz1 failed at LLVM verification with undef-%.0.
    0
