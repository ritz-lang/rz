# Test Level 2: Variables in tests
#
# Features tested:
# - let bindings (immutable)
# - var bindings (mutable)
# - Assignment
# - Variable in assert expressions

[[test]]
fn test_let_binding() -> i32
  let x: i32 = 42
  assert x == 42
  0

[[test]]
fn test_var_binding() -> i32
  var x: i32 = 10
  assert x == 10
  x = 20
  assert x == 20
  0

[[test]]
fn test_multiple_vars() -> i32
  var a: i32 = 1
  var b: i32 = 2
  var c: i32 = 3
  assert a + b + c == 6
  0

[[test]]
fn test_var_arithmetic() -> i32
  var x: i32 = 10
  x = x + 5
  assert x == 15
  x = x * 2
  assert x == 30
  0

[[test]]
fn test_i64_variables() -> i32
  var x: i64 = 1000000000000
  assert x > 0
  0

[[test]]
fn test_pointer_deref() -> i32
  var x: i32 = 42
  let ptr: *i32 = &x
  assert *ptr == 42
  0

[[test]]
fn test_pointer_write() -> i32
  var x: i32 = 10
  let ptr: *i32 = &x
  *ptr = 20
  assert x == 20
  0
