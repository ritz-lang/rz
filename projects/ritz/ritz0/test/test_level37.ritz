# Test: Direct cast from pointer dereference to wider integer
# Issue: ritz-lang/ritz#92
# Bug: s[0] as i64 produces wrong value, but let b = s[0]; b as i64 works

fn read_one_byte(s: *u8) -> i64
    return s[0] as i64

fn read_one_byte_fixed(s: *u8) -> i64
    let b: u8 = s[0]
    return b as i64

[[test]]
fn test_direct_cast_u8_to_i64() -> i32
    var data: [64]u8
    data[0] = 0xb6  # 182 decimal

    let val: i64 = read_one_byte(@data[0])
    if val != 182
        return 1  # FAILS - val has incorrect value

    return 0

[[test]]
fn test_intermediate_var_u8_to_i64() -> i32
    var data: [64]u8
    data[0] = 0xb6  # 182 decimal

    let val: i64 = read_one_byte_fixed(@data[0])
    if val != 182
        return 1  # PASSES

    return 0

[[test]]
fn test_direct_cast_in_expression() -> i32
    var data: [64]u8
    data[0] = 0xff  # 255 decimal

    # Direct cast in expression should also work
    let result: i64 = data[0] as i64
    if result != 255
        return 1

    return 0

[[test]]
fn test_ptr_index_cast() -> i32
    var data: [64]u8
    data[0] = 0x80  # 128 decimal

    let ptr: *u8 = @data[0]
    let val: i64 = ptr[0] as i64
    if val != 128
        return 1

    return 0

fn main() -> i32
    return 0
