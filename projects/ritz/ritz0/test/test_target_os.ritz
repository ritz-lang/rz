# Test file for [[target_os = "..."]] conditional compilation

[[target_os = "linux"]]
fn linux_syscall() -> i64
    # Linux-specific implementation
    return 42

[[target_os = "harland"]]
fn linux_syscall() -> i64
    # Harland-specific implementation
    return 99

# This function is always included
fn main() -> i32
    let result: i64 = linux_syscall()
    return result as i32
