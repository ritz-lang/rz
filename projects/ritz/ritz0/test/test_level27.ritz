# Test level 27: Generic Vec<T>
#
# Tests the Vec<T> type for dynamic arrays.
# Features tested:
# - vec_new<T> creates empty vec
# - vec_push<T> appends elements
# - vec_get<T> retrieves elements
# - vec_pop<T> removes last element
# - vec_drop<T> frees memory
# - Vec<T> with various types (i32, i64, structs)

import ritzlib.sys
import ritzlib.io
import ritzlib.gvec

# ============================================================================
# Basic Vec Tests
# ============================================================================

[[test]]
fn test_vec_i32_basic() -> i32
    var v: Vec<i32> = vec_new<i32>()
    assert vec_len<i32>(@v) == 0, c"new vec should be empty"
    assert vec_is_empty<i32>(@v) == 1, c"new vec should be empty"

    # Push some elements
    vec_push<i32>(@v, 10)
    vec_push<i32>(@v, 20)
    vec_push<i32>(@v, 30)

    assert vec_len<i32>(@v) == 3, c"len should be 3"
    assert vec_is_empty<i32>(@v) == 0, c"vec should not be empty"

    # Get elements
    assert vec_get<i32>(@v, 0) == 10, c"v[0] should be 10"
    assert vec_get<i32>(@v, 1) == 20, c"v[1] should be 20"
    assert vec_get<i32>(@v, 2) == 30, c"v[2] should be 30"

    vec_drop<i32>(@v)
    return 0

[[test]]
fn test_vec_i64_basic() -> i32
    var v: Vec<i64> = vec_new<i64>()

    vec_push<i64>(@v, 1000000)
    vec_push<i64>(@v, 2000000)

    assert vec_len<i64>(@v) == 2, c"len should be 2"
    assert vec_get<i64>(@v, 0) == 1000000, c"v[0] should be 1000000"
    assert vec_get<i64>(@v, 1) == 2000000, c"v[1] should be 2000000"

    vec_drop<i64>(@v)
    return 0

[[test]]
fn test_vec_pop() -> i32
    var v: Vec<i32> = vec_new<i32>()

    vec_push<i32>(@v, 1)
    vec_push<i32>(@v, 2)
    vec_push<i32>(@v, 3)

    assert vec_len<i32>(@v) == 3, c"len should be 3"

    let a: i32 = vec_pop<i32>(@v)
    assert a == 3, c"popped should be 3"
    assert vec_len<i32>(@v) == 2, c"len should be 2"

    let b: i32 = vec_pop<i32>(@v)
    assert b == 2, c"popped should be 2"
    assert vec_len<i32>(@v) == 1, c"len should be 1"

    let c: i32 = vec_pop<i32>(@v)
    assert c == 1, c"popped should be 1"
    assert vec_len<i32>(@v) == 0, c"len should be 0"

    vec_drop<i32>(@v)
    return 0

[[test]]
fn test_vec_set() -> i32
    var v: Vec<i32> = vec_new<i32>()

    vec_push<i32>(@v, 100)
    vec_push<i32>(@v, 200)

    assert vec_get<i32>(@v, 0) == 100, c"v[0] should be 100"

    vec_set<i32>(@v, 0, 999)
    assert vec_get<i32>(@v, 0) == 999, c"v[0] should be 999"

    vec_drop<i32>(@v)
    return 0

[[test]]
fn test_vec_first_last() -> i32
    var v: Vec<i32> = vec_new<i32>()

    vec_push<i32>(@v, 1)
    vec_push<i32>(@v, 2)
    vec_push<i32>(@v, 3)

    assert vec_first<i32>(@v) == 1, c"first should be 1"
    assert vec_last<i32>(@v) == 3, c"last should be 3"

    vec_drop<i32>(@v)
    return 0

# ============================================================================
# Vec with Struct Types
# ============================================================================

struct Point
    x: i32
    y: i32

[[test]]
fn test_vec_struct() -> i32
    var v: Vec<Point> = vec_new<Point>()

    var p1: Point = Point { x: 10, y: 20 }
    var p2: Point = Point { x: 30, y: 40 }

    vec_push<Point>(@v, p1)
    vec_push<Point>(@v, p2)

    assert vec_len<Point>(@v) == 2, c"len should be 2"

    let got1: Point = vec_get<Point>(@v, 0)
    assert got1.x == 10, c"p1.x should be 10"
    assert got1.y == 20, c"p1.y should be 20"

    let got2: Point = vec_get<Point>(@v, 1)
    assert got2.x == 30, c"p2.x should be 30"
    assert got2.y == 40, c"p2.y should be 40"

    vec_drop<Point>(@v)
    return 0

[[test]]
fn test_vec_struct_ptr() -> i32
    var v: Vec<Point> = vec_new<Point>()

    var p: Point = Point { x: 1, y: 2 }
    vec_push<Point>(@v, p)

    # Modify via pointer
    let ptr: *Point = vec_get_ptr<Point>(@v, 0)
    ptr.x = 100
    ptr.y = 200

    let got: Point = vec_get<Point>(@v, 0)
    assert got.x == 100, c"x should be 100"
    assert got.y == 200, c"y should be 200"

    vec_drop<Point>(@v)
    return 0

# ============================================================================
# Capacity and Growth Tests
# ============================================================================

[[test]]
fn test_vec_with_cap() -> i32
    var v: Vec<i32> = vec_with_cap<i32>(100)

    assert vec_len<i32>(@v) == 0, c"len should be 0"
    assert vec_cap<i32>(@v) >= 100, c"cap should be >= 100"

    vec_push<i32>(@v, 42)
    assert vec_len<i32>(@v) == 1, c"len should be 1"
    assert vec_cap<i32>(@v) >= 100, c"cap should still be >= 100"

    vec_drop<i32>(@v)
    return 0

[[test]]
fn test_vec_growth() -> i32
    var v: Vec<i32> = vec_new<i32>()

    # Push more than initial capacity to trigger growth
    var i: i32 = 0
    while i < 100
        vec_push<i32>(@v, i)
        i = i + 1

    assert vec_len<i32>(@v) == 100, c"len should be 100"
    assert vec_cap<i32>(@v) >= 100, c"cap should be >= 100"

    # Verify all elements
    i = 0
    while i < 100
        assert vec_get<i32>(@v, i as i64) == i, c"element mismatch"
        i = i + 1

    vec_drop<i32>(@v)
    return 0

[[test]]
fn test_vec_clear() -> i32
    var v: Vec<i32> = vec_new<i32>()

    vec_push<i32>(@v, 1)
    vec_push<i32>(@v, 2)
    vec_push<i32>(@v, 3)

    let old_cap: i64 = vec_cap<i32>(@v)

    vec_clear<i32>(@v)
    assert vec_len<i32>(@v) == 0, c"len should be 0 after clear"
    assert vec_cap<i32>(@v) == old_cap, c"cap should be unchanged"

    # Can push again
    vec_push<i32>(@v, 42)
    assert vec_get<i32>(@v, 0) == 42, c"new element should be 42"

    vec_drop<i32>(@v)
    return 0

# ============================================================================
# u8 Vec Test
# ============================================================================

[[test]]
fn test_vec_u8() -> i32
    var v: Vec<u8> = vec_new<u8>()

    vec_push<u8>(@v, 65)  # 'A'
    vec_push<u8>(@v, 66)  # 'B'
    vec_push<u8>(@v, 67)  # 'C'

    assert vec_len<u8>(@v) == 3, c"len should be 3"
    assert vec_get<u8>(@v, 0) == 65, c"v[0] should be 65"
    assert vec_get<u8>(@v, 1) == 66, c"v[1] should be 66"
    assert vec_get<u8>(@v, 2) == 67, c"v[2] should be 67"

    vec_drop<u8>(@v)
    return 0

# ============================================================================
# Main entry point
# ============================================================================

fn main() -> i32
    prints("Test level 27: Generic Vec<T>\n")

    # Run all tests
    test_vec_i32_basic()
    test_vec_i64_basic()
    test_vec_pop()
    test_vec_set()
    test_vec_first_last()
    test_vec_struct()
    test_vec_struct_ptr()
    test_vec_with_cap()
    test_vec_growth()
    test_vec_clear()
    test_vec_u8()

    prints("All Vec<T> tests passed!\n")
    return 0
