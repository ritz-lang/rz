{
  "source_hash": "b9a0a5087cfceb54",
  "functions": {
    "test_for_basic_sum": {
      "hash": "cda1497c59760a87",
      "ir": "define internal i32 @\"test_for_basic_sum\"() !dbg !17\n{\nentry:\n  %\"sum.addr\" = alloca i32, !dbg !41\n  %\"i\" = alloca i64, !dbg !44\n  %\".2\" = trunc i64 0 to i32 , !dbg !41\n  store i32 %\".2\", i32* %\"sum.addr\", !dbg !41\n  call void @\"llvm.dbg.declare\"(metadata i32* %\"sum.addr\", metadata !42, metadata !7), !dbg !43\n  store i64 0, i64* %\"i\", !dbg !44\n  br label %\"for.cond\", !dbg !44\nfor.cond:\n  %\".7\" = load i64, i64* %\"i\", !dbg !44\n  %\".8\" = icmp slt i64 %\".7\", 5 , !dbg !44\n  br i1 %\".8\", label %\"for.body\", label %\"for.end\", !dbg !44\nfor.body:\n  %\".10\" = load i32, i32* %\"sum.addr\", !dbg !45\n  %\".11\" = load i64, i64* %\"i\", !dbg !45\n  %\".12\" = sext i32 %\".10\" to i64 , !dbg !45\n  %\".13\" = add i64 %\".12\", %\".11\", !dbg !45\n  %\".14\" = trunc i64 %\".13\" to i32 , !dbg !45\n  store i32 %\".14\", i32* %\"sum.addr\", !dbg !45\n  br label %\"for.incr\", !dbg !45\nfor.incr:\n  %\".17\" = load i64, i64* %\"i\", !dbg !45\n  %\".18\" = add i64 %\".17\", 1, !dbg !45\n  store i64 %\".18\", i64* %\"i\", !dbg !45\n  br label %\"for.cond\", !dbg !45\nfor.end:\n  %\".21\" = load i32, i32* %\"sum.addr\", !dbg !46\n  %\".22\" = sext i32 %\".21\" to i64 , !dbg !46\n  %\".23\" = icmp eq i64 %\".22\", 10 , !dbg !46\n  br i1 %\".23\", label %\"assert.pass\", label %\"assert.fail\", !dbg !46\nassert.pass:\n  %\".27\" = trunc i64 0 to i32 , !dbg !47\n  ret i32 %\".27\", !dbg !47\nassert.fail:\n  %\".25\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !46\n  unreachable\n}"
    },
    "test_for_start_nonzero": {
      "hash": "9a11729feb29daa3",
      "ir": "define internal i32 @\"test_for_start_nonzero\"() !dbg !18\n{\nentry:\n  %\"sum.addr\" = alloca i32, !dbg !48\n  %\"i\" = alloca i64, !dbg !51\n  %\".2\" = trunc i64 0 to i32 , !dbg !48\n  store i32 %\".2\", i32* %\"sum.addr\", !dbg !48\n  call void @\"llvm.dbg.declare\"(metadata i32* %\"sum.addr\", metadata !49, metadata !7), !dbg !50\n  store i64 5, i64* %\"i\", !dbg !51\n  br label %\"for.cond\", !dbg !51\nfor.cond:\n  %\".7\" = load i64, i64* %\"i\", !dbg !51\n  %\".8\" = icmp slt i64 %\".7\", 10 , !dbg !51\n  br i1 %\".8\", label %\"for.body\", label %\"for.end\", !dbg !51\nfor.body:\n  %\".10\" = load i32, i32* %\"sum.addr\", !dbg !52\n  %\".11\" = load i64, i64* %\"i\", !dbg !52\n  %\".12\" = sext i32 %\".10\" to i64 , !dbg !52\n  %\".13\" = add i64 %\".12\", %\".11\", !dbg !52\n  %\".14\" = trunc i64 %\".13\" to i32 , !dbg !52\n  store i32 %\".14\", i32* %\"sum.addr\", !dbg !52\n  br label %\"for.incr\", !dbg !52\nfor.incr:\n  %\".17\" = load i64, i64* %\"i\", !dbg !52\n  %\".18\" = add i64 %\".17\", 1, !dbg !52\n  store i64 %\".18\", i64* %\"i\", !dbg !52\n  br label %\"for.cond\", !dbg !52\nfor.end:\n  %\".21\" = load i32, i32* %\"sum.addr\", !dbg !53\n  %\".22\" = sext i32 %\".21\" to i64 , !dbg !53\n  %\".23\" = icmp eq i64 %\".22\", 35 , !dbg !53\n  br i1 %\".23\", label %\"assert.pass\", label %\"assert.fail\", !dbg !53\nassert.pass:\n  %\".27\" = trunc i64 0 to i32 , !dbg !54\n  ret i32 %\".27\", !dbg !54\nassert.fail:\n  %\".25\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !53\n  unreachable\n}"
    },
    "test_for_single_iteration": {
      "hash": "05d87d26051c4d11",
      "ir": "define internal i32 @\"test_for_single_iteration\"() !dbg !19\n{\nentry:\n  %\"count.addr\" = alloca i32, !dbg !55\n  %\"i\" = alloca i64, !dbg !58\n  %\".2\" = trunc i64 0 to i32 , !dbg !55\n  store i32 %\".2\", i32* %\"count.addr\", !dbg !55\n  call void @\"llvm.dbg.declare\"(metadata i32* %\"count.addr\", metadata !56, metadata !7), !dbg !57\n  store i64 0, i64* %\"i\", !dbg !58\n  br label %\"for.cond\", !dbg !58\nfor.cond:\n  %\".7\" = load i64, i64* %\"i\", !dbg !58\n  %\".8\" = icmp slt i64 %\".7\", 1 , !dbg !58\n  br i1 %\".8\", label %\"for.body\", label %\"for.end\", !dbg !58\nfor.body:\n  %\".10\" = load i32, i32* %\"count.addr\", !dbg !59\n  %\".11\" = sext i32 %\".10\" to i64 , !dbg !59\n  %\".12\" = add i64 %\".11\", 1, !dbg !59\n  %\".13\" = trunc i64 %\".12\" to i32 , !dbg !59\n  store i32 %\".13\", i32* %\"count.addr\", !dbg !59\n  br label %\"for.incr\", !dbg !59\nfor.incr:\n  %\".16\" = load i64, i64* %\"i\", !dbg !59\n  %\".17\" = add i64 %\".16\", 1, !dbg !59\n  store i64 %\".17\", i64* %\"i\", !dbg !59\n  br label %\"for.cond\", !dbg !59\nfor.end:\n  %\".20\" = load i32, i32* %\"count.addr\", !dbg !60\n  %\".21\" = sext i32 %\".20\" to i64 , !dbg !60\n  %\".22\" = icmp eq i64 %\".21\", 1 , !dbg !60\n  br i1 %\".22\", label %\"assert.pass\", label %\"assert.fail\", !dbg !60\nassert.pass:\n  %\".26\" = trunc i64 0 to i32 , !dbg !61\n  ret i32 %\".26\", !dbg !61\nassert.fail:\n  %\".24\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !60\n  unreachable\n}"
    },
    "test_for_empty_range": {
      "hash": "7800a0ddfae6fcc2",
      "ir": "define internal i32 @\"test_for_empty_range\"() !dbg !20\n{\nentry:\n  %\"count.addr\" = alloca i32, !dbg !62\n  %\"i\" = alloca i64, !dbg !65\n  %\".2\" = trunc i64 0 to i32 , !dbg !62\n  store i32 %\".2\", i32* %\"count.addr\", !dbg !62\n  call void @\"llvm.dbg.declare\"(metadata i32* %\"count.addr\", metadata !63, metadata !7), !dbg !64\n  store i64 5, i64* %\"i\", !dbg !65\n  br label %\"for.cond\", !dbg !65\nfor.cond:\n  %\".7\" = load i64, i64* %\"i\", !dbg !65\n  %\".8\" = icmp slt i64 %\".7\", 5 , !dbg !65\n  br i1 %\".8\", label %\"for.body\", label %\"for.end\", !dbg !65\nfor.body:\n  %\".10\" = load i32, i32* %\"count.addr\", !dbg !66\n  %\".11\" = sext i32 %\".10\" to i64 , !dbg !66\n  %\".12\" = add i64 %\".11\", 1, !dbg !66\n  %\".13\" = trunc i64 %\".12\" to i32 , !dbg !66\n  store i32 %\".13\", i32* %\"count.addr\", !dbg !66\n  br label %\"for.incr\", !dbg !66\nfor.incr:\n  %\".16\" = load i64, i64* %\"i\", !dbg !66\n  %\".17\" = add i64 %\".16\", 1, !dbg !66\n  store i64 %\".17\", i64* %\"i\", !dbg !66\n  br label %\"for.cond\", !dbg !66\nfor.end:\n  %\".20\" = load i32, i32* %\"count.addr\", !dbg !67\n  %\".21\" = sext i32 %\".20\" to i64 , !dbg !67\n  %\".22\" = icmp eq i64 %\".21\", 0 , !dbg !67\n  br i1 %\".22\", label %\"assert.pass\", label %\"assert.fail\", !dbg !67\nassert.pass:\n  %\".26\" = trunc i64 0 to i32 , !dbg !68\n  ret i32 %\".26\", !dbg !68\nassert.fail:\n  %\".24\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !67\n  unreachable\n}"
    },
    "test_for_break": {
      "hash": "43cd79441398798d",
      "ir": "define internal i32 @\"test_for_break\"() !dbg !21\n{\nentry:\n  %\"sum.addr\" = alloca i32, !dbg !69\n  %\"i\" = alloca i64, !dbg !72\n  %\".2\" = trunc i64 0 to i32 , !dbg !69\n  store i32 %\".2\", i32* %\"sum.addr\", !dbg !69\n  call void @\"llvm.dbg.declare\"(metadata i32* %\"sum.addr\", metadata !70, metadata !7), !dbg !71\n  store i64 0, i64* %\"i\", !dbg !72\n  br label %\"for.cond\", !dbg !72\nfor.cond:\n  %\".7\" = load i64, i64* %\"i\", !dbg !72\n  %\".8\" = icmp slt i64 %\".7\", 10 , !dbg !72\n  br i1 %\".8\", label %\"for.body\", label %\"for.end\", !dbg !72\nfor.body:\n  %\".10\" = load i64, i64* %\"i\", !dbg !73\n  %\".11\" = icmp eq i64 %\".10\", 5 , !dbg !73\n  br i1 %\".11\", label %\"if.then\", label %\"if.end\", !dbg !73\nfor.incr:\n  %\".21\" = load i64, i64* %\"i\", !dbg !75\n  %\".22\" = add i64 %\".21\", 1, !dbg !75\n  store i64 %\".22\", i64* %\"i\", !dbg !75\n  br label %\"for.cond\", !dbg !75\nfor.end:\n  %\".25\" = load i32, i32* %\"sum.addr\", !dbg !76\n  %\".26\" = sext i32 %\".25\" to i64 , !dbg !76\n  %\".27\" = icmp eq i64 %\".26\", 10 , !dbg !76\n  br i1 %\".27\", label %\"assert.pass\", label %\"assert.fail\", !dbg !76\nif.then:\n  br label %\"for.end\", !dbg !74\nif.end:\n  %\".14\" = load i32, i32* %\"sum.addr\", !dbg !75\n  %\".15\" = load i64, i64* %\"i\", !dbg !75\n  %\".16\" = sext i32 %\".14\" to i64 , !dbg !75\n  %\".17\" = add i64 %\".16\", %\".15\", !dbg !75\n  %\".18\" = trunc i64 %\".17\" to i32 , !dbg !75\n  store i32 %\".18\", i32* %\"sum.addr\", !dbg !75\n  br label %\"for.incr\", !dbg !75\nassert.pass:\n  %\".31\" = trunc i64 0 to i32 , !dbg !77\n  ret i32 %\".31\", !dbg !77\nassert.fail:\n  %\".29\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !76\n  unreachable\n}"
    },
    "test_for_continue": {
      "hash": "68147bb7d5c99890",
      "ir": "define internal i32 @\"test_for_continue\"() !dbg !22\n{\nentry:\n  %\"sum.addr\" = alloca i32, !dbg !78\n  %\"i\" = alloca i64, !dbg !81\n  %\".2\" = trunc i64 0 to i32 , !dbg !78\n  store i32 %\".2\", i32* %\"sum.addr\", !dbg !78\n  call void @\"llvm.dbg.declare\"(metadata i32* %\"sum.addr\", metadata !79, metadata !7), !dbg !80\n  store i64 0, i64* %\"i\", !dbg !81\n  br label %\"for.cond\", !dbg !81\nfor.cond:\n  %\".7\" = load i64, i64* %\"i\", !dbg !81\n  %\".8\" = icmp slt i64 %\".7\", 10 , !dbg !81\n  br i1 %\".8\", label %\"for.body\", label %\"for.end\", !dbg !81\nfor.body:\n  %\".10\" = load i64, i64* %\"i\", !dbg !82\n  %\".11\" = srem i64 %\".10\", 2, !dbg !82\n  %\".12\" = icmp ne i64 %\".11\", 0 , !dbg !82\n  br i1 %\".12\", label %\"if.then\", label %\"if.end\", !dbg !82\nfor.incr:\n  %\".22\" = load i64, i64* %\"i\", !dbg !84\n  %\".23\" = add i64 %\".22\", 1, !dbg !84\n  store i64 %\".23\", i64* %\"i\", !dbg !84\n  br label %\"for.cond\", !dbg !84\nfor.end:\n  %\".26\" = load i32, i32* %\"sum.addr\", !dbg !85\n  %\".27\" = sext i32 %\".26\" to i64 , !dbg !85\n  %\".28\" = icmp eq i64 %\".27\", 20 , !dbg !85\n  br i1 %\".28\", label %\"assert.pass\", label %\"assert.fail\", !dbg !85\nif.then:\n  br label %\"for.incr\", !dbg !83\nif.end:\n  %\".15\" = load i32, i32* %\"sum.addr\", !dbg !84\n  %\".16\" = load i64, i64* %\"i\", !dbg !84\n  %\".17\" = sext i32 %\".15\" to i64 , !dbg !84\n  %\".18\" = add i64 %\".17\", %\".16\", !dbg !84\n  %\".19\" = trunc i64 %\".18\" to i32 , !dbg !84\n  store i32 %\".19\", i32* %\"sum.addr\", !dbg !84\n  br label %\"for.incr\", !dbg !84\nassert.pass:\n  %\".32\" = trunc i64 0 to i32 , !dbg !86\n  ret i32 %\".32\", !dbg !86\nassert.fail:\n  %\".30\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !85\n  unreachable\n}"
    },
    "test_for_nested": {
      "hash": "12c7999f20db4dee",
      "ir": "define internal i32 @\"test_for_nested\"() !dbg !23\n{\nentry:\n  %\"count.addr\" = alloca i32, !dbg !87\n  %\"i\" = alloca i64, !dbg !90\n  %\"j\" = alloca i64, !dbg !91\n  %\".2\" = trunc i64 0 to i32 , !dbg !87\n  store i32 %\".2\", i32* %\"count.addr\", !dbg !87\n  call void @\"llvm.dbg.declare\"(metadata i32* %\"count.addr\", metadata !88, metadata !7), !dbg !89\n  store i64 0, i64* %\"i\", !dbg !90\n  br label %\"for.cond\", !dbg !90\nfor.cond:\n  %\".7\" = load i64, i64* %\"i\", !dbg !90\n  %\".8\" = icmp slt i64 %\".7\", 3 , !dbg !90\n  br i1 %\".8\", label %\"for.body\", label %\"for.end\", !dbg !90\nfor.body:\n  store i64 0, i64* %\"j\", !dbg !91\n  br label %\"for.cond.1\", !dbg !91\nfor.incr:\n  %\".26\" = load i64, i64* %\"i\", !dbg !92\n  %\".27\" = add i64 %\".26\", 1, !dbg !92\n  store i64 %\".27\", i64* %\"i\", !dbg !92\n  br label %\"for.cond\", !dbg !92\nfor.end:\n  %\".30\" = load i32, i32* %\"count.addr\", !dbg !93\n  %\".31\" = sext i32 %\".30\" to i64 , !dbg !93\n  %\".32\" = icmp eq i64 %\".31\", 12 , !dbg !93\n  br i1 %\".32\", label %\"assert.pass\", label %\"assert.fail\", !dbg !93\nfor.cond.1:\n  %\".12\" = load i64, i64* %\"j\", !dbg !91\n  %\".13\" = icmp slt i64 %\".12\", 4 , !dbg !91\n  br i1 %\".13\", label %\"for.body.1\", label %\"for.end.1\", !dbg !91\nfor.body.1:\n  %\".15\" = load i32, i32* %\"count.addr\", !dbg !92\n  %\".16\" = sext i32 %\".15\" to i64 , !dbg !92\n  %\".17\" = add i64 %\".16\", 1, !dbg !92\n  %\".18\" = trunc i64 %\".17\" to i32 , !dbg !92\n  store i32 %\".18\", i32* %\"count.addr\", !dbg !92\n  br label %\"for.incr.1\", !dbg !92\nfor.incr.1:\n  %\".21\" = load i64, i64* %\"j\", !dbg !92\n  %\".22\" = add i64 %\".21\", 1, !dbg !92\n  store i64 %\".22\", i64* %\"j\", !dbg !92\n  br label %\"for.cond.1\", !dbg !92\nfor.end.1:\n  br label %\"for.incr\", !dbg !92\nassert.pass:\n  %\".36\" = trunc i64 0 to i32 , !dbg !94\n  ret i32 %\".36\", !dbg !94\nassert.fail:\n  %\".34\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !93\n  unreachable\n}"
    },
    "test_for_nested_with_break": {
      "hash": "dca1eda5b58eeb33",
      "ir": "define internal i32 @\"test_for_nested_with_break\"() !dbg !24\n{\nentry:\n  %\"outer_count.addr\" = alloca i32, !dbg !95\n  %\"inner_total.addr\" = alloca i32, !dbg !98\n  %\"i\" = alloca i64, !dbg !101\n  %\"j\" = alloca i64, !dbg !103\n  %\".2\" = trunc i64 0 to i32 , !dbg !95\n  store i32 %\".2\", i32* %\"outer_count.addr\", !dbg !95\n  call void @\"llvm.dbg.declare\"(metadata i32* %\"outer_count.addr\", metadata !96, metadata !7), !dbg !97\n  %\".5\" = trunc i64 0 to i32 , !dbg !98\n  store i32 %\".5\", i32* %\"inner_total.addr\", !dbg !98\n  call void @\"llvm.dbg.declare\"(metadata i32* %\"inner_total.addr\", metadata !99, metadata !7), !dbg !100\n  store i64 0, i64* %\"i\", !dbg !101\n  br label %\"for.cond\", !dbg !101\nfor.cond:\n  %\".10\" = load i64, i64* %\"i\", !dbg !101\n  %\".11\" = icmp slt i64 %\".10\", 3 , !dbg !101\n  br i1 %\".11\", label %\"for.body\", label %\"for.end\", !dbg !101\nfor.body:\n  %\".13\" = load i32, i32* %\"outer_count.addr\", !dbg !102\n  %\".14\" = sext i32 %\".13\" to i64 , !dbg !102\n  %\".15\" = add i64 %\".14\", 1, !dbg !102\n  %\".16\" = trunc i64 %\".15\" to i32 , !dbg !102\n  store i32 %\".16\", i32* %\"outer_count.addr\", !dbg !102\n  store i64 0, i64* %\"j\", !dbg !103\n  br label %\"for.cond.1\", !dbg !103\nfor.incr:\n  %\".38\" = load i64, i64* %\"i\", !dbg !106\n  %\".39\" = add i64 %\".38\", 1, !dbg !106\n  store i64 %\".39\", i64* %\"i\", !dbg !106\n  br label %\"for.cond\", !dbg !106\nfor.end:\n  %\".42\" = load i32, i32* %\"outer_count.addr\", !dbg !107\n  %\".43\" = sext i32 %\".42\" to i64 , !dbg !107\n  %\".44\" = icmp eq i64 %\".43\", 3 , !dbg !107\n  br i1 %\".44\", label %\"assert.pass\", label %\"assert.fail\", !dbg !107\nfor.cond.1:\n  %\".20\" = load i64, i64* %\"j\", !dbg !103\n  %\".21\" = icmp slt i64 %\".20\", 10 , !dbg !103\n  br i1 %\".21\", label %\"for.body.1\", label %\"for.end.1\", !dbg !103\nfor.body.1:\n  %\".23\" = load i64, i64* %\"j\", !dbg !104\n  %\".24\" = icmp eq i64 %\".23\", 2 , !dbg !104\n  br i1 %\".24\", label %\"if.then\", label %\"if.end\", !dbg !104\nfor.incr.1:\n  %\".33\" = load i64, i64* %\"j\", !dbg !106\n  %\".34\" = add i64 %\".33\", 1, !dbg !106\n  store i64 %\".34\", i64* %\"j\", !dbg !106\n  br label %\"for.cond.1\", !dbg !106\nfor.end.1:\n  br label %\"for.incr\", !dbg !106\nif.then:\n  br label %\"for.end.1\", !dbg !105\nif.end:\n  %\".27\" = load i32, i32* %\"inner_total.addr\", !dbg !106\n  %\".28\" = sext i32 %\".27\" to i64 , !dbg !106\n  %\".29\" = add i64 %\".28\", 1, !dbg !106\n  %\".30\" = trunc i64 %\".29\" to i32 , !dbg !106\n  store i32 %\".30\", i32* %\"inner_total.addr\", !dbg !106\n  br label %\"for.incr.1\", !dbg !106\nassert.pass:\n  %\".48\" = load i32, i32* %\"inner_total.addr\", !dbg !108\n  %\".49\" = sext i32 %\".48\" to i64 , !dbg !108\n  %\".50\" = icmp eq i64 %\".49\", 6 , !dbg !108\n  br i1 %\".50\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !108\nassert.fail:\n  %\".46\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !107\n  unreachable\nassert.pass.1:\n  %\".54\" = trunc i64 0 to i32 , !dbg !109\n  ret i32 %\".54\", !dbg !109\nassert.fail.1:\n  %\".52\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !108\n  unreachable\n}"
    },
