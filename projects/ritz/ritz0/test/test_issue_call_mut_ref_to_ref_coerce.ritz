# Regression: passing a `@&T` (TYPE_MUT_REF) argument to a function whose
# parameter is `@T` (TYPE_REF) used to emit `call i64 @callee(ptr %arg, ...)`
# — i.e. the caller dropped a `ptr` register into an `i64` parameter slot
# without a `ptrtoint` coercion.  Repro pulled from tome.ritz:3326-3327
# (`pub fn pubsub_unsubscribe(ps: @&PubSub, …)` calling `pubsub_find_channel(ps, …)`
# whose first parameter is `ps: @PubSub`).
#
# AGAST #187.  Earlier attempt regressed `test_issue_strview_as_bytes`, so
# the fix is narrowly scoped to "param is TYPE_REF AND arg is an EXPR_IDENT
# whose local has var_type == TYPE_MUT_REF" — no other ptr↔i64 coercion
# changes.

struct Counter
  value: i64

# Callee with TYPE_REF (`@T`) parameter — lowered as i64 in the LLVM signature.
fn read_value(c: @Counter) -> i64
    return c.value

# Caller with TYPE_MUT_REF (`@&T`) parameter — lowered as ptr.  Forwards
# its argument to the TYPE_REF callee; this is the call site that needed
# a `ptrtoint ptr %c to i64` coercion before #187.
fn forward(c: @&Counter) -> i64
    return read_value(c)

[[test]]
fn test_call_mut_ref_to_ref_coerce() -> i32
    var c: Counter
    c.value = 42
    let v: i64 = forward(@c)
    if v == 42
        0
    else
        1
