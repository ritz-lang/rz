# Test native String literals (Issue #89 Phase 3)
#
# Features tested:
# - "hello" produces String type
# - String can be assigned to var s: String
# - String methods work on literals
# - Implicit coercion to *u8 still works

import ritzlib.string

[[test]]
fn test_string_literal_type() -> i64
    # "hello" should produce String type
    var s: String = "hello"
    assert string_len(@s) == 5
    0

[[test]]
fn test_string_literal_methods() -> i64
    var s: String = "world"
    # Can use string methods
    string_push(@s, '!')
    assert string_len(@s) == 6
    0

[[test]]
fn test_string_to_ptr_coercion() -> i64
    var s: String = "test"
    # Should be able to pass String to functions expecting *u8
    # via implicit coercion
    let ptr: *u8 = string_as_ptr(@s)
    assert *ptr == 't'
    0

# Helper for testing coercion
fn takes_cstr(s: *u8) -> i64
    var len: i64 = 0
    while *(s + len) != 0
        len = len + 1
    len

[[test]]
fn test_coercion_in_call() -> i64
    var s: String = "hello"
    # String should be coerced to *u8 automatically
    let len: i64 = takes_cstr(s)
    assert len == 5
    0

[[test]]
fn test_cstring_still_works() -> i64
    # c"..." should still produce *u8
    let ptr: *u8 = c"hello"
    assert *ptr == 'h'
    assert *(ptr + 4) == 'o'
    0
