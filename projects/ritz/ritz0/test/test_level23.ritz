# Test level 23: Generics (Monomorphization)
#
# Tests generic structs and functions with monomorphization
# Features tested:
# - Generic struct definitions with type parameters
# - Generic function definitions with type parameters
# - Explicit type instantiation Pair<i32>
# - Multiple type parameters
# - Type parameters in function parameters and return types

import ritzlib.sys
import ritzlib.io

# ============================================================================
# Basic Generic Struct Tests
# ============================================================================

# A simple generic pair struct
struct Pair<T>
    first: T
    second: T

[[test]]
fn test_generic_struct_i32() -> i32
    # Create a Pair of i32
    var p: Pair<i32> = Pair<i32> { first: 10, second: 20 }
    assert p.first == 10, c"first should be 10"
    assert p.second == 20, c"second should be 20"
    return 0

[[test]]
fn test_generic_struct_i64() -> i32
    # Create a Pair of i64
    var p: Pair<i64> = Pair<i64> { first: 100, second: 200 }
    assert p.first == 100, c"first should be 100"
    assert p.second == 200, c"second should be 200"
    return 0

[[test]]
fn test_generic_struct_mutation() -> i32
    # Mutate a generic struct
    var p: Pair<i32> = Pair<i32> { first: 1, second: 2 }
    p.first = 100
    p.second = 200
    assert p.first == 100, c"first should be 100 after mutation"
    assert p.second == 200, c"second should be 200 after mutation"
    return 0

# ============================================================================
# Generic Function Tests
# ============================================================================

# A generic swap function
fn swap<T>(p: *Pair<T>) -> i32
    let tmp: T = p.first
    p.first = p.second
    p.second = tmp
    return 0

[[test]]
fn test_generic_function_swap() -> i32
    var p: Pair<i32> = Pair<i32> { first: 1, second: 2 }
    swap<i32>(@p)
    assert p.first == 2, c"after swap, first should be 2"
    assert p.second == 1, c"after swap, second should be 1"
    return 0

# A generic identity function
fn identity<T>(x: T) -> T
    return x

[[test]]
fn test_generic_function_identity() -> i32
    let x: i32 = identity<i32>(42)
    assert x == 42, c"identity should return 42"
    return 0

# ============================================================================
# Multiple Type Parameters
# ============================================================================

# A struct with two different type parameters
struct KeyValue<K, V>
    key: K
    value: V

[[test]]
fn test_multiple_type_params() -> i32
    var kv: KeyValue<i32, i64> = KeyValue<i32, i64> { key: 1, value: 1000 }
    assert kv.key == 1, c"key should be 1"
    assert kv.value == 1000, c"value should be 1000"
    return 0

# ============================================================================
# Generic Box (single value container)
# ============================================================================

struct Box<T>
    value: T

fn box_get<T>(b: *Box<T>) -> T
    return b.value

fn box_set<T>(b: *Box<T>, val: T) -> i32
    b.value = val
    return 0

[[test]]
fn test_box_operations() -> i32
    var b: Box<i32> = Box<i32> { value: 5 }
    assert box_get<i32>(@b) == 5, c"box should contain 5"

    box_set<i32>(@b, 10)
    assert box_get<i32>(@b) == 10, c"box should now contain 10"

    return 0

# ============================================================================
# Multiple Instantiations of Same Generic
# ============================================================================

[[test]]
fn test_multiple_instantiations() -> i32
    # Same generic struct with different types
    var pi32: Pair<i32> = Pair<i32> { first: 1, second: 2 }
    var pi64: Pair<i64> = Pair<i64> { first: 100, second: 200 }

    # Swap them independently
    swap<i32>(@pi32)
    swap<i64>(@pi64)

    assert pi32.first == 2, c"i32 pair first should be 2"
    assert pi32.second == 1, c"i32 pair second should be 1"
    assert pi64.first == 200, c"i64 pair first should be 200"
    assert pi64.second == 100, c"i64 pair second should be 100"

    return 0

# ============================================================================
# Nested Generic Usage
# ============================================================================

[[test]]
fn test_generic_with_pointer_type() -> i32
    # Using a pointer type as the generic argument
    let s: *u8 = c"hello"
    var b: Box<*u8> = Box<*u8> { value: s }
    let got: *u8 = box_get<*u8>(@b)
    # Just verify we can access it (can't easily compare strings)
    assert got != null, c"pointer should not be null"
    return 0

# ============================================================================
# Arithmetic with Generic Values
# ============================================================================

fn add_pairs<T>(a: *Pair<T>, b: *Pair<T>) -> Pair<T>
    return Pair<T> { first: a.first + b.first, second: a.second + b.second }

[[test]]
fn test_arithmetic_with_generics() -> i32
    var p1: Pair<i32> = Pair<i32> { first: 1, second: 2 }
    var p2: Pair<i32> = Pair<i32> { first: 10, second: 20 }

    let result: Pair<i32> = add_pairs<i32>(@p1, @p2)
    assert result.first == 11, c"result first should be 11"
    assert result.second == 22, c"result second should be 22"

    return 0

# ============================================================================
# Main entry point
# ============================================================================

fn main() -> i32
    prints(c"Test level 23: Generics (Monomorphization)\n")
    prints(c"OK\n")
    return 0
