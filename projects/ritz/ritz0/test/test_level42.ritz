# Test level 42: Conditional compilation with [[cfg()]]
#
# Tests the [[cfg()]] attribute for platform-specific code.
# The compiler filters items based on cfg conditions at compile time.

import ritzlib.sys

# ============================================================================
# Basic cfg: target_os conditions
# ============================================================================

# This function only exists on Linux
[[cfg(target_os = "linux")]]
pub fn get_platform_id() -> i32
    return 1

# This would only exist on Harland (filtered out on Linux)
[[cfg(target_os = "harland")]]
pub fn get_platform_id() -> i32
    return 2

# ============================================================================
# Test: correct platform function is selected
# ============================================================================

[[test]]
fn test_cfg_target_os() -> i32
    let id: i32 = get_platform_id()
    # On Linux, should get 1
    assert id == 1, "Linux platform id should be 1"
    0

# ============================================================================
# cfg with not() combinator
# ============================================================================

[[cfg(not(target_os = "harland"))]]
pub fn not_harland() -> i32
    return 42

[[test]]
fn test_cfg_not() -> i32
    # not(harland) = true on linux, so function exists
    assert not_harland() == 42, "not(harland) should be true on linux"
    0

# ============================================================================
# cfg on structs
# ============================================================================

[[cfg(target_os = "linux")]]
pub struct PlatformInfo
    fd_type: i32
    flags: i32

[[test]]
fn test_cfg_struct() -> i32
    var info: PlatformInfo = PlatformInfo { fd_type: 0, flags: 0 }
    assert info.fd_type == 0, "fd_type should be 0"
    0

# Entry point
fn main() -> i32
    0
