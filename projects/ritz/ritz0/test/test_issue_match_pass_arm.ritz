# Regression: enum match phi should handle pass/undefined arms.
import ritzlib.result

fn maybe(flag: bool) -> Result<i32, i32>
    if flag
        Ok(1)
    else
        Err(0)

fn use_match(flag: bool) -> i32
    let r = maybe(flag)
    match r
        Ok(v) => v
        Err(_) => pass

[[test]]
fn test_match_pass_arm() -> i32
    if use_match(true) == 1 and use_match(false) == 0
        0
    else
        1
