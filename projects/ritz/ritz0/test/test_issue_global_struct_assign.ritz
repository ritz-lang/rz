# Regression: `var g: Struct` global followed by `g = make_struct()` used to
# emit `store i64 %.N, ptr @g` where %.N was a `%Struct` SSA value.  ritz1
# fell through `emit_llvm_type(TYPE_STRUCT)` (which defaults to "i64") in the
# global-assign branch of emit_assign instead of using the struct type name.
#
# Repro shape pulled from tome's `var g_blk_store: Store` followed by
# `g_blk_store = store_new()` in blocking_server.ritz.

struct GBox
  a: i64
  b: i64
  c: i64

var g_box: GBox

fn box_make(x: i64) -> GBox
    GBox { a: x, b: x + 1, c: x + 2 }

[[test]]
fn test_global_struct_assign() -> i32
    g_box = box_make(10)
    assert g_box.a == 10
    assert g_box.b == 11
    assert g_box.c == 12
    g_box = box_make(100)
    assert g_box.a == 100
    assert g_box.b == 101
    assert g_box.c == 102
    0
