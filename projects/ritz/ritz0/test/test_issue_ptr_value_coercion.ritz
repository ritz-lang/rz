# Regression: pointer value should auto-deref when callee expects a value type.

struct PointI
    x: i32
    y: i32

fn sum_point(p: PointI) -> i32
    p.x + p.y

[[test]]
fn test_ptr_to_value_arg_coercion() -> i32
    let p = PointI { x: 2, y: 3 }
    let s = sum_point(@p)
    assert s == 5
    0
