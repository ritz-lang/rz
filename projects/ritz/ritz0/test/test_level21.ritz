# Test level 21: Buffer utilities for parsing
#
# Tests ritzlib/buf.ritz functionality

import ritzlib.sys
import ritzlib.io
import ritzlib.str
import ritzlib.buf

# ============================================================================
# Test: Buffer initialization
# ============================================================================

[[test]]
fn test_buf_init() -> i32
    var buf: Buffer
    let data: *u8 = c"hello world"
    buf_init(@buf, data, 11)

    assert buf.pos == 0, "initial pos should be 0"
    assert buf.len == 11, "len should be 11"
    assert buf_eof(@buf) == 0, "should not be at EOF"
    return 0

[[test]]
fn test_buf_from_str() -> i32
    var buf: Buffer
    buf_from_str(@buf, c"test")

    assert buf.len == 4, "len should be 4"
    assert buf_remaining(@buf) == 4, "remaining should be 4"
    return 0

# ============================================================================
# Test: Peek operations
# ============================================================================

[[test]]
fn test_buf_peek() -> i32
    var buf: Buffer
    buf_from_str(@buf, c"abc")

    assert buf_peek(@buf) == 97, "peek should return 'a'"
    assert buf_peek_at(@buf, 0) == 97, "peek_at(0) should return 'a'"
    assert buf_peek_at(@buf, 1) == 98, "peek_at(1) should return 'b'"
    assert buf_peek_at(@buf, 2) == 99, "peek_at(2) should return 'c'"
    assert buf_peek_at(@buf, 3) == 0, "peek_at(3) should return 0 (past end)"
    return 0

# ============================================================================
# Test: Advance operations
# ============================================================================

[[test]]
fn test_buf_advance() -> i32
    var buf: Buffer
    buf_from_str(@buf, c"xyz")

    assert buf_advance(@buf) == 120, "first advance should return 'x'"
    assert buf_advance(@buf) == 121, "second advance should return 'y'"
    assert buf_advance(@buf) == 122, "third advance should return 'z'"
    assert buf_advance(@buf) == 0, "fourth advance should return 0 (EOF)"
    assert buf_eof(@buf) != 0, "should be at EOF"
    return 0

[[test]]
fn test_buf_skip() -> i32
    var buf: Buffer
    buf_from_str(@buf, c"hello world")

    buf_skip(@buf, 6)
    assert buf_peek(@buf) == 119, "after skip 6, peek should be 'w'"
    return 0

# ============================================================================
# Test: Pattern matching
# ============================================================================

[[test]]
fn test_buf_match_char() -> i32
    var buf: Buffer
    buf_from_str(@buf, c"abc")

    assert buf_match_char(@buf, 97) != 0, "match 'a' should succeed"
    assert buf_peek(@buf) == 98, "after match, should be at 'b'"
    assert buf_match_char(@buf, 99) == 0, "match 'c' should fail (at 'b')"
    assert buf_peek(@buf) == 98, "position should not change on failed match"
    return 0

[[test]]
fn test_buf_match_str() -> i32
    var buf: Buffer
    buf_from_str(@buf, c"hello world")

    assert buf_match_str(@buf, c"hello") != 0, "match 'hello' should succeed"
    assert buf_peek(@buf) == 32, "after match, should be at space"
    buf_advance(@buf)
    assert buf_match_str(@buf, c"world") != 0, "match 'world' should succeed"
    return 0

# ============================================================================
# Test: Skip utilities
# ============================================================================

[[test]]
fn test_buf_skip_whitespace() -> i32
    var buf: Buffer
    buf_from_str(@buf, c"   hello")

    let skipped: i64 = buf_skip_whitespace(@buf)
    assert skipped == 3, "should skip 3 spaces"
    assert buf_peek(@buf) == 104, "should be at 'h'"
    return 0

[[test]]
fn test_buf_skip_until() -> i32
    var buf: Buffer
    buf_from_str(@buf, c"abc:def")

    let skipped: i64 = buf_skip_until(@buf, 58)  # ':'
    assert skipped == 3, "should skip 3 chars before ':'"
    assert buf_peek(@buf) == 58, "should be at ':'"
    return 0

# ============================================================================
# Test: Read utilities
# ============================================================================

[[test]]
fn test_buf_read_until() -> i32
    var buf: Buffer
    buf_from_str(@buf, c"key=value")

    var out: [32]u8
    let len: i64 = buf_read_until(@buf, 61, @out[0], 32)  # '='
    assert len == 3, "should read 3 chars"
    assert streq(@out[0], c"key") != 0, "should read 'key'"
    return 0

[[test]]
fn test_buf_read_while_digit() -> i32
    var buf: Buffer
    buf_from_str(@buf, c"12345abc")

    var out: [32]u8
    let len: i64 = buf_read_while_digit(@buf, @out[0], 32)
    assert len == 5, "should read 5 digits"
    assert streq(@out[0], c"12345") != 0, "should read '12345'"
    assert buf_peek(@buf) == 97, "should be at 'a'"
    return 0

[[test]]
fn test_buf_read_while_alnum() -> i32
    var buf: Buffer
    buf_from_str(@buf, c"abc_123 end")

    var out: [32]u8
    let len: i64 = buf_read_while_alnum(@buf, @out[0], 32)
    assert len == 7, "should read 7 chars"
    assert streq(@out[0], c"abc_123") != 0, "should read 'abc_123'"
    return 0

# ============================================================================
# Test: Save/restore (backtracking)
# ============================================================================

[[test]]
fn test_buf_save_restore() -> i32
    var buf: Buffer
    buf_from_str(@buf, c"abcdef")

    buf_advance(@buf)
    buf_advance(@buf)
    let saved: i64 = buf_save(@buf)
    assert buf_peek(@buf) == 99, "should be at 'c'"

    buf_advance(@buf)
    buf_advance(@buf)
    assert buf_peek(@buf) == 101, "should be at 'e'"

    buf_restore(@buf, saved)
    assert buf_peek(@buf) == 99, "after restore, should be at 'c'"
    return 0

# ============================================================================
# Test: Location tracking
# ============================================================================

[[test]]
fn test_buf_get_loc() -> i32
    var buf: Buffer
    buf_from_str(@buf, c"line1\nline2\nline3")

    # Move to start of line 2
    buf_skip_until(@buf, 10)  # Skip to newline
    buf_advance(@buf)         # Skip the newline

    var loc: BufLoc
    buf_get_loc(@buf, @loc)
    assert loc.line == 2, "should be on line 2"
    assert loc.col == 1, "should be at column 1"
    return 0

# ============================================================================
# Main entry point
# ============================================================================

fn main() -> i32
    prints(c"Test level 21: Buffer utilities\n")
    prints(c"OK\n")
    return 0
