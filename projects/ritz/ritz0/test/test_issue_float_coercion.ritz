# Regression: argument/field coercion across float widths should work.

struct Vec2
    x: f32
    y: f32

impl Vec2
    fn new(x: f32, y: f32) -> Vec2
        Vec2 { x: x, y: y }

fn mag2(v: Vec2) -> f32
    v.x * v.x + v.y * v.y

fn id_f32(v: f32) -> f32
    v

[[test]]
fn test_float_literal_to_f32_param_and_field() -> i32
    # Float literals parse as f64; emitter must coerce to f32 for params/fields.
    let v = Vec2.new(1.5, 2.0)
    let m = mag2(v)
    let mi = m as i32
    assert mi == 6
    0

[[test]]
fn test_int_to_f32_param() -> i32
    # Int literal should coerce to f32 parameter.
    let v = id_f32(7)
    let vi = v as i32
    assert vi == 7
    0

[[test]]
fn test_float_method_on_expression_receiver() -> i32
    let x = id_f32(1)
    let y = (x + (0.25 as f32)).ceil()
    let yi = y as i32
    assert yi == 2
    0
