# Regression: for-range wrappers like `0..n as usize` and `0..n - 1` should lower as ranges.

fn count_casted(n: i64) -> i64
    var total: i64 = 0
    for i in 0..n as i64
        total = total + i
    total

fn count_minus(n: i64) -> i64
    var total: i64 = 0
    for i in 0..n - 1
        total = total + 1
    total

[[test]]
fn test_for_range_wrapped_forms() -> i32
    let a = count_casted(4)   # 0+1+2+3 = 6
    let b = count_minus(5)    # 0..(5-1) => 4 iterations
    if a == 6 and b == 4
        0
    else
        1
