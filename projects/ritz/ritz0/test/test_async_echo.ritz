# test_async_echo.ritz - Test async task framework with echo pattern
#
# This test verifies:
#   - Task state machine handling
#   - Handler functions that return state codes
#   - Basic echo protocol (copy recv data to send)
#   - Task completion tracking

import ritzlib.sys
import ritzlib.io
import ritzlib.uring
import ritzlib.async_tasks


# ============================================================================
# Mock echo handler - simulates an echo connection
# ============================================================================

# Handler state codes
const TEST_STATE_RECV: i32 = 0
const TEST_STATE_SEND: i32 = 1
const TEST_STATE_DONE: i32 = 2


# A simplified echo handler for testing
# This doesn't actually do I/O - it just demonstrates the state machine pattern
fn test_echo_handler(task: *Task) -> i32
    if task.handler_state == TEST_STATE_RECV
        # Simulate receiving some data
        task.read_len = 5
        for i in 0..5
            task.read_buf[i] = 65 + i as u8  # "ABCDE"

        # Move to send state
        task.handler_state = TEST_STATE_SEND
        task.write_len = 5
        return -1  # Pending (pretend we submitted I/O)

    if task.handler_state == TEST_STATE_SEND
        # Simulate sending the echo
        task.write_pos = task.write_len
        task.handler_state = TEST_STATE_DONE
        return -1  # Pending (pretend we submitted I/O)

    if task.handler_state == TEST_STATE_DONE
        # Task is complete
        return 0


# ============================================================================
# Test 1: Handler state machine
# ============================================================================

fn test_handler_state_machine() -> i32
    var ring: IoUring
    uring_init(&ring, 64)

    var pool: TaskPool
    task_pool_init(&pool, &ring)

    # Spawn a task with our echo handler
    spawn_task(&pool, -1, test_echo_handler)

    var task = task_pool_find(&pool, 1)
    if task == null
        prints("FAIL: Could not find spawned task\n")
        uring_destroy(&ring)
        return 1

    # Initial state should be RECV
    if task.handler_state != TEST_STATE_RECV
        prints("FAIL: Initial state should be RECV\n")
        uring_destroy(&ring)
        return 1

    # First call to handler - should move to SEND state
    let result1 = test_echo_handler(task)
    if result1 != -1
        prints("FAIL: Handler should return -1 (pending) on first call\n")
        uring_destroy(&ring)
        return 1

    if task.handler_state != TEST_STATE_SEND
        prints("FAIL: Handler state should be SEND after first call\n")
        uring_destroy(&ring)
        return 1

    # Second call to handler - should move to DONE state
    let result2 = test_echo_handler(task)
    if result2 != -1
        prints("FAIL: Handler should return -1 (pending) on second call\n")
        uring_destroy(&ring)
        return 1

    if task.handler_state != TEST_STATE_DONE
        prints("FAIL: Handler state should be DONE after second call\n")
        uring_destroy(&ring)
        return 1

    # Third call to handler - task should complete
    let result3 = test_echo_handler(task)
    if result3 != 0
        prints("FAIL: Handler should return 0 (done) on third call\n")
        uring_destroy(&ring)
        return 1

    uring_destroy(&ring)
    prints("OK: handler_state_machine\n")
    return 0


# ============================================================================
# Test 2: Task buffer handling
# ============================================================================

fn test_task_buffers() -> i32
    var ring: IoUring
    uring_init(&ring, 64)

    var pool: TaskPool
    task_pool_init(&pool, &ring)

    spawn_task(&pool, -1, test_echo_handler)

    var task = task_pool_find(&pool, 1)

    # Call handler to populate read buffer
    test_echo_handler(task)

    # Verify buffer contents (should be "ABCDE" = 65-69)
    if task.read_len != 5
        prints("FAIL: read_len should be 5\n")
        uring_destroy(&ring)
        return 1

    for i in 0..5
        let expected: u8 = (65 + i) as u8
        if task.read_buf[i] != expected
            prints("FAIL: read_buf[%d] should be %d\n", i, expected)
            uring_destroy(&ring)
            return 1

    if task.write_len != 5
        prints("FAIL: write_len should be 5\n")
        uring_destroy(&ring)
        return 1

    uring_destroy(&ring)
    prints("OK: task_buffers\n")
    return 0


# ============================================================================
# Test 3: Multiple concurrent tasks
# ============================================================================

fn test_multiple_tasks() -> i32
    var ring: IoUring
    uring_init(&ring, 64)

    var pool: TaskPool
    task_pool_init(&pool, &ring)

    # Spawn 5 tasks
    for i in 0..5
        let ret = spawn_task(&pool, -(i + 1), test_echo_handler)
        if ret < 0
            prints("FAIL: spawn_task %d failed\n", i)
            uring_destroy(&ring)
            return 1

    if pool.active_count != 5
        prints("FAIL: active_count should be 5, got %d\n", pool.active_count)
        uring_destroy(&ring)
        return 1

    # Verify all tasks exist and are in correct state
    for i in 0..5
        let task = task_pool_find(&pool, (i + 1) as i64)
        if task == null
            prints("FAIL: task %d not found\n", i)
            uring_destroy(&ring)
            return 1

        if task.fd != -(i + 1)
            prints("FAIL: task %d fd should be %d\n", i, -(i + 1))
            uring_destroy(&ring)
            return 1

    # Complete all tasks
    for i in 0..5
        let task = task_pool_find(&pool, (i + 1) as i64)
        task_complete(&pool, task)

    if pool.active_count != 0
        prints("FAIL: active_count should be 0 after completing all tasks\n")
        uring_destroy(&ring)
        return 1

    uring_destroy(&ring)
    prints("OK: multiple_tasks\n")
    return 0


# ============================================================================
# Test 4: Task request counter
# ============================================================================

fn test_request_counter() -> i32
    var ring: IoUring
    uring_init(&ring, 64)

    var pool: TaskPool
    task_pool_init(&pool, &ring)

    spawn_task(&pool, -1, test_echo_handler)

    var task = task_pool_find(&pool, 1)

    # Initial request count should be 0
    if task.request_count != 0
        prints("FAIL: Initial request_count should be 0\n")
        uring_destroy(&ring)
        return 1

    # Increment it a few times
    task.request_count = 1
    if task.request_count != 1
        prints("FAIL: request_count should be 1\n")
        uring_destroy(&ring)
        return 1

    task.request_count = 10
    if task.request_count != 10
        prints("FAIL: request_count should be 10\n")
        uring_destroy(&ring)
        return 1

    uring_destroy(&ring)
    prints("OK: request_counter\n")
    return 0


# ============================================================================
# Main - run all tests
# ============================================================================

fn main() -> i32
    prints("Running async echo framework tests...\n")
    prints("====================================\n")

    var failures: i32 = 0

    failures += test_handler_state_machine()
    failures += test_task_buffers()
    failures += test_multiple_tasks()
    failures += test_request_counter()

    prints("====================================\n")
    if failures == 0
        prints("All async tests passed!\n")
        return 0
    else
        prints("Some tests failed!\n")
        return 1
