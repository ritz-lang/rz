# Test SHA-NI hardware crypto intrinsics
#
# SHA-NI (SHA Extensions) provides hardware acceleration for SHA-256.
#
# Required for cryptosec TLS 1.3 library (ritz#119).
#
# NOTE: This test requires CPU support for SHA-NI (Intel Goldmont, Ice Lake+, AMD Zen+).
# On CPUs without SHA-NI, these tests will be skipped.
#
# The tests verify the intrinsics generate correct LLVM IR and can be compiled,
# but execution requires hardware support.

# ============================================================================
# SHA-NI: SHA Extensions for SHA-256
# ============================================================================

[[test]]
fn test_sha256rnds2_basic() -> i32
    # Test two SHA-256 rounds
    # sha256rnds2(cdgh: v4i32, abef: v4i32, wk: v4i32) -> v4i32
    var cdgh: [4]i32
    var abef: [4]i32
    var wk: [4]i32

    # Initialize SHA-256 state (H0-H7 initial values split)
    cdgh[0] = 0x510e527f as i32  # e
    cdgh[1] = 0x9b05688c as i32  # f
    cdgh[2] = 0x1f83d9ab as i32  # g
    cdgh[3] = 0x5be0cd19 as i32  # h

    abef[0] = 0x6a09e667 as i32  # a
    abef[1] = 0xbb67ae85 as i32  # b
    abef[2] = 0x3c6ef372 as i32  # c
    abef[3] = 0xa54ff53a as i32  # d

    # Message schedule word + round constant
    wk[0] = 0x428a2f98 as i32
    wk[1] = 0x71374491 as i32
    wk[2] = 0x00000000 as i32  # Unused
    wk[3] = 0x00000000 as i32  # Unused

    let c: v4i32 = simd_loadu(@cdgh[0])
    let a: v4i32 = simd_loadu(@abef[0])
    let w: v4i32 = simd_loadu(@wk[0])

    # Perform two SHA-256 rounds
    let result: v4i32 = sha256rnds2(c, a, w)

    var out: [4]i32
    simd_storeu(@out[0], result)

    # Verify transformation occurred
    if out[0] == cdgh[0] and out[1] == cdgh[1]
        return 1

    0

[[test]]
fn test_sha256msg1_basic() -> i32
    # Test SHA-256 message schedule (part 1)
    # sha256msg1(w0: v4i32, w1: v4i32) -> v4i32
    var w0: [4]i32
    var w1: [4]i32

    w0[0] = 0x61626364 as i32  # "abcd"
    w0[1] = 0x65666768 as i32  # "efgh"
    w0[2] = 0x696a6b6c as i32  # "ijkl"
    w0[3] = 0x6d6e6f70 as i32  # "mnop"

    w1[0] = 0x71727374 as i32  # "qrst"
    w1[1] = 0x75767778 as i32  # "uvwx"
    w1[2] = 0x797a3031 as i32  # "yz01"
    w1[3] = 0x32333435 as i32  # "2345"

    let v0: v4i32 = simd_loadu(@w0[0])
    let v1: v4i32 = simd_loadu(@w1[0])

    let result: v4i32 = sha256msg1(v0, v1)

    var out: [4]i32
    simd_storeu(@out[0], result)

    # Verify transformation
    if out[0] == w0[0] and out[1] == w0[1]
        return 1

    0

[[test]]
fn test_sha256msg2_basic() -> i32
    # Test SHA-256 message schedule (part 2)
    # sha256msg2(w0: v4i32, w1: v4i32) -> v4i32
    var w0: [4]i32
    var w1: [4]i32

    w0[0] = 0x61626364 as i32
    w0[1] = 0x65666768 as i32
    w0[2] = 0x696a6b6c as i32
    w0[3] = 0x6d6e6f70 as i32

    w1[0] = 0x71727374 as i32
    w1[1] = 0x75767778 as i32
    w1[2] = 0x797a3031 as i32
    w1[3] = 0x32333435 as i32

    let v0: v4i32 = simd_loadu(@w0[0])
    let v1: v4i32 = simd_loadu(@w1[0])

    let result: v4i32 = sha256msg2(v0, v1)

    var out: [4]i32
    simd_storeu(@out[0], result)

    if out[0] == w0[0] and out[1] == w0[1]
        return 1

    0

[[test]]
fn test_sha256_message_schedule() -> i32
    # Test full message schedule expansion using msg1 and msg2
    # Use flat arrays to avoid 2D array indexing issues
    var w0: [4]i32
    var w1: [4]i32
    var w3: [4]i32
    var w4: [4]i32

    # Initialize first words
    w0[0] = 0x61626364 as i32
    w0[1] = 0x65666768 as i32
    w0[2] = 0x696a6b6c as i32
    w0[3] = 0x6d6e6f70 as i32

    w1[0] = 0x61626365 as i32
    w1[1] = 0x65666769 as i32
    w1[2] = 0x696a6b6d as i32
    w1[3] = 0x6d6e6f71 as i32

    w3[0] = 0x61626367 as i32
    w3[1] = 0x6566676b as i32
    w3[2] = 0x696a6b6f as i32
    w3[3] = 0x6d6e6f73 as i32

    # Expand w4 using w0 and w1
    let v0: v4i32 = simd_loadu(@w0[0])
    let v1: v4i32 = simd_loadu(@w1[0])

    let partial: v4i32 = sha256msg1(v0, v1)

    # Complete with w3
    let v3: v4i32 = simd_loadu(@w3[0])
    let result: v4i32 = sha256msg2(partial, v3)

    simd_storeu(@w4[0], result)

    # Verify expansion occurred
    if w4[0] == w0[0]
        return 1

    0

fn main() -> i32
    0
