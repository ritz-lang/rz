# Regression: for-in should support arrays and borrowed Vec values.
import ritzlib.gvec

const VALUES: [3]i32 = [2, 3, 5]

fn sum_array() -> i32
    var total: i32 = 0
    for v in VALUES
        total = total + v
    total

fn iter_empty_vec() -> i32
    var v = vec_new<u8>()
    var seen: i32 = 0
    for _n in @v
        seen = seen + 1
    seen

[[test]]
fn test_for_iter_array_ident() -> i32
    if sum_array() == 10
        0
    else
        1

[[test]]
fn test_for_iter_vec_ref() -> i32
    if iter_empty_vec() == 0
        0
    else
        1
