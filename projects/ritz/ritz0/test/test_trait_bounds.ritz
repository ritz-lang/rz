# Test file for trait bounds
#
# This file tests that trait bounds work correctly:
# - Functions with bounded type parameters
# - Structs with bounded type parameters
# - Bounds are satisfied when type implements required traits

import ritzlib.string
import ritzlib.gvec

# A simple trait for testing
trait Displayable
    fn display(self: *Self) -> i32

# A type that implements Displayable
struct Counter
    value: i32

impl Displayable for Counter
    fn display(self: *Counter) -> i32
        return self.value

# A type that does NOT implement Displayable
struct PlainInt
    value: i32

# =============================================================================
# Test: Function with trait bounds (satisfied)
# =============================================================================

# This function requires T: Displayable
fn show_value<T: Displayable>(item: *T) -> i32
    return item.display()

[[test]]
fn test_bounded_function_with_valid_type() -> i32
    # Counter implements Displayable, so this should work
    var c: Counter
    c.value = 42
    let result: i32 = show_value<Counter>(@c)
    if result != 42
        return 1
    return 0

# =============================================================================
# Test: Struct with trait bounds (satisfied by Drop)
# =============================================================================

# A container that requires its element type to implement Drop
struct DroppableContainer<T: Drop>
    data: T

# Vec<u8> implements Drop, so this should work
[[test]]
fn test_bounded_struct_with_drop() -> i32
    # String implements Drop, so DroppableContainer<String> should work
    var container: DroppableContainer<String>
    container.data = string_from("hello")
    if string_len(@container.data) != 5
        return 1
    return 0

# =============================================================================
# Test: Multiple bounds on same parameter
# =============================================================================

trait Cloneable
    fn clone(self: *Self) -> Self

struct Foo
    x: i32

impl Displayable for Foo
    fn display(self: *Foo) -> i32
        return self.x

impl Cloneable for Foo
    fn clone(self: *Foo) -> Foo
        var copy: Foo
        copy.x = self.x
        return copy

# Function requiring both Displayable and Cloneable
fn display_clone<T: Displayable + Cloneable>(item: *T) -> i32
    var cloned: T = item.clone()
    return item.display()

[[test]]
fn test_multiple_bounds_satisfied() -> i32
    var f: Foo
    f.x = 100
    let result: i32 = display_clone<Foo>(@f)
    if result != 100
        return 1
    return 0

# =============================================================================
# Test: Mixed bounded and unbounded parameters
# =============================================================================

fn mixed_params<T, U: Displayable>(a: T, b: *U) -> i32
    # T has no bounds, U must be Displayable
    return b.display()

[[test]]
fn test_mixed_bounded_unbounded() -> i32
    var c: Counter
    c.value = 77
    let result: i32 = mixed_params<i32, Counter>(99, @c)
    if result != 77
        return 1
    return 0

# =============================================================================
# Test: Impl block with bounds
# =============================================================================

struct Wrapper<T: Displayable>
    inner: T

impl<T: Displayable> Wrapper<T>
    fn get_display(self: *Wrapper<T>) -> i32
        return self.inner.display()

[[test]]
fn test_impl_with_bounds() -> i32
    var w: Wrapper<Counter>
    w.inner.value = 55
    let result: i32 = w.get_display()
    if result != 55
        return 1
    return 0
