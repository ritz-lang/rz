# Regression: `*p = value` where `p: @&T` (TYPE_MUT_REF) used to emit
# `inttoptr i64 %p to ptr` even though %p was already loaded as `ptr`.
# Repro shape pulled from tome's `pub fn store_lrange(... out_count: @&i64)`
# which writes `*out_count = 0` at the top of its body.

fn set_zero(p: @&i64)
    *p = 0

fn write_through(p: @&i64, val: i64)
    *p = val

[[test]]
fn test_mut_ref_deref_assign() -> i32
    var x: i64 = 42
    set_zero(@x)
    assert x == 0
    write_through(@x, 7)
    assert x == 7
    0
