# Test level 22: Dynamic arrays (Vec<T>)
#
# Tests ritzlib/gvec.ritz functionality - the generic Vec type.

import ritzlib.sys
import ritzlib.io
import ritzlib.str
import ritzlib.gvec

# ============================================================================
# Test: Vec<u8> basic operations (replaces ByteVec)
# ============================================================================

[[test]]
fn test_vec_u8_new() -> i32
    var v: Vec<u8> = vec_new<u8>()
    assert v.data == null, c"new vec should have null data"
    assert v.len == 0, c"new vec should have len 0"
    assert v.cap == 0, c"new vec should have cap 0"
    return 0

[[test]]
fn test_vec_u8_push() -> i32
    var v: Vec<u8> = vec_new<u8>()

    vec_push<u8>(@v, 65)  # 'A'
    vec_push<u8>(@v, 66)  # 'B'
    vec_push<u8>(@v, 67)  # 'C'

    assert v.len == 3, c"len should be 3"
    assert vec_get<u8>(@v, 0) == 65, c"first element should be 'A'"
    assert vec_get<u8>(@v, 1) == 66, c"second element should be 'B'"
    assert vec_get<u8>(@v, 2) == 67, c"third element should be 'C'"

    # Auto-drop via Drop trait
    return 0

[[test]]
fn test_vec_u8_push_str() -> i32
    var v: Vec<u8> = vec_new<u8>()

    vec_push_str(@v, c"hello")
    assert v.len == 5, c"len should be 5"

    let s: *u8 = vec_as_str(@v)
    assert streq(s, c"hello") != 0, c"should equal 'hello'"

    return 0

[[test]]
fn test_vec_u8_pop() -> i32
    var v: Vec<u8> = vec_new<u8>()

    vec_push<u8>(@v, 1)
    vec_push<u8>(@v, 2)
    vec_push<u8>(@v, 3)

    assert vec_pop<u8>(@v) == 3, c"pop should return 3"
    assert vec_pop<u8>(@v) == 2, c"pop should return 2"
    assert v.len == 1, c"len should be 1"

    return 0

[[test]]
fn test_vec_u8_clear() -> i32
    var v: Vec<u8> = vec_new<u8>()

    vec_push_str(@v, c"test")
    assert v.len == 4, c"len should be 4"

    vec_clear<u8>(@v)
    assert v.len == 0, c"len should be 0 after clear"
    assert v.cap > 0, c"cap should still be > 0"

    return 0

[[test]]
fn test_vec_u8_growth() -> i32
    var v: Vec<u8> = vec_new<u8>()

    # Push many elements to trigger growth
    var i: i32 = 0
    while i < 100
        vec_push<u8>(@v, (i % 256) as u8)
        i = i + 1

    assert v.len == 100, c"len should be 100"
    assert v.cap >= 100, c"cap should be >= 100"
    assert vec_get<u8>(@v, 50) == 50, c"element 50 should be 50"

    return 0

# ============================================================================
# Test: Vec<*u8> operations (replaces PtrVec)
# ============================================================================

[[test]]
fn test_vec_ptr_basic() -> i32
    var v: Vec<*u8> = vec_new<*u8>()

    let s1: *u8 = c"first"
    vec_push<*u8>(@v, s1)

    if v.len != 1
        return 1

    let p1: *u8 = vec_get<*u8>(@v, 0)
    if p1 != s1
        return 2

    return 0

[[test]]
fn test_vec_ptr_pop() -> i32
    var v: Vec<*u8> = vec_new<*u8>()

    vec_push<*u8>(@v, c"a")
    vec_push<*u8>(@v, c"b")
    vec_push<*u8>(@v, c"c")

    let popped: *u8 = vec_pop<*u8>(@v)
    assert streq(popped, c"c") != 0, c"popped should be 'c'"
    assert v.len == 2, c"len should be 2"

    return 0

# ============================================================================
# Test: Vec<i64> operations (replaces I64Vec)
# ============================================================================

[[test]]
fn test_vec_i64_basic() -> i32
    var v: Vec<i64> = vec_new<i64>()

    vec_push<i64>(@v, 100)
    vec_push<i64>(@v, 200)
    vec_push<i64>(@v, 300)

    assert v.len == 3, c"len should be 3"
    assert vec_get<i64>(@v, 0) == 100, c"first should be 100"
    assert vec_get<i64>(@v, 1) == 200, c"second should be 200"
    assert vec_get<i64>(@v, 2) == 300, c"third should be 300"

    return 0

[[test]]
fn test_vec_i64_set() -> i32
    var v: Vec<i64> = vec_new<i64>()

    vec_push<i64>(@v, 1)
    vec_push<i64>(@v, 2)
    vec_push<i64>(@v, 3)

    vec_set<i64>(@v, 1, 42)
    assert vec_get<i64>(@v, 1) == 42, c"after set, should be 42"

    return 0

[[test]]
fn test_vec_i64_sum() -> i32
    var v: Vec<i64> = vec_new<i64>()

    # Push 1..10
    var i: i64 = 1
    while i <= 10
        vec_push<i64>(@v, i)
        i = i + 1

    # Sum them
    var sum: i64 = 0
    i = 0
    while i < v.len
        sum = sum + vec_get<i64>(@v, i)
        i = i + 1

    assert sum == 55, c"sum of 1..10 should be 55"

    return 0

# ============================================================================
# Test: Pre-allocated capacity
# ============================================================================

[[test]]
fn test_vec_u8_with_cap() -> i32
    var v: Vec<u8> = vec_with_cap<u8>(100)

    assert v.cap >= 100, c"cap should be >= 100"
    assert v.len == 0, c"len should be 0"

    # Push without triggering reallocation
    var i: i32 = 0
    while i < 50
        vec_push<u8>(@v, (i % 256) as u8)
        i = i + 1

    assert v.len == 50, c"len should be 50"

    return 0

# ============================================================================
# Test: Vec<u8> push_bytes
# ============================================================================

[[test]]
fn test_vec_u8_push_bytes() -> i32
    var v: Vec<u8> = vec_new<u8>()

    let data: *u8 = c"hello" as *u8
    vec_push_bytes<u8>(@v, data, 5)

    assert v.len == 5, c"len should be 5"
    assert vec_get<u8>(@v, 0) == 104, c"first should be 'h'"
    assert vec_get<u8>(@v, 4) == 111, c"last should be 'o'"

    return 0

# ============================================================================
# Test: Method syntax
# ============================================================================

[[test]]
fn test_vec_method_syntax() -> i32
    var v: Vec<i64> = vec_new<i64>()

    v.push(10)
    v.push(20)
    v.push(30)

    assert v.len() == 3, c"len should be 3"
    assert v.get(0) == 10, c"first should be 10"
    assert v.get(1) == 20, c"second should be 20"
    assert v.last() == 30, c"last should be 30"

    let popped: i64 = v.pop()
    assert popped == 30, c"popped should be 30"
    assert v.len() == 2, c"len should be 2"

    return 0

# ============================================================================
# Main entry point
# ============================================================================

fn main() -> i32
    prints(c"Test level 22: Dynamic arrays (Vec<T>)\n")
    prints(c"OK\n")
    return 0
