# Test S-string literals: s"..."
#
# Features tested:
# - S-string literal syntax (s"...")
# - S-strings produce a { ptr: *u8, len: i64 } aggregate (Span<u8>)
# - Length is set at compile time from the literal
# - Escape sequences in s-strings
#
# AGAST #89 / CS1: ritz1 AST+emitter distinction for c"/s" string literals.
# Previously ritz1 collapsed c"..."/s"..." into a single EXPR_STRING_LIT
# which the emitter always typed as *u8. After CS1, s"..." is emitted as a
# Span<u8> aggregate so `let y: Span<u8> = s"hi"` type-checks correctly.
# (ritz0 already did this; this test guards the new ritz1 parity.)

[[test]]
fn test_sstring_basic() -> i32
    # The critical part: this declaration must type-check and emit a
    # { ptr, len } aggregate, not a bare *u8.
    let s: Span<u8> = s"hello"
    0

[[test]]
fn test_sstring_empty() -> i32
    let s: Span<u8> = s""
    0

[[test]]
fn test_sstring_escapes() -> i32
    # Escape sequences (cooked by lexer) are preserved in the span.
    let s: Span<u8> = s"a\nb\tc"
    0

[[test]]
fn test_sstring_multiple_in_scope() -> i32
    let a: Span<u8> = s"foo"
    let b: Span<u8> = s"bar"
    let c: Span<u8> = s"baz"
    0

[[test]]
fn test_sstring_with_cstring_alongside() -> i32
    # Separate declarations of both forms in the same function:
    # c"..." -> *u8, s"..." -> Span<u8>.
    let cp: *u8 = c"yo"
    let sp: Span<u8> = s"yo"
    # Just exercise the pointer from c"..." to prove it is *u8.
    assert *cp == 121  # 'y'
    0
