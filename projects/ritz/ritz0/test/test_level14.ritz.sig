    "test_heap_alloc_basic": {
      "hash": "7768bf0c8e0751fb",
      "ir": "define internal i32 @\"test_heap_alloc_basic\"() !dbg !19\n{\nentry:\n  %\".2\" = call i8* @\"l14_alloc\"(i64 4096), !dbg !38\n  %\".3\" = icmp ne i8* %\".2\", null , !dbg !39\n  br i1 %\".3\", label %\"assert.pass\", label %\"assert.fail\", !dbg !39\nassert.pass:\n  %\".7\" = trunc i64 42 to i8 , !dbg !40\n  store i8 %\".7\", i8* %\".2\", !dbg !40\n  %\".9\" = load i8, i8* %\".2\", !dbg !41\n  %\".10\" = zext i8 %\".9\" to i64 , !dbg !41\n  %\".11\" = icmp eq i64 %\".10\", 42 , !dbg !41\n  br i1 %\".11\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !41\nassert.fail:\n  %\".5\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !39\n  unreachable\nassert.pass.1:\n  %\".15\" = call i32 @\"l14_free\"(i8* %\".2\", i64 4096), !dbg !42\n  %\".16\" = sext i32 %\".15\" to i64 , !dbg !43\n  %\".17\" = icmp eq i64 %\".16\", 0 , !dbg !43\n  br i1 %\".17\", label %\"assert.pass.2\", label %\"assert.fail.2\", !dbg !43\nassert.fail.1:\n  %\".13\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !41\n  unreachable\nassert.pass.2:\n  %\".21\" = trunc i64 0 to i32 , !dbg !44\n  ret i32 %\".21\", !dbg !44\nassert.fail.2:\n  %\".19\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !43\n  unreachable\n}"
    },
    "test_heap_alloc_array": {
      "hash": "50637abae9f835c1",
      "ir": "define internal i32 @\"test_heap_alloc_array\"() !dbg !20\n{\nentry:\n  %\"i.addr\" = alloca i32, !dbg !49\n  %\".2\" = call i8* @\"l14_alloc\"(i64 400), !dbg !46\n  %\".3\" = icmp ne i8* %\".2\", null , !dbg !47\n  br i1 %\".3\", label %\"assert.pass\", label %\"assert.fail\", !dbg !47\nassert.pass:\n  %\".7\" = bitcast i8* %\".2\" to i32* , !dbg !48\n  %\".8\" = trunc i64 0 to i32 , !dbg !49\n  store i32 %\".8\", i32* %\"i.addr\", !dbg !49\n  call void @\"llvm.dbg.declare\"(metadata i32* %\"i.addr\", metadata !50, metadata !7), !dbg !51\n  br label %\"while.cond\", !dbg !52\nassert.fail:\n  %\".5\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !47\n  unreachable\nwhile.cond:\n  %\".12\" = load i32, i32* %\"i.addr\", !dbg !52\n  %\".13\" = sext i32 %\".12\" to i64 , !dbg !52\n  %\".14\" = icmp slt i64 %\".13\", 100 , !dbg !52\n  br i1 %\".14\", label %\"while.body\", label %\"while.end\", !dbg !52\nwhile.body:\n  %\".16\" = load i32, i32* %\"i.addr\", !dbg !53\n  %\".17\" = sext i32 %\".16\" to i64 , !dbg !53\n  %\".18\" = mul i64 %\".17\", 2, !dbg !53\n  %\".19\" = load i32, i32* %\"i.addr\", !dbg !53\n  %\".20\" = getelementptr i32, i32* %\".7\", i32 %\".19\" , !dbg !53\n  %\".21\" = trunc i64 %\".18\" to i32 , !dbg !53\n  store i32 %\".21\", i32* %\".20\", !dbg !53\n  %\".23\" = load i32, i32* %\"i.addr\", !dbg !54\n  %\".24\" = sext i32 %\".23\" to i64 , !dbg !54\n  %\".25\" = add i64 %\".24\", 1, !dbg !54\n  %\".26\" = trunc i64 %\".25\" to i32 , !dbg !54\n  store i32 %\".26\", i32* %\"i.addr\", !dbg !54\n  br label %\"while.cond\", !dbg !54\nwhile.end:\n  %\".29\" = getelementptr i32, i32* %\".7\", i64 0 , !dbg !55\n  %\".30\" = load i32, i32* %\".29\", !dbg !55\n  %\".31\" = sext i32 %\".30\" to i64 , !dbg !55\n  %\".32\" = icmp eq i64 %\".31\", 0 , !dbg !55\n  br i1 %\".32\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !55\nassert.pass.1:\n  %\".36\" = getelementptr i32, i32* %\".7\", i64 50 , !dbg !56\n  %\".37\" = load i32, i32* %\".36\", !dbg !56\n  %\".38\" = sext i32 %\".37\" to i64 , !dbg !56\n  %\".39\" = icmp eq i64 %\".38\", 100 , !dbg !56\n  br i1 %\".39\", label %\"assert.pass.2\", label %\"assert.fail.2\", !dbg !56\nassert.fail.1:\n  %\".34\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !55\n  unreachable\nassert.pass.2:\n  %\".43\" = getelementptr i32, i32* %\".7\", i64 99 , !dbg !57\n  %\".44\" = load i32, i32* %\".43\", !dbg !57\n  %\".45\" = sext i32 %\".44\" to i64 , !dbg !57\n  %\".46\" = icmp eq i64 %\".45\", 198 , !dbg !57\n  br i1 %\".46\", label %\"assert.pass.3\", label %\"assert.fail.3\", !dbg !57\nassert.fail.2:\n  %\".41\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !56\n  unreachable\nassert.pass.3:\n  %\".50\" = call i32 @\"l14_free\"(i8* %\".2\", i64 400), !dbg !58\n  %\".51\" = trunc i64 0 to i32 , !dbg !59\n  ret i32 %\".51\", !dbg !59\nassert.fail.3:\n  %\".48\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !57\n  unreachable\n}"
    },
    "test_heap_alloc_large": {
      "hash": "cf383f008a3bca5f",
      "ir": "define internal i32 @\"test_heap_alloc_large\"() !dbg !21\n{\nentry:\n  %\".2\" = call i8* @\"l14_alloc\"(i64 1048576), !dbg !61\n  %\".3\" = icmp ne i8* %\".2\", null , !dbg !62\n  br i1 %\".3\", label %\"assert.pass\", label %\"assert.fail\", !dbg !62\nassert.pass:\n  %\".7\" = trunc i64 1 to i8 , !dbg !63\n  store i8 %\".7\", i8* %\".2\", !dbg !63\n  %\".9\" = trunc i64 99 to i8 , !dbg !64\n  %\".10\" = getelementptr i8, i8* %\".2\", i64 1048575 , !dbg !64\n  store i8 %\".9\", i8* %\".10\", !dbg !64\n  %\".12\" = load i8, i8* %\".2\", !dbg !65\n  %\".13\" = zext i8 %\".12\" to i64 , !dbg !65\n  %\".14\" = icmp eq i64 %\".13\", 1 , !dbg !65\n  br i1 %\".14\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !65\nassert.fail:\n  %\".5\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !62\n  unreachable\nassert.pass.1:\n  %\".18\" = getelementptr i8, i8* %\".2\", i64 1048575 , !dbg !66\n  %\".19\" = load i8, i8* %\".18\", !dbg !66\n  %\".20\" = zext i8 %\".19\" to i64 , !dbg !66\n  %\".21\" = icmp eq i64 %\".20\", 99 , !dbg !66\n  br i1 %\".21\", label %\"assert.pass.2\", label %\"assert.fail.2\", !dbg !66\nassert.fail.1:\n  %\".16\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !65\n  unreachable\nassert.pass.2:\n  %\".25\" = call i32 @\"l14_free\"(i8* %\".2\", i64 1048576), !dbg !67\n  %\".26\" = trunc i64 0 to i32 , !dbg !68\n  ret i32 %\".26\", !dbg !68\nassert.fail.2:\n  %\".23\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !66\n  unreachable\n}"
    },
    "test_heap_alloc_multiple": {
      "hash": "5ed0715f77d818c9",
      "ir": "define internal i32 @\"test_heap_alloc_multiple\"() !dbg !22\n{\nentry:\n  %\".2\" = call i8* @\"l14_alloc\"(i64 4096), !dbg !69\n  %\".3\" = call i8* @\"l14_alloc\"(i64 4096), !dbg !70\n  %\".4\" = call i8* @\"l14_alloc\"(i64 4096), !dbg !71\n  %\".5\" = icmp ne i8* %\".2\", null , !dbg !72\n  br i1 %\".5\", label %\"assert.pass\", label %\"assert.fail\", !dbg !72\nassert.pass:\n  %\".9\" = icmp ne i8* %\".3\", null , !dbg !73\n  br i1 %\".9\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !73\nassert.fail:\n  %\".7\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !72\n  unreachable\nassert.pass.1:\n  %\".13\" = icmp ne i8* %\".4\", null , !dbg !74\n  br i1 %\".13\", label %\"assert.pass.2\", label %\"assert.fail.2\", !dbg !74\nassert.fail.1:\n  %\".11\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !73\n  unreachable\nassert.pass.2:\n  %\".17\" = icmp ne i8* %\".2\", %\".3\" , !dbg !75\n  br i1 %\".17\", label %\"assert.pass.3\", label %\"assert.fail.3\", !dbg !75\nassert.fail.2:\n  %\".15\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !74\n  unreachable\nassert.pass.3:\n  %\".21\" = icmp ne i8* %\".3\", %\".4\" , !dbg !76\n  br i1 %\".21\", label %\"assert.pass.4\", label %\"assert.fail.4\", !dbg !76\nassert.fail.3:\n  %\".19\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !75\n  unreachable\nassert.pass.4:\n  %\".25\" = icmp ne i8* %\".2\", %\".4\" , !dbg !77\n  br i1 %\".25\", label %\"assert.pass.5\", label %\"assert.fail.5\", !dbg !77\nassert.fail.4:\n  %\".23\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !76\n  unreachable\nassert.pass.5:\n  %\".29\" = trunc i64 1 to i8 , !dbg !78\n  store i8 %\".29\", i8* %\".2\", !dbg !78\n  %\".31\" = trunc i64 2 to i8 , !dbg !79\n  store i8 %\".31\", i8* %\".3\", !dbg !79\n  %\".33\" = trunc i64 3 to i8 , !dbg !80\n  store i8 %\".33\", i8* %\".4\", !dbg !80\n  %\".35\" = load i8, i8* %\".2\", !dbg !81\n  %\".36\" = zext i8 %\".35\" to i64 , !dbg !81\n  %\".37\" = icmp eq i64 %\".36\", 1 , !dbg !81\n  br i1 %\".37\", label %\"assert.pass.6\", label %\"assert.fail.6\", !dbg !81\nassert.fail.5:\n  %\".27\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !77\n  unreachable\nassert.pass.6:\n  %\".41\" = load i8, i8* %\".3\", !dbg !82\n  %\".42\" = zext i8 %\".41\" to i64 , !dbg !82\n  %\".43\" = icmp eq i64 %\".42\", 2 , !dbg !82\n  br i1 %\".43\", label %\"assert.pass.7\", label %\"assert.fail.7\", !dbg !82\nassert.fail.6:\n  %\".39\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !81\n  unreachable\nassert.pass.7:\n  %\".47\" = load i8, i8* %\".4\", !dbg !83\n  %\".48\" = zext i8 %\".47\" to i64 , !dbg !83\n  %\".49\" = icmp eq i64 %\".48\", 3 , !dbg !83\n  br i1 %\".49\", label %\"assert.pass.8\", label %\"assert.fail.8\", !dbg !83\nassert.fail.7:\n  %\".45\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !82\n  unreachable\nassert.pass.8:\n  %\".53\" = call i32 @\"l14_free\"(i8* %\".4\", i64 4096), !dbg !84\n  %\".54\" = call i32 @\"l14_free\"(i8* %\".3\", i64 4096), !dbg !85\n  %\".55\" = call i32 @\"l14_free\"(i8* %\".2\", i64 4096), !dbg !86\n  %\".56\" = trunc i64 0 to i32 , !dbg !87\n  ret i32 %\".56\", !dbg !87\nassert.fail.8:\n  %\".51\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !83\n  unreachable\n}"
    },
    "test_heap_struct_on_heap": {
      "hash": "26e638a83705c1cd",
      "ir": "define internal i32 @\"test_heap_struct_on_heap\"() !dbg !23\n{\nentry:\n  %\".2\" = call i8* @\"l14_alloc\"(i64 8), !dbg !88\n  %\".3\" = icmp ne i8* %\".2\", null , !dbg !89\n  br i1 %\".3\", label %\"assert.pass\", label %\"assert.fail\", !dbg !89\nassert.pass:\n  %\".7\" = bitcast i8* %\".2\" to %\"struct.ritz_module_1.HeapPoint\"* , !dbg !90\n  %\".8\" = getelementptr %\"struct.ritz_module_1.HeapPoint\", %\"struct.ritz_module_1.HeapPoint\"* %\".7\", i32 0, i32 0 , !dbg !91\n  %\".9\" = trunc i64 10 to i32 , !dbg !91\n  store i32 %\".9\", i32* %\".8\", !dbg !91\n  %\".11\" = getelementptr %\"struct.ritz_module_1.HeapPoint\", %\"struct.ritz_module_1.HeapPoint\"* %\".7\", i32 0, i32 1 , !dbg !92\n  %\".12\" = trunc i64 20 to i32 , !dbg !92\n  store i32 %\".12\", i32* %\".11\", !dbg !92\n  %\".14\" = getelementptr %\"struct.ritz_module_1.HeapPoint\", %\"struct.ritz_module_1.HeapPoint\"* %\".7\", i32 0, i32 0 , !dbg !93\n  %\".15\" = load i32, i32* %\".14\", !dbg !93\n  %\".16\" = sext i32 %\".15\" to i64 , !dbg !93\n  %\".17\" = icmp eq i64 %\".16\", 10 , !dbg !93\n  br i1 %\".17\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !93\nassert.fail:\n  %\".5\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !89\n  unreachable\nassert.pass.1:\n  %\".21\" = getelementptr %\"struct.ritz_module_1.HeapPoint\", %\"struct.ritz_module_1.HeapPoint\"* %\".7\", i32 0, i32 1 , !dbg !94\n  %\".22\" = load i32, i32* %\".21\", !dbg !94\n  %\".23\" = sext i32 %\".22\" to i64 , !dbg !94\n  %\".24\" = icmp eq i64 %\".23\", 20 , !dbg !94\n  br i1 %\".24\", label %\"assert.pass.2\", label %\"assert.fail.2\", !dbg !94\nassert.fail.1:\n  %\".19\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !93\n  unreachable\nassert.pass.2:\n  %\".28\" = call i32 @\"l14_free\"(i8* %\".2\", i64 8), !dbg !95\n  %\".29\" = trunc i64 0 to i32 , !dbg !96\n  ret i32 %\".29\", !dbg !96\nassert.fail.2:\n  %\".26\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !94\n  unreachable\n}"
    },
    "test_heap_aligned_access": {
      "hash": "bd57245ec78efe8a",
      "ir": "define internal i32 @\"test_heap_aligned_access\"() !dbg !24\n{\nentry:\n  %\"i.addr\" = alloca i64, !dbg !101\n  %\".2\" = call i8* @\"l14_alloc\"(i64 80), !dbg !98\n  %\".3\" = icmp ne i8* %\".2\", null , !dbg !99\n  br i1 %\".3\", label %\"assert.pass\", label %\"assert.fail\", !dbg !99\nassert.pass:\n  %\".7\" = bitcast i8* %\".2\" to i64* , !dbg !100\n  store i64 0, i64* %\"i.addr\", !dbg !101\n  call void @\"llvm.dbg.declare\"(metadata i64* %\"i.addr\", metadata !102, metadata !7), !dbg !103\n  br label %\"while.cond\", !dbg !104\nassert.fail:\n  %\".5\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !99\n  unreachable\nwhile.cond:\n  %\".11\" = load i64, i64* %\"i.addr\", !dbg !104\n  %\".12\" = icmp slt i64 %\".11\", 10 , !dbg !104\n  br i1 %\".12\", label %\"while.body\", label %\"while.end\", !dbg !104\nwhile.body:\n  %\".14\" = load i64, i64* %\"i.addr\", !dbg !105\n  %\".15\" = mul i64 %\".14\", 1000000000, !dbg !105\n  %\".16\" = load i64, i64* %\"i.addr\", !dbg !105\n  %\".17\" = getelementptr i64, i64* %\".7\", i64 %\".16\" , !dbg !105\n  store i64 %\".15\", i64* %\".17\", !dbg !105\n  %\".19\" = load i64, i64* %\"i.addr\", !dbg !106\n  %\".20\" = add i64 %\".19\", 1, !dbg !106\n  store i64 %\".20\", i64* %\"i.addr\", !dbg !106\n  br label %\"while.cond\", !dbg !106\nwhile.end:\n  %\".23\" = getelementptr i64, i64* %\".7\", i64 0 , !dbg !107\n  %\".24\" = load i64, i64* %\".23\", !dbg !107\n  %\".25\" = icmp eq i64 %\".24\", 0 , !dbg !107\n  br i1 %\".25\", label %\"assert.pass.1\", label %\"assert.fail.1\", !dbg !107\nassert.pass.1:\n  %\".29\" = getelementptr i64, i64* %\".7\", i64 5 , !dbg !108\n  %\".30\" = load i64, i64* %\".29\", !dbg !108\n  %\".31\" = icmp eq i64 %\".30\", 5000000000 , !dbg !108\n  br i1 %\".31\", label %\"assert.pass.2\", label %\"assert.fail.2\", !dbg !108\nassert.fail.1:\n  %\".27\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !107\n  unreachable\nassert.pass.2:\n  %\".35\" = getelementptr i64, i64* %\".7\", i64 9 , !dbg !109\n  %\".36\" = load i64, i64* %\".35\", !dbg !109\n  %\".37\" = icmp eq i64 %\".36\", 9000000000 , !dbg !109\n  br i1 %\".37\", label %\"assert.pass.3\", label %\"assert.fail.3\", !dbg !109\nassert.fail.2:\n  %\".33\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !108\n  unreachable\nassert.pass.3:\n  %\".41\" = call i32 @\"l14_free\"(i8* %\".2\", i64 80), !dbg !110\n  %\".42\" = trunc i64 0 to i32 , !dbg !111\n  ret i32 %\".42\", !dbg !111\nassert.fail.3:\n  %\".39\" = call i64 asm sideeffect \"syscall\", \"={rax},{rax},{rdi},~{rcx},~{r11},~{memory}\"(i64 60, i64 1), !dbg !109\n  unreachable\n}"
    },
    "test_heap_byte_buffer": {
