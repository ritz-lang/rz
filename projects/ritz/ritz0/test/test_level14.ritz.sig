    "l14_alloc": {
      "hash": "f7ffe60b948d3f35",
      "ir": "define internal i8* @\"l14_alloc\"(i64 %\"size.arg\") !dbg !17\n{\nentry:\n  %\"size\" = alloca i64\n  store i64 %\"size.arg\", i64* %\"size\"\n  call void @\"llvm.dbg.declare\"(metadata i64* %\"size\", metadata !26, metadata !7), !dbg !27\n  %\".5\" = load i64, i64* %\"size\", !dbg !28\n  %\".6\" = sub i64 0, 1, !dbg !28\n  %\".7\" = call i64 asm sideeffect \"syscall\", \"=&{rax},{rax},{rdi},{rsi},{rdx},{r10},{r8},{r9},~{rcx},~{r11},~{memory}\"(i64 9, i64 0, i64 %\".5\", i64 3, i64 34, i64 %\".6\", i64 0), !dbg !28\n  %\".8\" = icmp slt i64 %\".7\", 0 , !dbg !29\n  br i1 %\".8\", label %\"if.then\", label %\"if.end\", !dbg !29\nif.then:\n  ret i8* null, !dbg !30\nif.end:\n  %\".11\" = inttoptr i64 %\".7\" to i8* , !dbg !31\n  ret i8* %\".11\", !dbg !31\n}"
    },
    "l14_free": {
      "hash": "904dd47e34368e81",
      "ir": "define internal i32 @\"l14_free\"(i8* %\"ptr.arg\", i64 %\"size.arg\") !dbg !18\n{\nentry:\n  %\"ptr\" = alloca i8*\n  store i8* %\"ptr.arg\", i8** %\"ptr\"\n  call void @\"llvm.dbg.declare\"(metadata i8** %\"ptr\", metadata !33, metadata !7), !dbg !34\n  %\"size\" = alloca i64\n  store i64 %\"size.arg\", i64* %\"size\"\n  call void @\"llvm.dbg.declare\"(metadata i64* %\"size\", metadata !35, metadata !7), !dbg !34\n  %\".8\" = load i8*, i8** %\"ptr\", !dbg !36\n  %\".9\" = ptrtoint i8* %\".8\" to i64 , !dbg !36\n  %\".10\" = load i64, i64* %\"size\", !dbg !36\n  %\".11\" = call i64 asm sideeffect \"syscall\", \"=&{rax},{rax},{rdi},{rsi},{rdx},{r10},{r8},{r9},~{rcx},~{r11},~{memory}\"(i64 11, i64 %\".9\", i64 %\".10\", i64 0, i64 0, i64 0, i64 0), !dbg !36\n  %\".12\" = trunc i64 %\".11\" to i32 , !dbg !37\n  ret i32 %\".12\", !dbg !37\n}"
