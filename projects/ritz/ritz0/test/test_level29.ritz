# Test level 29: Drop trait and automatic cleanup
#
# Tests automatic destructor calls when variables go out of scope.
# Features tested:
# - Drop trait definition
# - impl Drop for Type
# - Automatic drop at end of scope
# - Automatic drop on early return
# - Nested types with Drop (String contains Vec<u8>)

import ritzlib.sys
import ritzlib.io
import ritzlib.box
import ritzlib.gvec
import ritzlib.string

# ============================================================================
# Manual Drop Tests (verify current behavior works)
# ============================================================================

[[test]]
fn test_box_manual_drop() -> i32
    var b: Box<i32> = box_new<i32>(42)
    let val: i32 = box_get<i32>(@b)
    assert val == 42, "box should contain 42"
    box_drop<i32>(@b)  # Manual drop
    return 0

[[test]]
fn test_vec_manual_drop() -> i32
    var v: Vec<i32> = vec_new<i32>()
    vec_push<i32>(@v, 1)
    vec_push<i32>(@v, 2)
    vec_push<i32>(@v, 3)
    assert vec_len<i32>(@v) == 3, "vec should have 3 elements"
    vec_drop<i32>(@v)  # Manual drop
    return 0

[[test]]
fn test_string_manual_drop() -> i32
    var s: String = string_from("hello")
    assert string_len(@s) == 5, "string should have 5 bytes"
    string_drop(@s)  # Manual drop
    return 0

