# ============================================================================
# Main entry point
# ============================================================================

fn main() -> i32
    prints("Test level 29: Drop trait and automatic cleanup\n")

    # Run manual drop tests
    test_box_manual_drop()
    test_vec_manual_drop()
    test_string_manual_drop()

    prints("All Drop tests passed!\n")
    return 0
