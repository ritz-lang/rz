# Test: Trait Objects (dyn Trait)
# Issue: ritz-lang/ritz#122

# Define a simple trait
trait Animal
    fn speak(self: *Self) -> i32

# Concrete types implementing the trait
struct Dog
    name_len: i32

struct Cat
    lives: i32

impl Animal for Dog
    fn speak(self: *Self) -> i32
        return 1  # Dogs say 1

impl Animal for Cat
    fn speak(self: *Self) -> i32
        return 2  # Cats say 2

# Test basic trait object creation and method call
[[test]]
fn test_dyn_basic() -> i32
    var dog: Dog = Dog { name_len: 5 }
    # Convert to trait object
    let animal: dyn Animal = @dog as dyn Animal
    # Call through vtable
    if animal.speak() != 1
        return 1
    return 0

# Test with Cat
[[test]]
fn test_dyn_cat() -> i32
    var cat: Cat = Cat { lives: 9 }
    let animal: dyn Animal = @cat as dyn Animal
    if animal.speak() != 2
        return 1
    return 0

# Test polymorphic function taking dyn Trait
fn make_speak(animal: dyn Animal) -> i32
    return animal.speak()

[[test]]
fn test_dyn_polymorphic_fn() -> i32
    var dog: Dog = Dog { name_len: 3 }
    var cat: Cat = Cat { lives: 7 }

    if make_speak(@dog as dyn Animal) != 1
        return 1
    if make_speak(@cat as dyn Animal) != 2
        return 2
    return 0

fn main() -> i32
    return 0
