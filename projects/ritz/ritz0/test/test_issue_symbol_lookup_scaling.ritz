# ritz-task-193 — Regression test for symbol-table HashMap conversion in
# ritz1's emitter_core.ritz.  Replaced linear-scan find_local / find_global
# / find_fn / find_struct / find_const_entry with O(1) HashMapI64 lookups
# (FNV-1a hashing the name bytes, with collision check).
#
# Bug: ritz1 cold-builds were 5.7× slower than ritz0 cold-builds because
# every symbol lookup did a from-end linear scan with byte-by-byte name
# compare.  ritz0 (Python) gets `dict[str, T]` for free.
#
# This file declares many local variables and many references — exercises
# the find_local / add_local hot path that dominates emit time.  If a
# future change reverts the HashMap to a linear scan, compile time of
# THIS file would scale O(N²) — easy to spot in pytest timings.
#
# Run via:  python3 -m pytest ritz0/test/test_issue_symbol_lookup_scaling.ritz

# ===== 50-local function: stresses find_local / add_local =====
[[test]]
fn test_many_locals_compile() -> i32
    # 50 distinct local bindings, each referenced multiple times — the
    # original linear-scan path made this O(50²) byte compares for each
    # find_local.  HashMap path is O(50) total adds + O(1) per find.
    let v00: i32 = 0
    let v01: i32 = 1
    let v02: i32 = 2
    let v03: i32 = 3
    let v04: i32 = 4
    let v05: i32 = 5
    let v06: i32 = 6
    let v07: i32 = 7
    let v08: i32 = 8
    let v09: i32 = 9
    let v10: i32 = 10
    let v11: i32 = 11
    let v12: i32 = 12
    let v13: i32 = 13
    let v14: i32 = 14
    let v15: i32 = 15
    let v16: i32 = 16
    let v17: i32 = 17
    let v18: i32 = 18
    let v19: i32 = 19
    let v20: i32 = 20
    let v21: i32 = 21
    let v22: i32 = 22
    let v23: i32 = 23
    let v24: i32 = 24
    let v25: i32 = 25
    let v26: i32 = 26
    let v27: i32 = 27
    let v28: i32 = 28
    let v29: i32 = 29
    let v30: i32 = 30
    let v31: i32 = 31
    let v32: i32 = 32
    let v33: i32 = 33
    let v34: i32 = 34
    let v35: i32 = 35
    let v36: i32 = 36
    let v37: i32 = 37
    let v38: i32 = 38
    let v39: i32 = 39
    let v40: i32 = 40
    let v41: i32 = 41
    let v42: i32 = 42
    let v43: i32 = 43
    let v44: i32 = 44
    let v45: i32 = 45
    let v46: i32 = 46
    let v47: i32 = 47
    let v48: i32 = 48
    let v49: i32 = 49
    # Reference every local so emit_expr's find_local_type fires for each.
    let sum: i32 = v00 + v01 + v02 + v03 + v04 + v05 + v06 + v07 + v08 + v09
    let sum2: i32 = v10 + v11 + v12 + v13 + v14 + v15 + v16 + v17 + v18 + v19
    let sum3: i32 = v20 + v21 + v22 + v23 + v24 + v25 + v26 + v27 + v28 + v29
    let sum4: i32 = v30 + v31 + v32 + v33 + v34 + v35 + v36 + v37 + v38 + v39
    let sum5: i32 = v40 + v41 + v42 + v43 + v44 + v45 + v46 + v47 + v48 + v49
    let total: i32 = sum + sum2 + sum3 + sum4 + sum5
    if total == 1225  # 0+1+...+49 = 1225
        0
    else
        1

# ===== Shadowing: scope rollback via {block} / match arm =====
# Verifies that the HashMap stays consistent across nested scopes — the
# inner shadowing binding must overwrite for find_local during the inner
# scope, but outer must be re-found after the inner ends.  ritz1's
# emit_match_arm_body calls rebuild_local_map on scope pop; this test
# pins down that semantics so a future "skip the rebuild" optimisation
# would surface as a correctness regression.
[[test]]
fn test_shadow_through_match() -> i32
    let x: i32 = 100
    let result: i32 = match x
        100 => x   # outer x visible here
        _   => 0
    if result == 100
        0
    else
        1
