# Test Level 12: Struct operations
#
# Features tested:
# - Struct definition
# - Struct literal creation
# - Field access
# - Struct pointers
# - Nested structs
# - Structs with arrays
# - Passing structs to functions

struct Point
  x: i32
  y: i32

struct Rect
  origin: Point
  width: i32
  height: i32

struct Vector3
  x: i32
  y: i32
  z: i32

struct Buffer
  data: [8]i32
  len: i32

struct Node
  value: i32
  next: *Node

# Helper functions

fn point_add(a: Point, b: Point) -> Point
  Point { x: a.x + b.x, y: a.y + b.y }

fn point_distance_squared(a: Point, b: Point) -> i32
  let dx: i32 = a.x - b.x
  let dy: i32 = a.y - b.y
  dx * dx + dy * dy

fn rect_area(r: Rect) -> i32
  r.width * r.height

fn vector_dot(a: Vector3, b: Vector3) -> i32
  a.x * b.x + a.y * b.y + a.z * b.z

fn vector_length_squared(v: Vector3) -> i32
  v.x * v.x + v.y * v.y + v.z * v.z

fn buffer_sum(b: *Buffer) -> i32
  var sum: i32 = 0
  var i: i32 = 0
  while i < b.len
    sum = sum + b.data[i]
    i = i + 1
  sum

# ===== TESTS =====

[[test]]
fn test_struct_create() -> i32
  let p: Point = Point { x: 10, y: 20 }
  assert p.x == 10
  assert p.y == 20
  0

[[test]]
fn test_struct_modify() -> i32
  var p: Point = Point { x: 0, y: 0 }
  p.x = 42
  p.y = 99
  assert p.x == 42
  assert p.y == 99
  0

[[test]]
fn test_struct_pointer() -> i32
  var p: Point = Point { x: 5, y: 10 }
  let ptr: *Point = @p
  assert ptr.x == 5
  assert ptr.y == 10
  ptr.x = 100
  assert p.x == 100
  0

[[test]]
fn test_nested_struct() -> i32
  let r: Rect = Rect {
    origin: Point { x: 0, y: 0 },
    width: 100,
    height: 50
  }
  assert r.origin.x == 0
  assert r.origin.y == 0
  assert r.width == 100
  assert r.height == 50
  0

[[test]]
fn test_nested_struct_modify() -> i32
  var r: Rect = Rect {
    origin: Point { x: 0, y: 0 },
    width: 10,
    height: 20
  }
  r.origin.x = 5
  r.origin.y = 10
  assert r.origin.x == 5
  assert r.origin.y == 10
  0

[[test]]
fn test_struct_function_pass() -> i32
  let a: Point = Point { x: 1, y: 2 }
  let b: Point = Point { x: 3, y: 4 }
  let c: Point = point_add(a, b)
  assert c.x == 4
  assert c.y == 6
  0

[[test]]
fn test_struct_function_return() -> i32
  let p1: Point = Point { x: 0, y: 0 }
  let p2: Point = Point { x: 3, y: 4 }
  let dist_sq: i32 = point_distance_squared(p1, p2)
  assert dist_sq == 25  # 3*3 + 4*4
  0

[[test]]
fn test_rect_area() -> i32
  let r: Rect = Rect {
    origin: Point { x: 0, y: 0 },
    width: 10,
    height: 5
  }
  assert rect_area(r) == 50
  0

[[test]]
fn test_vector_dot() -> i32
  let a: Vector3 = Vector3 { x: 1, y: 2, z: 3 }
  let b: Vector3 = Vector3 { x: 4, y: 5, z: 6 }
  let dot: i32 = vector_dot(a, b)
  assert dot == 32  # 1*4 + 2*5 + 3*6 = 4 + 10 + 18
  0

[[test]]
fn test_vector_length_squared() -> i32
  let v: Vector3 = Vector3 { x: 3, y: 4, z: 0 }
  assert vector_length_squared(v) == 25
  0

[[test]]
fn test_struct_with_array() -> i32
  var buf: Buffer = Buffer {
    data: [1, 2, 3, 4, 5, 0, 0, 0],
    len: 5
  }
  assert buf.data[0] == 1
  assert buf.data[4] == 5
  assert buf.len == 5
  0

[[test]]
fn test_struct_array_modify() -> i32
  var buf: Buffer = Buffer {
    data: [0; 8],
    len: 3
  }
  buf.data[0] = 10
  buf.data[1] = 20
  buf.data[2] = 30
  assert buffer_sum(@buf) == 60
  0

[[test]]
fn test_struct_pointer_chain() -> i32
  var n1: Node = Node { value: 1, next: null }
  var n2: Node = Node { value: 2, next: @n1 }
  var n3: Node = Node { value: 3, next: @n2 }

  assert n3.value == 3
  assert (*n3.next).value == 2
  assert (*(*n3.next).next).value == 1
  0

[[test]]
fn test_struct_in_array() -> i32
  # Initialize array of structs one by one
  var points: [3]Point = [Point { x: 0, y: 0 }, Point { x: 1, y: 1 }, Point { x: 2, y: 2 }]
  assert points[0].x == 0
  assert points[1].x == 1
  assert points[2].x == 2
  points[1].y = 100
  assert points[1].y == 100
  0
