# Test for Issue #98: Struct array member comparison always returns false
#
# Bug: Direct comparison of struct array members (s.data[0] == 222) always
# returns false, even when values are equal.
#
# Run with: python3 ritz0/ritz0.py --test ritz0/test/test_issue98.ritz

struct TestStruct
    data: [16]u8
    len: u64

struct IntArrayStruct
    values: [8]i32
    count: i64

# ===== Issue #98 Test Cases =====

[[test]]
fn test_struct_u8_array_cmp_literal() -> i32
    # This is the exact case from the bug report
    var s: TestStruct
    s.data[0] = 222  # 0xde

    # This comparison should return true but returns false!
    if s.data[0] == 222
        return 0  # Expected path

    return 1  # Bug: always reaches here

[[test]]
fn test_struct_u8_array_cmp_var() -> i32
    var s: TestStruct
    s.data[0] = 100
    let expected: u8 = 100

    if s.data[0] == expected
        return 0  # Expected path

    return 1  # Bug path

[[test]]
fn test_struct_i32_array_cmp() -> i32
    var s: IntArrayStruct
    s.values[0] = 42

    if s.values[0] == 42
        return 0  # Expected path

    return 1  # Bug path

[[test]]
fn test_struct_array_cmp_multiple_indices() -> i32
    var s: TestStruct
    s.data[0] = 10
    s.data[1] = 20
    s.data[2] = 30

    # All three should match
    if s.data[0] != 10
        return 1
    if s.data[1] != 20
        return 2
    if s.data[2] != 30
        return 3

    0

[[test]]
fn test_struct_array_cmp_via_intermediate() -> i32
    # This is the documented workaround - should pass
    var s: TestStruct
    s.data[0] = 222

    let first_byte: u8 = s.data[0]
    if first_byte == 222
        return 0  # This works

    return 1

[[test]]
fn test_struct_array_cmp_in_assert() -> i32
    var s: IntArrayStruct
    s.values[0] = 999

    # Assert form should also work
    assert s.values[0] == 999

    0
