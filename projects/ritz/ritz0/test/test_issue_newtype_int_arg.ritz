# Regression: scalar ints should coerce into single-field struct params (newtype wrappers).

struct Tag
    value: u32

impl Tag
    fn eq(self, other: Tag) -> bool
        self.value == other.value

const TAG_HEAD: u32 = 0x68656164

[[test]]
fn test_newtype_int_method_arg() -> i32
    let tag = Tag { value: TAG_HEAD }
    if tag.eq(TAG_HEAD)
        0
    else
        1
