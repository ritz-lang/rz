enum Shade
    Light
    Dark

fn is_dark(s: Shade) -> bool
    match s
        Light => false
        Dark => true

[[test]]
fn test_qualified_enum_variant_value() -> i32
    let a = Shade.Light
    let b = Shade.Dark

    assert not is_dark(a)
    assert is_dark(b)
    assert is_dark(Shade.Dark)
    0
