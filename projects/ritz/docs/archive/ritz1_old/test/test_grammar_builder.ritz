# Grammar Builder Tests
#
# Tests for the full grammar -> lexer pipeline.
# Requires: tokens, nfa, regex, lexer, grammar_parser, grammar_builder

# ============================================================================
# Full Grammar Build Tests
# ============================================================================

# Test: Build lexer from simple grammar
@test
fn test_build_from_grammar() -> i32
  let storage: *i8 = __builtin_alloca(65536)
  let states: *NFAState = storage
  let trans: *Transition = storage + 8192
  let patterns: *TokenPattern = storage + 24576

  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  var lex: Lexer = Lexer { src: "", len: 0, pos: 0, line: 1, col: 1, nfa: &nfa, patterns: patterns, pattern_count: 0 , indent_stack: [0; 64], indent_depth: 1, at_line_start: 1, pending_dedents: 0, bracket_depth: 0 }

  let grammar: *i8 = "PLUS = \"+\"\nINT = /[0-9]+/\n@skip WS = /[ ]+/"
  let count: i32 = grammar_build_lexer(&lex, grammar, 43)

  assert count == 3
  0

# Test: Build lexer and tokenize
@test
fn test_build_and_tokenize() -> i32
  let storage: *i8 = __builtin_alloca(65536)
  let states: *NFAState = storage
  let trans: *Transition = storage + 8192
  let patterns: *TokenPattern = storage + 24576

  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  var lex: Lexer = Lexer { src: "42 + 7", len: 6, pos: 0, line: 1, col: 1, nfa: &nfa, patterns: patterns, pattern_count: 0 , indent_stack: [0; 64], indent_depth: 1, at_line_start: 1, pending_dedents: 0, bracket_depth: 0 }

  let grammar: *i8 = "PLUS = \"+\"\nINT = /[0-9]+/\n@skip WS = /[ ]+/"
  let count: i32 = grammar_build_lexer(&lex, grammar, 43)

  lex.pos = 0

  let t1: Token = lexer_next(&lex)
  assert t1.type == TOK_INT
  assert t1.len == 2

  let t2: Token = lexer_next(&lex)
  assert t2.type == TOK_PLUS
  assert t2.len == 1

  let t3: Token = lexer_next(&lex)
  assert t3.type == TOK_INT
  assert t3.len == 1

  0

# Test: Priority ordering (high priority tokens first)
@test
fn test_priority_ordering() -> i32
  let storage: *i8 = __builtin_alloca(65536)
  let states: *NFAState = storage
  let trans: *Transition = storage + 8192
  let patterns: *TokenPattern = storage + 24576

  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  var lex: Lexer = Lexer { src: "==", len: 2, pos: 0, line: 1, col: 1, nfa: &nfa, patterns: patterns, pattern_count: 0 , indent_stack: [0; 64], indent_depth: 1, at_line_start: 1, pending_dedents: 0, bracket_depth: 0 }

  let grammar: *i8 = "EQ = \"=\"\nEQEQ.10 = \"==\""
  let count: i32 = grammar_build_lexer(&lex, grammar, 23)

  lex.pos = 0
  let t1: Token = lexer_next(&lex)
  assert t1.type == TOK_EQEQ
  assert t1.len == 2

  0
