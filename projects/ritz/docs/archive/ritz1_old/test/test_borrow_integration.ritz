@test
fn test_deref_type_correct() -> i32
  # Check that *r has type T when r has type &T

  let arena: *Arena = arena_new(4096)
  let src: *i8 = arena_alloc(arena, 8) as *i8
  *(src + 0) = 114 as i8  # 'r'

  let fc: *FullChecker = full_checker_new(arena, src)

  # Declare r: &i32
  let ty_i32: *Type = type_new(arena, TY_I32)
  let ty_ref: *Type = type_new(arena, TY_REF)
  ty_ref.inner = ty_i32
  fc_declare_var(fc, src, 1, ty_ref, 0)

  # Create *r expression
  let e_r: *Expr = arena_alloc(arena, 32) as *Expr
  e_r.kind = EXPR_IDENT
  e_r.val1 = 0
  e_r.val2 = 1

  let e_deref: *Expr = arena_alloc(arena, 32) as *Expr
  e_deref.kind = EXPR_UNARY_OP
  e_deref.val1 = OP_DEREF
  e_deref.left = e_r as *i32

  # Check type
  let deref_ty: *Type = fc_check_expr(fc, e_deref, 1)
  assert deref_ty.kind == TY_I32
  0
