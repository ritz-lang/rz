# ritz1/test/test_borrow_integration.ritz - Borrow checker + Type checker integration
#
# Tests that borrow checking is properly integrated with type checking.
# Uses TDD: write failing test, then implement.

# =============================================================================
# Constants
# =============================================================================

# Type kinds
const TY_VOID: i32 = 0
const TY_BOOL: i32 = 1
const TY_I32: i32 = 4
const TY_I64: i32 = 5
const TY_PTR: i32 = 10
const TY_REF: i32 = 11
const TY_REF_MUT: i32 = 12
const TY_STRUCT: i32 = 20
const TY_ERROR: i32 = 99

# Symbol kinds
const SYM_VAR: i32 = 1

# Expression kinds
const EXPR_INT_LIT: i32 = 1
const EXPR_IDENT: i32 = 2
const EXPR_UNARY_OP: i32 = 6
const EXPR_FIELD: i32 = 9

# Statement kinds
const STMT_LET: i32 = 22
const STMT_VAR: i32 = 21
const STMT_ASSIGN: i32 = 30
const STMT_BLOCK: i32 = 27

# Unary operators
const OP_REF: i32 = 1       # &
const OP_REF_MUT: i32 = 2   # &mut
const OP_DEREF: i32 = 3     # *
const OP_MOVE: i32 = 4      # (implicit move)

# Place kinds
const PLACE_VAR: i32 = 1
const PLACE_FIELD: i32 = 2

# Loan kinds
const LOAN_SHARED: i32 = 1
const LOAN_MUT: i32 = 2

# Borrow error kinds
const ERR_USE_AFTER_MOVE: i32 = 1
const ERR_MOVE_WHILE_BORROWED: i32 = 2
const ERR_MUT_WHILE_SHARED: i32 = 3
const ERR_DOUBLE_MUT_BORROW: i32 = 4
const ERR_ASSIGN_WHILE_BORROWED: i32 = 5

# =============================================================================
# Structures
# =============================================================================

struct Arena
  base: *i8
  size: i64
  used: i64

struct Type
  kind: i32
  is_mut: i32
  size: i32
  inner: *Type
  name: *i8
  name_len: i32
  fields: *Field
  params: *TypeList
  ret: *Type
  next: *Type

struct TypeList
  ty: *Type
  next: *TypeList

struct Field
  name: *i8
  name_len: i32
  ty: *Type
  offset: i32
  next: *Field

struct Symbol
  name: *i8
  name_len: i32
  kind: i32
  ty: *Type
  is_mut: i32
  next: *Symbol

struct Scope
  symbols: *Symbol
  parent: *Scope
  depth: i32

struct Expr
  kind: i32
  val1: i32
  val2: i32
  left: *i32
  right: *i32
  next: *i32

struct Stmt
  kind: i32
  name: *i8
  name_len: i32
  type_expr: *i32
  expr: *i32
  stmt: *i32
  next: *i32

struct Place
  kind: i32
  base: *Place
  var_name: *i8
  var_name_len: i32
  field_idx: i32
  depth: i32
  next: *Place

struct Loan
  place: *Place
  kind: i32
  scope_depth: i32
  expr_id: i32
  next: *Loan

struct MoveInfo
  place: *Place
  state: i32
  move_expr_id: i32
  next: *MoveInfo

struct BorrowError
  kind: i32
  place: *Place
  expr_id: i32
  loan: *Loan
  next: *BorrowError

struct BorrowChecker
  loans: *Loan
  moves: *MoveInfo
  errors: *BorrowError
  error_count: i32
  scope_depth: i32
  arena: *Arena
  src: *i8

# Combined checker that does both type checking and borrow checking
struct FullChecker
  # Type checker state
  global: *Scope
  current: *Scope
  type_errors: i32
  src: *i8
  arena: *Arena
  # Borrow checker state
  bc: *BorrowChecker

# =============================================================================
# Arena (from mem.ritz)
# =============================================================================

const SYS_MMAP: i64 = 9
const PROT_RW: i64 = 3
const MAP_PRIVATE_ANON: i64 = 34

fn mmap(addr: i64, length: i64, prot: i64, flags: i64, fd: i64, offset: i64) -> *i8
  syscall6(SYS_MMAP, addr, length, prot, flags, fd, offset) as *i8

fn arena_new(capacity: i64) -> *Arena
  let header_size: i64 = 24
  let total: i64 = header_size + capacity
  let mem: *i8 = mmap(0, total, PROT_RW, MAP_PRIVATE_ANON, -1, 0)
  if mem as i64 < 0
    return 0 as *Arena
  let arena: *Arena = mem as *Arena
  arena.base = mem + header_size
  arena.size = capacity
  arena.used = 0
  arena

fn arena_alloc(arena: *Arena, size: i64) -> *i8
  let aligned: i64 = (size + 7) & -8
  if arena.used + aligned > arena.size
    return 0 as *i8
  let ptr: *i8 = arena.base + arena.used
  arena.used = arena.used + aligned
  ptr

# =============================================================================
# Helper Functions
# =============================================================================

fn names_equal(a: *i8, a_len: i32, b: *i8, b_len: i32) -> i32
  if a_len != b_len
    return 0
  var i: i32 = 0
  while i < a_len
    if *(a + i) != *(b + i)
      return 0
    i = i + 1
  1

# =============================================================================
# Borrow Checker Functions (from borrow.ritz)
# =============================================================================

fn borrow_checker_new(arena: *Arena, src: *i8) -> *BorrowChecker
  let bc: *BorrowChecker = arena_alloc(arena, 64) as *BorrowChecker
  bc.loans = 0 as *Loan
  bc.moves = 0 as *MoveInfo
  bc.errors = 0 as *BorrowError
  bc.error_count = 0
  bc.scope_depth = 0
  bc.arena = arena
  bc.src = src
  bc

fn place_var(bc: *BorrowChecker, name: *i8, name_len: i32) -> *Place
  let p: *Place = arena_alloc(bc.arena, 48) as *Place
  p.kind = PLACE_VAR
  p.base = 0 as *Place
  p.var_name = name
  p.var_name_len = name_len
  p.field_idx = 0
  p.depth = 0
  p.next = 0 as *Place
  p

fn place_field(bc: *BorrowChecker, base: *Place, field_idx: i32) -> *Place
  let p: *Place = arena_alloc(bc.arena, 48) as *Place
  p.kind = PLACE_FIELD
  p.base = base
  p.var_name = 0 as *i8
  p.var_name_len = 0
  p.field_idx = field_idx
  p.depth = base.depth + 1
  p.next = 0 as *Place
  p

fn place_eq(a: *Place, b: *Place) -> i32
  if a == 0 as *Place
    if b == 0 as *Place
      return 1
    return 0
  if b == 0 as *Place
    return 0
  if a.kind != b.kind
    return 0
  if a.kind == PLACE_VAR
    return names_equal(a.var_name, a.var_name_len, b.var_name, b.var_name_len)
  if a.kind == PLACE_FIELD
    if a.field_idx != b.field_idx
      return 0
    return place_eq(a.base, b.base)
  0

fn place_is_prefix(a: *Place, b: *Place) -> i32
  if place_eq(a, b) == 1
    return 1
  var current: *Place = b.base
  while current != 0 as *Place
    if place_eq(a, current) == 1
      return 1
    current = current.base
  0

fn place_conflicts(a: *Place, b: *Place) -> i32
  if place_is_prefix(a, b) == 1
    return 1
  if place_is_prefix(b, a) == 1
    return 1
  0

fn add_loan(bc: *BorrowChecker, place: *Place, kind: i32, expr_id: i32) -> *Loan
  let loan: *Loan = arena_alloc(bc.arena, 32) as *Loan
  loan.place = place
  loan.kind = kind
  loan.scope_depth = bc.scope_depth
  loan.expr_id = expr_id
  loan.next = bc.loans
  bc.loans = loan
  loan

fn has_any_loan(bc: *BorrowChecker, place: *Place) -> *Loan
  var loan: *Loan = bc.loans
  while loan != 0 as *Loan
    if place_conflicts(loan.place, place) == 1
      return loan
    loan = loan.next
  0 as *Loan

fn has_mut_loan(bc: *BorrowChecker, place: *Place) -> *Loan
  var loan: *Loan = bc.loans
  while loan != 0 as *Loan
    if loan.kind == LOAN_MUT
      if place_conflicts(loan.place, place) == 1
        return loan
    loan = loan.next
  0 as *Loan

fn get_move_info(bc: *BorrowChecker, place: *Place) -> *MoveInfo
  var info: *MoveInfo = bc.moves
  while info != 0 as *MoveInfo
    if place_eq(info.place, place) == 1
      return info
    info = info.next
  0 as *MoveInfo

const MOVE_OWNED: i32 = 0
const MOVE_MOVED: i32 = 1

fn set_move_state(bc: *BorrowChecker, place: *Place, state: i32, expr_id: i32) -> *MoveInfo
  var info: *MoveInfo = get_move_info(bc, place)
  if info != 0 as *MoveInfo
    info.state = state
    info.move_expr_id = expr_id
    return info
  info = arena_alloc(bc.arena, 24) as *MoveInfo
  info.place = place
  info.state = state
  info.move_expr_id = expr_id
  info.next = bc.moves
  bc.moves = info
  info

fn is_moved(bc: *BorrowChecker, place: *Place) -> i32
  let info: *MoveInfo = get_move_info(bc, place)
  if info == 0 as *MoveInfo
    return 0
  if info.state == MOVE_MOVED
    return 1
  0

fn mark_moved(bc: *BorrowChecker, place: *Place, expr_id: i32) -> i32
  set_move_state(bc, place, MOVE_MOVED, expr_id)
  0

fn mark_owned(bc: *BorrowChecker, place: *Place) -> i32
  set_move_state(bc, place, MOVE_OWNED, 0)
  0

fn add_error(bc: *BorrowChecker, kind: i32, place: *Place, expr_id: i32, loan: *Loan) -> *BorrowError
  let err: *BorrowError = arena_alloc(bc.arena, 32) as *BorrowError
  err.kind = kind
  err.place = place
  err.expr_id = expr_id
  err.loan = loan
  err.next = bc.errors
  bc.errors = err
  bc.error_count = bc.error_count + 1
  err

fn bc_push_scope(bc: *BorrowChecker) -> i32
  bc.scope_depth = bc.scope_depth + 1
  0

fn expire_loans(bc: *BorrowChecker, min_depth: i32) -> i32
  var prev: *Loan = 0 as *Loan
  var current: *Loan = bc.loans
  while current != 0 as *Loan
    let next: *Loan = current.next
    if current.scope_depth >= min_depth
      if prev == 0 as *Loan
        bc.loans = next
      else
        prev.next = next
    else
      prev = current
    current = next
  0

fn bc_pop_scope(bc: *BorrowChecker) -> i32
  expire_loans(bc, bc.scope_depth)
  bc.scope_depth = bc.scope_depth - 1
  0

fn check_use(bc: *BorrowChecker, place: *Place, expr_id: i32) -> i32
  if is_moved(bc, place) == 1
    add_error(bc, ERR_USE_AFTER_MOVE, place, expr_id, 0 as *Loan)
    return 1
  0

fn check_move(bc: *BorrowChecker, place: *Place, expr_id: i32) -> i32
  if is_moved(bc, place) == 1
    add_error(bc, ERR_USE_AFTER_MOVE, place, expr_id, 0 as *Loan)
    return 1
  let loan: *Loan = has_any_loan(bc, place)
  if loan != 0 as *Loan
    add_error(bc, ERR_MOVE_WHILE_BORROWED, place, expr_id, loan)
    return 1
  mark_moved(bc, place, expr_id)
  0

fn check_shared_borrow(bc: *BorrowChecker, place: *Place, expr_id: i32) -> i32
  if is_moved(bc, place) == 1
    add_error(bc, ERR_USE_AFTER_MOVE, place, expr_id, 0 as *Loan)
    return 1
  let mut_loan: *Loan = has_mut_loan(bc, place)
  if mut_loan != 0 as *Loan
    add_error(bc, ERR_MUT_WHILE_SHARED, place, expr_id, mut_loan)
    return 1
  add_loan(bc, place, LOAN_SHARED, expr_id)
  0

fn check_mut_borrow(bc: *BorrowChecker, place: *Place, expr_id: i32) -> i32
  if is_moved(bc, place) == 1
    add_error(bc, ERR_USE_AFTER_MOVE, place, expr_id, 0 as *Loan)
    return 1
  let any_loan: *Loan = has_any_loan(bc, place)
  if any_loan != 0 as *Loan
    if any_loan.kind == LOAN_MUT
      add_error(bc, ERR_DOUBLE_MUT_BORROW, place, expr_id, any_loan)
    else
      add_error(bc, ERR_MUT_WHILE_SHARED, place, expr_id, any_loan)
    return 1
  add_loan(bc, place, LOAN_MUT, expr_id)
  0

fn check_assign(bc: *BorrowChecker, place: *Place, expr_id: i32) -> i32
  let loan: *Loan = has_any_loan(bc, place)
  if loan != 0 as *Loan
    add_error(bc, ERR_ASSIGN_WHILE_BORROWED, place, expr_id, loan)
    return 1
  mark_owned(bc, place)
  0

# =============================================================================
# Type Checker Functions (simplified)
# =============================================================================

fn type_new(arena: *Arena, kind: i32) -> *Type
  let ty: *Type = arena_alloc(arena, 96) as *Type
  ty.kind = kind
  ty.is_mut = 0
  ty.size = 0
  ty.inner = 0 as *Type
  ty.name = 0 as *i8
  ty.name_len = 0
  ty.fields = 0 as *Field
  ty.params = 0 as *TypeList
  ty.ret = 0 as *Type
  ty.next = 0 as *Type
  ty

fn scope_lookup(s: *Scope, name: *i8, name_len: i32) -> *Symbol
  var current: *Scope = s
  while current != 0 as *Scope
    var sym: *Symbol = current.symbols
    while sym != 0 as *Symbol
      if names_equal(sym.name, sym.name_len, name, name_len) == 1
        return sym
      sym = sym.next
    current = current.parent
  0 as *Symbol

fn scope_insert(s: *Scope, sym: *Symbol) -> *Symbol
  sym.next = s.symbols
  s.symbols = sym
  sym

# =============================================================================
# FullChecker - Combined Type + Borrow Checking
# =============================================================================

fn full_checker_new(arena: *Arena, src: *i8) -> *FullChecker
  let fc: *FullChecker = arena_alloc(arena, 48) as *FullChecker

  # Initialize type checker state
  let global: *Scope = arena_alloc(arena, 24) as *Scope
  global.symbols = 0 as *Symbol
  global.parent = 0 as *Scope
  global.depth = 0

  fc.global = global
  fc.current = global
  fc.type_errors = 0
  fc.src = src
  fc.arena = arena

  # Initialize borrow checker
  fc.bc = borrow_checker_new(arena, src)

  fc

fn fc_push_scope(fc: *FullChecker) -> i32
  # Push type checker scope
  let s: *Scope = arena_alloc(fc.arena, 24) as *Scope
  s.symbols = 0 as *Symbol
  s.parent = fc.current
  s.depth = fc.current.depth + 1
  fc.current = s

  # Push borrow checker scope
  bc_push_scope(fc.bc)
  0

fn fc_pop_scope(fc: *FullChecker) -> i32
  # Pop type checker scope
  if fc.current != fc.global
    fc.current = fc.current.parent

  # Pop borrow checker scope (expires loans)
  bc_pop_scope(fc.bc)
  0

# Get or create a Place for an identifier expression
fn expr_to_place(fc: *FullChecker, e: *Expr) -> *Place
  if e.kind == EXPR_IDENT
    let name: *i8 = fc.src + e.val1
    let name_len: i32 = e.val2
    return place_var(fc.bc, name, name_len)

  if e.kind == EXPR_FIELD
    let base_place: *Place = expr_to_place(fc, e.left as *Expr)
    if base_place == 0 as *Place
      return 0 as *Place
    return place_field(fc.bc, base_place, e.val1)

  0 as *Place

# Check an expression, returning its type and tracking borrows
fn fc_check_expr(fc: *FullChecker, e: *Expr, expr_id: i32) -> *Type
  if e == 0 as *Expr
    return type_new(fc.arena, TY_ERROR)

  let kind: i32 = e.kind

  # Integer literal - no borrow implications
  if kind == EXPR_INT_LIT
    return type_new(fc.arena, TY_I32)

  # Identifier - check for use-after-move
  if kind == EXPR_IDENT
    let name: *i8 = fc.src + e.val1
    let name_len: i32 = e.val2
    let sym: *Symbol = scope_lookup(fc.current, name, name_len)
    if sym == 0 as *Symbol
      fc.type_errors = fc.type_errors + 1
      return type_new(fc.arena, TY_ERROR)

    # Check if this place has been moved
    let place: *Place = place_var(fc.bc, name, name_len)
    check_use(fc.bc, place, expr_id)

    return sym.ty

  # Unary operator - handle &, &mut, *
  if kind == EXPR_UNARY_OP
    let op: i32 = e.val1
    let operand: *Expr = e.left as *Expr
    let operand_ty: *Type = fc_check_expr(fc, operand, expr_id)

    # Shared borrow: &x
    if op == OP_REF
      let place: *Place = expr_to_place(fc, operand)
      if place != 0 as *Place
        check_shared_borrow(fc.bc, place, expr_id)
      let ref_ty: *Type = type_new(fc.arena, TY_REF)
      ref_ty.inner = operand_ty
      return ref_ty

    # Mutable borrow: &mut x
    if op == OP_REF_MUT
      let place: *Place = expr_to_place(fc, operand)
      if place != 0 as *Place
        check_mut_borrow(fc.bc, place, expr_id)
      let ref_ty: *Type = type_new(fc.arena, TY_REF_MUT)
      ref_ty.inner = operand_ty
      return ref_ty

    # Dereference: *x
    if op == OP_DEREF
      if operand_ty.kind == TY_PTR
        return operand_ty.inner
      if operand_ty.kind == TY_REF
        return operand_ty.inner
      if operand_ty.kind == TY_REF_MUT
        return operand_ty.inner
      fc.type_errors = fc.type_errors + 1
      return type_new(fc.arena, TY_ERROR)

    return operand_ty

  # Field access - check base, then field
  if kind == EXPR_FIELD
    let base_ty: *Type = fc_check_expr(fc, e.left as *Expr, expr_id)
    # For now just return i32 as placeholder
    return type_new(fc.arena, TY_I32)

  type_new(fc.arena, TY_ERROR)

# Declare a variable (let/var)
fn fc_declare_var(fc: *FullChecker, name: *i8, name_len: i32, ty: *Type, is_mut: i32) -> *Symbol
  let sym: *Symbol = arena_alloc(fc.arena, 40) as *Symbol
  sym.name = name
  sym.name_len = name_len
  sym.kind = SYM_VAR
  sym.ty = ty
  sym.is_mut = is_mut
  sym.next = 0 as *Symbol
  scope_insert(fc.current, sym)

  # Mark as owned in borrow checker
  let place: *Place = place_var(fc.bc, name, name_len)
  mark_owned(fc.bc, place)

  sym

# Check an assignment statement
fn fc_check_assign(fc: *FullChecker, target: *Expr, value: *Expr, expr_id: i32) -> i32
  # Type check the value
  let val_ty: *Type = fc_check_expr(fc, value, expr_id)

  # Get the place being assigned to
  let place: *Place = expr_to_place(fc, target)
  if place == 0 as *Place
    fc.type_errors = fc.type_errors + 1
    return 1

  # Check assignment is allowed (no borrows)
  check_assign(fc.bc, place, expr_id)
  0

# =============================================================================
# Tests
# =============================================================================

@test
fn test_use_after_move_detected() -> i32
  # Scenario:
  #   let x: i32 = 42
  #   move x  (simulated)
  #   use x   <- error!

  let arena: *Arena = arena_new(4096)
  let src: *i8 = arena_alloc(arena, 8) as *i8
  *(src + 0) = 120 as i8  # 'x'

  let fc: *FullChecker = full_checker_new(arena, src)

  # Declare x
  let ty_i32: *Type = type_new(arena, TY_I32)
  fc_declare_var(fc, src, 1, ty_i32, 0)

  # Create expression for 'x'
  let e_x: *Expr = arena_alloc(arena, 32) as *Expr
  e_x.kind = EXPR_IDENT
  e_x.val1 = 0   # position of 'x'
  e_x.val2 = 1   # length

  # First use is ok
  fc_check_expr(fc, e_x, 1)
  assert fc.bc.error_count == 0

  # Simulate a move
  let place_x: *Place = place_var(fc.bc, src, 1)
  check_move(fc.bc, place_x, 2)
  assert fc.bc.error_count == 0

  # Second use should error
  fc_check_expr(fc, e_x, 3)
  assert fc.bc.error_count == 1
  assert fc.bc.errors.kind == ERR_USE_AFTER_MOVE
  0

@test
fn test_shared_borrow_ok() -> i32
  # Scenario:
  #   let x: i32 = 42
  #   let r1 = &x  <- ok
  #   let r2 = &x  <- ok (multiple shared borrows)

  let arena: *Arena = arena_new(4096)
  let src: *i8 = arena_alloc(arena, 8) as *i8
  *(src + 0) = 120 as i8  # 'x'

  let fc: *FullChecker = full_checker_new(arena, src)

  # Declare x
  let ty_i32: *Type = type_new(arena, TY_I32)
  fc_declare_var(fc, src, 1, ty_i32, 0)

  # Create &x expression
  let e_x: *Expr = arena_alloc(arena, 32) as *Expr
  e_x.kind = EXPR_IDENT
  e_x.val1 = 0
  e_x.val2 = 1

  let e_ref: *Expr = arena_alloc(arena, 32) as *Expr
  e_ref.kind = EXPR_UNARY_OP
  e_ref.val1 = OP_REF
  e_ref.left = e_x as *i32

  # First shared borrow
  let ty1: *Type = fc_check_expr(fc, e_ref, 1)
  assert ty1.kind == TY_REF
  assert fc.bc.error_count == 0

  # Second shared borrow - also ok
  let ty2: *Type = fc_check_expr(fc, e_ref, 2)
  assert ty2.kind == TY_REF
  assert fc.bc.error_count == 0
  0

@test
fn test_mut_borrow_conflicts_with_shared() -> i32
  # Scenario:
  #   let x: i32 = 42
  #   let r = &x     <- ok
  #   let m = &mut x <- error!

  let arena: *Arena = arena_new(4096)
  let src: *i8 = arena_alloc(arena, 8) as *i8
  *(src + 0) = 120 as i8  # 'x'

  let fc: *FullChecker = full_checker_new(arena, src)

  # Declare x
  let ty_i32: *Type = type_new(arena, TY_I32)
  fc_declare_var(fc, src, 1, ty_i32, 0)

  # Create expressions
  let e_x: *Expr = arena_alloc(arena, 32) as *Expr
  e_x.kind = EXPR_IDENT
  e_x.val1 = 0
  e_x.val2 = 1

  let e_ref: *Expr = arena_alloc(arena, 32) as *Expr
  e_ref.kind = EXPR_UNARY_OP
  e_ref.val1 = OP_REF
  e_ref.left = e_x as *i32

  let e_mut_ref: *Expr = arena_alloc(arena, 32) as *Expr
  e_mut_ref.kind = EXPR_UNARY_OP
  e_mut_ref.val1 = OP_REF_MUT
  e_mut_ref.left = e_x as *i32

  # Shared borrow first
  fc_check_expr(fc, e_ref, 1)
  assert fc.bc.error_count == 0

  # Mutable borrow should conflict
  fc_check_expr(fc, e_mut_ref, 2)
  assert fc.bc.error_count == 1
  0

@test
fn test_double_mut_borrow_error() -> i32
  # Scenario:
  #   let x: i32 = 42
  #   let m1 = &mut x <- ok
  #   let m2 = &mut x <- error!

  let arena: *Arena = arena_new(4096)
  let src: *i8 = arena_alloc(arena, 8) as *i8
  *(src + 0) = 120 as i8  # 'x'

  let fc: *FullChecker = full_checker_new(arena, src)

  # Declare x
  let ty_i32: *Type = type_new(arena, TY_I32)
  fc_declare_var(fc, src, 1, ty_i32, 0)

  # Create &mut x expression
  let e_x: *Expr = arena_alloc(arena, 32) as *Expr
  e_x.kind = EXPR_IDENT
  e_x.val1 = 0
  e_x.val2 = 1

  let e_mut_ref: *Expr = arena_alloc(arena, 32) as *Expr
  e_mut_ref.kind = EXPR_UNARY_OP
  e_mut_ref.val1 = OP_REF_MUT
  e_mut_ref.left = e_x as *i32

  # First mut borrow ok
  fc_check_expr(fc, e_mut_ref, 1)
  assert fc.bc.error_count == 0

  # Second mut borrow error
  fc_check_expr(fc, e_mut_ref, 2)
  assert fc.bc.error_count == 1
  assert fc.bc.errors.kind == ERR_DOUBLE_MUT_BORROW
  0

@test
fn test_borrow_expires_at_scope_end() -> i32
  # Scenario:
  #   let x: i32 = 42
  #   {
  #     let r = &mut x  <- ok
  #   }                 <- borrow expires
  #   let m = &mut x    <- ok now!

  let arena: *Arena = arena_new(4096)
  let src: *i8 = arena_alloc(arena, 8) as *i8
  *(src + 0) = 120 as i8  # 'x'

  let fc: *FullChecker = full_checker_new(arena, src)

  # Declare x
  let ty_i32: *Type = type_new(arena, TY_I32)
  fc_declare_var(fc, src, 1, ty_i32, 0)

  # Create &mut x expression
  let e_x: *Expr = arena_alloc(arena, 32) as *Expr
  e_x.kind = EXPR_IDENT
  e_x.val1 = 0
  e_x.val2 = 1

  let e_mut_ref: *Expr = arena_alloc(arena, 32) as *Expr
  e_mut_ref.kind = EXPR_UNARY_OP
  e_mut_ref.val1 = OP_REF_MUT
  e_mut_ref.left = e_x as *i32

  # Enter inner scope
  fc_push_scope(fc)

  # Mut borrow in inner scope
  fc_check_expr(fc, e_mut_ref, 1)
  assert fc.bc.error_count == 0

  # Exit inner scope - borrow expires
  fc_pop_scope(fc)

  # Mut borrow again - should be ok now
  fc_check_expr(fc, e_mut_ref, 2)
  assert fc.bc.error_count == 0
  0

@test
fn test_assign_while_borrowed_error() -> i32
  # Scenario:
  #   var x: i32 = 42
  #   let r = &x
  #   x = 10      <- error! can't assign while borrowed

  let arena: *Arena = arena_new(4096)
  let src: *i8 = arena_alloc(arena, 8) as *i8
  *(src + 0) = 120 as i8  # 'x'

  let fc: *FullChecker = full_checker_new(arena, src)

  # Declare x as mutable
  let ty_i32: *Type = type_new(arena, TY_I32)
  fc_declare_var(fc, src, 1, ty_i32, 1)  # is_mut = 1

  # Create expressions
  let e_x: *Expr = arena_alloc(arena, 32) as *Expr
  e_x.kind = EXPR_IDENT
  e_x.val1 = 0
  e_x.val2 = 1

  let e_ref: *Expr = arena_alloc(arena, 32) as *Expr
  e_ref.kind = EXPR_UNARY_OP
  e_ref.val1 = OP_REF
  e_ref.left = e_x as *i32

  let e_val: *Expr = arena_alloc(arena, 32) as *Expr
  e_val.kind = EXPR_INT_LIT
  e_val.val1 = 10

  # Borrow x
  fc_check_expr(fc, e_ref, 1)
  assert fc.bc.error_count == 0

  # Try to assign while borrowed
  fc_check_assign(fc, e_x, e_val, 2)
  assert fc.bc.error_count == 1
  assert fc.bc.errors.kind == ERR_ASSIGN_WHILE_BORROWED
  0

@test
fn test_move_while_borrowed_error() -> i32
  # Scenario:
  #   let x: i32 = 42
  #   let r = &x
  #   move x      <- error! can't move while borrowed

  let arena: *Arena = arena_new(4096)
  let src: *i8 = arena_alloc(arena, 8) as *i8
  *(src + 0) = 120 as i8  # 'x'

  let fc: *FullChecker = full_checker_new(arena, src)

  # Declare x
  let ty_i32: *Type = type_new(arena, TY_I32)
  fc_declare_var(fc, src, 1, ty_i32, 0)

  # Create expressions
  let e_x: *Expr = arena_alloc(arena, 32) as *Expr
  e_x.kind = EXPR_IDENT
  e_x.val1 = 0
  e_x.val2 = 1

  let e_ref: *Expr = arena_alloc(arena, 32) as *Expr
  e_ref.kind = EXPR_UNARY_OP
  e_ref.val1 = OP_REF
  e_ref.left = e_x as *i32

  # Borrow x
  fc_check_expr(fc, e_ref, 1)
  assert fc.bc.error_count == 0

  # Try to move while borrowed
  let place_x: *Place = place_var(fc.bc, src, 1)
  check_move(fc.bc, place_x, 2)
  assert fc.bc.error_count == 1
  assert fc.bc.errors.kind == ERR_MOVE_WHILE_BORROWED
  0

@test
fn test_reassign_after_move_ok() -> i32
  # Scenario:
  #   var x: i32 = 42
  #   move x
  #   x = 10      <- ok, reinitializes x
  #   use x       <- ok

  let arena: *Arena = arena_new(4096)
  let src: *i8 = arena_alloc(arena, 8) as *i8
  *(src + 0) = 120 as i8  # 'x'

  let fc: *FullChecker = full_checker_new(arena, src)

  # Declare x as mutable
  let ty_i32: *Type = type_new(arena, TY_I32)
  fc_declare_var(fc, src, 1, ty_i32, 1)

  # Create expressions
  let e_x: *Expr = arena_alloc(arena, 32) as *Expr
  e_x.kind = EXPR_IDENT
  e_x.val1 = 0
  e_x.val2 = 1

  let e_val: *Expr = arena_alloc(arena, 32) as *Expr
  e_val.kind = EXPR_INT_LIT
  e_val.val1 = 10

  # Move x
  let place_x: *Place = place_var(fc.bc, src, 1)
  check_move(fc.bc, place_x, 1)
  assert fc.bc.error_count == 0

  # Reassign x
  fc_check_assign(fc, e_x, e_val, 2)
  assert fc.bc.error_count == 0

  # Use x should be ok now
  fc_check_expr(fc, e_x, 3)
  assert fc.bc.error_count == 0
  0

@test
fn test_ref_type_correct() -> i32
  # Check that &x has type &T when x has type T

  let arena: *Arena = arena_new(4096)
  let src: *i8 = arena_alloc(arena, 8) as *i8
  *(src + 0) = 120 as i8  # 'x'

  let fc: *FullChecker = full_checker_new(arena, src)

  # Declare x: i32
  let ty_i32: *Type = type_new(arena, TY_I32)
  fc_declare_var(fc, src, 1, ty_i32, 0)

  # Create &x expression
  let e_x: *Expr = arena_alloc(arena, 32) as *Expr
  e_x.kind = EXPR_IDENT
  e_x.val1 = 0
  e_x.val2 = 1

  let e_ref: *Expr = arena_alloc(arena, 32) as *Expr
  e_ref.kind = EXPR_UNARY_OP
  e_ref.val1 = OP_REF
  e_ref.left = e_x as *i32

  # Check type
  let ref_ty: *Type = fc_check_expr(fc, e_ref, 1)
  assert ref_ty.kind == TY_REF
  assert ref_ty.inner.kind == TY_I32
  0

@test
fn test_mut_ref_type_correct() -> i32
