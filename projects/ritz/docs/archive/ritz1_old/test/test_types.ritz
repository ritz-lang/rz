# ritz1/test/test_types.ritz - Type system tests
#
# Tests for type representation and operations.

# ============================================================================
# Type Kind Constants (copied from types.ritz)
# ============================================================================

const TY_VOID: i32 = 0
const TY_BOOL: i32 = 1
const TY_I8: i32 = 2
const TY_I16: i32 = 3
const TY_I32: i32 = 4
const TY_I64: i32 = 5
const TY_U8: i32 = 6
const TY_U16: i32 = 7
const TY_U32: i32 = 8
const TY_U64: i32 = 9
const TY_PTR: i32 = 10
const TY_REF: i32 = 11
const TY_REF_MUT: i32 = 12
const TY_ARRAY: i32 = 13
const TY_SLICE: i32 = 14
const TY_STRUCT: i32 = 20
const TY_ENUM: i32 = 21
const TY_FN: i32 = 30
const TY_ERROR: i32 = 99

# ============================================================================
# Type Structures (copied from types.ritz)
# ============================================================================

struct Field
  name: *i8
  name_len: i32
  ty: *Type
  offset: i32
  next: *Field

struct TypeList
  ty: *Type
  next: *TypeList

struct Type
  kind: i32
  is_mut: i32
  size: i32
  inner: *Type
  name: *i8
  name_len: i32
  fields: *Field
  params: *TypeList
  ret: *Type
  next: *Type

# ============================================================================
# Type Constructor (simplified from types.ritz)
# ============================================================================

fn type_new(kind: i32) -> *Type
  let ty: *Type = __builtin_alloca(128) as *Type
  (*ty).kind = kind
  (*ty).is_mut = 0
  (*ty).size = 0
  (*ty).inner = 0 as *Type
  (*ty).name = 0 as *i8
  (*ty).name_len = 0
  (*ty).fields = 0 as *Field
  (*ty).params = 0 as *TypeList
  (*ty).ret = 0 as *Type
  (*ty).next = 0 as *Type
  ty

# ============================================================================
# Tests
# ============================================================================

@test
fn test_type_kind_constants() -> i32
  # Verify type kind constants are distinct
  assert TY_VOID == 0
  assert TY_BOOL == 1
  assert TY_I32 == 4
  assert TY_I64 == 5
  assert TY_PTR == 10
  assert TY_STRUCT == 20
  assert TY_FN == 30
  0

@test
fn test_type_new_primitive() -> i32
  let ty: *Type = type_new(TY_I32)
  assert (*ty).kind == TY_I32
  assert (*ty).is_mut == 0
  assert (*ty).inner == 0 as *Type
  0

@test
fn test_type_ptr() -> i32
  # Create *i32 - inline allocs to avoid stack frame issues
  let inner: *Type = __builtin_alloca(128) as *Type
  (*inner).kind = TY_I32
  (*inner).is_mut = 0
  (*inner).inner = 0 as *Type

  let ptr: *Type = __builtin_alloca(128) as *Type
  (*ptr).kind = TY_PTR
  (*ptr).inner = inner
  (*ptr).is_mut = 0

  assert (*ptr).kind == TY_PTR
  assert (*ptr).inner == inner
  assert (*(*ptr).inner).kind == TY_I32
  0

@test
fn test_type_ptr_mut() -> i32
  # Create *mut i32
  let inner: *Type = type_new(TY_I32)
  let ptr: *Type = type_new(TY_PTR)
  (*ptr).inner = inner
  (*ptr).is_mut = 1

  assert (*ptr).kind == TY_PTR
  assert (*ptr).is_mut == 1
  0

@test
fn test_type_array() -> i32
  # Create [10]i32 - inline allocs
  let elem: *Type = __builtin_alloca(128) as *Type
  (*elem).kind = TY_I32

  let arr: *Type = __builtin_alloca(128) as *Type
  (*arr).kind = TY_ARRAY
  (*arr).inner = elem
  (*arr).size = 10

  assert (*arr).kind == TY_ARRAY
  assert (*arr).size == 10
  assert (*(*arr).inner).kind == TY_I32
  0

@test
fn test_type_slice() -> i32
  # Create [i32] - inline allocs
  let elem: *Type = __builtin_alloca(128) as *Type
  (*elem).kind = TY_I32

  let slice: *Type = __builtin_alloca(128) as *Type
  (*slice).kind = TY_SLICE
  (*slice).inner = elem

  assert (*slice).kind == TY_SLICE
  assert (*(*slice).inner).kind == TY_I32
  0

@test
fn test_type_struct() -> i32
  # Create a struct type
  let ty: *Type = type_new(TY_STRUCT)
  (*ty).name = 0 as *i8  # Would be pointer to "Point"
  (*ty).name_len = 5

  assert (*ty).kind == TY_STRUCT
  assert (*ty).name_len == 5
  0

@test
fn test_type_struct_with_fields() -> i32
  # Create struct Point { x: i32, y: i32 } - inline allocs
  let ty: *Type = __builtin_alloca(128) as *Type
  (*ty).kind = TY_STRUCT
  (*ty).name_len = 5

  let field_x: *Field = __builtin_alloca(64) as *Field
  let field_y: *Field = __builtin_alloca(64) as *Field
  let i32_type: *Type = __builtin_alloca(128) as *Type
  (*i32_type).kind = TY_I32

  (*field_x).name_len = 1
  (*field_x).ty = i32_type
  (*field_x).offset = 0
  (*field_x).next = field_y

  (*field_y).name_len = 1
  (*field_y).ty = i32_type
  (*field_y).offset = 4
  (*field_y).next = 0 as *Field

  (*ty).fields = field_x

  assert (*ty).kind == TY_STRUCT
  assert (*ty).fields == field_x
  assert (*(*ty).fields).offset == 0
  assert (*(*(*ty).fields).next).offset == 4
  0

@test
fn test_type_fn() -> i32
  # Create fn(i32, i32) -> i32
  let i32_type: *Type = type_new(TY_I32)

  let param1: *TypeList = __builtin_alloca(32) as *TypeList
  let param2: *TypeList = __builtin_alloca(32) as *TypeList
  (*param1).ty = i32_type
  (*param1).next = param2
  (*param2).ty = i32_type
  (*param2).next = 0 as *TypeList

  let fn_ty: *Type = type_new(TY_FN)
  (*fn_ty).params = param1
  (*fn_ty).ret = i32_type

  assert (*fn_ty).kind == TY_FN
  assert (*fn_ty).params == param1
  assert (*fn_ty).ret == i32_type
  assert (*(*fn_ty).params).ty == i32_type
  0

@test
fn test_type_nested_ptr() -> i32
  # Create **i32 - inline allocs
  let i32_ty: *Type = __builtin_alloca(128) as *Type
  (*i32_ty).kind = TY_I32

  let ptr1: *Type = __builtin_alloca(128) as *Type
  (*ptr1).kind = TY_PTR
  (*ptr1).inner = i32_ty

  let ptr2: *Type = __builtin_alloca(128) as *Type
  (*ptr2).kind = TY_PTR
  (*ptr2).inner = ptr1

  assert (*ptr2).kind == TY_PTR
  assert (*(*ptr2).inner).kind == TY_PTR
  assert (*(*(*ptr2).inner).inner).kind == TY_I32
  0

@test
fn test_type_ref() -> i32
  # Create &i32 - inline allocs
  let inner: *Type = __builtin_alloca(128) as *Type
  (*inner).kind = TY_I32

  let ref_ty: *Type = __builtin_alloca(128) as *Type
  (*ref_ty).kind = TY_REF
  (*ref_ty).inner = inner

  assert (*ref_ty).kind == TY_REF
  assert (*(*ref_ty).inner).kind == TY_I32
  0

@test
fn test_type_ref_mut() -> i32
  # Create &mut i32 - inline allocs
  let inner: *Type = __builtin_alloca(128) as *Type
  (*inner).kind = TY_I32

  let ref_ty: *Type = __builtin_alloca(128) as *Type
  (*ref_ty).kind = TY_REF_MUT
  (*ref_ty).inner = inner

  assert (*ref_ty).kind == TY_REF_MUT
  assert (*(*ref_ty).inner).kind == TY_I32
  0
