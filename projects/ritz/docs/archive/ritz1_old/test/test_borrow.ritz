@test
fn test_shared_borrow_ok() -> i32
  let arena: *Arena = arena_new(4096)
  let src: *i8 = arena_alloc(arena, 8) as *i8
  *(src + 0) = 120 as i8  # 'x'

  let bc: *BorrowChecker = borrow_checker_new(arena, src)
  let x: *Place = place_var(bc, src, 1)

  # First shared borrow is ok
  check_shared_borrow(bc, x, 1)
  assert bc.error_count == 0

  # Second shared borrow is also ok (multiple readers)
  check_shared_borrow(bc, x, 2)
  assert bc.error_count == 0
  0

@test
fn test_mut_borrow_ok() -> i32
  let arena: *Arena = arena_new(4096)
  let src: *i8 = arena_alloc(arena, 8) as *i8
  *(src + 0) = 120 as i8  # 'x'

  let bc: *BorrowChecker = borrow_checker_new(arena, src)
  let x: *Place = place_var(bc, src, 1)

  # Mutable borrow with no other borrows is ok
  check_mut_borrow(bc, x, 1)
  assert bc.error_count == 0
  0

@test
fn test_mut_while_shared_error() -> i32
  let arena: *Arena = arena_new(4096)
  let src: *i8 = arena_alloc(arena, 8) as *i8
  *(src + 0) = 120 as i8  # 'x'

  let bc: *BorrowChecker = borrow_checker_new(arena, src)
  let x: *Place = place_var(bc, src, 1)

  # Shared borrow first
  check_shared_borrow(bc, x, 1)
  assert bc.error_count == 0

  # Then try mutable borrow - error!
  check_mut_borrow(bc, x, 2)
  assert bc.error_count == 1
  assert bc.errors.kind == ERR_MUT_WHILE_SHARED
  0

@test
fn test_double_mut_borrow_error() -> i32
  let arena: *Arena = arena_new(4096)
  let src: *i8 = arena_alloc(arena, 8) as *i8
  *(src + 0) = 120 as i8  # 'x'

  let bc: *BorrowChecker = borrow_checker_new(arena, src)
  let x: *Place = place_var(bc, src, 1)

  # First mutable borrow ok
  check_mut_borrow(bc, x, 1)
  assert bc.error_count == 0

  # Second mutable borrow - error!
  check_mut_borrow(bc, x, 2)
  assert bc.error_count == 1
  assert bc.errors.kind == ERR_DOUBLE_MUT_BORROW
  0

@test
fn test_shared_after_mut_error() -> i32
  let arena: *Arena = arena_new(4096)
  let src: *i8 = arena_alloc(arena, 8) as *i8
  *(src + 0) = 120 as i8  # 'x'

  let bc: *BorrowChecker = borrow_checker_new(arena, src)
  let x: *Place = place_var(bc, src, 1)

  # Mutable borrow first
  check_mut_borrow(bc, x, 1)
  assert bc.error_count == 0

  # Then shared borrow - error!
  check_shared_borrow(bc, x, 2)
  assert bc.error_count == 1
  0

@test
fn test_move_while_borrowed_error() -> i32
  let arena: *Arena = arena_new(4096)
  let src: *i8 = arena_alloc(arena, 8) as *i8
  *(src + 0) = 120 as i8  # 'x'

  let bc: *BorrowChecker = borrow_checker_new(arena, src)
  let x: *Place = place_var(bc, src, 1)

  # Borrow x
  check_shared_borrow(bc, x, 1)
  assert bc.error_count == 0

  # Try to move x while borrowed - error!
  check_move(bc, x, 2)
  assert bc.error_count == 1
  assert bc.errors.kind == ERR_MOVE_WHILE_BORROWED
  0

# =============================================================================
# Tests: Scope-based Lifetime
# =============================================================================

@test
fn test_loans_expire_at_scope_end() -> i32
  let arena: *Arena = arena_new(4096)
  let src: *i8 = arena_alloc(arena, 8) as *i8
  *(src + 0) = 120 as i8  # 'x'

  let bc: *BorrowChecker = borrow_checker_new(arena, src)
  let x: *Place = place_var(bc, src, 1)

  # Push inner scope
  push_scope(bc)
  assert bc.scope_depth == 1

  # Borrow in inner scope
  check_shared_borrow(bc, x, 1)
  assert has_any_loan(bc, x) != 0 as *Loan

  # Pop scope - loan should expire
  pop_scope(bc)
  assert bc.scope_depth == 0
  assert has_any_loan(bc, x) == 0 as *Loan

  # Now we can mutably borrow!
  check_mut_borrow(bc, x, 2)
  assert bc.error_count == 0
  0

@test
fn test_nested_scopes() -> i32
  let arena: *Arena = arena_new(4096)
  let src: *i8 = arena_alloc(arena, 8) as *i8
  *(src + 0) = 120 as i8  # 'x'

  let bc: *BorrowChecker = borrow_checker_new(arena, src)
  let x: *Place = place_var(bc, src, 1)

  # Outer scope
  push_scope(bc)
  check_shared_borrow(bc, x, 1)

  # Inner scope
  push_scope(bc)
  check_shared_borrow(bc, x, 2)

  # Pop inner - one loan gone
  pop_scope(bc)

  # Outer loan still active
  assert has_any_loan(bc, x) != 0 as *Loan

  # Pop outer - all loans gone
  pop_scope(bc)
  assert has_any_loan(bc, x) == 0 as *Loan
  0

