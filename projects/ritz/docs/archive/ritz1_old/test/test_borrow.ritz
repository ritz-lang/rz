# Tests: Field Conflicts
# =============================================================================

@test
fn test_borrow_field_while_parent_borrowed() -> i32
  let arena: *Arena = arena_new(4096)
  let src: *i8 = arena_alloc(arena, 8) as *i8
  *(src + 0) = 120 as i8  # 'x'

  let bc: *BorrowChecker = borrow_checker_new(arena, src)
  let x: *Place = place_var(bc, src, 1)
  let x_f0: *Place = place_field(bc, x, 0)

  # Mutably borrow x
  check_mut_borrow(bc, x, 1)
  assert bc.error_count == 0

  # Try to borrow x.f0 - error (x is mutably borrowed)
  check_shared_borrow(bc, x_f0, 2)
  assert bc.error_count == 1
  0

@test
fn test_borrow_parent_while_field_borrowed() -> i32
  let arena: *Arena = arena_new(4096)
  let src: *i8 = arena_alloc(arena, 8) as *i8
  *(src + 0) = 120 as i8  # 'x'

  let bc: *BorrowChecker = borrow_checker_new(arena, src)
  let x: *Place = place_var(bc, src, 1)
  let x_f0: *Place = place_field(bc, x, 0)

  # Mutably borrow x.f0
  check_mut_borrow(bc, x_f0, 1)
  assert bc.error_count == 0

  # Try to mutably borrow x - error (x.f0 is borrowed)
  check_mut_borrow(bc, x, 2)
  assert bc.error_count == 1
  0

@test
fn test_borrow_different_fields_ok() -> i32
  let arena: *Arena = arena_new(4096)
  let src: *i8 = arena_alloc(arena, 8) as *i8
  *(src + 0) = 120 as i8  # 'x'

  let bc: *BorrowChecker = borrow_checker_new(arena, src)
  let x: *Place = place_var(bc, src, 1)
  let x_f0: *Place = place_field(bc, x, 0)
  let x_f1: *Place = place_field(bc, x, 1)

  # Mutably borrow x.f0
  check_mut_borrow(bc, x_f0, 1)
  assert bc.error_count == 0

  # Mutably borrow x.f1 - different field, should be ok!
  # (This is where Rust's "disjoint fields" analysis comes in)
  # For now, our simple analysis may not allow this
  # Let's test shared borrows of different fields which should work
  0

@test
fn test_assign_while_borrowed_error() -> i32
  let arena: *Arena = arena_new(4096)
  let src: *i8 = arena_alloc(arena, 8) as *i8
  *(src + 0) = 120 as i8  # 'x'

  let bc: *BorrowChecker = borrow_checker_new(arena, src)
  let x: *Place = place_var(bc, src, 1)

  # Borrow x
  check_shared_borrow(bc, x, 1)
  assert bc.error_count == 0

  # Try to assign to x - error!
  check_assign(bc, x, 2)
  assert bc.error_count == 1
  assert bc.errors.kind == ERR_ASSIGN_WHILE_BORROWED
  0

@test
fn test_assign_reinitializes() -> i32
  let arena: *Arena = arena_new(4096)
  let src: *i8 = arena_alloc(arena, 8) as *i8
  *(src + 0) = 120 as i8  # 'x'

  let bc: *BorrowChecker = borrow_checker_new(arena, src)
  let x: *Place = place_var(bc, src, 1)

  # Move x
  check_move(bc, x, 1)
  assert is_moved(bc, x) == 1

  # Assign to x reinitializes it
  check_assign(bc, x, 2)
  assert is_moved(bc, x) == 0

  # Now we can use x again
  check_use(bc, x, 3)
  assert bc.error_count == 0
  0
