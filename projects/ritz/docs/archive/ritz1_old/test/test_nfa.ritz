# NFA Regex Engine Tests
#
# Test-driven implementation of NFA-based lexer.
# Run with: python ritz0/ritz0.py --lib ritz1/src/nfa.ritz --test ritz1/test/test_nfa.ritz
#
# Note: UTF-8 decoder tests are in test_utf8.ritz

# ============================================================================
# NFA Structure Tests
# ============================================================================

@test
fn test_nfa_add_states() -> i32
  # Use alloca for state/transition storage
  let states: *NFAState = __builtin_alloca(768)   # 64 * 12 bytes
  let trans: *Transition = __builtin_alloca(2560) # 128 * 20 bytes
  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  let s0: i32 = nfa_add_state(&nfa, 0, 0)
  let s1: i32 = nfa_add_state(&nfa, 1, 1)
  assert s0 == 0
  assert s1 == 1
  assert nfa.state_count == 2
  0

@test
fn test_nfa_add_transitions() -> i32
  let states: *NFAState = __builtin_alloca(768)
  let trans: *Transition = __builtin_alloca(2560)
  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  let s0: i32 = nfa_add_state(&nfa, 0, 0)
  let s1: i32 = nfa_add_state(&nfa, 1, 1)
  nfa_add_char_trans(&nfa, s0, s1, 97)  # 'a'
  assert nfa.trans_count == 1
  0

# ============================================================================
# NFA Simulation Tests
# ============================================================================

# Build NFA for single character 'a'
@test
fn test_nfa_match_single_char() -> i32
  let states: *NFAState = __builtin_alloca(768)
  let trans: *Transition = __builtin_alloca(2560)
  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  # NFA: s0 --'a'--> s1(accept)
  let s0: i32 = nfa_add_state(&nfa, 0, 0)
  let s1: i32 = nfa_add_state(&nfa, 1, 1)
  nfa_add_char_trans(&nfa, s0, s1, 97)
  nfa.start_state = s0

  assert nfa_accepts(&nfa, "a", 1) == 1
  assert nfa_accepts(&nfa, "b", 1) == 0
  assert nfa_accepts(&nfa, "", 0) == 0
  assert nfa_accepts(&nfa, "aa", 2) == 0
  0

# Build NFA for "ab"
@test
fn test_nfa_match_concat() -> i32
  let states: *NFAState = __builtin_alloca(768)
  let trans: *Transition = __builtin_alloca(2560)
  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  # NFA: s0 --'a'--> s1 --'b'--> s2(accept)
  let s0: i32 = nfa_add_state(&nfa, 0, 0)
  let s1: i32 = nfa_add_state(&nfa, 0, 0)
  let s2: i32 = nfa_add_state(&nfa, 1, 1)
  nfa_add_char_trans(&nfa, s0, s1, 97)  # 'a'
  nfa_add_char_trans(&nfa, s1, s2, 98)  # 'b'
  nfa.start_state = s0

  assert nfa_accepts(&nfa, "ab", 2) == 1
  assert nfa_accepts(&nfa, "a", 1) == 0
  assert nfa_accepts(&nfa, "abc", 3) == 0
  0

# Build NFA for "a|b" (alternation)
@test
fn test_nfa_match_alternation() -> i32
  let states: *NFAState = __builtin_alloca(768)
  let trans: *Transition = __builtin_alloca(2560)
  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  # NFA: s0 --eps--> s1 --'a'--> s2 --eps--> s5(accept)
  #      s0 --eps--> s3 --'b'--> s4 --eps--> s5(accept)
  let s0: i32 = nfa_add_state(&nfa, 0, 0)
  let s1: i32 = nfa_add_state(&nfa, 0, 0)
  let s2: i32 = nfa_add_state(&nfa, 0, 0)
  let s3: i32 = nfa_add_state(&nfa, 0, 0)
  let s4: i32 = nfa_add_state(&nfa, 0, 0)
  let s5: i32 = nfa_add_state(&nfa, 1, 1)

  nfa_add_epsilon_trans(&nfa, s0, s1)
  nfa_add_epsilon_trans(&nfa, s0, s3)
  nfa_add_char_trans(&nfa, s1, s2, 97)  # 'a'
  nfa_add_char_trans(&nfa, s3, s4, 98)  # 'b'
  nfa_add_epsilon_trans(&nfa, s2, s5)
  nfa_add_epsilon_trans(&nfa, s4, s5)
  nfa.start_state = s0

  assert nfa_accepts(&nfa, "a", 1) == 1
  assert nfa_accepts(&nfa, "b", 1) == 1
  assert nfa_accepts(&nfa, "c", 1) == 0
  assert nfa_accepts(&nfa, "ab", 2) == 0
  0

# Build NFA for [0-9] (character range)
@test
fn test_nfa_match_range() -> i32
  let states: *NFAState = __builtin_alloca(768)
  let trans: *Transition = __builtin_alloca(2560)
  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  # NFA: s0 --[0-9]--> s1(accept)
  let s0: i32 = nfa_add_state(&nfa, 0, 0)
  let s1: i32 = nfa_add_state(&nfa, 1, 1)
  nfa_add_range_trans(&nfa, s0, s1, 48, 57)  # '0'-'9'
  nfa.start_state = s0

  assert nfa_accepts(&nfa, "0", 1) == 1
  assert nfa_accepts(&nfa, "5", 1) == 1
  assert nfa_accepts(&nfa, "9", 1) == 1
  assert nfa_accepts(&nfa, "a", 1) == 0
  0

# Build NFA for a+ (one or more)
@test
fn test_nfa_match_plus() -> i32
  let states: *NFAState = __builtin_alloca(768)
  let trans: *Transition = __builtin_alloca(2560)
  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  # NFA for a+: s0 --'a'--> s1(accept) --eps--> s0
  let s0: i32 = nfa_add_state(&nfa, 0, 0)
  let s1: i32 = nfa_add_state(&nfa, 1, 1)
  nfa_add_char_trans(&nfa, s0, s1, 97)  # 'a'
  nfa_add_epsilon_trans(&nfa, s1, s0)   # loop back
  nfa.start_state = s0

  assert nfa_accepts(&nfa, "", 0) == 0
  assert nfa_accepts(&nfa, "a", 1) == 1
  assert nfa_accepts(&nfa, "aa", 2) == 1
  assert nfa_accepts(&nfa, "aaa", 3) == 1
  assert nfa_accepts(&nfa, "ab", 2) == 0
  0
