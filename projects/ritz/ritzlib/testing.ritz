# ritzlib/testing.ritz - Native Test Framework
#
# Provides test discovery, execution, and reporting for Ritz programs.
#
# Architecture:
# 1. Test files are compiled with --no-runtime (no _start)
# 2. Build system reads .o symbol tables to find test_* functions
# 3. Build system generates a small registration stub
# 4. This module provides _start and the test runner
#
# The build system generates code like:
#   import ritzlib.testing
#   fn __init_tests()
#       register_test("test_arena_new", @test_arena_new)
#       register_test("test_arena_alloc", @test_arena_alloc)
#       ...
#
# Then links with testing.ritz which provides _start that:
#   1. Calls __init_tests() to register all tests
#   2. Calls run_all_tests() to execute them
#
# Usage:
#   @test
#   fn test_addition() -> i32
#       assert 1 + 1 == 2
#       0

import ritzlib.sys
import ritzlib.io

# ============================================================================
# Test Registry
# ============================================================================
# We use a simple array-based registry. Tests are registered at startup
# before run_all_tests() is called.

const MAX_TESTS: i32 = 1024

struct TestEntry
    name: *i8
    func: *u8   # Function pointer stored as *u8 to avoid FnType in struct

# Global test registry
var g_tests: [1024]TestEntry
var g_test_count: i32 = 0

# Register a test function
fn register_test(name: *i8, func: *u8)
    if g_test_count >= MAX_TESTS
        eprints("Error: Too many tests registered\n")
        sys_exit(1)
    g_tests[g_test_count].name = name
    g_tests[g_test_count].func = func
    g_test_count += 1

# ============================================================================
# Test Execution
# ============================================================================

# Run a single test and return 1 if passed, 0 if failed
fn run_single_test(entry: *TestEntry) -> i32
    # Cast function pointer back and call it
    # The function signature is fn() -> i32
    let func_ptr: *u8 = entry.func

    # Call the test function using inline assembly
    # This is a bit hacky but avoids needing FnType support in struct fields
    var result: i32 = 0

    # Use syscall-style calling: put function pointer in a register and call it
    # Actually, we can just cast and call since the ABI is the same
    asm volatile "call *%1" : "={eax}"(result) : "r"(func_ptr) : "memory", "cc"

    # Print result
    prints("  ")
    if result == 0
        prints("[OK] ")
    else
        prints("[FAIL] ")
    prints(entry.name)
    prints("\n")

    if result == 0
        return 1
    return 0

# Run all registered tests
fn run_all_tests() -> i32
    if g_test_count == 0
        prints("No tests registered.\n")
        return 0

    prints("Running ")
    print_int(g_test_count)
    prints(" tests:\n")

    var passed: i32 = 0
    var failed: i32 = 0

    for i in 0..g_test_count
        if run_single_test(@g_tests[i]) != 0
            passed += 1
        else
            failed += 1

    # Print summary
    prints("\n")
    print_int(passed)
    prints(" passed, ")
    print_int(failed)
    prints(" failed\n")

    return failed

# ============================================================================
# Test Entry Point
# ============================================================================
# This is the main() for test binaries. The build system links this module
# with test object files and a generated __init_tests() function.

# Forward declaration - generated by build system
fn __init_tests()

# Main entry point for test binaries
fn main() -> i32
    # Register all tests
    __init_tests()

    # Run tests and return failure count as exit code
    return run_all_tests()

# ============================================================================
# Assertion helpers
# ============================================================================
# These provide better error messages for common assertion patterns.

# Assert with message - prints message on failure
fn assert_msg(condition: i32, msg: *i8)
    if condition == 0
        eprints("Assertion failed: ")
        eprints(msg)
        eprints("\n")
        sys_exit(1)

# Assert two i64 values are equal
fn assert_eq_i64(actual: i64, expected: i64, msg: *i8)
    if actual != expected
        eprints("Assertion failed: ")
        eprints(msg)
        eprints("\n  expected: ")
        eprint_int(expected as i32)
        eprints("\n  actual:   ")
        eprint_int(actual as i32)
        eprints("\n")
        sys_exit(1)

# Assert two i32 values are equal
fn assert_eq_i32(actual: i32, expected: i32, msg: *i8)
    if actual != expected
        eprints("Assertion failed: ")
        eprints(msg)
        eprints("\n  expected: ")
        eprint_int(expected)
        eprints("\n  actual:   ")
        eprint_int(actual)
        eprints("\n")
        sys_exit(1)

# Assert pointer is not null
fn assert_not_null(ptr: *u8, msg: *i8)
    if ptr == null
        eprints("Assertion failed (null pointer): ")
        eprints(msg)
        eprints("\n")
        sys_exit(1)

# Assert pointer is null
fn assert_null(ptr: *u8, msg: *i8)
    if ptr != null
        eprints("Assertion failed (expected null): ")
        eprints(msg)
        eprints("\n")
        sys_exit(1)
