# ritzlib/lang/lexer.ritz - Core Lexer Infrastructure
#
# Character-by-character scanner with indentation tracking.
# Used by grammar-driven lexers and hand-written lexers alike.

import ritzlib.sys
import ritzlib.io
import ritzlib.str
import ritzlib.lang.tokens

# =============================================================================
# Lexer State
# =============================================================================

const MAX_INDENT_STACK: i32 = 64

struct Lexer
    src: *u8            # Source buffer
    len: i64            # Source length
    pos: i64            # Current position
    line: i32           # Current line (1-based)
    col: i32            # Current column (1-based)
    # Indentation tracking
    indent_stack: [64]i32   # Stack of indentation levels
    indent_depth: i32       # Current stack depth
    pending_dedents: i32    # Number of pending DEDENT tokens
    at_line_start: i32      # 1 if at start of line (for indent tracking)
    # Token definitions for pattern matching (optional)
    defs: *TokenDefs        # May be nil for hand-written lexers

fn lexer_new(src: *u8, len: i64) -> Lexer
    var lex: Lexer = Lexer {
        src: src,
        len: len,
        pos: 0,
        line: 1,
        col: 1,
        indent_stack: [0; 64],
        indent_depth: 0,
        pending_dedents: 0,
        at_line_start: 1,
        defs: null
    }
    lex.indent_stack[0] = 0
    return lex

fn lexer_init(lex: *Lexer, src: *u8, len: i64, defs: *TokenDefs)
    lex.src = src
    lex.len = len
    lex.pos = 0
    lex.line = 1
    lex.col = 1
    lex.indent_stack[0] = 0
    lex.indent_depth = 0
    lex.pending_dedents = 0
    lex.at_line_start = 1
    lex.defs = defs

# =============================================================================
# Character Operations
# =============================================================================

# Peek current character without advancing
fn lexer_peek(lex: *Lexer) -> i32
    if lex.pos >= lex.len
        return 0  # EOF as null char
    return *(lex.src + lex.pos) as i32

# Peek character at offset from current position
fn lexer_peek_at(lex: *Lexer, offset: i64) -> i32
    let p: i64 = lex.pos + offset
    if p >= lex.len or p < 0
        return 0
    return *(lex.src + p) as i32

# Advance and return current character
fn lexer_advance(lex: *Lexer) -> i32
    if lex.pos >= lex.len
        return 0
    let ch: i32 = *(lex.src + lex.pos) as i32
    lex.pos = lex.pos + 1
    if ch == '\n'  # '\n'
        lex.line = lex.line + 1
        lex.col = 1
        lex.at_line_start = 1
    else
        lex.col = lex.col + 1
    return ch

# Check if at end of source
fn lexer_at_end(lex: *Lexer) -> i32
    if lex.pos >= lex.len
        return 1
    return 0

# =============================================================================
# Character Classification
# =============================================================================

fn is_digit(ch: i32) -> i32
    if ch >= '0' and ch <= '9'
        return 1
    return 0

fn is_hex_digit(ch: i32) -> i32
    if ch >= '0' and ch <= '9'
        return 1
    if ch >= 'A' and ch <= 70
        return 1
    if ch >= 'a' and ch <= 102
        return 1
    return 0

fn is_alpha(ch: i32) -> i32
    if ch >= 'A' and ch <= 'Z'
        return 1
    if ch >= 'a' and ch <= 'z'
        return 1
    if ch == '_'
        return 1
    return 0

fn is_alnum(ch: i32) -> i32
    if is_alpha(ch) != 0
        return 1
    if is_digit(ch) != 0
        return 1
    return 0

fn is_whitespace(ch: i32) -> i32
    if ch == ' ' or ch == '\t' or ch == '\r'
        return 1
    return 0

# =============================================================================
# Basic Scanning
# =============================================================================

# Skip whitespace (but NOT newlines - they're significant in Ritz)
fn lexer_skip_whitespace(lex: *Lexer)
    while lex.pos < lex.len
        let ch: i32 = lexer_peek(lex)
        if ch == ' ' or ch == '\t' or ch == '\r'
            lexer_advance(lex)
        else
            return

# Skip line comment (# to end of line)
fn lexer_skip_comment(lex: *Lexer)
    while lex.pos < lex.len
        let ch: i32 = lexer_peek(lex)
        if ch == '\n' or ch == 0
            return
        lexer_advance(lex)

# =============================================================================
# Indentation Handling
# =============================================================================

# Measure indentation at current line start
fn lexer_measure_indent(lex: *Lexer) -> i32
    var indent: i32 = 0
    var p: i64 = lex.pos
    while p < lex.len
        let ch: i32 = *(lex.src + p) as i32
        if ch == ' '
            # space
            indent += 1
            p += 1
        else
            if ch == '\t'
                # tab (count as 4 spaces)
                indent += 4
                p += 1
            else
                break
    return indent

# Handle indentation changes at line start
fn lexer_handle_indent(lex: *Lexer, tok: *Token) -> i32
    if lex.at_line_start == 0
        return 0

    # Return pending dedents first
    if lex.pending_dedents > 0
        lex.pending_dedents = lex.pending_dedents - 1
        *tok = token_new(TOK_DEDENT, lex.src + lex.pos, 0, lex.line, lex.col)
        return 1

    var indent: i32 = lexer_measure_indent(lex)

    # Skip blank lines and comment-only lines
    var p: i64 = lex.pos + (indent as i64)
    if p < lex.len
        let ch: i32 = *(lex.src + p) as i32
        if ch == '\n' or ch == '#'
            # newline or '#' comment
            return 0

    let current_indent: i32 = lex.indent_stack[lex.indent_depth]

    if indent > current_indent
        # Push new indent level
        if lex.indent_depth < MAX_INDENT_STACK - 1
            lex.indent_depth = lex.indent_depth + 1
            lex.indent_stack[lex.indent_depth] = indent
        # Skip the whitespace
        lexer_skip_indent_ws(lex, indent)
        lex.at_line_start = 0
        *tok = token_new(TOK_INDENT, lex.src + lex.pos, 0, lex.line, lex.col)
        return 1

    if indent < current_indent
        # Pop indent levels and queue DEDENTs
        while lex.indent_depth > 0 and lex.indent_stack[lex.indent_depth] > indent
            lex.indent_depth = lex.indent_depth - 1
            lex.pending_dedents = lex.pending_dedents + 1
        # Return first DEDENT
        if lex.pending_dedents > 0
            lex.pending_dedents = lex.pending_dedents - 1
            *tok = token_new(TOK_DEDENT, lex.src + lex.pos, 0, lex.line, lex.col)
            return 1

    # Same indent level - skip leading whitespace
    lexer_skip_indent_ws(lex, indent)
    lex.at_line_start = 0
    return 0

# Helper to skip indent whitespace
fn lexer_skip_indent_ws(lex: *Lexer, count: i32)
    var n: i32 = count
    while n > 0
        lexer_advance(lex)
        n -= 1

# =============================================================================
# Number Scanning
# =============================================================================

fn lexer_scan_number(lex: *Lexer, tok: *Token) -> i32
    let start: i64 = lex.pos
    let start_line: i32 = lex.line
    let start_col: i32 = lex.col

    # Check for hex literal
    if lexer_peek(lex) == '0' and lexer_peek_at(lex, 1) == 'x'  # 0x
        lexer_advance(lex)  # 0
        lexer_advance(lex)  # x
        while is_hex_digit(lexer_peek(lex)) != 0
            lexer_advance(lex)
        let len: i32 = (lex.pos - start) as i32
        *tok = token_new(TOK_HEX, lex.src + start, len, start_line, start_col)
        return 1

    # Decimal number
    while is_digit(lexer_peek(lex)) != 0
        lexer_advance(lex)

    let len: i32 = (lex.pos - start) as i32
    *tok = token_new(TOK_NUMBER, lex.src + start, len, start_line, start_col)
    return 1

# =============================================================================
# String Scanning
# =============================================================================

fn lexer_scan_string(lex: *Lexer, tok: *Token) -> i32
    let start: i64 = lex.pos
    let start_line: i32 = lex.line
    let start_col: i32 = lex.col

    lexer_advance(lex)  # Skip opening quote

    while lex.pos < lex.len
        let ch: i32 = lexer_peek(lex)
        if ch == '"'
            # closing "
            lexer_advance(lex)
            let len: i32 = (lex.pos - start) as i32
            *tok = token_new(TOK_STRING, lex.src + start, len, start_line, start_col)
            return 1
        else
            if ch == '\\'
                # backslash escape
                lexer_advance(lex)
                if lex.pos < lex.len
                    lexer_advance(lex)
            else
                if ch == '\n'
                    # newline in string (error)
                    break
                else
                    lexer_advance(lex)

    # Unterminated string
    let len: i32 = (lex.pos - start) as i32
    *tok = token_new(TOK_ERROR, lex.src + start, len, start_line, start_col)
    return 1

# =============================================================================
# Char Scanning
# =============================================================================

fn lexer_scan_char(lex: *Lexer, tok: *Token) -> i32
    let start: i64 = lex.pos
    let start_line: i32 = lex.line
    let start_col: i32 = lex.col

    lexer_advance(lex)  # Skip opening quote

    if lex.pos < lex.len
        let ch: i32 = lexer_peek(lex)
        if ch == '\\'  # escape
            lexer_advance(lex)
            if lex.pos < lex.len
                lexer_advance(lex)
        else
            lexer_advance(lex)

    # Expect closing quote
    if lexer_peek(lex) == '\''
        lexer_advance(lex)
        let len: i32 = (lex.pos - start) as i32
        *tok = token_new(TOK_CHAR, lex.src + start, len, start_line, start_col)
        return 1

    # Unterminated char
    let len: i32 = (lex.pos - start) as i32
    *tok = token_new(TOK_ERROR, lex.src + start, len, start_line, start_col)
    return 1

# =============================================================================
# Identifier Scanning
# =============================================================================

fn lexer_scan_ident(lex: *Lexer, tok: *Token) -> i32
    let start: i64 = lex.pos
    let start_line: i32 = lex.line
    let start_col: i32 = lex.col

    while is_alnum(lexer_peek(lex)) != 0
        lexer_advance(lex)

    let len: i32 = (lex.pos - start) as i32
    *tok = token_new(TOK_IDENT, lex.src + start, len, start_line, start_col)
    return 1
