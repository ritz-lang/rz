# =============================================================================
# Whitespace Handling Tests
# =============================================================================

[[test]]
fn test_parse_whitespace_around_value() -> i32
    let input = c"   42   "
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0
    assert result.value.kind == JSON_NUMBER
    assert result.value.num_val == 42
    json_free(result.value)
    0

[[test]]
fn test_parse_whitespace_in_array() -> i32
    let input = c"[ 1 , 2 , 3 ]"
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0
    assert result.value.kind == JSON_ARRAY
    assert result.value.count == 3
    json_free(result.value)
    0

[[test]]
fn test_parse_whitespace_in_object() -> i32
    let input = c"{ \"a\" : 1 , \"b\" : 2 }"
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0
    assert result.value.kind == JSON_OBJECT
    assert result.value.count == 2
    json_free(result.value)
    0

# =============================================================================
# JSON Emitter Tests
# =============================================================================

[[test]]
fn test_emit_null() -> i32
    let input = c"null"
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0

    let output: *u8 = json_to_string(result.value)
    assert output != null
    assert streq(output, c"null") != 0

    free(output)
    json_free(result.value)
    0

[[test]]
fn test_emit_bool_true() -> i32
    let input = c"true"
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0

    let output: *u8 = json_to_string(result.value)
    assert streq(output, c"true") != 0

    free(output)
    json_free(result.value)
    0

[[test]]
fn test_emit_number() -> i32
    let input = c"42"
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0

    let output: *u8 = json_to_string(result.value)
    assert streq(output, c"42") != 0

    free(output)
    json_free(result.value)
    0

[[test]]
fn test_emit_string() -> i32
    let input = c"\"hello\""
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0

    let output: *u8 = json_to_string(result.value)
    assert streq(output, c"\"hello\"") != 0

    free(output)
    json_free(result.value)
    0

[[test]]
fn test_emit_array() -> i32
    let input = c"[1, 2, 3]"
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0

    let output: *u8 = json_to_string(result.value)
    assert streq(output, c"[1, 2, 3]") != 0

    free(output)
    json_free(result.value)
    0

[[test]]
fn test_emit_object() -> i32
    # Note: Object key order may not be preserved in the same way
    let input = c"{\"a\": 1}"
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0

    let output: *u8 = json_to_string(result.value)
    # Check the output contains the expected content
    assert output != null
    assert strlen(output) > 0

    free(output)
    json_free(result.value)
    0

# =============================================================================
# Result-based API Tests (json_parse2)
# =============================================================================

[[test]]
fn test_parse2_success() -> i32
    let input = c"{\"key\": 42}"
    var result: Result<*JsonValue, JsonError> = json_parse2(input, strlen(input))
    let success: i32 = match result
        Ok(root) => check_parse2_result(root, 42)
        Err(err) => 1
    success

fn check_parse2_result(root: *JsonValue, expected: i64) -> i32
    if root.kind != JSON_OBJECT
        json_free(root)
        return 1
    let val: *JsonValue = json_get_field(root, c"key")
    if val == null or val.num_val != expected
        json_free(root)
        return 1
    json_free(root)
    0

[[test]]
fn test_parse2_error() -> i32
    let input = c""
    var result: Result<*JsonValue, JsonError> = json_parse2(input, 0)
    let success: i32 = match result
        Ok(root) => handle_unexpected_ok(root)
        Err(err) => check_err_code(err.code, JSON_ERR_UNEXPECTED_CHAR)
    success

fn handle_unexpected_ok(root: *JsonValue) -> i32
    json_free(root)
    1

fn check_err_code(got: i32, expected: i32) -> i32
    if got == expected
        return 0
    1

[[test]]
fn test_parse2_null() -> i32
    let input = c"null"
    var result: Result<*JsonValue, JsonError> = json_parse2(input, strlen(input))
    let success: i32 = match result
        Ok(root) => check_null_result(root)
        Err(err) => 1
    success

fn check_null_result(root: *JsonValue) -> i32
    if root.kind == JSON_NULL
        json_free(root)
        return 0
    json_free(root)
    1

[[test]]
fn test_parse2_array() -> i32
    let input = c"[1, 2, 3]"
    var result: Result<*JsonValue, JsonError> = json_parse2(input, strlen(input))
    let success: i32 = match result
        Ok(root) => check_array_result(root, 3)
        Err(err) => 1
    success

fn check_array_result(root: *JsonValue, expected_count: i64) -> i32
    if root.kind == JSON_ARRAY and root.count == expected_count
        json_free(root)
        return 0
    json_free(root)
    1

[[test]]
fn test_error_message() -> i32
    let msg: *u8 = json_error_message(JSON_ERR_UNEXPECTED_CHAR)
    if streq(msg, c"unexpected character") == 0
        return 1
    let msg2: *u8 = json_error_message(JSON_ERR_UNTERMINATED_STRING)
    if streq(msg2, c"unterminated string") == 0
        return 1
    0
