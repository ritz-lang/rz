# Test suite for ritzlib/json.ritz
#
# Tests JSON parsing and emitting functionality.
# Run with: python3 ritz0/ritz0.py --test ritzlib/tests/test_json.ritz

import ritzlib.sys
import ritzlib.str
import ritzlib.memory
import ritzlib.json
import ritzlib.result

# =============================================================================
# Primitive Parsing Tests
# =============================================================================

[[test]]
fn test_parse_null() -> i32
    let input = c"null"
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0
    assert result.value != null
    assert result.value.kind == JSON_NULL
    json_free(result.value)
    0

[[test]]
fn test_parse_true() -> i32
    let input = c"true"
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0
    assert result.value.kind == JSON_BOOL
    assert result.value.bool_val == 1
    json_free(result.value)
    0

[[test]]
fn test_parse_false() -> i32
    let input = c"false"
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0
    assert result.value.kind == JSON_BOOL
    assert result.value.bool_val == 0
    json_free(result.value)
    0

[[test]]
fn test_parse_number_positive() -> i32
    let input = c"42"
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0
    assert result.value.kind == JSON_NUMBER
    assert result.value.num_val == 42
    json_free(result.value)
    0

[[test]]
fn test_parse_number_negative() -> i32
    let input = c"-123"
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0
    assert result.value.kind == JSON_NUMBER
    assert result.value.num_val == 0 - 123
    json_free(result.value)
    0

[[test]]
fn test_parse_number_zero() -> i32
    let input = c"0"
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0
    assert result.value.kind == JSON_NUMBER
    assert result.value.num_val == 0
    json_free(result.value)
    0

# =============================================================================
# String Parsing Tests
# =============================================================================

[[test]]
fn test_parse_string_simple() -> i32
    let input = c"\"hello\""
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0
    assert result.value.kind == JSON_STRING
    assert streq(result.value.str_val, c"hello") != 0
    json_free(result.value)
    0

[[test]]
fn test_parse_string_empty() -> i32
    let input = c"\"\""
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0
    assert result.value.kind == JSON_STRING
    assert result.value.str_len == 0
    json_free(result.value)
    0

[[test]]
fn test_parse_string_escape_quote() -> i32
    # Input: "he\"llo"
    var input: [10]u8
    input[0] = 34   # "
    input[1] = 104  # h
    input[2] = 101  # e
    input[3] = 92   # \
    input[4] = 34   # "
    input[5] = 108  # l
    input[6] = 108  # l
    input[7] = 111  # o
    input[8] = 34   # "
    input[9] = 0    # null

    let result: JsonResult = json_parse(@input[0], 9)
    assert result.ok != 0
    assert result.value.kind == JSON_STRING
    # Result should be: he"llo
    assert result.value.str_len == 6
    json_free(result.value)
    0

[[test]]
fn test_parse_string_escape_newline() -> i32
    # Input: "line1\nline2"
    var input: [16]u8
    input[0] = 34   # "
    input[1] = 108  # l
    input[2] = 105  # i
    input[3] = 110  # n
    input[4] = 101  # e
    input[5] = 49   # 1
    input[6] = 92   # \
    input[7] = 110  # n
    input[8] = 108  # l
    input[9] = 105  # i
    input[10] = 110 # n
    input[11] = 101 # e
    input[12] = 50  # 2
    input[13] = 34  # "
    input[14] = 0   # null

    let result: JsonResult = json_parse(@input[0], 14)
    assert result.ok != 0
    assert result.value.kind == JSON_STRING
    # Result should contain actual newline character
    assert result.value.str_len == 11
    json_free(result.value)
    0

# =============================================================================
# Array Parsing Tests
# =============================================================================

[[test]]
fn test_parse_array_empty() -> i32
    let input = c"[]"
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0
    assert result.value.kind == JSON_ARRAY
    assert result.value.count == 0
    json_free(result.value)
    0

[[test]]
fn test_parse_array_single() -> i32
    let input = c"[42]"
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0
    assert result.value.kind == JSON_ARRAY
    assert result.value.count == 1
    let item: *JsonValue = json_get_index(result.value, 0)
    assert item.kind == JSON_NUMBER
    assert item.num_val == 42
    json_free(result.value)
    0

[[test]]
fn test_parse_array_multiple() -> i32
    let input = c"[1, 2, 3]"
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0
    assert result.value.kind == JSON_ARRAY
    assert result.value.count == 3
    assert json_get_number(json_get_index(result.value, 0)) == 1
    assert json_get_number(json_get_index(result.value, 1)) == 2
    assert json_get_number(json_get_index(result.value, 2)) == 3
    json_free(result.value)
    0

[[test]]
fn test_parse_array_mixed() -> i32
    let input = c"[1, \"hello\", true, null]"
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0
    assert result.value.kind == JSON_ARRAY
    assert result.value.count == 4

    let n: *JsonValue = json_get_index(result.value, 0)
    assert n.kind == JSON_NUMBER
    assert n.num_val == 1

    let s: *JsonValue = json_get_index(result.value, 1)
    assert s.kind == JSON_STRING
    assert streq(s.str_val, c"hello") != 0

    let b: *JsonValue = json_get_index(result.value, 2)
    assert b.kind == JSON_BOOL
    assert b.bool_val == 1

    let nl: *JsonValue = json_get_index(result.value, 3)
    assert nl.kind == JSON_NULL

    json_free(result.value)
    0

[[test]]
fn test_parse_array_nested() -> i32
    let input = c"[[1, 2], [3, 4]]"
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0
    assert result.value.kind == JSON_ARRAY
    assert result.value.count == 2

    let arr1: *JsonValue = json_get_index(result.value, 0)
    assert arr1.kind == JSON_ARRAY
    assert arr1.count == 2
    assert json_get_number(json_get_index(arr1, 0)) == 1
    assert json_get_number(json_get_index(arr1, 1)) == 2

    let arr2: *JsonValue = json_get_index(result.value, 1)
    assert arr2.kind == JSON_ARRAY
    assert arr2.count == 2
    assert json_get_number(json_get_index(arr2, 0)) == 3
    assert json_get_number(json_get_index(arr2, 1)) == 4

    json_free(result.value)
    0

# =============================================================================
# Object Parsing Tests
# =============================================================================

[[test]]
fn test_parse_object_empty() -> i32
    let input = c"{}"
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0
    assert result.value.kind == JSON_OBJECT
    assert result.value.count == 0
    json_free(result.value)
    0

[[test]]
fn test_parse_object_single() -> i32
    let input = c"{\"name\": \"test\"}"
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0
    assert result.value.kind == JSON_OBJECT
    assert result.value.count == 1

    let name: *JsonValue = json_get_field(result.value, c"name")
    assert name != null
    assert name.kind == JSON_STRING
    assert streq(name.str_val, c"test") != 0

    json_free(result.value)
    0

[[test]]
fn test_parse_object_multiple() -> i32
    let input = c"{\"a\": 1, \"b\": 2, \"c\": 3}"
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0
    assert result.value.kind == JSON_OBJECT
    assert result.value.count == 3

    assert json_get_number(json_get_field(result.value, c"a")) == 1
    assert json_get_number(json_get_field(result.value, c"b")) == 2
    assert json_get_number(json_get_field(result.value, c"c")) == 3

    json_free(result.value)
    0

[[test]]
fn test_parse_object_nested() -> i32
    let input = c"{\"outer\": {\"inner\": 42}}"
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0
    assert result.value.kind == JSON_OBJECT

    let outer: *JsonValue = json_get_field(result.value, c"outer")
    assert outer != null
    assert outer.kind == JSON_OBJECT

    let inner: *JsonValue = json_get_field(outer, c"inner")
    assert inner != null
    assert inner.kind == JSON_NUMBER
    assert inner.num_val == 42

    json_free(result.value)
    0

# =============================================================================
# Access Helper Tests
# =============================================================================

[[test]]
fn test_json_get_field_missing() -> i32
    let input = c"{\"a\": 1}"
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0

    let missing: *JsonValue = json_get_field(result.value, c"nonexistent")
    assert missing == null

    json_free(result.value)
    0

[[test]]
fn test_json_get_index_bounds() -> i32
    let input = c"[1, 2, 3]"
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0

    # Valid index
    let valid: *JsonValue = json_get_index(result.value, 1)
    assert valid != null

    # Out of bounds
    let oob: *JsonValue = json_get_index(result.value, 10)
    assert oob == null

    # Negative index
    let neg: *JsonValue = json_get_index(result.value, 0 - 1)
    assert neg == null

    json_free(result.value)
    0

[[test]]
fn test_json_array_len() -> i32
    let input = c"[1, 2, 3, 4, 5]"
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0
    assert json_array_len(result.value) == 5
    json_free(result.value)
    0

[[test]]
fn test_json_object_len() -> i32
    let input = c"{\"a\": 1, \"b\": 2}"
    let result: JsonResult = json_parse(input, strlen(input))
    assert result.ok != 0
    assert json_object_len(result.value) == 2
    json_free(result.value)
    0

