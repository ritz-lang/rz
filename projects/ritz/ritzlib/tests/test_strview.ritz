# Tests for ritzlib/strview.ritz

import ritzlib.strview

# ============================================================================
# Constructor tests
# ============================================================================

[[test]]
fn test_strview_empty() -> i32
    let s: StrView = strview_empty()
    assert s.len == 0
    assert strview_is_empty(@s) == 1
    0

[[test]]
fn test_strview_from_cstr() -> i32
    let s: StrView = strview_from_cstr(c"hello")
    assert s.len == 5
    assert strview_is_empty(@s) == 0
    0

[[test]]
fn test_strview_from_ptr() -> i32
    let data: *u8 = c"hello world"
    let s: StrView = strview_from_ptr(data, 5)  # Just "hello"
    assert s.len == 5
    assert strview_get(@s, 0) == 'h'
    assert strview_get(@s, 4) == 'o'
    0

# ============================================================================
# Comparison tests
# ============================================================================

[[test]]
fn test_strview_eq() -> i32
    let a: StrView = strview_from_cstr(c"hello")
    let b: StrView = strview_from_cstr(c"hello")
    let c: StrView = strview_from_cstr(c"world")
    assert strview_eq(@a, @b) == 1
    assert strview_eq(@a, @c) == 0
    0

[[test]]
fn test_strview_eq_cstr() -> i32
    let s: StrView = strview_from_cstr(c"hello")
    assert strview_eq_cstr(@s, c"hello") == 1
    assert strview_eq_cstr(@s, c"world") == 0
    assert strview_eq_cstr(@s, c"hell") == 0  # Shorter
    assert strview_eq_cstr(@s, c"hello!") == 0  # Longer
    0

# ============================================================================
# Slicing tests
# ============================================================================

[[test]]
fn test_strview_slice() -> i32
    let s: StrView = strview_from_cstr(c"hello world")
    let sub: StrView = strview_slice(@s, 0, 5)
    assert sub.len == 5
    assert strview_eq_cstr(@sub, c"hello") == 1
    0

[[test]]
fn test_strview_take_skip() -> i32
    let s: StrView = strview_from_cstr(c"hello world")

    let first5: StrView = strview_take(@s, 5)
    assert first5.len == 5
    assert strview_eq_cstr(@first5, c"hello") == 1

    let rest: StrView = strview_skip(@s, 6)
    assert rest.len == 5
    assert strview_eq_cstr(@rest, c"world") == 1
    0

# ============================================================================
# Search tests
# ============================================================================

[[test]]
fn test_strview_starts_with() -> i32
    let s: StrView = strview_from_cstr(c"hello world")
    let prefix: StrView = strview_from_cstr(c"hello")
    let wrong: StrView = strview_from_cstr(c"world")

    assert strview_starts_with(@s, @prefix) == 1
    assert strview_starts_with(@s, @wrong) == 0
    0

[[test]]
fn test_strview_ends_with() -> i32
    let s: StrView = strview_from_cstr(c"hello world")
    let suffix: StrView = strview_from_cstr(c"world")
    let wrong: StrView = strview_from_cstr(c"hello")

    assert strview_ends_with(@s, @suffix) == 1
    assert strview_ends_with(@s, @wrong) == 0
    0

[[test]]
fn test_strview_contains() -> i32
    let s: StrView = strview_from_cstr(c"hello world")
    let needle: StrView = strview_from_cstr(c"lo wo")
    let wrong: StrView = strview_from_cstr(c"xyz")

    assert strview_contains(@s, @needle) == 1
    assert strview_contains(@s, @wrong) == 0
    0

[[test]]
fn test_strview_find() -> i32
    let s: StrView = strview_from_cstr(c"hello world")
    let needle: StrView = strview_from_cstr(c"world")

    assert strview_find(@s, @needle) == 6

    let not_found: StrView = strview_from_cstr(c"xyz")
    assert strview_find(@s, @not_found) == -1
    0

[[test]]
fn test_strview_find_byte() -> i32
    let s: StrView = strview_from_cstr(c"hello world")

    assert strview_find_byte(@s, 'o') == 4  # First 'o'
    assert strview_find_byte(@s, ' ') == 5  # Space
    assert strview_find_byte(@s, 'x') == -1  # Not found
    0

# ============================================================================
# Split tests
# ============================================================================

[[test]]
fn test_strview_split_once() -> i32
    let s: StrView = strview_from_cstr(c"key=value")
    var before: StrView
    var after: StrView

    let found: i32 = strview_split_once(@s, '=', @before, @after)
    assert found == 1
    assert strview_eq_cstr(@before, c"key") == 1
    assert strview_eq_cstr(@after, c"value") == 1
    0

[[test]]
fn test_strview_split_once_not_found() -> i32
    let s: StrView = strview_from_cstr(c"nodelimiter")
    var before: StrView
    var after: StrView

    let found: i32 = strview_split_once(@s, '=', @before, @after)
    assert found == 0
    assert strview_eq_cstr(@before, c"nodelimiter") == 1
    assert after.len == 0
    0

# ============================================================================
# Trim tests
# ============================================================================

[[test]]
fn test_strview_trim() -> i32
    let s: StrView = strview_from_cstr(c"  hello  ")
    let trimmed: StrView = strview_trim(@s)
    assert strview_eq_cstr(@trimmed, c"hello") == 1
    0

[[test]]
fn test_strview_trim_start() -> i32
    let s: StrView = strview_from_cstr(c"  hello")
    let trimmed: StrView = strview_trim_start(@s)
    assert strview_eq_cstr(@trimmed, c"hello") == 1
    0

[[test]]
fn test_strview_trim_end() -> i32
    let s: StrView = strview_from_cstr(c"hello  ")
    let trimmed: StrView = strview_trim_end(@s)
    assert strview_eq_cstr(@trimmed, c"hello") == 1
    0

# ============================================================================
# Edge cases
# ============================================================================

[[test]]
fn test_strview_empty_operations() -> i32
    let empty: StrView = strview_empty()
    let other: StrView = strview_from_cstr(c"hello")

    # Empty contains empty
    assert strview_contains(@empty, @empty) == 1
    assert strview_contains(@other, @empty) == 1

    # Empty doesn't contain non-empty
    assert strview_contains(@empty, @other) == 0

    # Empty equals empty
    let empty2: StrView = strview_empty()
    assert strview_eq(@empty, @empty2) == 1
    0

[[test]]
fn test_strview_single_char() -> i32
    let s: StrView = strview_from_cstr(c"x")
    assert s.len == 1
    assert strview_get(@s, 0) == 'x'
    assert strview_find_byte(@s, 'x') == 0
    assert strview_find_byte(@s, 'y') == -1
    0

# ============================================================================
# FFI/C-string conversion tests
# ============================================================================

[[test]]
fn test_strview_to_cstr() -> i32
    let s: StrView = strview_from_cstr(c"hello")
    let cstr: *u8 = s.to_cstr()
    # Verify it's null-terminated
    assert *(cstr + 5) == 0
    # Verify content
    assert *cstr == 'h'
    assert *(cstr + 4) == 'o'
    # Must free the allocated buffer
    free(cstr)
    0

[[test]]
fn test_strview_as_cstr_unchecked() -> i32
    # When created from c"...", the underlying data is null-terminated
    let s: StrView = strview_from_cstr(c"hello")
    let cstr: *u8 = s.as_cstr_unchecked()
    # Should point to the original data
    assert *(cstr + 5) == 0
    # No need to free - we didn't allocate
    0
