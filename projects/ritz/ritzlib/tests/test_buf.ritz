# Test ritzlib/buf.ritz - Buffer and GrowBuf types
#
# Tests both:
# - Buffer: read-only view with position tracking
# - GrowBuf: owned growable buffer with Drop trait

import ritzlib.sys
import ritzlib.buf

# ============================================================================
# GrowBuf tests
# ============================================================================

[[test]]
fn test_growbuf_new() -> i32
    # New buffer should be empty
    var b: GrowBuf = growbuf_new()
    if b.len != 0
        return 1
    if b.cap != 0
        return 2
    # No need to free - Drop handles it
    return 0

[[test]]
fn test_growbuf_with_cap() -> i32
    # Buffer with capacity should have allocated memory
    var b: GrowBuf = growbuf_with_cap(64)
    if b.len != 0
        return 1
    if b.cap != 64
        return 2
    if b.data == null
        return 3
    return 0

[[test]]
fn test_growbuf_append_byte() -> i32
    # Append single bytes
    var b: GrowBuf = growbuf_new()
    growbuf_append_byte(@b, 65)  # 'A'
    growbuf_append_byte(@b, 66)  # 'B'
    growbuf_append_byte(@b, 67)  # 'C'

    if b.len != 3
        return 1
    if *(b.data) != 65
        return 2
    if *(b.data + 1) != 66
        return 3
    if *(b.data + 2) != 67
        return 4
    return 0

[[test]]
fn test_growbuf_append() -> i32
    # Append multiple bytes at once
    var b: GrowBuf = growbuf_new()
    let data = "hello" as *u8
    growbuf_append(@b, data, 5)

    if b.len != 5
        return 1
    if *(b.data) != 104  # 'h'
        return 2
    if *(b.data + 4) != 111  # 'o'
        return 3
    return 0

[[test]]
fn test_growbuf_clear() -> i32
    # Clear should reset length but keep capacity
    var b: GrowBuf = growbuf_with_cap(64)
    growbuf_append_byte(@b, 65)
    growbuf_append_byte(@b, 66)

    if b.len != 2
        return 1

    growbuf_clear(@b)

    if b.len != 0
        return 2
    if b.cap != 64
        return 3
    return 0

[[test]]
fn test_growbuf_grow() -> i32
    # Growth should preserve existing data
    var b: GrowBuf = growbuf_new()
    growbuf_append_byte(@b, 65)
    growbuf_append_byte(@b, 66)

    let old_cap: i64 = b.cap
    growbuf_grow(@b, 1024)

    if b.cap != 1024
        return 1
    if b.len != 2
        return 2
    if *(b.data) != 65
        return 3
    if *(b.data + 1) != 66
        return 4
    return 0

[[test]]
fn test_growbuf_accessors() -> i32
    # Test accessor functions
    var b: GrowBuf = growbuf_with_cap(32)
    growbuf_append_byte(@b, 65)
    growbuf_append_byte(@b, 66)

    if growbuf_len(@b) != 2
        return 1
    if growbuf_cap(@b) != ' '
        return 2
    if growbuf_data(@b) != b.data
        return 3
    if growbuf_get(@b, 0) != 65
        return 4
    if growbuf_get(@b, 1) != 66
        return 5
    if growbuf_is_empty(@b) != 0
        return 6
    return 0

[[test]]
fn test_growbuf_is_empty() -> i32
    var b: GrowBuf = growbuf_new()
    if growbuf_is_empty(@b) != 1
        return 1

    growbuf_append_byte(@b, 65)
    if growbuf_is_empty(@b) != 0
        return 2

    growbuf_clear(@b)
    if growbuf_is_empty(@b) != 1
        return 3
    return 0

# ============================================================================
# Buffer (read-only view) tests
# ============================================================================

[[test]]
fn test_buffer_init() -> i32
    # Initialize buffer from pointer and length
    var buf: Buffer
    let data = "hello world" as *u8
    buf_init(@buf, data, 11)

    if buf.len != 11
        return 1
    if buf.pos != 0
        return 2
    return 0

[[test]]
fn test_buffer_from_str() -> i32
    # Initialize buffer from C string
    var buf: Buffer
    buf_from_str(@buf, "hello" as *u8)

    if buf.len != 5
        return 1
    if buf.pos != 0
        return 2
    return 0

[[test]]
fn test_buffer_peek() -> i32
    # Peek should not advance position
    var buf: Buffer
    buf_from_str(@buf, "abc" as *u8)

    if buf_peek(@buf) != 97  # 'a'
        return 1
    if buf.pos != 0
        return 2
    if buf_peek(@buf) != 97  # Still 'a'
        return 3
    return 0

[[test]]
fn test_buffer_peek_at() -> i32
    # Peek at offset
    var buf: Buffer
    buf_from_str(@buf, "abc" as *u8)

    if buf_peek_at(@buf, 0) != 97  # 'a'
        return 1
    if buf_peek_at(@buf, 1) != 98  # 'b'
        return 2
    if buf_peek_at(@buf, 2) != 99  # 'c'
        return 3
    if buf_peek_at(@buf, 3) != 0   # Out of bounds
        return 4
    return 0

[[test]]
fn test_buffer_advance() -> i32
    # Advance should return current char and move position
    var buf: Buffer
    buf_from_str(@buf, "abc" as *u8)

    if buf_advance(@buf) != 97  # 'a'
        return 1
    if buf.pos != 1
        return 2
    if buf_advance(@buf) != 98  # 'b'
        return 3
    if buf.pos != 2
        return 4
    return 0

[[test]]
fn test_buffer_eof() -> i32
    # EOF detection
    var buf: Buffer
    buf_from_str(@buf, "ab" as *u8)

    if buf_eof(@buf) != 0
        return 1

    buf_advance(@buf)
    buf_advance(@buf)

    if buf_eof(@buf) != 1
        return 2
    return 0

[[test]]
fn test_buffer_remaining() -> i32
    # Remaining bytes calculation
    var buf: Buffer
    buf_from_str(@buf, "hello" as *u8)

    if buf_remaining(@buf) != 5
        return 1

    buf_advance(@buf)
    buf_advance(@buf)

    if buf_remaining(@buf) != 3
        return 2
    return 0

[[test]]
fn test_buffer_match_char() -> i32
    # Match single character
    var buf: Buffer
    buf_from_str(@buf, "abc" as *u8)

    if buf_match_char(@buf, 97) != 1  # 'a'
        return 1
    if buf.pos != 1
        return 2
    if buf_match_char(@buf, 97) != 0  # 'a' again - should fail
        return 3
    if buf.pos != 1
        return 4
    return 0

[[test]]
fn test_buffer_match_str() -> i32
    # Match string
    var buf: Buffer
    buf_from_str(@buf, "hello world" as *u8)

    if buf_match_str(@buf, "hello" as *u8) != 1
        return 1
    if buf.pos != 5
        return 2
    if buf_match_str(@buf, " world" as *u8) != 1
        return 3
    if buf.pos != 11
        return 4
    return 0

[[test]]
fn test_buffer_skip_whitespace() -> i32
    # Skip whitespace
    var buf: Buffer
    buf_from_str(@buf, "   abc" as *u8)

    let skipped: i64 = buf_skip_whitespace(@buf)
    if skipped != 3
        return 1
    if buf.pos != 3
        return 2
    if buf_peek(@buf) != 97  # 'a'
        return 3
    return 0

[[test]]
fn test_buffer_save_restore() -> i32
    # Save and restore position
    var buf: Buffer
    buf_from_str(@buf, "hello" as *u8)

    buf_advance(@buf)
    buf_advance(@buf)

    let saved: i64 = buf_save(@buf)
    if saved != 2
        return 1

    buf_advance(@buf)
    buf_advance(@buf)
    if buf.pos != 4
        return 2

    buf_restore(@buf, saved)
    if buf.pos != 2
        return 3
    return 0

[[test]]
fn test_buffer_get_loc() -> i32
    # Line/column tracking
    var buf: Buffer
    let text = "line1\nline2\nline3" as *u8
    buf_from_str(@buf, text)

    var loc: BufLoc

    # At start
    buf_get_loc(@buf, @loc)
    if loc.line != 1
        return 1
    if loc.col != 1
        return 2

    # Skip to second line
    buf_skip(@buf, 6)  # "line1\n"
    buf_get_loc(@buf, @loc)
    if loc.line != 2
        return 3
    if loc.col != 1
        return 4

    # Middle of second line
    buf_skip(@buf, 2)  # "li"
    buf_get_loc(@buf, @loc)
    if loc.line != 2
        return 5
    if loc.col != 3
        return 6

    return 0

[[test]]
fn test_buffer_read_until() -> i32
    # Read until delimiter
    var buf: Buffer
    buf_from_str(@buf, "hello,world" as *u8)

    var out: [16]u8
    let count: i64 = buf_read_until(@buf, 44, @out[0], 16)  # comma

    if count != 5
        return 1
    if out[0] != 104  # 'h'
        return 2
    if out[4] != 111  # 'o'
        return 3
    if out[5] != 0    # null terminator
        return 4
    return 0

[[test]]
fn test_buffer_read_while_digit() -> i32
    # Read digits
    var buf: Buffer
    buf_from_str(@buf, "12345abc" as *u8)

    var out: [16]u8
    let count: i64 = buf_read_while_digit(@buf, @out[0], 16)

    if count != 5
        return 1
    if out[0] != 49  # '1'
        return 2
    if out[4] != 53  # '5'
        return 3
    return 0

[[test]]
fn test_buffer_starts_with() -> i32
    # Check prefix without consuming
    var buf: Buffer
    buf_from_str(@buf, "hello world" as *u8)

    if buf_starts_with(@buf, "hello" as *u8) != 1
        return 1
    if buf.pos != 0  # Position unchanged
        return 2
    if buf_starts_with(@buf, "world" as *u8) != 0  # Not at start
        return 3
    return 0
