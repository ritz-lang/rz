# Tests for Span<T> - non-owning views into memory

import ritzlib.span
import ritzlib.gvec

# ============================================================================
# Span<u8> construction tests
# ============================================================================

[[test]]
fn test_span_empty() -> i32
    var s: Span<u8> = span_empty<u8>()
    assert s.len == 0
    assert s.ptr == null
    0

[[test]]
fn test_span_from_cstr() -> i32
    var s: Span<u8> = span_from_cstr("hello")
    assert s.len == 5
    assert s.ptr != null
    0

[[test]]
fn test_span_from_ptr() -> i32
    var data: [4]u8 = [10, 20, 30, 40]
    var s: Span<u8> = span_from_ptr<u8>(@data[0], 4)
    assert s.len == 4
    assert span_get<u8>(@s, 0) == '\n'
    assert span_get<u8>(@s, 3) == 40
    0

[[test]]
fn test_span_from_vec() -> i32
    var v: Vec<u8> = vec_new<u8>()
    v.push(1)
    v.push(2)
    v.push(3)
    var s: Span<u8> = span_from_vec<u8>(@v)
    assert s.len == 3
    assert span_get<u8>(@s, 0) == 1
    assert span_get<u8>(@s, 2) == 3
    0

# ============================================================================
# Span<u8> accessor tests
# ============================================================================

[[test]]
fn test_span_len() -> i32
    var s: Span<u8> = span_from_cstr("test")
    assert span_len<u8>(@s) == 4
    0

[[test]]
fn test_span_is_empty() -> i32
    var empty: Span<u8> = span_empty<u8>()
    var nonempty: Span<u8> = span_from_cstr("a")
    assert span_is_empty<u8>(@empty) == 1
    assert span_is_empty<u8>(@nonempty) == 0
    0

[[test]]
fn test_span_get() -> i32
    var s: Span<u8> = span_from_cstr("abc")
    assert span_get<u8>(@s, 0) == 'a'  # 'a'
    assert span_get<u8>(@s, 1) == 'b'  # 'b'
    assert span_get<u8>(@s, 2) == 'c'  # 'c'
    0

# ============================================================================
# Span<u8> slicing tests
# ============================================================================

[[test]]
fn test_span_slice_basic() -> i32
    var s: Span<u8> = span_from_cstr("hello")
    var sub: Span<u8> = span_slice<u8>(@s, 1, 4)  # "ell"
    assert sub.len == 3
    assert span_get<u8>(@sub, 0) == 'e'  # 'e'
    assert span_get<u8>(@sub, 1) == 108  # 'l'
    assert span_get<u8>(@sub, 2) == 108  # 'l'
    0

[[test]]
fn test_span_slice_from() -> i32
    var s: Span<u8> = span_from_cstr("hello")
    var sub: Span<u8> = span_from<u8>(@s, 2)  # "llo"
    assert sub.len == 3
    assert span_get<u8>(@sub, 0) == 108  # 'l'
    0

[[test]]
fn test_span_slice_to() -> i32
    var s: Span<u8> = span_from_cstr("hello")
    var sub: Span<u8> = span_to<u8>(@s, 2)  # "he"
    assert sub.len == 2
    assert span_get<u8>(@sub, 0) == 104  # 'h'
    assert span_get<u8>(@sub, 1) == 'e'  # 'e'
    0

# ============================================================================
# Span<u8> comparison tests
# ============================================================================

[[test]]
fn test_span_eq() -> i32
    var a: Span<u8> = span_from_cstr("hello")
    var b: Span<u8> = span_from_cstr("hello")
    var c: Span<u8> = span_from_cstr("world")
    assert span_eq(@a, @b) == 1
    assert span_eq(@a, @c) == 0
    0

[[test]]
fn test_span_eq_empty() -> i32
    var a: Span<u8> = span_empty<u8>()
    var b: Span<u8> = span_empty<u8>()
    assert span_eq(@a, @b) == 1
    0

# ============================================================================
# Span<u8> search tests
# ============================================================================

[[test]]
fn test_span_contains() -> i32
    var haystack: Span<u8> = span_from_cstr("hello world")
    var needle: Span<u8> = span_from_cstr("world")
    var missing: Span<u8> = span_from_cstr("foo")
    assert span_contains(@haystack, @needle) == 1
    assert span_contains(@haystack, @missing) == 0
    0

[[test]]
fn test_span_contains_empty() -> i32
    var haystack: Span<u8> = span_from_cstr("hello")
    var empty: Span<u8> = span_empty<u8>()
    assert span_contains(@haystack, @empty) == 1
    0

[[test]]
fn test_span_starts_with() -> i32
    var s: Span<u8> = span_from_cstr("hello world")
    var prefix: Span<u8> = span_from_cstr("hello")
    var not_prefix: Span<u8> = span_from_cstr("world")
    assert span_starts_with(@s, @prefix) == 1
    assert span_starts_with(@s, @not_prefix) == 0
    0

[[test]]
fn test_span_ends_with() -> i32
    var s: Span<u8> = span_from_cstr("hello world")
    var suffix: Span<u8> = span_from_cstr("world")
    var not_suffix: Span<u8> = span_from_cstr("hello")
    assert span_ends_with(@s, @suffix) == 1
    assert span_ends_with(@s, @not_suffix) == 0
    0

[[test]]
fn test_span_find() -> i32
    var haystack: Span<u8> = span_from_cstr("hello world")
    var needle: Span<u8> = span_from_cstr("world")
    var missing: Span<u8> = span_from_cstr("foo")
    assert span_find(@haystack, @needle) == 6
    assert span_find(@haystack, @missing) == -1
    0

[[test]]
fn test_span_find_at_start() -> i32
    var haystack: Span<u8> = span_from_cstr("hello world")
    var needle: Span<u8> = span_from_cstr("hello")
    assert span_find(@haystack, @needle) == 0
    0

# ============================================================================
# Span<i64> tests (different element type)
# ============================================================================

[[test]]
fn test_span_i64() -> i32
    var v: Vec<i64> = vec_new<i64>()
    v.push(100)
    v.push(200)
    v.push(300)
    var s: Span<i64> = span_from_vec<i64>(@v)
    assert s.len == 3
    assert span_get<i64>(@s, 0) == 'd'
    assert span_get<i64>(@s, 2) == 300
    0

[[test]]
fn test_span_i64_slice() -> i32
    var v: Vec<i64> = vec_new<i64>()
    v.push(10)
    v.push(20)
    v.push(30)
    v.push(40)
    var s: Span<i64> = span_from_vec<i64>(@v)
    var sub: Span<i64> = span_slice<i64>(@s, 1, 3)
    assert sub.len == 2
    assert span_get<i64>(@sub, 0) == 20
    assert span_get<i64>(@sub, 1) == 30
    0

# ============================================================================
# Method syntax tests
# ============================================================================

[[test]]
fn test_span_method_len() -> i32
    var s: Span<u8> = span_from_cstr("test")
    assert s.len() == 4
    0

[[test]]
fn test_span_method_is_empty() -> i32
    var empty: Span<u8> = span_empty<u8>()
    var nonempty: Span<u8> = span_from_cstr("a")
    assert empty.is_empty() == 1
    assert nonempty.is_empty() == 0
    0

[[test]]
fn test_span_method_slice() -> i32
    var s: Span<u8> = span_from_cstr("hello")
    var sub: Span<u8> = s.slice(1, 4)
    assert sub.len() == 3
    0
