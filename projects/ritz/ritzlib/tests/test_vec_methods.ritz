# Tests for Vec<T> method syntax (v.method() instead of vec_method<T>(@v))
import ritzlib.gvec

# ============================================================================
# Basic method tests
# ============================================================================

[[test]]
fn test_vec_method_len() -> i32
    var v: Vec<i64> = vec_new<i64>()
    if v.len() != 0
        return 1
    v.push(10)
    if v.len() != 1
        return 2
    return 0

[[test]]
fn test_vec_method_cap() -> i32
    var v: Vec<i64> = vec_with_cap<i64>(16)
    if v.cap() < 16
        return 1
    return 0

[[test]]
fn test_vec_method_is_empty_true() -> i32
    var v: Vec<i32> = vec_new<i32>()
    if v.is_empty() == 0
        return 1
    return 0

[[test]]
fn test_vec_method_is_empty_false() -> i32
    var v: Vec<i32> = vec_new<i32>()
    v.push(42)
    if v.is_empty() == 1
        return 1
    return 0

[[test]]
fn test_vec_method_push() -> i32
    var v: Vec<i64> = vec_new<i64>()
    v.push(100)
    v.push(200)
    v.push(300)
    if v.len() != 3
        return 1
    return 0

[[test]]
fn test_vec_method_pop() -> i32
    var v: Vec<i64> = vec_new<i64>()
    v.push(10)
    v.push(20)
    v.push(30)
    let x: i64 = v.pop()
    if x != 30
        return 1
    if v.len() != 2
        return 2
    return 0

[[test]]
fn test_vec_method_get() -> i32
    var v: Vec<i64> = vec_new<i64>()
    v.push(100)
    v.push(200)
    v.push(300)
    if v.get(0) != 100
        return 1
    if v.get(1) != 200
        return 2
    if v.get(2) != 300
        return 3
    return 0

[[test]]
fn test_vec_method_set() -> i32
    var v: Vec<i64> = vec_new<i64>()
    v.push(1)
    v.push(2)
    v.push(3)
    v.set(1, 42)
    if v.get(1) != 42
        return 1
    return 0

[[test]]
fn test_vec_method_clear() -> i32
    var v: Vec<i64> = vec_new<i64>()
    v.push(1)
    v.push(2)
    v.push(3)
    v.clear()
    if v.len() != 0
        return 1
    if v.is_empty() == 0
        return 2
    return 0

[[test]]
fn test_vec_method_first() -> i32
    var v: Vec<i64> = vec_new<i64>()
    v.push(100)
    v.push(200)
    v.push(300)
    if v.first() != 100
        return 1
    return 0

[[test]]
fn test_vec_method_last() -> i32
    var v: Vec<i64> = vec_new<i64>()
    v.push(100)
    v.push(200)
    v.push(300)
    if v.last() != 300
        return 1
    return 0

[[test]]
fn test_vec_method_slice() -> i32
    var v: Vec<i64> = vec_new<i64>()
    v.push(10)
    v.push(20)
    v.push(30)
    v.push(40)
    v.push(50)

    var part: Vec<i64> = v.slice(1, 4)
    if part.len() != 3
        return 1
    if part.get(0) != 20
        return 2
    if part.get(1) != 30
        return 3
    if part.get(2) != 40
        return 4
    return 0

# ============================================================================
# Chaining tests
# ============================================================================

[[test]]
fn test_vec_method_chaining() -> i32
    var v: Vec<i64> = vec_new<i64>()
    v.push(1)
    v.push(2)
    v.push(3)

    # Chain: get slice, then get length
    var part: Vec<i64> = v.slice(0, 2)
    if part.len() != 2
        return 1

    # Get first from slice
    if part.first() != 1
        return 2

    # Get last from slice
    if part.last() != 2
        return 3

    return 0

# ============================================================================
# Type variations (ensure generic impl works for different types)
# ============================================================================

[[test]]
fn test_vec_method_i32() -> i32
    var v: Vec<i32> = vec_new<i32>()
    v.push(42 as i32)
    v.push(99 as i32)
    if v.len() != 2
        return 1
    if v.get(0) != 42 as i32
        return 2
    return 0

[[test]]
fn test_vec_method_u8() -> i32
    var v: Vec<u8> = vec_new<u8>()
    v.push(65)  # 'A'
    v.push(66)  # 'B'
    v.push(67)  # 'C'
    if v.len() != 3
        return 1
    if v.first() != 65
        return 2
    if v.last() != 67
        return 3
    return 0
