# Test BitOps intrinsics for primitive integer types
#
# These tests verify that bit manipulation operations work correctly
# on all integer types. The implementation uses LLVM intrinsics for
# optimal codegen.

import ritzlib.sys
import ritzlib.io

# ============================================================================
# rotate left (rotl) tests
# ============================================================================

[[test]]
fn test_u32_rotl_basic() -> i32
    let x: u32 = 0x12345678
    # Rotate left by 8: 0x12345678 -> 0x34567812
    let result: u32 = x.rotl(8)
    if result == 0x34567812
        return 0
    return 1

[[test]]
fn test_u32_rotl_zero() -> i32
    let x: u32 = 0xdeadbeef
    # Rotate by 0 should be identity
    let result: u32 = x.rotl(0)
    if result == 0xdeadbeef
        return 0
    return 1

[[test]]
fn test_u32_rotl_full() -> i32
    let x: u32 = 0xdeadbeef
    # Rotate by 32 should be identity
    let result: u32 = x.rotl(32)
    if result == 0xdeadbeef
        return 0
    return 1

[[test]]
fn test_u64_rotl() -> i32
    let x: u64 = 0x123456789abcdef0
    let result: u64 = x.rotl(16)
    if result == 0x56789abcdef01234
        return 0
    return 1

[[test]]
fn test_u8_rotl() -> i32
    let x: u8 = 0b10110001
    # Rotate left by 3: 10110001 -> 10001101
    let result: u8 = x.rotl(3)
    if result == 0b10001101
        return 0
    return 1

# ============================================================================
# rotate right (rotr) tests
# ============================================================================

[[test]]
fn test_u32_rotr_basic() -> i32
    let x: u32 = 0x12345678
    # Rotate right by 8: 0x12345678 -> 0x78123456
    let result: u32 = x.rotr(8)
    if result == 0x78123456
        return 0
    return 1

[[test]]
fn test_u32_rotr_zero() -> i32
    let x: u32 = 0xdeadbeef
    let result: u32 = x.rotr(0)
    if result == 0xdeadbeef
        return 0
    return 1

[[test]]
fn test_u64_rotr() -> i32
    let x: u64 = 0x123456789abcdef0
    let result: u64 = x.rotr(16)
    if result == 0xdef0123456789abc
        return 0
    return 1

# ============================================================================
# count leading zeros (clz) tests
# ============================================================================

[[test]]
fn test_u32_clz_zero() -> i32
    let x: u32 = 0
    # All zeros -> 32 leading zeros
    let result: u8 = x.clz()
    if result == 32
        return 0
    return 1

[[test]]
fn test_u32_clz_one() -> i32
    let x: u32 = 1
    # 0x00000001 -> 31 leading zeros
    let result: u8 = x.clz()
    if result == 31
        return 0
    return 1

[[test]]
fn test_u32_clz_high_bit() -> i32
    let x: u32 = 0x80000000
    # High bit set -> 0 leading zeros
    let result: u8 = x.clz()
    if result == 0
        return 0
    return 1

[[test]]
fn test_u64_clz() -> i32
    let x: u64 = 0x0000000100000000
    # Bit 32 set -> 31 leading zeros
    let result: u8 = x.clz()
    if result == 31
        return 0
    return 1

# ============================================================================
# count trailing zeros (ctz) tests
# ============================================================================

[[test]]
fn test_u32_ctz_zero() -> i32
    let x: u32 = 0
    # All zeros -> 32 trailing zeros
    let result: u8 = x.ctz()
    if result == 32
        return 0
    return 1

[[test]]
fn test_u32_ctz_one() -> i32
    let x: u32 = 1
    # Bit 0 set -> 0 trailing zeros
    let result: u8 = x.ctz()
    if result == 0
        return 0
    return 1

[[test]]
fn test_u32_ctz_high_bit() -> i32
    let x: u32 = 0x80000000
    # Only high bit set -> 31 trailing zeros
    let result: u8 = x.ctz()
    if result == 31
        return 0
    return 1

[[test]]
fn test_u32_ctz_low_nibble() -> i32
    let x: u32 = 0x10
    # Bit 4 set -> 4 trailing zeros
    let result: u8 = x.ctz()
    if result == 4
        return 0
    return 1

# ============================================================================
# population count (popcnt) tests
# ============================================================================

[[test]]
fn test_u32_popcnt_zero() -> i32
    let x: u32 = 0
    let result: u8 = x.popcnt()
    if result == 0
        return 0
    return 1

[[test]]
fn test_u32_popcnt_all_ones() -> i32
    let x: u32 = 0xffffffff
    let result: u8 = x.popcnt()
    if result == 32
        return 0
    return 1

[[test]]
fn test_u32_popcnt_alternating() -> i32
    let x: u32 = 0xaaaaaaaa  # 10101010... -> 16 bits set
    let result: u8 = x.popcnt()
    if result == 16
        return 0
    return 1

[[test]]
fn test_u64_popcnt() -> i32
    let x: u64 = 0xf0f0f0f0f0f0f0f0  # 4 bits per byte * 8 = 32
    let result: u8 = x.popcnt()
    if result == 32
        return 0
    return 1

# ============================================================================
# byte swap (swap_bytes) tests
# ============================================================================

[[test]]
fn test_u32_swap_bytes() -> i32
    let x: u32 = 0x12345678
    let result: u32 = x.swap_bytes()
    if result == 0x78563412
        return 0
    return 1

[[test]]
fn test_u64_swap_bytes() -> i32
    let x: u64 = 0x0102030405060708
    let result: u64 = x.swap_bytes()
    if result == 0x0807060504030201
        return 0
    return 1

[[test]]
fn test_u16_swap_bytes() -> i32
    let x: u16 = 0x1234
    let result: u16 = x.swap_bytes()
    if result == 0x3412
        return 0
    return 1

# ============================================================================
# Practical cryptography use case: ChaCha20 quarter round
# ============================================================================

[[test]]
fn test_chacha20_quarter_round() -> i32
    # Simplified quarter round to verify rotl works in context
    var a: u32 = 0x11111111
    var b: u32 = 0x01020304
    var c: u32 = 0x9b8d6f43
    var d: u32 = 0x01234567

    # One iteration of quarter round operations
    a = a + b
    d = (d ^ a).rotl(16)
    c = c + d
    b = (b ^ c).rotl(12)
    a = a + b
    d = (d ^ a).rotl(8)
    c = c + d
    b = (b ^ c).rotl(7)

    # Just verify it runs without crashing and produces some result
    # (actual crypto tests would verify against test vectors)
    if a != 0x11111111  # Should have changed
        return 0
    return 1

fn main() -> i32
    return 0
