# Test Option<T> from ritzlib
import ritzlib.option

[[test]]
fn test_option_some_i32() -> i32
    var opt: Option<i32> = Some(42)
    let result = match opt
        Some(x) => x
        None => 0
    if result == 42
        return 0
    return 1

[[test]]
fn test_option_none_i32() -> i32
    var opt: Option<i32> = None
    let result = match opt
        Some(x) => x
        None => 100
    if result == 100
        return 0
    return 1

[[test]]
fn test_option_some_i64() -> i32
    var opt: Option<i64> = Some(9999)
    let result = match opt
        Some(x) => x
        None => 0
    if result == 9999
        return 0
    return 1

[[test]]
fn test_option_is_some() -> i32
    var opt: Option<i32> = Some(1)
    if option_is_some<i32>(@opt) == 1
        return 0
    return 1

[[test]]
fn test_option_is_none() -> i32
    var opt: Option<i32> = None
    if option_is_none<i32>(@opt) == 1
        return 0
    return 1

[[test]]
fn test_option_unwrap_or_some() -> i32
    var opt: Option<i32> = Some(42)
    let result = option_unwrap_or<i32>(@opt, 0)
    if result == 42
        return 0
    return 1

[[test]]
fn test_option_unwrap_or_none() -> i32
    var opt: Option<i32> = None
    let result = option_unwrap_or<i32>(@opt, 99)
    if result == 99
        return 0
    return 1

fn main() -> i32
    test_option_some_i32()
    test_option_none_i32()
    test_option_some_i64()
    test_option_is_some()
    test_option_is_none()
    test_option_unwrap_or_some()
    test_option_unwrap_or_none()
    return 0
