# Tests for fs.ritz String-based path functions
import ritzlib.fs
import ritzlib.string
import ritzlib.result

# ============================================================================
# Path manipulation tests
# ============================================================================

[[test]]
fn test_path_join_string() -> i32
    var dir: String = string_from("/home/user")
    var name: String = string_from("file.txt")
    var result: String = path_join_string(@dir, @name)
    var expected: String = string_from("/home/user/file.txt")
    if string_eq(@result, @expected) == 0
        return 1
    return 0

[[test]]
fn test_path_join_string_trailing_slash() -> i32
    var dir: String = string_from("/home/user/")
    var name: String = string_from("file.txt")
    var result: String = path_join_string(@dir, @name)
    var expected: String = string_from("/home/user/file.txt")
    if string_eq(@result, @expected) == 0
        return 1
    return 0

[[test]]
fn test_path_basename_string() -> i32
    var path: String = string_from("/home/user/file.txt")
    var result: String = path_basename_string(@path)
    var expected: String = string_from("file.txt")
    if string_eq(@result, @expected) == 0
        return 1
    return 0

[[test]]
fn test_path_basename_string_no_slash() -> i32
    var path: String = string_from("file.txt")
    var result: String = path_basename_string(@path)
    var expected: String = string_from("file.txt")
    if string_eq(@result, @expected) == 0
        return 1
    return 0

[[test]]
fn test_path_dirname_string() -> i32
    var path: String = string_from("/home/user/file.txt")
    var result: String = path_dirname_string(@path)
    var expected: String = string_from("/home/user")
    if string_eq(@result, @expected) == 0
        return 1
    return 0

[[test]]
fn test_path_dirname_string_root() -> i32
    var path: String = string_from("/file.txt")
    var result: String = path_dirname_string(@path)
    var expected: String = string_from("/")
    if string_eq(@result, @expected) == 0
        return 1
    return 0

[[test]]
fn test_path_dirname_string_no_slash() -> i32
    var path: String = string_from("file.txt")
    var result: String = path_dirname_string(@path)
    var expected: String = string_from(".")
    if string_eq(@result, @expected) == 0
        return 1
    return 0

[[test]]
fn test_path_extension_string() -> i32
    var path: String = string_from("/home/user/file.txt")
    var result: String = path_extension_string(@path)
    var expected: String = string_from("txt")
    if string_eq(@result, @expected) == 0
        return 1
    return 0

[[test]]
fn test_path_extension_string_none() -> i32
    var path: String = string_from("/home/user/file")
    var result: String = path_extension_string(@path)
    if string_len(@result) != 0
        return 1
    return 0

[[test]]
fn test_path_extension_string_dotfile() -> i32
    # .gitignore should have no extension (dot at start of basename)
    var path: String = string_from("/home/user/.gitignore")
    var result: String = path_extension_string(@path)
    var expected: String = string_from("gitignore")
    # Actually ".gitignore" has extension "gitignore" - the dot is at start of basename
    # Wait, no - the dot at position 11 is after the slash at 10, so it's last_slash + 1
    # So the condition last_dot == last_slash + 1 catches this case
    if string_len(@result) != 0
        return 1
    return 0

[[test]]
fn test_path_stem_string() -> i32
    var path: String = string_from("/home/user/file.txt")
    var result: String = path_stem_string(@path)
    var expected: String = string_from("/home/user/file")
    if string_eq(@result, @expected) == 0
        return 1
    return 0

[[test]]
fn test_path_stem_string_no_ext() -> i32
    var path: String = string_from("/home/user/file")
    var result: String = path_stem_string(@path)
    var expected: String = string_from("/home/user/file")
    if string_eq(@result, @expected) == 0
        return 1
    return 0

# ============================================================================
# File system operation tests (using actual filesystem)
# ============================================================================

[[test]]
fn test_path_exists_string_current_dir() -> i32
    var path: String = string_from(".")
    if path_exists_string(@path) == 0
        return 1
    return 0

[[test]]
fn test_path_exists_string_nonexistent() -> i32
    var path: String = string_from("/nonexistent/path/that/should/not/exist")
    if path_exists_string(@path) == 1
        return 1
    return 0

[[test]]
fn test_is_directory_string() -> i32
    var path: String = string_from(".")
    if is_directory_string(@path) == 0
        return 1
    return 0

[[test]]
fn test_is_regular_file_string() -> i32
    # This test file itself should exist and be a regular file
    var path: String = string_from("ritzlib/tests/test_fs.ritz")
    if is_regular_file_string(@path) == 0
        return 1
    return 0

[[test]]
fn test_file_size_string_ok() -> i32
    var path: String = string_from(".")
    var result: Result<i64, i32> = file_size_string(@path)
    if result_is_ok<i64, i32>(@result) == 0
        return 1
    # Directory size should be positive
    let size: i64 = result_unwrap_or<i64, i32>(@result, 0 - 1)
    if size < 0
        return 2
    return 0

[[test]]
fn test_file_size_string_err() -> i32
    var path: String = string_from("/nonexistent/path")
    var result: Result<i64, i32> = file_size_string(@path)
    if result_is_err<i64, i32>(@result) == 0
        return 1
    return 0
