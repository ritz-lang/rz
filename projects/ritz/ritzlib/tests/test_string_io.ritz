# Tests for String type extensions and io.ritz String functions
import ritzlib.string
import ritzlib.io

# Helper to compare a String to expected bytes (no null termination dependency)
fn expect_string(s: *String, expected: *String) -> i32
    return string_eq(s, expected)

[[test]]
fn test_string_from_i64_zero() -> i32
    var s: String = string_from_i64(0)
    if string_len(@s) != 1
        return 1
    if string_get(@s, 0) != 48  # '0'
        return 2
    return 0

[[test]]
fn test_string_from_i64_positive() -> i32
    var s: String = string_from_i64(12345)
    var expected: String = string_from("12345")
    if string_len(@s) != 5
        return 1
    if string_eq(@s, @expected) == 0
        return 2
    return 0

[[test]]
fn test_string_from_i64_negative() -> i32
    var s: String = string_from_i64(0 - 42)
    var expected: String = string_from("-42")
    if string_len(@s) != 3
        return 1
    if string_eq(@s, @expected) == 0
        return 2
    return 0

[[test]]
fn test_string_from_i64_large() -> i32
    var s: String = string_from_i64(9223372036854775807)  # i64 max
    var expected: String = string_from("9223372036854775807")
    if string_eq(@s, @expected) == 0
        return 1
    return 0

[[test]]
fn test_string_push_i64() -> i32
    var s: String = string_from("value: ")
    string_push_i64(@s, 123)
    var expected: String = string_from("value: 123")
    if string_eq(@s, @expected) == 0
        return 1
    return 0

[[test]]
fn test_string_push_i64_negative() -> i32
    var s: String = string_from("x=")
    string_push_i64(@s, 0 - 999)
    var expected: String = string_from("x=-999")
    if string_eq(@s, @expected) == 0
        return 1
    return 0

[[test]]
fn test_string_from_hex_zero() -> i32
    var s: String = string_from_hex(0 as u64)
    var expected: String = string_from("0x0")
    if string_eq(@s, @expected) == 0
        return 1
    return 0

[[test]]
fn test_string_from_hex_value() -> i32
    var s: String = string_from_hex(255 as u64)
    var expected: String = string_from("0xff")
    if string_eq(@s, @expected) == 0
        return 1
    return 0

[[test]]
fn test_string_from_hex_large() -> i32
    var s: String = string_from_hex(0xdeadbeef as u64)
    var expected: String = string_from("0xdeadbeef")
    if string_eq(@s, @expected) == 0
        return 1
    return 0

[[test]]
fn test_string_push_bytes() -> i32
    var s: String = string_new()
    var data: [5]u8
    data[0] = 72   # 'H'
    data[1] = 101  # 'e'
    data[2] = 108  # 'l'
    data[3] = 108  # 'l'
    data[4] = 111  # 'o'
    string_push_bytes(@s, @data[0], 5)
    if string_len(@s) != 5
        return 1
    var expected: String = string_from("Hello")
    if string_eq(@s, @expected) == 0
        return 2
    return 0

[[test]]
fn test_string_push_bytes_partial() -> i32
    var s: String = string_from("Hi")
    var data: [10]u8
    data[0] = 32   # ' '
    data[1] = 84   # 'T'
    data[2] = 104  # 'h'
    data[3] = 101  # 'e'
    data[4] = 114  # 'r'
    data[5] = 101  # 'e'
    # Push only first 3 bytes: " Th"
    string_push_bytes(@s, @data[0], 3)
    var expected: String = string_from("Hi Th")
    if string_eq(@s, @expected) == 0
        return 1
    return 0

[[test]]
fn test_string_from_bytes() -> i32
    var data: [3]u8
    data[0] = 65  # 'A'
    data[1] = 66  # 'B'
    data[2] = 67  # 'C'
    var s: String = string_from_bytes(@data[0], 3)
    if string_len(@s) != 3
        return 1
    var expected: String = string_from("ABC")
    if string_eq(@s, @expected) == 0
        return 2
    return 0

# ============================================================================
# String predicate tests (String-to-String versions)
# ============================================================================

[[test]]
fn test_string_starts_with_string() -> i32
    var s: String = string_from("hello world")
    var prefix: String = string_from("hello")
    if string_starts_with_string(@s, @prefix) == 0
        return 1
    return 0

[[test]]
fn test_string_starts_with_string_no_match() -> i32
    var s: String = string_from("hello world")
    var prefix: String = string_from("world")
    if string_starts_with_string(@s, @prefix) == 1
        return 1
    return 0

[[test]]
fn test_string_ends_with_string() -> i32
    var s: String = string_from("hello world")
    var suffix: String = string_from("world")
    if string_ends_with_string(@s, @suffix) == 0
        return 1
    return 0

[[test]]
fn test_string_ends_with_string_no_match() -> i32
    var s: String = string_from("hello world")
    var suffix: String = string_from("hello")
    if string_ends_with_string(@s, @suffix) == 1
        return 1
    return 0

[[test]]
fn test_string_contains_string() -> i32
    var s: String = string_from("hello world")
    var needle: String = string_from("lo wo")
    if string_contains_string(@s, @needle) == 0
        return 1
    return 0

[[test]]
fn test_string_contains_string_no_match() -> i32
    var s: String = string_from("hello world")
    var needle: String = string_from("xyz")
    if string_contains_string(@s, @needle) == 1
        return 1
    return 0

[[test]]
fn test_string_find() -> i32
    var s: String = string_from("hello world")
    var needle: String = string_from("world")
    let idx: i64 = string_find(@s, @needle)
    if idx != 6
        return 1
    return 0

[[test]]
fn test_string_find_not_found() -> i32
    var s: String = string_from("hello world")
    var needle: String = string_from("xyz")
    let idx: i64 = string_find(@s, @needle)
    if idx != 0 - 1
        return 1
    return 0

[[test]]
fn test_string_slice() -> i32
    var s: String = string_from("hello world")
    var slice: String = string_slice(@s, 6, 11)
    var expected: String = string_from("world")
    if string_eq(@slice, @expected) == 0
        return 1
    return 0

[[test]]
fn test_string_slice_bounds() -> i32
    var s: String = string_from("abc")
    # Test out-of-bounds clamping
    var slice: String = string_slice(@s, 0 - 5, 100)
    var expected: String = string_from("abc")
    if string_eq(@slice, @expected) == 0
        return 1
    return 0

[[test]]
fn test_string_char_at() -> i32
    var s: String = string_from("ABC")
    if string_char_at(@s, 0) != 65
        return 1
    if string_char_at(@s, 1) != 66
        return 2
    if string_char_at(@s, 2) != 67
        return 3
    # Out of bounds returns 0
    if string_char_at(@s, 10) != 0
        return 4
    return 0

[[test]]
fn test_string_set_char() -> i32
    var s: String = string_from("ABC")
    if string_set_char(@s, 1, 88) != 0  # 'X'
        return 1
    var expected: String = string_from("AXC")
    if string_eq(@s, @expected) == 0
        return 2
    return 0
