# Tests for Python-style slice syntax: s[start:end]
import ritzlib.string
import ritzlib.gvec

# ============================================================================
# String slice syntax tests
# ============================================================================

[[test]]
fn test_string_slice_basic() -> i32
    var s: String = string_from("hello world")
    var part: String = s[0:5]  # "hello"
    var expected: String = string_from("hello")
    if string_eq(@part, @expected) == 0
        return 1
    return 0

[[test]]
fn test_string_slice_middle() -> i32
    var s: String = string_from("hello world")
    var part: String = s[6:11]  # "world"
    var expected: String = string_from("world")
    if string_eq(@part, @expected) == 0
        return 1
    return 0

[[test]]
fn test_string_slice_from_start() -> i32
    var s: String = string_from("hello world")
    var part: String = s[:5]  # "hello" (omit start = 0)
    var expected: String = string_from("hello")
    if string_eq(@part, @expected) == 0
        return 1
    return 0

[[test]]
fn test_string_slice_to_end() -> i32
    var s: String = string_from("hello world")
    var part: String = s[6:]  # "world" (omit end = len)
    var expected: String = string_from("world")
    if string_eq(@part, @expected) == 0
        return 1
    return 0

[[test]]
fn test_string_slice_full() -> i32
    var s: String = string_from("hello")
    var part: String = s[:]  # full copy
    var expected: String = string_from("hello")
    if string_eq(@part, @expected) == 0
        return 1
    return 0

[[test]]
fn test_string_slice_empty() -> i32
    var s: String = string_from("hello")
    var part: String = s[2:2]  # empty slice
    if string_len(@part) != 0
        return 1
    return 0

[[test]]
fn test_string_slice_single_char() -> i32
    var s: String = string_from("hello")
    var part: String = s[1:2]  # "e"
    var expected: String = string_from("e")
    if string_eq(@part, @expected) == 0
        return 1
    return 0

# ============================================================================
# Vec slice syntax tests
# ============================================================================

[[test]]
fn test_vec_slice_basic() -> i32
    var v: Vec<i64> = vec_new<i64>()
    vec_push<i64>(@v, 10)
    vec_push<i64>(@v, 20)
    vec_push<i64>(@v, 30)
    vec_push<i64>(@v, 40)
    vec_push<i64>(@v, 50)

    var part: Vec<i64> = v[1:4]  # [20, 30, 40]
    if vec_len<i64>(@part) != 3
        return 1
    if vec_get<i64>(@part, 0) != 20
        return 2
    if vec_get<i64>(@part, 1) != 30
        return 3
    if vec_get<i64>(@part, 2) != 40
        return 4
    return 0

[[test]]
fn test_vec_slice_from_start() -> i32
    var v: Vec<i64> = vec_new<i64>()
    vec_push<i64>(@v, 1)
    vec_push<i64>(@v, 2)
    vec_push<i64>(@v, 3)

    var part: Vec<i64> = v[:2]  # [1, 2]
    if vec_len<i64>(@part) != 2
        return 1
    if vec_get<i64>(@part, 0) != 1
        return 2
    if vec_get<i64>(@part, 1) != 2
        return 3
    return 0

[[test]]
fn test_vec_slice_to_end() -> i32
    var v: Vec<i64> = vec_new<i64>()
    vec_push<i64>(@v, 1)
    vec_push<i64>(@v, 2)
    vec_push<i64>(@v, 3)

    var part: Vec<i64> = v[1:]  # [2, 3]
    if vec_len<i64>(@part) != 2
        return 1
    if vec_get<i64>(@part, 0) != 2
        return 2
    if vec_get<i64>(@part, 1) != 3
        return 3
    return 0

[[test]]
fn test_vec_slice_full() -> i32
    var v: Vec<i64> = vec_new<i64>()
    vec_push<i64>(@v, 100)
    vec_push<i64>(@v, 200)

    var part: Vec<i64> = v[:]  # full copy
    if vec_len<i64>(@part) != 2
        return 1
    if vec_get<i64>(@part, 0) != 100
        return 2
    if vec_get<i64>(@part, 1) != 200
        return 3
    return 0

[[test]]
fn test_vec_slice_empty() -> i32
    var v: Vec<i64> = vec_new<i64>()
    vec_push<i64>(@v, 1)
    vec_push<i64>(@v, 2)
    vec_push<i64>(@v, 3)

    var part: Vec<i64> = v[1:1]  # empty
    if vec_len<i64>(@part) != 0
        return 1
    return 0

# ============================================================================
# Combining index and slice
# ============================================================================

[[test]]
fn test_slice_and_index_combined() -> i32
    var s: String = string_from("hello world")
    # Slice then get character
    var part: String = s[0:5]  # "hello"
    if string_get(@part, 0) != 104  # 'h'
        return 1
    if string_get(@part, 4) != 111  # 'o'
        return 2
    return 0
