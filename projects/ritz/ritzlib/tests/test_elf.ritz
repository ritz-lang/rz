# Test the ELF parser by reading a compiled object file

import ritzlib.sys
import ritzlib.io
import ritzlib.memory
import ritzlib.elf

# lseek whence values
const SEEK_SET: i32 = 0
const SEEK_CUR: i32 = 1
const SEEK_END: i32 = 2

fn main(argc: i32, argv: **i8) -> i32
    if argc < 2
        prints("Usage: test_elf <file.o>\n")
        return 1

    let filename: *i8 = *(argv + 1)
    prints("Reading ELF file: ")
    prints(filename)
    prints("\n")

    # Open and read the file
    let fd: i32 = sys_open(filename as *u8, O_RDONLY)
    if fd < 0
        prints("Error: Could not open file\n")
        return 1

    # Get file size using lseek
    let size: i64 = sys_lseek(fd, 0, SEEK_END)
    sys_lseek(fd, 0, SEEK_SET)

    prints("File size: ")
    print_int(size as i32)
    prints(" bytes\n")

    # Allocate buffer and read file
    let data: *u8 = malloc(size)
    if data == null
        prints("Error: Could not allocate memory\n")
        sys_close(fd)
        return 1

    let bytes_read: i64 = sys_read(fd, data, size)
    sys_close(fd)

    if bytes_read != size
        prints("Error: Could not read entire file\n")
        return 1

    # Initialize ELF reader
    var reader: ElfReader
    if elf_init(@reader, data, size) != 0
        prints("Error: Not a valid ELF64 file\n")
        return 1

    prints("Valid ELF64 file\n")

    # Parse sections
    if elf_parse_sections(@reader) != 0
        prints("Error: Could not parse sections\n")
        return 1

    prints("Symbol count: ")
    print_int(elf_symbol_count(@reader) as i32)
    prints("\n")

    # Find test functions
    let test_count: i32 = elf_find_test_functions(@reader, null, null)
    prints("Test functions: ")
    print_int(test_count)
    prints("\n")

    # Print them
    elf_print_test_functions(@reader)

    free(data)
    return 0
