# Tests for String method syntax (s.method() instead of string_method(@s))
import ritzlib.string
import ritzlib.strview

# ============================================================================
# Basic method tests
# ============================================================================

[[test]]
fn test_method_len() -> i32
    var s: String = string_from("hello")
    if s.len() != 5
        return 1
    return 0

[[test]]
fn test_method_cap() -> i32
    var s: String = string_with_cap(100)
    if s.cap() < 100
        return 1
    return 0

[[test]]
fn test_method_is_empty_true() -> i32
    var s: String = string_new()
    if s.is_empty() == 0
        return 1
    return 0

[[test]]
fn test_method_is_empty_false() -> i32
    var s: String = string_from("x")
    if s.is_empty() == 1
        return 1
    return 0

[[test]]
fn test_method_get() -> i32
    var s: String = string_from("ABC")
    if s.get(0) != 65  # 'A'
        return 1
    if s.get(1) != 66  # 'B'
        return 2
    if s.get(2) != 67  # 'C'
        return 3
    return 0

[[test]]
fn test_method_push() -> i32
    var s: String = string_new()
    s.push(72)   # 'H'
    s.push(105)  # 'i'
    if s.len() != 2
        return 1
    if s.get(0) != 72
        return 2
    if s.get(1) != 105
        return 3
    return 0

[[test]]
fn test_method_push_string() -> i32
    var s: String = string_from("Hello")
    var world: String = string_from(" World")
    s.push_string(@world)
    var expected: String = string_from("Hello World")
    if s.eq(@expected) == 0
        return 1
    return 0

[[test]]
fn test_method_push_i64() -> i32
    var s: String = string_from("Count: ")
    s.push_i64(42)
    var expected: String = string_from("Count: 42")
    if s.eq(@expected) == 0
        return 1
    return 0

[[test]]
fn test_method_clear() -> i32
    var s: String = string_from("hello")
    s.clear()
    if s.len() != 0
        return 1
    if s.is_empty() == 0
        return 2
    return 0

[[test]]
fn test_method_pop() -> i32
    var s: String = string_from("abc")
    let c: u8 = s.pop()
    if c != 99  # 'c'
        return 1
    if s.len() != 2
        return 2
    return 0

[[test]]
fn test_method_clone() -> i32
    var s: String = string_from("original")
    var copy: String = s.clone()
    if s.eq(@copy) == 0
        return 1
    # Modify original, copy should be unchanged
    s.push(33)  # '!'
    if s.eq(@copy) == 1
        return 2
    return 0

[[test]]
fn test_method_char_at() -> i32
    var s: String = string_from("xyz")
    if s.char_at(0) != 120  # 'x'
        return 1
    if s.char_at(1) != 121  # 'y'
        return 2
    if s.char_at(2) != 122  # 'z'
        return 3
    # Out of bounds
    if s.char_at(10) != 0
        return 4
    return 0

[[test]]
fn test_method_set_char() -> i32
    var s: String = string_from("aaa")
    s.set_char(1, 98)  # 'b'
    var expected: String = string_from("aba")
    if s.eq(@expected) == 0
        return 1
    return 0

[[test]]
fn test_method_slice() -> i32
    var s: String = string_from("hello world")
    var part: String = s.slice(0, 5)
    var expected: String = string_from("hello")
    if part.eq(@expected) == 0
        return 1
    return 0

[[test]]
fn test_method_find() -> i32
    var s: String = string_from("hello world")
    var needle: String = string_from("world")
    let idx: i64 = s.find(@needle)
    if idx != 6
        return 1
    return 0

[[test]]
fn test_method_find_not_found() -> i32
    var s: String = string_from("hello")
    var needle: String = string_from("xyz")
    let idx: i64 = s.find(@needle)
    if idx != 0 - 1
        return 1
    return 0

[[test]]
fn test_method_starts_with() -> i32
    var s: String = string_from("hello world")
    var prefix: String = string_from("hello")
    if s.starts_with(@prefix) == 0
        return 1
    return 0

[[test]]
fn test_method_ends_with() -> i32
    var s: String = string_from("hello world")
    var suffix: String = string_from("world")
    if s.ends_with(@suffix) == 0
        return 1
    return 0

[[test]]
fn test_method_contains() -> i32
    var s: String = string_from("hello world")
    var needle: String = string_from("lo wo")
    if s.contains(@needle) == 0
        return 1
    return 0

[[test]]
fn test_method_eq() -> i32
    var a: String = string_from("test")
    var b: String = string_from("test")
    var c: String = string_from("different")
    if a.eq(@b) == 0
        return 1
    if a.eq(@c) == 1
        return 2
    return 0

[[test]]
fn test_method_hash() -> i32
    var s: String = string_from("hello")
    let h: u64 = s.hash()
    # Just verify hash returns a value (non-zero for non-empty string)
    if h == 0 as u64
        return 1
    return 0

# ============================================================================
# Chaining tests (method syntax enables fluent APIs)
# ============================================================================

[[test]]
fn test_method_chaining_slice_len() -> i32
    var s: String = string_from("hello world")
    var part: String = s.slice(6, 11)
    if part.len() != 5
        return 1
    return 0

# ============================================================================
# StrView interop tests
# ============================================================================

[[test]]
fn test_string_from_strview() -> i32
    let sv: StrView = strview_from_cstr(c"hello")
    var s: String = string_from_strview(@sv)
    if s.len() != 5
        return 1
    var expected: String = string_from(c"hello")
    if s.eq(@expected) == 0
        return 2
    return 0

[[test]]
fn test_string_from_strview_empty() -> i32
    let sv: StrView = strview_empty()
    var s: String = string_from_strview(@sv)
    if s.len() != 0
        return 1
    if s.is_empty() == 0
        return 2
    return 0

[[test]]
fn test_string_from_strview_partial() -> i32
    # Create a StrView of just "hel" from "hello"
    let full: *u8 = c"hello"
    let sv: StrView = strview_from_ptr(full, 3)
    var s: String = string_from_strview(@sv)
    if s.len() != 3
        return 1
    var expected: String = string_from(c"hel")
    if s.eq(@expected) == 0
        return 2
    return 0
