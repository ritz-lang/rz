# Test suite for ritzlib/meta.ritz
#
# Tests metadata parsing from .ritz-meta JSON files.
# Run with: python3 ritz0/ritz0.py --test ritzlib/tests/test_meta.ritz

import ritzlib.sys
import ritzlib.str
import ritzlib.memory
import ritzlib.json
import ritzlib.meta

# =============================================================================
# Minimal Metadata Parsing Tests
# =============================================================================

[[test]]
fn test_parse_empty_metadata() -> i32
    let json = "{\"source_path\": \"\", \"source_mtime\": 0, \"imports\": [], \"functions\": [], \"structs\": [], \"enums\": [], \"constants\": [], \"type_aliases\": [], \"traits\": []}"

    let m: *ModuleMetadata = meta_from_json(json, strlen(json))
    assert m != null
    assert m.function_count == 0
    assert m.struct_count == 0
    assert m.enum_count == 0
    assert m.constant_count == 0
    assert m.type_alias_count == 0
    assert m.trait_count == 0
    assert m.import_count == 0

    meta_free(m)
    0

[[test]]
fn test_parse_source_path() -> i32
    let json = "{\"source_path\": \"/path/to/file.ritz\", \"source_mtime\": 12345, \"imports\": [], \"functions\": [], \"structs\": [], \"enums\": [], \"constants\": [], \"type_aliases\": [], \"traits\": []}"

    let m: *ModuleMetadata = meta_from_json(json, strlen(json))
    assert m != null
    assert streq(m.source_path, "/path/to/file.ritz") != 0
    assert m.source_mtime == 12345

    meta_free(m)
    0

[[test]]
fn test_parse_imports() -> i32
    let json = "{\"source_path\": \"\", \"source_mtime\": 0, \"imports\": [\"ritzlib.sys\", \"ritzlib.str\"], \"functions\": [], \"structs\": [], \"enums\": [], \"constants\": [], \"type_aliases\": [], \"traits\": []}"

    let m: *ModuleMetadata = meta_from_json(json, strlen(json))
    assert m != null
    assert m.import_count == 2
    assert streq(*(m.imports + 0), "ritzlib.sys") != 0
    assert streq(*(m.imports + 1), "ritzlib.str") != 0

    meta_free(m)
    0

# =============================================================================
# Function Metadata Tests
# =============================================================================

[[test]]
fn test_parse_simple_function() -> i32
    let json = "{\"source_path\": \"\", \"source_mtime\": 0, \"imports\": [], \"functions\": [{\"name\": \"foo\", \"params\": [], \"ret_type\": \"void\", \"is_extern\": false, \"is_generic\": false, \"type_params\": []}], \"structs\": [], \"enums\": [], \"constants\": [], \"type_aliases\": [], \"traits\": []}"

    let m: *ModuleMetadata = meta_from_json(json, strlen(json))
    assert m != null
    assert m.function_count == 1

    let f: *FnSignature = m.functions
    assert streq(f.name, "foo") != 0
    assert streq(f.ret_type, "void") != 0
    assert f.param_count == 0
    assert f.is_extern == 0
    assert f.is_generic == 0

    meta_free(m)
    0

[[test]]
fn test_parse_function_with_params() -> i32
    let json = "{\"source_path\": \"\", \"source_mtime\": 0, \"imports\": [], \"functions\": [{\"name\": \"add\", \"params\": [{\"name\": \"a\", \"type\": \"i32\"}, {\"name\": \"b\", \"type\": \"i32\"}], \"ret_type\": \"i32\", \"is_extern\": false, \"is_generic\": false, \"type_params\": []}], \"structs\": [], \"enums\": [], \"constants\": [], \"type_aliases\": [], \"traits\": []}"

    let m: *ModuleMetadata = meta_from_json(json, strlen(json))
    assert m != null
    assert m.function_count == 1

    let f: *FnSignature = m.functions
    assert streq(f.name, "add") != 0
    assert f.param_count == 2

    let p1: *ParamMeta = f.params
    assert streq(p1.name, "a") != 0
    assert streq(p1.type_str, "i32") != 0

    let p2: *ParamMeta = f.params + 1
    assert streq(p2.name, "b") != 0
    assert streq(p2.type_str, "i32") != 0

    meta_free(m)
    0

[[test]]
fn test_parse_extern_function() -> i32
    let json = "{\"source_path\": \"\", \"source_mtime\": 0, \"imports\": [], \"functions\": [{\"name\": \"syscall0\", \"params\": [{\"name\": \"n\", \"type\": \"i64\"}], \"ret_type\": \"i64\", \"is_extern\": true, \"is_generic\": false, \"type_params\": []}], \"structs\": [], \"enums\": [], \"constants\": [], \"type_aliases\": [], \"traits\": []}"

    let m: *ModuleMetadata = meta_from_json(json, strlen(json))
    assert m != null
    assert m.function_count == 1

    let f: *FnSignature = m.functions
    assert streq(f.name, "syscall0") != 0
    assert f.is_extern != 0

    meta_free(m)
    0

# =============================================================================
# Struct Metadata Tests
# =============================================================================

[[test]]
fn test_parse_simple_struct() -> i32
    let json = "{\"source_path\": \"\", \"source_mtime\": 0, \"imports\": [], \"functions\": [], \"structs\": [{\"name\": \"Point\", \"fields\": [{\"name\": \"x\", \"type\": \"i32\"}, {\"name\": \"y\", \"type\": \"i32\"}], \"is_generic\": false, \"type_params\": []}], \"enums\": [], \"constants\": [], \"type_aliases\": [], \"traits\": []}"

    let m: *ModuleMetadata = meta_from_json(json, strlen(json))
    assert m != null
    assert m.struct_count == 1

    let s: *StructMeta = m.structs
    assert streq(s.name, "Point") != 0
    assert s.field_count == 2
    assert s.is_generic == 0

    let f1: *ParamMeta = s.fields
    assert streq(f1.name, "x") != 0
    assert streq(f1.type_str, "i32") != 0

    let f2: *ParamMeta = s.fields + 1
    assert streq(f2.name, "y") != 0
    assert streq(f2.type_str, "i32") != 0

    meta_free(m)
    0

# =============================================================================
# Constant Metadata Tests
# =============================================================================

[[test]]
fn test_parse_constants() -> i32
    let json = "{\"source_path\": \"\", \"source_mtime\": 0, \"imports\": [], \"functions\": [], \"structs\": [], \"enums\": [], \"constants\": [{\"name\": \"MAX_SIZE\", \"type\": \"i64\"}, {\"name\": \"PI\", \"type\": \"f64\"}], \"type_aliases\": [], \"traits\": []}"

    let m: *ModuleMetadata = meta_from_json(json, strlen(json))
    assert m != null
    assert m.constant_count == 2

    let c1: *ConstMeta = m.constants
    assert streq(c1.name, "MAX_SIZE") != 0
    assert streq(c1.type_str, "i64") != 0

    let c2: *ConstMeta = m.constants + 1
    assert streq(c2.name, "PI") != 0
    assert streq(c2.type_str, "f64") != 0

    meta_free(m)
    0

# =============================================================================
# Lookup Function Tests
# =============================================================================

[[test]]
fn test_find_function() -> i32
    let json = "{\"source_path\": \"\", \"source_mtime\": 0, \"imports\": [], \"functions\": [{\"name\": \"foo\", \"params\": [], \"ret_type\": \"void\", \"is_extern\": false, \"is_generic\": false, \"type_params\": []}, {\"name\": \"bar\", \"params\": [], \"ret_type\": \"i32\", \"is_extern\": false, \"is_generic\": false, \"type_params\": []}], \"structs\": [], \"enums\": [], \"constants\": [], \"type_aliases\": [], \"traits\": []}"

    let m: *ModuleMetadata = meta_from_json(json, strlen(json))
    assert m != null

    let foo: *FnSignature = meta_find_function(m, "foo")
    assert foo != null
    assert streq(foo.name, "foo") != 0

    let bar: *FnSignature = meta_find_function(m, "bar")
    assert bar != null
    assert streq(bar.name, "bar") != 0

    let baz: *FnSignature = meta_find_function(m, "baz")
    assert baz == null

    meta_free(m)
    0

[[test]]
fn test_find_struct() -> i32
    let json = "{\"source_path\": \"\", \"source_mtime\": 0, \"imports\": [], \"functions\": [], \"structs\": [{\"name\": \"Point\", \"fields\": [], \"is_generic\": false, \"type_params\": []}, {\"name\": \"Rect\", \"fields\": [], \"is_generic\": false, \"type_params\": []}], \"enums\": [], \"constants\": [], \"type_aliases\": [], \"traits\": []}"

    let m: *ModuleMetadata = meta_from_json(json, strlen(json))
    assert m != null

    let point: *StructMeta = meta_find_struct(m, "Point")
    assert point != null

    let rect: *StructMeta = meta_find_struct(m, "Rect")
    assert rect != null

    let missing: *StructMeta = meta_find_struct(m, "Circle")
    assert missing == null

    meta_free(m)
    0

[[test]]
fn test_find_constant() -> i32
    let json = "{\"source_path\": \"\", \"source_mtime\": 0, \"imports\": [], \"functions\": [], \"structs\": [], \"enums\": [], \"constants\": [{\"name\": \"MAX\", \"type\": \"i64\"}], \"type_aliases\": [], \"traits\": []}"

    let m: *ModuleMetadata = meta_from_json(json, strlen(json))
    assert m != null

    let found: *ConstMeta = meta_find_constant(m, "MAX")
    assert found != null

    let missing: *ConstMeta = meta_find_constant(m, "MIN")
    assert missing == null

    meta_free(m)
    0

# =============================================================================
# Cache Path Tests
# =============================================================================

[[test]]
fn test_cache_path_simple() -> i32
    var buf: [256]u8
    let len: i64 = get_cache_path("foo.ritz", @buf[0], 256)
    assert len > 0
    assert streq(@buf[0], ".ritz-cache/foo.ritz-meta") != 0
    0

[[test]]
fn test_cache_path_nested() -> i32
    var buf: [256]u8
    let len: i64 = get_cache_path("ritzlib/sys.ritz", @buf[0], 256)
    assert len > 0
    assert streq(@buf[0], ".ritz-cache/ritzlib/sys.ritz-meta") != 0
    0

[[test]]
fn test_cache_path_absolute() -> i32
    var buf: [256]u8
    # Leading / should be stripped
    let len: i64 = get_cache_path("/home/user/foo.ritz", @buf[0], 256)
    assert len > 0
    # Result should start with .ritz-cache/ and strip leading /
    assert strneq(@buf[0], ".ritz-cache/", 12) != 0
    0

# =============================================================================
# Type Alias Tests
# =============================================================================

[[test]]
fn test_parse_type_alias() -> i32
    let json = "{\"source_path\": \"\", \"source_mtime\": 0, \"imports\": [], \"functions\": [], \"structs\": [], \"enums\": [], \"constants\": [], \"type_aliases\": [{\"name\": \"Size\", \"target\": \"i64\"}], \"traits\": []}"

    let m: *ModuleMetadata = meta_from_json(json, strlen(json))
    assert m != null
    assert m.type_alias_count == 1

    let t: *TypeAliasMeta = m.type_aliases
    assert streq(t.name, "Size") != 0
    assert streq(t.target, "i64") != 0

    meta_free(m)
    0

# =============================================================================
# Null Handling Tests
# =============================================================================

[[test]]
fn test_meta_free_null() -> i32
    # Should not crash
    meta_free(null)
    0

[[test]]
fn test_find_in_null() -> i32
    let f: *FnSignature = meta_find_function(null, "foo")
    assert f == null

    let s: *StructMeta = meta_find_struct(null, "bar")
    assert s == null
    0
