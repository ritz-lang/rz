# test_fs_iter.ritz - Tests for directory iteration
#
# TDD: These tests define the API we want for DirIter

import ritzlib.sys
import ritzlib.io
import ritzlib.fs
import ritzlib.str
import ritzlib.string
import ritzlib.gvec

# Test infrastructure
var g_passed: i32 = 0
var g_failed: i32 = 0

fn assert_true(name: *u8, cond: i32)
    if cond != 0
        g_passed += 1
    else
        prints_cstr("FAIL: ")
        prints_cstr(name)
        prints_cstr("\n")
        g_failed += 1

fn assert_gt(name: *u8, val: i64, min: i64)
    if val > min
        g_passed += 1
    else
        prints_cstr("FAIL: ")
        prints_cstr(name)
        prints_cstr(" - expected > ")
        print_int(min)
        prints_cstr(", got ")
        print_int(val)
        prints_cstr("\n")
        g_failed += 1

# ============================================================================
# Directory Iteration Tests
# ============================================================================

[[test]]
fn test_dir_open_close() -> i32
    # Open current directory
    var dir: DirIter = dir_open(c".")
    assert_true(c"dir_open returns valid", dir_valid(@dir))
    dir_close(@dir)
    0

[[test]]
fn test_dir_open_invalid() -> i32
    # Try to open non-existent directory
    var dir: DirIter = dir_open(c"/this/path/does/not/exist")
    assert_true(c"dir_open invalid returns invalid", dir_valid(@dir) == 0)
    0

[[test]]
fn test_dir_iterate_current() -> i32
    # Iterate over current directory, count entries
    var dir: DirIter = dir_open(c".")
    var count: i64 = 0

    while dir_next(@dir)
        count += 1

    dir_close(@dir)

    # Current directory should have some entries
    assert_gt(c"dir has entries", count, 0)
    0

[[test]]
fn test_dir_entry_name() -> i32
    # Check that we can get entry names
    var dir: DirIter = dir_open(c".")
    var found_dot: i32 = 0

    while dir_next(@dir)
        let name: *u8 = dir_entry_name(@dir)
        if strcmp(name, c".") == 0
            found_dot = 1

    dir_close(@dir)
    assert_true(c"found . entry", found_dot)
    0

[[test]]
fn test_dir_entry_is_dir() -> i32
    # Check entry type detection
    var dir: DirIter = dir_open(c".")
    var found_subdir: i32 = 0

    while dir_next(@dir)
        if dir_entry_is_dir(@dir) != 0
            found_subdir = 1
            break

    dir_close(@dir)
    # Current directory should have at least . and .. which are dirs
    assert_true(c"found a directory entry", found_subdir)
    0

[[test]]
fn test_dir_iterate_projects() -> i32
    # Iterate over projects directory (the one rzrz will use)
    var dir: DirIter = dir_open(c"projects")
    var count: i64 = 0

    while dir_next(@dir)
        let name: *u8 = dir_entry_name(@dir)
        # Skip . and ..
        if strcmp(name, c".") != 0 and strcmp(name, c"..") != 0
            count += 1

    dir_close(@dir)

    # Should have multiple projects
    assert_gt(c"projects has multiple entries", count, 5)
    0

# ============================================================================
# Main test runner
# ============================================================================

fn main(argc: i32, argv: **u8) -> i32
    prints_cstr("Running fs directory iteration tests...\n\n")

    test_dir_open_close()
    test_dir_open_invalid()
    test_dir_iterate_current()
    test_dir_entry_name()
    test_dir_entry_is_dir()
    test_dir_iterate_projects()

    prints_cstr("\n")
    print_int(g_passed as i64)
    prints_cstr(" passed, ")
    print_int(g_failed as i64)
    prints_cstr(" failed\n")

    if g_failed > 0
        return 1
    0
