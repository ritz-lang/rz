# Test suite for ritzlib/memory.ritz
#
# Tests the Arena allocator and heap functions.
# Run with: python3 ritz0/ritz0.py --test ritzlib/tests/test_memory.ritz

import ritzlib.memory
import ritzlib.sys

# ============================================================================
# Arena Tests
# ============================================================================

[[test]]
fn test_arena_new() -> i32
    var a: Arena = arena_new(4096)
    assert arena_valid(@a) == 1
    assert arena_used(@a) == 0
    assert arena_remaining(@a) == 4096
    arena_destroy(@a)
    0

[[test]]
fn test_arena_default() -> i32
    var a: Arena = arena_default()
    assert arena_valid(@a) == 1
    assert a.size == 1048576  # 1 MB
    arena_destroy(@a)
    0

[[test]]
fn test_arena_alloc() -> i32
    var a: Arena = arena_new(4096)

    # Allocate 100 bytes
    let p1: *u8 = arena_alloc(@a, 100)
    assert p1 != null
    # 100 bytes rounds up to 104 (aligned to 8)
    assert arena_used(@a) == 104

    # Allocate another 50 bytes
    let p2: *u8 = arena_alloc(@a, 50)
    assert p2 != null
    # 50 rounds to 56, total 160
    assert arena_used(@a) == 160

    # Pointers should be different
    assert p1 != p2

    arena_destroy(@a)
    0

[[test]]
fn test_arena_alloc_zero() -> i32
    var a: Arena = arena_new(4096)

    let p: *u8 = arena_alloc_zero(@a, 16)
    assert p != null

    # Verify all bytes are zero
    for i in 0..16
        assert *(p + i) == 0

    arena_destroy(@a)
    0

[[test]]
fn test_arena_alloc_array() -> i32
    var a: Arena = arena_new(4096)

    # Allocate array of 10 i64s (80 bytes)
    let arr: *i64 = arena_alloc_array(@a, 10, 8) as *i64
    assert arr != null
    assert arena_used(@a) == 80

    # Write to the array
    for i in 0..10
        *(arr + i) = i * 10

    # Read back
    assert *(arr + 0) == 0
    assert *(arr + 5) == 50
    assert *(arr + 9) == 'Z'

    arena_destroy(@a)
    0

[[test]]
fn test_arena_reset() -> i32
    var a: Arena = arena_new(4096)

    # Allocate some memory
    arena_alloc(@a, 100)
    arena_alloc(@a, 200)
    assert arena_used(@a) > 0

    # Reset
    arena_reset(@a)
    assert arena_used(@a) == 0
    assert arena_remaining(@a) == 4096

    # Can allocate again
    let p: *u8 = arena_alloc(@a, 50)
    assert p != null
    assert arena_used(@a) == 56

    arena_destroy(@a)
    0

[[test]]
fn test_arena_exhaustion() -> i32
    var a: Arena = arena_new(128)

    # Allocate most of the arena
    let p1: *u8 = arena_alloc(@a, 100)
    assert p1 != null

    # Try to allocate more than remaining (should fail)
    let p2: *u8 = arena_alloc(@a, 100)
    assert p2 == null

    arena_destroy(@a)
    0

# ============================================================================
# Heap Tests
# ============================================================================

[[test]]
fn test_heap_alloc_free() -> i32
    let size: i64 = 1024
    let p: *u8 = heap_alloc(size)
    assert p != null

    # Write some data
    *p = 42
    *(p + 1) = 43
    assert *p == 42
    assert *(p + 1) == 43

    # Free it
    let result: i32 = heap_free(p, size)
    assert result == 0
    0

[[test]]
fn test_heap_realloc() -> i32
    let old_size: i64 = 64
    let new_size: i64 = 128

    # Allocate initial buffer
    let p1: *u8 = heap_alloc(old_size)
    assert p1 != null

    # Write some data
    for i in 0..old_size
        *(p1 + i) = (i % 256) as u8

    # Reallocate to larger size
    let p2: *u8 = heap_realloc(p1, old_size, new_size)
    assert p2 != null

    # Verify data preserved
    for i in 0..old_size
        assert *(p2 + i) == (i % 256) as u8

    heap_free(p2, new_size)
    0

# ============================================================================
# Memory Utility Tests
# ============================================================================

[[test]]
fn test_memcpy() -> i32
    var src: [16]u8
    var dst: [16]u8

    # Initialize source
    for i in 0..16
        src[i] = (i + 1) as u8
        dst[i] = 0

    # Copy
    memcpy(@dst[0], @src[0], 16)

    # Verify
    for i in 0..16
        assert dst[i] == (i + 1) as u8
    0

[[test]]
fn test_memset() -> i32
    var buf: [16]u8

    # Set all to 42
    memset(@buf[0], 42, 16)

    # Verify
    for i in 0..16
        assert buf[i] == 42
    0

[[test]]
fn test_memzero() -> i32
    var buf: [16]u8

    # Initialize with non-zero
    for i in 0..16
        buf[i] = 0xFF as u8

    # Zero it
    memzero(@buf[0], 16)

    # Verify
    for i in 0..16
        assert buf[i] == 0
    0

[[test]]
fn test_memcmp_equal() -> i32
    var a: [8]u8
    var b: [8]u8

    for i in 0..8
        a[i] = (i + 10) as u8
        b[i] = (i + 10) as u8

    assert memcmp(@a[0], @b[0], 8) == 0
    0

[[test]]
fn test_memcmp_less() -> i32
    var a: [8]u8
    var b: [8]u8

    for i in 0..8
        a[i] = (i + 10) as u8
        b[i] = (i + 10) as u8

    # Make a < b at position 4
    a[4] = 0
    b[4] = 100

    assert memcmp(@a[0], @b[0], 8) < 0
    0

[[test]]
fn test_memcmp_greater() -> i32
    var a: [8]u8
    var b: [8]u8

    for i in 0..8
        a[i] = (i + 10) as u8
        b[i] = (i + 10) as u8

    # Make a > b at position 4
    a[4] = 100
    b[4] = 0

    assert memcmp(@a[0], @b[0], 8) > 0
    0

# ============================================================================
# Struct Allocation Tests
# ============================================================================

struct TestStruct
    x: i32
    y: i32
    ptr: *u8

[[test]]
fn test_arena_alloc_struct() -> i32
    var a: Arena = arena_new(4096)

    # Allocate a struct (12 bytes, rounds to 16)
    let s: *TestStruct = arena_alloc(@a, 24) as *TestStruct
    assert s != null

    # Set fields
    s.x = 10
    s.y = 20
    s.ptr = null

    assert s.x == '\n'
    assert s.y == 20

    arena_destroy(@a)
    0

[[test]]
fn test_arena_multiple_structs() -> i32
    var a: Arena = arena_new(4096)

    # Allocate several structs
    let s1: *TestStruct = arena_alloc(@a, 24) as *TestStruct
    let s2: *TestStruct = arena_alloc(@a, 24) as *TestStruct
    let s3: *TestStruct = arena_alloc(@a, 24) as *TestStruct

    assert s1 != null
    assert s2 != null
    assert s3 != null

    # They should be distinct
    assert s1 != s2
    assert s2 != s3

    # Set values
    s1.x = 1
    s2.x = 2
    s3.x = 3

    # Verify no overlap
    assert s1.x == 1
    assert s2.x == 2
    assert s3.x == 3

    arena_destroy(@a)
    0

# ============================================================================
# jemalloc-style Allocator Tests (malloc/free/realloc)
# ============================================================================

[[test]]
fn test_malloc_small() -> i32
    # Test small allocations in different size classes
    let p1: *u8 = malloc(8)     # Class 0
    let p2: *u8 = malloc(16)    # Class 0
    let p3: *u8 = malloc(32)    # Class 1
    let p4: *u8 = malloc(64)    # Class 2
    let p5: *u8 = malloc(128)   # Class 3
    let p6: *u8 = malloc(256)   # Class 4
    let p7: *u8 = malloc(512)   # Class 5
    let p8: *u8 = malloc(1024)  # Class 6
    let p9: *u8 = malloc(2048)  # Class 7

    assert p1 != null
    assert p2 != null
    assert p3 != null
    assert p4 != null
    assert p5 != null
    assert p6 != null
    assert p7 != null
    assert p8 != null
    assert p9 != null

    # All pointers should be different
    assert p1 != p2
    assert p2 != p3
    assert p3 != p4

    free(p1)
    free(p2)
    free(p3)
    free(p4)
    free(p5)
    free(p6)
    free(p7)
    free(p8)
    free(p9)
    0

[[test]]
fn test_malloc_large() -> i32
    # Test large allocation (>2048 bytes, goes to mmap)
    let p: *u8 = malloc(8192)
    assert p != null

    # Write to verify it's usable
    *p = 42
    *(p + 8191) = 99
    assert *p == 42
    assert *(p + 8191) == 'c'

    free(p)
    0

[[test]]
fn test_malloc_write_read() -> i32
    # Allocate and write data
    let p: *u8 = malloc(100)
    assert p != null

    for i in 0..100
        *(p + i) = (i % 256) as u8

    # Read back
    for i in 0..100
        assert *(p + i) == (i % 256) as u8

    free(p)
    0

[[test]]
fn test_free_and_reuse() -> i32
    # Allocate, free, allocate again - should reuse
    let p1: *u8 = malloc(32)
    assert p1 != null
    *p1 = 10

    free(p1)

    # Allocate same size - might get same block from free list
    let p2: *u8 = malloc(32)
    assert p2 != null

    # Write new value
    *p2 = 20
    assert *p2 == 20

    free(p2)
    0

[[test]]
fn test_calloc() -> i32
    let p: *u8 = calloc(10, 10)  # 100 bytes, zero-initialized
    assert p != null

    # Verify all zeros
    for i in 0..100
        assert *(p + i) == 0

    free(p)
    0

[[test]]
fn test_realloc_grow() -> i32
    # Start small
    let p1: *u8 = malloc(16)
    assert p1 != null

    # Write data
    for i in 0..16
        *(p1 + i) = (i + 1) as u8

    # Grow to larger size class
    let p2: *u8 = realloc(p1, 100)
    assert p2 != null

    # Verify data preserved
    for i in 0..16
        assert *(p2 + i) == (i + 1) as u8

    free(p2)
    0

[[test]]
fn test_realloc_shrink() -> i32
    # Start larger
    let p1: *u8 = malloc(256)
    assert p1 != null

    # Write data
    for i in 0..256
        *(p1 + i) = (i % 256) as u8

    # Shrink
    let p2: *u8 = realloc(p1, 32)
    assert p2 != null

    # Verify data preserved (first 32 bytes)
    for i in 0..32
        assert *(p2 + i) == (i % 256) as u8

    free(p2)
    0

[[test]]
fn test_realloc_null() -> i32
    # realloc(NULL, size) should behave like malloc
    let p: *u8 = realloc(null, 64)
    assert p != null

    *p = 42
    assert *p == 42

    free(p)
    0

[[test]]
fn test_realloc_zero() -> i32
    # realloc(ptr, 0) should free and return NULL
    let p1: *u8 = malloc(64)
    assert p1 != null

    let p2: *u8 = realloc(p1, 0)
    assert p2 == null
    # p1 has been freed
    0

[[test]]
fn test_free_null() -> i32
    # free(NULL) should be a no-op
    free(null)
    0

[[test]]
fn test_many_allocations() -> i32
    # Stress test: many small allocations
    var ptrs: [100]*u8

    for i in 0..100
        ptrs[i] = malloc(32)
        assert ptrs[i] != null
        *(ptrs[i]) = i as u8

    # Verify all values
    for i in 0..100
        assert *(ptrs[i]) == i as u8

    # Free all
    for i in 0..100
        free(ptrs[i])
    0

[[test]]
fn test_mixed_sizes() -> i32
    # Allocate different sizes interleaved
    let p1: *u8 = malloc(8)
    let p2: *u8 = malloc(1024)
    let p3: *u8 = malloc(64)
    let p4: *u8 = malloc(4096)  # Large allocation
    let p5: *u8 = malloc(128)

    assert p1 != null
    assert p2 != null
    assert p3 != null
    assert p4 != null
    assert p5 != null

    # Free in different order
    free(p3)
    free(p1)
    free(p5)
    free(p2)
    free(p4)
    0

[[test]]
fn test_size_class_boundaries() -> i32
    # Test allocations at size class boundaries
    let p16: *u8 = malloc(16)    # Max for class 0
    let p17: *u8 = malloc(17)    # Min for class 1
    let p32: *u8 = malloc(32)    # Max for class 1
    let p33: *u8 = malloc(33)    # Min for class 2

    assert p16 != null
    assert p17 != null
    assert p32 != null
    assert p33 != null

    free(p16)
    free(p17)
    free(p32)
    free(p33)
    0
