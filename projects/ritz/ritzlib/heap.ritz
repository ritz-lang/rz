# ritzlib/heap.ritz - Heap allocation smart pointer
#
# Heap<T> provides a heap-allocated container for a single value.
# - Ownership semantics: one owner, automatic cleanup via Drop trait
# - Heap allocation via malloc/free
# - Generic via monomorphization
#
# Usage:
#   var p = heap 42           # Using heap keyword (preferred)
#   var p = heap_new<i64>(42) # Explicit constructor
#   let val = heap_get(@p)
#   heap_set(@p, 100)
#   # Automatic cleanup when p goes out of scope (Drop trait)
#
# Note: The `heap` keyword desugars to heap_new() calls.

import ritzlib.memory
import ritzlib.drop

# ============================================================================
# Heap<T> - Heap-allocated single value
# ============================================================================
# Unlike a stack-allocated wrapper, Heap<T> stores a *pointer* to heap memory.
# The value T is stored on the heap, not inline in the struct.

struct Heap<T>
    ptr: *T    # Pointer to heap-allocated T

# ============================================================================
# Drop trait implementation for automatic cleanup
# ============================================================================

impl<T> Drop for Heap<T>
    fn drop(self: @&Heap<T>)
        if self.ptr != null
            free(self.ptr as *u8)
        self.ptr = null

# ============================================================================
# Method syntax support
# ============================================================================

impl<T> Heap<T>
    # Get the value from a Heap (returns a copy).
    fn get(self: @Heap<T>) -> T
        return *self.ptr

    # Get a pointer to the value (for in-place modification).
    fn as_ptr(self: @Heap<T>) -> *T
        return self.ptr

    # Set a new value in the Heap (overwrites the old value).
    fn set(self: @&Heap<T>, value: T)
        *self.ptr = value

    # Check if a Heap is valid (successfully allocated).
    fn valid(self: @Heap<T>) -> i32
        if self.ptr != null
            return 1
        return 0

# ============================================================================
# Constructor - called by `heap` keyword
# ============================================================================

# Create a new Heap containing a copy of the value.
# Allocates sizeof(T) bytes on the heap.
#
# The `heap` keyword desugars to this function:
#   let p = heap 42
#   // becomes: let p = heap_new<i64>(42)
pub fn heap_new<T>(value: T) -> Heap<T>
    var h: Heap<T>
    h.ptr = malloc(sizeof(T)) as *T
    if h.ptr != null
        *h.ptr = value
    return h

# ============================================================================
# Standalone functions (for compatibility)
# ============================================================================

# Get the value from a Heap (returns a copy).
pub fn heap_get<T>(h: @Heap<T>) -> T
    return *h.ptr

# Get a pointer to the value (for in-place modification).
pub fn heap_as_ptr<T>(h: @Heap<T>) -> *T
    return h.ptr

# Set a new value in the Heap (overwrites the old value).
pub fn heap_set<T>(h: @&Heap<T>, value: T)
    *h.ptr = value

# Drop (free) the Heap - prefer automatic Drop via scope exit.
pub fn heap_drop<T>(h: @&Heap<T>)
    if h.ptr != null
        free(h.ptr as *u8)
    h.ptr = null

# Check if a Heap is valid (successfully allocated).
pub fn heap_valid<T>(h: @Heap<T>) -> i32
    if h.ptr != null
        return 1
    return 0
