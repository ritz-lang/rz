# ritzlib/drop.ritz - Drop trait for automatic cleanup
#
# The Drop trait enables automatic cleanup when values go out of scope.
# Types that implement Drop get their drop() method called automatically
# at the end of their scope (or on early return).
#
# Usage:
#   trait Drop
#       fn drop(self: @&Self)
#
#   impl Drop for MyType
#       fn drop(self: @&MyType)
#           # cleanup code here
#
# The compiler automatically inserts drop calls at:
# - End of block scope
# - Before return statements
# - Before break/continue in loops (for variables declared in loop)
#
# Drop is called in reverse declaration order (LIFO).

# The Drop trait - types implementing this get automatic cleanup
# NOTE: ritz1 doesn't parse trait definitions yet, so this is commented out.
# The trait concept exists but isn't enforced at compile time.
# trait Drop
#     fn drop(self: @&Self)
