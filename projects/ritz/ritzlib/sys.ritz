# ============================================================================
# File operations syscalls (Linux-only)
# ============================================================================

[[target_os = "linux"]]
pub fn sys_unlink(path: *u8) -> i32
    return syscall1(SYS_UNLINK, path as i64) as i32

[[target_os = "linux"]]
pub fn sys_rename(oldpath: *u8, newpath: *u8) -> i32
    return syscall2(SYS_RENAME, oldpath as i64, newpath as i64) as i32

[[target_os = "linux"]]
pub fn sys_link(oldpath: *u8, newpath: *u8) -> i32
    return syscall2(SYS_LINK, oldpath as i64, newpath as i64) as i32

[[target_os = "linux"]]
pub fn sys_symlink(target: *u8, linkpath: *u8) -> i32
    return syscall2(SYS_SYMLINK, target as i64, linkpath as i64) as i32

[[target_os = "linux"]]
pub fn sys_readlink(path: *u8, buf: *u8, size: i64) -> i64
    return syscall3(SYS_READLINK, path as i64, buf as i64, size)

