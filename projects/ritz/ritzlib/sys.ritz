    return syscall2(SYS_STAT, path as i64, statbuf as i64) as i32

[[target_os = "linux"]]
pub fn sys_fstat(fd: i32, statbuf: *u8) -> i32
    return syscall2(SYS_FSTAT, fd as i64, statbuf as i64) as i32

[[target_os = "linux"]]
pub fn sys_lstat(path: *u8, statbuf: *u8) -> i32
    return syscall2(SYS_LSTAT, path as i64, statbuf as i64) as i32

[[target_os = "linux"]]
pub fn sys_chmod(path: *u8, mode: i32) -> i32
    return syscall2(SYS_CHMOD, path as i64, mode as i64) as i32

[[target_os = "linux"]]
pub fn sys_fchmod(fd: i32, mode: i32) -> i32
    return syscall2(SYS_FCHMOD, fd as i64, mode as i64) as i32

[[target_os = "linux"]]
pub fn sys_chown(path: *u8, uid: i32, gid: i32) -> i32
    return syscall3(SYS_CHOWN, path as i64, uid as i64, gid as i64) as i32

[[target_os = "linux"]]
pub fn sys_fchown(fd: i32, uid: i32, gid: i32) -> i32
    return syscall3(SYS_FCHOWN, fd as i64, uid as i64, gid as i64) as i32

[[target_os = "linux"]]
pub fn sys_access(path: *u8, mode: i32) -> i32
    return syscall2(SYS_ACCESS, path as i64, mode as i64) as i32

[[target_os = "linux"]]
pub fn sys_utimensat(dirfd: i32, path: *u8, times: *i64, flags: i32) -> i32
    return syscall4(SYS_UTIMENSAT, dirfd as i64, path as i64, times as i64, flags as i64) as i32

