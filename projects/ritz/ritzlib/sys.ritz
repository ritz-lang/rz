# ============================================================================

[[target_os = "linux"]]
pub fn sys_pipe(pipefd: *i32) -> i32
    return syscall1(SYS_PIPE, pipefd as i64) as i32

[[target_os = "linux"]]
pub fn sys_dup(oldfd: i32) -> i32
    return syscall1(SYS_DUP, oldfd as i64) as i32

[[target_os = "linux"]]
pub fn sys_dup2(oldfd: i32, newfd: i32) -> i32
    return syscall2(SYS_DUP2, oldfd as i64, newfd as i64) as i32

# ============================================================================
# Signal constants (Linux-only)
# ============================================================================

[[target_os = "linux"]]
const SIGHUP: i32 = 1       # Hangup
[[target_os = "linux"]]
const SIGINT: i32 = 2       # Interrupt (Ctrl+C)
[[target_os = "linux"]]
const SIGQUIT: i32 = 3      # Quit (Ctrl+\)
[[target_os = "linux"]]
const SIGILL: i32 = 4       # Illegal instruction
[[target_os = "linux"]]
const SIGTRAP: i32 = 5      # Trace/breakpoint trap
[[target_os = "linux"]]
const SIGABRT: i32 = 6      # Abort
[[target_os = "linux"]]
const SIGBUS: i32 = 7       # Bus error
[[target_os = "linux"]]
const SIGFPE: i32 = 8       # Floating point exception
[[target_os = "linux"]]
const SIGKILL: i32 = 9      # Kill (cannot be caught)
[[target_os = "linux"]]
const SIGUSR1: i32 = 10     # User-defined signal 1
[[target_os = "linux"]]
const SIGSEGV: i32 = 11     # Segmentation fault
[[target_os = "linux"]]
const SIGUSR2: i32 = 12     # User-defined signal 2
[[target_os = "linux"]]
const SIGPIPE: i32 = 13     # Broken pipe
[[target_os = "linux"]]
const SIGALRM: i32 = 14     # Alarm clock
[[target_os = "linux"]]
const SIGTERM: i32 = 15     # Termination
[[target_os = "linux"]]
const SIGCHLD: i32 = 17     # Child stopped or terminated
[[target_os = "linux"]]
const SIGCONT: i32 = 18     # Continue if stopped
[[target_os = "linux"]]
const SIGSTOP: i32 = 19     # Stop (cannot be caught)
[[target_os = "linux"]]
const SIGTSTP: i32 = 20     # Terminal stop (Ctrl+Z)

# Wait options for wait4 (Linux-only)
[[target_os = "linux"]]
const WNOHANG: i32 = 1      # Don't block if no child has exited
[[target_os = "linux"]]
const WUNTRACED: i32 = 2    # Also return for stopped children

# Signal handler constants (Linux-only)
[[target_os = "linux"]]
const SIG_DFL: i64 = 0      # Default signal handling
[[target_os = "linux"]]
const SIG_IGN: i64 = 1      # Ignore signal

# ============================================================================
# Signal syscalls (Linux-only)
# ============================================================================

# rt_sigaction sigaction structure (kernel version, x86-64)
# Note: This is a simplified version - just setting handler
# The kernel sigaction struct on x86-64:
#   sa_handler: 8 bytes (pointer or SIG_IGN/SIG_DFL)
#   sa_flags: 8 bytes
#   sa_restorer: 8 bytes
#   sa_mask: 8 bytes (64-bit signal set)
[[target_os = "linux"]]
const SA_RESTORER: i64 = 67108864  # 0x04000000 - must be set when sa_restorer is used

[[target_os = "linux"]]
pub fn sys_rt_sigaction(signum: i32, act: *u8, oldact: *u8, sigsetsize: i64) -> i32
    return syscall4(SYS_RT_SIGACTION, signum as i64, act as i64, oldact as i64, sigsetsize) as i32

# Convenience function to ignore a signal (Linux-only)
[[target_os = "linux"]]
pub fn signal_ignore(signum: i32) -> i32
    # Build a minimal sigaction struct to ignore the signal
    # struct kernel_sigaction {
    #   void *sa_handler;    // 0: SIG_IGN (1)
    #   unsigned long sa_flags;  // 8: 0
    #   void *sa_restorer;   // 16: 0 (not using restorer)
    #   sigset_t sa_mask;    // 24: 0 (empty mask)
    # }
    var act: [32]u8   # 32 bytes for the structure

    # Zero out the structure
    var i: i64 = 0
    while i < 32
        act[i] = 0
        i += 1

    # Set sa_handler to SIG_IGN (1)
    # Little-endian: LSB first
    act[0] = 1  # SIG_IGN = 1

    return sys_rt_sigaction(signum, @act[0], null, 8)

# ============================================================================
# Access mode constants (for sys_access) (Linux-only)
# ============================================================================

[[target_os = "linux"]]
const F_OK: i32 = 0         # Test for existence
[[target_os = "linux"]]
const X_OK: i32 = 1         # Test for execute permission
[[target_os = "linux"]]
const W_OK: i32 = 2         # Test for write permission
[[target_os = "linux"]]
const R_OK: i32 = 4         # Test for read permission

# ============================================================================
# Time syscalls (Linux-only)
# ============================================================================

[[target_os = "linux"]]
pub fn sys_nanosleep(req: *i64, rem: *i64) -> i32
    return syscall2(SYS_NANOSLEEP, req as i64, rem as i64) as i32

# Timeval structure for gettimeofday
# tv_sec (i64 at offset 0): seconds since epoch
# tv_usec (i64 at offset 8): microseconds
[[target_os = "linux"]]
struct Timeval
    tv_sec: i64
    tv_usec: i64

[[target_os = "linux"]]
pub fn sys_gettimeofday(tv: *Timeval, tz: *u8) -> i32
    return syscall2(SYS_GETTIMEOFDAY, tv as i64, tz as i64) as i32


# ============================================================================
# Sendfile syscall (Linux-only)
# ============================================================================

# sendfile - transfer data between file descriptors (zero-copy)
# out_fd: destination file descriptor (must be a socket)
# in_fd: source file descriptor (must support mmap-like operations)
# offset: pointer to offset in input file, updated on return (or null for current position)
# count: number of bytes to transfer
# Returns: number of bytes written on success, negative errno on failure
[[target_os = "linux"]]
pub fn sys_sendfile(out_fd: i32, in_fd: i32, offset: *i64, count: i64) -> i64
    return syscall4(SYS_SENDFILE, out_fd as i64, in_fd as i64, offset as i64, count)
