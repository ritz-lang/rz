# ritzlib/sys.ritz - System call wrappers
#
# Cross-platform syscall interface supporting both Linux and Harland.
# Uses [[target_os]] attributes for compile-time platform selection.
#
# Common syscalls (available on both platforms):
#   - sys_read, sys_write, sys_exit
#
# For Linux target: Full POSIX-compatible syscall set
# For Harland target: Basic I/O and process control
#
# These are the raw syscall wrappers - prefer higher-level
# abstractions in other ritzlib modules when available.

# ============================================================================
# Raw syscall interface
# ============================================================================

extern fn syscall0(n: i64) -> i64
extern fn syscall1(n: i64, a1: i64) -> i64
extern fn syscall2(n: i64, a1: i64, a2: i64) -> i64
extern fn syscall3(n: i64, a1: i64, a2: i64, a3: i64) -> i64
extern fn syscall4(n: i64, a1: i64, a2: i64, a3: i64, a4: i64) -> i64
extern fn syscall5(n: i64, a1: i64, a2: i64, a3: i64, a4: i64, a5: i64) -> i64
extern fn syscall6(n: i64, a1: i64, a2: i64, a3: i64, a4: i64, a5: i64, a6: i64) -> i64

# ============================================================================
# Syscall numbers
# ============================================================================
# Common syscalls (same number on Linux and Harland)
const SYS_READ: i64 = 0
const SYS_WRITE: i64 = 1

# Platform-specific: SYS_EXIT differs
[[target_os = "linux"]]
const SYS_EXIT: i64 = 60

[[target_os = "harland"]]
const SYS_EXIT: i64 = 20

# ============================================================================
# Harland-specific syscall numbers
# ============================================================================
# These syscalls are available on Harland but have different numbers than Linux.
# The syscall numbers MUST match the harland kernel (kernel/src/main.ritz).

[[target_os = "harland"]]
const SYS_READDIR: i64 = 17

[[target_os = "harland"]]
const SYS_SPAWN: i64 = 21

[[target_os = "harland"]]
const SYS_WAIT: i64 = 22

[[target_os = "harland"]]
const SYS_GETPID: i64 = 23

[[target_os = "harland"]]
const SYS_YIELD: i64 = 24

[[target_os = "harland"]]
const SYS_SPAWN_ARGS: i64 = 25

[[target_os = "harland"]]
const SYS_ACPI_POWEROFF: i64 = 200

# ============================================================================
# Harland syscall wrappers
# ============================================================================

[[target_os = "harland"]]
pub fn sys_yield() -> i32
    return syscall0(SYS_YIELD) as i32

[[target_os = "harland"]]
pub fn sys_getpid() -> i32
    return syscall0(SYS_GETPID) as i32

[[target_os = "harland"]]
pub fn sys_spawn(path: *u8) -> i64
    return syscall1(SYS_SPAWN, path as i64)

[[target_os = "harland"]]
pub fn sys_spawn_args(path: *u8, argv: **u8, argc: i32) -> i64
    return syscall3(SYS_SPAWN_ARGS, path as i64, argv as i64, argc as i64)

[[target_os = "harland"]]
pub fn sys_wait(pid: i32) -> i64
    return syscall1(SYS_WAIT, pid as i64)

[[target_os = "harland"]]
pub fn sys_readdir(path: *u8, buf: *u8, buf_size: i64) -> i64
    return syscall3(SYS_READDIR, path as i64, buf as i64, buf_size)

[[target_os = "harland"]]
pub fn sys_acpi_poweroff()
    syscall0(SYS_ACPI_POWEROFF)

