# ============================================================================
# Stat structure (Linux x86-64 struct stat)
# ============================================================================
# Total size: 144 bytes
# Layout verified against glibc sys/stat.h

[[target_os = "linux"]]
struct Stat
    st_dev: i64       # 0: device ID
    st_ino: i64       # 8: inode number
    st_nlink: i64     # 16: number of hard links
    st_mode: i32      # 24: file mode (permissions + type)
    st_uid: i32       # 28: user ID of owner
    st_gid: i32       # 32: group ID of owner
    __pad0: i32       # 36: padding
    st_rdev: i64      # 40: device ID (if special file)
    st_size: i64      # 48: total size in bytes
    st_blksize: i64   # 56: block size for filesystem I/O
    st_blocks: i64    # 64: number of 512B blocks allocated
    st_atime: i64     # 72: last access time (seconds)
    st_atime_ns: i64  # 80: last access time (nanoseconds)
    st_mtime: i64     # 88: last modification time (seconds)
    st_mtime_ns: i64  # 96: last modification time (nanoseconds)
    st_ctime: i64     # 104: last status change time (seconds)
    st_ctime_ns: i64  # 112: last status change time (nanoseconds)
    __reserved: i64   # 120: reserved
    __reserved2: i64  # 128: reserved
    __reserved3: i64  # 136: reserved

const STAT_SIZE: i64 = 144

# Stat wrapper functions that take typed Stat pointer
[[target_os = "linux"]]
pub fn sys_stat2(path: *u8, statbuf: *Stat) -> i32
    return syscall2(SYS_STAT, path as i64, statbuf as i64) as i32

[[target_os = "linux"]]
pub fn sys_fstat2(fd: i32, statbuf: *Stat) -> i32
    return syscall2(SYS_FSTAT, fd as i64, statbuf as i64) as i32

[[target_os = "linux"]]
pub fn sys_lstat2(path: *u8, statbuf: *Stat) -> i32
    return syscall2(SYS_LSTAT, path as i64, statbuf as i64) as i32

# ============================================================================
# Dirent structure (Linux getdents64)
# ============================================================================
# Variable-length structure, but we can define the fixed part

[[target_os = "linux"]]
struct Dirent64
    d_ino: i64        # 0: inode number
    d_off: i64        # 8: offset to next structure
    d_reclen: u16     # 16: length of this record (2 bytes, but we use i32 for alignment)
    d_type: u8        # 18: type of file
    # d_name[]: char  # 19: filename (null-terminated, variable length)

# Note: d_reclen is actually u16 at offset 16, d_type is u8 at offset 18
# d_name starts at offset 19

# Dirent type constants (Linux-only)
[[target_os = "linux"]]
const DT_UNKNOWN: u8 = 0
[[target_os = "linux"]]
const DT_FIFO: u8 = 1
[[target_os = "linux"]]
const DT_CHR: u8 = 2
[[target_os = "linux"]]
const DT_DIR: u8 = 4
[[target_os = "linux"]]
const DT_BLK: u8 = 6
[[target_os = "linux"]]
const DT_REG: u8 = 8
[[target_os = "linux"]]
const DT_LNK: u8 = 10
[[target_os = "linux"]]
const DT_SOCK: u8 = 12

# ============================================================================
# Special constants (Linux-only)
# ============================================================================

# AT_FDCWD = -100: use cwd for *at() syscalls
# Since ritz0 doesn't support negative const literals yet, define as function
[[target_os = "linux"]]
pub fn at_fdcwd() -> i32
    return -100
[[target_os = "linux"]]
const UTIME_NOW: i64 = 1073741823       # (1 << 30) - 1
[[target_os = "linux"]]
const UTIME_OMIT: i64 = 1073741822      # (1 << 30) - 2

# ============================================================================
# Standard file descriptors
# ============================================================================

const STDIN: i32 = 0
const STDOUT: i32 = 1
const STDERR: i32 = 2

# ============================================================================
# File I/O syscalls
# ============================================================================

pub fn sys_read(fd: i32, buf: *u8, count: i64) -> i64
    return syscall3(SYS_READ, fd as i64, buf as i64, count)

pub fn sys_write(fd: i32, buf: *u8, count: i64) -> i64
    return syscall3(SYS_WRITE, fd as i64, buf as i64, count)

[[target_os = "linux"]]
pub fn sys_open(path: *u8, flags: i32) -> i32
    return syscall2(SYS_OPEN, path as i64, flags as i64) as i32

[[target_os = "linux"]]
pub fn sys_open3(path: *u8, flags: i32, mode: i32) -> i32
    return syscall3(SYS_OPEN, path as i64, flags as i64, mode as i64) as i32

[[target_os = "linux"]]
pub fn sys_close(fd: i32) -> i32
    return syscall1(SYS_CLOSE, fd as i64) as i32

[[target_os = "linux"]]
pub fn sys_lseek(fd: i32, offset: i64, whence: i32) -> i64
    return syscall3(SYS_LSEEK, fd as i64, offset, whence as i64)

[[target_os = "linux"]]
pub fn sys_ftruncate(fd: i32, length: i64) -> i32
    return syscall2(SYS_FTRUNCATE, fd as i64, length) as i32

# ============================================================================
# File metadata syscalls (Linux-only)
# ============================================================================

[[target_os = "linux"]]
pub fn sys_stat(path: *u8, statbuf: *u8) -> i32
    return syscall2(SYS_STAT, path as i64, statbuf as i64) as i32

[[target_os = "linux"]]
pub fn sys_fstat(fd: i32, statbuf: *u8) -> i32
    return syscall2(SYS_FSTAT, fd as i64, statbuf as i64) as i32

[[target_os = "linux"]]
pub fn sys_lstat(path: *u8, statbuf: *u8) -> i32
    return syscall2(SYS_LSTAT, path as i64, statbuf as i64) as i32

[[target_os = "linux"]]
pub fn sys_chmod(path: *u8, mode: i32) -> i32
    return syscall2(SYS_CHMOD, path as i64, mode as i64) as i32

[[target_os = "linux"]]
pub fn sys_fchmod(fd: i32, mode: i32) -> i32
    return syscall2(SYS_FCHMOD, fd as i64, mode as i64) as i32

[[target_os = "linux"]]
pub fn sys_chown(path: *u8, uid: i32, gid: i32) -> i32
    return syscall3(SYS_CHOWN, path as i64, uid as i64, gid as i64) as i32

[[target_os = "linux"]]
pub fn sys_fchown(fd: i32, uid: i32, gid: i32) -> i32
    return syscall3(SYS_FCHOWN, fd as i64, uid as i64, gid as i64) as i32

[[target_os = "linux"]]
pub fn sys_access(path: *u8, mode: i32) -> i32
    return syscall2(SYS_ACCESS, path as i64, mode as i64) as i32

[[target_os = "linux"]]
pub fn sys_utimensat(dirfd: i32, path: *u8, times: *i64, flags: i32) -> i32
    return syscall4(SYS_UTIMENSAT, dirfd as i64, path as i64, times as i64, flags as i64) as i32

