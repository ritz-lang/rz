# ritzlib/sys.ritz - System call wrappers
#
# Cross-platform syscall interface supporting both Linux and Harland.
# Uses [[target_os]] attributes for compile-time platform selection.
#
# Common syscalls (available on both platforms):
#   - sys_read, sys_write, sys_exit
#
# For Linux target: Full POSIX-compatible syscall set
# For Harland target: Basic I/O and process control
#
# These are the raw syscall wrappers - prefer higher-level
# abstractions in other ritzlib modules when available.

# ============================================================================
# Raw syscall interface
# ============================================================================

extern fn syscall0(n: i64) -> i64
extern fn syscall1(n: i64, a1: i64) -> i64
extern fn syscall2(n: i64, a1: i64, a2: i64) -> i64
extern fn syscall3(n: i64, a1: i64, a2: i64, a3: i64) -> i64
extern fn syscall4(n: i64, a1: i64, a2: i64, a3: i64, a4: i64) -> i64
extern fn syscall5(n: i64, a1: i64, a2: i64, a3: i64, a4: i64, a5: i64) -> i64
extern fn syscall6(n: i64, a1: i64, a2: i64, a3: i64, a4: i64, a5: i64, a6: i64) -> i64

# ============================================================================
# Syscall numbers
# ============================================================================
# Common syscalls (same number on Linux and Harland)
const SYS_READ: i64 = 0
const SYS_WRITE: i64 = 1

# Platform-specific: SYS_EXIT differs
[[target_os = "linux"]]
const SYS_EXIT: i64 = 60

[[target_os = "harland"]]
const SYS_EXIT: i64 = 20

# ============================================================================
# Harland-specific syscall numbers
# ============================================================================
# These syscalls are available on Harland but have different numbers than Linux.
# The syscall numbers MUST match the harland kernel (kernel/src/main.ritz).

[[target_os = "harland"]]
const SYS_READDIR: i64 = 17

[[target_os = "harland"]]
const SYS_SPAWN: i64 = 21

[[target_os = "harland"]]
const SYS_WAIT: i64 = 22

[[target_os = "harland"]]
const SYS_GETPID: i64 = 23

[[target_os = "harland"]]
const SYS_YIELD: i64 = 24

[[target_os = "harland"]]
const SYS_SPAWN_ARGS: i64 = 25

[[target_os = "harland"]]
const SYS_MMAP: i64 = 9

[[target_os = "harland"]]
const SYS_MUNMAP: i64 = 11

[[target_os = "harland"]]
const SYS_ACPI_POWEROFF: i64 = 200

[[target_os = "harland"]]
const SYS_GETCWD: i64 = 26

[[target_os = "harland"]]
const SYS_CHDIR: i64 = 27

[[target_os = "harland"]]
const SYS_SPAWN_EX: i64 = 28

[[target_os = "harland"]]
const SYS_PIPE: i64 = 29

# Input syscalls - moved to 50-51 to avoid IPC conflict (30-33)
[[target_os = "harland"]]
const SYS_INPUT_POLL: i64 = 50

[[target_os = "harland"]]
const SYS_INPUT_READ: i64 = 51

# Harland memory protection flags
[[target_os = "harland"]]
pub const PROT_READ: i32 = 1

[[target_os = "harland"]]
pub const PROT_WRITE: i32 = 2

[[target_os = "harland"]]
pub const PROT_EXEC: i32 = 4

# Harland memory map flags
[[target_os = "harland"]]
pub const MAP_PRIVATE: i32 = 2

[[target_os = "harland"]]
pub const MAP_ANONYMOUS: i32 = 32

[[target_os = "harland"]]
pub const MAP_FIXED: i32 = 16

# ============================================================================
# Harland syscall wrappers
# ============================================================================

[[target_os = "harland"]]
pub fn sys_yield() -> i32
    return syscall0(SYS_YIELD) as i32

[[target_os = "harland"]]
pub fn sys_getpid() -> i32
    return syscall0(SYS_GETPID) as i32

[[target_os = "harland"]]
pub fn sys_spawn(path: *u8) -> i64
    return syscall1(SYS_SPAWN, path as i64)

[[target_os = "harland"]]
pub fn sys_spawn_args(path: *u8, argv: **u8, argc: i32) -> i64
    return syscall3(SYS_SPAWN_ARGS, path as i64, argv as i64, argc as i64)

[[target_os = "harland"]]
pub fn sys_wait(pid: i32) -> i64
    return syscall1(SYS_WAIT, pid as i64)

[[target_os = "harland"]]
pub fn sys_readdir(path: *u8, buf: *u8, buf_size: i64) -> i64
    return syscall3(SYS_READDIR, path as i64, buf as i64, buf_size)

[[target_os = "harland"]]
pub fn sys_acpi_poweroff()
    syscall0(SYS_ACPI_POWEROFF)

# sys_getcwd: Get current working directory
# buf: Buffer to write path to (null-terminated)
# size: Size of buffer
# Returns: Length of path on success, -1 on error
[[target_os = "harland"]]
pub fn sys_getcwd(buf: *u8, size: i64) -> i64
    return syscall2(SYS_GETCWD, buf as i64, size)

# sys_chdir: Change current working directory
# path: Path to new directory (null-terminated)
# Returns: 0 on success, -1 on error
[[target_os = "harland"]]
pub fn sys_chdir(path: *u8) -> i32
    return syscall1(SYS_CHDIR, path as i64) as i32

# sys_spawn_ex: Spawn process with redirected stdin/stdout
# path: Path to executable (null-terminated)
# argv: Argument array
# argc: Argument count
# stdin_fd: File descriptor for child's stdin (-1 to use default)
# stdout_fd: File descriptor for child's stdout (-1 to use default)
# Returns: Child PID on success, negative error code on failure
[[target_os = "harland"]]
pub fn sys_spawn_ex(path: *u8, argv: **u8, argc: i32, stdin_fd: i32, stdout_fd: i32) -> i64
    return syscall5(SYS_SPAWN_EX, path as i64, argv as i64, argc as i64, stdin_fd as i64, stdout_fd as i64)

# sys_pipe: Create a pipe
# Returns: Packed file descriptors (read_fd in lower 32 bits, write_fd in upper 32 bits)
#          or negative error code
[[target_os = "harland"]]
pub fn sys_pipe() -> i64
    return syscall0(SYS_PIPE)

# sys_input_poll: Poll for pending input events
# Returns: Number of events pending in the kernel input queue
[[target_os = "harland"]]
pub fn sys_input_poll() -> i64
    return syscall0(SYS_INPUT_POLL)

# sys_input_read: Read next input event from the kernel
# event_ptr: Pointer to 8-byte event structure (type: u16, code: u16, value: i32)
# Returns: 0 if event was read, -1 if no events pending
[[target_os = "harland"]]
pub fn sys_input_read(event_ptr: *u8) -> i32
    return syscall1(SYS_INPUT_READ, event_ptr as i64) as i32

# Harland memory mapping syscalls
# sys_mmap: Map anonymous memory pages
#   addr: Suggested address (0 = kernel chooses)
#   length: Number of bytes to map
#   prot: Protection flags (PROT_READ | PROT_WRITE | PROT_EXEC)
#   flags: Mapping flags (MAP_ANONYMOUS | MAP_PRIVATE)
# Returns: Address of mapped region, or -1 on error
[[target_os = "harland"]]
pub fn sys_mmap(addr: i64, length: i64, prot: i32, flags: i32) -> *u8
    # Harland mmap uses 4 args, Linux uses 6 (with fd and offset)
    return syscall4(SYS_MMAP, addr, length, prot as i64, flags as i64) as *u8

# sys_munmap: Unmap memory pages
#   addr: Address of region to unmap (must be page-aligned)
#   length: Number of bytes to unmap
# Returns: 0 on success, -1 on error
[[target_os = "harland"]]
pub fn sys_munmap(addr: *u8, length: i64) -> i32
    return syscall2(SYS_MUNMAP, addr as i64, length) as i32

