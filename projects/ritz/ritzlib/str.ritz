# ritzlib/str.ritz - String manipulation functions
#
# Provides common string operations. All strings are null-terminated.

# ============================================================================
# Length and comparison
# ============================================================================

pub fn strlen(s: *u8) -> i64
    var len: i64 = 0
    while *(s + len) != 0
        len += 1
    return len

pub fn streq(a: *u8, b: *u8) -> i32
    var i: i64 = 0
    while *(a + i) != 0 and *(b + i) != 0
        if *(a + i) != *(b + i)
            return 0
        i += 1
    return (*(a + i) == *(b + i)) as i32

pub fn strneq(a: *u8, b: *u8, n: i64) -> i32
    var i: i64 = 0
    while i < n and *(a + i) != 0 and *(b + i) != 0
        if *(a + i) != *(b + i)
            return 0
        i += 1
    if i == n
        return 1
    return (*(a + i) == *(b + i)) as i32

pub fn strcmp(a: *u8, b: *u8) -> i32
    var i: i64 = 0
    while *(a + i) != 0 and *(b + i) != 0
        if *(a + i) < *(b + i)
            return -1
        if *(a + i) > *(b + i)
            return 1
        i += 1
    if *(a + i) == 0 and *(b + i) == 0
        return 0
    if *(a + i) == 0
        return -1
    return 1

# ============================================================================
# Search
# ============================================================================

pub fn strchr(s: *u8, c: u8) -> *u8
    var i: i64 = 0
    while *(s + i) != 0
        if *(s + i) == c
            return s + i
        i += 1
    if c == 0
        return s + i
    return null

pub fn strrchr(s: *u8, c: u8) -> *u8
    var last: *u8 = null
    var i: i64 = 0
    while *(s + i) != 0
        if *(s + i) == c
            last = s + i
        i += 1
    if c == 0
        return s + i
    return last

pub fn strstr(haystack: *u8, needle: *u8) -> *u8
    if *needle == 0
        return haystack
    var i: i64 = 0
    while *(haystack + i) != 0
        var j: i64 = 0
        while *(needle + j) != 0 and *(haystack + i + j) == *(needle + j)
            j += 1
        if *(needle + j) == 0
            return haystack + i
        i += 1
    return null

# ============================================================================
# Copy and concatenate
# ============================================================================

pub fn strcpy(dest: *u8, src: *u8) -> *u8
    var i: i64 = 0
    while *(src + i) != 0
        *(dest + i) = *(src + i)
        i += 1
    *(dest + i) = 0
    return dest

pub fn strncpy(dest: *u8, src: *u8, n: i64) -> *u8
    var i: i64 = 0
    while i < n and *(src + i) != 0
        *(dest + i) = *(src + i)
        i += 1
    while i < n
        *(dest + i) = 0
        i += 1
    return dest

pub fn strcat(dest: *u8, src: *u8) -> *u8
    var len: i64 = strlen(dest)
    strcpy(dest + len, src)
    return dest

# ============================================================================
# Conversion
# ============================================================================

pub fn atoi(s: *u8) -> i64
    var result: i64 = 0
    var neg: i32 = 0
    var i: i64 = 0

    # Skip whitespace
    while *(s + i) == ' ' or *(s + i) == '\t'
        i += 1

    # Check sign
    if *(s + i) == '-'  # '-'
        neg = 1
        i += 1
    else if *(s + i) == '+'  # '+'
        i += 1

    # Parse digits
    while *(s + i) >= '0' and *(s + i) <= '9'
        result = result * 10 + (*(s + i) - '0') as i64
        i += 1

    if neg != 0
        return 0 - result
    return result

pub fn itoa(n: i64, buf: *u8) -> *u8
    var neg: i32 = 0
    if n < 0
        neg = 1
        n = 0 - n

    # Build digits backwards
    var tmp: [20]u8
    var len: i64 = 0

    if n == 0
        tmp[0] = 48
        len = 1
    else
        while n > 0
            tmp[len] = ((n % 10) + 48) as u8
            n /= 10
            len += 1

    # Copy to buffer with sign
    var pos: i64 = 0
    if neg != 0
        *buf = 45
        pos = 1

    var i: i64 = len - 1
    while i >= 0
        *(buf + pos) = tmp[i]
        pos += 1
        i -= 1

    *(buf + pos) = 0
    return buf

# ============================================================================
# Character classification
# ============================================================================

pub fn isdigit(c: u8) -> i32
    return (c >= '0' and c <= '9') as i32

pub fn isalpha(c: u8) -> i32
    return ((c >= 'A' and c <= 'Z') or (c >= 'a' and c <= 'z')) as i32

pub fn isalnum(c: u8) -> i32
    return (isdigit(c) != 0 or isalpha(c) != 0) as i32

pub fn isspace(c: u8) -> i32
    return (c == ' ' or c == '\t' or c == '\n' or c == '\r') as i32

pub fn isupper(c: u8) -> i32
    return (c >= 'A' and c <= 'Z') as i32

pub fn islower(c: u8) -> i32
    return (c >= 'a' and c <= 'z') as i32

pub fn toupper(c: u8) -> u8
    if c >= 'a' and c <= 'z'
        return c - 32
    return c

pub fn tolower(c: u8) -> u8
    if c >= 'A' and c <= 'Z'
        return c + 32
    return c

# ============================================================================
# Memory operations
# ============================================================================

pub fn memset(dest: *u8, c: u8, n: i64) -> *u8
    for i in 0..n
        *(dest + i) = c
    return dest

pub fn memcpy(dest: *u8, src: *u8, n: i64) -> *u8
    for i in 0..n
        *(dest + i) = *(src + i)
    return dest

pub fn memcmp(a: *u8, b: *u8, n: i64) -> i32
    for i in 0..n
        if *(a + i) < *(b + i)
            return -1
        if *(a + i) > *(b + i)
            return 1
    return 0
