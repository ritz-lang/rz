# ritzlib/eq.ritz - Equality comparison utilities
#
# Provides equality functions for use in HashMap and other data structures.
#
# For primitive types, use the standalone eq functions:
#   eq_i32(a, b) -> i32  (returns 1 if equal, 0 otherwise)
#   eq_i64(a, b) -> i32
#   eq_u64(a, b) -> i32

# ============================================================================
# Standalone equality functions for primitive types
# ============================================================================

pub fn eq_i32(a: i32, b: i32) -> i32
    if a == b
        return 1
    return 0

pub fn eq_i64(a: i64, b: i64) -> i32
    if a == b
        return 1
    return 0

pub fn eq_u64(a: u64, b: u64) -> i32
    if a == b
        return 1
    return 0

