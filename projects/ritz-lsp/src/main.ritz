# main.ritz - ritz-lsp Entry Point
#
# Language Server Protocol implementation for the Ritz programming language.
# Communicates over stdio using JSON-RPC 2.0.

import ritzlib.sys
import ritzlib.io

import server

pub fn main() -> i32
    eprints_cstr(c"[ritz-lsp] Ritz Language Server v0.1.0\n")

    var s: Server = server_new()
    let exit_code: i32 = server_run(&s)
    server_drop(&s)

    return exit_code
