# documents.ritz - Document Store for LSP
#
# Tracks open documents and their contents.

import ritzlib.sys
import ritzlib.io
import ritzlib.str
import ritzlib.memory
import ritzlib.gvec

# =============================================================================
# Document Structure
# =============================================================================

const MAX_DOCUMENTS: i32 = 256

struct Document
    uri: *u8            # Document URI (owned)
    content: *u8        # Document content (owned)
    content_len: i64    # Content length
    version: i64        # Document version

struct DocumentStore
    docs: [256]Document
    count: i32

pub fn document_store_new() -> DocumentStore
    var store: DocumentStore
    store.count = 0
    for i in 0..MAX_DOCUMENTS
        store.docs[i].uri = null
        store.docs[i].content = null
        store.docs[i].content_len = 0
        store.docs[i].version = 0
    return store

pub fn document_store_drop(store: *DocumentStore)
    for i in 0..store.count
        if store.docs[i].uri != null
            free(store.docs[i].uri)
        if store.docs[i].content != null
            free(store.docs[i].content)

# =============================================================================
# Document Operations
# =============================================================================

# Find document by URI, returns index or -1
pub fn document_find(store: *DocumentStore, uri: *u8) -> i32
    for i in 0..store.count
        if store.docs[i].uri != null
            if streq(store.docs[i].uri, uri) != 0
                return i
    return -1

# Open a document (add to store)
pub fn document_open(store: *DocumentStore, uri: *u8, content: *u8, version: i64) -> i32
    # Check if already open
    let existing: i32 = document_find(store, uri)
    if existing >= 0
        # Update existing
        if store.docs[existing].content != null
            free(store.docs[existing].content)
        let content_len: i64 = strlen(content)
        store.docs[existing].content = malloc(content_len + 1)
        if store.docs[existing].content != null
            memcpy(store.docs[existing].content, content, content_len + 1)
            store.docs[existing].content_len = content_len
        store.docs[existing].version = version
        return existing

    # Add new document
    if store.count >= MAX_DOCUMENTS
        return -1

    let idx: i32 = store.count
    store.count += 1

    # Copy URI
    let uri_len: i64 = strlen(uri)
    store.docs[idx].uri = malloc(uri_len + 1)
    if store.docs[idx].uri != null
        memcpy(store.docs[idx].uri, uri, uri_len + 1)

    # Copy content
    let content_len: i64 = strlen(content)
    store.docs[idx].content = malloc(content_len + 1)
    if store.docs[idx].content != null
        memcpy(store.docs[idx].content, content, content_len + 1)
        store.docs[idx].content_len = content_len

    store.docs[idx].version = version

    return idx

# Update document content
pub fn document_change(store: *DocumentStore, uri: *u8, content: *u8, version: i64) -> i32
    let idx: i32 = document_find(store, uri)
    if idx < 0
        return -1

    # Free old content
    if store.docs[idx].content != null
        free(store.docs[idx].content)

    # Copy new content
    let content_len: i64 = strlen(content)
    store.docs[idx].content = malloc(content_len + 1)
    if store.docs[idx].content != null
        memcpy(store.docs[idx].content, content, content_len + 1)
        store.docs[idx].content_len = content_len

    store.docs[idx].version = version

    return idx

# Close a document (remove from store)
pub fn document_close(store: *DocumentStore, uri: *u8) -> i32
    let idx: i32 = document_find(store, uri)
    if idx < 0
        return -1

    # Free resources
    if store.docs[idx].uri != null
        free(store.docs[idx].uri)
    if store.docs[idx].content != null
        free(store.docs[idx].content)

    # Shift remaining documents
    var i: i32 = idx
    let end: i32 = store.count - 1
    while i < end
        store.docs[i] = store.docs[i + 1]
        i += 1

    store.count -= 1

    # Clear last slot
    store.docs[store.count].uri = null
    store.docs[store.count].content = null
    store.docs[store.count].content_len = 0
    store.docs[store.count].version = 0

    return 0

# Get document content
pub fn document_get(store: *DocumentStore, uri: *u8) -> *Document
    let idx: i32 = document_find(store, uri)
    if idx < 0
        return null
    return &store.docs[idx]
