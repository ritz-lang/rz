# spire/test/test_app.ritz
#
# Tests for SpireApp configuration and context

import ritzlib.strview { StrView }
import ritzlib.string { String, string_from_strview }
import ritzlib.gvec { Vec, vec_new, vec_push }
import ritzlib.option

import spire.app { AppConfig, ConfigValue, app_config_new }
import spire.app { config_get, config_get_or, config_is_production, config_is_development }
import spire.app { RequestContext, request_context_new, context_set_user, context_is_authenticated }
import spire.app { HealthStatus, health_healthy, health_degraded, health_unhealthy }
import spire.app { health_is_healthy, health_is_ready }
import spire.app { ShutdownSignal, Graceful, Immediate, Restart, shutdown_is_graceful }
import spire.app { AppError, app_error_config, app_error_database, app_error_init }
import spire.app { app_error_message }
import spire.utils { strview_eq }

# ============================================================================
# AppConfig tests
# ============================================================================

[[test]]
fn test_app_config_new_empty() -> i32
    let cfg: AppConfig = app_config_new()
    # Should have no values
    0

[[test]]
fn test_config_get_not_found() -> i32
    let cfg: AppConfig = app_config_new()
    let key: StrView = "missing_key"
    match config_get(&cfg, &key)
        Some(_) => 1
        None => 0

[[test]]
fn test_config_get_or_default() -> i32
    let cfg: AppConfig = app_config_new()
    let key: StrView = "missing_key"
    let default_val: StrView = "default_value"
    let result: StrView = config_get_or(&cfg, &key, &default_val)
    assert strview_eq(&result, &default_val) == 1
    0

[[test]]
fn test_config_is_production_true() -> i32
    var cfg: AppConfig = app_config_new()
    let prod: StrView = "production"
    cfg.environment = string_from_strview(&prod)
    assert config_is_production(&cfg) == 1
    0

[[test]]
fn test_config_is_production_false() -> i32
    var cfg: AppConfig = app_config_new()
    let dev: StrView = "development"
    cfg.environment = string_from_strview(&dev)
    assert config_is_production(&cfg) == 0
    0

[[test]]
fn test_config_is_development_true() -> i32
    var cfg: AppConfig = app_config_new()
    let dev: StrView = "development"
    cfg.environment = string_from_strview(&dev)
    assert config_is_development(&cfg) == 1
    0

[[test]]
fn test_config_is_development_false() -> i32
    var cfg: AppConfig = app_config_new()
    let staging: StrView = "staging"
    cfg.environment = string_from_strview(&staging)
    assert config_is_development(&cfg) == 0
    0

# ============================================================================
# RequestContext tests
# ============================================================================

[[test]]
fn test_request_context_new() -> i32
    let req_id: StrView = "req-12345"
    let ctx: RequestContext = request_context_new(&req_id)
    # Should have the request_id set
    0

[[test]]
fn test_context_not_authenticated_by_default() -> i32
    let req_id: StrView = "req-12345"
    let ctx: RequestContext = request_context_new(&req_id)
    assert context_is_authenticated(&ctx) == 0
    0

[[test]]
fn test_context_set_user_authenticates() -> i32
    let req_id: StrView = "req-12345"
    var ctx: RequestContext = request_context_new(&req_id)
    let user_id: StrView = "user-67890"
    context_set_user(&ctx, &user_id)
    assert context_is_authenticated(&ctx) == 1
    0

# ============================================================================
# HealthStatus tests
# ============================================================================

[[test]]
fn test_health_healthy_is_healthy() -> i32
    let status: HealthStatus = health_healthy()
    assert health_is_healthy(&status) == 1
    0

[[test]]
fn test_health_healthy_is_ready() -> i32
    let status: HealthStatus = health_healthy()
    assert health_is_ready(&status) == 1
    0

[[test]]
fn test_health_degraded_is_not_healthy() -> i32
    let reason: StrView = "Database slow"
    let status: HealthStatus = health_degraded(&reason)
    assert health_is_healthy(&status) == 0
    0

[[test]]
fn test_health_degraded_is_ready() -> i32
    let reason: StrView = "Database slow"
    let status: HealthStatus = health_degraded(&reason)
    # Degraded is still ready (can serve requests)
    assert health_is_ready(&status) == 1
    0

[[test]]
fn test_health_unhealthy_is_not_healthy() -> i32
    let reason: StrView = "Database down"
    let status: HealthStatus = health_unhealthy(&reason)
    assert health_is_healthy(&status) == 0
    0

[[test]]
fn test_health_unhealthy_is_not_ready() -> i32
    let reason: StrView = "Database down"
    let status: HealthStatus = health_unhealthy(&reason)
    # Unhealthy is NOT ready
    assert health_is_ready(&status) == 0
    0

# ============================================================================
# ShutdownSignal tests
# ============================================================================

[[test]]
fn test_shutdown_graceful_is_graceful() -> i32
    let signal: ShutdownSignal = Graceful
    assert shutdown_is_graceful(&signal) == 1
    0

[[test]]
fn test_shutdown_restart_is_graceful() -> i32
    let signal: ShutdownSignal = Restart
    assert shutdown_is_graceful(&signal) == 1
    0

[[test]]
fn test_shutdown_immediate_is_not_graceful() -> i32
    let signal: ShutdownSignal = Immediate
    assert shutdown_is_graceful(&signal) == 0
    0

# ============================================================================
# AppError tests
# ============================================================================

[[test]]
fn test_app_error_config() -> i32
    let msg: StrView = "Invalid config"
    let err: AppError = app_error_config(&msg)
    let result: StrView = app_error_message(&err)
    assert strview_eq(&result, &msg) == 1
    0

[[test]]
fn test_app_error_database() -> i32
    let msg: StrView = "Connection failed"
    let err: AppError = app_error_database(&msg)
    let result: StrView = app_error_message(&err)
    assert strview_eq(&result, &msg) == 1
    0

[[test]]
fn test_app_error_init() -> i32
    let msg: StrView = "Failed to start"
    let err: AppError = app_error_init(&msg)
    let result: StrView = app_error_message(&err)
    assert strview_eq(&result, &msg) == 1
    0
