# spire/test/test_http_method.ritz
#
# Tests for HTTP method types and operations

import ritzlib.strview { StrView }
import ritzlib.option

import spire.http.method { Method, GET, POST, PUT, DELETE, PATCH, HEAD, OPTIONS }
import spire.http.method { method_from_str, method_to_str }
import spire.http.method { method_is_safe, method_is_idempotent, method_has_body }

# ============================================================================
# method_from_str tests
# ============================================================================

[[test]]
fn test_method_from_str_get() -> i32
    let input: StrView = "GET"
    match method_from_str(&input)
        Some(m) =>
            let output: StrView = method_to_str(&m)
            let expected: StrView = "GET"
            assert output.len == expected.len
            0
        None => 1

[[test]]
fn test_method_from_str_post() -> i32
    let input: StrView = "POST"
    match method_from_str(&input)
        Some(m) =>
            let output: StrView = method_to_str(&m)
            let expected: StrView = "POST"
            assert output.len == expected.len
            0
        None => 1

[[test]]
fn test_method_from_str_put() -> i32
    let input: StrView = "PUT"
    match method_from_str(&input)
        Some(m) =>
            let output: StrView = method_to_str(&m)
            let expected: StrView = "PUT"
            assert output.len == expected.len
            0
        None => 1

[[test]]
fn test_method_from_str_delete() -> i32
    let input: StrView = "DELETE"
    match method_from_str(&input)
        Some(m) =>
            let output: StrView = method_to_str(&m)
            let expected: StrView = "DELETE"
            assert output.len == expected.len
            0
        None => 1

[[test]]
fn test_method_from_str_patch() -> i32
    let input: StrView = "PATCH"
    match method_from_str(&input)
        Some(m) =>
            let output: StrView = method_to_str(&m)
            let expected: StrView = "PATCH"
            assert output.len == expected.len
            0
        None => 1

[[test]]
fn test_method_from_str_invalid() -> i32
    let input: StrView = "INVALID"
    match method_from_str(&input)
        Some(_) => 1  # Should not match
        None => 0     # Expected

[[test]]
fn test_method_from_str_lowercase_fails() -> i32
    # HTTP methods are case-sensitive per RFC 7230
    let input: StrView = "get"
    match method_from_str(&input)
        Some(_) => 1  # Should not match
        None => 0     # Expected

# ============================================================================
# method_to_str tests
# ============================================================================

[[test]]
fn test_method_to_str_get() -> i32
    let s: StrView = method_to_str(&GET)
    assert s.len == 3
    0

[[test]]
fn test_method_to_str_post() -> i32
    let s: StrView = method_to_str(&POST)
    assert s.len == 4
    0

[[test]]
fn test_method_to_str_delete() -> i32
    let s: StrView = method_to_str(&DELETE)
    assert s.len == 6
    0

# ============================================================================
# method_is_safe tests
# ============================================================================

[[test]]
fn test_get_is_safe() -> i32
    assert method_is_safe(&GET) == 1
    0

[[test]]
fn test_head_is_safe() -> i32
    assert method_is_safe(&HEAD) == 1
    0

[[test]]
fn test_options_is_safe() -> i32
    assert method_is_safe(&OPTIONS) == 1
    0

[[test]]
fn test_post_is_not_safe() -> i32
    assert method_is_safe(&POST) == 0
    0

[[test]]
fn test_put_is_not_safe() -> i32
    assert method_is_safe(&PUT) == 0
    0

[[test]]
fn test_delete_is_not_safe() -> i32
    assert method_is_safe(&DELETE) == 0
    0

[[test]]
fn test_patch_is_not_safe() -> i32
    assert method_is_safe(&PATCH) == 0
    0

# ============================================================================
# method_is_idempotent tests
# ============================================================================

[[test]]
fn test_get_is_idempotent() -> i32
    assert method_is_idempotent(&GET) == 1
    0

[[test]]
fn test_put_is_idempotent() -> i32
    assert method_is_idempotent(&PUT) == 1
    0

[[test]]
fn test_delete_is_idempotent() -> i32
    assert method_is_idempotent(&DELETE) == 1
    0

[[test]]
fn test_post_is_not_idempotent() -> i32
    assert method_is_idempotent(&POST) == 0
    0

[[test]]
fn test_patch_is_not_idempotent() -> i32
    assert method_is_idempotent(&PATCH) == 0
    0

# ============================================================================
# method_has_body tests
# ============================================================================

[[test]]
fn test_post_has_body() -> i32
    assert method_has_body(&POST) == 1
    0

[[test]]
fn test_put_has_body() -> i32
    assert method_has_body(&PUT) == 1
    0

[[test]]
fn test_patch_has_body() -> i32
    assert method_has_body(&PATCH) == 1
    0

[[test]]
fn test_get_has_no_body() -> i32
    assert method_has_body(&GET) == 0
    0

[[test]]
fn test_head_has_no_body() -> i32
    assert method_has_body(&HEAD) == 0
    0

[[test]]
fn test_delete_has_no_body() -> i32
    assert method_has_body(&DELETE) == 0
    0
