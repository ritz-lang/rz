# spire/test/test_model_timestamp.ritz
#
# Tests for Timestamp type

import ritzlib.strview { StrView }
import ritzlib.option

import spire.model.timestamp { Timestamp, timestamp_now, timestamp_zero }
import spire.model.timestamp { timestamp_from_unix, timestamp_to_unix }
import spire.model.timestamp { timestamp_from_iso8601, timestamp_to_iso8601 }
import spire.model.timestamp { timestamp_eq, timestamp_lt, timestamp_gt }
import spire.model.timestamp { timestamp_add_seconds, timestamp_sub_seconds }
import spire.utils { strview_eq }

# ============================================================================
# timestamp_zero tests
# ============================================================================

[[test]]
fn test_timestamp_zero_value() -> i32
    let t: Timestamp = timestamp_zero()
    assert t.seconds == 0
    assert t.nanos == 0
    0

[[test]]
fn test_timestamp_zero_to_unix() -> i32
    let t: Timestamp = timestamp_zero()
    assert timestamp_to_unix(&t) == 0
    0

# ============================================================================
# timestamp_now tests
# ============================================================================

[[test]]
fn test_timestamp_now_is_not_zero() -> i32
    let t: Timestamp = timestamp_now()
    # Current time should be after Unix epoch
    assert t.seconds > 0
    0

[[test]]
fn test_timestamp_now_is_reasonable() -> i32
    let t: Timestamp = timestamp_now()
    # After year 2020: 1577836800 (Jan 1, 2020)
    # Before year 2100: 4102444800 (Jan 1, 2100)
    assert t.seconds > 1577836800
    assert t.seconds < 4102444800
    0

[[test]]
fn test_timestamp_now_nanos_in_range() -> i32
    let t: Timestamp = timestamp_now()
    # Nanoseconds should be 0-999999999
    assert t.nanos >= 0
    assert t.nanos < 1000000000
    0

# ============================================================================
# timestamp_from_unix tests
# ============================================================================

[[test]]
fn test_timestamp_from_unix_zero() -> i32
    let t: Timestamp = timestamp_from_unix(0)
    assert t.seconds == 0
    assert t.nanos == 0
    0

[[test]]
fn test_timestamp_from_unix_positive() -> i32
    let t: Timestamp = timestamp_from_unix(1234567890)
    assert t.seconds == 1234567890
    0

[[test]]
fn test_timestamp_from_unix_roundtrip() -> i32
    let original: i64 = 1609459200  # Jan 1, 2021
    let t: Timestamp = timestamp_from_unix(original)
    let result: i64 = timestamp_to_unix(&t)
    assert result == original
    0

# ============================================================================
# timestamp_to_unix tests
# ============================================================================

[[test]]
fn test_timestamp_to_unix_zero() -> i32
    let t: Timestamp = timestamp_zero()
    assert timestamp_to_unix(&t) == 0
    0

[[test]]
fn test_timestamp_to_unix_with_nanos() -> i32
    var t: Timestamp = timestamp_zero()
    t.seconds = 1000
    t.nanos = 500000000  # 0.5 seconds
    # to_unix should return just seconds
    assert timestamp_to_unix(&t) == 1000
    0

# ============================================================================
# timestamp_from_iso8601 tests
# ============================================================================

[[test]]
fn test_timestamp_from_iso8601_valid() -> i32
    let s: StrView = "2021-01-01T00:00:00Z"
    match timestamp_from_iso8601(&s)
        Some(t) =>
            # Jan 1, 2021 00:00:00 UTC = 1609459200
            assert t.seconds == 1609459200
            0
        None => 1

[[test]]
fn test_timestamp_from_iso8601_with_time() -> i32
    let s: StrView = "2021-06-15T12:30:45Z"
    match timestamp_from_iso8601(&s)
        Some(t) =>
            assert t.seconds > 0
            0
        None => 1

[[test]]
fn test_timestamp_from_iso8601_invalid() -> i32
    let s: StrView = "not-a-date"
    match timestamp_from_iso8601(&s)
        Some(_) => 1  # Should fail
        None => 0     # Expected

[[test]]
fn test_timestamp_from_iso8601_empty() -> i32
    let s: StrView = ""
    match timestamp_from_iso8601(&s)
        Some(_) => 1
        None => 0

# ============================================================================
# timestamp_to_iso8601 tests
# ============================================================================

[[test]]
fn test_timestamp_to_iso8601_zero() -> i32
    let t: Timestamp = timestamp_zero()
    let s: StrView = timestamp_to_iso8601(&t)
    # 1970-01-01T00:00:00Z
    assert s.len == 20
    0

[[test]]
fn test_timestamp_to_iso8601_format() -> i32
    let t: Timestamp = timestamp_from_unix(1609459200)  # Jan 1, 2021
    let s: StrView = timestamp_to_iso8601(&t)
    # Check format: YYYY-MM-DDTHH:MM:SSZ
    # Position 4: '-'
    assert *(s.ptr + 4) == 45
    # Position 7: '-'
    assert *(s.ptr + 7) == 45
    # Position 10: 'T'
    assert *(s.ptr + 10) == 84
    # Position 13: ':'
    assert *(s.ptr + 13) == 58
    # Position 16: ':'
    assert *(s.ptr + 16) == 58
    0

[[test]]
fn test_timestamp_to_iso8601_roundtrip() -> i32
    let original: StrView = "2021-01-01T00:00:00Z"
    match timestamp_from_iso8601(&original)
        Some(t) =>
            let result: StrView = timestamp_to_iso8601(&t)
            assert strview_eq(&result, &original) == 1
            0
        None => 1

# ============================================================================
# Comparison tests
# ============================================================================

[[test]]
fn test_timestamp_eq_same() -> i32
    let t1: Timestamp = timestamp_from_unix(1000)
    let t2: Timestamp = timestamp_from_unix(1000)
    assert timestamp_eq(&t1, &t2) == 1
    0

[[test]]
fn test_timestamp_eq_different_seconds() -> i32
    let t1: Timestamp = timestamp_from_unix(1000)
    let t2: Timestamp = timestamp_from_unix(2000)
    assert timestamp_eq(&t1, &t2) == 0
    0

[[test]]
fn test_timestamp_eq_different_nanos() -> i32
    var t1: Timestamp = timestamp_from_unix(1000)
    var t2: Timestamp = timestamp_from_unix(1000)
    t1.nanos = 100
    t2.nanos = 200
    assert timestamp_eq(&t1, &t2) == 0
    0

[[test]]
fn test_timestamp_lt_less() -> i32
    let t1: Timestamp = timestamp_from_unix(1000)
    let t2: Timestamp = timestamp_from_unix(2000)
    assert timestamp_lt(&t1, &t2) == 1
    0

[[test]]
fn test_timestamp_lt_greater() -> i32
    let t1: Timestamp = timestamp_from_unix(2000)
    let t2: Timestamp = timestamp_from_unix(1000)
    assert timestamp_lt(&t1, &t2) == 0
    0

[[test]]
fn test_timestamp_lt_equal() -> i32
    let t1: Timestamp = timestamp_from_unix(1000)
    let t2: Timestamp = timestamp_from_unix(1000)
    assert timestamp_lt(&t1, &t2) == 0
    0

[[test]]
fn test_timestamp_gt_greater() -> i32
    let t1: Timestamp = timestamp_from_unix(2000)
    let t2: Timestamp = timestamp_from_unix(1000)
    assert timestamp_gt(&t1, &t2) == 1
    0

[[test]]
fn test_timestamp_gt_less() -> i32
    let t1: Timestamp = timestamp_from_unix(1000)
    let t2: Timestamp = timestamp_from_unix(2000)
    assert timestamp_gt(&t1, &t2) == 0
    0

# ============================================================================
# Arithmetic tests
# ============================================================================

[[test]]
fn test_timestamp_add_seconds() -> i32
    var t: Timestamp = timestamp_from_unix(1000)
    timestamp_add_seconds(&t, 500)
    assert t.seconds == 1500
    0

[[test]]
fn test_timestamp_add_seconds_negative() -> i32
    var t: Timestamp = timestamp_from_unix(1000)
    timestamp_add_seconds(&t, -500)
    assert t.seconds == 500
    0

[[test]]
fn test_timestamp_sub_seconds() -> i32
    var t: Timestamp = timestamp_from_unix(1000)
    timestamp_sub_seconds(&t, 500)
    assert t.seconds == 500
    0
