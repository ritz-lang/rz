[[test]]
fn test_400_is_error() -> i32
    let s: Status = status_bad_request()
    assert status_is_error(&s) == 1
    0

[[test]]
fn test_401_is_error() -> i32
    let s: Status = status_unauthorized()
    assert status_is_error(&s) == 1
    0

[[test]]
fn test_403_is_error() -> i32
    let s: Status = status_forbidden()
    assert status_is_error(&s) == 1
    0

[[test]]
fn test_404_is_error() -> i32
    let s: Status = status_not_found()
    assert status_is_error(&s) == 1
    0

[[test]]
fn test_500_is_error() -> i32
    let s: Status = status_internal_server_error()
    assert status_is_error(&s) == 1
    0

[[test]]
fn test_200_is_not_error() -> i32
    let s: Status = status_ok()
    assert status_is_error(&s) == 0
    0

[[test]]
fn test_201_is_not_error() -> i32
    let s: Status = status_created()
    assert status_is_error(&s) == 0
    0

[[test]]
fn test_302_is_not_error() -> i32
