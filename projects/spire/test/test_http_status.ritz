# spire/test/test_http_status.ritz
#
# Tests for HTTP status codes and operations

import ritzlib.strview { StrView }
import ritzlib.option

import spire.http.status { Status, status_from_code }
import spire.http.status { status_ok, status_created, status_no_content }
import spire.http.status { status_moved_permanently, status_found, status_see_other }
import spire.http.status { status_bad_request, status_unauthorized, status_forbidden }
import spire.http.status { status_not_found, status_conflict, status_unprocessable_entity }
import spire.http.status { status_internal_server_error }
import spire.http.status { status_is_success, status_is_redirect, status_is_error }

# ============================================================================
# Status constructor tests
# ============================================================================

[[test]]
fn test_status_ok_code() -> i32
    let s: Status = status_ok()
    assert s.code == 200
    0

[[test]]
fn test_status_created_code() -> i32
    let s: Status = status_created()
    assert s.code == 201
    0

[[test]]
fn test_status_no_content_code() -> i32
    let s: Status = status_no_content()
    assert s.code == 204
    0

[[test]]
fn test_status_moved_permanently_code() -> i32
    let s: Status = status_moved_permanently()
    assert s.code == 301
    0

[[test]]
fn test_status_found_code() -> i32
    let s: Status = status_found()
    assert s.code == 302
    0

[[test]]
fn test_status_see_other_code() -> i32
    let s: Status = status_see_other()
    assert s.code == 303
    0

[[test]]
fn test_status_bad_request_code() -> i32
    let s: Status = status_bad_request()
    assert s.code == 400
    0

[[test]]
fn test_status_unauthorized_code() -> i32
    let s: Status = status_unauthorized()
    assert s.code == 401
    0

[[test]]
fn test_status_forbidden_code() -> i32
    let s: Status = status_forbidden()
    assert s.code == 403
    0

[[test]]
fn test_status_not_found_code() -> i32
    let s: Status = status_not_found()
    assert s.code == 404
    0

[[test]]
fn test_status_conflict_code() -> i32
    let s: Status = status_conflict()
    assert s.code == 409
    0

[[test]]
fn test_status_unprocessable_entity_code() -> i32
    let s: Status = status_unprocessable_entity()
    assert s.code == 422
    0

[[test]]
fn test_status_internal_server_error_code() -> i32
    let s: Status = status_internal_server_error()
    assert s.code == 500
    0

# ============================================================================
# status_from_code tests
# ============================================================================

[[test]]
fn test_status_from_code_200() -> i32
    match status_from_code(200)
        Some(s) =>
            assert s.code == 200
            0
        None => 1

[[test]]
fn test_status_from_code_404() -> i32
    match status_from_code(404)
        Some(s) =>
            assert s.code == 404
            0
        None => 1

[[test]]
fn test_status_from_code_500() -> i32
    match status_from_code(500)
        Some(s) =>
            assert s.code == 500
            0
        None => 1

# ============================================================================
# status_is_success tests
# ============================================================================

[[test]]
fn test_200_is_success() -> i32
    let s: Status = status_ok()
    assert status_is_success(&s) == 1
    0

[[test]]
fn test_201_is_success() -> i32
    let s: Status = status_created()
    assert status_is_success(&s) == 1
    0

[[test]]
fn test_204_is_success() -> i32
    let s: Status = status_no_content()
    assert status_is_success(&s) == 1
    0

[[test]]
fn test_301_is_not_success() -> i32
    let s: Status = status_moved_permanently()
    assert status_is_success(&s) == 0
    0

[[test]]
fn test_400_is_not_success() -> i32
    let s: Status = status_bad_request()
    assert status_is_success(&s) == 0
    0

[[test]]
fn test_500_is_not_success() -> i32
    let s: Status = status_internal_server_error()
    assert status_is_success(&s) == 0
    0

# ============================================================================
# status_is_redirect tests
# ============================================================================

[[test]]
fn test_301_is_redirect() -> i32
    let s: Status = status_moved_permanently()
    assert status_is_redirect(&s) == 1
    0

[[test]]
fn test_302_is_redirect() -> i32
    let s: Status = status_found()
    assert status_is_redirect(&s) == 1
    0

[[test]]
fn test_303_is_redirect() -> i32
    let s: Status = status_see_other()
    assert status_is_redirect(&s) == 1
    0

[[test]]
fn test_200_is_not_redirect() -> i32
    let s: Status = status_ok()
    assert status_is_redirect(&s) == 0
    0

[[test]]
fn test_404_is_not_redirect() -> i32
    let s: Status = status_not_found()
    assert status_is_redirect(&s) == 0
    0

