# spire/test/test_http_request.ritz
#
# Tests for HTTP Request type

import ritzlib.strview { StrView }
import ritzlib.option

import spire.http.method { Method, GET, POST, PUT, DELETE }
import spire.http.request { Request, request_new, request_with }
import spire.http.request { request_method, request_path, request_param }
import spire.http.request { request_query_param, request_header, request_body_str, request_body_len }
import spire.http.request { request_wants_json, request_wants_html }
import spire.http.request { request_is_json, request_is_form }
import spire.http.request { request_set_header, request_set_param, request_set_query }
import spire.utils { strview_eq }

# ============================================================================
# request_new tests
# ============================================================================

[[test]]
fn test_request_new_default_method_is_get() -> i32
    let req: Request = request_new()
    # Default method should be GET
    let expected: StrView = "GET"
    let actual: Method = request_method(&req)
    # Compare by checking the method enum
    0

[[test]]
fn test_request_new_default_path_is_root() -> i32
    let req: Request = request_new()
    let path: StrView = request_path(&req)
    let expected: StrView = "/"
    assert strview_eq(&path, &expected) == 1
    0

[[test]]
fn test_request_new_body_is_empty() -> i32
    let req: Request = request_new()
    assert request_body_len(&req) == 0
    0

# ============================================================================
# request_with tests
# ============================================================================

[[test]]
fn test_request_with_get() -> i32
    let path: StrView = "/api/tasks"
    let req: Request = request_with(GET, &path)
    let actual_path: StrView = request_path(&req)
    assert strview_eq(&actual_path, &path) == 1
    0

[[test]]
fn test_request_with_post() -> i32
    let path: StrView = "/api/tasks"
    let req: Request = request_with(POST, &path)
    let actual_path: StrView = request_path(&req)
    assert strview_eq(&actual_path, &path) == 1
    0

[[test]]
fn test_request_with_complex_path() -> i32
    let path: StrView = "/api/users/123/tasks/456"
    let req: Request = request_with(GET, &path)
    let actual_path: StrView = request_path(&req)
    assert strview_eq(&actual_path, &path) == 1
    0

# ============================================================================
# request_param tests (route parameters like :id)
# ============================================================================

[[test]]
fn test_request_param_set_and_get() -> i32
    var req: Request = request_new()
    let name: StrView = "id"
    let value: StrView = "123"
    request_set_param(&req, &name, &value)
    match request_param(&req, &name)
        Some(v) =>
            assert strview_eq(&v, &value) == 1
            0
        None => 1

[[test]]
fn test_request_param_not_found() -> i32
    let req: Request = request_new()
    let name: StrView = "missing"
    match request_param(&req, &name)
        Some(_) => 1
        None => 0

[[test]]
fn test_request_param_multiple() -> i32
    var req: Request = request_new()
    let id_name: StrView = "id"
    let id_value: StrView = "123"
    let slug_name: StrView = "slug"
    let slug_value: StrView = "hello-world"
    request_set_param(&req, &id_name, &id_value)
    request_set_param(&req, &slug_name, &slug_value)

    match request_param(&req, &id_name)
        Some(v) =>
            assert strview_eq(&v, &id_value) == 1
        None => return 1

    match request_param(&req, &slug_name)
        Some(v) =>
            assert strview_eq(&v, &slug_value) == 1
            0
        None => 1

