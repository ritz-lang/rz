[[test]]
fn test_request_header_set_and_get() -> i32
    var req: Request = request_new()
    let name: StrView = "X-Custom-Header"
    let value: StrView = "custom-value"
    request_set_header(&req, &name, &value)
    match request_header(&req, &name)
        Some(v) =>
            assert strview_eq(&v, &value) == 1
            0
        None => 1

[[test]]
fn test_request_header_not_found() -> i32
    let req: Request = request_new()
    let name: StrView = "X-Missing"
    match request_header(&req, &name)
        Some(_) => 1
        None => 0

# ============================================================================
# content negotiation tests
# ============================================================================

[[test]]
fn test_request_wants_json_with_accept_json() -> i32
    var req: Request = request_new()
    let name: StrView = "Accept"
    let value: StrView = "application/json"
    request_set_header(&req, &name, &value)
    assert request_wants_json(&req) == 1
    0

[[test]]
fn test_request_wants_json_with_wildcard() -> i32
    var req: Request = request_new()
    let name: StrView = "Accept"
    let value: StrView = "*/*"
    request_set_header(&req, &name, &value)
    assert request_wants_json(&req) == 1
    0

[[test]]
fn test_request_wants_json_without_accept() -> i32
    let req: Request = request_new()
    assert request_wants_json(&req) == 0
    0

[[test]]
fn test_request_wants_html_with_accept_html() -> i32
    var req: Request = request_new()
    let name: StrView = "Accept"
    let value: StrView = "text/html"
    request_set_header(&req, &name, &value)
    assert request_wants_html(&req) == 1
    0

[[test]]
fn test_request_wants_html_default() -> i32
    # Without Accept header, should default to HTML
    let req: Request = request_new()
    assert request_wants_html(&req) == 1
    0

# ============================================================================
# content type checks
# ============================================================================

[[test]]
fn test_request_is_json_with_json_content_type() -> i32
    var req: Request = request_new()
    let name: StrView = "Content-Type"
    let value: StrView = "application/json"
    request_set_header(&req, &name, &value)
    assert request_is_json(&req) == 1
    0

[[test]]
fn test_request_is_json_with_json_charset() -> i32
    var req: Request = request_new()
    let name: StrView = "Content-Type"
    let value: StrView = "application/json; charset=utf-8"
    request_set_header(&req, &name, &value)
    assert request_is_json(&req) == 1
    0

[[test]]
fn test_request_is_json_without_content_type() -> i32
    let req: Request = request_new()
    assert request_is_json(&req) == 0
    0

[[test]]
fn test_request_is_form_with_form_content_type() -> i32
    var req: Request = request_new()
    let name: StrView = "Content-Type"
    let value: StrView = "application/x-www-form-urlencoded"
    request_set_header(&req, &name, &value)
    assert request_is_form(&req) == 1
    0

[[test]]
fn test_request_is_form_without_content_type() -> i32
    let req: Request = request_new()
    assert request_is_form(&req) == 0
    0
