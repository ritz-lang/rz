[[test]]
fn test_header_content_type_value() -> i32
    let ct: StrView = header_content_type()
    let expected: StrView = "Content-Type"
    assert strview_eq(&ct, &expected) == 1
    0

[[test]]
fn test_header_content_length_value() -> i32
    let cl: StrView = header_content_length()
    let expected: StrView = "Content-Length"
    assert strview_eq(&cl, &expected) == 1
    0

[[test]]
fn test_header_accept_value() -> i32
    let a: StrView = header_accept()
    let expected: StrView = "Accept"
    assert strview_eq(&a, &expected) == 1
    0

