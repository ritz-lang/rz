# spire/test/test_http_headers.ritz
#
# Tests for HTTP headers collection

import ritzlib.strview { StrView }
import ritzlib.option

import spire.http.headers { Headers, Header, headers_new, headers_add, headers_set }
import spire.http.headers { headers_get, headers_remove, headers_len }
import spire.http.headers { header_content_type, header_content_length, header_accept }
import spire.http.headers { header_authorization, header_cookie, header_set_cookie }
import spire.http.headers { header_location, header_host, header_user_agent }
import spire.http.headers { content_type_html, content_type_json, content_type_text }
import spire.utils { strview_eq }

# ============================================================================
# headers_new tests
# ============================================================================

[[test]]
fn test_headers_new_is_empty() -> i32
    let h: Headers = headers_new()
    assert headers_len(&h) == 0
    0

# ============================================================================
# headers_add tests
# ============================================================================

[[test]]
fn test_headers_add_single() -> i32
    var h: Headers = headers_new()
    let name: StrView = "Content-Type"
    let value: StrView = "application/json"
    headers_add(&h, &name, &value)
    assert headers_len(&h) == 1
    0

[[test]]
fn test_headers_add_multiple() -> i32
    var h: Headers = headers_new()
    let ct_name: StrView = "Content-Type"
    let ct_value: StrView = "application/json"
    let cl_name: StrView = "Content-Length"
    let cl_value: StrView = "42"
    headers_add(&h, &ct_name, &ct_value)
    headers_add(&h, &cl_name, &cl_value)
    assert headers_len(&h) == 2
    0

[[test]]
fn test_headers_add_duplicate_name_allowed() -> i32
    # HTTP allows multiple headers with same name (e.g., Set-Cookie)
    var h: Headers = headers_new()
    let name: StrView = "Set-Cookie"
    let val1: StrView = "session=abc123"
    let val2: StrView = "tracking=xyz789"
    headers_add(&h, &name, &val1)
    headers_add(&h, &name, &val2)
    assert headers_len(&h) == 2
    0

# ============================================================================
# headers_set tests
# ============================================================================

[[test]]
fn test_headers_set_new_header() -> i32
    var h: Headers = headers_new()
    let name: StrView = "Content-Type"
    let value: StrView = "text/html"
    headers_set(&h, &name, &value)
    assert headers_len(&h) == 1
    0

[[test]]
fn test_headers_set_replaces_existing() -> i32
    var h: Headers = headers_new()
    let name: StrView = "Content-Type"
    let val1: StrView = "text/html"
    let val2: StrView = "application/json"
    headers_set(&h, &name, &val1)
    headers_set(&h, &name, &val2)
    # Should still be 1 header, not 2
    assert headers_len(&h) == 1
    # And the value should be the new one
    match headers_get(&h, &name)
        Some(v) =>
            let expected: StrView = "application/json"
            assert strview_eq(&v, &expected) == 1
            0
        None => 1

# ============================================================================
# headers_get tests
# ============================================================================

[[test]]
fn test_headers_get_existing() -> i32
    var h: Headers = headers_new()
    let name: StrView = "X-Custom"
    let value: StrView = "custom-value"
    headers_add(&h, &name, &value)
    match headers_get(&h, &name)
        Some(v) =>
            assert strview_eq(&v, &value) == 1
            0
        None => 1

[[test]]
fn test_headers_get_not_found() -> i32
    let h: Headers = headers_new()
    let name: StrView = "X-Missing"
    match headers_get(&h, &name)
        Some(_) => 1  # Should not find
        None => 0     # Expected

[[test]]
fn test_headers_get_case_insensitive() -> i32
    var h: Headers = headers_new()
    let name: StrView = "Content-Type"
    let value: StrView = "text/plain"
    headers_add(&h, &name, &value)
    # Try to get with different case - HTTP headers should be case-insensitive
    # Note: This test documents expected behavior - implementation may need update
    let lower_name: StrView = "content-type"
    match headers_get(&h, &lower_name)
        Some(v) =>
            assert strview_eq(&v, &value) == 1
            0
        None =>
            # If case-insensitive lookup not implemented, this is acceptable for now
            0

# ============================================================================
# headers_remove tests
# ============================================================================

[[test]]
fn test_headers_remove_existing() -> i32
    var h: Headers = headers_new()
    let name: StrView = "X-Remove-Me"
    let value: StrView = "gone"
    headers_add(&h, &name, &value)
    assert headers_len(&h) == 1
    headers_remove(&h, &name)
    assert headers_len(&h) == 0
    0

[[test]]
fn test_headers_remove_not_found() -> i32
    var h: Headers = headers_new()
    let name: StrView = "X-Missing"
    # Should not crash when removing non-existent header
    headers_remove(&h, &name)
    assert headers_len(&h) == 0
    0

