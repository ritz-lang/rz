# spire/test/test_http_response.ritz
#
# Tests for HTTP Response type

import ritzlib.strview { StrView }
import ritzlib.option

import spire.http.status { Status, status_ok, status_created, status_not_found }
import spire.http.response { Response, response_new, response_ok, response_created }
import spire.http.response { response_bad_request, response_unauthorized, response_forbidden }
import spire.http.response { response_not_found, response_internal_error }
import spire.http.response { response_html, response_json_str, response_text }
import spire.http.response { response_redirect, response_redirect_permanent }
import spire.http.response { response_json_error, response_error_bad_request }
import spire.http.response { response_error_not_found, response_error_internal }
import spire.http.response { response_status_code, response_body_len }
import spire.http.headers { headers_get }
import spire.utils { strview_eq }

# ============================================================================
# Constructor tests
# ============================================================================

[[test]]
fn test_response_ok_status_code() -> i32
    let resp: Response = response_ok()
    assert response_status_code(&resp) == 200
    0

[[test]]
fn test_response_created_status_code() -> i32
    let resp: Response = response_created()
    assert response_status_code(&resp) == 201
    0

[[test]]
fn test_response_bad_request_status_code() -> i32
    let resp: Response = response_bad_request()
    assert response_status_code(&resp) == 400
    0

[[test]]
fn test_response_unauthorized_status_code() -> i32
    let resp: Response = response_unauthorized()
    assert response_status_code(&resp) == 401
    0

[[test]]
fn test_response_forbidden_status_code() -> i32
    let resp: Response = response_forbidden()
    assert response_status_code(&resp) == 403
    0

[[test]]
fn test_response_not_found_status_code() -> i32
    let resp: Response = response_not_found()
    assert response_status_code(&resp) == 404
    0

[[test]]
fn test_response_internal_error_status_code() -> i32
    let resp: Response = response_internal_error()
    assert response_status_code(&resp) == 500
    0

# ============================================================================
# Body tests
# ============================================================================

[[test]]
fn test_response_new_body_is_empty() -> i32
    let resp: Response = response_ok()
    assert response_body_len(&resp) == 0
    0

[[test]]
fn test_response_html_sets_content_type() -> i32
    var resp: Response = response_ok()
    let html: StrView = "<h1>Hello</h1>"
    response_html(&resp, &html)
    let ct_name: StrView = "Content-Type"
    match headers_get(&resp.headers, &ct_name)
        Some(ct) =>
            let expected: StrView = "text/html"
            assert strview_eq(&ct, &expected) == 1
            0
        None => 1

[[test]]
fn test_response_html_sets_body() -> i32
    var resp: Response = response_ok()
    let html: StrView = "<h1>Hello</h1>"
    response_html(&resp, &html)
    assert response_body_len(&resp) == html.len
    0

[[test]]
fn test_response_json_str_sets_content_type() -> i32
    var resp: Response = response_ok()
    let json: StrView = "{\"key\": \"value\"}"
    response_json_str(&resp, &json)
    let ct_name: StrView = "Content-Type"
    match headers_get(&resp.headers, &ct_name)
        Some(ct) =>
            let expected: StrView = "application/json"
            assert strview_eq(&ct, &expected) == 1
            0
        None => 1

[[test]]
fn test_response_json_str_sets_body() -> i32
    var resp: Response = response_ok()
    let json: StrView = "{\"key\": \"value\"}"
    response_json_str(&resp, &json)
    assert response_body_len(&resp) == json.len
    0

[[test]]
fn test_response_text_sets_content_type() -> i32
    var resp: Response = response_ok()
    let text: StrView = "Hello, World!"
    response_text(&resp, &text)
    let ct_name: StrView = "Content-Type"
    match headers_get(&resp.headers, &ct_name)
        Some(ct) =>
            let expected: StrView = "text/plain"
            assert strview_eq(&ct, &expected) == 1
            0
        None => 1

# ============================================================================
# Redirect tests
# ============================================================================

[[test]]
fn test_response_redirect_status_code() -> i32
    let location: StrView = "/new-location"
    let resp: Response = response_redirect(&location)
    assert response_status_code(&resp) == 302
    0

[[test]]
fn test_response_redirect_sets_location() -> i32
    let location: StrView = "/new-location"
    let resp: Response = response_redirect(&location)
    let loc_name: StrView = "Location"
    match headers_get(&resp.headers, &loc_name)
        Some(loc) =>
            assert strview_eq(&loc, &location) == 1
            0
        None => 1

[[test]]
fn test_response_redirect_permanent_status_code() -> i32
    let location: StrView = "/permanent-location"
    let resp: Response = response_redirect_permanent(&location)
    assert response_status_code(&resp) == 301
    0

[[test]]
fn test_response_redirect_permanent_sets_location() -> i32
    let location: StrView = "/permanent-location"
    let resp: Response = response_redirect_permanent(&location)
    let loc_name: StrView = "Location"
    match headers_get(&resp.headers, &loc_name)
        Some(loc) =>
            assert strview_eq(&loc, &location) == 1
            0
        None => 1

# ============================================================================
# Error response tests
# ============================================================================

[[test]]
fn test_response_error_bad_request_status() -> i32
    let msg: StrView = "Invalid input"
    let resp: Response = response_error_bad_request(&msg)
    assert response_status_code(&resp) == 400
    0

[[test]]
fn test_response_error_bad_request_is_json() -> i32
    let msg: StrView = "Invalid input"
    let resp: Response = response_error_bad_request(&msg)
    let ct_name: StrView = "Content-Type"
    match headers_get(&resp.headers, &ct_name)
        Some(ct) =>
            let expected: StrView = "application/json"
            assert strview_eq(&ct, &expected) == 1
            0
        None => 1

[[test]]
fn test_response_error_bad_request_has_body() -> i32
    let msg: StrView = "Invalid input"
    let resp: Response = response_error_bad_request(&msg)
    assert response_body_len(&resp) > 0
    0

[[test]]
fn test_response_error_not_found_status() -> i32
    let msg: StrView = "Resource not found"
    let resp: Response = response_error_not_found(&msg)
    assert response_status_code(&resp) == 404
    0

[[test]]
fn test_response_error_internal_status() -> i32
    let msg: StrView = "Something went wrong"
    let resp: Response = response_error_internal(&msg)
    assert response_status_code(&resp) == 500
    0
