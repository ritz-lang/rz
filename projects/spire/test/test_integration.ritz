# spire/test/test_integration.ritz
#
# Integration tests for Spire framework
#
# These tests exercise the full request/response cycle including:
# - Router setup
# - Request handling
# - Response generation
# - Content negotiation

import ritzlib.strview { StrView }
import ritzlib.string { String, string_from_strview }
import ritzlib.gvec { Vec, vec_new, vec_push }
import ritzlib.option

import spire.http.method { Method, GET, POST, PUT, DELETE }
import spire.http.request { Request, request_new, request_with }
import spire.http.request { request_set_header, request_set_param }
import spire.http.response { Response, response_ok, response_created, response_not_found }
import spire.http.response { response_json_str, response_html, response_text }
import spire.http.response { response_status_code, response_body_len }
import spire.http.headers { headers_get }
import spire.router { Router, router_new, router_get, router_post, router_put, router_delete }
import spire.router { router_handle }
import spire.utils { strview_eq }
import test.test_utils { request_get, request_post, request_post_json }
import test.test_utils { request_accept_json, request_accept_html }
import test.test_utils { assert_status_ok, assert_status_created, assert_status_not_found }
import test.test_utils { assert_content_type_json, assert_content_type_html }
import test.test_utils { assert_body_contains }

# ============================================================================
# Test Handlers
# ============================================================================

fn handler_home(req: *Request) -> Response
    var resp: Response = response_ok()
    let html: StrView = "<h1>Welcome to Spire</h1>"
    response_html(&resp, &html)
    resp

fn handler_api_status(req: *Request) -> Response
    var resp: Response = response_ok()
    let json: StrView = "{\"status\": \"ok\"}"
    response_json_str(&resp, &json)
    resp

fn handler_tasks_list(req: *Request) -> Response
    var resp: Response = response_ok()
    let json: StrView = "{\"tasks\": []}"
    response_json_str(&resp, &json)
    resp

fn handler_tasks_create(req: *Request) -> Response
    var resp: Response = response_created()
    let json: StrView = "{\"id\": \"123\", \"title\": \"New Task\"}"
    response_json_str(&resp, &json)
    resp

fn handler_task_show(req: *Request) -> Response
    var resp: Response = response_ok()
    # In a real app, we'd use the :id param
    let json: StrView = "{\"id\": \"123\", \"title\": \"Task\"}"
    response_json_str(&resp, &json)
    resp

fn handler_task_update(req: *Request) -> Response
    var resp: Response = response_ok()
    let json: StrView = "{\"id\": \"123\", \"title\": \"Updated Task\"}"
    response_json_str(&resp, &json)
    resp

fn handler_task_delete(req: *Request) -> Response
    var resp: Response = response_ok()
    resp.status.code = 204  # No Content
    resp

fn handler_users_show(req: *Request) -> Response
    var resp: Response = response_ok()
    let json: StrView = "{\"id\": \"user123\", \"name\": \"Test User\"}"
    response_json_str(&resp, &json)
    resp

fn handler_custom_404(req: *Request) -> Response
    var resp: Response = response_not_found()
    let json: StrView = "{\"error\": \"Resource not found\"}"
    response_json_str(&resp, &json)
    resp

# ============================================================================
# Helper: Create test router
# ============================================================================

fn create_test_router() -> Router
    var r: Router = router_new()

    # Home page
    let home_path: StrView = "/"
    router_get(&r, &home_path, handler_home)

    # API status
    let status_path: StrView = "/api/status"
    router_get(&r, &status_path, handler_api_status)

    # Tasks CRUD
    let tasks_path: StrView = "/api/tasks"
    router_get(&r, &tasks_path, handler_tasks_list)
    router_post(&r, &tasks_path, handler_tasks_create)

    let task_path: StrView = "/api/tasks/:id"
    router_get(&r, &task_path, handler_task_show)
    router_put(&r, &task_path, handler_task_update)
    router_delete(&r, &task_path, handler_task_delete)

    # Users
    let user_path: StrView = "/api/users/:id"
    router_get(&r, &user_path, handler_users_show)

    r

# ============================================================================
# Basic routing tests
# ============================================================================

[[test]]
fn test_integration_home_page() -> i32
    var router: Router = create_test_router()
    let path: StrView = "/"
    var req: Request = request_get(&path)
    let resp: Response = router_handle(&router, &req)

    assert response_status_code(&resp) == 200
    assert response_body_len(&resp) > 0
    0

[[test]]
fn test_integration_api_status() -> i32
    var router: Router = create_test_router()
    let path: StrView = "/api/status"
    var req: Request = request_get(&path)
    let resp: Response = router_handle(&router, &req)

    assert response_status_code(&resp) == 200
    # Should return JSON
    let ct_name: StrView = "Content-Type"
    match headers_get(&resp.headers, &ct_name)
        Some(ct) =>
            let expected: StrView = "application/json"
            assert strview_eq(&ct, &expected) == 1
        None => return 1
    0

# ============================================================================
# CRUD operation tests
# ============================================================================

[[test]]
fn test_integration_list_tasks() -> i32
    var router: Router = create_test_router()
    let path: StrView = "/api/tasks"
    var req: Request = request_get(&path)
    let resp: Response = router_handle(&router, &req)

    assert response_status_code(&resp) == 200
    0

[[test]]
fn test_integration_create_task() -> i32
    var router: Router = create_test_router()
    let path: StrView = "/api/tasks"
    let body: StrView = "{\"title\": \"New Task\"}"
    var req: Request = request_post_json(&path, &body)
    let resp: Response = router_handle(&router, &req)

    assert response_status_code(&resp) == 201
    0

[[test]]
fn test_integration_show_task() -> i32
    var router: Router = create_test_router()
    let path: StrView = "/api/tasks/123"
    var req: Request = request_get(&path)
    let resp: Response = router_handle(&router, &req)

    assert response_status_code(&resp) == 200
    0

[[test]]
fn test_integration_update_task() -> i32
    var router: Router = create_test_router()
    let path: StrView = "/api/tasks/123"
    var req: Request = request_with(PUT, &path)
    let ct_name: StrView = "Content-Type"
    let ct_value: StrView = "application/json"
    request_set_header(&req, &ct_name, &ct_value)
    let resp: Response = router_handle(&router, &req)

    assert response_status_code(&resp) == 200
    0

[[test]]
fn test_integration_delete_task() -> i32
    var router: Router = create_test_router()
    let path: StrView = "/api/tasks/123"
    var req: Request = request_with(DELETE, &path)
    let resp: Response = router_handle(&router, &req)

    assert response_status_code(&resp) == 204
    0

