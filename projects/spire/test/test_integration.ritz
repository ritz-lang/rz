# ============================================================================
# 404 handling tests
# ============================================================================

[[test]]
fn test_integration_not_found() -> i32
    var router: Router = create_test_router()
    let path: StrView = "/api/nonexistent"
    var req: Request = request_get(&path)
    let resp: Response = router_handle(&router, &req)

    assert response_status_code(&resp) == 404
    0

[[test]]
fn test_integration_wrong_method() -> i32
    var router: Router = create_test_router()
    # Try POST on a GET-only route
    let path: StrView = "/api/status"
    var req: Request = request_with(POST, &path)
    let resp: Response = router_handle(&router, &req)

    assert response_status_code(&resp) == 404
    0

# ============================================================================
# Content negotiation tests
# ============================================================================

[[test]]
fn test_integration_home_returns_html() -> i32
    var router: Router = create_test_router()
    let path: StrView = "/"
    var req: Request = request_get(&path)
    request_accept_html(&req)
    let resp: Response = router_handle(&router, &req)

    let ct_name: StrView = "Content-Type"
    match headers_get(&resp.headers, &ct_name)
        Some(ct) =>
            let expected: StrView = "text/html"
            assert strview_eq(&ct, &expected) == 1
            0
        None => 1

[[test]]
fn test_integration_api_returns_json() -> i32
    var router: Router = create_test_router()
    let path: StrView = "/api/tasks"
    var req: Request = request_get(&path)
    request_accept_json(&req)
    let resp: Response = router_handle(&router, &req)

    let ct_name: StrView = "Content-Type"
    match headers_get(&resp.headers, &ct_name)
        Some(ct) =>
            let expected: StrView = "application/json"
            assert strview_eq(&ct, &expected) == 1
            0
        None => 1

# ============================================================================
# Multiple requests to same router
# ============================================================================

[[test]]
fn test_integration_multiple_requests() -> i32
    var router: Router = create_test_router()

    # First request
    let path1: StrView = "/api/tasks"
    var req1: Request = request_get(&path1)
    let resp1: Response = router_handle(&router, &req1)
    assert response_status_code(&resp1) == 200

    # Second request
    let path2: StrView = "/api/users/123"
    var req2: Request = request_get(&path2)
    let resp2: Response = router_handle(&router, &req2)
    assert response_status_code(&resp2) == 200

    # Third request
    let path3: StrView = "/"
    var req3: Request = request_get(&path3)
    let resp3: Response = router_handle(&router, &req3)
    assert response_status_code(&resp3) == 200

    0

# ============================================================================
# Edge cases
# ============================================================================

[[test]]
fn test_integration_root_only() -> i32
    var router: Router = router_new()
    let path: StrView = "/"
    router_get(&router, &path, handler_home)

    let req_path: StrView = "/"
    var req: Request = request_get(&req_path)
    let resp: Response = router_handle(&router, &req)

    assert response_status_code(&resp) == 200
    0

[[test]]
fn test_integration_nested_paths() -> i32
    var router: Router = router_new()

    let path1: StrView = "/a"
    let path2: StrView = "/a/b"
    let path3: StrView = "/a/b/c"

    router_get(&router, &path1, handler_api_status)
    router_get(&router, &path2, handler_api_status)
    router_get(&router, &path3, handler_api_status)

    # Test each level
    let req_path: StrView = "/a/b"
    var req: Request = request_get(&req_path)
    let resp: Response = router_handle(&router, &req)

    assert response_status_code(&resp) == 200
    0
