# spire/model/mod.ritz
#
# Model module - Types and utilities for data models
#
# Models in Spire are pure data structs decorated with @model.
# The @model attribute enables:
# - JSON serialization/deserialization
# - Schema metadata for migrations
# - Field validation descriptors
#
# Example:
#
#   @model
#   struct Task
#       id: Uuid
#       title: String
#       completed: i32  # 0 = false, 1 = true
#       created_at: Timestamp
#
# The code generator (spire-gen) processes @model attributes
# and generates serialization code.

# Re-export model types
pub import lib.model.uuid { Uuid, uuid_zero, uuid_new_v4, uuid_from_str }
pub import lib.model.uuid { uuid_to_string, uuid_eq, uuid_is_zero }

pub import lib.model.timestamp { Timestamp, timestamp_zero, timestamp_now }
pub import lib.model.timestamp { timestamp_from_unix, timestamp_from_millis }
pub import lib.model.timestamp { timestamp_unix, timestamp_millis }
pub import lib.model.timestamp { timestamp_eq, timestamp_lt, timestamp_gt }
pub import lib.model.timestamp { timestamp_add_seconds, timestamp_add_days }
pub import lib.model.timestamp { timestamp_to_iso8601 }

# ============================================================================
# Model Attribute Documentation
# ============================================================================
#
# The @model attribute tells spire-gen to generate:
#
# 1. JSON Serialization:
#    fn task_to_json(t: *Task) -> String
#    fn task_from_json(j: *StrView) -> Result<Task, ParseError>
#
# 2. Schema Metadata:
#    const TASK_SCHEMA: Schema = Schema { ... }
#
# 3. Field Attributes:
#    @model
#    struct User
#        id: Uuid
#        @unique
#        email: String
#        @nullable
#        bio: Option<String>
#        @default("now")
#        created_at: Timestamp
#
# The generator is external tooling (spire-gen), not compiler built-in.
# This keeps the compiler generic and Spire-specific logic in Spire.
