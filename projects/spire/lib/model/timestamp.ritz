# spire/model/timestamp.ritz
#
# Timestamp type for model datetime fields
#
# Unix timestamp (seconds since 1970-01-01 00:00:00 UTC)

import ritzlib.string { String, string_with_cap, string_push }
import ritzlib.sys { clock_gettime }

# Timestamp stored as Unix epoch seconds + nanoseconds
pub struct Timestamp
    seconds: i64
    nanos: i32

# Create zero timestamp (Unix epoch)
pub fn timestamp_zero() -> Timestamp
    var ts: Timestamp
    ts.seconds = 0
    ts.nanos = 0
    return ts

# Get current time
pub fn timestamp_now() -> Timestamp
    var ts: Timestamp
    # clock_gettime(CLOCK_REALTIME=0, @timespec)
    clock_gettime(0, @ts.seconds)
    return ts

# Create from Unix seconds
pub fn timestamp_from_unix(seconds: i64) -> Timestamp
    var ts: Timestamp
    ts.seconds = seconds
    ts.nanos = 0
    return ts

# Create from Unix milliseconds
pub fn timestamp_from_millis(millis: i64) -> Timestamp
    var ts: Timestamp
    ts.seconds = millis / 1000
    ts.nanos = ((millis % 1000) * 1000000) as i32
    return ts

# Get Unix seconds
pub fn timestamp_unix(ts: *Timestamp) -> i64
    return ts.seconds

# Get Unix milliseconds
pub fn timestamp_millis(ts: *Timestamp) -> i64
    return ts.seconds * 1000 + (ts.nanos / 1000000) as i64

# Compare timestamps
pub fn timestamp_eq(a: *Timestamp, b: *Timestamp) -> i32
    if a.seconds == b.seconds and a.nanos == b.nanos
        return 1
    return 0

pub fn timestamp_lt(a: *Timestamp, b: *Timestamp) -> i32
    if a.seconds != b.seconds
        if a.seconds < b.seconds
            return 1
        return 0
    if a.nanos < b.nanos
        return 1
    return 0

pub fn timestamp_gt(a: *Timestamp, b: *Timestamp) -> i32
    if a.seconds != b.seconds
        if a.seconds > b.seconds
            return 1
        return 0
    if a.nanos > b.nanos
        return 1
    return 0

pub fn timestamp_lte(a: *Timestamp, b: *Timestamp) -> i32
    if timestamp_gt(a, b) == 1
        return 0
    return 1

pub fn timestamp_gte(a: *Timestamp, b: *Timestamp) -> i32
    if timestamp_lt(a, b) == 1
        return 0
    return 1

# Add duration (seconds)
pub fn timestamp_add_seconds(ts: *Timestamp, seconds: i64) -> Timestamp
    var result: Timestamp
    result.seconds = ts.seconds + seconds
    result.nanos = ts.nanos
    return result

# Add duration (days)
pub fn timestamp_add_days(ts: *Timestamp, days: i64) -> Timestamp
    return timestamp_add_seconds(ts, days * 86400)

# Difference in seconds
pub fn timestamp_diff_seconds(a: *Timestamp, b: *Timestamp) -> i64
    return a.seconds - b.seconds

# Format as ISO 8601 (YYYY-MM-DDTHH:MM:SSZ)
pub fn timestamp_to_iso8601(ts: *Timestamp) -> String
    # Calculate date/time components
    var secs: i64 = ts.seconds

    # Days since epoch
    var days: i64 = secs / 86400
    var day_secs: i64 = secs % 86400

    # Time components
    let hours: i64 = day_secs / 3600
    let minutes: i64 = (day_secs % 3600) / 60
    let seconds: i64 = day_secs % 60

    # Date components (simplified - doesn't handle all edge cases)
    var year: i64 = 1970
    var month: i64 = 1
    var day: i64 = 1

    # Count years
    while days >= days_in_year(year)
        days -= days_in_year(year)
        year += 1

    # Count months
    while days >= days_in_month(year, month)
        days -= days_in_month(year, month)
        month += 1

    day = days + 1

    # Format string
    var s: String = string_with_cap(24)
    push_padded(@s, year, 4)
    string_push(@s, 45)  # '-'
    push_padded(@s, month, 2)
    string_push(@s, 45)  # '-'
    push_padded(@s, day, 2)
    string_push(@s, 84)  # 'T'
    push_padded(@s, hours, 2)
    string_push(@s, 58)  # ':'
    push_padded(@s, minutes, 2)
    string_push(@s, 58)  # ':'
    push_padded(@s, seconds, 2)
    string_push(@s, 90)  # 'Z'
    return s

# Helper: push zero-padded number
fn push_padded(s:& String, n: i64, width: i64)
    if width == 4
        string_push(s, (48 + ((n / 1000) % 10)) as u8)  # '0' = 48
        string_push(s, (48 + ((n / 100) % 10)) as u8)
        string_push(s, (48 + ((n / 10) % 10)) as u8)
        string_push(s, (48 + (n % 10)) as u8)
    else if width == 2
        string_push(s, (48 + ((n / 10) % 10)) as u8)
        string_push(s, (48 + (n % 10)) as u8)

fn is_leap_year(year: i64) -> i32
    if (year % 4 == 0 and year % 100 != 0) or (year % 400 == 0)
        return 1
    return 0

fn days_in_year(year: i64) -> i64
    if is_leap_year(year) == 1
        return 366
    return 365

fn days_in_month(year: i64, month: i64) -> i64
    if month == 1
        return 31
    if month == 2
        if is_leap_year(year) == 1
            return 29
        return 28
    if month == 3
        return 31
    if month == 4
        return 30
    if month == 5
        return 31
    if month == 6
        return 30
    if month == 7
        return 31
    if month == 8
        return 31
    if month == 9
        return 30
    if month == 10
        return 31
    if month == 11
        return 30
    if month == 12
        return 31
    return 30
