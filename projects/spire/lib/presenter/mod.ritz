    json_object_end(@builder)
    json_object_end(@builder)

    var resp: Response = response_new(status_forbidden())
    let body: StrView = json_builder_finish(@builder)
    response_json_str(@resp, @body)
    return resp

pub fn present_internal_error() -> Response
    var builder: JsonBuilder = json_builder_new()
    json_object_start(@builder)

    let success_field: StrView = "success"
    json_field_bool(@builder, success_field, 0)

    let error_field: StrView = "error"
    json_field_object(@builder, error_field)

    let code_field: StrView = "code"
    let code_val: StrView = "INTERNAL_ERROR"
    json_field_str(@builder, code_field, code_val)

    let msg_field: StrView = "message"
    let msg_val: StrView = "An internal error occurred"
    json_field_str(@builder, msg_field, msg_val)

    json_object_end(@builder)
    json_object_end(@builder)

    var resp: Response = response_new(status_internal_server_error())
    let body: StrView = json_builder_finish(@builder)
    response_json_str(@resp, @body)
    return resp

# ============================================================================
# Content negotiation
# ============================================================================

# Present based on Accept header
pub fn present_negotiated(request: *Request, json: StrView, html: StrView) -> Response
    if request_wants_json(request) != 0
        var resp: Response = response_ok()
        response_json_str(@resp, @json)
        return resp
    else
        var resp: Response = response_ok()
        response_html(@resp, @html)
        return resp

# ============================================================================
# Raw JSON field insertion helper
# ============================================================================

fn json_field_raw(builder:& JsonBuilder, name: StrView, value: StrView)
    # Write field name
    maybe_comma(builder)
    vec_push<u8>(@builder.buffer, 34)  # '"'
    var i: i64 = 0
    while i < name.len
        vec_push<u8>(@builder.buffer, *(name.ptr + i))
        i += 1
    vec_push<u8>(@builder.buffer, 34)  # '"'
    vec_push<u8>(@builder.buffer, 58)  # ':'

    # Write raw value
    i = 0
    while i < value.len
        vec_push<u8>(@builder.buffer, *(value.ptr + i))
        i += 1

    set_needs_comma(builder)

fn maybe_comma(builder:& JsonBuilder)
    let len: i64 = vec_len<i32>(@builder.needs_comma)
    if len > 0
        if *(builder.needs_comma.data + len - 1) != 0
            vec_push<u8>(@builder.buffer, 44)  # ','

fn set_needs_comma(builder:& JsonBuilder)
    let len: i64 = vec_len<i32>(@builder.needs_comma)
    if len > 0
        *(builder.needs_comma.data + len - 1) = 1
