# spire/http/mod.ritz
#
# HTTP module - High-level Request, Response, and related types
#
# This module provides Spire's web framework HTTP abstractions.
# It uses the `http` crate for low-level protocol handling and provides
# a more ergonomic API for web application development.

# Re-export HTTP methods from http crate
pub import http.types { METHOD_GET, METHOD_POST, METHOD_PUT, METHOD_DELETE, METHOD_PATCH, METHOD_HEAD, METHOD_OPTIONS, METHOD_TRACE, METHOD_CONNECT, method_from_span, method_to_span, STATUS_OK, STATUS_CREATED, STATUS_NO_CONTENT, STATUS_MOVED_PERMANENTLY, STATUS_FOUND, STATUS_SEE_OTHER, STATUS_NOT_MODIFIED, STATUS_BAD_REQUEST, STATUS_UNAUTHORIZED, STATUS_FORBIDDEN, STATUS_NOT_FOUND, STATUS_METHOD_NOT_ALLOWED, STATUS_CONFLICT, STATUS_UNPROCESSABLE_ENTITY, STATUS_INTERNAL_SERVER_ERROR, STATUS_NOT_IMPLEMENTED, STATUS_BAD_GATEWAY, STATUS_SERVICE_UNAVAILABLE, status_reason, status_is_success, status_is_redirect, status_is_client_error, status_is_server_error }

# Spire's high-level types
pub import lib.http.headers { Header, Headers, headers_new, headers_add, headers_set, headers_get, headers_contains, headers_remove, headers_len, header_content_type, header_content_length, header_accept, header_authorization, header_cookie, header_set_cookie, header_location, header_host, header_user_agent, content_type_html, content_type_json, content_type_text }

pub import lib.http.request { Request, request_new, request_with, request_method, request_path, request_param, request_query_param, request_header, request_body_str, request_body_len, request_wants_json, request_wants_html, request_is_json, request_is_form }

pub import lib.http.response { Response, response_new, response_ok, response_created, response_bad_request, response_unauthorized, response_forbidden, response_not_found, response_internal_error, response_html, response_json_str, response_text, response_redirect, response_redirect_permanent }
