fn show_help() -> i32
    let help: StrView = "Spire - MVRSPT Web Framework for Ritz

Usage: spire <command> [options]

Commands:
  test              Run tests
    -v, --verbose   Show test names as they run
    -q, --quiet     Minimal output (failures + summary)
    -f, --filter    Run only tests matching pattern
    --no-fork       Disable fork isolation (for debugging)
    -t, --timeout   Set per-test timeout in ms (default: 5000)

  serve             Start development server
    -p, --port      Port to listen on (default: 8000)
    -h, --host      Host to bind to (default: 127.0.0.1)
    --no-reload     Disable auto-reload

  routes            List all registered routes

  gen <type> <name> Generate boilerplate code
    Types: model, repo, service, presenter, migration

  migrate           Run pending database migrations

  shell             Start interactive shell

  help, --help      Show this help message
  version, -V       Show version

Examples:
  spire test                    # Run all tests
  spire test -f user            # Run tests matching 'user'
  spire serve -p 3000           # Start server on port 3000
  spire gen model Task          # Generate Task model
  spire gen repo Task           # Generate TaskRepository
"
    print_str(@help)
    0

fn show_version() -> i32
    let version: StrView = "Spire 0.1.0\n"
    print_str(@version)
    0

# ============================================================================
# Main Entry Point
# ============================================================================

# Call this from your app's main()
pub fn spire_cli_run(argc: i32, argv: **u8) -> i32
    let cmd: Command = parse_args(argc, argv)
    return execute_command(cmd)

# Simplified version for apps that manage their own argv
pub fn spire_cli(args: Vec<StrView>) -> i32
    # Convert Vec<StrView> to argc/argv style
    # For now, just handle common cases

    if vec_len<StrView>(@args) == 0
        return execute_command(Help)

    let first: StrView = vec_get<StrView>(@args, 0)

    let test_cmd: StrView = "test"
    let serve_cmd: StrView = "serve"
    let help_cmd: StrView = "help"

    if strview_eq(@first, @test_cmd) == 1
        var opts: TestOptions = test_options_default()
        # Parse remaining args...
        return execute_command(Test(opts))

    if strview_eq(@first, @serve_cmd) == 1
        var opts: ServeOptions = serve_options_default()
        return execute_command(Serve(opts))

    if strview_eq(@first, @help_cmd) == 1
        return execute_command(Help)

    return execute_command(Unknown(string_from_strview(@first)))

# ============================================================================
# Helper Functions
# ============================================================================

fn cstr_to_strview(s: *u8) -> StrView
    var len: i64 = 0
    while *(s + len) != 0
        len += 1
    return strview_from_ptr(s, len)

fn parse_i64(s: StrView) -> i64
    var result: i64 = 0
    var i: i64 = 0

    while i < s.len
        let ch: u8 = *(s.ptr + i)
        if ch >= 48 and ch <= 57
            result = result * 10 + (ch - 48) as i64
        i += 1

    return result

fn print_str(s: StrView)
    write(1, s.ptr, s.len)

fn print_u16(n: u16)
    var buf: [6]u8
    var count: i64 = 0
    var val: u16 = n

    if val == 0
        buf[0] = 48
        write(1, @buf[0], 1)
        return

    while val > 0
        buf[5 - count] = (48 + (val % 10)) as u8
        val = val / 10
        count += 1

    write(1, @buf[6 - count], count)
