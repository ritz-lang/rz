# test/test_math.ritz - Additional test file to verify multi-file discovery
#
# When compiled and linked with runner_test_v2.ritz, these test_* functions
# should also be discovered via ELF symbol table scanning.

import ritzlib.sys
import ritzlib.io

@test
fn test_multiplication() -> i32
    let result: i32 = 6 * 7
    if result == 42
        return 0  # PASS
    return 1  # FAIL

@test
fn test_division() -> i32
    let result: i32 = 100 / 4
    if result == 25
        return 0  # PASS
    return 1  # FAIL

@test
fn test_modulo() -> i32
    let result: i32 = 17 % 5
    if result == 2
        return 0  # PASS
    return 1  # FAIL

@test
fn test_negative() -> i32
    let a: i32 = -10
    let b: i32 = 3
    let result: i32 = a + b
    if result == -7
        return 0  # PASS
    return 1  # FAIL

# Non-test helper (should NOT be discovered)
fn math_helper() -> i32
    return 123
