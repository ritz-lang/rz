# test/test_assertions.ritz - Self-tests for ritzunit assertions
#
# These tests verify that the assertion functions work correctly.
# They don't depend on any external library, making them perfect
# for testing the test framework itself.

import ritzlib.sys
import ritzlib.io

# ============================================================================
# Boolean Assertions (inline to be self-contained)
# ============================================================================

fn assert_true(condition: i32) -> i32
    if condition != 0
        return 0  # PASS
    return 1  # FAIL

fn assert_false(condition: i32) -> i32
    if condition == 0
        return 0  # PASS
    return 1  # FAIL

fn assert_eq_i32(actual: i32, expected: i32) -> i32
    if actual == expected
        return 0  # PASS
    return 1  # FAIL

fn assert_ne_i32(actual: i32, expected: i32) -> i32
    if actual != expected
        return 0  # PASS
    return 1  # FAIL

fn assert_lt_i32(actual: i32, bound: i32) -> i32
    if actual < bound
        return 0  # PASS
    return 1  # FAIL

fn assert_le_i32(actual: i32, bound: i32) -> i32
    if actual <= bound
        return 0  # PASS
    return 1  # FAIL

fn assert_gt_i32(actual: i32, bound: i32) -> i32
    if actual > bound
        return 0  # PASS
    return 1  # FAIL

fn assert_ge_i32(actual: i32, bound: i32) -> i32
    if actual >= bound
        return 0  # PASS
    return 1  # FAIL

# ============================================================================
# Tests for assert_true
# ============================================================================

@test
fn test_assert_true_passes_on_nonzero() -> i32
    return assert_true(1)

@test
fn test_assert_true_passes_on_larger_nonzero() -> i32
    return assert_true(42)

@test
fn test_assert_true_passes_on_negative() -> i32
    return assert_true(-1)

@test
fn test_assert_true_fails_on_zero() -> i32
    # This tests that assert_true returns 1 (failure) when given 0
    let result: i32 = assert_true(0)
    if result == 1
        return 0  # Our meta-test passes
    return 1  # Our meta-test fails

# ============================================================================
# Tests for assert_false
# ============================================================================

@test
fn test_assert_false_passes_on_zero() -> i32
    return assert_false(0)

@test
fn test_assert_false_fails_on_nonzero() -> i32
    let result: i32 = assert_false(1)
    if result == 1
        return 0  # Our meta-test passes
    return 1  # Our meta-test fails

# ============================================================================
# Tests for assert_eq_i32
# ============================================================================

@test
fn test_assert_eq_passes_when_equal() -> i32
    return assert_eq_i32(42, 42)

@test
fn test_assert_eq_fails_when_different() -> i32
    let result: i32 = assert_eq_i32(42, 17)
    if result == 1
        return 0  # Our meta-test passes
    return 1  # Our meta-test fails

@test
fn test_assert_eq_zero() -> i32
    return assert_eq_i32(0, 0)

@test
fn test_assert_eq_negative() -> i32
    return assert_eq_i32(-5, -5)

# ============================================================================
# Tests for assert_ne_i32
# ============================================================================

@test
fn test_assert_ne_passes_when_different() -> i32
    return assert_ne_i32(42, 17)

@test
fn test_assert_ne_fails_when_equal() -> i32
    let result: i32 = assert_ne_i32(42, 42)
    if result == 1
        return 0  # Our meta-test passes
    return 1  # Our meta-test fails

# ============================================================================
# Tests for comparison assertions
# ============================================================================

@test
fn test_assert_lt_passes() -> i32
    return assert_lt_i32(5, 10)

@test
fn test_assert_lt_fails_when_equal() -> i32
    let result: i32 = assert_lt_i32(10, 10)
    if result == 1
        return 0
    return 1

@test
fn test_assert_lt_fails_when_greater() -> i32
    let result: i32 = assert_lt_i32(15, 10)
    if result == 1
        return 0
    return 1

@test
fn test_assert_le_passes_when_less() -> i32
    return assert_le_i32(5, 10)

@test
fn test_assert_le_passes_when_equal() -> i32
    return assert_le_i32(10, 10)

@test
fn test_assert_le_fails_when_greater() -> i32
    let result: i32 = assert_le_i32(15, 10)
    if result == 1
        return 0
    return 1

@test
fn test_assert_gt_passes() -> i32
    return assert_gt_i32(10, 5)

@test
fn test_assert_ge_passes_when_greater() -> i32
    return assert_ge_i32(10, 5)

@test
fn test_assert_ge_passes_when_equal() -> i32
    return assert_ge_i32(10, 10)

# ============================================================================
# Edge cases
# ============================================================================

@test
fn test_large_numbers_equal() -> i32
    return assert_eq_i32(2147483647, 2147483647)

@test
fn test_large_negative_equal() -> i32
    return assert_eq_i32(-2147483648, -2147483648)
