# Simple test file to verify ritzunit's ELF-based discovery
#
# Test functions must be prefixed with test_ to be discovered.

import ritzlib.sys
import ritzlib.io

# Helper to simulate test pass
fn test_passes() -> i32
    return 0

# Helper to simulate test fail
fn test_also_passes() -> i32
    return 0

# Test addition
fn test_addition() -> i32
    let result: i32 = 2 + 2
    if result == 4
        return 0
    return 1

# Test comparison
fn test_comparison() -> i32
    if 5 > 3
        return 0
    return 1

# Non-test function (should not be discovered)
fn helper_function() -> i32
    return 42
