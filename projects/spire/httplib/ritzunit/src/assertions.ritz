# ritzunit/src/assertions.ritz - Assertion library for unit tests
#
# Provides assertion functions that return error codes for test failures.
# All assertions return 0 on success, non-zero on failure.
#
# Usage in tests:
#   let result: i32 = assert_eq_i32(actual, expected)
#   if result != 0
#       return result
#
# Uses ritz string interpolation for clear failure messages.

import ritzlib.io
import ritzlib.str

# ============================================================================
# Boolean Assertions
# ============================================================================

# Assert condition is true (non-zero)
fn assert_true(condition: i32) -> i32
    if condition != 0
        return 0  # PASS
    "FAIL: expected true, got false\n"
    return 1  # FAIL

# Assert condition is false (zero)
fn assert_false(condition: i32) -> i32
    if condition == 0
        return 0  # PASS
    "FAIL: expected false, got true\n"
    return 1  # FAIL

# ============================================================================
# Integer Equality Assertions
# ============================================================================

# Assert two i32 values are equal
fn assert_eq_i32(actual: i32, expected: i32) -> i32
    if actual == expected
        return 0  # PASS
    "FAIL: assert_eq_i32\n  expected: {expected}\n  actual:   {actual}\n"
    return 1  # FAIL

# Assert two i64 values are equal
fn assert_eq_i64(actual: i64, expected: i64) -> i32
    if actual == expected
        return 0  # PASS
    "FAIL: assert_eq_i64\n  expected: {expected}\n  actual:   {actual}\n"
    return 1  # FAIL

# Assert two i32 values are not equal
fn assert_ne_i32(actual: i32, expected: i32) -> i32
    if actual != expected
        return 0  # PASS
    "FAIL: assert_ne_i32 - values should differ\n  both were: {actual}\n"
    return 1  # FAIL

# Assert two i64 values are not equal
fn assert_ne_i64(actual: i64, expected: i64) -> i32
    if actual != expected
        return 0  # PASS
    "FAIL: assert_ne_i64 - values should differ\n  both were: {actual}\n"
    return 1  # FAIL

# ============================================================================
# Comparison Assertions
# ============================================================================

# Assert actual < expected
fn assert_lt_i32(actual: i32, bound: i32) -> i32
    if actual < bound
        return 0  # PASS
    "FAIL: assert_lt_i32\n  expected: < {bound}\n  actual:   {actual}\n"
    return 1  # FAIL

# Assert actual <= expected
fn assert_le_i32(actual: i32, bound: i32) -> i32
    if actual <= bound
        return 0  # PASS
    "FAIL: assert_le_i32\n  expected: <= {bound}\n  actual:   {actual}\n"
    return 1  # FAIL

# Assert actual > expected
fn assert_gt_i32(actual: i32, bound: i32) -> i32
    if actual > bound
        return 0  # PASS
    "FAIL: assert_gt_i32\n  expected: > {bound}\n  actual:   {actual}\n"
    return 1  # FAIL

# Assert actual >= expected
fn assert_ge_i32(actual: i32, bound: i32) -> i32
    if actual >= bound
        return 0  # PASS
    "FAIL: assert_ge_i32\n  expected: >= {bound}\n  actual:   {actual}\n"
    return 1  # FAIL

# ============================================================================
# String Assertions
# ============================================================================

# Assert two null-terminated strings are equal
fn assert_str_eq(actual: *u8, expected: *u8) -> i32
    if str_eq(actual, expected, str_len(expected)) == 1
        return 0  # PASS
    "FAIL: assert_str_eq\n  expected: \"{expected}\"\n  actual:   \"{actual}\"\n"
    return 1  # FAIL

# Assert string starts with prefix
fn assert_starts_with(s: *u8, prefix: *u8) -> i32
    var i: i64 = 0
    while *(prefix + i) != 0
        if *(s + i) != *(prefix + i)
            "FAIL: assert_starts_with\n  string: \"{s}\"\n  prefix: \"{prefix}\"\n"
            return 1  # FAIL
        i += 1
    return 0  # PASS

# Assert string contains substring
fn assert_contains(haystack: *u8, needle: *u8) -> i32
    let needle_len: i64 = str_len(needle)
    var i: i64 = 0
    while *(haystack + i) != 0
        if str_eq(haystack + i, needle, needle_len) == 1
            return 0  # PASS - found
        i += 1
    "FAIL: assert_contains\n  haystack: \"{haystack}\"\n  needle:   \"{needle}\"\n"
    return 1  # FAIL

# ============================================================================
# Pointer Assertions
# ============================================================================

# Assert pointer is not null
fn assert_not_null(ptr: *u8) -> i32
    if ptr != null
        return 0  # PASS
    "FAIL: assert_not_null - pointer was null\n"
    return 1  # FAIL

# Assert pointer is null
fn assert_null(ptr: *u8) -> i32
    if ptr == null
        return 0  # PASS
    "FAIL: assert_null - pointer was not null\n"
    return 1  # FAIL
