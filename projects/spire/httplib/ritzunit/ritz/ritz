#!/usr/bin/env python3
"""
🎭 ritz - The Ritz Language Toolchain

A unified command-line interface for all Ritz development workflows.

USAGE
    ritz <command> [options] [args]

COMMANDS
    Build & Run
        build       Build a package or source file
        run         Compile and run a single .ritz file
        clean       Remove build artifacts and caches

    Testing
        test        Build and run tests for a package
        check       Run language tests (ritz0 test suite)

    Development
        compile     Low-level: compile .ritz to .ll (direct ritz0 access)
        fmt         Format Ritz source files (TODO)
        lint        Check for common issues (TODO)

    Package Management
        new         Create a new Ritz project
        init        Initialize ritz.toml in current directory
        package     Package project for distribution

    Toolchain
        version     Show version information
        help        Show this help message

EXAMPLES
    # Build and test a package
    ritz build 01_hello
    ritz test 01_hello

    # Compile and run a single file
    ritz run examples/01_hello/src/main.ritz

    # Run language test suite
    ritz check

    # Low-level compilation
    ritz compile src/main.ritz -o build/main.ll

    # Create a new project
    ritz new myproject
    cd myproject
    ritz build

    # Initialize existing directory
    ritz init

    # Package for distribution
    ritz package

ENVIRONMENT
    RITZ_PATH   Colon-separated list of directories to search for imports.
                Defaults to the project root (detected by .git or ritzlib/).

FILES
    ritz.toml   Package manifest (name, version, binaries, dependencies)
    ritzlib/    Standard library modules
    examples/   Example packages with test suites

For more information, visit: https://github.com/nevelis/langdev
"""

import sys
import os
import argparse
import subprocess
from pathlib import Path

# Add ritz0 to path for imports
SCRIPT_DIR = Path(__file__).parent.resolve()
RITZ0_DIR = SCRIPT_DIR / "ritz0"
sys.path.insert(0, str(RITZ0_DIR))
sys.path.insert(0, str(SCRIPT_DIR))

# ============================================================================
# Version
# ============================================================================

VERSION = "0.1.0-dev"
CODENAME = "Bootstrap"

# ============================================================================
# Utilities
# ============================================================================

def find_project_root() -> Path:
    """Find the project root by looking for .git or ritzlib/."""
    cwd = Path.cwd()
    for parent in [cwd] + list(cwd.parents):
        if (parent / ".git").exists() or (parent / "ritzlib").exists():
            return parent
    return cwd


def print_error(msg: str):
    """Print an error message to stderr."""
    print(f"error: {msg}", file=sys.stderr)


def print_success(msg: str):
    """Print a success message."""
    print(f"✓ {msg}")


# ============================================================================
# Commands
# ============================================================================

def cmd_version(args):
    """Show version information."""
    print(f"ritz {VERSION} ({CODENAME})")
    print(f"  ritz0 compiler: {RITZ0_DIR}")
    print(f"  project root: {find_project_root()}")
    return 0


def cmd_help(args):
    """Show help message."""
    print(__doc__)
    return 0


def cmd_build(args):
    """Build a package or all packages."""
    # Delegate to build.py
    build_script = SCRIPT_DIR / "build.py"
    cmd = [sys.executable, str(build_script), "build"]

    if args.all:
        cmd.append("--all")
    elif args.target:
        cmd.append(args.target)
    else:
        print_error("specify a package name or --all")
        return 1

    if args.debug:
        cmd.append("--debug")
    if args.no_cache:
        cmd.append("--no-cache")

    return subprocess.run(cmd).returncode


def cmd_test(args):
    """Build and test a package."""
    build_script = SCRIPT_DIR / "build.py"
    cmd = [sys.executable, str(build_script), "test"]

    if args.all:
        cmd.append("--all")
    elif args.target:
        cmd.append(args.target)
    else:
        print_error("specify a package name or --all")
        return 1

    if args.debug:
        cmd.append("--debug")
    if args.no_cache:
        cmd.append("--no-cache")

    return subprocess.run(cmd).returncode


def cmd_run(args):
    """Compile and run a single .ritz file."""
    build_script = SCRIPT_DIR / "build.py"
    cmd = [sys.executable, str(build_script), "run", args.file]

    if args.debug:
        cmd.append("--debug")

    # Pass through program arguments
    if args.args:
        cmd.extend(args.args)

    return subprocess.run(cmd).returncode


def cmd_clean(args):
    """Remove build artifacts and caches."""
    build_script = SCRIPT_DIR / "build.py"
    return subprocess.run([sys.executable, str(build_script), "clean"]).returncode


def cmd_check(args):
    """Run the ritz0 language test suite."""
    build_script = SCRIPT_DIR / "build.py"
    cmd = [sys.executable, str(build_script)]

    if args.ritz1:
        cmd.append("ritz1-tests")
    else:
        cmd.append("ritz-tests")

    return subprocess.run(cmd).returncode


def cmd_compile(args):
    """Low-level: compile a .ritz file to LLVM IR."""
    ritz0_script = RITZ0_DIR / "ritz0.py"
    cmd = [sys.executable, str(ritz0_script), args.source]

    if args.output:
        cmd.extend(["-o", args.output])
    else:
        # Default output
        output = Path(args.source).stem + ".ll"
        cmd.extend(["-o", output])

    if args.no_runtime:
        cmd.append("--no-runtime")
    if args.verbose:
        cmd.append("--verbose")

    return subprocess.run(cmd).returncode


def cmd_regression(args):
    """Run the multi-stage regression test suite."""
    regression_script = SCRIPT_DIR / "scripts" / "regression.sh"
    cmd = ["bash", str(regression_script)]

    if args.stage:
        cmd.extend(["--stage", str(args.stage)])
    if args.quick:
        cmd.append("--quick")
    if args.verbose:
        cmd.append("--verbose")

    return subprocess.run(cmd).returncode


def cmd_cache(args):
    """Manage the build cache."""
    build_script = SCRIPT_DIR / "build.py"

    if args.action == "status":
        cmd = [sys.executable, str(build_script), "cache-status"]
        if args.verbose:
            cmd.append("--verbose")
    elif args.action == "clear":
        cmd = [sys.executable, str(build_script), "cache-clear"]
    else:
        print_error(f"unknown cache action: {args.action}")
        return 1

    return subprocess.run(cmd).returncode


def cmd_list(args):
    """List all available packages."""
    build_script = SCRIPT_DIR / "build.py"
    return subprocess.run([sys.executable, str(build_script), "list"]).returncode


def cmd_new(args):
    """Create a new Ritz project from template."""
    project_name = args.name
    project_dir = Path.cwd() / project_name

    if project_dir.exists():
        print_error(f"directory '{project_name}' already exists")
        return 1

    # Create project structure
    project_dir.mkdir()
    (project_dir / "src").mkdir()

    # Create ritz.toml
    toml_content = f'''[package]
name = "{project_name}"
version = "0.1.0"
authors = []
edition = "2024"
description = ""

[[bin]]
name = "{project_name}"
path = "src/main.ritz"

[dependencies]
# Add dependencies here

[build]
# Build settings

[test]
# Test settings
files = ["tests/*.ritz"]
'''
    (project_dir / "ritz.toml").write_text(toml_content)

    # Create main.ritz
    main_content = f'''# {project_name} - A Ritz project

fn main() -> i32
    # Welcome to Ritz!
    # Use the syscall wrappers from ritzlib for I/O:
    #
    # import ritzlib.sys {{ write }}
    # write(1, "Hello, World!\\n")

    0
'''
    (project_dir / "src" / "main.ritz").write_text(main_content)

    # Create tests directory
    (project_dir / "tests").mkdir()

    # Create a sample test
    test_content = f'''# Sample test for {project_name}
# Run with: ritz test

@test
fn test_example() -> i32
    # Add your tests here
    # Use assert statements:
    # assert 1 + 1 == 2
    0
'''
    (project_dir / "tests" / f"test_{project_name}.ritz").write_text(test_content)

    print_success(f"Created new Ritz project '{project_name}'")
    print(f"\n  cd {project_name}")
    print("  ritz build")
    print("  ritz run src/main.ritz\n")
    return 0


def cmd_init(args):
    """Initialize ritz.toml in current directory."""
    cwd = Path.cwd()
    toml_path = cwd / "ritz.toml"

    if toml_path.exists() and not args.force:
        print_error("ritz.toml already exists (use --force to overwrite)")
        return 1

    # Determine project name from directory
    project_name = cwd.name

    # Look for existing source files
    src_dir = cwd / "src"
    main_path = "src/main.ritz"
    if not src_dir.exists():
        # Check for main.ritz in current dir
        if (cwd / "main.ritz").exists():
            main_path = "main.ritz"

    toml_content = f'''[package]
name = "{project_name}"
version = "0.1.0"
authors = []
edition = "2024"
description = ""

[[bin]]
name = "{project_name}"
path = "{main_path}"

[dependencies]
# Add dependencies here

[build]
# Build settings

[test]
# Test settings
'''
    toml_path.write_text(toml_content)
    print_success(f"Created ritz.toml for '{project_name}'")
    return 0


def cmd_package(args):
    """Package the project for distribution."""
    import tarfile

    cwd = Path.cwd()
    toml_path = cwd / "ritz.toml"

    if not toml_path.exists():
        print_error("no ritz.toml found in current directory")
        return 1

    try:
        import tomllib
    except ImportError:
        import tomli as tomllib

    with open(toml_path, "rb") as f:
        config = tomllib.load(f)

    pkg_name = config.get("package", {}).get("name", cwd.name)
    pkg_version = config.get("package", {}).get("version", "0.0.0")

    # Build first
    print(f"Building {pkg_name} v{pkg_version}...")
    build_script = SCRIPT_DIR / "build.py"
    result = subprocess.run([sys.executable, str(build_script), "build", str(cwd)],
                          capture_output=True, text=True)
    if result.returncode != 0:
        print_error(f"build failed: {result.stderr}")
        return 1

    # Create dist directory
    dist_dir = cwd / "dist"
    dist_dir.mkdir(exist_ok=True)

    # Create tarball name
    tarball_name = f"{pkg_name}-{pkg_version}.tar.gz"
    tarball_path = dist_dir / tarball_name

    # Package the binary and any additional files
    with tarfile.open(tarball_path, "w:gz") as tar:
        # Add binaries from build directory
        build_dir = cwd / "build"
        if build_dir.exists():
            for bin_file in build_dir.iterdir():
                if bin_file.is_file() and not bin_file.suffix:
                    # Add binary to tar
                    arcname = f"{pkg_name}-{pkg_version}/bin/{bin_file.name}"
                    tar.add(bin_file, arcname=arcname)

        # Add ritz.toml
        tar.add(toml_path, arcname=f"{pkg_name}-{pkg_version}/ritz.toml")

        # Add README if exists
        for readme in ["README.md", "README.txt", "README"]:
            readme_path = cwd / readme
            if readme_path.exists():
                tar.add(readme_path, arcname=f"{pkg_name}-{pkg_version}/{readme}")
                break

        # Add LICENSE if exists
        for license_file in ["LICENSE", "LICENSE.txt", "LICENSE.md"]:
            license_path = cwd / license_file
            if license_path.exists():
                tar.add(license_path, arcname=f"{pkg_name}-{pkg_version}/{license_file}")
                break

    print_success(f"Created {tarball_path}")
    print(f"  Size: {tarball_path.stat().st_size:,} bytes")
    return 0


# ============================================================================
# Main
# ============================================================================

def main():
    parser = argparse.ArgumentParser(
        prog="ritz",
        description="🎭 The Ritz Language Toolchain",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="Run 'ritz help' for detailed usage information."
    )
    subparsers = parser.add_subparsers(dest="command", metavar="<command>")

    # version
    subparsers.add_parser("version", help="Show version information")

    # help
    subparsers.add_parser("help", help="Show detailed help")

    # build
    build_parser = subparsers.add_parser("build", help="Build a package")
    build_parser.add_argument("target", nargs="?", help="Package name or directory")
    build_parser.add_argument("--all", "-a", action="store_true", help="Build all packages")
    build_parser.add_argument("--debug", "-g", action="store_true",
                              help="Keep intermediate files for debugging")
    build_parser.add_argument("--no-cache", action="store_true",
                              help="Disable build cache")

    # test
    test_parser = subparsers.add_parser("test", help="Build and test a package")
    test_parser.add_argument("target", nargs="?", help="Package name or directory")
    test_parser.add_argument("--all", "-a", action="store_true", help="Test all packages")
    test_parser.add_argument("--debug", "-g", action="store_true",
                             help="Keep intermediate files for debugging")
    test_parser.add_argument("--no-cache", action="store_true",
                             help="Disable build cache")

    # run
    run_parser = subparsers.add_parser("run", help="Compile and run a .ritz file")
    run_parser.add_argument("file", help="Source file to run")
    run_parser.add_argument("args", nargs="*", help="Arguments to pass to the program")
    run_parser.add_argument("--debug", "-g", action="store_true",
                            help="Keep intermediate files for debugging")

    # clean
    subparsers.add_parser("clean", help="Remove build artifacts and caches")

    # check
    check_parser = subparsers.add_parser("check", help="Run language test suite")
    check_parser.add_argument("--ritz1", action="store_true",
                              help="Run ritz1 tests instead of ritz0 tests")

    # compile (low-level)
    compile_parser = subparsers.add_parser("compile", help="Compile .ritz to LLVM IR")
    compile_parser.add_argument("source", help="Source file to compile")
    compile_parser.add_argument("-o", "--output", help="Output .ll file")
    compile_parser.add_argument("--no-runtime", action="store_true",
                                help="Don't emit _start (for libraries)")
    compile_parser.add_argument("-v", "--verbose", action="store_true",
                                help="Verbose output")

    # regression
    regression_parser = subparsers.add_parser("regression",
                                               help="Run multi-stage regression suite")
    regression_parser.add_argument("--stage", "-s", type=int, choices=[1, 2, 3, 4],
                                   help="Run only specific stage")
    regression_parser.add_argument("--quick", "-q", action="store_true",
                                   help="Skip Stage 4 (slower)")
    regression_parser.add_argument("-v", "--verbose", action="store_true",
                                   help="Verbose output")

    # cache
    cache_parser = subparsers.add_parser("cache", help="Manage build cache")
    cache_parser.add_argument("action", choices=["status", "clear"],
                              help="Cache action to perform")
    cache_parser.add_argument("-v", "--verbose", action="store_true",
                              help="Show detailed information")

    # list
    subparsers.add_parser("list", help="List available packages")

    # new
    new_parser = subparsers.add_parser("new", help="Create a new Ritz project")
    new_parser.add_argument("name", help="Project name")

    # init
    init_parser = subparsers.add_parser("init", help="Initialize ritz.toml in current directory")
    init_parser.add_argument("--force", "-f", action="store_true",
                             help="Overwrite existing ritz.toml")

    # package
    subparsers.add_parser("package", help="Package project for distribution")

    # Parse arguments
    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        return 0

    # Dispatch to command handler
    commands = {
        "version": cmd_version,
        "help": cmd_help,
        "build": cmd_build,
        "test": cmd_test,
        "run": cmd_run,
        "clean": cmd_clean,
        "check": cmd_check,
        "compile": cmd_compile,
        "regression": cmd_regression,
        "cache": cmd_cache,
        "list": cmd_list,
        "new": cmd_new,
        "init": cmd_init,
        "package": cmd_package,
    }

    handler = commands.get(args.command)
    if handler:
        return handler(args)
    else:
        print_error(f"unknown command: {args.command}")
        return 1


if __name__ == "__main__":
    sys.exit(main())
