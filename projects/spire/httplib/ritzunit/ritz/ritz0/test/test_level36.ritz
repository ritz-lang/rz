# test_level36.ritz - Comprehensive operator tests
#
# Tests all operators in the Ritz language:
# - Bitwise: &, |, ^, ~, <<, >>
# - Comparison: ==, !=, <, >, <=, >=
# - Arithmetic: +, -, *, /, %
# - Logical: &&, ||, !
# - Unary: -, !, ~, @, *
# - Assignment: =, +=, -=, *=, /=
# - Postfix: ?, [] (indexing), . (field), () (call)

# ============================================================================
# Bitwise operators
# ============================================================================

@test
fn test_bitwise_and() -> i32
    # AND: both bits must be 1
    assert (0b1100 & 0b1010) == 0b1000, "0b1100 & 0b1010 = 0b1000"
    assert (0xFF & 0x0F) == 0x0F, "0xFF & 0x0F = 0x0F"
    assert (0 & 0xFFFFFFFF) == 0, "0 & any = 0"
    assert (0xFFFFFFFF & 0xFFFFFFFF) == 0xFFFFFFFF, "all ones & all ones"
    0

@test
fn test_bitwise_or() -> i32
    # OR: either bit can be 1
    assert (0b1100 | 0b1010) == 0b1110, "0b1100 | 0b1010 = 0b1110"
    assert (0xF0 | 0x0F) == 0xFF, "0xF0 | 0x0F = 0xFF"
    assert (0 | 0xAB) == 0xAB, "0 | x = x"
    0

@test
fn test_bitwise_xor() -> i32
    # XOR: bits must differ
    assert (0b1100 ^ 0b1010) == 0b0110, "0b1100 ^ 0b1010 = 0b0110"
    assert (0xFF ^ 0xFF) == 0, "x ^ x = 0"
    assert (0xAA ^ 0x55) == 0xFF, "alternating bits"
    assert (0 ^ 42) == 42, "0 ^ x = x"
    0

@test
fn test_bitwise_not() -> i32
    # NOT: flip all bits
    let x: i64 = 0
    let y: i64 = ~x
    # ~0 is all ones (signed -1)
    assert y == 0 - 1, "~0 = -1 (all ones)"

    let a: i64 = 0xFF
    let b: i64 = ~a
    # ~0xFF has upper bits set
    assert (b & 0xFF) == 0, "lower 8 bits are cleared"
    0

@test
fn test_shift_left() -> i32
    # Shift left: multiply by 2^n
    assert (1 << 0) == 1, "1 << 0 = 1"
    assert (1 << 1) == 2, "1 << 1 = 2"
    assert (1 << 4) == 16, "1 << 4 = 16"
    assert (1 << 8) == 256, "1 << 8 = 256"
    assert (0b101 << 2) == 0b10100, "0b101 << 2 = 0b10100"
    0

@test
fn test_shift_right() -> i32
    # Shift right: divide by 2^n (logical for unsigned)
    assert (16 >> 0) == 16, "16 >> 0 = 16"
    assert (16 >> 1) == 8, "16 >> 1 = 8"
    assert (16 >> 4) == 1, "16 >> 4 = 1"
    assert (256 >> 8) == 1, "256 >> 8 = 1"
    assert (0b10100 >> 2) == 0b101, "0b10100 >> 2 = 0b101"
    0

@test
fn test_bitwise_combined() -> i32
    # Combine multiple bitwise operations
    let flags: i64 = 0
    let flag1: i64 = 1
    let flag2: i64 = 2
    let flag4: i64 = 4

    # Set flags
    let result: i64 = flags | flag1 | flag4
    assert result == 5, "set bits 0 and 2"

    # Check flags
    assert (result & flag1) != 0, "flag1 is set"
    assert (result & flag2) == 0, "flag2 is not set"
    assert (result & flag4) != 0, "flag4 is set"

    # Clear flag
    let cleared: i64 = result & (~flag1)
    assert (cleared & flag1) == 0, "flag1 cleared"
    assert (cleared & flag4) != 0, "flag4 still set"

    # Toggle flag
    let toggled: i64 = result ^ flag1
    assert (toggled & flag1) == 0, "flag1 toggled off"
    0

# ============================================================================
# Modulo operator
# ============================================================================

@test
fn test_modulo() -> i32
    assert (10 % 3) == 1, "10 % 3 = 1"
    assert (15 % 5) == 0, "15 % 5 = 0"
    assert (7 % 2) == 1, "7 % 2 = 1"
    assert (100 % 7) == 2, "100 % 7 = 2"
    0

# ============================================================================
# Compound assignment operators
# ============================================================================

@test
fn test_plus_eq() -> i32
    var x: i32 = 10
    x += 5
    assert x == 15, "10 += 5 = 15"
    x += 1
    assert x == 16, "15 += 1 = 16"
    0

@test
fn test_minus_eq() -> i32
    var x: i32 = 20
    x -= 5
    assert x == 15, "20 -= 5 = 15"
    x -= 15
    assert x == 0, "15 -= 15 = 0"
    0

@test
fn test_star_eq() -> i32
    var x: i32 = 3
    x *= 4
    assert x == 12, "3 *= 4 = 12"
    x *= 2
    assert x == 24, "12 *= 2 = 24"
    0

@test
fn test_slash_eq() -> i32
    var x: i32 = 24
    x /= 4
    assert x == 6, "24 /= 4 = 6"
    x /= 2
    assert x == 3, "6 /= 2 = 3"
    0

# ============================================================================
# Logical operators
# ============================================================================

@test
fn test_logical_and() -> i32
    assert (1 == 1) && (2 == 2), "true && true = true"
    assert !((1 == 2) && (2 == 2)), "false && true = false"
    assert !((1 == 1) && (2 == 3)), "true && false = false"
    0

@test
fn test_logical_or() -> i32
    assert (1 == 1) || (2 == 3), "true || false = true"
    assert (1 == 2) || (2 == 2), "false || true = true"
    assert !((1 == 2) || (2 == 3)), "false || false = false"
    0

@test
fn test_logical_not() -> i32
    assert !(1 == 2), "!(false) = true"
    assert !!(1 == 1), "!!(true) = true"
    0

# ============================================================================
# Unary minus
# ============================================================================

@test
fn test_unary_minus() -> i32
    let x: i32 = 5
    let y: i32 = -x
    assert y == 0 - 5, "-5"

    let z: i32 = -10
    assert z == 0 - 10, "-10"

    assert -1 == 0 - 1, "-1"
    0

# ============================================================================
# Address-of and dereference
# ============================================================================

@test
fn test_address_of() -> i32
    var x: i32 = 42
    let ptr: *i32 = &x
    assert *ptr == 42, "deref of &x should be 42"
    0

@test
fn test_deref_assign() -> i32
    var x: i32 = 10
    let ptr: *i32 = &x
    *ptr = 20
    assert x == 20, "assignment through pointer"
    0

# ============================================================================
# Operator precedence
# ============================================================================

@test
fn test_precedence_mul_add() -> i32
    # * binds tighter than +
    assert 2 + 3 * 4 == 14, "2 + (3 * 4) = 14"
    assert 3 * 4 + 2 == 14, "(3 * 4) + 2 = 14"
    0

@test
fn test_precedence_shift_compare() -> i32
    # << should bind tighter than comparisons
    let x: i64 = 1 << 4
    assert x == 16, "1 << 4 = 16"
    assert (1 << 4) > 10, "16 > 10"
    0

@test
fn test_precedence_bitwise_logical() -> i32
    # Bitwise should bind tighter than logical
    let a: i64 = 0b1111
    let b: i64 = 0b0101
    assert ((a & b) == 0b0101) && ((a | b) == 0b1111), "bitwise before logical"
    0

@test
fn test_precedence_parentheses() -> i32
    assert (2 + 3) * 4 == 20, "(2 + 3) * 4 = 20"
    assert 2 * (3 + 4) == 14, "2 * (3 + 4) = 14"
    0
