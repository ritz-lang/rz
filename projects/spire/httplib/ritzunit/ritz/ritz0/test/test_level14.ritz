# Test Level 14: Heap Allocation
#
# Features tested:
# - mmap/munmap syscalls for memory regions
# - Heap allocation and deallocation
# - Allocating arrays of arbitrary size at runtime

# Constants for mmap
const PROT_READ: i32 = 1
const PROT_WRITE: i32 = 2
const PROT_RW: i32 = 3        # PROT_READ | PROT_WRITE

const MAP_PRIVATE: i32 = 2
const MAP_ANONYMOUS: i32 = 32
const MAP_ANON_PRIV: i32 = 34  # MAP_PRIVATE | MAP_ANONYMOUS

# mmap syscall: allocate memory from the kernel - prefixed to avoid conflict
# mmap(addr=0, length, prot, flags, fd=-1, offset=0) -> *u8
fn l14_alloc(size: i64) -> *u8
  # syscall6(9, addr, length, prot, flags, fd, offset)
  # syscall 9 = mmap on x86_64 Linux
  let result: i64 = syscall6(9, 0, size, 3, 34, -1, 0)
  # mmap returns -1 on error (or -errno)
  if result < 0
    return null  # null on failure
  result as *u8

# munmap syscall: release memory back to the kernel - prefixed to avoid conflict
# munmap(addr, length) -> i32
fn l14_free(ptr: *u8, size: i64) -> i32
  # syscall 11 = munmap on x86_64 Linux
  let result: i64 = syscall6(11, ptr as i64, size, 0, 0, 0, 0)
  result as i32

# ===== TESTS =====

@test
fn test_heap_alloc_basic() -> i32
  # Allocate a page of memory (4096 bytes)
  let ptr: *u8 = l14_alloc(4096)
  assert ptr != null

  # Write to the memory
  *ptr = 42
  assert *ptr == 42

  # Free the memory
  let result: i32 = l14_free(ptr, 4096)
  assert result == 0

  0

@test
fn test_heap_alloc_array() -> i32
  # Allocate space for 100 i32s (400 bytes)
  let size: i64 = 400
  let ptr: *u8 = l14_alloc(size)
  assert ptr != null

  # Cast to i32 pointer
  let arr: *i32 = ptr as *i32

  # Initialize array
  var i: i32 = 0
  while i < 100
    *(arr + i) = i * 2
    i = i + 1

  # Verify values
  assert *(arr + 0) == 0
  assert *(arr + 50) == 100
  assert *(arr + 99) == 198

  # Free
  l14_free(ptr, size)
  0

@test
fn test_heap_alloc_large() -> i32
  # Allocate 1MB
  let size: i64 = 1048576
  let ptr: *u8 = l14_alloc(size)
  assert ptr != null

  # Write to first and last byte
  *ptr = 1 as u8
  *(ptr + 1048575) = 99 as u8  # Use smaller value to avoid signed issues

  assert *ptr == 1
  assert *(ptr + 1048575) == 99

  l14_free(ptr, size)
  0

@test
fn test_heap_alloc_multiple() -> i32
  # Allocate multiple blocks
  let p1: *u8 = l14_alloc(4096)
  let p2: *u8 = l14_alloc(4096)
  let p3: *u8 = l14_alloc(4096)

  assert p1 != null
  assert p2 != null
  assert p3 != null

  # They should all be different addresses
  assert p1 != p2
  assert p2 != p3
  assert p1 != p3

  # Write different values
  *p1 = 1
  *p2 = 2
  *p3 = 3

  assert *p1 == 1
  assert *p2 == 2
  assert *p3 == 3

  l14_free(p3, 4096)
  l14_free(p2, 4096)
  l14_free(p1, 4096)
  0

# Struct for heap testing (defined at module level)
struct HeapPoint
  x: i32
  y: i32

@test
fn test_heap_struct_on_heap() -> i32
  # Allocate a struct on the heap
  let ptr: *u8 = l14_alloc(8)  # sizeof(HeapPoint) = 8
  assert ptr != null

  let p: *HeapPoint = ptr as *HeapPoint
  p.x = 10
  p.y = 20

  assert p.x == 10
  assert p.y == 20

  l14_free(ptr, 8)
  0

@test
fn test_heap_aligned_access() -> i32
  # Allocate and write i64 values (8-byte aligned)
  let size: i64 = 80  # 10 * 8 bytes
  let ptr: *u8 = l14_alloc(size)
  assert ptr != null

  let arr: *i64 = ptr as *i64
  var i: i64 = 0
  while i < 10
    *(arr + i) = i * 1000000000  # Use large values to test i64
    i = i + 1

  assert *(arr + 0) == 0
  assert *(arr + 5) == 5000000000
  assert *(arr + 9) == 9000000000

  l14_free(ptr, size)
  0

@test
fn test_heap_byte_buffer() -> i32
  # Allocate a byte buffer (common pattern for file I/O)
  let size: i64 = 256
  let buf: *u8 = l14_alloc(size)
  assert buf != null

  # Fill with a pattern
  var i: i32 = 0
  while i < 256
    *(buf + i) = i as u8
    i = i + 1

  # Verify pattern - cast literals to i32 for comparison
  let v0: i32 = *(buf + 0) as i32
  let v127: i32 = *(buf + 127) as i32
  let v255: i32 = *(buf + 255) as i32

  assert v0 == 0
  assert v127 == 127
  # 255 as u8 stays 255 when zero-extended to i32
  assert v255 == 255

  l14_free(buf, size)
  0

