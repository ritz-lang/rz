# Test Level 5: Arrays
#
# Features tested:
# - Stack-allocated arrays
# - Array indexing (read/write)
# - Array in function parameters
# - Array iteration

fn sum_array(arr: *i32, len: i32) -> i32
  var total: i32 = 0
  var i: i32 = 0
  while i < len
    total = total + *(arr + i)
    i = i + 1
  total

fn fill_array(arr: *i32, len: i32, val: i32) -> i32
  var i: i32 = 0
  while i < len
    *(arr + i) = val
    i = i + 1
  0

@test
fn test_stack_array_index() -> i32
  var arr: [3]i32 = [0, 0, 0]
  arr[0] = 10
  arr[1] = 20
  arr[2] = 30
  assert arr[0] == 10
  assert arr[1] == 20
  assert arr[2] == 30
  0

@test
fn test_array_sum() -> i32
  var arr: [4]i32 = [1, 2, 3, 4]
  let ptr: *i32 = &arr[0]
  assert sum_array(ptr, 4) == 10
  0

@test
fn test_array_write_via_ptr() -> i32
  var arr: [3]i32 = [0, 0, 0]
  let ptr: *i32 = &arr[0]
  fill_array(ptr, 3, 42)
  assert arr[0] == 42
  assert arr[1] == 42
  assert arr[2] == 42
  0

@test
fn test_array_init_values() -> i32
  var arr: [5]i32 = [5, 4, 3, 2, 1]
  assert arr[0] == 5
  assert arr[4] == 1
  0

