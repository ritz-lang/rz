# Test Level 16: Unsigned types and character literals
#
# Features tested:
# - Character literals ('A', 'z', etc.)
# - Unsigned comparisons (u8, u16, u32, u64)
# - Unsigned division and modulo
# - Proper extension (zext vs sext)

@test
fn test_char_literal_basic() -> i32
    # Basic character literal values
    let a: u8 = 'A'
    assert a == 65 as u8
    let z: u8 = 'z'
    assert z == 122 as u8
    let zero: u8 = '0'
    assert zero == 48 as u8
    let newline: u8 = '\n'
    assert newline == 10 as u8
    0

@test
fn test_char_comparison() -> i32
    # Character comparisons should use unsigned semantics
    let a: u8 = 'A'
    let b: u8 = 'B'
    assert a < b    # 65 < 66
    assert b > a
    assert a <= a
    assert b >= a
    0

@test
fn test_unsigned_high_values() -> i32
    # High values (> 127) should compare correctly with unsigned semantics
    # In signed interpretation, 200 would be -56, and 200 < 100 would be true
    # In unsigned interpretation, 200 > 100 is true
    let high: u8 = 200 as u8
    let low: u8 = 100 as u8

    # These should be TRUE with unsigned comparison
    assert high > low    # 200 > 100
    assert low < high    # 100 < 200
    assert high >= low
    assert low <= high
    0

@test
fn test_unsigned_boundary() -> i32
    # Test around the signed/unsigned boundary (127-128)
    let below: u8 = 127 as u8
    let above: u8 = 128 as u8

    # Unsigned: 128 > 127 (correct)
    # Signed: 128 = -128, so -128 < 127 (wrong!)
    assert above > below
    assert below < above
    0

@test
fn test_unsigned_max() -> i32
    # Test with 255 (max u8)
    let max: u8 = 255 as u8
    let min: u8 = 0 as u8
    let mid: u8 = 127 as u8

    assert max > min
    assert max > mid
    assert max >= max
    assert min < max
    assert min <= min
    0

@test
fn test_u8_division() -> i32
    # Unsigned division: 200 / 10 = 20
    # If signed: -56 / 10 = -5 or similar (wrong!)
    let a: u8 = 200 as u8
    let b: u8 = 10 as u8
    let result: u8 = a / b
    assert result == 20 as u8
    0

@test
fn test_u8_modulo() -> i32
    # Unsigned modulo: 200 % 30 = 20
    let a: u8 = 200 as u8
    let b: u8 = 30 as u8
    let result: u8 = a % b
    assert result == 20 as u8
    0

@test
fn test_char_equality() -> i32
    # Character equality (sign-agnostic)
    let c1: u8 = 'X'
    let c2: u8 = 'X'
    let c3: u8 = 'Y'
    assert c1 == c2
    assert c1 != c3
    0

@test
fn test_mixed_signed_unsigned() -> i32
    # When mixing signed and unsigned, should use unsigned
    let u: u8 = 200 as u8
    let s: i8 = 50 as i8

    # Cast to same type for comparison
    let u_as_i32: i32 = u as i64 as i32
    let s_as_i32: i32 = s as i64 as i32

    assert u_as_i32 == 200
    assert s_as_i32 == 50
    0

@test
fn test_u64_large_values() -> i32
    # Test with large u64 values (> i64 max)
    let big: u64 = 10000000000000000000 as u64  # 10^19, larger than i64 max
    let small: u64 = 1 as u64

    # This should work correctly with unsigned comparison
    assert big > small
    assert small < big
    0

fn main() -> i32
    0
