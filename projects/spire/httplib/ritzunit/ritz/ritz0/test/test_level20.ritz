# Test level 20: For loops
#
# Tests for loop syntax and behavior

import ritzlib.sys
import ritzlib.io

# ============================================================================
# Test: Basic for loop with range
# ============================================================================

@test
fn test_for_basic_sum() -> i32
    # Sum 0..5 = 0 + 1 + 2 + 3 + 4 = 10
    var sum: i32 = 0
    for i in 0..5
        sum = sum + i
    assert sum == 10, "sum of 0..5 should be 10"
    return 0

@test
fn test_for_start_nonzero() -> i32
    # Sum 5..10 = 5 + 6 + 7 + 8 + 9 = 35
    var sum: i32 = 0
    for i in 5..10
        sum = sum + i
    assert sum == 35, "sum of 5..10 should be 35"
    return 0

@test
fn test_for_single_iteration() -> i32
    # 0..1 should iterate once with i=0
    var count: i32 = 0
    for i in 0..1
        count = count + 1
    assert count == 1, "0..1 should iterate once"
    return 0

@test
fn test_for_empty_range() -> i32
    # 5..5 should iterate zero times
    var count: i32 = 0
    for i in 5..5
        count = count + 1
    assert count == 0, "5..5 should not iterate"
    return 0

# ============================================================================
# Test: For loop with break and continue
# ============================================================================

@test
fn test_for_break() -> i32
    # Sum until we hit 5
    var sum: i32 = 0
    for i in 0..10
        if i == 5
            break
        sum = sum + i
    # 0 + 1 + 2 + 3 + 4 = 10
    assert sum == 10, "sum before break at 5 should be 10"
    return 0

@test
fn test_for_continue() -> i32
    # Sum only even numbers
    var sum: i32 = 0
    for i in 0..10
        if i % 2 != 0
            continue
        sum = sum + i
    # 0 + 2 + 4 + 6 + 8 = 20
    assert sum == 20, "sum of even numbers 0..10 should be 20"
    return 0

# ============================================================================
# Test: Nested for loops
# ============================================================================

@test
fn test_for_nested() -> i32
    # Count iterations of nested loops
    var count: i32 = 0
    for i in 0..3
        for j in 0..4
            count = count + 1
    # 3 * 4 = 12
    assert count == 12, "3x4 nested loop should have 12 iterations"
    return 0

@test
fn test_for_nested_with_break() -> i32
    # Inner break shouldn't affect outer loop
    var outer_count: i32 = 0
    var inner_total: i32 = 0
    for i in 0..3
        outer_count = outer_count + 1
        for j in 0..10
            if j == 2
                break
            inner_total = inner_total + 1
    # Outer: 3 iterations, Inner: 2 per outer (0, 1 before break) = 6
    assert outer_count == 3, "outer loop should run 3 times"
    assert inner_total == 6, "inner loop should run 2 times per outer"
    return 0

# ============================================================================
# Test: For loop with different types
# ============================================================================

@test
fn test_for_i64() -> i32
    var sum: i64 = 0
    for i in 0 as i64..5 as i64
        sum = sum + i
    assert sum == 10 as i64, "i64 sum should be 10"
    return 0

# ============================================================================
# Main entry point
# ============================================================================

fn main() -> i32
    prints("Test level 20: For loops\n")
    prints("OK\n")
    return 0
