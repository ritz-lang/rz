    if out[1] != 0x00000100 as i32
        return 2
    0

@test
fn test_simd_rotl_v8i32_7() -> i32
    # Test rotate left by 7 bits
    var arr: [8]i32
    arr[0] = 0x12345678 as i32
    arr[1] = 0x00000001 as i32
    arr[2] = 0 as i32
    arr[3] = 0 as i32
    arr[4] = 0 as i32
    arr[5] = 0 as i32
    arr[6] = 0 as i32
    arr[7] = 0 as i32

    let v: v8i32 = simd_loadu(&arr[0])
    let result: v8i32 = simd_rotl(v, 7)

    var out: [8]i32
    simd_storeu(&out[0], result)

    # rotl(0x12345678, 7) = 0x1a2b3c09
    if out[0] != 0x1a2b3c09 as i32
        return 1
    # rotl(0x00000001, 7) = 0x00000080
    if out[1] != 0x00000080 as i32
        return 2
    0

# ============================================================================
# Combined operations (ChaCha20 quarter round pattern)
# ============================================================================

@test
fn test_chacha_qr_ops_v8i32() -> i32
    # Test the pattern: a = a + b; d = (d ^ a).rotl(16)
    # This is the first step of the ChaCha20 quarter round

    var arr_a: [8]i32
    var arr_b: [8]i32
    var arr_d: [8]i32

    # Initialize with simple values
    var i: i64 = 0
    while i < 8
        arr_a[i] = 1 as i32
        arr_b[i] = 2 as i32
        arr_d[i] = 3 as i32
        i = i + 1

    let a: v8i32 = simd_loadu(&arr_a[0])
    let b: v8i32 = simd_loadu(&arr_b[0])
    let d: v8i32 = simd_loadu(&arr_d[0])

    # a = a + b (all lanes: 1 + 2 = 3)
    let a2: v8i32 = simd_add(a, b)

    # d ^ a2 (all lanes: 3 ^ 3 = 0)
    let d_xor: v8i32 = simd_xor(d, a2)

    # rotl(0, 16) = 0
    let d2: v8i32 = simd_rotl(d_xor, 16)

    var out_a: [8]i32
    var out_d: [8]i32
    simd_storeu(&out_a[0], a2)
    simd_storeu(&out_d[0], d2)

    # Verify all lanes
    i = 0
    while i < 8
        if out_a[i] != 3
            return 1
        if out_d[i] != 0
            return 2
        i = i + 1
    0

fn main() -> i32
    0
