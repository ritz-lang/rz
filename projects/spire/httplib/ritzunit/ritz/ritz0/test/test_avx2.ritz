# Test AVX2 vector intrinsics for 256-bit operations
#
# These tests verify that AVX2 SIMD vector operations work correctly.
# The implementation uses LLVM vector types and intrinsics.
#
# AVX2 provides 256-bit integer SIMD operations (double the width of SSE2).
# Key types: v8i32 (8 x 32-bit integers), v4i64 (4 x 64-bit integers)
#
# NOTE: This test file uses no imports to allow standalone compilation.

# ============================================================================
# Basic AVX2 vector type tests (256-bit)
# ============================================================================

@test
fn test_v8i32_local() -> i32
    # Test that we can declare v8i32 local variables (256-bit = 8 x i32)
    var v: v8i32
    0

@test
fn test_v4i64_local() -> i32
    # Test v4i64 type (256-bit = 4 x i64)
    var v: v4i64
    0

@test
fn test_v32i8_local() -> i32
    # Test v32i8 type (256-bit = 32 x i8)
    var v: v32i8
    0

# ============================================================================
# AVX2 simd_load / simd_store tests (256-bit)
# ============================================================================

@test
fn test_avx2_load_store_i32() -> i32
    # Test AVX2 vector load/store with i32 array
    var arr: [8]i32
    arr[0] = 1
    arr[1] = 2
    arr[2] = 3
    arr[3] = 4
    arr[4] = 5
    arr[5] = 6
    arr[6] = 7
    arr[7] = 8

    # Load as 256-bit vector (unaligned for safety with stack vars)
    let v: v8i32 = simd_loadu(&arr[0])

    # Store to different location
    var out: [8]i32
    simd_storeu(&out[0], v)

    # Verify round-trip
    if out[0] != 1
        return 1
    if out[1] != 2
        return 2
    if out[2] != 3
        return 3
    if out[3] != 4
        return 4
    if out[4] != 5
        return 5
    if out[5] != 6
        return 6
    if out[6] != 7
        return 7
    if out[7] != 8
        return 8
    0

@test
fn test_avx2_load_store_i64() -> i32
    # Test with i64 (v4i64)
    var arr: [4]i64
    arr[0] = 0x123456789abcdef0
    arr[1] = 0xfedcba9876543210
    arr[2] = 0x1111111122222222
    arr[3] = 0x3333333344444444

    let v: v4i64 = simd_loadu(&arr[0])

    var out: [4]i64
    simd_storeu(&out[0], v)

    if out[0] != 0x123456789abcdef0
        return 1
    if out[1] != 0xfedcba9876543210
        return 2
    if out[2] != 0x1111111122222222
        return 3
    if out[3] != 0x3333333344444444
        return 4
    0

# ============================================================================
# AVX2 simd_extract / simd_insert tests
# ============================================================================

@test
fn test_avx2_extract_i32() -> i32
    var arr: [8]i32
    arr[0] = 100
    arr[1] = 200
    arr[2] = 300
    arr[3] = 400
    arr[4] = 500
    arr[5] = 600
    arr[6] = 700
    arr[7] = 800

    let v: v8i32 = simd_loadu(&arr[0])

    # Extract individual elements
    let e0: i32 = simd_extract(v, 0)
    let e1: i32 = simd_extract(v, 1)
    let e4: i32 = simd_extract(v, 4)
    let e7: i32 = simd_extract(v, 7)

    if e0 != 100
        return 1
    if e1 != 200
        return 2
    if e4 != 500
        return 3
    if e7 != 800
        return 4
    0

@test
fn test_avx2_insert_i32() -> i32
    var arr: [8]i32
    var i: i64 = 0
    while i < 8
        arr[i] = 0
        i = i + 1

    var v: v8i32 = simd_loadu(&arr[0])

    # Insert values at various positions
    v = simd_insert(v, 0, 111 as i32)
    v = simd_insert(v, 3, 333 as i32)
    v = simd_insert(v, 7, 777 as i32)

    # Store back and verify
    simd_storeu(&arr[0], v)

    if arr[0] != 111
        return 1
    if arr[3] != 333
        return 2
    if arr[7] != 777
        return 3
    0

# ============================================================================
# simd_add - Vector integer addition
# ============================================================================

@test
fn test_simd_add_v8i32() -> i32
    # Test vector addition with v8i32
    var arr_a: [8]i32
    var arr_b: [8]i32

    arr_a[0] = 1
    arr_a[1] = 2
    arr_a[2] = 3
    arr_a[3] = 4
    arr_a[4] = 5
    arr_a[5] = 6
    arr_a[6] = 7
    arr_a[7] = 8

    arr_b[0] = 10
    arr_b[1] = 20
    arr_b[2] = 30
    arr_b[3] = 40
    arr_b[4] = 50
    arr_b[5] = 60
    arr_b[6] = 70
    arr_b[7] = 80

    let a: v8i32 = simd_loadu(&arr_a[0])
    let b: v8i32 = simd_loadu(&arr_b[0])

    # Vector add: [1+10, 2+20, 3+30, 4+40, 5+50, 6+60, 7+70, 8+80]
    let result: v8i32 = simd_add(a, b)

    var out: [8]i32
    simd_storeu(&out[0], result)

    if out[0] != 11
        return 1
    if out[1] != 22
        return 2
    if out[2] != 33
        return 3
    if out[3] != 44
        return 4
    if out[4] != 55
        return 5
    if out[5] != 66
        return 6
    if out[6] != 77
        return 7
    if out[7] != 88
        return 8
    0

@test
fn test_simd_add_v4i32() -> i32
    # Test vector addition with SSE2 v4i32 (should also work)
    var arr_a: [4]i32
    var arr_b: [4]i32

    arr_a[0] = 1
    arr_a[1] = 2
    arr_a[2] = 3
    arr_a[3] = 4

    arr_b[0] = 100
    arr_b[1] = 200
    arr_b[2] = 300
    arr_b[3] = 400

    let a: v4i32 = simd_loadu(&arr_a[0])
    let b: v4i32 = simd_loadu(&arr_b[0])

    let result: v4i32 = simd_add(a, b)

    var out: [4]i32
    simd_storeu(&out[0], result)

    if out[0] != 101
        return 1
    if out[1] != 202
        return 2
    if out[2] != 303
        return 3
    if out[3] != 404
        return 4
    0

# ============================================================================
# simd_xor - Vector XOR
# ============================================================================

@test
fn test_simd_xor_v8i32() -> i32
    # Test vector XOR with v8i32
    var arr_a: [8]i32
    var arr_b: [8]i32

    arr_a[0] = 0xff as i32
    arr_a[1] = 0xaa as i32
    arr_a[2] = 0x55 as i32
    arr_a[3] = 0x00 as i32
    arr_a[4] = 0xffffffff as i32
    arr_a[5] = 0x12345678 as i32
    arr_a[6] = 0x87654321 as i32
    arr_a[7] = 0xdeadbeef as i32

    arr_b[0] = 0xff as i32
    arr_b[1] = 0x55 as i32
    arr_b[2] = 0x55 as i32
    arr_b[3] = 0xff as i32
    arr_b[4] = 0xffffffff as i32
    arr_b[5] = 0x12345678 as i32
    arr_b[6] = 0x12345678 as i32
    arr_b[7] = 0xcafebabe as i32

    let a: v8i32 = simd_loadu(&arr_a[0])
    let b: v8i32 = simd_loadu(&arr_b[0])

    let result: v8i32 = simd_xor(a, b)

    var out: [8]i32
    simd_storeu(&out[0], result)

    # 0xff ^ 0xff = 0
    if out[0] != 0
        return 1
    # 0xaa ^ 0x55 = 0xff
    if out[1] != 0xff
        return 2
    # 0x55 ^ 0x55 = 0
    if out[2] != 0
        return 3
    # 0x00 ^ 0xff = 0xff
    if out[3] != 0xff
        return 4
    # 0xffffffff ^ 0xffffffff = 0
    if out[4] != 0
        return 5
    # 0x12345678 ^ 0x12345678 = 0
    if out[5] != 0
        return 6
    # 0x87654321 ^ 0x12345678 = 0x95511559
    if out[6] != 0x95511559 as i32
        return 7
    # 0xdeadbeef ^ 0xcafebabe = 0x14530451
    if out[7] != 0x14530451 as i32
        return 8
    0

# ============================================================================
# simd_rotl - Vector rotate left (for ChaCha20)
# ============================================================================

@test
fn test_simd_rotl_v8i32_16() -> i32
    # Test rotate left by 16 bits (ChaCha20 uses rotl by 16, 12, 8, 7)
    var arr: [8]i32
    arr[0] = 0x12345678 as i32
    arr[1] = 0x00000001 as i32
    arr[2] = 0x80000000 as i32
    arr[3] = 0xffffffff as i32
    arr[4] = 0xaabbccdd as i32
    arr[5] = 0x11223344 as i32
    arr[6] = 0x00ff00ff as i32
    arr[7] = 0xff00ff00 as i32

    let v: v8i32 = simd_loadu(&arr[0])
    let result: v8i32 = simd_rotl(v, 16)

    var out: [8]i32
    simd_storeu(&out[0], result)

    # rotl(0x12345678, 16) = 0x56781234
    if out[0] != 0x56781234 as i32
        return 1
    # rotl(0x00000001, 16) = 0x00010000
    if out[1] != 0x00010000 as i32
        return 2
    # rotl(0x80000000, 16) = 0x00008000
    if out[2] != 0x00008000 as i32
        return 3
    # rotl(0xffffffff, 16) = 0xffffffff
    if out[3] != 0xffffffff as i32
        return 4
    # rotl(0xaabbccdd, 16) = 0xccddaabb
    if out[4] != 0xccddaabb as i32
        return 5
    0

@test
fn test_simd_rotl_v8i32_12() -> i32
    # Test rotate left by 12 bits
    var arr: [8]i32
    arr[0] = 0x12345678 as i32
    arr[1] = 0x00000001 as i32
    arr[2] = 0 as i32
    arr[3] = 0 as i32
    arr[4] = 0 as i32
    arr[5] = 0 as i32
    arr[6] = 0 as i32
    arr[7] = 0 as i32

    let v: v8i32 = simd_loadu(&arr[0])
    let result: v8i32 = simd_rotl(v, 12)

    var out: [8]i32
    simd_storeu(&out[0], result)

    # rotl(0x12345678, 12) = 0x45678123
    if out[0] != 0x45678123 as i32
        return 1
    # rotl(0x00000001, 12) = 0x00001000
    if out[1] != 0x00001000 as i32
        return 2
    0

