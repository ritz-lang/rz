# Test SIMD vector intrinsics for SSE2 operations
#
# These tests verify that SIMD vector operations work correctly.
# The implementation uses LLVM vector types and intrinsics.
#
# NOTE: This test file uses no imports to allow standalone compilation.

# ============================================================================
# Basic vector type tests
# ============================================================================

@test
fn test_v4i32_local() -> i32
    # Test that we can declare v4i32 local variables
    var v: v4i32
    # Zero-initialize check would require comparison ops
    0

@test
fn test_v2i64_local() -> i32
    # Test v2i64 type
    var v: v2i64
    0

@test
fn test_v16i8_local() -> i32
    # Test v16i8 type (common for byte operations)
    var v: v16i8
    0

# ============================================================================
# simd_load / simd_store tests
# ============================================================================

@test
fn test_simd_load_store_i32() -> i32
    # Test vector load/store with i32 array
    # NOTE: Using simd_loadu/storeu because stack vars aren't guaranteed 16-byte aligned
    var arr: [4]i32
    arr[0] = 1
    arr[1] = 2
    arr[2] = 3
    arr[3] = 4

    # Load as vector (unaligned for safety with stack vars)
    let v: v4i32 = simd_loadu(&arr[0])

    # Store to different location
    var out: [4]i32
    simd_storeu(&out[0], v)

    # Verify round-trip
    if out[0] != 1
        return 1
    if out[1] != 2
        return 2
    if out[2] != 3
        return 3
    if out[3] != 4
        return 4
    0

@test
fn test_simd_load_store_i64() -> i32
    # Test with i64 (v2i64)
    # NOTE: Using simd_loadu/storeu because stack vars aren't guaranteed 16-byte aligned
    var arr: [2]i64
    arr[0] = 0x123456789abcdef0
    arr[1] = 0xfedcba9876543210

    let v: v2i64 = simd_loadu(&arr[0])

    var out: [2]i64
    simd_storeu(&out[0], v)

    if out[0] != 0x123456789abcdef0
        return 1
    if out[1] != 0xfedcba9876543210
        return 2
    0

@test
fn test_simd_loadu_storeu() -> i32
    # Test unaligned load/store (common in real-world code)
    var arr: [8]i32  # Extra space for unaligned access
    arr[1] = 10
    arr[2] = 20
    arr[3] = 30
    arr[4] = 40

    # Load from unaligned offset (element 1, not 16-byte aligned)
    let v: v4i32 = simd_loadu(&arr[1])

    var out: [8]i32
    simd_storeu(&out[2], v)

    if out[2] != 10
        return 1
    if out[3] != 20
        return 2
    if out[4] != 30
        return 3
    if out[5] != 40
        return 4
    0

# ============================================================================
# simd_extract / simd_insert tests
# ============================================================================

@test
fn test_simd_extract() -> i32
    var arr: [4]i32
    arr[0] = 100
    arr[1] = 200
    arr[2] = 300
    arr[3] = 400

    let v: v4i32 = simd_loadu(&arr[0])

    # Extract individual elements
    let e0: i32 = simd_extract(v, 0)
    let e1: i32 = simd_extract(v, 1)
    let e2: i32 = simd_extract(v, 2)
    let e3: i32 = simd_extract(v, 3)

    if e0 != 100
        return 1
    if e1 != 200
        return 2
    if e2 != 300
        return 3
    if e3 != 400
        return 4
    0

@test
fn test_simd_insert() -> i32
    var arr: [4]i32
    arr[0] = 0
    arr[1] = 0
    arr[2] = 0
    arr[3] = 0

    var v: v4i32 = simd_loadu(&arr[0])

    # Insert values at each position (cast to i32 for v4i32)
    v = simd_insert(v, 0, 111 as i32)
    v = simd_insert(v, 1, 222 as i32)
    v = simd_insert(v, 2, 333 as i32)
    v = simd_insert(v, 3, 444 as i32)

    # Store back and verify
    simd_storeu(&arr[0], v)

    if arr[0] != 111
        return 1
    if arr[1] != 222
        return 2
    if arr[2] != 333
        return 3
    if arr[3] != 444
        return 4
    0

# ============================================================================
# simd_shuffle tests
# ============================================================================

@test
fn test_simd_shuffle_identity() -> i32
    # Identity shuffle: keep elements in same order
    var arr: [4]i32
    arr[0] = 1
    arr[1] = 2
    arr[2] = 3
    arr[3] = 4

    let a: v4i32 = simd_loadu(&arr[0])
    var zeros: [4]i32
    let b: v4i32 = simd_loadu(&zeros[0])  # Second operand (unused with indices 0-3)

    # Identity: indices 0,1,2,3 keep same order
    let result: v4i32 = simd_shuffle(a, b, 0, 1, 2, 3)

    var out: [4]i32
    simd_storeu(&out[0], result)

    if out[0] != 1
        return 1
    if out[1] != 2
        return 2
    if out[2] != 3
        return 3
    if out[3] != 4
        return 4
    0

@test
fn test_simd_shuffle_reverse() -> i32
    # Reverse elements
    var arr: [4]i32
    arr[0] = 1
    arr[1] = 2
    arr[2] = 3
    arr[3] = 4

    let a: v4i32 = simd_loadu(&arr[0])
    var zeros: [4]i32
    let b: v4i32 = simd_loadu(&zeros[0])

    # Reverse: indices 3,2,1,0
    let result: v4i32 = simd_shuffle(a, b, 3, 2, 1, 0)

    var out: [4]i32
    simd_storeu(&out[0], result)

    if out[0] != 4
        return 1
    if out[1] != 3
        return 2
    if out[2] != 2
        return 3
    if out[3] != 1
        return 4
    0

@test
fn test_simd_shuffle_broadcast() -> i32
    # Broadcast first element to all positions
    var arr: [4]i32
    arr[0] = 42
    arr[1] = 0
    arr[2] = 0
    arr[3] = 0

    let a: v4i32 = simd_loadu(&arr[0])
    var zeros: [4]i32
    let b: v4i32 = simd_loadu(&zeros[0])

    # Broadcast: all indices = 0
    let result: v4i32 = simd_shuffle(a, b, 0, 0, 0, 0)

    var out: [4]i32
    simd_storeu(&out[0], result)

    if out[0] != 42
        return 1
    if out[1] != 42
        return 2
    if out[2] != 42
        return 3
    if out[3] != 42
        return 4
    0

# ============================================================================
# simd_sad (sum of absolute differences) tests
# ============================================================================

@test
fn test_simd_sad_zero() -> i32
    # SAD of identical vectors should be 0
    var arr: [16]i8
    var i: i64 = 0
    while i < 16
        arr[i] = 1 as i8
        i = i + 1

    let a: v16i8 = simd_loadu(&arr[0])
    let b: v16i8 = simd_loadu(&arr[0])

    let result: v2i64 = simd_sad(a, b)

    # Both halves should be 0
    let lo: i64 = simd_extract(result, 0)
    let hi: i64 = simd_extract(result, 1)

    if lo != 0
        return 1
    if hi != 0
        return 2
    0

@test
fn test_simd_sad_simple() -> i32
    # SAD of [1,1,1,...] and [2,2,2,...] = 8 per half (8 elements * |2-1|)
    var arr_a: [16]i8
    var arr_b: [16]i8
    var i: i64 = 0
    while i < 16
        arr_a[i] = 1 as i8
        arr_b[i] = 2 as i8
        i = i + 1

    let a: v16i8 = simd_loadu(&arr_a[0])
    let b: v16i8 = simd_loadu(&arr_b[0])

    let result: v2i64 = simd_sad(a, b)

    # Each half has 8 elements with diff=1, so sum=8
    let lo: i64 = simd_extract(result, 0)
    let hi: i64 = simd_extract(result, 1)

    if lo != 8
        return 1
    if hi != 8
        return 2
    0

# ============================================================================
# Practical use case: Simple checksum accumulation
# ============================================================================

@test
fn test_simd_checksum() -> i32
    # Sum bytes using SIMD (useful for Adler-32 style checksums)
    var data: [16]i8
    data[0] = 1 as i8
    data[1] = 2 as i8
    data[2] = 3 as i8
    data[3] = 4 as i8
    data[4] = 5 as i8
    data[5] = 6 as i8
    data[6] = 7 as i8
    data[7] = 8 as i8
    data[8] = 1 as i8
    data[9] = 2 as i8
    data[10] = 3 as i8
    data[11] = 4 as i8
    data[12] = 5 as i8
    data[13] = 6 as i8
    data[14] = 7 as i8
    data[15] = 8 as i8

    # Load data
    let v: v16i8 = simd_loadu(&data[0])

    # SAD with zero vector gives sum of bytes
    # Initialize zeros array explicitly (Ritz doesn't auto-zero)
    var zeros: [16]i8
    var i: i64 = 0
    while i < 16
        zeros[i] = 0 as i8
        i = i + 1
    let zero_vec: v16i8 = simd_loadu(&zeros[0])

    let sums: v2i64 = simd_sad(v, zero_vec)

    # Sum both halves (1+2+3+4+5+6+7+8 = 36 per half)
    let lo: i64 = simd_extract(sums, 0)
    let hi: i64 = simd_extract(sums, 1)
    let total: i64 = lo + hi

    if total != 72  # 36 + 36
        return 1
    0

# ============================================================================
# simd_clmul (PCLMULQDQ) tests for CRC32 acceleration
# ============================================================================

@test
fn test_simd_clmul_basic() -> i32
    # Test carryless multiply with simple values
    # PCLMULQDQ is used for fast CRC32 computation
    var arr_a: [2]i64
    var arr_b: [2]i64

    # Simple test: multiply 1 * 1 = 1 in carryless arithmetic
    arr_a[0] = 1
    arr_a[1] = 0
    arr_b[0] = 1
    arr_b[1] = 0

    let a: v2i64 = simd_loadu(&arr_a[0])
    let b: v2i64 = simd_loadu(&arr_b[0])

    # 0x00 = low * low
    let result: v2i64 = simd_clmul(a, b, 0x00 as i8)

    var out: [2]i64
    simd_storeu(&out[0], result)

    # 1 * 1 in carryless multiply = 1
    if out[0] != 1
        return 1
    if out[1] != 0  # High bits should be 0
        return 2
    0

@test
fn test_simd_clmul_polynomial() -> i32
    # Test with a non-trivial polynomial multiplication
    # In carryless multiply: (x + 1) * (x + 1) = x^2 + 1 (not x^2 + 2x + 1)
    # Binary: 0b11 * 0b11 = 0b101 (not 0b1001)
    var arr_a: [2]i64
    var arr_b: [2]i64

    arr_a[0] = 3  # 0b11 = x + 1
    arr_a[1] = 0
    arr_b[0] = 3  # 0b11 = x + 1
    arr_b[1] = 0

    let a: v2i64 = simd_loadu(&arr_a[0])
    let b: v2i64 = simd_loadu(&arr_b[0])

    let result: v2i64 = simd_clmul(a, b, 0x00 as i8)

    var out: [2]i64
    simd_storeu(&out[0], result)

    # Carryless: 0b11 * 0b11 = 0b101 = 5
    # Regular multiply would give 9 (0b1001)
    if out[0] != 5
        return 1
    0

@test
fn test_simd_clmul_imm_variants() -> i32
    # Test different imm8 values for selecting halves
    var arr_a: [2]i64
    var arr_b: [2]i64

    arr_a[0] = 2  # Low half = 2
    arr_a[1] = 3  # High half = 3
    arr_b[0] = 5  # Low half = 5
    arr_b[1] = 7  # High half = 7

    let a: v2i64 = simd_loadu(&arr_a[0])
    let b: v2i64 = simd_loadu(&arr_b[0])

    # 0x00: low * low = 2 * 5 = 10 (carryless)
    let r00: v2i64 = simd_clmul(a, b, 0x00 as i8)
    var out00: [2]i64
    simd_storeu(&out00[0], r00)
    if out00[0] != 10
        return 1

    # 0x01: high * low = 3 * 5 = 15 (carryless)
    let r01: v2i64 = simd_clmul(a, b, 0x01 as i8)
    var out01: [2]i64
    simd_storeu(&out01[0], r01)
    if out01[0] != 15
        return 2

    # 0x10: low * high = 2 * 7 = 14 (carryless)
    let r10: v2i64 = simd_clmul(a, b, 0x10 as i8)
    var out10: [2]i64
    simd_storeu(&out10[0], r10)
    if out10[0] != 14
        return 3

    # 0x11: high * high = 3 * 7 = 21 (carryless, but same as regular for small values)
    let r11: v2i64 = simd_clmul(a, b, 0x11 as i8)
    var out11: [2]i64
    simd_storeu(&out11[0], r11)
    # 3 * 7 carryless: 0b11 * 0b111 = 0b10101 = 21 (happens to match regular)
    if out11[0] != 9  # Actually 0b11 * 0b111 = 0b1001 = 9 in carryless
        return 4

    0

@test
fn test_simd_clmul_crc_style() -> i32
    # Test pattern similar to CRC32 folding
    # This verifies the intrinsic works with larger values
    var arr_a: [2]i64
    var arr_b: [2]i64

    # CRC32 polynomial constant (simplified)
    arr_a[0] = 0x1db710641 as i64  # CRC32 related constant
    arr_a[1] = 0
    arr_b[0] = 0xffffffff as i64  # 32 bits of data
    arr_b[1] = 0

    let a: v2i64 = simd_loadu(&arr_a[0])
    let b: v2i64 = simd_loadu(&arr_b[0])

    # Perform the carryless multiply
    let result: v2i64 = simd_clmul(a, b, 0x00 as i8)

    var out: [2]i64
    simd_storeu(&out[0], result)

    # Just verify we get a non-zero result (actual value depends on carryless math)
    # The specific value is complex to compute by hand, so we just check it works
    if out[0] == 0 && out[1] == 0
        return 1
    0

fn main() -> i32
    0
