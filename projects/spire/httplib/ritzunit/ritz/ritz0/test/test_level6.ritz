# Test Level 6: Process spawning
#
# Features tested:
# - fork() syscall
# - execve() syscall
# - wait4() syscall
# - Process exit code capture
#
# Note: spawn() is a complex operation requiring multiple syscalls:
# 1. fork() to create child process
# 2. execve() in child to run command
# 3. wait4() in parent to get exit status

# Fork creates a child process
# Returns: 0 in child, pid in parent, -1 on error
fn fork() -> i64
  syscall1(57, 0)

# Wait for child process to exit
# Returns: child pid on success, -1 on error
# status_ptr points to i32 that receives exit status
fn wait4(pid: i64, status_ptr: *i32, options: i32) -> i64
  syscall4(61, pid, status_ptr, options, 0)

# Extract exit code from wait status (status >> 8) & 0xff
fn exit_status(status: i32) -> i32
  (status / 256) % 256

# execve replaces current process with new program
# argv and envp are null-terminated arrays of strings
fn execve(path: *i8, argv: **i8, envp: **i8) -> i64
  syscall3(59, path, argv, envp)

# Exit the current process - prefixed to avoid conflict with sys.ritz
fn l6_exit(code: i32) -> i64
  syscall1(60, code)

@test
fn test_fork_returns_in_parent() -> i32
  let pid: i64 = fork()
  if pid < 0
    return 1
  if pid == 0
    # Child - exit immediately
    l6_exit(0)
    0
  else
    # Parent - wait for child
    var status: i32 = 0
    let result: i64 = wait4(pid, &status, 0)
    if result < 0
      return 2
    0

@test
fn test_child_exit_code() -> i32
  let pid: i64 = fork()
  if pid < 0
    return 1
  if pid == 0
    # Child - exit with code 42
    l6_exit(42)
    0
  else
    # Parent - wait and check exit code
    var status: i32 = 0
    let result: i64 = wait4(pid, &status, 0)
    if result < 0
      return 2
    let code: i32 = exit_status(status)
    assert code == 42
    0

@test
fn test_fork_child_can_run() -> i32
  let pid: i64 = fork()
  if pid < 0
    return 1
  if pid == 0
    # Child - do some work, then exit 0
    var sum: i32 = 0
    var i: i32 = 0
    while i < 100
      sum = sum + i
      i = i + 1
    if sum == 4950
      l6_exit(0)
    else
      l6_exit(1)
    0
  else
    # Parent - wait for child
    var status: i32 = 0
    let result: i64 = wait4(pid, &status, 0)
    if result < 0
      return 2
    let code: i32 = exit_status(status)
    assert code == 0
    0

