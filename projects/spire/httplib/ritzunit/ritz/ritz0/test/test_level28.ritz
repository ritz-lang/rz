# Test level 28: Owned String type
#
# Tests the String type for owned text.
# Features tested:
# - string_new, string_from creates strings
# - string_push_str appends text
# - string_as_ptr gets C string for printing
# - string_eq, string_eq_cstr for comparison
# - string_drop frees memory

import ritzlib.sys
import ritzlib.io
import ritzlib.string

# ============================================================================
# Basic String Tests
# ============================================================================

@test
fn test_string_new() -> i32
    var s: String = string_new()
    assert string_len(&s) == 0, "new string should be empty"
    assert string_is_empty(&s) == 1, "new string should be empty"
    string_drop(&s)
    return 0

@test
fn test_string_from() -> i32
    var s: String = string_from("hello")
    assert string_len(&s) == 5, "len should be 5"
    assert string_is_empty(&s) == 0, "should not be empty"

    # Check content
    assert string_get(&s, 0) == 104, "h = 104"
    assert string_get(&s, 1) == 101, "e = 101"
    assert string_get(&s, 2) == 108, "l = 108"
    assert string_get(&s, 3) == 108, "l = 108"
    assert string_get(&s, 4) == 111, "o = 111"

    string_drop(&s)
    return 0

@test
fn test_string_push_str() -> i32
    var s: String = string_from("hello")
    string_push_str(&s, " world")

    assert string_len(&s) == 11, "len should be 11"
    assert string_eq_cstr(&s, "hello world") == 1, "should equal 'hello world'"

    string_drop(&s)
    return 0

@test
fn test_string_push() -> i32
    var s: String = string_new()
    string_push(&s, 65)  # A
    string_push(&s, 66)  # B
    string_push(&s, 67)  # C

    assert string_len(&s) == 3, "len should be 3"
    assert string_get(&s, 0) == 65, "should be A"
    assert string_get(&s, 1) == 66, "should be B"
    assert string_get(&s, 2) == 67, "should be C"

    string_drop(&s)
    return 0

@test
fn test_string_as_ptr() -> i32
    var s: String = string_from("test")
    let ptr: *u8 = string_as_ptr(&s)

    # Check null-terminated
    assert *(ptr + 0) == 116, "t"
    assert *(ptr + 1) == 101, "e"
    assert *(ptr + 2) == 115, "s"
    assert *(ptr + 3) == 116, "t"
    assert *(ptr + 4) == 0, "null terminated"

    string_drop(&s)
    return 0

# ============================================================================
# Comparison Tests
# ============================================================================

@test
fn test_string_eq() -> i32
    var a: String = string_from("hello")
    var b: String = string_from("hello")
    var c: String = string_from("world")

    assert string_eq(&a, &b) == 1, "a should equal b"
    assert string_eq(&a, &c) == 0, "a should not equal c"

    string_drop(&a)
    string_drop(&b)
    string_drop(&c)
    return 0

@test
fn test_string_eq_cstr() -> i32
    var s: String = string_from("hello")

    assert string_eq_cstr(&s, "hello") == 1, "should equal 'hello'"
    assert string_eq_cstr(&s, "hello!") == 0, "should not equal 'hello!'"
    assert string_eq_cstr(&s, "hell") == 0, "should not equal 'hell'"
    assert string_eq_cstr(&s, "world") == 0, "should not equal 'world'"

    string_drop(&s)
    return 0

# ============================================================================
# Utility Tests
# ============================================================================

@test
fn test_string_clone() -> i32
    var s: String = string_from("original")
    var clone: String = string_clone(&s)

    assert string_eq(&s, &clone) == 1, "clone should equal original"

    # Modify original
    string_push_str(&s, "!")
    assert string_eq(&s, &clone) == 0, "after modify, should differ"

    string_drop(&s)
    string_drop(&clone)
    return 0

@test
fn test_string_starts_with() -> i32
    var s: String = string_from("hello world")

    assert string_starts_with(&s, "hello") == 1, "should start with 'hello'"
    assert string_starts_with(&s, "hell") == 1, "should start with 'hell'"
    assert string_starts_with(&s, "h") == 1, "should start with 'h'"
    assert string_starts_with(&s, "") == 1, "should start with empty"
    assert string_starts_with(&s, "world") == 0, "should not start with 'world'"
    assert string_starts_with(&s, "hello world!") == 0, "too long"

    string_drop(&s)
    return 0

@test
fn test_string_ends_with() -> i32
    var s: String = string_from("hello world")

    assert string_ends_with(&s, "world") == 1, "should end with 'world'"
    assert string_ends_with(&s, "ld") == 1, "should end with 'ld'"
    assert string_ends_with(&s, "d") == 1, "should end with 'd'"
    assert string_ends_with(&s, "") == 1, "should end with empty"
    assert string_ends_with(&s, "hello") == 0, "should not end with 'hello'"
    assert string_ends_with(&s, "hello world!") == 0, "too long"

    string_drop(&s)
    return 0

@test
fn test_string_contains() -> i32
    var s: String = string_from("hello world")

    assert string_contains(&s, "hello") == 1, "should contain 'hello'"
    assert string_contains(&s, "world") == 1, "should contain 'world'"
    assert string_contains(&s, "lo wo") == 1, "should contain 'lo wo'"
    assert string_contains(&s, " ") == 1, "should contain space"
    assert string_contains(&s, "") == 1, "should contain empty"
    assert string_contains(&s, "xyz") == 0, "should not contain 'xyz'"
    assert string_contains(&s, "hello world!") == 0, "too long"

    string_drop(&s)
    return 0

@test
fn test_string_clear() -> i32
    var s: String = string_from("hello")
    let old_cap: i64 = string_cap(&s)

    string_clear(&s)
    assert string_len(&s) == 0, "len should be 0"
    assert string_cap(&s) == old_cap, "cap should be unchanged"

    # Can push again
    string_push_str(&s, "world")
    assert string_eq_cstr(&s, "world") == 1, "should be 'world'"

    string_drop(&s)
    return 0

@test
fn test_string_pop() -> i32
    var s: String = string_from("abc")

    let c: u8 = string_pop(&s)
    assert c == 99, "popped should be 'c'"
    assert string_len(&s) == 2, "len should be 2"

    string_drop(&s)
    return 0

@test
fn test_string_push_string() -> i32
    var a: String = string_from("hello")
    var b: String = string_from(" world")

    string_push_string(&a, &b)
    assert string_eq_cstr(&a, "hello world") == 1, "should be 'hello world'"

    string_drop(&a)
    string_drop(&b)
    return 0

# ============================================================================
# Main entry point
# ============================================================================

fn main() -> i32
    prints("Test level 28: Owned String type\n")

    # Run all tests
    test_string_new()
    test_string_from()
    test_string_push_str()
    test_string_push()
    test_string_as_ptr()
    test_string_eq()
    test_string_eq_cstr()
    test_string_clone()
    test_string_starts_with()
    test_string_ends_with()
    test_string_contains()
    test_string_clear()
    test_string_pop()
    test_string_push_string()

    prints("All String tests passed!\n")
    return 0
