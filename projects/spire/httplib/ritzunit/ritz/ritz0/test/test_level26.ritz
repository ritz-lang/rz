# Test level 26: Heap-allocated Box<T>
#
# Tests the Box<T> type for heap-allocated single values.
# Features tested:
# - box_new<T> allocates on heap
# - box_get<T> retrieves value
# - box_set<T> modifies value
# - box_drop<T> frees memory
# - Box<T> with various types (i32, i64, structs)

import ritzlib.sys
import ritzlib.io
import ritzlib.box

# ============================================================================
# Basic Box Tests
# ============================================================================

@test
fn test_box_i32_basic() -> i32
    # Create a box containing 42
    var b: Box<i32> = box_new<i32>(42)
    assert box_valid<i32>(&b) == 1, "box should be valid"

    # Get the value
    let val: i32 = box_get<i32>(&b)
    assert val == 42, "box should contain 42"

    # Clean up
    box_drop<i32>(&b)
    return 0

@test
fn test_box_i64_basic() -> i32
    var b: Box<i64> = box_new<i64>(1000000)
    assert box_valid<i64>(&b) == 1, "box should be valid"

    let val: i64 = box_get<i64>(&b)
    assert val == 1000000, "box should contain 1000000"

    box_drop<i64>(&b)
    return 0

@test
fn test_box_set() -> i32
    var b: Box<i32> = box_new<i32>(10)
    assert box_get<i32>(&b) == 10, "initial value should be 10"

    # Modify the value
    box_set<i32>(&b, 20)
    assert box_get<i32>(&b) == 20, "value should now be 20"

    box_set<i32>(&b, 30)
    assert box_get<i32>(&b) == 30, "value should now be 30"

    box_drop<i32>(&b)
    return 0

@test
fn test_box_as_ptr() -> i32
    var b: Box<i32> = box_new<i32>(100)

    # Get a pointer to the value and modify directly
    let ptr: *i32 = box_as_ptr<i32>(&b)
    *ptr = 200

    assert box_get<i32>(&b) == 200, "value should be 200 after ptr write"

    box_drop<i32>(&b)
    return 0

# ============================================================================
# Box with Struct Types
# ============================================================================

struct Point
    x: i32
    y: i32

@test
fn test_box_struct() -> i32
    var pt: Point = Point { x: 10, y: 20 }
    var b: Box<Point> = box_new<Point>(pt)

    assert box_valid<Point>(&b) == 1, "box should be valid"

    let got: Point = box_get<Point>(&b)
    assert got.x == 10, "x should be 10"
    assert got.y == 20, "y should be 20"

    box_drop<Point>(&b)
    return 0

@test
fn test_box_struct_modify() -> i32
    var pt: Point = Point { x: 1, y: 2 }
    var b: Box<Point> = box_new<Point>(pt)

    # Modify via pointer
    let ptr: *Point = box_as_ptr<Point>(&b)
    ptr.x = 100
    ptr.y = 200

    let got: Point = box_get<Point>(&b)
    assert got.x == 100, "x should be 100"
    assert got.y == 200, "y should be 200"

    box_drop<Point>(&b)
    return 0

# ============================================================================
# Multiple Boxes
# ============================================================================

@test
fn test_multiple_boxes() -> i32
    var b1: Box<i32> = box_new<i32>(1)
    var b2: Box<i32> = box_new<i32>(2)
    var b3: Box<i32> = box_new<i32>(3)

    assert box_get<i32>(&b1) == 1, "b1 should be 1"
    assert box_get<i32>(&b2) == 2, "b2 should be 2"
    assert box_get<i32>(&b3) == 3, "b3 should be 3"

    # Free in different order than allocation
    box_drop<i32>(&b2)
    box_drop<i32>(&b1)
    box_drop<i32>(&b3)
    return 0

# ============================================================================
# u8 Box Test
# ============================================================================

@test
fn test_box_u8() -> i32
    var b: Box<u8> = box_new<u8>(255)
    assert box_valid<u8>(&b) == 1, "box should be valid"

    let val: u8 = box_get<u8>(&b)
    assert val == 255, "should be 255"

    box_drop<u8>(&b)
    return 0

# ============================================================================
# Main entry point
# ============================================================================

fn main() -> i32
    prints("Test level 26: Heap-allocated Box<T>\n")

    # Run all tests
    test_box_i32_basic()
    test_box_i64_basic()
    test_box_set()
    test_box_as_ptr()
    test_box_struct()
    test_box_struct_modify()
    test_multiple_boxes()
    test_box_u8()

    prints("All Box<T> tests passed!\n")
    return 0
