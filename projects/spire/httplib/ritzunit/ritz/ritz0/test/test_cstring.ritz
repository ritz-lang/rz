# Test C-string literals: c"..."
#
# Features tested:
# - C-string literal syntax (c"...")
# - C-strings produce *u8 type (null-terminated)
# - Escape sequences in C-strings
# - No interpolation in C-strings (braces are literal)

fn strlen(s: *u8) -> i64
    var i: i64 = 0
    while *(s + i) != 0
        i = i + 1
    i

@test
fn test_cstring_basic() -> i64
    let s: *u8 = c"hello"
    assert strlen(s) == 5
    0

@test
fn test_cstring_empty() -> i64
    let s: *u8 = c""
    assert strlen(s) == 0
    0

@test
fn test_cstring_escapes() -> i64
    let s: *u8 = c"a\nb\tc"
    assert strlen(s) == 5
    # newline is 10, tab is 9
    assert *(s + 1) == 10
    assert *(s + 3) == 9
    0

@test
fn test_cstring_literal_braces() -> i64
    # Braces in C-strings are literal, not interpolation
    let s: *u8 = c"hello {world}"
    assert strlen(s) == 13
    # { is 123
    assert *(s + 6) == 123
    0

@test
fn test_cstring_null_terminator() -> i64
    let s: *u8 = c"abc"
    assert *(s + 3) == 0
    0

@test
fn test_cstring_first_char() -> i64
    let s: *u8 = c"abc"
    # 'a' is 97
    assert *s == 97
    0
