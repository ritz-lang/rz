# Test that sizeof(T) works correctly in generic functions
# This was a bug where sizeof(T) would return 8 (pointer size) instead of
# the actual size of the concrete type T

import ritzlib.io
import ritzlib.memory

struct BigStruct
    a: i64
    b: i64
    c: i64
    d: i64

fn generic_sizeof<T>() -> i64
    return sizeof(T)

@test
fn test_sizeof_generic_i32() -> i32
    let size: i64 = generic_sizeof<i32>()
    if size != 4
        prints("FAIL: sizeof(i32) = ")
        print_int(size)
        prints(", expected 4\n")
        return 1
    return 0

@test
fn test_sizeof_generic_i64() -> i32
    let size: i64 = generic_sizeof<i64>()
    if size != 8
        prints("FAIL: sizeof(i64) = ")
        print_int(size)
        prints(", expected 8\n")
        return 1
    return 0

@test
fn test_sizeof_generic_struct() -> i32
    let size: i64 = generic_sizeof<BigStruct>()
    if size != 32
        prints("FAIL: sizeof(BigStruct) = ")
        print_int(size)
        prints(", expected 32\n")
        return 1
    return 0

# Test sizeof in vec_grow-like context (the original bug scenario)
struct Vec<T>
    data: *T
    len: i64
    cap: i64

fn vec_alloc_size<T>(count: i64) -> i64
    return count * sizeof(T)

@test
fn test_sizeof_in_allocation() -> i32
    # For BigStruct (32 bytes), allocating 10 elements should need 320 bytes
    let size: i64 = vec_alloc_size<BigStruct>(10)
    if size != 320
        prints("FAIL: vec_alloc_size<BigStruct>(10) = ")
        print_int(size)
        prints(", expected 320\n")
        return 1
    return 0
