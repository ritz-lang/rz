# Test: Const array literals at module level
# Issue: ritz-lang/ritz#94

# Simple const array
const SMALL: [4]u8 = [0x63, 0x7c, 0x77, 0x7b]

# Const array with fill syntax
const ZEROS: [8]u8 = [0; 8]

# Const array with signed integers
const SIGNED: [4]i32 = [1, -2, 3, -4]

# Multiline const array (tests parser newline handling)
const MULTILINE: [8]u8 = [
    0x01, 0x02, 0x03, 0x04,
    0x05, 0x06, 0x07, 0x08
]

# Const array with hex values (common for crypto lookup tables)
const SBOX_SAMPLE: [16]u8 = [
    0x63, 0x7c, 0x77, 0x7b, 0xf2, 0x6b, 0x6f, 0xc5,
    0x30, 0x01, 0x67, 0x2b, 0xfe, 0xd7, 0xab, 0x76
]

@test
fn test_const_array_simple() -> i32
    if SMALL[0] != 0x63
        return 1
    if SMALL[1] != 0x7c
        return 2
    if SMALL[2] != 0x77
        return 3
    if SMALL[3] != 0x7b
        return 4
    return 0

@test
fn test_const_array_fill() -> i32
    for i in 0..8
        if ZEROS[i] != 0
            return 1
    return 0

@test
fn test_const_array_signed() -> i32
    if SIGNED[0] != 1
        return 1
    if SIGNED[1] != -2
        return 2
    if SIGNED[2] != 3
        return 3
    if SIGNED[3] != -4
        return 4
    return 0

@test
fn test_const_array_multiline() -> i32
    if MULTILINE[0] != 1
        return 1
    if MULTILINE[7] != 8
        return 2
    return 0

@test
fn test_const_array_sbox_sample() -> i32
    # Test hex values
    if SBOX_SAMPLE[0] != 0x63
        return 1
    if SBOX_SAMPLE[8] != 0x30
        return 2
    if SBOX_SAMPLE[15] != 0x76
        return 3
    return 0

@test
fn test_const_array_index_variable() -> i32
    # Test indexing with a runtime variable
    var idx: i32 = 2
    if SMALL[idx] != 0x77
        return 1
    idx = 0
    if SBOX_SAMPLE[idx] != 0x63
        return 2
    return 0

# Helper function using const array lookup
fn sbox_lookup(i: u8) -> u8
    return SBOX_SAMPLE[i as i64]

@test
fn test_const_array_in_function() -> i32
    if sbox_lookup(0) != 0x63
        return 1
    if sbox_lookup(15) != 0x76
        return 2
    return 0

fn main() -> i32
    return 0
