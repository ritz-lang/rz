# Test Level 3: Function calls in tests
#
# Features tested:
# - Function definitions
# - Function calls
# - Function calls in assert expressions
# - Return values
# - Recursive calls

fn add(a: i32, b: i32) -> i32
  a + b

fn sub(a: i32, b: i32) -> i32
  a - b

fn mul(a: i32, b: i32) -> i32
  a * b

fn identity(x: i32) -> i32
  x

fn square(x: i32) -> i32
  x * x

fn double(x: i32) -> i32
  x + x

fn abs_diff(a: i32, b: i32) -> i32
  if a > b
    a - b
  else
    b - a

fn fib(n: i32) -> i32
  if n < 2
    n
  else
    fib(n - 1) + fib(n - 2)

@test
fn test_simple_call() -> i32
  assert add(2, 3) == 5
  0

@test
fn test_nested_call() -> i32
  assert add(add(1, 2), add(3, 4)) == 10
  0

@test
fn test_call_in_expression() -> i32
  assert add(1, 2) + sub(5, 3) == 5
  0

@test
fn test_call_with_literals() -> i32
  assert mul(6, 7) == 42
  0

@test
fn test_identity() -> i32
  assert identity(42) == 42
  0

@test
fn test_square() -> i32
  assert square(5) == 25
  0

@test
fn test_double() -> i32
  assert double(21) == 42
  0

@test
fn test_abs_diff() -> i32
  assert abs_diff(10, 7) == 3
  assert abs_diff(7, 10) == 3
  0

@test
fn test_recursive_fib() -> i32
  assert fib(0) == 0
  assert fib(1) == 1
  assert fib(5) == 5
  assert fib(10) == 55
  0

@test
fn test_call_with_var() -> i32
  var x: i32 = 10
  var y: i32 = 20
  assert add(x, y) == 30
  0

@test
fn test_call_result_in_var() -> i32
  let result: i32 = add(100, 200)
  assert result == 300
  0

