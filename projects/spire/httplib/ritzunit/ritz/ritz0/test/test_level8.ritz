# Test Level 8: Forward Function References
#
# Features tested:
# - Calling functions defined later in source
# - Mutual recursion between functions
# - Order-independent function definitions

# ============================================================================
# Forward Reference Tests
# ============================================================================

@test
fn test_forward_call_simple() -> i32
  # Call a function defined later in this file
  let result: i32 = helper_later()
  assert result == 42
  0

fn helper_later() -> i32
  42

@test
fn test_forward_call_with_args() -> i32
  # Call a function defined later with arguments
  let result: i32 = add_later(10, 32)
  assert result == 42
  0

fn add_later(a: i32, b: i32) -> i32
  a + b

@test
fn test_mutual_recursion_even_odd() -> i32
  # Classic mutual recursion: is_even calls is_odd and vice versa
  assert is_even(0) == 1
  assert is_even(1) == 0
  assert is_even(2) == 1
  assert is_even(3) == 0
  assert is_even(10) == 1
  assert is_odd(0) == 0
  assert is_odd(1) == 1
  assert is_odd(5) == 1
  0

fn is_even(n: i32) -> i32
  if n == 0
    return 1
  is_odd(n - 1)

fn is_odd(n: i32) -> i32
  if n == 0
    return 0
  is_even(n - 1)

@test
fn test_chain_forward_calls() -> i32
  # Chain of forward calls: a -> b -> c -> d
  let result: i32 = chain_a(10)
  assert result == 40
  0

fn chain_a(x: i32) -> i32
  chain_b(x) + 10

fn chain_b(x: i32) -> i32
  chain_c(x) + 10

fn chain_c(x: i32) -> i32
  chain_d(x) + 10

fn chain_d(x: i32) -> i32
  x

@test
fn test_forward_with_struct() -> i32
  # Forward call returning struct data
  let result: i32 = get_struct_value()
  assert result == 123
  0

struct TestData
  value: i32

fn get_struct_value() -> i32
  let data: TestData = make_test_data()
  data.value

fn make_test_data() -> TestData
  TestData { value: 123 }

# ============================================================================
# Parser Edge Cases
# ============================================================================

@test
fn test_deref_assign_after_if() -> i32
  # Regression test: if statement followed by dereference assignment
  # Parser was treating *(ptr + len) as if_expr * (ptr + len)
  var buf: *i8 = __builtin_alloca(10)
  var len: i64 = 0
  if len >= 10
    return -1
  *(buf + len) = 65 as i8
  len = len + 1
  assert len == 1
  assert *(buf + 0) == 65
  0

@test
fn test_deref_assign_after_match_style_if() -> i32
  # Similar test with else branch
  var buf: *i8 = __builtin_alloca(10)
  var idx: i64 = 0
  if idx < 0
    idx = 0
  else
    idx = 1
  *(buf + idx) = 66 as i8
  assert *(buf + 1) == 66
  0
