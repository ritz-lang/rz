# Test mutable reference in method receiver

struct Point
    x: i32
    y: i32

impl Point
    fn set_x(self: &mut Point, val: i32)
        self.x = val
    
    fn add_x(self: &mut Point, delta: i32)
        self.x = self.x + delta
    
    fn get_x(self: &Point) -> i32
        return self.x

@test
fn test_mut_ref_method() -> i32
    var p: Point
    p.x = 5
    p.y = 10
    
    # Test mutable borrow method
    p.set_x(20)
    if p.x != 20
        return 1
    
    # Test another mutating method
    p.add_x(5)
    if p.x != 25
        return 1
    
    # Test read-only reference method
    let x: i32 = p.get_x()
    if x != 25
        return 1
    
    return 0
