# Test Level 4: C-string literals (c"...")
#
# Features tested:
# - C-string literal syntax (c"...")
# - C-string as pointer (const *i8)
# - Pointer arithmetic for string traversal
# - Null terminator check
# - String length calculation
#
# Note: "..." now produces String type. Use c"..." for C-strings.

# Local helper - prefixed to avoid conflict with str.ritz
fn l4_strlen(s: *i8) -> i32
  var i: i32 = 0
  while *(s + i) != 0
    i = i + 1
  i

fn l4_streq(a: *i8, b: *i8) -> i32
  var i: i32 = 0
  while *(a + i) != 0 && *(b + i) != 0
    if *(a + i) != *(b + i)
      return 0
    i = i + 1
  if *(a + i) != *(b + i)
    0
  else
    1

@test
fn test_empty_string() -> i32
  let s: *i8 = c""
  assert l4_strlen(s) == 0
  0

@test
fn test_single_char() -> i32
  let s: *i8 = c"a"
  assert l4_strlen(s) == 1
  0

@test
fn test_hello_length() -> i32
  let s: *i8 = c"hello"
  assert l4_strlen(s) == 5
  0

@test
fn test_longer_string() -> i32
  let s: *i8 = c"hello, world!"
  assert l4_strlen(s) == 13
  0

@test
fn test_first_char() -> i32
  let s: *i8 = c"abc"
  assert *s == 97
  0

@test
fn test_second_char() -> i32
  let s: *i8 = c"abc"
  assert *(s + 1) == 98
  0

@test
fn test_null_terminator() -> i32
  let s: *i8 = c"abc"
  assert *(s + 3) == 0
  0

@test
fn test_streq_same() -> i32
  let a: *i8 = c"hello"
  let b: *i8 = c"hello"
  assert l4_streq(a, b) == 1
  0

@test
fn test_streq_different() -> i32
  let a: *i8 = c"hello"
  let b: *i8 = c"world"
  assert l4_streq(a, b) == 0
  0

@test
fn test_streq_prefix() -> i32
  let a: *i8 = c"hello"
  let b: *i8 = c"hell"
  assert l4_streq(a, b) == 0
  0

@test
fn test_escape_newline() -> i32
  let s: *i8 = c"a\nb"
  assert l4_strlen(s) == 3
  assert *(s + 1) == 10
  0

@test
fn test_escape_tab() -> i32
  let s: *i8 = c"a\tb"
  assert l4_strlen(s) == 3
  assert *(s + 1) == 9
  0

