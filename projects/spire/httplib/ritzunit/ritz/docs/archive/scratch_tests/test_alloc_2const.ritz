const PROT_READ: i64 = 1
const PROT_WRITE: i64 = 2

struct BumpAllocator
  base: *i8
  current: *i8
  end: *i8
  total_size: i64

fn allocator_init(alloc: *BumpAllocator, size: i64)
  let prot: i64 = PROT_READ | PROT_WRITE
  let flags: i64 = 2
  let base: i64 = __syscall6(9, 0, size, prot, flags, -1, 0)
  0

fn allocator_alloc(alloc: *BumpAllocator, size: i64) -> *i8
  let aligned_size: i64 = size
  let remainder: i64 = size - (size / 8) * 8
  0
