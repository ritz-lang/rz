# ritz1/src/symbols.ritz - Symbol Table
#
# Symbol table with lexical scoping for the Ritz compiler.
# Supports nested scopes (global, function, block) with parent lookup.

import types  # For Type, Field, TypeList structs
import mem    # For Arena, arena_alloc

# ============================================================================
# Symbol Kind Constants
# ============================================================================

const SYM_VAR: i32 = 1       # Variable (let or var)
const SYM_FN: i32 = 2        # Function
const SYM_TYPE: i32 = 3      # Type (struct, enum)
const SYM_PARAM: i32 = 4     # Function parameter
const SYM_CONST: i32 = 5     # Constant

# ============================================================================
# Symbol Structure
# ============================================================================

struct Symbol
  name: *i8
  name_len: i32
  kind: i32         # SYM_* constant
  ty: *Type         # Type of this symbol
  is_mut: i32       # For SYM_VAR: 1 if mutable (var), 0 if immutable (let)
  next: *Symbol     # Next symbol in same scope

# ============================================================================
# Scope Structure
# ============================================================================

struct Scope
  symbols: *Symbol  # Linked list of symbols in this scope
  parent: *Scope    # Enclosing scope (null for global)
  depth: i32        # Nesting depth (0 = global)

# ============================================================================
# Scope Management
# ============================================================================

fn scope_new(arena: *Arena, parent: *Scope) -> *Scope
  let s: *Scope = arena_alloc(arena, 64) as *Scope
  (*s).symbols = 0 as *Symbol
  (*s).parent = parent
  if parent == 0 as *Scope
    (*s).depth = 0
  else
    (*s).depth = (*parent).depth + 1
  s

fn scope_push(arena: *Arena, current: *Scope) -> *Scope
  scope_new(arena, current)

fn scope_pop(current: *Scope) -> *Scope
  if current == 0 as *Scope
    return 0 as *Scope
  (*current).parent

# ============================================================================
# Symbol Operations
# ============================================================================

# Create a new symbol
fn symbol_new(arena: *Arena, name: *i8, name_len: i32, kind: i32, ty: *Type) -> *Symbol
  let sym: *Symbol = arena_alloc(arena, 64) as *Symbol
  (*sym).name = name
  (*sym).name_len = name_len
  (*sym).kind = kind
  (*sym).ty = ty
  (*sym).is_mut = 0
  (*sym).next = 0 as *Symbol
  sym

# Insert a symbol into the current scope (prepend to list)
fn scope_insert(s: *Scope, sym: *Symbol) -> *Symbol
  if s == 0 as *Scope
    return sym
  (*sym).next = (*s).symbols
  (*s).symbols = sym
  sym

# Create and insert a symbol in one call
fn scope_define(arena: *Arena, s: *Scope, name: *i8, name_len: i32, kind: i32, ty: *Type) -> *Symbol
  let sym: *Symbol = symbol_new(arena, name, name_len, kind, ty)
  scope_insert(s, sym)

# ============================================================================
# Name Comparison Helper
# ============================================================================

fn names_equal(a: *i8, a_len: i32, b: *i8, b_len: i32) -> i32
  if a_len != b_len
    return 0
  var i: i32 = 0
  while i < a_len
    let ca: i32 = *(a + i) as i32
    let cb: i32 = *(b + i) as i32
    if ca != cb
      return 0
    i = i + 1
  1

# ============================================================================
# Symbol Lookup
# ============================================================================

# Lookup symbol in a single scope (no parent traversal)
fn scope_lookup_local(s: *Scope, name: *i8, name_len: i32) -> *Symbol
  if s == 0 as *Scope
    return 0 as *Symbol
  var sym: *Symbol = (*s).symbols
  while sym != 0 as *Symbol
    if names_equal((*sym).name, (*sym).name_len, name, name_len) == 1
      return sym
    sym = (*sym).next
  0 as *Symbol

# Lookup symbol in current scope and all parent scopes
fn scope_lookup(s: *Scope, name: *i8, name_len: i32) -> *Symbol
  var current: *Scope = s
  while current != 0 as *Scope
    let sym: *Symbol = scope_lookup_local(current, name, name_len)
    if sym != 0 as *Symbol
      return sym
    current = (*current).parent
  0 as *Symbol

# Check if a name is already defined in the current scope only
fn scope_is_defined_local(s: *Scope, name: *i8, name_len: i32) -> i32
  let sym: *Symbol = scope_lookup_local(s, name, name_len)
  if sym != 0 as *Symbol
    return 1
  0

# ============================================================================
# Convenience Functions
# ============================================================================

fn scope_define_var(arena: *Arena, s: *Scope, name: *i8, name_len: i32, ty: *Type, is_mut: i32) -> *Symbol
  let sym: *Symbol = scope_define(arena, s, name, name_len, SYM_VAR, ty)
  (*sym).is_mut = is_mut
  sym

fn scope_define_fn(arena: *Arena, s: *Scope, name: *i8, name_len: i32, ty: *Type) -> *Symbol
  scope_define(arena, s, name, name_len, SYM_FN, ty)

fn scope_define_type(arena: *Arena, s: *Scope, name: *i8, name_len: i32, ty: *Type) -> *Symbol
  scope_define(arena, s, name, name_len, SYM_TYPE, ty)

fn scope_define_param(arena: *Arena, s: *Scope, name: *i8, name_len: i32, ty: *Type) -> *Symbol
  scope_define(arena, s, name, name_len, SYM_PARAM, ty)
