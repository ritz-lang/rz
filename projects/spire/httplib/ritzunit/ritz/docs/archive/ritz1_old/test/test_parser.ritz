# ritz1/test/test_parser.ritz - Parser Tests
#
# Tests for the recursive descent parser with Pratt expression parsing.
# Covers expression parsing, statement parsing, and error cases.
#
# Run with:
# python ritz0/ritz0.py --lib ritz1/src/*.ritz --test ritz1/test/test_parser.ritz

# ============================================================================
# Type Redefinitions (must match parser.ritz definitions)
# ============================================================================

# Expression AST node
struct Expr
  kind: i32
  val1: i32
  val2: i32
  left: *i32
  right: *i32
  next: *i32

# Statement AST node
struct Stmt
  kind: i32
  name: *i8
  name_len: i32
  expr: *i32
  stmt: *i32
  next: *i32

# Function definition
struct FnDef
  name: *i8
  name_len: i32
  body: *Stmt

# Module
struct Module
  items: *Stmt

# Parser state
struct Parser
  lex: *Lexer
  current: Token

# ============================================================================
# Helper Functions
# ============================================================================

# Create a simple lexer from source code
fn create_lexer(src: *i8, len: i32) -> Lexer
  let storage: *i8 = __builtin_alloca(32768)
  let states: *NFAState = storage
  let trans: *Transition = storage + 4096
  let patterns: *TokenPattern = storage + 16384

  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  var lex: Lexer = Lexer { src: src, len: len, pos: 0, line: 1, col: 1, nfa: &nfa, patterns: patterns, pattern_count: 0 , indent_stack: [0; 64], indent_depth: 1, at_line_start: 1, pending_dedents: 0, bracket_depth: 0 }

  # Build lexer from DSL
  let dsl: *i8 = "INT = [0-9]+\nIDENT = [a-zA-Z_][a-zA-Z0-9_]*"
  # TODO: use ritz_tokens DSL when available
  # For now, use simpler patterns
  lexer_add_pattern(&lex, "[0-9]+", 6, TOK_INT, 0)
  lexer_add_pattern(&lex, "[a-zA-Z_][a-zA-Z0-9_]*", 22, TOK_IDENT, 0)
  lexer_add_pattern(&lex, "\"+\"", 3, TOK_PLUS, 1)
  lexer_add_pattern(&lex, "\"-\"", 3, TOK_MINUS, 1)
  lexer_add_pattern(&lex, "\"*\"", 3, TOK_STAR, 1)
  lexer_add_pattern(&lex, "\"/\"", 3, TOK_SLASH, 1)
  lexer_add_pattern(&lex, "\"(\"", 3, TOK_LPAREN, 1)
  lexer_add_pattern(&lex, "\")\"", 3, TOK_RPAREN, 1)
  lexer_add_pattern(&lex, "\"=\"", 3, TOK_EQ, 1)
  lexer_add_pattern(&lex, "\"==\"", 4, TOK_EQEQ, 1)
  lexer_add_pattern(&lex, "\"!=\"", 4, TOK_NEQ, 1)
  lexer_finalize(&lex)

  lex

# ============================================================================
# Expression Parsing Tests
# ============================================================================

@test
fn test_parse_integer() -> i32
  let src: *i8 = "42"
  var lex: Lexer = create_lexer(src, 2)
  var p: Parser = parser_init(&lex)

  let expr: *Expr = parse_expr(&p, 0)
  assert expr != 0
  assert (*expr).kind == EXPR_INT_LIT
  0

@test
fn test_parse_identifier() -> i32
  let src: *i8 = "x"
  var lex: Lexer = create_lexer(src, 1)
  var p: Parser = parser_init(&lex)

  let expr: *Expr = parse_expr(&p, 0)
  assert expr != 0
  assert (*expr).kind == EXPR_IDENT
  0

@test
fn test_parse_unary_minus() -> i32
  let src: *i8 = "-5"
  var lex: Lexer = create_lexer(src, 2)
  var p: Parser = parser_init(&lex)

  let expr: *Expr = parse_expr(&p, 0)
  assert expr != 0
  assert (*expr).kind == EXPR_UNARY_OP
  assert (*expr).val2 == TOK_MINUS
  assert (*expr).left != 0
  0

@test
fn test_parse_addition() -> i32
  let src: *i8 = "1+2"
  var lex: Lexer = create_lexer(src, 3)
  var p: Parser = parser_init(&lex)

  let expr: *Expr = parse_expr(&p, 0)
  assert expr != 0
  assert (*expr).kind == EXPR_BIN_OP
  assert (*expr).val2 == TOK_PLUS
  assert (*expr).left != 0
  assert (*expr).right != 0
  0

@test
fn test_parse_precedence() -> i32
  # 1 + 2 * 3 should parse as 1 + (2 * 3)
  let src: *i8 = "1+2*3"
  var lex: Lexer = create_lexer(src, 5)
  var p: Parser = parser_init(&lex)

  let expr: *Expr = parse_expr(&p, 0)
  assert expr != 0
  assert (*expr).kind == EXPR_BIN_OP
  assert (*expr).val2 == TOK_PLUS
  # Right side should be multiplication
  assert (*expr).right != 0
  assert (*(*expr).right).kind == EXPR_BIN_OP
  assert (*(*expr).right).val2 == TOK_STAR
  0

@test
fn test_parse_paren_expr() -> i32
  let src: *i8 = "(1+2)"
  var lex: Lexer = create_lexer(src, 5)
  var p: Parser = parser_init(&lex)

  let expr: *Expr = parse_expr(&p, 0)
  assert expr != 0
  # Paren expression should unwrap to the inner expression
  assert (*expr).kind == EXPR_BIN_OP
  0

# ============================================================================
# Statement Parsing Tests
# ============================================================================

@test
fn test_parse_var_decl() -> i32
  let src: *i8 = "var x = 5"
  var lex: Lexer = create_lexer(src, 9)
  var p: Parser = parser_init(&lex)

  let stmt: *Stmt = parse_stmt(&p)
  assert stmt != 0
  assert (*stmt).kind == STMT_VAR
  assert (*stmt).name_len == 1  # Length of "x"
  0

@test
fn test_parse_return_stmt() -> i32
  let src: *i8 = "return 42"
  var lex: Lexer = create_lexer(src, 9)
  var p: Parser = parser_init(&lex)

  let stmt: *Stmt = parse_stmt(&p)
  assert stmt != 0
  assert (*stmt).kind == STMT_RETURN
  assert (*stmt).expr != 0
  0

@test
fn test_parse_expr_stmt() -> i32
  let src: *i8 = "1+2"
  var lex: Lexer = create_lexer(src, 3)
  var p: Parser = parser_init(&lex)

  let stmt: *Stmt = parse_stmt(&p)
  assert stmt != 0
  assert (*stmt).kind == STMT_EXPR
  assert (*stmt).expr != 0
  assert (*(*stmt).expr).kind == EXPR_BIN_OP
  0

# ============================================================================
# Function Definition Tests
# ============================================================================

@test
fn test_parse_function_skeleton() -> i32
  let src: *i8 = "fn add() -> i32 { }"
  var lex: Lexer = create_lexer(src, 19)
  var p: Parser = parser_init(&lex)

  let fn_def: *FnDef = parse_fn_def(&p)
  assert fn_def != 0
  0

# ============================================================================
# Operator Precedence Tests
# ============================================================================

@test
fn test_precedence_addition_vs_mult() -> i32
  # 2 * 3 + 4 should parse as (2 * 3) + 4
  let src: *i8 = "2*3+4"
  var lex: Lexer = create_lexer(src, 5)
  var p: Parser = parser_init(&lex)

  let expr: *Expr = parse_expr(&p, 0)
  assert expr != 0
  # Root should be addition
  assert (*expr).kind == EXPR_BIN_OP
  assert (*expr).val2 == TOK_PLUS
  # Left should be multiplication
  assert (*expr).left != 0
  assert (*(*expr).left).kind == EXPR_BIN_OP
  assert (*(*expr).left).val2 == TOK_STAR
  0

@test
fn test_precedence_same_level() -> i32
  # 1 + 2 + 3 should be left-associative: (1 + 2) + 3
  let src: *i8 = "1+2+3"
  var lex: Lexer = create_lexer(src, 5)
  var p: Parser = parser_init(&lex)

  let expr: *Expr = parse_expr(&p, 0)
  assert expr != 0
  # Root should be addition
  assert (*expr).val2 == TOK_PLUS
  # Left should also be addition
  assert (*expr).left != 0
  assert (*(*expr).left).val2 == TOK_PLUS
  0

# ============================================================================
# Edge Cases
# ============================================================================

@test
fn test_parse_single_number() -> i32
  let src: *i8 = "0"
  var lex: Lexer = create_lexer(src, 1)
  var p: Parser = parser_init(&lex)

  let expr: *Expr = parse_expr(&p, 0)
  assert expr != 0
  assert (*expr).kind == EXPR_INT_LIT
  0

@test
fn test_parse_complex_expression() -> i32
  # -1 + 2 * 3
  let src: *i8 = "-1+2*3"
  var lex: Lexer = create_lexer(src, 6)
  var p: Parser = parser_init(&lex)

  let expr: *Expr = parse_expr(&p, 0)
  assert expr != 0
  # Should parse correctly without crashing
  0
