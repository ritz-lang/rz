# ritz1/test/test_arena.ritz - Arena allocator tests
#
# Tests the mmap-based arena allocator in mem.ritz

# =============================================================================
# Linux x86_64 mmap constants (duplicated for test independence)
# =============================================================================

const SYS_MMAP: i64 = 9
const SYS_MUNMAP: i64 = 11
const PROT_RW: i64 = 3
const MAP_PRIVATE_ANON: i64 = 34

# =============================================================================
# Arena implementation (inline for testing)
# =============================================================================

fn mmap(addr: i64, length: i64, prot: i64, flags: i64, fd: i64, offset: i64) -> *i8
  syscall6(SYS_MMAP, addr, length, prot, flags, fd, offset) as *i8

fn munmap(addr: *i8, length: i64) -> i64
  syscall2(SYS_MUNMAP, addr as i64, length)

struct Arena
  base: *i8
  size: i64
  used: i64

fn arena_new(capacity: i64) -> *Arena
  let header_size: i64 = 24
  let total: i64 = header_size + capacity
  let mem: *i8 = mmap(0, total, PROT_RW, MAP_PRIVATE_ANON, -1, 0)
  if mem as i64 < 0
    return 0 as *Arena
  let arena: *Arena = mem as *Arena
  arena.base = mem + header_size
  arena.size = capacity
  arena.used = 0
  arena

fn arena_alloc(arena: *Arena, size: i64) -> *i8
  let aligned: i64 = (size + 7) & -8
  if arena.used + aligned > arena.size
    return 0 as *i8
  let ptr: *i8 = arena.base + arena.used
  arena.used = arena.used + aligned
  ptr

fn arena_reset(arena: *Arena) -> i64
  arena.used = 0
  0

fn arena_destroy(arena: *Arena) -> i64
  let header_size: i64 = 24
  let total: i64 = header_size + arena.size
  munmap(arena as *i8, total)

# =============================================================================
# Tests
# =============================================================================

@test
fn test_arena_new() -> i32
  # Create a 4KB arena
  let arena: *Arena = arena_new(4096)

  # Should not be null
  assert arena != 0 as *Arena

  # Should have correct size
  assert arena.size == 4096

  # Should start empty
  assert arena.used == 0

  # Cleanup
  arena_destroy(arena)
  0

@test
fn test_arena_alloc_basic() -> i32
  let arena: *Arena = arena_new(4096)
  assert arena != 0 as *Arena

  # Allocate 64 bytes
  let ptr1: *i8 = arena_alloc(arena, 64)
  assert ptr1 != 0 as *i8

  # Should have advanced the used counter (aligned to 8)
  assert arena.used == 64

  # Allocate another 32 bytes
  let ptr2: *i8 = arena_alloc(arena, 32)
  assert ptr2 != 0 as *i8

  # Pointers should be different
  assert ptr1 != ptr2

  # ptr2 should be 64 bytes after ptr1
  assert ptr2 == ptr1 + 64

  # Used should be 96
  assert arena.used == 96

  arena_destroy(arena)
  0

@test
fn test_arena_alignment() -> i32
  let arena: *Arena = arena_new(4096)
  assert arena != 0 as *Arena

  # Allocate 1 byte - should round up to 8
  let ptr1: *i8 = arena_alloc(arena, 1)
  assert arena.used == 8

  # Allocate 7 bytes - should round up to 8
  let ptr2: *i8 = arena_alloc(arena, 7)
  assert arena.used == 16

  # Allocate 9 bytes - should round up to 16
  let ptr3: *i8 = arena_alloc(arena, 9)
  assert arena.used == 32

  arena_destroy(arena)
  0

@test
fn test_arena_write_read() -> i32
  let arena: *Arena = arena_new(4096)
  assert arena != 0 as *Arena

  # Allocate and write some data
  let ptr: *i64 = arena_alloc(arena, 8) as *i64
  *ptr = 12345678

  # Read it back
  assert *ptr == 12345678

  arena_destroy(arena)
  0

@test
fn test_arena_multiple_values() -> i32
  let arena: *Arena = arena_new(4096)
  assert arena != 0 as *Arena

  # Allocate several i64 values
  let a: *i64 = arena_alloc(arena, 8) as *i64
  let b: *i64 = arena_alloc(arena, 8) as *i64
  let c: *i64 = arena_alloc(arena, 8) as *i64

  # Write different values
  *a = 100
  *b = 200
  *c = 300

  # They should remain independent (no address reuse!)
  assert *a == 100
  assert *b == 200
  assert *c == 300

  arena_destroy(arena)
  0

@test
fn test_arena_reset() -> i32
  let arena: *Arena = arena_new(4096)
  assert arena != 0 as *Arena

  # Allocate some stuff
  arena_alloc(arena, 100)
  arena_alloc(arena, 200)
  assert arena.used > 0

  # Reset
  arena_reset(arena)
  assert arena.used == 0

  # Can allocate again from the beginning
  let ptr: *i8 = arena_alloc(arena, 50)
  assert ptr == arena.base

  arena_destroy(arena)
  0

@test
fn test_arena_exhaustion() -> i32
  # Create a tiny arena (64 bytes)
  let arena: *Arena = arena_new(64)
  assert arena != 0 as *Arena

  # Should be able to allocate up to capacity
  let ptr1: *i8 = arena_alloc(arena, 32)
  assert ptr1 != 0 as *i8

  let ptr2: *i8 = arena_alloc(arena, 32)
  assert ptr2 != 0 as *i8

  # Should fail when exhausted
  let ptr3: *i8 = arena_alloc(arena, 8)
  assert ptr3 == 0 as *i8

  arena_destroy(arena)
  0

# Test struct to verify complex allocations
struct Point
  x: i64
  y: i64

@test
fn test_arena_struct_allocation() -> i32
  let arena: *Arena = arena_new(4096)
  assert arena != 0 as *Arena

  # Allocate a Point (16 bytes)
  let p1: *Point = arena_alloc(arena, 16) as *Point
  p1.x = 10
  p1.y = 20

  # Allocate another Point
  let p2: *Point = arena_alloc(arena, 16) as *Point
  p2.x = 30
  p2.y = 40

  # Both should retain their values
  assert p1.x == 10
  assert p1.y == 20
  assert p2.x == 30
  assert p2.y == 40

  # They should be at different addresses
  assert p1 != p2

  arena_destroy(arena)
  0

@test
fn test_arena_large_allocation() -> i32
  # Create a 1MB arena
  let arena: *Arena = arena_new(1048576)
  assert arena != 0 as *Arena

  # Allocate a large block (256KB)
  let ptr: *i8 = arena_alloc(arena, 262144)
  assert ptr != 0 as *i8

  # Write to first and last byte to verify memory is accessible
  *ptr = 42
  *(ptr + 262143) = 99

  assert *ptr == 42
  assert *(ptr + 262143) == 99

  arena_destroy(arena)
  0
