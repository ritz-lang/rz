# Test break and continue statements

@test
fn test_break_exits_loop() -> i32
  var i: i32 = 0
  while i < 10
    if i == 5
      break
    i = i + 1
  assert i == 5, "break should exit at i=5"
  0

@test
fn test_continue_skips_iteration() -> i32
  var i: i32 = 0
  var sum: i32 = 0
  while i < 5
    i = i + 1
    if i == 3
      continue
    sum = sum + i
  # sum = 1 + 2 + 4 + 5 = 12 (skipped 3)
  assert sum == 12, "continue should skip i=3"
  0

@test
fn test_break_in_nested_loop() -> i32
  var outer: i32 = 0
  var inner_sum: i32 = 0
  while outer < 3
    var inner: i32 = 0
    while inner < 10
      if inner == 2
        break
      inner_sum = inner_sum + 1
      inner = inner + 1
    outer = outer + 1
  # Each outer loop runs inner 0,1 then breaks at 2 (2 iterations)
  # 3 outer loops * 2 inner iterations = 6
  assert inner_sum == 6, "nested break should work"
  0
