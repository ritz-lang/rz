# ritz1 Regex Parser Tests
#
# Tests for regex pattern parsing and NFA construction.
# Run with: python ritz0/ritz0.py --lib ritz1/src/nfa.ritz ritz1/src/regex.ritz --test ritz1/test/test_regex.ritz

# Helper to allocate NFA storage on stack
fn make_nfa() -> NFA
  let states: *NFAState = __builtin_alloca(3072)    # 256 * 12 bytes
  let trans: *Transition = __builtin_alloca(10240)  # 512 * 20 bytes
  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)
  nfa

# Test single character pattern
@test
fn test_regex_char() -> i32
  var nfa: NFA = make_nfa()
  let frag: NFAFragment = regex_parse("a", 1, &nfa)
  thompson_accept(&nfa, frag, 1)

  assert nfa_accepts(&nfa, "a", 1) == 1
  assert nfa_accepts(&nfa, "b", 1) == 0
  0

# Test concatenation: "ab"
@test
fn test_regex_concat() -> i32
  var nfa: NFA = make_nfa()
  let frag: NFAFragment = regex_parse("ab", 2, &nfa)
  thompson_accept(&nfa, frag, 1)

  assert nfa_accepts(&nfa, "ab", 2) == 1
  assert nfa_accepts(&nfa, "a", 1) == 0
  assert nfa_accepts(&nfa, "abc", 3) == 0
  0

# Test alternation: "a|b"
@test
fn test_regex_alt() -> i32
  var nfa: NFA = make_nfa()
  let frag: NFAFragment = regex_parse("a|b", 3, &nfa)
  thompson_accept(&nfa, frag, 1)

  assert nfa_accepts(&nfa, "a", 1) == 1
  assert nfa_accepts(&nfa, "b", 1) == 1
  assert nfa_accepts(&nfa, "c", 1) == 0
  0

# Test Kleene star: "a*"
@test
fn test_regex_star() -> i32
  var nfa: NFA = make_nfa()
  let frag: NFAFragment = regex_parse("a*", 2, &nfa)
  thompson_accept(&nfa, frag, 1)

  assert nfa_accepts(&nfa, "", 0) == 1
  assert nfa_accepts(&nfa, "a", 1) == 1
  assert nfa_accepts(&nfa, "aaa", 3) == 1
  assert nfa_accepts(&nfa, "b", 1) == 0
  0

# Test plus: "a+"
@test
fn test_regex_plus() -> i32
  var nfa: NFA = make_nfa()
  let frag: NFAFragment = regex_parse("a+", 2, &nfa)
  thompson_accept(&nfa, frag, 1)

  assert nfa_accepts(&nfa, "", 0) == 0
  assert nfa_accepts(&nfa, "a", 1) == 1
  assert nfa_accepts(&nfa, "aaa", 3) == 1
  0

# Test optional: "a?"
@test
fn test_regex_opt() -> i32
  var nfa: NFA = make_nfa()
  let frag: NFAFragment = regex_parse("a?", 2, &nfa)
  thompson_accept(&nfa, frag, 1)

  assert nfa_accepts(&nfa, "", 0) == 1
  assert nfa_accepts(&nfa, "a", 1) == 1
  assert nfa_accepts(&nfa, "aa", 2) == 0
  0

# Test character class: [abc]
@test
fn test_regex_class_chars() -> i32
  var nfa: NFA = make_nfa()
  let frag: NFAFragment = regex_parse("[abc]", 5, &nfa)
  thompson_accept(&nfa, frag, 1)

  assert nfa_accepts(&nfa, "a", 1) == 1
  assert nfa_accepts(&nfa, "b", 1) == 1
  assert nfa_accepts(&nfa, "c", 1) == 1
  assert nfa_accepts(&nfa, "d", 1) == 0
  0

# Test character range: [a-z]
@test
fn test_regex_class_range() -> i32
  var nfa: NFA = make_nfa()
  let frag: NFAFragment = regex_parse("[a-z]", 5, &nfa)
  thompson_accept(&nfa, frag, 1)

  assert nfa_accepts(&nfa, "a", 1) == 1
  assert nfa_accepts(&nfa, "m", 1) == 1
  assert nfa_accepts(&nfa, "z", 1) == 1
  assert nfa_accepts(&nfa, "A", 1) == 0
  assert nfa_accepts(&nfa, "0", 1) == 0
  0

# Test digit pattern: [0-9]+
@test
fn test_regex_digits() -> i32
  var nfa: NFA = make_nfa()
  let frag: NFAFragment = regex_parse("[0-9]+", 6, &nfa)
  thompson_accept(&nfa, frag, 1)

  assert nfa_accepts(&nfa, "0", 1) == 1
  assert nfa_accepts(&nfa, "42", 2) == 1
  assert nfa_accepts(&nfa, "12345", 5) == 1
  assert nfa_accepts(&nfa, "", 0) == 0
  assert nfa_accepts(&nfa, "abc", 3) == 0
  0

# Test identifier pattern: [a-z][a-z0-9]*
@test
fn test_regex_ident() -> i32
  var nfa: NFA = make_nfa()
  let frag: NFAFragment = regex_parse("[a-z][a-z0-9]*", 14, &nfa)
  thompson_accept(&nfa, frag, 1)

  assert nfa_accepts(&nfa, "a", 1) == 1
  assert nfa_accepts(&nfa, "foo", 3) == 1
  assert nfa_accepts(&nfa, "x1", 2) == 1
  assert nfa_accepts(&nfa, "abc123", 6) == 1
  assert nfa_accepts(&nfa, "1abc", 4) == 0
  assert nfa_accepts(&nfa, "", 0) == 0
  0

# Test dot (any character): a.b
@test
fn test_regex_dot() -> i32
  var nfa: NFA = make_nfa()
  let frag: NFAFragment = regex_parse("a.b", 3, &nfa)
  thompson_accept(&nfa, frag, 1)

  assert nfa_accepts(&nfa, "aXb", 3) == 1
  assert nfa_accepts(&nfa, "a1b", 3) == 1
  assert nfa_accepts(&nfa, "ab", 2) == 0
  assert nfa_accepts(&nfa, "aXXb", 4) == 0
  0

# Test escape sequences
@test
fn test_regex_escape() -> i32
  var nfa: NFA = make_nfa()
  # Match literal *
  let frag: NFAFragment = regex_parse("a\\*b", 4, &nfa)
  thompson_accept(&nfa, frag, 1)

  assert nfa_accepts(&nfa, "a*b", 3) == 1
  assert nfa_accepts(&nfa, "ab", 2) == 0
  assert nfa_accepts(&nfa, "aXb", 3) == 0
  0

# Test quoted literal: parse_literal helper
@test
fn test_regex_literal() -> i32
  var nfa: NFA = make_nfa()
  let frag: NFAFragment = regex_parse_literal("\"fn\"", 4, &nfa)
  thompson_accept(&nfa, frag, 1)

  assert nfa_accepts(&nfa, "fn", 2) == 1
  assert nfa_accepts(&nfa, "f", 1) == 0
  assert nfa_accepts(&nfa, "fnn", 3) == 0
  0

# Test multi-char operator: ->
@test
fn test_regex_arrow() -> i32
  var nfa: NFA = make_nfa()
  let frag: NFAFragment = regex_parse_literal("\"->\"", 4, &nfa)
  thompson_accept(&nfa, frag, 1)

  assert nfa_accepts(&nfa, "->", 2) == 1
  assert nfa_accepts(&nfa, "-", 1) == 0
  assert nfa_accepts(&nfa, ">", 1) == 0
  0
