# ritz1/test/test_parser_ast.ritz - Parser AST structure tests
#
# Tests for AST structures and allocation patterns.
# These tests don't require the full parser - just the data structures.

# Import AST constants directly (can't use parser.ritz due to forward ref issues)
const EXPR_INT_LIT: i32 = 1
const EXPR_IDENT: i32 = 2
const EXPR_STRING_LIT: i32 = 3
const EXPR_BOOL_LIT: i32 = 4
const EXPR_BIN_OP: i32 = 5
const EXPR_UNARY_OP: i32 = 6
const EXPR_CALL: i32 = 7
const EXPR_INDEX: i32 = 8
const EXPR_FIELD: i32 = 9
const EXPR_PAREN: i32 = 10
const EXPR_CAST: i32 = 11

const STMT_EXPR: i32 = 20
const STMT_VAR: i32 = 21
const STMT_LET: i32 = 22
const STMT_RETURN: i32 = 26

# Type kinds
const TYPE_NAMED: i32 = 50
const TYPE_PTR: i32 = 51
const TYPE_REF: i32 = 52
const TYPE_REF_MUT: i32 = 53
const TYPE_ARRAY: i32 = 54
const TYPE_SLICE: i32 = 55

# Define AST structs directly
struct Expr
  kind: i32
  val1: i32
  val2: i32
  left: *i32
  right: *i32
  next: *i32

struct TypeExpr
  kind: i32
  name: *i8
  name_len: i32
  inner: *i32
  size: i32
  is_mut: i32

struct Stmt
  kind: i32
  name: *i8
  name_len: i32
  type_expr: *i32
  expr: *i32
  stmt: *i32
  next: *i32

# ============================================================================
# Tests
# ============================================================================

@test
fn test_expr_kinds_defined() -> i32
  assert EXPR_INT_LIT == 1
  assert EXPR_IDENT == 2
  assert EXPR_BIN_OP == 5
  assert EXPR_UNARY_OP == 6
  assert EXPR_CAST == 11
  0

@test
fn test_stmt_kinds_defined() -> i32
  assert STMT_EXPR == 20
  assert STMT_VAR == 21
  assert STMT_RETURN == 26
  0

@test
fn test_expr_alloca_with_cast() -> i32
  # Test that alloca with cast compiles and works
  let ptr: *Expr = __builtin_alloca(256) as *Expr
  (*ptr).kind = EXPR_INT_LIT
  (*ptr).val1 = 42
  assert (*ptr).kind == EXPR_INT_LIT
  assert (*ptr).val1 == 42
  0

@test
fn test_stmt_alloca_with_cast() -> i32
  # Test Stmt allocation with cast
  let stmt: *Stmt = __builtin_alloca(256) as *Stmt
  (*stmt).kind = STMT_VAR
  (*stmt).name_len = 10
  assert (*stmt).kind == STMT_VAR
  assert (*stmt).name_len == 10
  0

@test
fn test_expr_ptr_fields() -> i32
  # Test pointer field assignment
  let expr1: *Expr = __builtin_alloca(256) as *Expr
  let expr2: *Expr = __builtin_alloca(256) as *Expr
  (*expr1).kind = EXPR_BIN_OP
  (*expr2).kind = EXPR_INT_LIT
  (*expr1).left = expr2 as *i32
  assert (*expr1).kind == EXPR_BIN_OP
  let retrieved: *Expr = (*expr1).left as *Expr
  assert (*retrieved).kind == EXPR_INT_LIT
  0

@test
fn test_linked_list_pattern() -> i32
  # Test building linked list of nodes
  let node1: *Expr = __builtin_alloca(256) as *Expr
  let node2: *Expr = __builtin_alloca(256) as *Expr
  let node3: *Expr = __builtin_alloca(256) as *Expr

  (*node1).kind = 1
  (*node2).kind = 2
  (*node3).kind = 3

  (*node1).next = node2 as *i32
  (*node2).next = node3 as *i32
  (*node3).next = 0 as *i32

  # Traverse
  var cur: *Expr = node1
  assert (*cur).kind == 1
  cur = (*cur).next as *Expr
  assert (*cur).kind == 2
  cur = (*cur).next as *Expr
  assert (*cur).kind == 3
  0

@test
fn test_type_kinds_defined() -> i32
  assert TYPE_NAMED == 50
  assert TYPE_PTR == 51
  assert TYPE_REF == 52
  assert TYPE_REF_MUT == 53
  assert TYPE_ARRAY == 54
  assert TYPE_SLICE == 55
  0

@test
fn test_type_expr_alloca() -> i32
  # Test TypeExpr allocation
  let ty: *TypeExpr = __builtin_alloca(256) as *TypeExpr
  (*ty).kind = TYPE_NAMED
  (*ty).name_len = 3
  (*ty).is_mut = 0
  assert (*ty).kind == TYPE_NAMED
  assert (*ty).name_len == 3
  0

@test
fn test_type_ptr_chain() -> i32
  # Test pointer type: *i32
  let outer: *TypeExpr = __builtin_alloca(256) as *TypeExpr
  let inner: *TypeExpr = __builtin_alloca(256) as *TypeExpr

  (*inner).kind = TYPE_NAMED
  (*inner).name_len = 3  # i32

  (*outer).kind = TYPE_PTR
  (*outer).inner = inner as *i32
  (*outer).is_mut = 0

  assert (*outer).kind == TYPE_PTR
  let retrieved: *TypeExpr = (*outer).inner as *TypeExpr
  assert (*retrieved).kind == TYPE_NAMED
  0

@test
fn test_stmt_with_type() -> i32
  # Test Stmt with type_expr field
  let stmt: *Stmt = __builtin_alloca(256) as *Stmt
  let ty: *TypeExpr = __builtin_alloca(256) as *TypeExpr

  (*ty).kind = TYPE_NAMED
  (*ty).name_len = 3

  (*stmt).kind = STMT_VAR
  (*stmt).name_len = 1
  (*stmt).type_expr = ty as *i32

  assert (*stmt).kind == STMT_VAR
  let retrieved: *TypeExpr = (*stmt).type_expr as *TypeExpr
  assert (*retrieved).kind == TYPE_NAMED
  0
