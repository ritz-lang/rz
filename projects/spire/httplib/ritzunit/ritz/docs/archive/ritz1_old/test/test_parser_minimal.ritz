@test
fn test_stmt_break_continue_kinds() -> i32
  # Test STMT_BREAK and STMT_CONTINUE constants
  assert STMT_BREAK == 28
  assert STMT_CONTINUE == 29

  let brk: *Stmt = __builtin_alloca(256) as *Stmt
  let cont: *Stmt = __builtin_alloca(256) as *Stmt
  (*brk).kind = STMT_BREAK
  (*cont).kind = STMT_CONTINUE

  assert (*brk).kind == STMT_BREAK
  assert (*cont).kind == STMT_CONTINUE
  0

@test
fn test_if_stmt_structure() -> i32
  # Test if statement struct layout
  let stmt: *Stmt = __builtin_alloca(256) as *Stmt
  let cond: *Expr = __builtin_alloca(128) as *Expr
  let then_body: *Stmt = __builtin_alloca(256) as *Stmt
  let else_body: *Stmt = __builtin_alloca(256) as *Stmt

  (*cond).kind = EXPR_BOOL_LIT
  (*cond).val1 = 1  # true

  (*then_body).kind = STMT_BLOCK
  (*else_body).kind = STMT_BLOCK

  (*stmt).kind = STMT_IF
  (*stmt).expr = cond as *i32
  (*stmt).stmt = then_body as *i32
  (*stmt).next = else_body as *i32

  assert (*stmt).kind == STMT_IF
  let retrieved_cond: *Expr = (*stmt).expr as *Expr
  assert (*retrieved_cond).kind == EXPR_BOOL_LIT
  let retrieved_then: *Stmt = (*stmt).stmt as *Stmt
  assert (*retrieved_then).kind == STMT_BLOCK
  let retrieved_else: *Stmt = (*stmt).next as *Stmt
  assert (*retrieved_else).kind == STMT_BLOCK
  0

@test
fn test_while_stmt_structure() -> i32
  # Test while statement struct layout
  let stmt: *Stmt = __builtin_alloca(256) as *Stmt
  let cond: *Expr = __builtin_alloca(128) as *Expr
  let body: *Stmt = __builtin_alloca(256) as *Stmt

  (*cond).kind = EXPR_BIN_OP
  (*body).kind = STMT_BLOCK

  (*stmt).kind = STMT_WHILE
  (*stmt).expr = cond as *i32
  (*stmt).stmt = body as *i32

  assert (*stmt).kind == STMT_WHILE
  let retrieved_cond: *Expr = (*stmt).expr as *Expr
  assert (*retrieved_cond).kind == EXPR_BIN_OP
  let retrieved_body: *Stmt = (*stmt).stmt as *Stmt
  assert (*retrieved_body).kind == STMT_BLOCK
  0

# ============================================================================
# Cast Expression Tests
# ============================================================================

@test
fn test_cast_expr_structure() -> i32
  # Test cast expression struct layout
  let expr: *Expr = __builtin_alloca(256) as *Expr
  let source: *Expr = __builtin_alloca(128) as *Expr
  let target_type: *TypeExpr = __builtin_alloca(128) as *TypeExpr

  # source: 42
  (*source).kind = EXPR_INT_LIT
  (*source).val1 = 42

  # target type: *i8
  (*target_type).kind = TYPE_PTR
  (*target_type).is_mut = 0

  # cast: 42 as *i8
  (*expr).kind = EXPR_CAST
  (*expr).left = source as *i32
  (*expr).right = target_type as *i32

  assert (*expr).kind == EXPR_CAST
  let retrieved_source: *Expr = (*expr).left as *Expr
  assert (*retrieved_source).kind == EXPR_INT_LIT
  assert (*retrieved_source).val1 == 42
  let retrieved_type: *TypeExpr = (*expr).right as *TypeExpr
  assert (*retrieved_type).kind == TYPE_PTR
  0

@test
fn test_cast_chain() -> i32
  # Test chained casts: x as *i8 as *i32
  let cast1: *Expr = __builtin_alloca(256) as *Expr
  let cast2: *Expr = __builtin_alloca(256) as *Expr
  let source: *Expr = __builtin_alloca(128) as *Expr
  let type1: *TypeExpr = __builtin_alloca(128) as *TypeExpr
  let type2: *TypeExpr = __builtin_alloca(128) as *TypeExpr

  (*source).kind = EXPR_IDENT
  (*type1).kind = TYPE_PTR
  (*type2).kind = TYPE_PTR

  # x as *i8
  (*cast1).kind = EXPR_CAST
  (*cast1).left = source as *i32
  (*cast1).right = type1 as *i32

  # (x as *i8) as *i32
  (*cast2).kind = EXPR_CAST
  (*cast2).left = cast1 as *i32
  (*cast2).right = type2 as *i32

  assert (*cast2).kind == EXPR_CAST
  let inner: *Expr = (*cast2).left as *Expr
  assert (*inner).kind == EXPR_CAST
  let innermost: *Expr = (*inner).left as *Expr
  assert (*innermost).kind == EXPR_IDENT
  0

# ============================================================================
# Struct Literal Tests
# ============================================================================

@test
fn test_struct_lit_kinds() -> i32
  # Test EXPR_STRUCT_LIT and EXPR_FIELD_INIT constants
  assert EXPR_STRUCT_LIT == 12
  assert EXPR_FIELD_INIT == 13
  0

@test
fn test_struct_lit_structure() -> i32
  # Test struct literal: Point { x: 1, y: 2 }
  let expr: *Expr = __builtin_alloca(256) as *Expr
  let field1: *Expr = __builtin_alloca(128) as *Expr
  let field2: *Expr = __builtin_alloca(128) as *Expr
  let val1: *Expr = __builtin_alloca(128) as *Expr
  let val2: *Expr = __builtin_alloca(128) as *Expr

  # Field values
  (*val1).kind = EXPR_INT_LIT
  (*val1).val1 = 1
  (*val2).kind = EXPR_INT_LIT
  (*val2).val1 = 2

  # Field initializers: x: 1, y: 2
  (*field1).kind = EXPR_FIELD_INIT
  (*field1).val1 = 100  # field name position
  (*field1).val2 = 1    # field name length
  (*field1).right = val1 as *i32
  (*field1).next = field2 as *i32

  (*field2).kind = EXPR_FIELD_INIT
  (*field2).val1 = 105
  (*field2).val2 = 1
  (*field2).right = val2 as *i32
  (*field2).next = 0

  # Struct literal
  (*expr).kind = EXPR_STRUCT_LIT
  (*expr).val1 = 50   # struct name position
  (*expr).val2 = 5    # struct name length
  (*expr).left = field1 as *i32

  assert (*expr).kind == EXPR_STRUCT_LIT
  let first_field: *Expr = (*expr).left as *Expr
  assert (*first_field).kind == EXPR_FIELD_INIT
  let second_field: *Expr = (*first_field).next as *Expr
  assert (*second_field).kind == EXPR_FIELD_INIT
  0

@test
fn test_field_init_with_expr() -> i32
  # Test field initializer with complex expression
  let field: *Expr = __builtin_alloca(128) as *Expr
  let value: *Expr = __builtin_alloca(128) as *Expr

  (*value).kind = EXPR_BIN_OP
  (*value).val2 = TOK_PLUS

  (*field).kind = EXPR_FIELD_INIT
  (*field).val1 = 10
  (*field).val2 = 3
  (*field).right = value as *i32

  assert (*field).kind == EXPR_FIELD_INIT
  let retrieved_value: *Expr = (*field).right as *Expr
  assert (*retrieved_value).kind == EXPR_BIN_OP
  assert (*retrieved_value).val2 == TOK_PLUS
  0
