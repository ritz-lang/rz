# ritz1/test/test_parser_minimal.ritz - Minimal parser tests
#
# Tests for the recursive descent parser.
# Run with: python ritz0/ritz0.py --lib <parser-deps> ritz1/src/parser.ritz --test ritz1/test/test_parser_minimal.ritz
#
# Note: AST structures and constants are defined in parser.ritz

# ============================================================================
# Test: Parser helpers compile
# ============================================================================

@test
fn test_parser_can_initialize() -> i32
  # Parser now works with explicit casts from __builtin_alloca
  0

@test
fn test_expr_kinds_defined() -> i32
  # Verify expression kind constants are accessible
  assert EXPR_INT_LIT == 1
  assert EXPR_IDENT == 2
  assert EXPR_BIN_OP == 5
  assert EXPR_UNARY_OP == 6
  assert EXPR_CAST == 11
  0

@test
fn test_stmt_kinds_defined() -> i32
  # Verify statement kind constants are accessible
  assert STMT_EXPR == 20
  assert STMT_VAR == 21
  assert STMT_RETURN == 26
  0

@test
fn test_tok_as_defined() -> i32
  # Verify TOK_AS is defined (needed for cast expressions)
  assert TOK_AS == 27
  0

@test
fn test_cast_precedence() -> i32
  # Verify cast has highest precedence
  assert get_infix_precedence(TOK_AS) == 12
  assert get_infix_precedence(TOK_STAR) == 9
  assert get_infix_precedence(TOK_PLUS) == 8
  0

@test
fn test_alloca_with_cast() -> i32
  # Test that alloca with cast compiles and works
  let ptr: *Expr = __builtin_alloca(256) as *Expr
  (*ptr).kind = EXPR_INT_LIT
  (*ptr).val1 = 42
  assert (*ptr).kind == EXPR_INT_LIT
  assert (*ptr).val1 == 42
  0

@test
fn test_stmt_alloca_with_cast() -> i32
  # Test Stmt allocation with cast
  let stmt: *Stmt = __builtin_alloca(256) as *Stmt
  (*stmt).kind = STMT_VAR
  (*stmt).name_len = 10
  assert (*stmt).kind == STMT_VAR
  assert (*stmt).name_len == 10
  0

@test
fn test_param_struct_alloca() -> i32
  # Test Param struct allocation
  let param: *Param = __builtin_alloca(128) as *Param
  (*param).name = 0 as *i8
  (*param).name_len = 5
  (*param).type_expr = 0 as *TypeExpr
  (*param).next = 0 as *Param
  assert (*param).name_len == 5
  0

@test
fn test_param_linked_list() -> i32
  # Test Param linked list (forward struct reference)
  let p1: *Param = __builtin_alloca(128) as *Param
  let p2: *Param = __builtin_alloca(128) as *Param
  let p3: *Param = __builtin_alloca(128) as *Param

  (*p1).name_len = 1
  (*p2).name_len = 2
  (*p3).name_len = 3

  (*p1).next = p2
  (*p2).next = p3
  (*p3).next = 0 as *Param

  # Traverse the list
  var cur: *Param = p1
  assert (*cur).name_len == 1
  cur = (*cur).next
  assert (*cur).name_len == 2
  cur = (*cur).next
  assert (*cur).name_len == 3
  0

@test
fn test_fndef_with_params() -> i32
  # Test FnDef with params and ret_type fields
  let fn_def: *FnDef = __builtin_alloca(256) as *FnDef
  let param: *Param = __builtin_alloca(128) as *Param
  let ret_ty: *TypeExpr = __builtin_alloca(128) as *TypeExpr

  (*param).name_len = 3
  (*param).next = 0 as *Param

  (*ret_ty).kind = TYPE_NAMED
  (*ret_ty).name_len = 3

  (*fn_def).name = 0 as *i8
  (*fn_def).name_len = 4
  (*fn_def).params = param
  (*fn_def).ret_type = ret_ty
  (*fn_def).body = 0 as *Stmt

  assert (*fn_def).name_len == 4
  assert (*(*fn_def).params).name_len == 3
  assert (*(*fn_def).ret_type).kind == TYPE_NAMED
  0

@test
fn test_param_with_type() -> i32
  # Test Param with a TypeExpr
  let param: *Param = __builtin_alloca(128) as *Param
  let ty: *TypeExpr = __builtin_alloca(128) as *TypeExpr

  (*ty).kind = TYPE_PTR
  (*ty).is_mut = 1

  (*param).name_len = 5
  (*param).type_expr = ty
  (*param).next = 0 as *Param

  assert (*param).name_len == 5
  assert (*(*param).type_expr).kind == TYPE_PTR
  assert (*(*param).type_expr).is_mut == 1
  0

