# ritz1/src/main.ritz - Main entry point for ritz1 compiler
#
# The ritz1 compiler: compiles Ritz source to LLVM IR
#
# Usage: ritz1 input.ritz > output.ll
#        ritz1 --lib lib1.ritz lib2.ritz main.ritz > output.ll
#
# Pipeline:
#   1. Read source from file arguments
#   2. Initialize lexer with NFA patterns
#   3. Parse source to AST
#   4. Emit LLVM IR
#   5. Write IR to stdout

# =============================================================================
# Constants
# =============================================================================

const STDIN: i32 = 0
const STDOUT: i32 = 1
const STDERR: i32 = 2
const O_RDONLY: i32 = 0
const O_WRONLY: i32 = 1
const O_CREAT: i32 = 64
const O_TRUNC: i32 = 512
const BUF_SIZE: i64 = 131072  # 128KB buffer for source files

# =============================================================================
# Syscall wrappers (no libc dependency)
# =============================================================================

# Linux x86_64 syscall numbers
const SYS_READ: i64 = 0
const SYS_WRITE: i64 = 1
const SYS_OPEN: i64 = 2
const SYS_CLOSE: i64 = 3

fn sys_read(fd: i32, buf: *i8, count: i64) -> i64
  syscall3(SYS_READ, fd as i64, buf as i64, count)

fn sys_write(fd: i32, buf: *i8, count: i64) -> i64
  syscall3(SYS_WRITE, fd as i64, buf as i64, count)

fn sys_open(path: *i8, flags: i32, mode: i32) -> i32
  let result: i64 = syscall3(SYS_OPEN, path as i64, flags as i64, mode as i64)
  result as i32

fn sys_close(fd: i32) -> i32
  let result: i64 = syscall1(SYS_CLOSE, fd as i64)
  result as i32

# =============================================================================
# Helper functions
# =============================================================================

# Print a null-terminated string to stderr
fn eprint(msg: *i8) -> i32
  var len: i64 = 0
  while *(msg + len) != 0
    len = len + 1
  sys_write(STDERR, msg, len)
  0

# Print a null-terminated string to stdout
fn print(msg: *i8) -> i32
  var len: i64 = 0
  while *(msg + len) != 0
    len = len + 1
  sys_write(STDOUT, msg, len)
  0

# Check if two strings are equal (for argument parsing)
# NOTE: We mask with 255 to extract only the low byte from 8-byte loads
# This is necessary because ritz1's emitter loads i64 for all dereferences
fn streq(a: *i8, b: *i8) -> i32
  var i: i32 = 0
  while 1 == 1
    let ca: i32 = (*(a + i)) & 255
    let cb: i32 = (*(b + i)) & 255
    if ca != cb
      return 0
    if ca == 0
      return 1
    i = i + 1
  0

# Read entire file into buffer, return length
fn read_file(path: *i8, buf: *mut i8, max_size: i64) -> i64
  let fd: i32 = sys_open(path, O_RDONLY, 0)
  if fd < 0
    eprint("Error: Cannot open file: ")
    eprint(path)
    eprint("\n")
    return -1

  var total: i64 = 0
  var n: i64 = 1

  while n > 0
    if total >= max_size
      eprint("Error: File too large: ")
      eprint(path)
      eprint("\n")
      sys_close(fd)
      return -1
    n = sys_read(fd, buf + total, max_size - total)
    if n < 0
      eprint("Error: Read failed: ")
      eprint(path)
      eprint("\n")
      sys_close(fd)
      return -1
    total = total + n

  sys_close(fd)
  # Null-terminate the buffer
  *(buf + total) = 0
  total

# Write buffer to file
fn write_file(path: *i8, buf: *i8, len: i64) -> i32
  let fd: i32 = sys_open(path, O_WRONLY + O_CREAT + O_TRUNC, 420)  # 0644 octal = 420 decimal
  if fd < 0
    eprint("Error: Cannot open output file: ")
    eprint(path)
    eprint("\n")
    return -1
  sys_write(fd, buf, len)
  sys_close(fd)
  0

# =============================================================================
# Main entry point
# =============================================================================

fn main(argc: i32, argv: **u8) -> i32
  # Check arguments
  if argc < 2
    eprint("Usage: ritz1 [--lib] <files...> -o <output.ll>\n")
    eprint("  Compiles Ritz source files to LLVM IR\n")
    return 1

  # Parse arguments
  var is_lib_mode: i32 = 0
  var file_start: i32 = 1
  var file_end: i32 = argc
  var output_file: *i8 = 0 as *i8

  # Check for --lib flag
  if argc >= 2
    let arg1: *i8 = argv[1]
    if streq(arg1, "--lib") == 1
      is_lib_mode = 1
      file_start = 2

  # Find -o flag and output file
  var i: i32 = file_start
  while i < argc
    let arg: *i8 = argv[i]
    if streq(arg, "-o") == 1
      if i + 1 >= argc
        eprint("Error: -o requires an argument\n")
        return 1
      output_file = argv[i + 1]
      file_end = i
      i = argc  # Break out of loop
    else
      i = i + 1

  # Require -o flag
  if output_file == 0 as *i8
    eprint("Error: -o <output.ll> is required\n")
    return 1

  # Need at least one file
  if file_start >= file_end
    eprint("Error: No input files\n")
    return 1

  # Allocate memory for compilation
  # - Source buffer for reading files
  # - Arena for parser/lexer allocations
  # - NFA/lexer state
  # - IR output buffer
  let src_buf: *mut i8 = __builtin_alloca(BUF_SIZE) as *mut i8
  let arena_buf: *i8 = __builtin_alloca(2097152) as *i8  # 2MB arena
  var arena: Arena = Arena { base: arena_buf, size: 2097152, used: 0 }

  # NFA for lexer
  let nfa_states_buf: *i8 = __builtin_alloca(16384) as *i8
  let nfa_trans_buf: *i8 = __builtin_alloca(32768) as *i8
  var nfa: NFA = NFA {
    states: nfa_states_buf as *NFAState,
    state_count: 0,
    transitions: nfa_trans_buf as *Transition,
    trans_count: 0,
    start_state: 0
  }

  # Patterns array
  let patterns_buf: *i8 = __builtin_alloca(8192) as *i8

  # IR builder
  let ir_buf: *i8 = __builtin_alloca(1048576) as *i8  # 1MB for IR output
  var ir: IRBuilder = IRBuilder {
    buf: ir_buf,
    len: 0,
    cap: 1048576,
    arena: &arena,
    next_id: 1,
    next_label: 0,
    indent: 0,
    consts: 0 as *i8,
    structs: 0 as *i8
  }

  # Emit module header
  ir_emit_module_header(&ir, "ritz1_output")

  # Process each input file
  var file_idx: i32 = file_start
  var total_fns: i32 = 0

  while file_idx < file_end
    let file_path: *i8 = argv[file_idx]

    # Read file
    let src_len: i64 = read_file(file_path, src_buf, BUF_SIZE)
    if src_len < 0
      return 1

    # Initialize lexer for this file
    var lex: Lexer = Lexer {
      src: src_buf as *i8,
      len: src_len as i32,
      pos: 0,
      line: 1,
      col: 1,
      nfa: &nfa,
      patterns: patterns_buf as *TokenPattern,
      pattern_count: 0,
      indent_stack: [0; 64],
      indent_depth: 1,
      at_line_start: 1,
      pending_dedents: 0,
      bracket_depth: 0
    }

    # Build Ritz token patterns (only on first file - patterns persist)
    if file_idx == file_start
      build_ritz_lexer(&lex)

    # Initialize parser with arena for allocations
    var parser: Parser = parser_init(&lex, &arena)

    # Parse module
    let module: *Module = parse_module(&parser)

    # Register constants and structs from this module with IR builder
    ir_add_consts(&ir, (*module).consts as *i8)
    ir_add_structs(&ir, (*module).structs as *i8)

    # Emit IR for each function in the module
    var fn_def: *FnDef = (*module).fns
    while fn_def != 0 as *FnDef
      emit_ast_fn(&ir, fn_def as *i8, src_buf as *i8)
      total_fns = total_fns + 1
      fn_def = (*fn_def).next

    file_idx = file_idx + 1

  # Emit _start wrapper that passes argc/argv to main
  ir_emit_start_with_args(&ir)

  # Write IR to output file
  if ir.len > 0
    if write_file(output_file, ir.buf, ir.len) < 0
      return 1

  0

