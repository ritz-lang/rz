# ritz1/test/test_pipeline.ritz - End-to-end pipeline tests
#
# Tests the full compilation pipeline: source -> lexer -> parser -> emitter -> IR
# This validates that all components work together correctly.
#
# Uses mem.ritz, tokens.ritz, lexer.ritz, ritz_tokens.ritz from --lib

# =============================================================================
# Test Helpers
# =============================================================================

fn str_contains(s: *i8, needle: *i8) -> i32
  var i: i32 = 0
  while *(s + i) != 0
    var j: i32 = 0
    var matched: i32 = 1
    while *(needle + j) != 0
      if *(s + i + j) != *(needle + j)
        matched = 0
        break
      j = j + 1
    if matched == 1
      return 1
    i = i + 1
  0

# =============================================================================
# Minimal IRBuilder for tests
# =============================================================================

struct IRBuilder
  buf: *i8
  len: i64
  cap: i64
  arena: *Arena
  next_id: i32
  indent: i32

fn ir_builder_new(arena: *Arena, capacity: i64) -> *IRBuilder
  let b: *IRBuilder = arena_alloc(arena, 48) as *IRBuilder
  b.buf = arena_alloc(arena, capacity)
  b.len = 0
  b.cap = capacity
  b.arena = arena
  b.next_id = 1
  b.indent = 0
  b

fn ir_fresh_id(b: *IRBuilder) -> i32
  let id: i32 = b.next_id
  b.next_id = b.next_id + 1
  id

fn ir_put_byte(b: *IRBuilder, ch: i32) -> i32
  if b.len >= b.cap
    return -1
  *(b.buf + b.len) = ch as i8
  b.len = b.len + 1
  0

fn ir_put_str(b: *IRBuilder, s: *i8) -> i32
  var i: i32 = 0
  while *(s + i) != 0
    if ir_put_byte(b, *(s + i) as i32) < 0
      return -1
    i = i + 1
  0

fn ir_put_int(b: *IRBuilder, n: i64) -> i32
  if n < 0
    ir_put_byte(b, 45)
    return ir_put_int(b, 0 - n)
  if n == 0
    return ir_put_byte(b, 48)
  var digits: [20]i8 = [0; 20]
  var count: i32 = 0
  var val: i64 = n
  while val > 0
    let digit: i32 = (val - (val / 10) * 10) as i32
    digits[count] = (48 + digit) as i8
    count = count + 1
    val = val / 10
  var i: i32 = count - 1
  while i >= 0
    if ir_put_byte(b, digits[i] as i32) < 0
      return -1
    i = i - 1
  0

fn ir_newline(b: *IRBuilder) -> i32
  ir_put_byte(b, 10)

fn ir_put_indent(b: *IRBuilder) -> i32
  var i: i32 = 0
  while i < b.indent
    ir_put_str(b, "  ")
    i = i + 1
  0

fn ir_get_buffer(b: *IRBuilder) -> *i8
  if b.len < b.cap
    *(b.buf + b.len) = 0
  b.buf

# Type constants
const TY_VOID: i32 = 1
const TY_BOOL: i32 = 2
const TY_I8: i32 = 3
const TY_I32: i32 = 5
const TY_I64: i32 = 6

fn ir_emit_type(b: *IRBuilder, kind: i32) -> i32
  if kind == TY_VOID
    ir_put_str(b, "void")
  else if kind == TY_BOOL
    ir_put_str(b, "i1")
  else if kind == TY_I32
    ir_put_str(b, "i32")
  else if kind == TY_I64
    ir_put_str(b, "i64")
  else
    ir_put_str(b, "i64")

fn ir_emit_alloca(b: *IRBuilder, result: i32, ty: i32) -> i32
  ir_put_indent(b)
  ir_put_str(b, "%")
  ir_put_int(b, result as i64)
  ir_put_str(b, " = alloca ")
  ir_emit_type(b, ty)
  ir_newline(b)

fn ir_emit_store_imm(b: *IRBuilder, ty: i32, imm: i64, ptr: i32) -> i32
  ir_put_indent(b)
  ir_put_str(b, "store ")
  ir_emit_type(b, ty)
  ir_put_str(b, " ")
  ir_put_int(b, imm)
  ir_put_str(b, ", ")
  ir_emit_type(b, ty)
  ir_put_str(b, "* %")
  ir_put_int(b, ptr as i64)
  ir_newline(b)

fn ir_emit_load(b: *IRBuilder, result: i32, ty: i32, ptr: i32) -> i32
  ir_put_indent(b)
  ir_put_str(b, "%")
  ir_put_int(b, result as i64)
  ir_put_str(b, " = load ")
  ir_emit_type(b, ty)
  ir_put_str(b, ", ")
  ir_emit_type(b, ty)
  ir_put_str(b, "* %")
  ir_put_int(b, ptr as i64)
  ir_newline(b)

fn ir_emit_binop(b: *IRBuilder, op: *i8, ty: i32, result: i32, lhs: i32, rhs: i32) -> i32
  ir_put_indent(b)
  ir_put_str(b, "%")
  ir_put_int(b, result as i64)
  ir_put_str(b, " = ")
  ir_put_str(b, op)
  ir_put_str(b, " ")
  ir_emit_type(b, ty)
  ir_put_str(b, " %")
  ir_put_int(b, lhs as i64)
  ir_put_str(b, ", %")
  ir_put_int(b, rhs as i64)
  ir_newline(b)

fn ir_emit_ret(b: *IRBuilder, ty: i32, val: i32) -> i32
  ir_put_indent(b)
  ir_put_str(b, "ret ")
  ir_emit_type(b, ty)
  ir_put_str(b, " %")
  ir_put_int(b, val as i64)
  ir_newline(b)

fn ir_emit_ret_imm(b: *IRBuilder, ty: i32, imm: i64) -> i32
  ir_put_indent(b)
  ir_put_str(b, "ret ")
  ir_emit_type(b, ty)
  ir_put_str(b, " ")
  ir_put_int(b, imm)
  ir_newline(b)

fn ir_emit_fn_start(b: *IRBuilder, name: *i8, ret_ty: i32) -> i32
  ir_put_str(b, "define ")
  ir_emit_type(b, ret_ty)
  ir_put_str(b, " @\"")
  ir_put_str(b, name)
  ir_put_str(b, "\"()")
  ir_newline(b)
  ir_put_str(b, "{")
  ir_newline(b)
  ir_put_str(b, "entry:")
  ir_newline(b)
  b.indent = 1
  0

fn ir_emit_fn_end(b: *IRBuilder) -> i32
  b.indent = 0
  ir_put_str(b, "}")
  ir_newline(b)

# =============================================================================
# Pipeline context
# =============================================================================

# Expression kinds (from parser.ritz)
const EXPR_INT_LIT: i32 = 1
const EXPR_BIN_OP: i32 = 5

# Parsed expression node
struct PipeExpr
  kind: i32
  val1: i32
  val2: i32
  left: *PipeExpr
  right: *PipeExpr

# Pipeline context
struct Pipeline
  arena: *Arena
  builder: *IRBuilder
  src: *i8
  src_len: i32

fn pipeline_new(arena: *Arena, src: *i8, src_len: i32) -> *Pipeline
  let p: *Pipeline = arena_alloc(arena, 64) as *Pipeline
  p.arena = arena
  p.builder = ir_builder_new(arena, 8192)
  p.src = src
  p.src_len = src_len
  p

# =============================================================================
# Simplified expression emission for pipeline tests
# =============================================================================

fn pipeline_emit_expr(p: *Pipeline, e: *PipeExpr) -> i32
  let b: *IRBuilder = p.builder

  if e.kind == EXPR_INT_LIT
    let slot: i32 = ir_fresh_id(b)
    ir_emit_alloca(b, slot, TY_I64)
    ir_emit_store_imm(b, TY_I64, e.val1 as i64, slot)
    let result: i32 = ir_fresh_id(b)
    ir_emit_load(b, result, TY_I64, slot)
    return result

  if e.kind == EXPR_BIN_OP
    let lhs: i32 = pipeline_emit_expr(p, e.left)
    let rhs: i32 = pipeline_emit_expr(p, e.right)
    let result: i32 = ir_fresh_id(b)
    if e.val2 == TOK_PLUS
      ir_emit_binop(b, "add", TY_I64, result, lhs, rhs)
    return result

  -1

# =============================================================================
# Tests
# =============================================================================

@test
fn test_pipeline_setup() -> i32
  # Test that we can create a pipeline
  let arena: *Arena = arena_new(16384)
  let src: *i8 = "1 + 2"
  let p: *Pipeline = pipeline_new(arena, src, 5)

  assert p != 0 as *Pipeline, "pipeline should be created"
  assert p.arena == arena, "arena should be set"
  assert p.builder != 0 as *IRBuilder, "builder should be set"
  0

@test
fn test_pipeline_emit_int() -> i32
  # Test emitting a single integer
  let arena: *Arena = arena_new(16384)
  let p: *Pipeline = pipeline_new(arena, "42", 2)

  # Manually construct AST: 42
  let expr: *PipeExpr = arena_alloc(arena, 48) as *PipeExpr
  expr.kind = EXPR_INT_LIT
  expr.val1 = 42

  ir_emit_fn_start(p.builder, "test", TY_I64)
  let result: i32 = pipeline_emit_expr(p, expr)
  ir_emit_ret(p.builder, TY_I64, result)
  ir_emit_fn_end(p.builder)

  let ir: *i8 = ir_get_buffer(p.builder)
  assert str_contains(ir, "define i64") == 1, "should have function"
  assert str_contains(ir, "store i64 42") == 1, "should store 42"
  assert str_contains(ir, "ret i64") == 1, "should have return"
  0

@test
fn test_pipeline_emit_add() -> i32
  # Test emitting 1 + 2
  let arena: *Arena = arena_new(16384)
  let p: *Pipeline = pipeline_new(arena, "1 + 2", 5)

  # Manually construct AST: 1 + 2
  let left: *PipeExpr = arena_alloc(arena, 48) as *PipeExpr
  left.kind = EXPR_INT_LIT
  left.val1 = 1

  let right: *PipeExpr = arena_alloc(arena, 48) as *PipeExpr
  right.kind = EXPR_INT_LIT
  right.val1 = 2

  let add: *PipeExpr = arena_alloc(arena, 48) as *PipeExpr
  add.kind = EXPR_BIN_OP
  add.val2 = TOK_PLUS
  add.left = left
  add.right = right

  ir_emit_fn_start(p.builder, "test", TY_I64)
  let result: i32 = pipeline_emit_expr(p, add)
  ir_emit_ret(p.builder, TY_I64, result)
  ir_emit_fn_end(p.builder)

  let ir: *i8 = ir_get_buffer(p.builder)
  assert str_contains(ir, "define i64") == 1, "should have function"
  assert str_contains(ir, "store i64 1") == 1, "should store 1"
  assert str_contains(ir, "store i64 2") == 1, "should store 2"
  assert str_contains(ir, "add i64") == 1, "should have add"
  assert str_contains(ir, "ret i64") == 1, "should have return"
  0

@test
fn test_pipeline_lex_to_ast() -> i32
  # Test lexing source to tokens and building AST
  # This tests the lexer -> parser step
  let arena: *Arena = arena_new(131072)
  let storage: *i8 = arena_alloc(arena, 65536)

  # Set up NFA and lexer storage
  let states: *NFAState = storage as *NFAState
  let trans: *Transition = (storage + 8192) as *Transition
  let patterns: *TokenPattern = (storage + 24576) as *TokenPattern

  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  # Create lexer for expression "1 + 2"
  let src: *i8 = "1 + 2"
  var lex: Lexer = Lexer { src: src, len: 5, pos: 0, line: 1, col: 1, nfa: &nfa, patterns: patterns, pattern_count: 0 , indent_stack: [0; 64], indent_depth: 1, at_line_start: 1, pending_dedents: 0, bracket_depth: 0 }
  build_ritz_lexer(&lex)

  # Lex tokens
  let t1: Token = lexer_next(&lex)
  assert t1.type == TOK_INT, "first token should be int"
  assert t1.len == 1, "first token length should be 1"

  let t2: Token = lexer_next(&lex)
  assert t2.type == TOK_PLUS, "second token should be plus"

  let t3: Token = lexer_next(&lex)
  assert t3.type == TOK_INT, "third token should be int"
  assert t3.len == 1, "third token length should be 1"

  # Build AST from tokens
  let left: *PipeExpr = arena_alloc(arena, 48) as *PipeExpr
  left.kind = EXPR_INT_LIT
  # Parse integer value from source: src[t1.start..t1.start+t1.len]
  left.val1 = *(src + t1.start) as i32 - 48  # '1' - '0' = 1

  let right: *PipeExpr = arena_alloc(arena, 48) as *PipeExpr
  right.kind = EXPR_INT_LIT
  right.val1 = *(src + t3.start) as i32 - 48  # '2' - '0' = 2

  let add: *PipeExpr = arena_alloc(arena, 48) as *PipeExpr
  add.kind = EXPR_BIN_OP
  add.val2 = t2.type  # TOK_PLUS
  add.left = left
  add.right = right

  # Emit IR
  let p: *Pipeline = pipeline_new(arena, src, 5)
  ir_emit_fn_start(p.builder, "test", TY_I64)
  let result: i32 = pipeline_emit_expr(p, add)
  ir_emit_ret(p.builder, TY_I64, result)
  ir_emit_fn_end(p.builder)

  let ir: *i8 = ir_get_buffer(p.builder)
  assert str_contains(ir, "store i64 1") == 1, "should store 1 from lexed token"
  assert str_contains(ir, "store i64 2") == 1, "should store 2 from lexed token"
  assert str_contains(ir, "add i64") == 1, "should have add op"
  0

@test
fn test_pipeline_complete_program() -> i32
  # Test generating a complete program: fn main() -> i32 { 1 + 2 }
  let arena: *Arena = arena_new(131072)
  let storage: *i8 = arena_alloc(arena, 65536)

  let states: *NFAState = storage as *NFAState
  let trans: *Transition = (storage + 8192) as *Transition
  let patterns: *TokenPattern = (storage + 24576) as *TokenPattern

  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  # Lex "1 + 2"
  let src: *i8 = "1 + 2"
  var lex: Lexer = Lexer { src: src, len: 5, pos: 0, line: 1, col: 1, nfa: &nfa, patterns: patterns, pattern_count: 0 , indent_stack: [0; 64], indent_depth: 1, at_line_start: 1, pending_dedents: 0, bracket_depth: 0 }
  build_ritz_lexer(&lex)

  let t1: Token = lexer_next(&lex)
  let t2: Token = lexer_next(&lex)
  let t3: Token = lexer_next(&lex)

  # Build AST
  let left: *PipeExpr = arena_alloc(arena, 48) as *PipeExpr
  left.kind = EXPR_INT_LIT
  left.val1 = *(src + t1.start) as i32 - 48

  let right: *PipeExpr = arena_alloc(arena, 48) as *PipeExpr
  right.kind = EXPR_INT_LIT
  right.val1 = *(src + t3.start) as i32 - 48

  let add: *PipeExpr = arena_alloc(arena, 48) as *PipeExpr
  add.kind = EXPR_BIN_OP
  add.val2 = t2.type
  add.left = left
  add.right = right

  # Emit complete program
  let b: *IRBuilder = ir_builder_new(arena, 8192)

  # Module header
  ir_put_str(b, "; ritz1 compiled program")
  ir_newline(b)
  ir_put_str(b, "target triple = \"x86_64-unknown-linux-gnu\"")
  ir_newline(b)
  ir_newline(b)

  # Function
  ir_put_str(b, "define i32 @main() {")
  ir_newline(b)
  ir_put_str(b, "entry:")
  ir_newline(b)
  b.indent = 1

  # Emit expression using pipeline
  let p: *Pipeline = arena_alloc(arena, 64) as *Pipeline
  p.arena = arena
  p.builder = b
  p.src = src
  p.src_len = 5

  let result: i32 = pipeline_emit_expr(p, add)

  # Truncate i64 result to i32 for return
  ir_put_indent(b)
  ir_put_str(b, "%ret = trunc i64 %")
  ir_put_int(b, result as i64)
  ir_put_str(b, " to i32")
  ir_newline(b)

  ir_put_indent(b)
  ir_put_str(b, "ret i32 %ret")
  ir_newline(b)

  b.indent = 0
  ir_put_str(b, "}")
  ir_newline(b)

  let ir: *i8 = ir_get_buffer(b)
  assert str_contains(ir, "; ritz1 compiled program") == 1, "should have header"
  assert str_contains(ir, "define i32 @main()") == 1, "should have main"
  assert str_contains(ir, "entry:") == 1, "should have entry label"
  assert str_contains(ir, "add i64") == 1, "should have add"
  assert str_contains(ir, "trunc i64") == 1, "should have trunc"
  assert str_contains(ir, "ret i32 %ret") == 1, "should return"
  0
