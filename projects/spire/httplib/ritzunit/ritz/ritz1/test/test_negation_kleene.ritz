# Test: Debug negation + kleene star hang
# Isolate where the infinite loop occurs

const SYS_WRITE: i64 = 1
const STDERR: i32 = 2

fn sys_write(fd: i32, buf: *i8, count: i64) -> i64
  syscall3(SYS_WRITE, fd as i64, buf as i64, count)

fn print_msg(msg: *i8)
  var len: i32 = 0
  while *(msg + len) != 0
    len = len + 1
  sys_write(STDERR, msg, len as i64)

fn main() -> i32
  var states: [512]NFAState
  var trans: [1024]Transition
  var nfa: NFA

  nfa_init(&nfa, &states, &trans)
  
  print_msg("Test 1: Simple negation [^a] without star...\n")
  let pattern1: *i8 = "[^a]"
  let frag1: NFAFragment = regex_parse(pattern1, 4, &nfa)
  thompson_accept(&nfa, frag1, 10)
  print_msg("  Pattern compiled successfully!\n")
  
  print_msg("\nTest 2: Single char 'a' with star...\n")
  let pattern2: *i8 = "a*"
  let frag2: NFAFragment = regex_parse(pattern2, 2, &nfa)
  thompson_accept(&nfa, frag2, 11)
  print_msg("  Pattern compiled successfully!\n")
  
  print_msg("\nTest 3: Negation [^a] with star [^a]*...\n")
  let pattern3: *i8 = "[^a]*"
  print_msg("  About to call regex_parse()...\n")
  let frag3: NFAFragment = regex_parse(pattern3, 5, &nfa)
  print_msg("  regex_parse() returned!\n")
  thompson_accept(&nfa, frag3, 12)
  print_msg("  Pattern compiled successfully!\n")
  
  print_msg("\nAll tests passed!\n")
  0
