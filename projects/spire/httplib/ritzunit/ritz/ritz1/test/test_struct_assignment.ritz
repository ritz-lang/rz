# Test struct assignment to verify next pointer initialization
# This test should reveal whether ritz0's struct assignment is correct

struct SimpleNode
  value: i32
  next: *SimpleNode

fn create_node_inline(v: i32) -> SimpleNode
  SimpleNode {
    value: v,
    next: 0
  }

fn print_msg(msg: *i8)
  var len: i32 = 0
  while *(msg + len) != 0
    len = len + 1
  __syscall3(1, 1, msg as i64, len as i64)

fn main() -> i32
  # Test 1: Direct struct literal return
  let node1: SimpleNode = create_node_inline(42)
  if node1.next != 0
    print_msg("FAIL: node1.next is not null!\n")
    return 1

  # Test 2: Struct assignment via pointer
  let s: *SimpleNode = __builtin_alloca(128)
  *s = create_node_inline(99)

  # Check if next pointer is null
  if s.next != 0
    print_msg("FAIL: s.next is not null after assignment!\n")
    print_msg("  This is the STRUCT BUG!\n")
    return 1

  # Test 3: Explicitly set next to 0 after assignment
  s.next = 0
  if s.next != 0
    print_msg("FAIL: s.next is not null even after explicit set!\n")
    return 1

  print_msg("PASS: All struct assignment tests passed\n")
  0
