# Minimal I/O functions for ritz1 examples
# Only pure functions - no malloc/free/String dependencies

import ritzlib.sys

fn prints(s: *u8)
    var len: i64 = 0
    while *(s + len) != 0
        len = len + 1
    sys_write(STDOUT, s, len)

fn eprints(s: *u8)
    var len: i64 = 0
    while *(s + len) != 0
        len = len + 1
    sys_write(STDERR, s, len)

fn print_char(c: u8)
    var buf: [1]u8
    buf[0] = c
    sys_write(STDOUT, &buf[0], 1)

fn eprint_char(c: u8)
    var buf: [1]u8
    buf[0] = c
    sys_write(STDERR, &buf[0], 1)

fn print_int(n: i64)
    if n < 0
        print_char(45)  # '-'
        n = 0 - n

    if n == 0
        print_char(48)
        return

    var buf: [20]u8
    var len: i64 = 0

    var tmp: i64 = n
    while tmp > 0
        len = len + 1
        tmp = tmp / 10

    var i: i64 = len - 1
    while n > 0
        buf[i] = ((n % 10) + '0') as u8
        n = n / 10
        i = i - 1

    sys_write(STDOUT, &buf[0], len)

fn eprint_int(n: i64)
    if n < 0
        eprint_char(45)  # '-'
        n = 0 - n

    if n == 0
        eprint_char(48)
        return

    var buf: [20]u8
    var len: i64 = 0

    var tmp: i64 = n
    while tmp > 0
        len = len + 1
        tmp = tmp / 10

    var i: i64 = len - 1
    while n > 0
        buf[i] = ((n % 10) + '0') as u8
        n = n / 10
        i = i - 1

    sys_write(STDERR, &buf[0], len)
