@test
fn test_emit_branch()
  let arena_buf: *i8 = __builtin_alloca(4096) as *i8
  var arena: Arena = Arena { base: arena_buf, size: 4096, used: 0 }

  let b: *IRBuilder = ir_builder_new(&arena, 1024)
  b.indent = 1
  ir_emit_br(b, 5)

  let output: *i8 = ir_builder_get_output(b)
  assert str_contains(output, "br label %L5") == 1, "should emit br"

@test
fn test_emit_branch_cond()
  let arena_buf: *i8 = __builtin_alloca(4096) as *i8
  var arena: Arena = Arena { base: arena_buf, size: 4096, used: 0 }

  let b: *IRBuilder = ir_builder_new(&arena, 1024)
  b.indent = 1
  ir_emit_br_cond(b, 1, 2, 3)

  let output: *i8 = ir_builder_get_output(b)
  assert str_contains(output, "br i1 %1, label %L2, label %L3") == 1, "should emit cond br"

@test
fn test_emit_string_const()
  let arena_buf: *i8 = __builtin_alloca(4096) as *i8
  var arena: Arena = Arena { base: arena_buf, size: 4096, used: 0 }

  let b: *IRBuilder = ir_builder_new(&arena, 1024)
  ir_emit_string_const(b, 0, "hello", 5)

  let output: *i8 = ir_builder_get_output(b)
  assert str_contains(output, "@.str.0") == 1, "should have string name"
  assert str_contains(output, "6 x i8") == 1, "should have array type (5+1 for null)"
  assert str_contains(output, "c\"hello\\00\"") == 1, "should have string content"

@test
fn test_emit_struct_def()
  let arena_buf: *i8 = __builtin_alloca(4096) as *i8
  var arena: Arena = Arena { base: arena_buf, size: 4096, used: 0 }

  let b: *IRBuilder = ir_builder_new(&arena, 1024)
  ir_emit_struct_start(b, "Point")
  ir_emit_struct_field(b, TY_I32, 1)
  ir_emit_struct_field(b, TY_I32, 0)
  ir_emit_struct_end(b)

  let output: *i8 = ir_builder_get_output(b)
  assert str_contains(output, "%Point = type { i32, i32 }") == 1, "should emit struct"

