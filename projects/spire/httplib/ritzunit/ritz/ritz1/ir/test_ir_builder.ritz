@test
fn test_emit_function_def()
  let arena_buf: *i8 = __builtin_alloca(8192) as *i8
  var arena: Arena = Arena { base: arena_buf, size: 8192, used: 0 }

  let b: *IRBuilder = ir_builder_new(&arena, 4096)
  ir_emit_fn_start(b, "add", TY_I32)
  ir_emit_fn_param(b, TY_I32, "a", 1)
  ir_emit_fn_param(b, TY_I32, "b", 0)
  ir_emit_fn_header_end(b)
  ir_emit_ret_imm(b, TY_I32, 0)
  ir_emit_fn_end(b)

  let output: *i8 = ir_builder_get_output(b)
  assert str_contains(output, "define i32 @add(") == 1, "should have function def"
  assert str_contains(output, "i32 %\"a.arg\"") == 1, "should have param a"
  assert str_contains(output, "i32 %\"b.arg\"") == 1, "should have param b"
  assert str_contains(output, "ret i32 0") == 1, "should have return"

@test
fn test_emit_alloca()
  let arena_buf: *i8 = __builtin_alloca(4096) as *i8
  var arena: Arena = Arena { base: arena_buf, size: 4096, used: 0 }

  let b: *IRBuilder = ir_builder_new(&arena, 1024)
  b.indent = 1
  let id: i32 = ir_fresh_id(b)
  ir_emit_alloca(b, id, TY_I32)

  let output: *i8 = ir_builder_get_output(b)
  assert str_contains(output, "%1 = alloca i32") == 1, "should emit alloca"

@test
fn test_emit_binop()
  let arena_buf: *i8 = __builtin_alloca(4096) as *i8
  var arena: Arena = Arena { base: arena_buf, size: 4096, used: 0 }

  let b: *IRBuilder = ir_builder_new(&arena, 1024)
  b.indent = 1
  ir_emit_binop(b, "add", TY_I32, 3, 1, 2)

  let output: *i8 = ir_builder_get_output(b)
  assert str_contains(output, "%3 = add i32 %1, %2") == 1, "should emit add"

@test
fn test_emit_icmp()
