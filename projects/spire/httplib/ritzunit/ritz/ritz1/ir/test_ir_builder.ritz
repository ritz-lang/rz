# ritz1/ir/test_ir_builder.ritz - Tests for IR Builder
#
# These tests verify that the IR builder generates correct LLVM IR text.
# Each test generates IR and checks the output matches expected strings.

import mem
import types
import ir_builder

# =============================================================================
# Test Helpers
# =============================================================================

fn str_eq(a: *i8, b: *i8) -> i32
  var i: i32 = 0
  while 1 == 1
    let ca: i32 = *(a + i) as i32 & 255
    let cb: i32 = *(b + i) as i32 & 255
    if ca != cb
      return 0
    if ca == 0
      return 1
    i = i + 1
  0

fn str_contains(haystack: *i8, needle: *i8) -> i32
  var h: i32 = 0
  while *(haystack + h) != 0
    var n: i32 = 0
    var matched: i32 = 1
    while *(needle + n) != 0
      let ch: i32 = *(haystack + h + n) as i32 & 255
      let cn: i32 = *(needle + n) as i32 & 255
      if ch != cn
        matched = 0
      n = n + 1
    if matched == 1
      return 1
    h = h + 1
  0

fn print_str(s: *i8) -> i32
  var len: i32 = 0
  while *(s + len) != 0
    len += 1
  write(1, s, len as i64)
  0

fn print_int(n: i64) -> i32
  if n < 0
    write(1, "-", 1)
    return print_int(0 - n)
  if n == 0
    write(1, "0", 1)
    return 0
  var digits: [20]i8 = [0; 20]
  var count: i32 = 0
  var val: i64 = n
  while val > 0
    let digit: i32 = (val - (val / 10) * 10) as i32
    digits[count] = (48 + digit) as i8
    count = count + 1
    val = val / 10
  var i: i32 = count - 1
  while i >= 0
    write(1, &digits[i], 1)
    i -= 1
  0

# =============================================================================
# Tests
# =============================================================================

@test
fn test_buffer_put_str()
  let arena_buf: *i8 = __builtin_alloca(4096) as *i8
  var arena: Arena = Arena { base: arena_buf, size: 4096, used: 0 }

  var buf: IRBuffer = ir_buffer_new(&arena, 256)
  ir_buffer_put_str(&buf, "hello")
  ir_buffer_put_byte(&buf, 0)

  assert str_eq(buf.data, "hello") == 1, "buffer should contain 'hello'"

@test
fn test_buffer_put_int()
  let arena_buf: *i8 = __builtin_alloca(4096) as *i8
  var arena: Arena = Arena { base: arena_buf, size: 4096, used: 0 }

  var buf: IRBuffer = ir_buffer_new(&arena, 256)
  ir_buffer_put_int(&buf, 12345)
  ir_buffer_put_byte(&buf, 0)

  assert str_eq(buf.data, "12345") == 1, "buffer should contain '12345'"

@test
fn test_buffer_put_negative()
  let arena_buf: *i8 = __builtin_alloca(4096) as *i8
  var arena: Arena = Arena { base: arena_buf, size: 4096, used: 0 }

  var buf: IRBuffer = ir_buffer_new(&arena, 256)
  ir_buffer_put_int(&buf, -42 as i64)
  ir_buffer_put_byte(&buf, 0)

  assert str_eq(buf.data, "-42") == 1, "buffer should contain '-42'"

@test
fn test_emit_module_header()
  let arena_buf: *i8 = __builtin_alloca(8192) as *i8
  var arena: Arena = Arena { base: arena_buf, size: 8192, used: 0 }

  let b: *IRBuilder = ir_builder_new(&arena, 4096)
  ir_emit_module_header(b, "test_module")

  let output: *i8 = ir_builder_get_output(b)
  assert str_contains(output, "ModuleID = 'test_module'") == 1, "should have module ID"
  assert str_contains(output, "target triple") == 1, "should have target triple"

@test
fn test_emit_type_i32()
  let arena_buf: *i8 = __builtin_alloca(4096) as *i8
  var arena: Arena = Arena { base: arena_buf, size: 4096, used: 0 }

  let b: *IRBuilder = ir_builder_new(&arena, 256)
  ir_emit_type(b, TY_I32)
  ir_put_byte(b, 0)

  let output: *i8 = ir_builder_get_output(b)
  assert str_eq(output, "i32") == 1, "should emit 'i32'"

