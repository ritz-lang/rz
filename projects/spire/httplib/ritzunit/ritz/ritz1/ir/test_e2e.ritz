# ritz1/ir/test_e2e.ritz - End-to-End Program Generation Test
#
# Generates complete LLVM IR programs and writes them to files for testing.

import mem
import types
import ir_builder
import expr_codegen
import stmt_codegen
import function_codegen

# =============================================================================
# End-to-End Test: fn main() -> i32 { return 42 }
# =============================================================================

@test
fn test_e2e_main_return_42()
  let arena_buf: *i8 = __builtin_alloca(65536) as *i8
  var arena: Arena = Arena { base: arena_buf, size: 65536, used: 0 }

  # Build: fn main() -> i32 { return 42 }
  var ret_expr: Expr = Expr { kind: EXPR_INT, int_val: 42, bool_val: 0, var_id: 0, op: 0, left: null, right: null, operand: null, ty: TY_I32, target_ty: 0 }
  var ret_stmt: Stmt = Stmt { kind: STMT_RETURN, var_name: null, var_ty: 0, var_init: null, lhs: null, rhs: null, ret_val: &ret_expr, condition: null, then_block: null, else_block: null, body: null, expr: null }

  var func: Function = Function { name: "main", ret_type: TY_I32, params: null, param_count: 0, body: &ret_stmt, body_count: 1 }

  let output: *i8 = emit_program(&arena, &func)

  # Verify structure
  assert str_contains(output, "define i32 @main()") == 1, "should have main"
  assert str_contains(output, "define void @_start()") == 1, "should have _start"
  assert str_contains(output, "call main") == 1, "should call main"
  assert str_contains(output, "ret i32 42") == 1, "should return immediate 42"

  # Write to file for manual inspection
  let fd: i64 = open("/tmp/test_main.ll", 577, 420)  # O_WRONLY|O_CREAT|O_TRUNC, 0644
  if fd >= 0
    var len: i32 = 0
    while *(output + len) != 0
      len = len + 1
    write(fd, output, len as i64)
    close(fd)

# =============================================================================
# Syscall wrappers (minimal)
# =============================================================================

fn open(path: *i8, flags: i32, mode: i32) -> i64
  syscall3(2, path as i64, flags as i64, mode as i64)

fn write(fd: i32, buf: *i8, count: i64) -> i64
  syscall3(1, fd as i64, buf as i64, count)

fn close(fd: i32) -> i64
  syscall1(3, fd as i64)

# Helper function
fn str_contains(haystack: *i8, needle: *i8) -> i32
  var h: i32 = 0
  while *(haystack + h) != 0
    var n: i32 = 0
    var matched: i32 = 1
    while *(needle + n) != 0
      let ch: i32 = *(haystack + h + n) as i32 & 255
      let cn: i32 = *(needle + n) as i32 & 255
      if ch != cn
        matched = 0
      n = n + 1
    if matched == 1
      return 1
    h = h + 1
  0
