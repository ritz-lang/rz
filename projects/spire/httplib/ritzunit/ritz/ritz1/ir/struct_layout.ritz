# ritz1/ir/struct_layout.ritz - LLVM-Compatible Struct Layout
#
# Computes struct field offsets, alignment, and total size matching LLVM's
# data layout algorithm for x86_64 Linux.
#
# LLVM Struct Layout Rules (x86_64):
# 1. Each field is aligned to its natural alignment
# 2. Padding is inserted before fields as needed to satisfy alignment
# 3. Struct size is rounded up to the alignment of the largest field
# 4. Natural alignment by type:
#    - i8, u8: 1 byte
#    - i16, u16: 2 bytes
#    - i32, u32, f32: 4 bytes
#    - i64, u64, f64, ptr: 8 bytes
#    - Arrays: alignment of element type
#    - Structs: alignment of largest field

import types  # For TY_* constants

# =============================================================================
# Type Alignment
# =============================================================================

fn type_alignment(ty: i32) -> i32
  if ty == TY_I8 || ty == TY_U8 || ty == TY_BOOL
    return 1
  else if ty == TY_I16 || ty == TY_U16
    return 2
  else if ty == TY_I32 || ty == TY_U32
    return 4
  else if ty == TY_I64 || ty == TY_U64 || ty == TY_PTR
    return 8
  else
    # Unknown type - default to pointer alignment
    return 8

fn type_size(ty: i32) -> i32
  if ty == TY_BOOL
    return 1
  else if ty == TY_I8 || ty == TY_U8
    return 1
  else if ty == TY_I16 || ty == TY_U16
    return 2
  else if ty == TY_I32 || ty == TY_U32
    return 4
  else if ty == TY_I64 || ty == TY_U64 || ty == TY_PTR
    return 8
  else
    # Unknown type - default to pointer size
    return 8

# =============================================================================
# Padding Calculation
# =============================================================================

# Round up to nearest multiple of alignment
fn align_to(offset: i32, alignment: i32) -> i32
  let remainder: i32 = offset - (offset / alignment) * alignment
  if remainder == 0
    offset
  else
    offset + (alignment - remainder)

# =============================================================================
# Struct Layout Computation
# =============================================================================

# Field layout info
struct FieldLayout
  offset: i32      # Byte offset from struct base
  size: i32        # Field size in bytes
  alignment: i32   # Field alignment requirement

# Struct layout info
struct StructLayout
  fields: *FieldLayout  # Array of field layouts
  field_count: i32      # Number of fields
  total_size: i32       # Total struct size (with padding)
  alignment: i32        # Struct alignment (max of field alignments)

# Compute layout for a struct with given field types
fn compute_struct_layout(field_types: *i32, field_count: i32, fields_out: *FieldLayout) -> StructLayout
  var offset: i32 = 0
  var max_align: i32 = 1

  # Process each field
  for i in 0..field_count
    let field_ty: i32 = *(field_types + i)
    let field_size: i32 = type_size(field_ty)
    let field_align: i32 = type_alignment(field_ty)

    # Track maximum alignment
    if field_align > max_align
      max_align = field_align

    # Align current offset to field's alignment requirement
    offset = align_to(offset, field_align)

    # Store field layout
    (*(fields_out + i)).offset = offset
    (*(fields_out + i)).size = field_size
    (*(fields_out + i)).alignment = field_align

    # Advance offset
    offset = offset + field_size

  # Round total size up to struct alignment
  let total_size: i32 = align_to(offset, max_align)

  StructLayout {
    fields: fields_out,
    field_count: field_count,
    total_size: total_size,
    alignment: max_align
  }

# =============================================================================
# Array Layout
# =============================================================================

struct ArrayLayout
  element_size: i32
  element_align: i32
  total_size: i32      # element_size * count
  alignment: i32       # Same as element alignment

fn compute_array_layout(elem_ty: i32, count: i32) -> ArrayLayout
  let elem_size: i32 = type_size(elem_ty)
  let elem_align: i32 = type_alignment(elem_ty)

  ArrayLayout {
    element_size: elem_size,
    element_align: elem_align,
    total_size: elem_size * count,
    alignment: elem_align
  }

# =============================================================================
# Tests
# =============================================================================

@test
fn test_type_alignment_primitives()
  assert type_alignment(TY_I8) == 1, "i8 should align to 1"
  assert type_alignment(TY_I16) == 2, "i16 should align to 2"
  assert type_alignment(TY_I32) == 4, "i32 should align to 4"
  assert type_alignment(TY_I64) == 8, "i64 should align to 8"
  assert type_alignment(TY_PTR) == 8, "ptr should align to 8"

@test
fn test_type_size_primitives()
  assert type_size(TY_I8) == 1, "i8 should be 1 byte"
  assert type_size(TY_I16) == 2, "i16 should be 2 bytes"
  assert type_size(TY_I32) == 4, "i32 should be 4 bytes"
  assert type_size(TY_I64) == 8, "i64 should be 8 bytes"
  assert type_size(TY_PTR) == 8, "ptr should be 8 bytes"

@test
fn test_align_to()
  assert align_to(0, 4) == 0, "0 aligned to 4 is 0"
  assert align_to(1, 4) == 4, "1 aligned to 4 is 4"
  assert align_to(4, 4) == 4, "4 aligned to 4 is 4"
  assert align_to(5, 4) == 8, "5 aligned to 4 is 8"
  assert align_to(7, 8) == 8, "7 aligned to 8 is 8"
  assert align_to(9, 8) == 16, "9 aligned to 8 is 16"

@test
fn test_struct_layout_simple()
  # struct Point { x: i32, y: i32 }
  var field_types: [2]i32 = [TY_I32, TY_I32]
  var field_layouts: [2]FieldLayout = [FieldLayout { offset: 0, size: 0, alignment: 0 }, FieldLayout { offset: 0, size: 0, alignment: 0 }]

  let layout: StructLayout = compute_struct_layout(&field_types[0], 2, &field_layouts[0])

  assert layout.field_count == 2, "should have 2 fields"
  assert layout.alignment == 4, "struct alignment should be 4 (max of i32)"
  assert layout.total_size == 8, "total size should be 8 (4+4)"

  assert field_layouts[0].offset == 0, "x offset should be 0"
  assert field_layouts[0].size == 4, "x size should be 4"

  assert field_layouts[1].offset == 4, "y offset should be 4"
  assert field_layouts[1].size == 4, "y size should be 4"

@test
fn test_struct_layout_with_padding()
  # struct Mixed { a: i8, b: i32, c: i8 }
  var field_types: [3]i32 = [TY_I8, TY_I32, TY_I8]
  var field_layouts: [3]FieldLayout = [FieldLayout { offset: 0, size: 0, alignment: 0 }, FieldLayout { offset: 0, size: 0, alignment: 0 }, FieldLayout { offset: 0, size: 0, alignment: 0 }]

  let layout: StructLayout = compute_struct_layout(&field_types[0], 3, &field_layouts[0])

  assert layout.alignment == 4, "struct alignment should be 4 (max field is i32)"
  assert layout.total_size == 12, "total size should be 12 (1+3pad+4+1+3pad)"

  assert field_layouts[0].offset == 0, "a offset should be 0"
  assert field_layouts[0].size == 1, "a size should be 1"

  # i32 requires 4-byte alignment, so 3 bytes padding after 'a'
  assert field_layouts[1].offset == 4, "b offset should be 4 (0+1+3pad)"
  assert field_layouts[1].size == 4, "b size should be 4"

  assert field_layouts[2].offset == 8, "c offset should be 8 (4+4)"
  assert field_layouts[2].size == 1, "c size should be 1"

  # Total size 9, rounded up to alignment 4 = 12

@test
fn test_struct_layout_nested_alignment()
  # struct Big { ptr: *i8, x: i64, y: i16 }
  var field_types: [3]i32 = [TY_PTR, TY_I64, TY_I16]
  var field_layouts: [3]FieldLayout = [FieldLayout { offset: 0, size: 0, alignment: 0 }, FieldLayout { offset: 0, size: 0, alignment: 0 }, FieldLayout { offset: 0, size: 0, alignment: 0 }]

  let layout: StructLayout = compute_struct_layout(&field_types[0], 3, &field_layouts[0])

  assert layout.alignment == 8, "struct alignment should be 8 (max of ptr/i64)"
  assert layout.total_size == 24, "total size should be 24"

  assert field_layouts[0].offset == 0, "ptr offset should be 0"
  assert field_layouts[0].size == 8, "ptr size should be 8"

  assert field_layouts[1].offset == 8, "i64 offset should be 8"
  assert field_layouts[1].size == 8, "i64 size should be 8"

  assert field_layouts[2].offset == 16, "i16 offset should be 16"
  assert field_layouts[2].size == 2, "i16 size should be 2"

  # Total: 18 bytes, rounded up to 8-byte alignment = 24

@test
fn test_array_layout()
  # [10]i32
  let layout: ArrayLayout = compute_array_layout(TY_I32, 10)

  assert layout.element_size == 4, "element size should be 4"
  assert layout.element_align == 4, "element alignment should be 4"
  assert layout.total_size == 40, "total size should be 40 (4*10)"
  assert layout.alignment == 4, "array alignment should be 4"

@test
fn test_array_layout_i8()
  # [64]i8
  let layout: ArrayLayout = compute_array_layout(TY_I8, 64)

  assert layout.element_size == 1, "element size should be 1"
  assert layout.element_align == 1, "element alignment should be 1"
  assert layout.total_size == 64, "total size should be 64"
  assert layout.alignment == 1, "array alignment should be 1"
