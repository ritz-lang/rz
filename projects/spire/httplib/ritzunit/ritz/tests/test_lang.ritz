import ritzlib.lang.tokens
import ritzlib.lang.lexer
import ritzlib.sys
import ritzlib.io

fn main() -> i32
    prints("ritzlib.lang test\n")
    
    # Test Token creation
    var src: [16]u8 = [0; 16]
    src[0] = 72  # H
    src[1] = 105 # i
    
    var tok: Token = token_new(TOK_IDENT, &src[0], 2, 1, 1)
    prints("Token kind: ")
    print_int(tok.kind as i64)
    prints("\n")
    
    # Test Lexer creation
    var lex: Lexer = lexer_new(&src[0], 2)
    prints("Lexer pos: ")
    print_int(lex.pos)
    prints("\n")
    
    return 0
