# Level 3, Test 10: Signed to unsigned cast
# Test that i32 as u64 uses zero extension, not sign extension
# This is critical for cryptographic code that uses bitmasks

fn main() -> i32
    # Test 1: Non-negative i32 to u64
    let a: i32 = 1
    let a64: u64 = a as u64
    if a64 != 1
        return 1

    # Test 2: The critical test - using result in bitwise operations
    # If sign extended, (1 as u64) | (0 - (1 as u64)) would be wrong
    let c32: u32 = a as u32
    let c64: u64 = c32 as u64
    let ored: u64 = c64 | (0 - c64)
    let norm: u64 = ored >> 63  # Should be 1 (MSB set)
    if norm != 1
        return 2

    # Test 3: Direct i32 -> u64 cast
    let cond: i32 = 1
    let cond64: u64 = cond as u64
    if cond64 != 1
        return 3

    # Test 4: Mask generation from condition
    let ored2: u64 = cond64 | (0 - cond64)
    let norm2: u64 = ored2 >> 63
    let mask: u64 = 0 - norm2  # Should be 0xFFFFFFFFFFFFFFFF
    if mask != 0xFFFFFFFFFFFFFFFF
        return 4

    # Test 5: u8 to u64 (should always use zext)
    let b: u8 = 0xAA
    let b64: u64 = b as u64
    if b64 != 0xAA
        return 5

    0
