# kill - send signals to processes
#
# Usage: kill [-SIGNAL] PID...
#        kill -l
#
# Send signals to processes by PID.
#
# Options:
#   -l           List all signal names
#   -SIGNAL      Signal to send (name or number)
#                e.g., -9, -KILL, -HUP, -TERM
#
# Examples:
#   kill 1234           # send SIGTERM to process 1234
#   kill -9 1234        # send SIGKILL to process 1234
#   kill -KILL 1234     # same as above
#   kill -HUP 1234 5678 # send SIGHUP to multiple processes
#   kill -l             # list all signals

# ============================================================================
# Standard library imports
# ============================================================================

import ritzlib.sys
import ritzlib.io
import ritzlib.str

# ============================================================================
# Signal name table
# ============================================================================

# Signal number to name mapping
# Index is signal number, value is name

fn get_signal_name(sig: i32) -> *u8
    if sig == 1
        return "HUP"
    if sig == 2
        return "INT"
    if sig == 3
        return "QUIT"
    if sig == 4
        return "ILL"
    if sig == 5
        return "TRAP"
    if sig == 6
        return "ABRT"
    if sig == 7
        return "BUS"
    if sig == 8
        return "FPE"
    if sig == 9
        return "KILL"
    if sig == 10
        return "USR1"
    if sig == 11
        return "SEGV"
    if sig == 12
        return "USR2"
    if sig == 13
        return "PIPE"
    if sig == 14
        return "ALRM"
    if sig == 15
        return "TERM"
    if sig == 16
        return "STKFLT"
    if sig == 17
        return "CHLD"
    if sig == 18
        return "CONT"
    if sig == 19
        return "STOP"
    if sig == 20
        return "TSTP"
    if sig == 21
        return "TTIN"
    if sig == 22
        return "TTOU"
    if sig == 23
        return "URG"
    if sig == 24
        return "XCPU"
    if sig == 25
        return "XFSZ"
    if sig == 26
        return "VTALRM"
    if sig == 27
        return "PROF"
    if sig == 28
        return "WINCH"
    if sig == 29
        return "IO"
    if sig == 30
        return "PWR"
    if sig == 31
        return "SYS"
    return null

fn parse_signal_name(name: *u8) -> i32
    # Parse signal name (without SIG prefix) to number
    # Returns -1 if not found

    # Skip optional "SIG" prefix
    var n: *u8 = name
    if *n == 'S' && *(n+1) == 'I' && *(n+2) == 'G'  # "SIG"
        n += 3

    if streq(n, "HUP") != 0
        return 1
    if streq(n, "INT") != 0
        return 2
    if streq(n, "QUIT") != 0
        return 3
    if streq(n, "ILL") != 0
        return 4
    if streq(n, "TRAP") != 0
        return 5
    if streq(n, "ABRT") != 0
        return 6
    if streq(n, "BUS") != 0
        return 7
    if streq(n, "FPE") != 0
        return 8
    if streq(n, "KILL") != 0
        return 9
    if streq(n, "USR1") != 0
        return 10
    if streq(n, "SEGV") != 0
        return 11
    if streq(n, "USR2") != 0
        return 12
    if streq(n, "PIPE") != 0
        return 13
    if streq(n, "ALRM") != 0
        return 14
    if streq(n, "TERM") != 0
        return 15
    if streq(n, "STKFLT") != 0
        return 16
    if streq(n, "CHLD") != 0
        return 17
    if streq(n, "CONT") != 0
        return 18
    if streq(n, "STOP") != 0
        return 19
    if streq(n, "TSTP") != 0
        return 20
    if streq(n, "TTIN") != 0
        return 21
    if streq(n, "TTOU") != 0
        return 22
    if streq(n, "URG") != 0
        return 23
    if streq(n, "XCPU") != 0
        return 24
    if streq(n, "XFSZ") != 0
        return 25
    if streq(n, "VTALRM") != 0
        return 26
    if streq(n, "PROF") != 0
        return 27
    if streq(n, "WINCH") != 0
        return 28
    if streq(n, "IO") != 0
        return 29
    if streq(n, "PWR") != 0
        return 30
    if streq(n, "SYS") != 0
        return 31

    return -1

# ============================================================================
# Helper functions
# ============================================================================

fn is_digit(c: u8) -> i32
    if c >= '0' && c <= '9'
        return 1
    return 0

fn is_all_digits(s: *u8) -> i32
    # Check if string is all digits (possibly with leading -)
    var p: *u8 = s
    if *p == '-'  # '-'
        p += 1
    if *p == 0
        return 0
    while *p != 0
        if is_digit(*p) == 0
            return 0
        p += 1
    return 1

fn print_usage()
    prints("Usage: kill [-SIGNAL] PID...\n")
    prints("       kill -l\n")
    prints("\n")
    prints("Send signals to processes.\n")
    prints("\n")
    prints("Options:\n")
    prints("  -l           List all signal names\n")
    prints("  -SIGNAL      Signal to send (name or number)\n")
    prints("               e.g., -9, -KILL, -HUP, -TERM\n")

fn list_signals()
    # List all signals in a format similar to GNU kill -l
    var sig: i32 = 1
    var col: i32 = 0
    while sig <= 31
        let name: *u8 = get_signal_name(sig)
        if name != null
            # Print signal number and name
            if sig < 10
                prints(" ")
            print_int(sig as i64)
            prints(") SIG")
            prints(name)

            col += 1
            if col >= 4
                print_char(10)  # newline
                col = 0
            else
                # Pad to column width (approx 16 chars)
                let name_len: i64 = strlen(name)
                var pad: i64 = 12 - name_len
                while pad > 0
                    print_char(32)  # space
                    pad -= 1
        sig += 1

    if col > 0
        print_char(10)  # final newline

fn parse_signal(arg: *u8) -> i32
    # Parse signal specification (after the leading -)
    # Returns signal number or -1 on error

    # Check if it's a number
    if is_all_digits(arg) != 0
        let sig: i64 = atoi(arg)
        # Signal 0 is special (check process existence)
        if sig >= 0 && sig <= 31
            return sig as i32
        return -1

    # Try to parse as signal name
    return parse_signal_name(arg)

# ============================================================================
# Main
# ============================================================================

fn main(argc: i32, argv: **u8, envp: **u8) -> i32
    if argc < 2
        print_usage()
        return 1

    var signal: i32 = SIGTERM  # default signal
    var first_pid_idx: i32 = 1
    var exit_code: i32 = 0

    # Check for -l (list signals)
    let arg1: *u8 = *(argv + 1)
    if streq(arg1, "-l") != 0 || streq(arg1, "--list") != 0
        list_signals()
        return 0

    # Check for --help
    if streq(arg1, "--help") != 0
        print_usage()
        return 0

    # Check for signal specification
    if *arg1 == '-'  # '-'
        let sig_spec: *u8 = arg1 + 1

        # Not just "-" alone
        if *sig_spec != 0
            # Check if it looks like a signal (not a negative PID for now)
            # Signal specs: -9, -KILL, -SIGKILL, -HUP, etc.
            signal = parse_signal(sig_spec)
            if signal < 0
                eprints("kill: invalid signal specification '")
                eprints(sig_spec)
                eprints("'\n")
                return 1
            first_pid_idx = 2

    # Need at least one PID
    if first_pid_idx >= argc
        eprints("kill: missing PID\n")
        print_usage()
        return 1

    # Send signal to each PID
    var i: i32 = first_pid_idx
    while i < argc
        let pid_str: *u8 = *(argv + i)

        # Parse PID (can be negative for process groups)
        if is_all_digits(pid_str) == 0
            eprints("kill: invalid PID '")
            eprints(pid_str)
            eprints("'\n")
            exit_code = 1
            i += 1
            continue

        let pid: i64 = atoi(pid_str)

        # Send the signal
        let result: i32 = sys_kill(pid as i32, signal)

        if result < 0
            let err: i32 = 0 - result
            eprints("kill: (")
            eprint_int(pid)
            eprints(") - ")

            if err == ESRCH
                eprints("No such process\n")
            else if err == EPERM
                eprints("Operation not permitted\n")
            else if err == EINVAL
                eprints("Invalid signal\n")
            else
                eprints("Error ")
                eprint_int(err as i64)
                eprints("\n")

            exit_code = 1

        i += 1

    return exit_code
