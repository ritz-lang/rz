# Test auto-dereference for pointer field access
# p.x should work like (*p).x

struct Point
    x: i32
    y: i32

struct Nested
    point: Point
    name: *u8

@test
fn test_pointer_field_read() -> i32
    var pt: Point = Point { x: 42, y: 100 }
    let p: *Point = &pt
    # p.x should auto-deref to (*p).x
    assert p.x == 42
    assert p.y == 100
    0

@test
fn test_pointer_field_write() -> i32
    var pt: Point = Point { x: 1, y: 2 }
    let p: *Point = &pt
    # p.x = value should auto-deref to (*p).x = value
    p.x = 99
    p.y = 88
    assert pt.x == 99
    assert pt.y == 88
    0

@test
fn test_nested_pointer_field() -> i32
    var pt: Point = Point { x: 5, y: 10 }
    var n: Nested = Nested { point: pt, name: null }
    let np: *Nested = &n
    # np.point.x should work (auto-deref np, then access point.x)
    assert np.point.x == 5
    assert np.point.y == 10
    0

@test
fn test_function_param_pointer() -> i32
    var pt: Point = Point { x: 10, y: 20 }
    # Test that pointer params work with auto-deref
    assert get_x(&pt) == 10
    assert get_sum(&pt) == 30
    0

fn get_x(p: *Point) -> i32
    p.x

fn get_sum(p: *Point) -> i32
    p.x + p.y
