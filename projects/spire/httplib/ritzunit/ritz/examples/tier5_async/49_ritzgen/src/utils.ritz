# ritzgen/utils.ritz - Shared utility functions
#
# Common helpers used across multiple ritzgen modules.

# =============================================================================
# Character classification
# =============================================================================

fn is_alpha(c: u8) -> i32
    if c >= 'A' && c <= 'Z'   # A-Z
        return 1
    if c >= 'a' && c <= 'z'  # a-z
        return 1
    if c == '_'              # _
        return 1
    return 0

fn is_alnum(c: u8) -> i32
    if is_alpha(c) != 0
        return 1
    if c >= '0' && c <= '9'   # 0-9
        return 1
    return 0

fn is_digit(c: u8) -> i32
    if c >= '0' && c <= '9'   # 0-9
        return 1
    return 0

# =============================================================================
# Name classification
# =============================================================================

# Check if a name is a terminal (all uppercase, underscores, digits allowed)
fn is_terminal_name(name: *u8, len: i32) -> i32
    var i: i32 = 0
    while i < len
        let c: u8 = *(name + i)
        # Must be uppercase letter or underscore or digit
        if c >= 'A' && c <= 'Z'  # A-Z
            i += 1
            continue
        if c == '_'  # _
            i += 1
            continue
        if c >= '0' && c <= '9'  # 0-9
            i += 1
            continue
        return 0  # Not a terminal
    return 1
