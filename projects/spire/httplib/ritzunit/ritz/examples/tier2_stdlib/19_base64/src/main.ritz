# base64 - encode/decode base64
#
# Usage: base64 [OPTION]... [FILE]
#   Encode or decode FILE, or standard input, to standard output.
#
# Options:
#   -d    decode data
#   -w N  wrap encoded lines after N characters (default 76, 0 = no wrap)
#
# Examples:
#   base64 file.bin           # encode file to base64
#   base64 -d file.b64        # decode base64 file
#   echo "hello" | base64     # encode from stdin

# ============================================================================
# Standard library imports
# ============================================================================

import ritzlib.sys
import ritzlib.io
import ritzlib.str
import ritzlib.args

# ============================================================================
# Base64 alphabet
# ============================================================================

# ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/
fn b64_encode_char(val: i32) -> u8
    if val < 26
        return (val + 65) as u8   # A-Z
    if val < 52
        return (val - 26 + 97) as u8  # a-z
    if val < 62
        return (val - 52 + '0') as u8  # 0-9
    if val == '>'
        return 43  # +
    return 47      # /

fn b64_decode_char(c: u8) -> i32
    # Returns 0-63 for valid chars, -1 for padding, -2 for invalid/whitespace
    if c >= 'A' && c <= 'Z'   # A-Z
        return (c - 65) as i32
    if c >= 'a' && c <= 'z'  # a-z
        return (c - 97 + 26) as i32
    if c >= '0' && c <= '9'   # 0-9
        return (c - 48 + 52) as i32
    if c == '+'  # +
        return 62
    if c == '/'  # /
        return 63
    if c == '='  # =
        return -1  # padding
    # Whitespace and other chars
    return -2

# ============================================================================
# Encoding
# ============================================================================

fn encode_fd(fd: i32, wrap_at: i32) -> i32
    var buf: [4096]u8
    var outbuf: [8192]u8
    var out_len: i64 = 0
    var col: i32 = 0

    # Leftover bytes from previous read
    var leftover: [2]u8
    var leftover_count: i32 = 0

    loop
        let n: i64 = sys_read(fd, &buf[0], 4096)
        if n < 0
            return 1
        if n == 0
            break

        var i: i64 = 0

        # First, handle any leftover bytes from previous chunk
        if leftover_count > 0
            # Fill up to 3 bytes
            while leftover_count < 3 && i < n
                leftover[leftover_count] = buf[i]
                leftover_count += 1
                i += 1

            if leftover_count == 3
                # Encode the 3 bytes
                let b0: i32 = leftover[0] as i32
                let b1: i32 = leftover[1] as i32
                let b2: i32 = leftover[2] as i32

                outbuf[out_len] = b64_encode_char(b0 / 4)
                out_len += 1
                outbuf[out_len] = b64_encode_char(((b0 % 4) * 16) + (b1 / 16))
                out_len += 1
                outbuf[out_len] = b64_encode_char(((b1 % 16) * 4) + (b2 / 64))
                out_len += 1
                outbuf[out_len] = b64_encode_char(b2 % 64)
                out_len += 1

                col += 4
                if wrap_at > 0 && col >= wrap_at
                    outbuf[out_len] = 10
                    out_len += 1
                    col = 0

                leftover_count = 0

        # Process remaining bytes in groups of 3
        while i + 2 < n
            let b0: i32 = buf[i] as i32
            let b1: i32 = buf[i + 1] as i32
            let b2: i32 = buf[i + 2] as i32

            outbuf[out_len] = b64_encode_char(b0 / 4)
            out_len += 1
            outbuf[out_len] = b64_encode_char(((b0 % 4) * 16) + (b1 / 16))
            out_len += 1
            outbuf[out_len] = b64_encode_char(((b1 % 16) * 4) + (b2 / 64))
            out_len += 1
            outbuf[out_len] = b64_encode_char(b2 % 64)
            out_len += 1

            col += 4
            if wrap_at > 0 && col >= wrap_at
                outbuf[out_len] = 10
                out_len += 1
                col = 0

            i += 3

            # Flush if buffer getting full
            if out_len >= 8000
                sys_write(STDOUT, &outbuf[0], out_len)
                out_len = 0

        # Save leftover bytes
        leftover_count = 0
        while i < n
            leftover[leftover_count] = buf[i]
            leftover_count += 1
            i += 1

    # Handle final leftover bytes with padding
    if leftover_count == 1
        let b0: i32 = leftover[0] as i32
        outbuf[out_len] = b64_encode_char(b0 / 4)
        out_len += 1
        outbuf[out_len] = b64_encode_char((b0 % 4) * 16)
        out_len += 1
        outbuf[out_len] = 61  # =
        out_len += 1
        outbuf[out_len] = 61  # =
        out_len += 1
    else if leftover_count == 2
        let b0: i32 = leftover[0] as i32
        let b1: i32 = leftover[1] as i32
        outbuf[out_len] = b64_encode_char(b0 / 4)
        out_len += 1
        outbuf[out_len] = b64_encode_char(((b0 % 4) * 16) + (b1 / 16))
        out_len += 1
        outbuf[out_len] = b64_encode_char((b1 % 16) * 4)
        out_len += 1
        outbuf[out_len] = 61  # =
        out_len += 1

    # Final newline
    if out_len > 0
        outbuf[out_len] = 10
        out_len += 1
        sys_write(STDOUT, &outbuf[0], out_len)

    return 0

# ============================================================================
# Decoding
# ============================================================================

fn decode_fd(fd: i32) -> i32
    var buf: [4096]u8
    var outbuf: [4096]u8
    var out_len: i64 = 0

    # Accumulate 4 base64 chars
    var accum: [4]i32
    var accum_count: i32 = 0

    loop
        let n: i64 = sys_read(fd, &buf[0], 4096)
        if n < 0
            return 1
        if n == 0
            break

        var i: i64 = 0
        while i < n
            let c: u8 = buf[i]
            let val: i32 = b64_decode_char(c)

            if val == -2
                # Skip whitespace
                i += 1
                continue

            accum[accum_count] = val
            accum_count += 1

            if accum_count == 4
                # Decode 4 chars to 3 bytes (or less with padding)
                let v0: i32 = accum[0]
                let v1: i32 = accum[1]
                let v2: i32 = accum[2]
                let v3: i32 = accum[3]

                # First byte always present
                outbuf[out_len] = ((v0 * 4) + (v1 / 16)) as u8
                out_len += 1

                # Second byte if v2 is not padding
                if v2 != -1
                    outbuf[out_len] = (((v1 % 16) * 16) + (v2 / 4)) as u8
                    out_len += 1

                # Third byte if v3 is not padding
                if v3 != -1
                    outbuf[out_len] = (((v2 % 4) * 64) + v3) as u8
                    out_len += 1

                accum_count = 0

                # Flush if buffer getting full
                if out_len >= 4000
                    sys_write(STDOUT, &outbuf[0], out_len)
                    out_len = 0

            i += 1

    # Flush remaining
    if out_len > 0
        sys_write(STDOUT, &outbuf[0], out_len)

    return 0

# ============================================================================
# Main
# ============================================================================

fn main(argc: i32, argv: **u8) -> i32
    # Set up argument parser
    var parser: ArgParser
    args_init(&parser, "base64", "Encode or decode base64")

    # Define options
    args_flag(&parser, 'd' as u8, "decode", "Decode data")
    args_option(&parser, 'w' as u8, "wrap", "N", "Wrap encoded lines after N characters (0 = no wrap)", "76")

    # Define positional argument (optional file)
    args_positional(&parser, "FILE", "Input file (default: stdin)", 0, 1)

    # Parse arguments
    if args_parse(&parser, argc, argv) != 0
        return 1

    # Get option values
    let decode: i32 = args_get_flag(&parser, 'd' as u8)
    let wrap_at: i32 = args_get_int(&parser, 'w' as u8) as i32

    # Open input file or use stdin
    var fd: i32 = STDIN
    if parser.positional_count > 0
        let input_file: *u8 = args_get_positional(&parser, 0)
        fd = sys_open(input_file, O_RDONLY)
        if fd < 0
            eprints("base64: cannot open file\n")
            return 1

    # Encode or decode
    var result: i32 = 0
    if decode != 0
        result = decode_fd(fd)
    else
        result = encode_fd(fd, wrap_at)

    # Close file if we opened one
    if parser.positional_count > 0
        sys_close(fd)

    return result
