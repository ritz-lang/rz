# Tests for Tier 1: Basic helper functions
# These unit tests verify helper functions work correctly
# Socket integration tests are done via shell scripts

import ritzlib.io


# ============================================================================
# Test SockAddrIn struct layout
# ============================================================================

struct SockAddrIn
    sin_family: u16
    sin_port: u16
    sin_addr: u32
    sin_zero: i64  # padding


@test
fn test_sockaddr_struct_size()
    # SockAddrIn should be 16 bytes total
    # 2 (family) + 2 (port) + 4 (addr) + 8 (zero) = 16
    var addr: SockAddrIn
    addr.sin_family = 2
    addr.sin_port = 0x901F  # 8080 in network byte order
    addr.sin_addr = 0
    addr.sin_zero = 0
    assert addr.sin_family == 2


@test
fn test_sockaddr_field_values()
    var addr = SockAddrIn {
        sin_family: 2,
        sin_port: 0x1F90,  # 8080 in little endian
        sin_addr: 0,
        sin_zero: 0
    }
    assert addr.sin_family == 2
    assert addr.sin_addr == 0


# ============================================================================
# Constants tests
# ============================================================================

const AF_INET: i32 = 2
const SOCK_STREAM: i32 = 1


@test
fn test_socket_constants()
    assert AF_INET == 2
    assert SOCK_STREAM == 1


fn main() -> i32
    return 0
