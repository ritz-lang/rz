# Ritz Language Grammar
# Combined lexer/parser specification for the Ritz language
#
# Syntax:
#   %tokens      - Begin token definitions section
#   %skip        - Patterns to skip (whitespace, etc.)
#   %grammar     - Begin grammar rules section (future)
#
# Token definition syntax:
#   NAME = "literal"           # Exact string match
#   NAME = /pattern/           # Regex pattern
#   NAME = /pattern/ priority  # With explicit priority (higher wins)
#
# Patterns use a simplified regex:
#   [abc]    - Character class
#   [a-z]    - Character range
#   [^abc]   - Negated class
#   *        - Zero or more
#   +        - One or more
#   ?        - Optional
#   |        - Alternation
#   ()       - Grouping
#   \n \t \r \\ \" \' - Escapes

%tokens

# =============================================================================
# Keywords (sorted by length for efficient matching)
# =============================================================================

# 2-character keywords
FN          = "fn"
IF          = "if"
AS          = "as"
IN          = "in"

# 3-character keywords
LET         = "let"
VAR         = "var"
FOR         = "for"

# 4-character keywords
ELSE        = "else"
TRUE        = "true"
ENUM        = "enum"
TYPE        = "type"
IMPL        = "impl"

# 5-character keywords
WHILE       = "while"
CONST       = "const"
BREAK       = "break"
MATCH       = "match"
FALSE       = "false"
TRAIT       = "trait"

# 6-character keywords
RETURN      = "return"
STRUCT      = "struct"
IMPORT      = "import"
EXTERN      = "extern"
UNSAFE      = "unsafe"
ASSERT      = "assert"

# 8-character keywords
CONTINUE    = "continue"

# =============================================================================
# Type keywords
# =============================================================================

I8          = "i8"
I16         = "i16"
I32         = "i32"
I64         = "i64"
U8          = "u8"
U16         = "u16"
U32         = "u32"
U64         = "u64"
BOOL        = "bool"

# =============================================================================
# Multi-character operators (order matters - longer first)
# =============================================================================

ARROW       = "->"
FAT_ARROW   = "=>"
DOT_DOT     = ".."
COLON_COLON = "::"
AND         = "&&"
OR          = "||"
EQ          = "=="
NE          = "!="
LE          = "<="
GE          = ">="
SHL         = "<<"
SHR         = ">>"
PLUS_EQ     = "+="
MINUS_EQ    = "-="
STAR_EQ     = "*="
SLASH_EQ    = "/="

# =============================================================================
# Single-character operators
# =============================================================================

PLUS        = "+"
MINUS       = "-"
STAR        = "*"
SLASH       = "/"
PERCENT     = "%"
AMP         = "&"
PIPE        = "|"
CARET       = "^"
TILDE       = "~"
BANG        = "!"
LT          = "<"
GT          = ">"
ASSIGN      = "="
DOT         = "."
QUESTION    = "?"
AT          = "@"

# =============================================================================
# Delimiters
# =============================================================================

LPAREN      = "("
RPAREN      = ")"
LBRACKET    = "["
RBRACKET    = "]"
LBRACE      = "{"
RBRACE      = "}"
COMMA       = ","
COLON       = ":"
SEMI        = ";"

# =============================================================================
# Patterns (regex-like)
# =============================================================================

# Identifiers: start with letter or underscore, followed by alphanumerics
IDENT       = /[a-zA-Z_][a-zA-Z0-9_]*/

# Numbers: decimal integers (TODO: hex, binary, floats)
NUMBER      = /[0-9]+/

# Strings: double-quoted with escape sequences
STRING      = /"([^"\\]|\\.)*"/

# Characters: single-quoted
CHAR        = /'([^'\\]|\\.)'/

# =============================================================================
# Whitespace and comments (to skip or handle specially)
# =============================================================================

%skip
WHITESPACE  = /[ \t\r]+/

%tokens
COMMENT     = /#[^\n]*/
NEWLINE     = /\n/

# =============================================================================
# Special tokens
# =============================================================================

# These are synthesized by the lexer, not matched from input
# INDENT      - Increase in indentation level
# DEDENT      - Decrease in indentation level
# EOF         - End of file
# ERROR       - Invalid token

# =============================================================================
# Grammar rules
# =============================================================================

%grammar

module
    : item*
    ;

item
    : fn_def
    | struct_def
    | const_def
    | import_stmt
    | type_alias
    | trait_def
    | impl_block
    ;

fn_def
    : FN IDENT LPAREN params? RPAREN return_type? block
    ;

params
    : param COMMA params
    | param
    ;

param
    : IDENT COLON type
    ;

return_type
    : ARROW type
    ;

struct_def
    : STRUCT IDENT INDENT struct_fields DEDENT
    ;

struct_fields
    : struct_field*
    ;

struct_field
    : IDENT COLON type NEWLINE
    ;

const_def
    : CONST IDENT COLON type ASSIGN expr NEWLINE
    ;

import_stmt
    : IMPORT module_path NEWLINE
    ;

module_path
    : IDENT DOT module_path
    | IDENT
    ;

type_alias
    : TYPE IDENT ASSIGN type NEWLINE
    ;

trait_def
    : TRAIT IDENT INDENT trait_methods DEDENT
    ;

trait_methods
    : trait_method*
    ;

trait_method
    : FN IDENT LPAREN params? RPAREN return_type? NEWLINE
    ;

impl_block
    : IMPL type INDENT impl_methods DEDENT
    ;

impl_methods
    : fn_def*
    ;

type
    : primitive_type
    | IDENT
    | STAR type
    | LBRACKET NUMBER RBRACKET type
    | LBRACKET RBRACKET type
    ;

primitive_type
    : I8 | I16 | I32 | I64
    | U8 | U16 | U32 | U64
    | BOOL
    ;

block
    : INDENT stmts DEDENT
    ;

stmts
    : stmt*
    ;

stmt
    : let_stmt
    | var_stmt
    | return_stmt
    | if_stmt
    | while_stmt
    | for_stmt
    | expr NEWLINE
    ;

let_stmt
    : LET IDENT COLON type ASSIGN expr NEWLINE
    ;

var_stmt
    : VAR IDENT COLON type ASSIGN expr NEWLINE
    ;

return_stmt
    : RETURN expr? NEWLINE
    ;

if_stmt
    : IF expr block else_clause?
    ;

else_clause
    : ELSE block
    | ELSE if_stmt
    ;

while_stmt
    : WHILE expr block
    ;

for_stmt
    : FOR IDENT IN expr block
    ;

expr
    : or_expr
    ;

or_expr
    : and_expr OR or_expr
    | and_expr
    ;

and_expr
    : cmp_expr AND and_expr
    | cmp_expr
    ;

cmp_expr
    : add_expr cmp_op add_expr
    | add_expr
    ;

cmp_op
    : EQ | NE | LT | LE | GT | GE
    ;

add_expr
    : mul_expr add_op add_expr
    | mul_expr
    ;

add_op
    : PLUS | MINUS
    ;

mul_expr
    : unary_expr mul_op mul_expr
    | unary_expr
    ;

mul_op
    : STAR | SLASH | PERCENT
    ;

unary_expr
    : MINUS unary_expr
    | BANG unary_expr
    | AMP unary_expr
    | STAR unary_expr
    | postfix_expr
    ;

postfix_expr
    : primary_expr postfix_op*
    ;

postfix_op
    : LPAREN args? RPAREN
    | LBRACKET expr RBRACKET
    | DOT IDENT
    | AS type
    ;

args
    : expr COMMA args
    | expr
    ;

primary_expr
    : NUMBER
    | STRING
    | CHAR
    | TRUE
    | FALSE
    | IDENT
    | LPAREN expr RPAREN
    ;
