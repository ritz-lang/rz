# Level 3, Test 11: Real nested struct
# Test struct containing another struct

struct Point
    x: i32
    y: i32

struct Rect
    origin: Point
    size: Point

fn main() -> i32
    var r: Rect
    r.origin.x = 10
    r.origin.y = 20
    r.size.x = 30
    r.size.y = 40
    r.origin.x + r.origin.y + r.size.x + r.size.y - 100  # Should be 0
