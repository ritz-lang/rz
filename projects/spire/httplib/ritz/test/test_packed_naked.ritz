# Tests for [[packed]] and [[naked]] attributes
# These are kernel development features for low-level control

import ritzlib.sys

# ============================================================================
# [[packed]] struct tests
# ============================================================================

# Regular struct has alignment padding
struct NormalStruct
    a: u8    # offset 0, size 1
    b: u64   # offset 8 (aligned), size 8
    c: u8    # offset 16, size 1
# Total size with padding: 24 bytes (or similar, depends on tail padding)

# Packed struct has NO alignment padding
[[packed]]
struct PackedStruct
    a: u8    # offset 0, size 1
    b: u64   # offset 1, size 8
    c: u8    # offset 9, size 1
# Total size: exactly 10 bytes

[[test]]
fn test_packed_struct_size() -> i32
    # The packed struct should be exactly 10 bytes
    # u8 (1) + u64 (8) + u8 (1) = 10
    let packed_size: u64 = sizeof(PackedStruct)
    assert packed_size == 10, "PackedStruct should be 10 bytes"
    0

[[test]]
fn test_normal_struct_has_padding() -> i32
    # The normal struct should be larger than 10 bytes due to alignment
    # Typically: 1 + 7(pad) + 8 + 1 + 7(tail pad) = 24
    let normal_size: u64 = sizeof(NormalStruct)
    assert normal_size > 10, "NormalStruct should have padding"
    0

[[test]]
fn test_packed_struct_field_access() -> i32
    # Ensure we can read/write packed struct fields correctly
    var p: PackedStruct
    p.a = 0x11
    p.b = 0x2222222222222222
    p.c = 0x33

    assert p.a == 0x11
    assert p.b == 0x2222222222222222
    assert p.c == 0x33
    0

# ============================================================================
# [[naked]] function tests
# ============================================================================

# A naked function has no compiler-generated prologue/epilogue
# It must use inline assembly to manage its own stack frame
#
# NOTE: Naked functions in LLVM cannot reference their parameters through
# LLVM IR - they must access arguments directly via calling convention
# registers in the inline assembly. Parameters are declared but not used
# in the function body.
#
# x86_64 System V ABI calling convention:
#   Arguments: rdi, rsi, rdx, rcx, r8, r9 (integers)
#   Return:    rax
[[naked]]
fn naked_return_42() -> i32
    # In x86_64, return value goes in rax
    # Naked functions skip prologue/epilogue so we must return ourselves
    asm x86_64:
        movl $$42, %eax
        retq

[[test]]
fn test_naked_function() -> i32
    let result: i32 = naked_return_42()
    assert result == 42, "naked function should return 42"
    0

# A slightly more complex naked function
# Args come in via calling convention: a in edi, b in esi
[[naked]]
fn naked_add(a: i32, b: i32) -> i32
    # x86_64 calling convention: first i32 arg in edi, second in esi
    # We don't reference 'a' or 'b' - we access registers directly
    asm x86_64:
        movl %edi, %eax
        addl %esi, %eax
        retq

[[test]]
fn test_naked_add() -> i32
    let result: i32 = naked_add(10, 32)
    assert result == 42, "naked_add(10, 32) should be 42"
    0

# Test naked function that preserves registers
[[naked]]
fn naked_identity(x: i64) -> i64
    # Just return the argument (which is already in rdi)
    asm x86_64:
        movq %rdi, %rax
        retq

[[test]]
fn test_naked_identity() -> i32
    let result: i64 = naked_identity(12345)
    assert result == 12345
    0
