# Tests for inline assembly blocks
#
# Note: x86_64 asm uses AT&T syntax (default for LLVM/GCC)
# - Source, destination order: mov src, dest
# - Register prefix: %rax
# - Immediate prefix: $42
# - Operand references: {name} becomes AT&T format

# Test basic asm block with no operands
[[test]]
fn test_asm_nop() -> i32
    asm x86_64:
        nop
        nop
        nop
    0

# Test asm preserves execution flow
[[test]]
fn test_asm_execution_flow() -> i32
    var before: i32 = 1
    asm x86_64:
        nop
    var after: i32 = 2
    if before == 1 && after == 2
        0
    else
        1

# Test function with asm can be called
fn helper_with_asm(x: i64) -> i64
    asm x86_64:
        nop
    return x + 1

[[test]]
fn test_asm_in_function() -> i32
    let result = helper_with_asm(41)
    if result == 42
        0
    else
        1

# Test asm with memory fence
[[test]]
fn test_asm_mfence() -> i32
    asm x86_64:
        mfence
    0

# Test asm with register clobbers (AT&T syntax uses % prefix)
[[test]]
fn test_asm_with_registers() -> i32
    asm x86_64:
        xorl %eax, %eax
        xorl %ebx, %ebx
    0

# Test asm with operand input (AT&T syntax: movq src, %dest)
[[test]]
fn test_asm_input() -> i32
    let value: i64 = 42
    asm x86_64:
        movq {value}, %rax
    0
