# Test Level 1: Basic assert with literal expressions
#
# Features tested:
# - @test attribute
# - assert statement
# - Integer literals
# - Comparison operators (==, !=, <, >, <=, >=)
# - Arithmetic operators (+, -, *, /)
# - Boolean operators (&&, ||)

[[test]]
fn test_equality() -> i32
  assert 1 == 1
  assert 42 == 42
  assert 0 == 0
  0

[[test]]
fn test_inequality() -> i32
  assert 1 != 2
  assert 0 != 1
  assert 100 != 99
  0

[[test]]
fn test_less_than() -> i32
  assert 1 < 2
  assert 0 < 1
  assert 99 < 100
  0

[[test]]
fn test_greater_than() -> i32
  assert 2 > 1
  assert 1 > 0
  assert 100 > 99
  0

[[test]]
fn test_less_equal() -> i32
  assert 1 <= 1
  assert 1 <= 2
  assert 0 <= 0
  0

[[test]]
fn test_greater_equal() -> i32
  assert 1 >= 1
  assert 2 >= 1
  assert 1 >= 0
  0

[[test]]
fn test_l1_addition() -> i32
  assert 1 + 1 == 2
  assert 0 + 0 == 0
  assert 10 + 20 == 30
  0

[[test]]
fn test_subtraction() -> i32
  assert 2 - 1 == 1
  assert 10 - 5 == 5
  assert 100 - 100 == 0
  0

[[test]]
fn test_multiplication() -> i32
  assert 2 * 3 == 6
  assert 10 * 10 == 100
  assert 1 * 0 == 0
  0

[[test]]
fn test_division() -> i32
  assert 6 / 2 == 3
  assert 10 / 5 == 2
  assert 100 / 10 == 10
  0

[[test]]
fn test_combined_arithmetic() -> i32
  assert 2 + 3 * 4 == 14
  assert 10 - 2 * 3 == 4
  0

[[test]]
fn test_parentheses() -> i32
  assert (2 + 3) * 4 == 20
  assert (10 - 2) * 3 == 24
  0
