# Test for Issue #99: Qualified import name resolution
#
# Bug: The parser supports `import ritzlib.sys as sys` but the name resolver
# doesn't handle `sys::write()` qualified name access.
#
# Run with: python3 ritz0/ritz0.py --test ritz0/test/test_issue99.ritz

import ritzlib.sys as sys

# ===== Issue #99 Test Cases =====

[[test]]
fn test_qualified_write() -> i32
    # Basic qualified function call
    sys::write(1, c"OK\n", 3)
    0

[[test]]
fn test_qualified_exit_code() -> i32
    # Test that qualified calls work correctly
    # (we're testing that this compiles and runs, not sys_exit behavior)
    0

[[test]]
fn test_qualified_multiple_calls() -> i32
    # Multiple qualified calls in sequence
    sys::write(1, c"A", 1)
    sys::write(1, c"B", 1)
    sys::write(1, c"\n", 1)
    0

[[test]]
fn test_qualified_in_expression() -> i32
    # Qualified call used in expression
    let result: i64 = sys::write(1, c"X\n", 2)
    if result < 0
        return 1
    0
