# Test level 34: Generic Enums (Option<T>)
#
# Tests for Option<T> and basic enum functionality

# ============================================================================
# Enum definitions
# ============================================================================

enum Option<T>
    Some(T)
    None

# Simple non-generic enum
enum Color
    Red
    Green
    Blue

# ============================================================================
# Test: Enum type exists and has correct size
# ============================================================================

[[test]]
fn test_option_type_exists() -> i32
    # Just declare a variable of the type - tests that enum compiles
    var opt: Option<i32>
    return 0

[[test]]
fn test_color_type_exists() -> i32
    var c: Color
    return 0

# ============================================================================
# Test: Variant construction
# ============================================================================

[[test]]
fn test_some_construction() -> i32
    # Construct Some(42)
    var opt: Option<i32> = Some(42)
    return 0

[[test]]
fn test_color_variant() -> i32
    # Construct Color::Red
    var c: Color = Red()
    return 0

[[test]]
fn test_none_construction() -> i32
    # Construct None - unit variant with call syntax
    var opt: Option<i32> = None()
    return 0

[[test]]
fn test_none_no_parens() -> i32
    # Construct None - unit variant without parentheses
    var opt: Option<i32> = None
    return 0

[[test]]
fn test_color_no_parens() -> i32
    # Construct Color::Blue without parentheses
    var c: Color = Blue
    return 0

# ============================================================================
# Test: Pattern matching
# ============================================================================

[[test]]
fn test_match_some() -> i32
    var opt: Option<i32> = Some(42)
    let result = match opt
        Some(x) => x
        None => 0
    # Result should be 42
    if result == 42
        return 0
    return 1

[[test]]
fn test_match_none() -> i32
    var opt: Option<i32> = None
    let result = match opt
        Some(x) => x
        None => 100
    # Result should be 100
    if result == 100
        return 0
    return 1

[[test]]
fn test_match_color() -> i32
    var c: Color = Green
    let result = match c
        Red => 1
        Green => 2
        Blue => 3
    # Result should be 2
    if result == 2
        return 0
    return 1

# Entry point for standalone testing
fn main() -> i32
    test_option_type_exists()
    test_color_type_exists()
    test_some_construction()
    test_color_variant()
    test_none_construction()
    test_none_no_parens()
    test_color_no_parens()
    test_match_some()
    test_match_none()
    test_match_color()
    return 0
