# Test the ? operator for Result types
import ritzlib.result

# Helper function that may fail
fn divide(a: i32, b: i32) -> Result<i32, i32>
    if b == 0
        return Err(1)  # Division by zero error
    return Ok(a / b)

# Test using ? operator - should propagate error
fn compute(a: i32, b: i32) -> Result<i32, i32>
    let x = divide(a, b)?
    return Ok(x + 10)

[[test]]
fn test_try_op_ok() -> i32
    var res: Result<i32, i32> = compute(20, 4)
    let val = result_unwrap_or<i32, i32>(&res, -1)
    # 20/4 + 10 = 15
    if val == 15
        return 0
    return 1

[[test]]
fn test_try_op_err() -> i32
    var res: Result<i32, i32> = compute(10, 0)
    # Should be Err(1)
    if result_is_err<i32, i32>(&res) == 1
        return 0
    return 1

# Test chaining multiple ? operators
fn compute_chain(a: i32, b: i32, c: i32) -> Result<i32, i32>
    let x = divide(a, b)?
    let y = divide(x, c)?
    return Ok(y * 2)

[[test]]
fn test_try_op_chain_ok() -> i32
    # 100/5 = 20, 20/2 = 10, 10*2 = 20
    var res: Result<i32, i32> = compute_chain(100, 5, 2)
    let val = result_unwrap_or<i32, i32>(&res, -1)
    if val == 20
        return 0
    return 1

[[test]]
fn test_try_op_chain_first_err() -> i32
    var res: Result<i32, i32> = compute_chain(10, 0, 2)  # First divide fails
    if result_is_err<i32, i32>(&res) == 1
        return 0
    return 1

[[test]]
fn test_try_op_chain_second_err() -> i32
    var res: Result<i32, i32> = compute_chain(10, 2, 0)  # Second divide fails
    if result_is_err<i32, i32>(&res) == 1
        return 0
    return 1

fn main() -> i32
    return 0
