# Level 17: For Loop Tests

# ============================================================================
# Test: Basic for loop - range iteration
# ============================================================================

[[test]]
fn test_for_basic_sum()
    # Sum 0..5 = 0+1+2+3+4 = 10
    var sum: i64 = 0
    for i in 0..5
        sum = sum + i
    assert sum == 10

[[test]]
fn test_for_with_break()
    # Break at j == 5, so count should be 6 (0,1,2,3,4,5)
    var count: i64 = 0
    for j in 0..100
        count = count + 1
        if j == 5
            break
    assert count == 6

[[test]]
fn test_for_with_continue()
    # Sum only even numbers: 0+2+4+6+8 = 20
    var even_sum: i64 = 0
    for k in 0..10
        if k % 2 != 0
            continue
        even_sum = even_sum + k
    assert even_sum == 20

[[test]]
fn test_for_nested()
    # 3 * 4 = 12 iterations
    var product: i64 = 0
    for a in 0..3
        for b in 0..4
            product = product + 1
    assert product == 12

[[test]]
fn test_for_empty_range()
    # Range 5..5 should not iterate
    var count: i64 = 0
    for i in 5..5
        count = count + 1
    assert count == 0

[[test]]
fn test_for_single_iteration()
    # Range 0..1 should iterate once
    var count: i64 = 0
    for i in 0..1
        count = count + 1
    assert count == 1

[[test]]
fn test_for_variable_bounds()
    # Use variables for bounds
    let start: i64 = 2
    let end: i64 = 5
    var sum: i64 = 0
    for i in start..end
        sum = sum + i  # 2 + 3 + 4 = 9
    assert sum == 9
