# test_level9.ritz - Arrays inside structs
#
# Tests for embedded array fields in struct types.
# This is essential for self-hosting: the lexer needs indent_stack: [64]i32

# =============================================================================
# Test: Struct with array field - basic
# =============================================================================

struct StackBuffer
  data: [16]i32
  len: i32

[[test]]
fn test_struct_array_field_init() -> i32
  var buf: StackBuffer = StackBuffer { data: [0; 16], len: 0 }
  assert buf.len == 0
  0

[[test]]
fn test_struct_array_field_write() -> i32
  var buf: StackBuffer = StackBuffer { data: [0; 16], len: 0 }
  buf.data[0] = 42
  buf.data[1] = 100
  buf.len = 2
  assert buf.data[0] == 42
  assert buf.data[1] == 100
  assert buf.len == 2
  0

[[test]]
fn test_struct_array_field_sum() -> i32
  var buf: StackBuffer = StackBuffer { data: [0; 16], len: 0 }
  buf.data[0] = 10
  buf.data[1] = 20
  buf.data[2] = 30
  buf.len = 3
  var sum: i32 = 0
  var i: i32 = 0
  while i < buf.len
    sum = sum + buf.data[i]
    i = i + 1
  assert sum == 60
  0

# =============================================================================
# Test: Pointer to struct with array field
# =============================================================================

fn init_buffer(b: *StackBuffer) -> i32
  b.data[0] = 1
  b.data[1] = 2
  b.data[2] = 3
  b.len = 3
  0

[[test]]
fn test_struct_array_via_ptr() -> i32
  var buf: StackBuffer = StackBuffer { data: [0; 16], len: 0 }
  init_buffer(&buf)
  assert buf.data[0] == 1
  assert buf.data[1] == 2
  assert buf.data[2] == 3
  assert buf.len == 3
  0

# =============================================================================
# Test: Struct with byte array (common for strings/buffers)
# =============================================================================

struct ByteBuffer
  bytes: [32]i8
  size: i32

[[test]]
fn test_struct_byte_array() -> i32
  var bb: ByteBuffer = ByteBuffer { bytes: [0; 32], size: 0 }
  bb.bytes[0] = 72  # 'H'
  bb.bytes[1] = 105 # 'i'
  bb.bytes[2] = 0   # null terminator
  bb.size = 2
  assert bb.bytes[0] == 72
  assert bb.bytes[1] == 105
  assert bb.size == 2
  0

# =============================================================================
# Test: Lexer-like indent stack
# =============================================================================

struct IndentLexer
  pos: i32
  indent_stack: [64]i32
  indent_depth: i32

[[test]]
fn test_indent_stack_struct() -> i32
  var lex: IndentLexer = IndentLexer { pos: 0, indent_stack: [0; 64], indent_depth: 1 }
  # Push indentation level 2
  lex.indent_stack[1] = 2
  lex.indent_depth = 2
  # Push indentation level 4
  lex.indent_stack[2] = 4
  lex.indent_depth = 3
  # Check stack
  assert lex.indent_stack[0] == 0
  assert lex.indent_stack[1] == 2
  assert lex.indent_stack[2] == 4
  assert lex.indent_depth == 3
  0

[[test]]
fn test_indent_stack_via_ptr() -> i32
  var lex: IndentLexer = IndentLexer { pos: 0, indent_stack: [0; 64], indent_depth: 1 }
  let p: *IndentLexer = &lex
  p.indent_stack[0] = 0
  p.indent_stack[1] = 2
  p.indent_depth = 2
  assert p.indent_stack[0] == 0
  assert p.indent_stack[1] == 2
  assert p.indent_depth == 2
  0

# =============================================================================
# Test: Multiple array fields
# =============================================================================

struct MultiArrays
  xs: [8]i32
  ys: [8]i32
  count: i32

[[test]]
fn test_multiple_array_fields() -> i32
  var m: MultiArrays = MultiArrays { xs: [0; 8], ys: [0; 8], count: 0 }
  m.xs[0] = 1
  m.ys[0] = 10
  m.xs[1] = 2
  m.ys[1] = 20
  m.count = 2
  assert m.xs[0] + m.ys[0] == 11
  assert m.xs[1] + m.ys[1] == 22
  0
