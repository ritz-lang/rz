# ritz1/ir/test_struct_ir.ritz - Test struct IR generation with layout
#
# Tests that we can generate correct LLVM IR for struct access using
# computed field offsets from struct_layout.ritz

import mem
import types
import ir_builder
import struct_layout

# =============================================================================
# Struct IR Generation
# =============================================================================

# Emit struct type definition with field layout
fn ir_emit_struct_type(b: *IRBuilder, name: *i8, layout: *StructLayout) -> i32
  ir_emit_struct_start(b, name)

  for i in 0..layout.field_count
    let field: *FieldLayout = layout.fields + i
    # For now, we need to know the field type - this is a TODO
    # For this test, we'll assume all fields are i32
    var is_first: i32 = 0
    if i == 0
      is_first = 1
    ir_emit_struct_field(b, TY_I32, is_first)

  ir_emit_struct_end(b)
  0

# Emit GEP to get field address
fn ir_emit_gep_field(b: *IRBuilder, result_id: i32, struct_name: *i8, base_ptr: i32, field_index: i32) -> i32
  ir_emit_gep_struct(b, result_id, struct_name, base_ptr, field_index)

# =============================================================================
# Tests
# =============================================================================

[[test]]
fn test_struct_type_emission()
  let arena_buf: *i8 = __builtin_alloca(8192) as *i8
  var arena: Arena = Arena { base: arena_buf, size: 8192, used: 0 }

  # Define struct Point { x: i32, y: i32 }
  var field_types: [2]i32 = [TY_I32, TY_I32]
  var field_layouts: [2]FieldLayout = [FieldLayout { offset: 0, size: 0, alignment: 0 }, FieldLayout { offset: 0, size: 0, alignment: 0 }]
  var layout: StructLayout = compute_struct_layout(&field_types[0], 2, &field_layouts[0])

  # Emit IR
  let b: *IRBuilder = ir_builder_new(&arena, 2048)
  ir_emit_struct_type(b, "Point", &layout)

  let output: *i8 = ir_builder_get_output(b)
  assert str_contains(output, "%Point = type { i32, i32 }") == 1, "should emit Point struct type"

[[test]]
fn test_struct_gep_emission()
  let arena_buf: *i8 = __builtin_alloca(8192) as *i8
  var arena: Arena = Arena { base: arena_buf, size: 8192, used: 0 }

  let b: *IRBuilder = ir_builder_new(&arena, 2048)
  b.indent = 1

  # Emit: %2 = getelementptr %Point, ptr %1, i32 0, i32 0  (access field 0)
  ir_emit_gep_field(b, 2, "Point", 1, 0)

  # Emit: %3 = getelementptr %Point, ptr %1, i32 0, i32 1  (access field 1)
  ir_emit_gep_field(b, 3, "Point", 1, 1)

  let output: *i8 = ir_builder_get_output(b)
  assert str_contains(output, "getelementptr %Point, ptr %1, i32 0, i32 0") == 1, "should emit GEP for field 0"
  assert str_contains(output, "getelementptr %Point, ptr %1, i32 0, i32 1") == 1, "should emit GEP for field 1"

[[test]]
fn test_struct_with_padding_layout()
  let arena_buf: *i8 = __builtin_alloca(8192) as *i8
  var arena: Arena = Arena { base: arena_buf, size: 8192, used: 0 }

  # struct Mixed { a: i8, b: i32, c: i8 }
  # Expected layout: offset 0, 4, 8 (with padding)
  var field_types: [3]i32 = [TY_I8, TY_I32, TY_I8]
  var field_layouts: [3]FieldLayout = [FieldLayout { offset: 0, size: 0, alignment: 0 }, FieldLayout { offset: 0, size: 0, alignment: 0 }, FieldLayout { offset: 0, size: 0, alignment: 0 }]
  var layout: StructLayout = compute_struct_layout(&field_types[0], 3, &field_layouts[0])

  # Verify offsets match LLVM's expectations
  assert field_layouts[0].offset == 0, "field a at offset 0"
  assert field_layouts[1].offset == 4, "field b at offset 4 (3 bytes padding)"
  assert field_layouts[2].offset == 8, "field c at offset 8"

  # Key insight: field INDEX != field OFFSET
  # GEP uses field index (0, 1, 2) not byte offsets
  # LLVM computes the byte offsets internally based on struct type definition

[[test]]
fn test_complete_struct_example()
  let arena_buf: *i8 = __builtin_alloca(16384) as *i8
  var arena: Arena = Arena { base: arena_buf, size: 16384, used: 0 }

  # Define TimeSpec struct from 10_sleep example
  # struct TimeSpec { tv_sec: i64, tv_nsec: i64 }
  var field_types: [2]i32 = [TY_I64, TY_I64]
  var field_layouts: [2]FieldLayout = [FieldLayout { offset: 0, size: 0, alignment: 0 }, FieldLayout { offset: 0, size: 0, alignment: 0 }]
  var layout: StructLayout = compute_struct_layout(&field_types[0], 2, &field_layouts[0])

  assert layout.total_size == 16, "TimeSpec should be 16 bytes"
  assert layout.alignment == 8, "TimeSpec should align to 8 bytes"
  assert field_layouts[0].offset == 0, "tv_sec at offset 0"
  assert field_layouts[1].offset == 8, "tv_nsec at offset 8"

# Helper from test_ir_builder.ritz
fn str_contains(haystack: *i8, needle: *i8) -> i32
  var h: i32 = 0
  while *(haystack + h) != 0
    var n: i32 = 0
    var matched: i32 = 1
    while *(needle + n) != 0
      let ch: i32 = *(haystack + h + n) as i32 & 255
      let cn: i32 = *(needle + n) as i32 & 255
      if ch != cn
        matched = 0
      n = n + 1
    if matched == 1
      return 1
    h = h + 1
  0
