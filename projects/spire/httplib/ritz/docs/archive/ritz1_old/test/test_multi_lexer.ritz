# ritz1 Multi-Pattern Lexer Tests
#
# Tests for the NFA-based multi-pattern lexer.
# Run with: python ritz0/ritz0.py --lib ritz1/src/utf8.ritz ritz1/src/nfa.ritz ritz1/src/regex.ritz ritz1/src/tokens.ritz ritz1/src/lexer.ritz --test ritz1/test/test_multi_lexer.ritz

# Note: Storage must be allocated in the test function itself, not in helpers,
# because __builtin_alloca memory is freed when the allocating function returns.

# Test: Single pattern matching integers
@test
fn test_lexer_single_pattern() -> i32
  # Allocate storage in test function (alloca is only valid within this function)
  let storage: *i8 = __builtin_alloca(16384)
  let states: *NFAState = storage
  let trans: *Transition = storage + 3072
  let patterns: *TokenPattern = storage + 13312

  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  let src: *i8 = "42"
  var lex: Lexer = Lexer { src: src, len: 2, pos: 0, line: 1, col: 1, nfa: &nfa, patterns: patterns, pattern_count: 0 , indent_stack: [0; 64], indent_depth: 1, at_line_start: 1, pending_dedents: 0, bracket_depth: 0 }
  lexer_init(&lex, src, 2, &nfa, patterns)

  # Add integer pattern: [0-9]+
  lexer_add_pattern(&lex, "[0-9]+", 6, TOK_INT, 0)
  lexer_finalize(&lex)

  let tok: Token = lexer_next(&lex)
  assert tok.type == TOK_INT
  assert tok.start == 0
  assert tok.len == 2
  0

# Test: Multiple patterns - keyword vs identifier
@test
fn test_lexer_keyword_priority() -> i32
  let storage: *i8 = __builtin_alloca(16384)
  let states: *NFAState = storage
  let trans: *Transition = storage + 3072
  let patterns: *TokenPattern = storage + 13312

  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  let src: *i8 = "fn"
  var lex: Lexer = Lexer { src: src, len: 2, pos: 0, line: 1, col: 1, nfa: &nfa, patterns: patterns, pattern_count: 0 , indent_stack: [0; 64], indent_depth: 1, at_line_start: 1, pending_dedents: 0, bracket_depth: 0 }
  lexer_init(&lex, src, 2, &nfa, patterns)

  # Add keyword first (higher priority)
  lexer_add_pattern(&lex, "\"fn\"", 4, TOK_FN, 1)
  # Add identifier pattern
  lexer_add_pattern(&lex, "[a-z]+", 6, TOK_IDENT, 0)
  lexer_finalize(&lex)

  let tok: Token = lexer_next(&lex)
  assert tok.type == TOK_FN  # Should match keyword, not identifier
  assert tok.len == 2
  0

# Test: Longest match wins
@test
fn test_lexer_longest_match() -> i32
  let storage: *i8 = __builtin_alloca(16384)
  let states: *NFAState = storage
  let trans: *Transition = storage + 3072
  let patterns: *TokenPattern = storage + 13312

  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  let src: *i8 = "foobar"
  var lex: Lexer = Lexer { src: src, len: 6, pos: 0, line: 1, col: 1, nfa: &nfa, patterns: patterns, pattern_count: 0 , indent_stack: [0; 64], indent_depth: 1, at_line_start: 1, pending_dedents: 0, bracket_depth: 0 }
  lexer_init(&lex, src, 6, &nfa, patterns)

  # Add "foo" literal
  lexer_add_pattern(&lex, "\"foo\"", 5, TOK_FN, 1)  # Using TOK_FN as placeholder
  # Add identifier pattern (will match longer)
  lexer_add_pattern(&lex, "[a-z]+", 6, TOK_IDENT, 0)
  lexer_finalize(&lex)

  let tok: Token = lexer_next(&lex)
  assert tok.type == TOK_IDENT  # Longest match wins
  assert tok.len == 6
  0

# Test: Multiple tokens in sequence
@test
fn test_lexer_sequence() -> i32
  let storage: *i8 = __builtin_alloca(16384)
  let states: *NFAState = storage
  let trans: *Transition = storage + 3072
  let patterns: *TokenPattern = storage + 13312

  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  let src: *i8 = "123abc"
  var lex: Lexer = Lexer { src: src, len: 6, pos: 0, line: 1, col: 1, nfa: &nfa, patterns: patterns, pattern_count: 0 , indent_stack: [0; 64], indent_depth: 1, at_line_start: 1, pending_dedents: 0, bracket_depth: 0 }
  lexer_init(&lex, src, 6, &nfa, patterns)

  lexer_add_pattern(&lex, "[0-9]+", 6, TOK_INT, 0)
  lexer_add_pattern(&lex, "[a-z]+", 6, TOK_IDENT, 0)
  lexer_finalize(&lex)

  let tok1: Token = lexer_next(&lex)
  assert tok1.type == TOK_INT
  assert tok1.len == 3

  let tok2: Token = lexer_next(&lex)
  assert tok2.type == TOK_IDENT
  assert tok2.len == 3
  0

# Test: EOF handling
@test
fn test_lexer_eof() -> i32
  let storage: *i8 = __builtin_alloca(16384)
  let states: *NFAState = storage
  let trans: *Transition = storage + 3072
  let patterns: *TokenPattern = storage + 13312

  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  let src: *i8 = ""
  var lex: Lexer = Lexer { src: src, len: 0, pos: 0, line: 1, col: 1, nfa: &nfa, patterns: patterns, pattern_count: 0 , indent_stack: [0; 64], indent_depth: 1, at_line_start: 1, pending_dedents: 0, bracket_depth: 0 }
  lexer_init(&lex, src, 0, &nfa, patterns)

  lexer_add_pattern(&lex, "[a-z]+", 6, TOK_IDENT, 0)
  lexer_finalize(&lex)

  let tok: Token = lexer_next(&lex)
  assert tok.type == TOK_EOF
  0

# Test: Operators (single char)
@test
fn test_lexer_operators() -> i32
  let storage: *i8 = __builtin_alloca(16384)
  let states: *NFAState = storage
  let trans: *Transition = storage + 3072
  let patterns: *TokenPattern = storage + 13312

  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  let src: *i8 = "+-*"
  var lex: Lexer = Lexer { src: src, len: 3, pos: 0, line: 1, col: 1, nfa: &nfa, patterns: patterns, pattern_count: 0 , indent_stack: [0; 64], indent_depth: 1, at_line_start: 1, pending_dedents: 0, bracket_depth: 0 }
  lexer_init(&lex, src, 3, &nfa, patterns)

  lexer_add_pattern(&lex, "\"+\"", 3, TOK_PLUS, 1)
  lexer_add_pattern(&lex, "\"-\"", 3, TOK_MINUS, 1)
  lexer_add_pattern(&lex, "\"*\"", 3, TOK_STAR, 1)
  lexer_finalize(&lex)

  let t1: Token = lexer_next(&lex)
  assert t1.type == TOK_PLUS

  let t2: Token = lexer_next(&lex)
  assert t2.type == TOK_MINUS

  let t3: Token = lexer_next(&lex)
  assert t3.type == TOK_STAR
  0

# Test: Multi-char operators
@test
fn test_lexer_multi_char_ops() -> i32
  let storage: *i8 = __builtin_alloca(16384)
  let states: *NFAState = storage
  let trans: *Transition = storage + 3072
  let patterns: *TokenPattern = storage + 13312

  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  let src: *i8 = "->=="
  var lex: Lexer = Lexer { src: src, len: 4, pos: 0, line: 1, col: 1, nfa: &nfa, patterns: patterns, pattern_count: 0 , indent_stack: [0; 64], indent_depth: 1, at_line_start: 1, pending_dedents: 0, bracket_depth: 0 }
  lexer_init(&lex, src, 4, &nfa, patterns)

  # Multi-char ops first (higher priority)
  lexer_add_pattern(&lex, "\"->\"", 4, TOK_ARROW, 1)
  lexer_add_pattern(&lex, "\"==\"", 4, TOK_EQEQ, 1)
  # Single char fallbacks
  lexer_add_pattern(&lex, "\"-\"", 3, TOK_MINUS, 1)
  lexer_add_pattern(&lex, "\">\"", 3, TOK_GT, 1)
  lexer_add_pattern(&lex, "\"=\"", 3, TOK_EQ, 1)
  lexer_finalize(&lex)

  let t1: Token = lexer_next(&lex)
  assert t1.type == TOK_ARROW
  assert t1.len == 2

  let t2: Token = lexer_next(&lex)
  assert t2.type == TOK_EQEQ
  assert t2.len == 2
  0

# Test: Identifier with underscore
@test
fn test_lexer_ident_underscore() -> i32
  let storage: *i8 = __builtin_alloca(16384)
  let states: *NFAState = storage
  let trans: *Transition = storage + 3072
  let patterns: *TokenPattern = storage + 13312

  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  let src: *i8 = "foo_bar"
  var lex: Lexer = Lexer { src: src, len: 7, pos: 0, line: 1, col: 1, nfa: &nfa, patterns: patterns, pattern_count: 0 , indent_stack: [0; 64], indent_depth: 1, at_line_start: 1, pending_dedents: 0, bracket_depth: 0 }
  lexer_init(&lex, src, 7, &nfa, patterns)

  lexer_add_pattern(&lex, "[a-z_][a-z0-9_]*", 16, TOK_IDENT, 0)
  lexer_finalize(&lex)

  let tok: Token = lexer_next(&lex)
  assert tok.type == TOK_IDENT
  assert tok.len == 7
  0

# Test: Error token for unrecognized char
@test
fn test_lexer_error() -> i32
  let storage: *i8 = __builtin_alloca(16384)
  let states: *NFAState = storage
  let trans: *Transition = storage + 3072
  let patterns: *TokenPattern = storage + 13312

  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  let src: *i8 = "@"
  var lex: Lexer = Lexer { src: src, len: 1, pos: 0, line: 1, col: 1, nfa: &nfa, patterns: patterns, pattern_count: 0 , indent_stack: [0; 64], indent_depth: 1, at_line_start: 1, pending_dedents: 0, bracket_depth: 0 }
  lexer_init(&lex, src, 1, &nfa, patterns)

  lexer_add_pattern(&lex, "[a-z]+", 6, TOK_IDENT, 0)
  lexer_finalize(&lex)

  let tok: Token = lexer_next(&lex)
  assert tok.type == TOK_ERROR
  assert tok.len == 1
  0
