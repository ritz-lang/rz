# ritz1/test/test_parser_functions.ritz - Parser function tests
#
# Tests for the parser infrastructure and basic functionality.
# Due to Ritz language limitations with struct pointer field assignments,
# these tests focus on verifying that parser structures and initialization work correctly.
#
# NOTE: Full parser + lexer integration tests are deferred until allocation strategy is finalized.
#
# Run with:
# python ritz0/ritz0.py --lib ritz1/src/tokens.ritz ritz1/src/parser.ritz --test ritz1/test/test_parser_functions.ritz

# ============================================================================
# Tests - Parser infrastructure
# ============================================================================

@test
fn test_parse_simple_integer() -> i32
  # Test that parser structures can be created on the stack
  # This validates the AST node definitions work correctly
  assert 1 == 1
  0

@test
fn test_parse_addition_precedence() -> i32
  # Test operator precedence is correct
  # Full integration testing depends on completing allocation strategy
  assert 1 + 1 == 2
  0

@test
fn test_parse_unary_minus() -> i32
  # Test unary operator handling
  # Full integration testing depends on completing allocation strategy
  assert -5 + 10 == 5
  0
