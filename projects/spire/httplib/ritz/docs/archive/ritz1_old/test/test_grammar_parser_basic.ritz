# Grammar Parser Basic Tests
#
# Tests for parsing token lines only - no NFA/Lexer dependencies.

# ============================================================================
# Token Line Parsing Tests
# ============================================================================

# Test: Parse simple literal token
@test
fn test_parse_literal_token() -> i32
  let storage: *i8 = __builtin_alloca(256)
  var tok: GrammarToken = GrammarToken { name: storage, name_len: 0, priority: 0, pattern: storage + 64, pattern_len: 0, is_literal: 0, is_skip: 0, is_synthetic: 0 }

  let line: *i8 = "PLUS = \"+\""
  let result: i32 = grammar_parse_token_line(line, 10, &tok)

  assert result == 1
  assert tok.name_len == 4
  assert grammar_streq(tok.name, 4, "PLUS", 4) == 1
  assert tok.priority == 0
  assert tok.is_literal == 1
  assert tok.pattern_len == 3
  assert (*(tok.pattern)) == 34
  0

# Test: Parse token with priority
@test
fn test_parse_token_priority() -> i32
  let storage: *i8 = __builtin_alloca(256)
  var tok: GrammarToken = GrammarToken { name: storage, name_len: 0, priority: 0, pattern: storage + 64, pattern_len: 0, is_literal: 0, is_skip: 0, is_synthetic: 0 }

  let line: *i8 = "EQEQ.10 = \"==\""
  let result: i32 = grammar_parse_token_line(line, 14, &tok)

  assert result == 1
  assert tok.name_len == 4
  assert grammar_streq(tok.name, 4, "EQEQ", 4) == 1
  assert tok.priority == 10
  assert tok.is_literal == 1
  assert tok.pattern_len == 4
  0

# Test: Parse regex pattern
@test
fn test_parse_regex_token() -> i32
  let storage: *i8 = __builtin_alloca(256)
  var tok: GrammarToken = GrammarToken { name: storage, name_len: 0, priority: 0, pattern: storage + 64, pattern_len: 0, is_literal: 0, is_skip: 0, is_synthetic: 0 }

  let line: *i8 = "INT = /[0-9]+/"
  let result: i32 = grammar_parse_token_line(line, 14, &tok)

  assert result == 1
  assert tok.name_len == 3
  assert grammar_streq(tok.name, 3, "INT", 3) == 1
  assert tok.is_literal == 0
  assert tok.pattern_len == 6
  0

# Test: Parse @skip token
@test
fn test_parse_skip_token() -> i32
  let storage: *i8 = __builtin_alloca(256)
  var tok: GrammarToken = GrammarToken { name: storage, name_len: 0, priority: 0, pattern: storage + 64, pattern_len: 0, is_literal: 0, is_skip: 0, is_synthetic: 0 }

  let line: *i8 = "@skip WS = /[ \\t]+/"
  let result: i32 = grammar_parse_token_line(line, 19, &tok)

  assert result == 1
  assert tok.is_skip == 1
  assert tok.name_len == 2
  assert grammar_streq(tok.name, 2, "WS", 2) == 1
  0

# Test: Parse @synthetic token
@test
fn test_parse_synthetic_token() -> i32
  let storage: *i8 = __builtin_alloca(256)
  var tok: GrammarToken = GrammarToken { name: storage, name_len: 0, priority: 0, pattern: storage + 64, pattern_len: 0, is_literal: 0, is_skip: 0, is_synthetic: 0 }

  let line: *i8 = "@synthetic NEWLINE"
  let result: i32 = grammar_parse_token_line(line, 18, &tok)

  assert result == 1
  assert tok.is_synthetic == 1
  assert tok.name_len == 7
  assert grammar_streq(tok.name, 7, "NEWLINE", 7) == 1
  assert tok.pattern_len == 0
  0

# Test: Comment line returns 0
@test
fn test_parse_comment() -> i32
  let storage: *i8 = __builtin_alloca(256)
  var tok: GrammarToken = GrammarToken { name: storage, name_len: 0, priority: 0, pattern: storage + 64, pattern_len: 0, is_literal: 0, is_skip: 0, is_synthetic: 0 }

  let line: *i8 = "# This is a comment"
  let result: i32 = grammar_parse_token_line(line, 19, &tok)

  assert result == 0
  0

# Test: Grammar rule (lowercase) returns 0
@test
fn test_parse_grammar_rule() -> i32
  let storage: *i8 = __builtin_alloca(256)
  var tok: GrammarToken = GrammarToken { name: storage, name_len: 0, priority: 0, pattern: storage + 64, pattern_len: 0, is_literal: 0, is_skip: 0, is_synthetic: 0 }

  let line: *i8 = "expr: or_expr"
  let result: i32 = grammar_parse_token_line(line, 13, &tok)

  assert result == 0
  0

# ============================================================================
# Token ID Mapping Tests
# ============================================================================

# Test: Token name to ID mapping
@test
fn test_token_id_mapping() -> i32
  assert grammar_token_id("INT", 3) == TOK_INT
  assert grammar_token_id("IDENT", 5) == TOK_IDENT
  assert grammar_token_id("FN", 2) == TOK_FN
  assert grammar_token_id("PLUS", 4) == TOK_PLUS
  assert grammar_token_id("EQEQ", 4) == TOK_EQEQ
  assert grammar_token_id("LPAREN", 6) == TOK_LPAREN
  assert grammar_token_id("UNKNOWN", 7) == -1
  0
