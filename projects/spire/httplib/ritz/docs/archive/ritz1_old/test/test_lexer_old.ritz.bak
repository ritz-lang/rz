# ritz1 Lexer Tests
#
# TDD: Start simple, add complexity as needed.
# Each test drives language feature implementation.

# For now, use integer constants instead of enum
# TokenType will be: 0=EOF, 1=INT, 2=IDENT, 3=PLUS, etc.
const TT_EOF: i32 = 0
const TT_INT: i32 = 1
const TT_IDENT: i32 = 2
const TT_PLUS: i32 = 3
const TT_LPAREN: i32 = 4
const TT_RPAREN: i32 = 5

struct Token
  type: i32
  start: i32
  len: i32

struct Lexer
  src: *i8
  pos: i32
  len: i32

fn lexer_new(src: *i8, len: i32) -> Lexer
  Lexer { src: src, pos: 0, len: len }

fn is_digit(c: i32) -> i32
  if c >= 48 && c <= 57
    1
  else
    0

fn is_alpha(c: i32) -> i32
  if c >= 65 && c <= 90
    1
  else
    if c >= 97 && c <= 122
      1
    else
      if c == 95
        1
      else
        0

fn lexer_peek(lex: *Lexer) -> i32
  if (*lex).pos >= (*lex).len
    0
  else
    *((*lex).src + (*lex).pos)

fn lexer_advance(lex: *Lexer) -> i32
  let c: i32 = lexer_peek(lex)
  (*lex).pos = (*lex).pos + 1
  c

fn lexer_skip_whitespace(lex: *Lexer) -> i32
  while lexer_peek(lex) == 32 || lexer_peek(lex) == 9
    lexer_advance(lex)
  0

fn lexer_next(lex: *Lexer) -> Token
  lexer_skip_whitespace(lex)

  let start: i32 = (*lex).pos
  let c: i8 = lexer_peek(lex)

  # EOF
  if c == 0
    return Token { type: TT_EOF, start: start, len: 0 }

  # Integer
  if is_digit(c) == 1
    while is_digit(lexer_peek(lex)) == 1
      lexer_advance(lex)
    return Token { type: TT_INT, start: start, len: (*lex).pos - start }

  # Identifier
  if is_alpha(c) == 1
    while is_alpha(lexer_peek(lex)) == 1 || is_digit(lexer_peek(lex)) == 1
      lexer_advance(lex)
    return Token { type: TT_IDENT, start: start, len: (*lex).pos - start }

  # Single-char tokens
  lexer_advance(lex)
  if c == 43
    return Token { type: TT_PLUS, start: start, len: 1 }
  if c == 40
    return Token { type: TT_LPAREN, start: start, len: 1 }
  if c == 41
    return Token { type: TT_RPAREN, start: start, len: 1 }

  # Unknown - return EOF for now
  Token { type: TT_EOF, start: start, len: 0 }

# Helper to get string length
fn strlen(s: *i8) -> i32
  var i: i32 = 0
  while *(s + i) != 0
    i = i + 1
  i

@test
fn test_empty_input() -> i32
  let src: *i8 = ""
  var lex: Lexer = lexer_new(src, 0)
  let tok: Token = lexer_next(&lex)
  assert tok.type == TT_EOF
  0

@test
fn test_single_integer() -> i32
  let src: *i8 = "42"
  var lex: Lexer = lexer_new(src, 2)
  let tok: Token = lexer_next(&lex)
  assert tok.type == TT_INT
  assert tok.start == 0
  assert tok.len == 2
  0

@test
fn test_identifier() -> i32
  let src: *i8 = "foo"
  var lex: Lexer = lexer_new(src, 3)
  let tok: Token = lexer_next(&lex)
  assert tok.type == TT_IDENT
  assert tok.len == 3
  0

@test
fn test_skip_whitespace() -> i32
  let src: *i8 = "  42"
  var lex: Lexer = lexer_new(src, 4)
  let tok: Token = lexer_next(&lex)
  assert tok.type == TT_INT
  assert tok.start == 2
  0

@test
fn test_multiple_tokens() -> i32
  let src: *i8 = "1 + 2"
  var lex: Lexer = lexer_new(src, 5)

  let t1: Token = lexer_next(&lex)
  assert t1.type == TT_INT

  let t2: Token = lexer_next(&lex)
  assert t2.type == TT_PLUS

  let t3: Token = lexer_next(&lex)
  assert t3.type == TT_INT

  let t4: Token = lexer_next(&lex)
  assert t4.type == TT_EOF
  0

@test
fn test_parens() -> i32
  let src: *i8 = "(x)"
  var lex: Lexer = lexer_new(src, 3)

  let t1: Token = lexer_next(&lex)
  assert t1.type == TT_LPAREN

  let t2: Token = lexer_next(&lex)
  assert t2.type == TT_IDENT

  let t3: Token = lexer_next(&lex)
  assert t3.type == TT_RPAREN
  0
