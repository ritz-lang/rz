# Ritz Lexer Tests
#
# Tests for tokenizing actual Ritz source code.
# Run with: python ritz0/ritz0.py --lib ritz1/src/utf8.ritz ritz1/src/nfa.ritz ritz1/src/regex.ritz ritz1/src/tokens.ritz ritz1/src/lexer.ritz ritz1/src/token_dsl.ritz ritz1/src/ritz_tokens.ritz --test ritz1/test/test_ritz_lexer.ritz

# ============================================================================
# Basic Token Tests
# ============================================================================

# Test: Lex identifiers
@test
fn test_lex_ident() -> i32
  let storage: *i8 = __builtin_alloca(65536)
  let states: *NFAState = storage
  let trans: *Transition = storage + 8192
  let patterns: *TokenPattern = storage + 24576

  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  var lex: Lexer = Lexer { src: "foo bar baz", len: 11, pos: 0, line: 1, col: 1, nfa: &nfa, patterns: patterns, pattern_count: 0 , indent_stack: [0; 64], indent_depth: 1, at_line_start: 1, pending_dedents: 0, bracket_depth: 0 }
  build_ritz_lexer(&lex)

  let t1: Token = lexer_next(&lex)
  assert t1.type == TOK_IDENT
  assert t1.len == 3

  let t2: Token = lexer_next(&lex)
  assert t2.type == TOK_IDENT
  assert t2.len == 3

  let t3: Token = lexer_next(&lex)
  assert t3.type == TOK_IDENT
  assert t3.len == 3

  0

# Test: Lex integers
@test
fn test_lex_int() -> i32
  let storage: *i8 = __builtin_alloca(65536)
  let states: *NFAState = storage
  let trans: *Transition = storage + 8192
  let patterns: *TokenPattern = storage + 24576

  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  var lex: Lexer = Lexer { src: "42 0 123456", len: 11, pos: 0, line: 1, col: 1, nfa: &nfa, patterns: patterns, pattern_count: 0 , indent_stack: [0; 64], indent_depth: 1, at_line_start: 1, pending_dedents: 0, bracket_depth: 0 }
  build_ritz_lexer(&lex)

  let t1: Token = lexer_next(&lex)
  assert t1.type == TOK_INT
  assert t1.len == 2

  let t2: Token = lexer_next(&lex)
  assert t2.type == TOK_INT
  assert t2.len == 1

  let t3: Token = lexer_next(&lex)
  assert t3.type == TOK_INT
  assert t3.len == 6

  0

# Test: Lex keywords
@test
fn test_lex_keywords() -> i32
  let storage: *i8 = __builtin_alloca(65536)
  let states: *NFAState = storage
  let trans: *Transition = storage + 8192
  let patterns: *TokenPattern = storage + 24576

  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  var lex: Lexer = Lexer { src: "fn let var if else while", len: 24, pos: 0, line: 1, col: 1, nfa: &nfa, patterns: patterns, pattern_count: 0 , indent_stack: [0; 64], indent_depth: 1, at_line_start: 1, pending_dedents: 0, bracket_depth: 0 }
  build_ritz_lexer(&lex)

  let t1: Token = lexer_next(&lex)
  assert t1.type == TOK_FN
  assert t1.len == 2

  let t2: Token = lexer_next(&lex)
  assert t2.type == TOK_LET
  assert t2.len == 3

  let t3: Token = lexer_next(&lex)
  assert t3.type == TOK_VAR
  assert t3.len == 3

  let t4: Token = lexer_next(&lex)
  assert t4.type == TOK_IF
  assert t4.len == 2

  let t5: Token = lexer_next(&lex)
  assert t5.type == TOK_ELSE
  assert t5.len == 4

  let t6: Token = lexer_next(&lex)
  assert t6.type == TOK_WHILE
  assert t6.len == 5

  0

# Test: Lex operators
@test
fn test_lex_operators() -> i32
  let storage: *i8 = __builtin_alloca(65536)
  let states: *NFAState = storage
  let trans: *Transition = storage + 8192
  let patterns: *TokenPattern = storage + 24576

  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  var lex: Lexer = Lexer { src: "+ - * / == !=", len: 13, pos: 0, line: 1, col: 1, nfa: &nfa, patterns: patterns, pattern_count: 0 , indent_stack: [0; 64], indent_depth: 1, at_line_start: 1, pending_dedents: 0, bracket_depth: 0 }
  build_ritz_lexer(&lex)

  let t1: Token = lexer_next(&lex)
  assert t1.type == TOK_PLUS
  assert t1.len == 1

  let t2: Token = lexer_next(&lex)
  assert t2.type == TOK_MINUS
  assert t2.len == 1

  let t3: Token = lexer_next(&lex)
  assert t3.type == TOK_STAR
  assert t3.len == 1

  let t4: Token = lexer_next(&lex)
  assert t4.type == TOK_SLASH
  assert t4.len == 1

  let t5: Token = lexer_next(&lex)
  assert t5.type == TOK_EQEQ
  assert t5.len == 2

  let t6: Token = lexer_next(&lex)
  assert t6.type == TOK_NEQ
  assert t6.len == 2

  0

# Test: Lex delimiters
@test
fn test_lex_delimiters() -> i32
  let storage: *i8 = __builtin_alloca(65536)
  let states: *NFAState = storage
  let trans: *Transition = storage + 8192
  let patterns: *TokenPattern = storage + 24576

  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  var lex: Lexer = Lexer { src: "( ) { } [ ] , :", len: 15, pos: 0, line: 1, col: 1, nfa: &nfa, patterns: patterns, pattern_count: 0, indent_stack: [0; 64], indent_depth: 1, at_line_start: 1, pending_dedents: 0, bracket_depth: 0 }
  build_ritz_lexer(&lex)

  let t1: Token = lexer_next(&lex)
  assert t1.type == TOK_LPAREN

  let t2: Token = lexer_next(&lex)
  assert t2.type == TOK_RPAREN

  let t3: Token = lexer_next(&lex)
  assert t3.type == TOK_LBRACE

  let t4: Token = lexer_next(&lex)
  assert t4.type == TOK_RBRACE

  let t5: Token = lexer_next(&lex)
  assert t5.type == TOK_LBRACKET

  let t6: Token = lexer_next(&lex)
  assert t6.type == TOK_RBRACKET

  let t7: Token = lexer_next(&lex)
  assert t7.type == TOK_COMMA

  let t8: Token = lexer_next(&lex)
  assert t8.type == TOK_COLON

  0

# ============================================================================
# Compound Expression Tests
# ============================================================================

# Test: Lex function signature
@test
fn test_lex_fn_sig() -> i32
  let storage: *i8 = __builtin_alloca(65536)
  let states: *NFAState = storage
  let trans: *Transition = storage + 8192
  let patterns: *TokenPattern = storage + 24576

  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  var lex: Lexer = Lexer { src: "fn foo(x: i32) -> i32", len: 21, pos: 0, line: 1, col: 1, nfa: &nfa, patterns: patterns, pattern_count: 0 , indent_stack: [0; 64], indent_depth: 1, at_line_start: 1, pending_dedents: 0, bracket_depth: 0 }
  build_ritz_lexer(&lex)

  let t1: Token = lexer_next(&lex)
  assert t1.type == TOK_FN

  let t2: Token = lexer_next(&lex)
  assert t2.type == TOK_IDENT  # foo

  let t3: Token = lexer_next(&lex)
  assert t3.type == TOK_LPAREN

  let t4: Token = lexer_next(&lex)
  assert t4.type == TOK_IDENT  # x

  let t5: Token = lexer_next(&lex)
  assert t5.type == TOK_COLON

  let t6: Token = lexer_next(&lex)
  assert t6.type == TOK_IDENT  # i32

  let t7: Token = lexer_next(&lex)
  assert t7.type == TOK_RPAREN

  let t8: Token = lexer_next(&lex)
  assert t8.type == TOK_ARROW

  let t9: Token = lexer_next(&lex)
  assert t9.type == TOK_IDENT  # i32

  0

# Test: Lex variable declaration
@test
fn test_lex_var_decl() -> i32
  let storage: *i8 = __builtin_alloca(65536)
  let states: *NFAState = storage
  let trans: *Transition = storage + 8192
  let patterns: *TokenPattern = storage + 24576

  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  var lex: Lexer = Lexer { src: "let x: i32 = 42", len: 15, pos: 0, line: 1, col: 1, nfa: &nfa, patterns: patterns, pattern_count: 0 , indent_stack: [0; 64], indent_depth: 1, at_line_start: 1, pending_dedents: 0, bracket_depth: 0 }
  build_ritz_lexer(&lex)

  let t1: Token = lexer_next(&lex)
  assert t1.type == TOK_LET

  let t2: Token = lexer_next(&lex)
  assert t2.type == TOK_IDENT  # x

  let t3: Token = lexer_next(&lex)
  assert t3.type == TOK_COLON

  let t4: Token = lexer_next(&lex)
  assert t4.type == TOK_IDENT  # i32

  let t5: Token = lexer_next(&lex)
  assert t5.type == TOK_EQ

  let t6: Token = lexer_next(&lex)
  assert t6.type == TOK_INT

  0

# Test: Lex comparison expression
@test
fn test_lex_comparison() -> i32
  let storage: *i8 = __builtin_alloca(65536)
  let states: *NFAState = storage
  let trans: *Transition = storage + 8192
  let patterns: *TokenPattern = storage + 24576

  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  var lex: Lexer = Lexer { src: "x <= y && y >= z", len: 16, pos: 0, line: 1, col: 1, nfa: &nfa, patterns: patterns, pattern_count: 0 , indent_stack: [0; 64], indent_depth: 1, at_line_start: 1, pending_dedents: 0, bracket_depth: 0 }
  build_ritz_lexer(&lex)

  let t1: Token = lexer_next(&lex)
  assert t1.type == TOK_IDENT  # x

  let t2: Token = lexer_next(&lex)
  assert t2.type == TOK_LEQ

  let t3: Token = lexer_next(&lex)
  assert t3.type == TOK_IDENT  # y

  let t4: Token = lexer_next(&lex)
  assert t4.type == TOK_AMPAMP

  let t5: Token = lexer_next(&lex)
  assert t5.type == TOK_IDENT  # y

  let t6: Token = lexer_next(&lex)
  assert t6.type == TOK_GEQ

  let t7: Token = lexer_next(&lex)
  assert t7.type == TOK_IDENT  # z

  0

# Test: Keywords vs identifiers (keyword_like should be IDENT)
@test
fn test_keyword_vs_ident() -> i32
  let storage: *i8 = __builtin_alloca(65536)
  let states: *NFAState = storage
  let trans: *Transition = storage + 8192
  let patterns: *TokenPattern = storage + 24576

  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  var lex: Lexer = Lexer { src: "fn fns fn2 letter", len: 17, pos: 0, line: 1, col: 1, nfa: &nfa, patterns: patterns, pattern_count: 0 , indent_stack: [0; 64], indent_depth: 1, at_line_start: 1, pending_dedents: 0, bracket_depth: 0 }
  build_ritz_lexer(&lex)

  let t1: Token = lexer_next(&lex)
  assert t1.type == TOK_FN  # "fn" is keyword

  let t2: Token = lexer_next(&lex)
  assert t2.type == TOK_IDENT  # "fns" is identifier (has suffix)

  let t3: Token = lexer_next(&lex)
  assert t3.type == TOK_IDENT  # "fn2" is identifier

  let t4: Token = lexer_next(&lex)
  assert t4.type == TOK_IDENT  # "letter" is identifier (contains "let")

  0
