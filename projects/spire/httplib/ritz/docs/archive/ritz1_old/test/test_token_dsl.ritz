# Token DSL Parser Tests
#
# Tests for parsing the token definition DSL.
# Run with: python ritz0/ritz0.py --lib ritz1/src/utf8.ritz ritz1/src/nfa.ritz ritz1/src/regex.ritz ritz1/src/tokens.ritz ritz1/src/lexer.ritz ritz1/src/token_dsl.ritz --test ritz1/test/test_token_dsl.ritz

# ============================================================================
# DSL Line Parsing Tests
# ============================================================================

# Test: Parse a simple token definition
@test
fn test_dsl_parse_simple_def() -> i32
  let storage: *i8 = __builtin_alloca(1024)
  var def: TokenDef = TokenDef { name: storage, name_len: 0, pattern: storage + 64, pattern_len: 0, flags: 0, token_id: 0 }

  let line: *i8 = "INT = [0-9]+"
  let result: i32 = dsl_parse_line(line, 12, &def)

  assert result == 1  # Success
  assert def.name_len == 3  # "INT"
  assert def.pattern_len == 6  # "[0-9]+"
  assert def.flags == 0  # No flags
  0

# Test: Parse keyword literal
@test
fn test_dsl_parse_keyword() -> i32
  let storage: *i8 = __builtin_alloca(1024)
  var def: TokenDef = TokenDef { name: storage, name_len: 0, pattern: storage + 64, pattern_len: 0, flags: 0, token_id: 0 }

  let line: *i8 = "FN = \"fn\""
  let result: i32 = dsl_parse_line(line, 9, &def)

  assert result == 1
  assert def.name_len == 2  # "FN"
  assert def.pattern_len == 4  # "\"fn\""
  0

# Test: Parse @skip token
@test
fn test_dsl_parse_skip() -> i32
  let storage: *i8 = __builtin_alloca(1024)
  var def: TokenDef = TokenDef { name: storage, name_len: 0, pattern: storage + 64, pattern_len: 0, flags: 0, token_id: 0 }

  let line: *i8 = "@skip WS = [ \\t]+"
  let result: i32 = dsl_parse_line(line, 17, &def)

  assert result == 1
  assert def.name_len == 2  # "WS"
  assert def.flags == DSL_FLAG_SKIP
  0

# Test: Parse @synthetic token (no pattern)
@test
fn test_dsl_parse_synthetic() -> i32
  let storage: *i8 = __builtin_alloca(1024)
  var def: TokenDef = TokenDef { name: storage, name_len: 0, pattern: storage + 64, pattern_len: 0, flags: 0, token_id: 0 }

  let line: *i8 = "@synthetic INDENT"
  let result: i32 = dsl_parse_line(line, 17, &def)

  assert result == 1
  assert def.name_len == 6  # "INDENT"
  assert def.pattern_len == 0  # No pattern
  assert def.flags == DSL_FLAG_SYNTHETIC
  0

# Test: Skip comment lines
@test
fn test_dsl_skip_comment() -> i32
  let storage: *i8 = __builtin_alloca(1024)
  var def: TokenDef = TokenDef { name: storage, name_len: 0, pattern: storage + 64, pattern_len: 0, flags: 0, token_id: 0 }

  let line: *i8 = "# This is a comment"
  let result: i32 = dsl_parse_line(line, 19, &def)

  assert result == 0  # Skip (no token defined)
  0

# Test: Skip empty lines
@test
fn test_dsl_skip_empty() -> i32
  let storage: *i8 = __builtin_alloca(1024)
  var def: TokenDef = TokenDef { name: storage, name_len: 0, pattern: storage + 64, pattern_len: 0, flags: 0, token_id: 0 }

  let line: *i8 = "   "
  let result: i32 = dsl_parse_line(line, 3, &def)

  assert result == 0  # Skip
  0

# ============================================================================
# Integration Tests - Build Lexer from DSL
# ============================================================================

# Test: Build lexer from simple DSL
@test
fn test_dsl_build_lexer() -> i32
  let storage: *i8 = __builtin_alloca(32768)
  let states: *NFAState = storage
  let trans: *Transition = storage + 4096
  let patterns: *TokenPattern = storage + 16384

  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  var lex: Lexer = Lexer { src: "", len: 0, pos: 0, line: 1, col: 1, nfa: &nfa, patterns: patterns, pattern_count: 0 , indent_stack: [0; 64], indent_depth: 1, at_line_start: 1, pending_dedents: 0, bracket_depth: 0 }

  # Simple DSL: just INT and PLUS
  let dsl: *i8 = "INT = [0-9]+\nPLUS = \"+\""
  let result: i32 = dsl_build_lexer(&lex, dsl, 23)

  assert result == 2  # Two patterns added
  assert lex.pattern_count == 2
  0

# Test: Lex with DSL-built lexer
@test
fn test_dsl_lex_simple() -> i32
  let storage: *i8 = __builtin_alloca(32768)
  let states: *NFAState = storage
  let trans: *Transition = storage + 4096
  let patterns: *TokenPattern = storage + 16384

  var nfa: NFA = NFA { states: states, state_count: 0, transitions: trans, trans_count: 0, start_state: 0 }
  nfa_init(&nfa, states, trans)

  let src: *i8 = "42+3"
  var lex: Lexer = Lexer { src: src, len: 4, pos: 0, line: 1, col: 1, nfa: &nfa, patterns: patterns, pattern_count: 0 , indent_stack: [0; 64], indent_depth: 1, at_line_start: 1, pending_dedents: 0, bracket_depth: 0 }

  # Build lexer from DSL
  let dsl: *i8 = "INT = [0-9]+\nPLUS = \"+\""
  dsl_build_lexer(&lex, dsl, 23)
  lexer_finalize(&lex)

  # Tokenize
  let t1: Token = lexer_next(&lex)
  assert t1.type == 0  # First defined token (INT)
  assert t1.len == 2

  let t2: Token = lexer_next(&lex)
  assert t2.type == 1  # Second token (PLUS)
  assert t2.len == 1

  let t3: Token = lexer_next(&lex)
  assert t3.type == 0  # INT again
  assert t3.len == 1
  0
