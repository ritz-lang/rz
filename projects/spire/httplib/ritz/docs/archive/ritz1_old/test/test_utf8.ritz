# ritz1 UTF-8 Decoder Tests
#
# Tests for src/utf8.ritz module.
# Run with: python ritz0/ritz0.py --test ritz1/src/utf8.ritz ritz1/test/test_utf8.ritz

@test
fn test_utf8_ascii() -> i32
  let src: *i8 = "abc"
  var dec: Utf8Decoder = utf8_new(src, 3)
  assert utf8_next(&dec) == 97   # 'a'
  assert utf8_next(&dec) == 98   # 'b'
  assert utf8_next(&dec) == 99   # 'c'
  assert utf8_next(&dec) == -1   # EOF
  0

@test
fn test_utf8_empty() -> i32
  let src: *i8 = ""
  var dec: Utf8Decoder = utf8_new(src, 0)
  assert utf8_next(&dec) == -1
  0

# UTF-8 for 'e' (U+00E9) = 0xC3 0xA9 = 195 169
@test
fn test_utf8_2byte() -> i32
  var buf: [2]i8 = [0, 0]
  buf[0] = 195
  buf[1] = 169
  let src: *i8 = &buf[0]
  var dec: Utf8Decoder = utf8_new(src, 2)
  assert utf8_next(&dec) == 233  # U+00E9 = 233
  assert utf8_next(&dec) == -1
  0

# UTF-8 for '中' (U+4E2D) = 0xE4 0xB8 0xAD = 228 184 173
@test
fn test_utf8_3byte() -> i32
  var buf: [3]i8 = [0, 0, 0]
  buf[0] = 228
  buf[1] = 184
  buf[2] = 173
  let src: *i8 = &buf[0]
  var dec: Utf8Decoder = utf8_new(src, 3)
  assert utf8_next(&dec) == 20013  # U+4E2D = 20013
  assert utf8_next(&dec) == -1
  0

# UTF-8 for emoji (U+1F600) = 0xF0 0x9F 0x98 0x80 = 240 159 152 128
@test
fn test_utf8_4byte() -> i32
  var buf: [4]i8 = [0, 0, 0, 0]
  buf[0] = 240
  buf[1] = 159
  buf[2] = 152
  buf[3] = 128
  let src: *i8 = &buf[0]
  var dec: Utf8Decoder = utf8_new(src, 4)
  assert utf8_next(&dec) == 128512  # U+1F600 = 128512
  assert utf8_next(&dec) == -1
  0

@test
fn test_utf8_peek() -> i32
  let src: *i8 = "ab"
  var dec: Utf8Decoder = utf8_new(src, 2)
  # Peek doesn't consume
  assert utf8_peek(&dec) == 97
  assert utf8_peek(&dec) == 97
  # Next does consume
  assert utf8_next(&dec) == 97
  assert utf8_peek(&dec) == 98
  0

@test
fn test_utf8_remaining() -> i32
  let src: *i8 = "abc"
  var dec: Utf8Decoder = utf8_new(src, 3)
  assert utf8_remaining(&dec) == 3
  utf8_next(&dec)
  assert utf8_remaining(&dec) == 2
  0
