# ritz1/test/test_checker_integration.ritz - Integration Tests
#
# Tests that connect the parser to the type checker.
# These tests parse real Ritz code and verify type checking works.

# ============================================================================
# Constants
# ============================================================================

const TY_VOID: i32 = 0
const TY_BOOL: i32 = 1
const TY_I8: i32 = 2
const TY_I32: i32 = 4
const TY_PTR: i32 = 10
const TY_ERROR: i32 = 99

const SYM_VAR: i32 = 1
const SYM_FN: i32 = 2

const EXPR_INT_LIT: i32 = 1
const EXPR_IDENT: i32 = 2
const EXPR_BOOL_LIT: i32 = 4
const EXPR_BIN_OP: i32 = 5
const EXPR_FIELD: i32 = 9

const TY_STRUCT: i32 = 20
const TY_REF: i32 = 11

const STMT_VAR: i32 = 21
const STMT_LET: i32 = 22

# Token types for operators
const TOK_PLUS: i32 = 28
const TOK_MINUS: i32 = 29
const TOK_STAR: i32 = 30
const TOK_LT: i32 = 38
const TOK_EQEQ: i32 = 43
const TOK_AMPAMP: i32 = 50

# ============================================================================
# Structures
# ============================================================================

struct TypeList
  ty: *Type
  next: *TypeList

struct Field
  name: *i8
  name_len: i32
  ty: *Type
  offset: i32
  next: *Field

struct Type
  kind: i32
  is_mut: i32
  size: i32
  inner: *Type
  name: *i8
  name_len: i32
  fields: *Field
  params: *TypeList
  ret: *Type
  next: *Type

struct Symbol
  name: *i8
  name_len: i32
  kind: i32
  ty: *Type
  is_mut: i32
  next: *Symbol

struct Scope
  symbols: *Symbol
  parent: *Scope
  depth: i32

struct Expr
  kind: i32
  val1: i32        # For IDENT: position in source
  val2: i32        # For IDENT: length
  left: *i32
  right: *i32
  next: *i32

struct Checker
  global: *Scope
  current: *Scope
  errors: i32
  current_fn: *Type
  src: *i8

# ============================================================================
# Helper Functions
# ============================================================================

fn names_equal(a: *i8, a_len: i32, b: *i8, b_len: i32) -> i32
  if a_len != b_len
    return 0
  var i: i32 = 0
  while i < a_len
    let ca: i32 = *(a + i) as i32
    let cb: i32 = *(b + i) as i32
    if ca != cb
      return 0
    i = i + 1
  1

fn type_new(kind: i32) -> *Type
  let ty: *Type = __builtin_alloca(128) as *Type
  (*ty).kind = kind
  (*ty).is_mut = 0
  (*ty).size = 0
  (*ty).inner = 0 as *Type
  (*ty).name = 0 as *i8
  (*ty).name_len = 0
  (*ty).fields = 0 as *Field
  (*ty).params = 0 as *TypeList
  (*ty).ret = 0 as *Type
  (*ty).next = 0 as *Type
  ty

fn type_error() -> *Type
  type_new(TY_ERROR)

fn scope_lookup_local(s: *Scope, name: *i8, name_len: i32) -> *Symbol
  if s == 0 as *Scope
    return 0 as *Symbol
  var sym: *Symbol = (*s).symbols
  while sym != 0 as *Symbol
    if names_equal((*sym).name, (*sym).name_len, name, name_len) == 1
      return sym
    sym = (*sym).next
  0 as *Symbol

fn scope_lookup(s: *Scope, name: *i8, name_len: i32) -> *Symbol
  var current: *Scope = s
  while current != 0 as *Scope
    let sym: *Symbol = scope_lookup_local(current, name, name_len)
    if sym != 0 as *Symbol
      return sym
    current = (*current).parent
  0 as *Symbol

fn scope_insert(s: *Scope, sym: *Symbol) -> *Symbol
  (*sym).next = (*s).symbols
  (*s).symbols = sym
  sym

# ============================================================================
# Check Expression (with source-based name resolution)
# ============================================================================

fn check_expr(c: *Checker, e: *Expr) -> *Type
  if e == 0 as *Expr
    return type_error()

  let kind: i32 = (*e).kind

  if kind == EXPR_INT_LIT
    return type_new(TY_I32)

  if kind == EXPR_BOOL_LIT
    return type_new(TY_BOOL)

  if kind == EXPR_IDENT
    # val1 = position in source, val2 = length
    let name: *i8 = (*c).src + (*e).val1
    let name_len: i32 = (*e).val2
    let sym: *Symbol = scope_lookup((*c).current, name, name_len)
    if sym == 0 as *Symbol
      (*c).errors = (*c).errors + 1
      return type_error()
    return (*sym).ty

  if kind == EXPR_BIN_OP
    let left_ty: *Type = check_expr(c, (*e).left as *Expr)
    let right_ty: *Type = check_expr(c, (*e).right as *Expr)
    let op: i32 = (*e).val2

    # Arithmetic: return left type
    if op == TOK_PLUS
      return left_ty
    if op == TOK_MINUS
      return left_ty
    if op == TOK_STAR
      return left_ty

    # Comparison: return bool
    if op == TOK_LT
      return type_new(TY_BOOL)
    if op == TOK_EQEQ
      return type_new(TY_BOOL)

    # Logical: return bool
    if op == TOK_AMPAMP
      return type_new(TY_BOOL)

    return left_ty

  # Field access (e.g., foo.bar)
  if kind == EXPR_FIELD
    let struct_ty: *Type = check_expr(c, (*e).left as *Expr)

    # Handle pointer/ref auto-dereference
    var actual_ty: *Type = struct_ty
    if (*struct_ty).kind == TY_PTR
      actual_ty = (*struct_ty).inner
    if (*struct_ty).kind == TY_REF
      actual_ty = (*struct_ty).inner

    if (*actual_ty).kind != TY_STRUCT
      (*c).errors = (*c).errors + 1
      return type_error()

    # Look up field: val1 = position, val2 = length
    let field_name: *i8 = (*c).src + (*e).val1
    let field_len: i32 = (*e).val2

    var field: *Field = (*actual_ty).fields
    while field != 0 as *Field
      if names_equal((*field).name, (*field).name_len, field_name, field_len) == 1
        return (*field).ty
      field = (*field).next

    # Field not found
    (*c).errors = (*c).errors + 1
    return type_error()

  (*c).errors = (*c).errors + 1
  type_error()

# ============================================================================
# Tests
# ============================================================================

@test
fn test_ident_with_source_offset() -> i32
  # Source: "let x: i32 = 42"
  # The 'x' is at position 4, length 1
  let src: *i8 = __builtin_alloca(20) as *i8
  *(src + 0) = 108 as i8   # 'l'
  *(src + 1) = 101 as i8   # 'e'
  *(src + 2) = 116 as i8   # 't'
  *(src + 3) = 32 as i8    # ' '
  *(src + 4) = 120 as i8   # 'x'
  *(src + 5) = 58 as i8    # ':'
  *(src + 6) = 32 as i8    # ' '

  # Setup checker with source
  let scope: *Scope = __builtin_alloca(64) as *Scope
  (*scope).symbols = 0 as *Symbol
  (*scope).parent = 0 as *Scope
  (*scope).depth = 0

  let c: *Checker = __builtin_alloca(64) as *Checker
  (*c).global = scope
  (*c).current = scope
  (*c).errors = 0
  (*c).current_fn = 0 as *Type
  (*c).src = src

  # Add 'x' at position 4 in source to symbol table
  let ty_i32: *Type = __builtin_alloca(128) as *Type
  (*ty_i32).kind = TY_I32

  let sym: *Symbol = __builtin_alloca(64) as *Symbol
  (*sym).name = src + 4        # Points to 'x' in source
  (*sym).name_len = 1
  (*sym).kind = SYM_VAR
  (*sym).ty = ty_i32
  (*sym).is_mut = 0
  (*sym).next = 0 as *Symbol
  scope_insert(scope, sym)

  # Create identifier expression: position=4, length=1
  let e: *Expr = __builtin_alloca(64) as *Expr
  (*e).kind = EXPR_IDENT
  (*e).val1 = 4    # Position of 'x' in source
  (*e).val2 = 1    # Length of 'x'

  # Type check
  let result_ty: *Type = check_expr(c, e)
  assert (*result_ty).kind == TY_I32
  assert (*c).errors == 0
  0

@test
fn test_ident_not_in_scope() -> i32
  # Source: "y"
  let src: *i8 = __builtin_alloca(4) as *i8
  *(src + 0) = 121 as i8   # 'y'

  let scope: *Scope = __builtin_alloca(64) as *Scope
  (*scope).symbols = 0 as *Symbol
  (*scope).parent = 0 as *Scope
  (*scope).depth = 0

  let c: *Checker = __builtin_alloca(64) as *Checker
  (*c).global = scope
  (*c).current = scope
  (*c).errors = 0
  (*c).current_fn = 0 as *Type
  (*c).src = src

  # Create identifier expression for 'y' at position 0
  let e: *Expr = __builtin_alloca(64) as *Expr
  (*e).kind = EXPR_IDENT
  (*e).val1 = 0    # Position
  (*e).val2 = 1    # Length

  let result_ty: *Type = check_expr(c, e)
  assert (*result_ty).kind == TY_ERROR
  assert (*c).errors == 1
  0

@test
fn test_multiple_idents_in_source() -> i32
  # Source: "x + y"
  # x at pos 0, y at pos 4
  let src: *i8 = __builtin_alloca(8) as *i8
  *(src + 0) = 120 as i8   # 'x'
  *(src + 1) = 32 as i8    # ' '
  *(src + 2) = 43 as i8    # '+'
  *(src + 3) = 32 as i8    # ' '
  *(src + 4) = 121 as i8   # 'y'

  let scope: *Scope = __builtin_alloca(64) as *Scope
  (*scope).symbols = 0 as *Symbol
  (*scope).parent = 0 as *Scope
  (*scope).depth = 0

  let ty_i32: *Type = __builtin_alloca(128) as *Type
  (*ty_i32).kind = TY_I32

  # Add both x and y
  let sym_x: *Symbol = __builtin_alloca(64) as *Symbol
  (*sym_x).name = src + 0
  (*sym_x).name_len = 1
  (*sym_x).kind = SYM_VAR
  (*sym_x).ty = ty_i32
  (*sym_x).is_mut = 0
  (*sym_x).next = 0 as *Symbol
  scope_insert(scope, sym_x)

  let ty_bool: *Type = __builtin_alloca(128) as *Type
  (*ty_bool).kind = TY_BOOL

  let sym_y: *Symbol = __builtin_alloca(64) as *Symbol
  (*sym_y).name = src + 4
  (*sym_y).name_len = 1
  (*sym_y).kind = SYM_VAR
  (*sym_y).ty = ty_bool
  (*sym_y).is_mut = 0
  (*sym_y).next = 0 as *Symbol
  scope_insert(scope, sym_y)

  let c: *Checker = __builtin_alloca(64) as *Checker
  (*c).global = scope
  (*c).current = scope
  (*c).errors = 0
  (*c).current_fn = 0 as *Type
  (*c).src = src

  # Check x
  let e_x: *Expr = __builtin_alloca(64) as *Expr
  (*e_x).kind = EXPR_IDENT
  (*e_x).val1 = 0
  (*e_x).val2 = 1

  let ty_x: *Type = check_expr(c, e_x)
  assert (*ty_x).kind == TY_I32

  # Check y
  let e_y: *Expr = __builtin_alloca(64) as *Expr
  (*e_y).kind = EXPR_IDENT
  (*e_y).val1 = 4
  (*e_y).val2 = 1

  let ty_y: *Type = check_expr(c, e_y)
  assert (*ty_y).kind == TY_BOOL

  assert (*c).errors == 0
  0

@test
fn test_longer_ident_name() -> i32
  # Source: "count"
  let src: *i8 = __builtin_alloca(8) as *i8
  *(src + 0) = 99 as i8    # 'c'
  *(src + 1) = 111 as i8   # 'o'
  *(src + 2) = 117 as i8   # 'u'
  *(src + 3) = 110 as i8   # 'n'
  *(src + 4) = 116 as i8   # 't'

  let scope: *Scope = __builtin_alloca(64) as *Scope
  (*scope).symbols = 0 as *Symbol
  (*scope).parent = 0 as *Scope
  (*scope).depth = 0

  let ty_i32: *Type = __builtin_alloca(128) as *Type
  (*ty_i32).kind = TY_I32

  let sym: *Symbol = __builtin_alloca(64) as *Symbol
  (*sym).name = src
  (*sym).name_len = 5
  (*sym).kind = SYM_VAR
  (*sym).ty = ty_i32
  (*sym).is_mut = 0
  (*sym).next = 0 as *Symbol
  scope_insert(scope, sym)

  let c: *Checker = __builtin_alloca(64) as *Checker
  (*c).global = scope
  (*c).current = scope
  (*c).errors = 0
  (*c).current_fn = 0 as *Type
  (*c).src = src

  let e: *Expr = __builtin_alloca(64) as *Expr
  (*e).kind = EXPR_IDENT
  (*e).val1 = 0
  (*e).val2 = 5

  let result_ty: *Type = check_expr(c, e)
  assert (*result_ty).kind == TY_I32
  assert (*c).errors == 0
  0

# ============================================================================
# Binary Operator Tests
# ============================================================================

@test
fn test_binop_arithmetic_plus() -> i32
  # 1 + 2 should be i32
  let src: *i8 = __builtin_alloca(4) as *i8  # Dummy source

  let scope: *Scope = __builtin_alloca(64) as *Scope
  (*scope).symbols = 0 as *Symbol
  (*scope).parent = 0 as *Scope
  (*scope).depth = 0

  let c: *Checker = __builtin_alloca(64) as *Checker
  (*c).global = scope
  (*c).current = scope
  (*c).errors = 0
  (*c).current_fn = 0 as *Type
  (*c).src = src

  # Left operand: 1
  let left: *Expr = __builtin_alloca(64) as *Expr
  (*left).kind = EXPR_INT_LIT
  (*left).val1 = 1

  # Right operand: 2
  let right: *Expr = __builtin_alloca(64) as *Expr
  (*right).kind = EXPR_INT_LIT
  (*right).val1 = 2

  # Binary op: left + right
  let e: *Expr = __builtin_alloca(64) as *Expr
  (*e).kind = EXPR_BIN_OP
  (*e).val2 = TOK_PLUS
  (*e).left = left as *i32
  (*e).right = right as *i32

  let result_ty: *Type = check_expr(c, e)
  assert (*result_ty).kind == TY_I32
  assert (*c).errors == 0
  0

@test
fn test_binop_comparison_lt() -> i32
  # 1 < 2 should be bool
  let src: *i8 = __builtin_alloca(4) as *i8

  let scope: *Scope = __builtin_alloca(64) as *Scope
