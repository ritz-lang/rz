  let left: *Expr = __builtin_alloca(64) as *Expr
  (*left).kind = EXPR_INT_LIT
  (*left).val1 = 1

  let right: *Expr = __builtin_alloca(64) as *Expr
  (*right).kind = EXPR_INT_LIT
  (*right).val1 = 2

  let e: *Expr = __builtin_alloca(64) as *Expr
