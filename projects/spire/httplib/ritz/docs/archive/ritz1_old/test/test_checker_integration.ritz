@test
fn test_binop_logical_and() -> i32
  # true && false should be bool
  let src: *i8 = __builtin_alloca(4) as *i8

  let scope: *Scope = __builtin_alloca(64) as *Scope
  (*scope).symbols = 0 as *Symbol
  (*scope).parent = 0 as *Scope
  (*scope).depth = 0

  let c: *Checker = __builtin_alloca(64) as *Checker
  (*c).global = scope
  (*c).current = scope
  (*c).errors = 0
  (*c).current_fn = 0 as *Type
  (*c).src = src

  let left: *Expr = __builtin_alloca(64) as *Expr
  (*left).kind = EXPR_BOOL_LIT
  (*left).val1 = 1  # true

  let right: *Expr = __builtin_alloca(64) as *Expr
  (*right).kind = EXPR_BOOL_LIT
  (*right).val1 = 0  # false

  let e: *Expr = __builtin_alloca(64) as *Expr
  (*e).kind = EXPR_BIN_OP
  (*e).val2 = TOK_AMPAMP
  (*e).left = left as *i32
  (*e).right = right as *i32

  let result_ty: *Type = check_expr(c, e)
  assert (*result_ty).kind == TY_BOOL
  assert (*c).errors == 0
  0

# ============================================================================
# Struct Field Access Tests
# ============================================================================

@test
fn test_field_access_direct() -> i32
  # Source: "p.x"
  # 'p' at 0, 'x' at 2
  let src: *i8 = __builtin_alloca(8) as *i8
  *(src + 0) = 112 as i8   # 'p'
  *(src + 1) = 46 as i8    # '.'
  *(src + 2) = 120 as i8   # 'x'

  let scope: *Scope = __builtin_alloca(64) as *Scope
  (*scope).symbols = 0 as *Symbol
  (*scope).parent = 0 as *Scope
  (*scope).depth = 0

  # Create struct type Point { x: i32 }
  let ty_i32: *Type = __builtin_alloca(128) as *Type
  (*ty_i32).kind = TY_I32

  let field_x: *Field = __builtin_alloca(64) as *Field
  (*field_x).name = src + 2      # Points to 'x' in source
  (*field_x).name_len = 1
  (*field_x).ty = ty_i32
  (*field_x).offset = 0
  (*field_x).next = 0 as *Field

  let ty_point: *Type = __builtin_alloca(128) as *Type
  (*ty_point).kind = TY_STRUCT
  (*ty_point).name = 0 as *i8     # Could set "Point" if needed
  (*ty_point).name_len = 0
  (*ty_point).fields = field_x

  # Add variable 'p' of type Point
  let sym_p: *Symbol = __builtin_alloca(64) as *Symbol
  (*sym_p).name = src + 0
  (*sym_p).name_len = 1
  (*sym_p).kind = SYM_VAR
  (*sym_p).ty = ty_point
  (*sym_p).is_mut = 0
  (*sym_p).next = 0 as *Symbol
  scope_insert(scope, sym_p)

  let c: *Checker = __builtin_alloca(64) as *Checker
  (*c).global = scope
  (*c).current = scope
  (*c).errors = 0
  (*c).current_fn = 0 as *Type
  (*c).src = src

  # Create expression for 'p' (identifier)
  let e_p: *Expr = __builtin_alloca(64) as *Expr
  (*e_p).kind = EXPR_IDENT
  (*e_p).val1 = 0    # position of 'p'
  (*e_p).val2 = 1    # length

  # Create field access expression: p.x
  let e: *Expr = __builtin_alloca(64) as *Expr
  (*e).kind = EXPR_FIELD
  (*e).left = e_p as *i32
  (*e).val1 = 2      # position of 'x'
  (*e).val2 = 1      # length of 'x'

  let result_ty: *Type = check_expr(c, e)
  assert (*result_ty).kind == TY_I32
  assert (*c).errors == 0
  0

@test
fn test_field_access_via_pointer() -> i32
  # Source: "p.x" where p is *Point
  let src: *i8 = __builtin_alloca(8) as *i8
  *(src + 0) = 112 as i8   # 'p'
  *(src + 1) = 46 as i8    # '.'
  *(src + 2) = 120 as i8   # 'x'

  let scope: *Scope = __builtin_alloca(64) as *Scope
  (*scope).symbols = 0 as *Symbol
  (*scope).parent = 0 as *Scope
  (*scope).depth = 0

  # Create struct type Point { x: i32 }
  let ty_i32: *Type = __builtin_alloca(128) as *Type
  (*ty_i32).kind = TY_I32

  let field_x: *Field = __builtin_alloca(64) as *Field
  (*field_x).name = src + 2
  (*field_x).name_len = 1
  (*field_x).ty = ty_i32
  (*field_x).offset = 0
  (*field_x).next = 0 as *Field

  let ty_point: *Type = __builtin_alloca(128) as *Type
  (*ty_point).kind = TY_STRUCT
  (*ty_point).fields = field_x

  # Create pointer to Point type
  let ty_ptr_point: *Type = __builtin_alloca(128) as *Type
  (*ty_ptr_point).kind = TY_PTR
  (*ty_ptr_point).inner = ty_point

  # Add variable 'p' of type *Point
  let sym_p: *Symbol = __builtin_alloca(64) as *Symbol
  (*sym_p).name = src + 0
  (*sym_p).name_len = 1
  (*sym_p).kind = SYM_VAR
  (*sym_p).ty = ty_ptr_point
  (*sym_p).is_mut = 0
  (*sym_p).next = 0 as *Symbol
  scope_insert(scope, sym_p)

  let c: *Checker = __builtin_alloca(64) as *Checker
  (*c).global = scope
  (*c).current = scope
  (*c).errors = 0
  (*c).current_fn = 0 as *Type
  (*c).src = src

  let e_p: *Expr = __builtin_alloca(64) as *Expr
  (*e_p).kind = EXPR_IDENT
  (*e_p).val1 = 0
  (*e_p).val2 = 1

  let e: *Expr = __builtin_alloca(64) as *Expr
  (*e).kind = EXPR_FIELD
  (*e).left = e_p as *i32
  (*e).val1 = 2
  (*e).val2 = 1

  let result_ty: *Type = check_expr(c, e)
  assert (*result_ty).kind == TY_I32
  assert (*c).errors == 0
  0

@test
fn test_field_not_found() -> i32
  # Source: "p.z" where Point only has x
  let src: *i8 = __builtin_alloca(8) as *i8
  *(src + 0) = 112 as i8   # 'p'
  *(src + 1) = 46 as i8    # '.'
  *(src + 2) = 122 as i8   # 'z'

  let scope: *Scope = __builtin_alloca(64) as *Scope
  (*scope).symbols = 0 as *Symbol
  (*scope).parent = 0 as *Scope
  (*scope).depth = 0

  let ty_i32: *Type = __builtin_alloca(128) as *Type
  (*ty_i32).kind = TY_I32

  # Field 'x' in source would be at different position
  # We use a separate buffer for field name
  let field_name: *i8 = __builtin_alloca(4) as *i8
  *(field_name + 0) = 120 as i8  # 'x'

  let field_x: *Field = __builtin_alloca(64) as *Field
  (*field_x).name = field_name
  (*field_x).name_len = 1
  (*field_x).ty = ty_i32
  (*field_x).offset = 0
  (*field_x).next = 0 as *Field

  let ty_point: *Type = __builtin_alloca(128) as *Type
  (*ty_point).kind = TY_STRUCT
  (*ty_point).fields = field_x

  let sym_p: *Symbol = __builtin_alloca(64) as *Symbol
  (*sym_p).name = src + 0
  (*sym_p).name_len = 1
  (*sym_p).kind = SYM_VAR
  (*sym_p).ty = ty_point
  (*sym_p).is_mut = 0
  (*sym_p).next = 0 as *Symbol
  scope_insert(scope, sym_p)

  let c: *Checker = __builtin_alloca(64) as *Checker
  (*c).global = scope
  (*c).current = scope
  (*c).errors = 0
  (*c).current_fn = 0 as *Type
  (*c).src = src

  let e_p: *Expr = __builtin_alloca(64) as *Expr
  (*e_p).kind = EXPR_IDENT
  (*e_p).val1 = 0
  (*e_p).val2 = 1

  let e: *Expr = __builtin_alloca(64) as *Expr
  (*e).kind = EXPR_FIELD
  (*e).left = e_p as *i32
  (*e).val1 = 2      # 'z' position
  (*e).val2 = 1

  let result_ty: *Type = check_expr(c, e)
  assert (*result_ty).kind == TY_ERROR
  assert (*c).errors == 1
  0

@test
fn test_field_access_on_non_struct() -> i32
  # Source: "x.y" where x is i32 (not a struct)
  let src: *i8 = __builtin_alloca(8) as *i8
  *(src + 0) = 120 as i8   # 'x'
  *(src + 1) = 46 as i8    # '.'
  *(src + 2) = 121 as i8   # 'y'

  let scope: *Scope = __builtin_alloca(64) as *Scope
  (*scope).symbols = 0 as *Symbol
  (*scope).parent = 0 as *Scope
  (*scope).depth = 0

  let ty_i32: *Type = __builtin_alloca(128) as *Type
  (*ty_i32).kind = TY_I32

  let sym_x: *Symbol = __builtin_alloca(64) as *Symbol
  (*sym_x).name = src + 0
  (*sym_x).name_len = 1
  (*sym_x).kind = SYM_VAR
  (*sym_x).ty = ty_i32   # x is i32, not struct
  (*sym_x).is_mut = 0
  (*sym_x).next = 0 as *Symbol
  scope_insert(scope, sym_x)

  let c: *Checker = __builtin_alloca(64) as *Checker
  (*c).global = scope
  (*c).current = scope
  (*c).errors = 0
  (*c).current_fn = 0 as *Type
  (*c).src = src

  let e_x: *Expr = __builtin_alloca(64) as *Expr
  (*e_x).kind = EXPR_IDENT
  (*e_x).val1 = 0
  (*e_x).val2 = 1

  let e: *Expr = __builtin_alloca(64) as *Expr
  (*e).kind = EXPR_FIELD
  (*e).left = e_x as *i32
  (*e).val1 = 2
  (*e).val2 = 1

  let result_ty: *Type = check_expr(c, e)
  assert (*result_ty).kind == TY_ERROR
  assert (*c).errors == 1
  0
