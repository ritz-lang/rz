# Token structure
struct Token
  kind: i32
  start: *i8
  len: i32
  line: i32
  col: i32

# Helper function to create a Token
fn token_new(kind: i32, pos: i32, len: i32, line: i32, col: i32) -> Token
  Token {
    kind: kind,
    start: nil,
    len: len,
    line: line,
    col: col
  }

fn main() -> i32
  0
