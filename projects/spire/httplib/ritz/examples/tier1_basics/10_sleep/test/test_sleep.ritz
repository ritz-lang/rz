# Tests for 10_sleep - nanosleep syscall and duration parsing
#
# The 10_sleep example demonstrates:
# - Nanosleep syscall usage
# - Struct definitions (TimeSpec)
# - Duration parsing with fractional seconds
# - Pointer-to-struct casting

import ritzlib.sys
import ritzlib.str

# Test parse_duration basic whole numbers
[[test]]
fn test_parse_whole() -> i32
    var sec: i64 = 0
    var nsec: i64 = 0

    let result: i32 = parse_duration_test("5", &sec, &nsec)
    assert result == 0
    assert sec == 5
    assert nsec == 0
    0

fn parse_duration_test(s: *u8, out_sec: *i64, out_nsec: *i64) -> i32
    var sec: i64 = 0
    var nsec: i64 = 0
    var i: i32 = 0
    var frac_digits: i32 = 0
    var in_frac: i32 = 0

    while *(s + i) != 0
        let c: u8 = *(s + i)

        if c == '.'
            if in_frac == 1
                return 1
            in_frac = 1
            i += 1
        else
            if c < '0'
                return 1
            if c > '9'
                return 1

            if in_frac == 0
                sec = sec * 10 + (c - '0') as i64
            else
                if frac_digits < 9
                    nsec = nsec * 10 + (c - '0') as i64
                    frac_digits += 1
            i += 1

    for _ in frac_digits..9
        nsec *= 10

    out_sec[0] = sec
    out_nsec[0] = nsec
    0

# Test parse_duration with decimal
[[test]]
fn test_parse_decimal() -> i32
    var sec: i64 = 0
    var nsec: i64 = 0

    let result: i32 = parse_duration_test("1.5", &sec, &nsec)
    assert result == 0
    assert sec == 1
    assert nsec == 500000000  # 0.5 seconds in nanoseconds
    0

# Test parse_duration with many decimal places
[[test]]
fn test_parse_many_decimals() -> i32
    var sec: i64 = 0
    var nsec: i64 = 0

    let result: i32 = parse_duration_test("0.001", &sec, &nsec)
    assert result == 0
    assert sec == 0
    assert nsec == 1000000  # 1 millisecond
    0

# Test parse_duration zero
[[test]]
fn test_parse_zero() -> i32
    var sec: i64 = 0
    var nsec: i64 = 0

    let result: i32 = parse_duration_test("0", &sec, &nsec)
    assert result == 0
    assert sec == 0
    assert nsec == 0
    0

# Test parse_duration larger number
[[test]]
fn test_parse_large() -> i32
    var sec: i64 = 0
    var nsec: i64 = 0

    let result: i32 = parse_duration_test("60", &sec, &nsec)
    assert result == 0
    assert sec == 60
    assert nsec == 0
    0

# Test nanoseconds calculation
[[test]]
fn test_nanoseconds() -> i32
    # 1 second = 1,000,000,000 nanoseconds
    let one_sec_ns: i64 = 1000000000
    assert one_sec_ns == 1000000000

    # 0.1 seconds = 100,000,000 nanoseconds
    let point_one: i64 = 100000000
    assert point_one == 100000000
    0

# ============================================================================
# Integration test: verify ./sleep actually delays
# ============================================================================

[[test]]
fn test_sleep_timing() -> i32
    # Test sleep 0 - should complete quickly
    let pid: i32 = sys_fork()
    if pid < 0
        return 1

    if pid == 0
        var argv: [3]*u8
        argv[0] = c"./sleep"
        argv[1] = c"0"
        argv[2] = null

        sys_execve(c"./sleep", &argv[0], null)
        sys_exit(127)

    var status: i32 = 0
    sys_wait4(pid, &status, 0, null)

    # Extract exit code
    let code: i32 = (status / 256) % 256
    assert code == 0, "sleep 0 should exit 0"
    return 0
