# Tests for 07_wc - word, line, and byte counting
#
# The 07_wc example demonstrates:
# - Counting algorithms (words, lines, bytes)
# - State machine for word detection
# - Character classification (isspace)
# - Output pointer parameters

import ritzlib.sys
import ritzlib.str
import ritzlib.io

# Test isspace function
[[test]]
fn test_isspace() -> i32
    assert isspace(32) == 1   # space
    assert isspace(9) == 1    # tab
    assert isspace(10) == 1   # newline
    assert isspace(13) == 1   # carriage return
    assert isspace(97) == 0   # 'a'
    assert isspace(48) == 0   # '0'
    0

# Test isdigit function
[[test]]
fn test_isdigit() -> i32
    assert isdigit(48) == 1   # '0'
    assert isdigit(57) == 1   # '9'
    assert isdigit(47) == 0   # '/'
    assert isdigit(58) == 0   # ':'
    assert isdigit(97) == 0   # 'a'
    0

# Test isalpha function
[[test]]
fn test_isalpha() -> i32
    assert isalpha(65) == 1   # 'A'
    assert isalpha(90) == 1   # 'Z'
    assert isalpha(97) == 1   # 'a'
    assert isalpha(122) == 1  # 'z'
    assert isalpha(64) == 0   # '@'
    assert isalpha(48) == 0   # '0'
    0

# Test word counting
[[test]]
fn test_count_words() -> i32
    let s1: *u8 = "hello world"
    assert count_words(s1) == 2

    let s2: *u8 = "one"
    assert count_words(s2) == 1

    let s3: *u8 = ""
    assert count_words(s3) == 0

    let s4: *u8 = "   "
    assert count_words(s4) == 0
    0

fn count_words(s: *u8) -> i32
    var count: i32 = 0
    var in_word: i32 = 0
    var i: i64 = 0
    while *(s + i) != 0
        let c: u8 = *(s + i)
        if isspace(c) == 1
            in_word = 0
        else
            if in_word == 0
                count += 1
                in_word = 1
        i += 1
    return count

# Test line counting
[[test]]
fn test_count_lines() -> i32
    let s1: *u8 = "line1\nline2\nline3"
    assert count_lines(s1) == 2

    let s2: *u8 = "line1\n"
    assert count_lines(s2) == 1

    let s3: *u8 = "no newline"
    assert count_lines(s3) == 0

    let s4: *u8 = "\n\n\n"
    assert count_lines(s4) == 3
    0

fn count_lines(s: *u8) -> i32
    var count: i32 = 0
    var i: i64 = 0
    while *(s + i) != 0
        if *(s + i) == '\n'
            count += 1
        i += 1
    return count

# Test byte counting (strlen)
[[test]]
fn test_count_bytes() -> i32
    assert strlen("") == 0
    assert strlen("hello") == 5
    assert strlen("a b c") == 5
    0

# Test combined counting
[[test]]
fn test_wc_combined() -> i32
    let text = "hello world\nfoo bar baz\n"
    var lines: i64 = 0
    var words: i64 = 0
    var bytes: i64 = 0

    wc_string(text, &lines, &words, &bytes)

    assert lines == 2
    assert words == 5
    assert bytes == 24
    0

fn wc_string(s: *u8, out_lines: *i64, out_words: *i64, out_bytes: *i64)
    var lines: i64 = 0
    var words: i64 = 0
    var bytes: i64 = 0
    var in_word: i32 = 0
    var i: i64 = 0

    while *(s + i) != 0
        let c: u8 = *(s + i)
        bytes += 1

        if c == '\n'
            lines += 1

        if isspace(c) == 1
            in_word = 0
        else
            if in_word == 0
                words += 1
                in_word = 1
        i += 1

    *out_lines = lines
    *out_words = words
    *out_bytes = bytes

# Test multiple consecutive spaces
[[test]]
fn test_multiple_spaces() -> i32
    let s = "one   two    three"
    assert count_words(s) == 3
    0

# Test tabs and mixed whitespace
[[test]]
fn test_mixed_whitespace() -> i32
    let s = "one\ttwo\n\nthree"
    assert count_words(s) == 3
    assert count_lines(s) == 2
    0

# ============================================================================
# Integration test: verify ./wc outputs correct counts
# ============================================================================

fn wc_starts_with(buf: *u8, prefix: *u8) -> i32
    var i: i64 = 0
    while *(prefix + i) != 0
        if *(buf + i) != *(prefix + i)
            return 0
        i += 1
    return 1

[[test]]
fn test_wc_file() -> i32
    # Create test file: "hello world\nfoo bar baz\n"
    # Expected: 2 lines, 5 words, 24 bytes
    let path: *u8 = c"/tmp/ritz_test_wc_int.txt"
    let content: *u8 = c"hello world\nfoo bar baz\n"

    let fd_w: i32 = sys_open3(path, O_WRONLY + O_CREAT + O_TRUNC, 420)
    if fd_w < 0
        return 1
    sys_write(fd_w, content, 24)
    sys_close(fd_w)

    # Create pipe for capturing output
    var pipefd: [2]i32
    if sys_pipe(&pipefd[0]) < 0
        return 2

    let pid: i32 = sys_fork()
    if pid < 0
        sys_close(pipefd[0])
        sys_close(pipefd[1])
        return 3

    if pid == 0
        sys_dup2(pipefd[1], 1)
        sys_close(pipefd[0])
        sys_close(pipefd[1])

        var argv: [3]*u8
        argv[0] = c"./wc"
        argv[1] = path
        argv[2] = null

        sys_execve(c"./wc", &argv[0], null)
        sys_exit(127)

    sys_close(pipefd[1])

    var out: [256]u8
    let n: i64 = sys_read(pipefd[0], &out[0], 255)
    sys_close(pipefd[0])

    var status: i32 = 0
    sys_wait4(pid, &status, 0, null)

    sys_unlink(path)

    if n <= 0
        return 4

    out[n] = 0
    # wc should output "2 5 24 ..."
    assert wc_starts_with(&out[0], c"2 5 24") == 1, "expected 2 5 24"
    return 0
