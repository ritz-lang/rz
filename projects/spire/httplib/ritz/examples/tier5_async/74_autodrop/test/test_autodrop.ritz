# Tests for automatic Drop at scope exit
#
# The compiler automatically calls drop() for types implementing Drop
# when they go out of scope. No manual cleanup needed!

import ritzlib.memory
import ritzlib.io

# Global counter to track drop calls
var drop_count: i64 = 0

# A simple resource that implements Drop
struct Resource
    id: i64

impl Drop for Resource
    fn drop(self: &mut Resource)
        drop_count += 1

fn resource_new(id: i64) -> Resource
    return Resource { id: id }

# ============================================================================
# Helper functions that create resources and return
# ============================================================================

fn create_one_resource() -> i64
    drop_count = 0
    var r = resource_new(1)
    # r is automatically dropped when this function returns
    42

fn create_three_resources() -> i64
    drop_count = 0
    var r1 = resource_new(1)
    var r2 = resource_new(2)
    var r3 = resource_new(3)
    # All three automatically dropped (LIFO order)
    99

fn early_return_helper(do_return: i64) -> i64
    drop_count = 0
    var r = resource_new(1)
    if do_return == 1
        return 42  # r is still dropped!
    99

# ============================================================================
# Tests verify drop happened AFTER helper function returned
# ============================================================================

[[test]]
fn test_auto_drop_simple() -> i32
    let result = create_one_resource()
    assert result == 42, "return value"
    assert drop_count == 1, "drop should be called once"
    0

[[test]]
fn test_auto_drop_multiple() -> i32
    let result = create_three_resources()
    assert result == 99, "return value"
    assert drop_count == 3, "all three dropped"
    0

[[test]]
fn test_drop_order_lifo() -> i32
    # Verify drops happen (we can't easily verify LIFO order here,
    # but the implementation does LIFO)
    let result = create_three_resources()
    assert drop_count == 3, "all dropped"
    0

[[test]]
fn test_drop_on_early_return() -> i32
    let result = early_return_helper(1)
    assert result == 42, "early return value"
    assert drop_count == 1, "drop called on early return"
    0

[[test]]
fn test_drop_on_normal_return() -> i32
    let result = early_return_helper(0)
    assert result == 99, "normal return value"
    assert drop_count == 1, "drop called on normal return"
    0

# ============================================================================
# Main entry point
# ============================================================================

fn main() -> i32
    0
