import ritzlib.string
import ritzlib.result

# Test that Result<String, i32> works correctly
fn create_greeting(name: *u8) -> Result<String, i32>
    if name == null
        return Err(1)
    var s: String = string_new()
    string_push_str(&s, "Hello, ")
    string_push_str(&s, name)
    string_push(&s, '!' as u8)
    return Ok(s)

fn check_greeting_ok(greeting: String, expected_len: i64) -> i32
    let len: i64 = string_len(&greeting)
    # Test fails here - return len as error code for debugging
    if len == expected_len
        string_drop(&greeting)
        0
    else
        string_drop(&greeting)
        len as i32

fn return_one() -> i32
    1

[[test]]
fn test_ok_case() -> i32
    var result: Result<String, i32> = create_greeting("World")
    match result
        Ok(greeting) => check_greeting_ok(greeting, 13)
        Err(_) => return_one()

fn check_err_code(code: i32, expected: i32) -> i32
    if code == expected
        0
    else
        1

[[test]]
fn test_err_case() -> i32
    var result: Result<String, i32> = create_greeting(null)
    match result
        Ok(_) => return_one()
        Err(code) => check_err_code(code, 1)
