# Test grammar with return types and semantic actions

%tokens
NUMBER      = /[0-9]+/
PLUS        = "+"
LPAREN      = "("
RPAREN      = ")"

%skip
WHITESPACE  = /[ \t\r\n]+/

%grammar

# Test return type and semantic actions
expr -> *Expr
    : term PLUS expr { expr_binary(OP_ADD, $1, $3) }
    | term { $1 }
    ;

term -> *Expr
    : NUMBER { expr_int(parse_int($1)) }
    | LPAREN expr RPAREN { $2 }
    ;
