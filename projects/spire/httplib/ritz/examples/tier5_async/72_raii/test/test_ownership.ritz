# Tests for ownership and move semantics
#
# Ritz uses move semantics for non-Copy types:
# - Assignment transfers ownership
# - Original binding becomes invalid after move
# - Only one owner at a time
# - Owner is responsible for cleanup

import ritzlib.memory
import ritzlib.box
import ritzlib.io

# Non-Copy type (contains a pointer)
struct UniquePtr
    ptr: *u8
    size: i64

fn unique_ptr_new(size: i64) -> UniquePtr
    let p = malloc(size)
    return UniquePtr { ptr: p, size: size }

fn unique_ptr_null() -> UniquePtr
    return UniquePtr { ptr: null, size: 0 }

fn unique_ptr_drop(self: &mut UniquePtr)
    if self.ptr != null
        free(self.ptr)
    self.ptr = null
    self.size = 0

# Copy type (all primitives)
struct Pair
    x: i64
    y: i64

fn pair_new(x: i64, y: i64) -> Pair
    return Pair { x: x, y: y }

[[test]]
fn test_copy_semantics() -> i32
    # Primitives are Copy - assignment copies the value
    let a: i64 = 42
    let b = a  # Copy
    assert a == 42, "original unchanged"
    assert b == 42, "copy has same value"
    0

[[test]]
fn test_struct_copy() -> i32
    # Structs with only Copy fields are Copy
    let p1 = pair_new(1, 2)
    let p2 = p1  # Copy (all fields are i64, which is Copy)
    assert p1.x == 1, "original unchanged"
    assert p2.x == 1, "copy has same value"
    0

[[test]]
fn test_box_ownership() -> i32
    # Box<T> is a move type - assignment transfers ownership
    var b1: Box<i64> = box_new<i64>(42)
    assert b1.valid() == 1, "b1 is valid"

    # After move, b1 should be invalid
    # var b2 = b1  # Would move ownership
    # assert b1.valid() == 0, "b1 invalid after move"
    # assert b2.valid() == 1, "b2 is valid"

    # For now, just test basic usage
    assert b1.get() == 42, "value should be 42"
    b1.drop()
    0

[[test]]
fn test_unique_ptr_create() -> i32
    var p = unique_ptr_new(1024)
    assert p.ptr != null, "should be allocated"
    assert p.size == 1024, "size should be 1024"
    unique_ptr_drop(&p)
    assert p.ptr == null, "should be null after drop"
    0

# Test function that takes ownership
fn consume_unique(p: UniquePtr)
    # p is moved into this function
    # p.drop() would be called automatically at end
    var mp = p
    unique_ptr_drop(&mp)  # Manual for now

[[test]]
fn test_move_to_function() -> i32
    var p = unique_ptr_new(512)
    consume_unique(p)
    # p is now moved, should not be used
    # (move checker should catch use-after-move)
    0

# Test function that borrows
fn borrow_unique(p: &UniquePtr) -> i64
    return p.size

[[test]]
fn test_borrow_preserves_ownership() -> i32
    var p = unique_ptr_new(256)
    let size = borrow_unique(&p)
    assert size == 256, "borrowed size"
    # p is still valid - borrow doesn't transfer ownership
    assert p.ptr != null, "still valid after borrow"
    unique_ptr_drop(&p)
    0

# Test mutable borrow
fn modify_size(p: &mut UniquePtr, new_size: i64)
    p.size = new_size

[[test]]
fn test_mutable_borrow() -> i32
    var p = unique_ptr_new(100)
    assert p.size == 100, "initial size"

    modify_size(&p, 200)
    assert p.size == 200, "modified size"

    # Still own p
    unique_ptr_drop(&p)
    0

[[test]]
fn test_null_unique_ptr() -> i32
    var p = unique_ptr_null()
    assert p.ptr == null, "should be null"
    unique_ptr_drop(&p)  # Should be safe to drop null
    0

# Ownership transfer via return
fn create_resource() -> UniquePtr
    var p = unique_ptr_new(64)
    return p  # Ownership transferred to caller

[[test]]
fn test_return_ownership() -> i32
    var p = create_resource()
    assert p.ptr != null, "received ownership"
    assert p.size == 64, "correct size"
    unique_ptr_drop(&p)
    0
