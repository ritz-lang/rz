# Test application using dependency
# RFC #109 Phase 2: Dependency namespacing
#
# Note: Currently uses flat import model (all pub items imported directly).
# Qualified syntax (gzip::compress_level) pending module system Phase 2.

import squeeze.gzip

fn main() -> i32
    # Functions from squeeze.gzip are imported directly
    let level = compress_level()
    let magic = decompress_magic()

    # level should be 6, magic should be 0x1f8b (8075)
    # Return 0 if both are correct
    if level == 6
        if magic == 0x1f8b
            0
        else
            2
    else
        1
