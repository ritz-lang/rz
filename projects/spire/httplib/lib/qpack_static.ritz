    if index == 61
        entry.name = span_from_cstr("x-content-type-options")
        entry.value = span_from_cstr("nosniff")
        return 0
    if index == 62
        entry.name = span_from_cstr("x-xss-protection")
        entry.value = span_from_cstr("1; mode=block")
        return 0
    if index == 63
        entry.name = span_from_cstr(":status")
        entry.value = span_from_cstr("100")
        return 0
    if index == 64
        entry.name = span_from_cstr(":status")
        entry.value = span_from_cstr("204")
        return 0
    if index == 65
        entry.name = span_from_cstr(":status")
