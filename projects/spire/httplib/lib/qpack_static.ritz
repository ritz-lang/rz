# ============================================================================
# Static Table Search
# ============================================================================

# Find entry by name only (returns first match)
# Returns index (0-98) or -1 if not found
pub fn qpack_static_find_name(name: Span<u8>) -> i32
    var i: i32 = 0
    while i < QPACK_STATIC_TABLE_SIZE
        var entry: QpackStaticEntry
        qpack_static_get(i, @entry)
        if span_equals(name, entry.name) != 0
            return i
        i = i + 1
    return -1

# Find entry by name and value (exact match)
# Returns index (0-98) or -1 if not found
pub fn qpack_static_find_exact(name: Span<u8>, value: Span<u8>) -> i32
    var i: i32 = 0
    while i < QPACK_STATIC_TABLE_SIZE
        var entry: QpackStaticEntry
        qpack_static_get(i, @entry)
        if span_equals(name, entry.name) != 0 && span_equals(value, entry.value) != 0
            return i
        i = i + 1
    return -1

# Compare two spans for equality
fn span_equals(a: Span<u8>, b: Span<u8>) -> i32
    if a.len != b.len
        return 0
    var i: i32 = 0
    while i < a.len
        if *(a.ptr + i) != *(b.ptr + i)
            return 0
        i = i + 1
    return 1

