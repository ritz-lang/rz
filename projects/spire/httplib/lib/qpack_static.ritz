# lib/qpack_static.ritz - QPACK Static Table (RFC 9204 Appendix A)
#
# The QPACK static table has 99 entries (indices 0-98)
# This is larger than HPACK's 61 entries and includes
# more common HTTP/3 headers.

import ritzlib.span

# ============================================================================
# Static Table Entry
# ============================================================================

pub struct QpackStaticEntry
    name: Span<u8>
    value: Span<u8>

# ============================================================================
# Static Table Size
# ============================================================================

pub const QPACK_STATIC_TABLE_SIZE: i32 = 99

# ============================================================================
# Static Table Lookup
# ============================================================================

# Get static table entry by index (0-98)
# Returns 0 on success, -1 if index out of range
pub fn qpack_static_get(index: i32, entry: *QpackStaticEntry) -> i32
    if index < 0 || index >= QPACK_STATIC_TABLE_SIZE
        return -1

    # Initialize to empty
    entry.name.ptr = null
    entry.name.len = 0
    entry.value.ptr = null
    entry.value.len = 0

    # Static table entries (RFC 9204 Appendix A)
    if index == 0
        entry.name = span_from_cstr(":authority")
        return 0
    if index == 1
        entry.name = span_from_cstr(":path")
        entry.value = span_from_cstr("/")
        return 0
    if index == 2
        entry.name = span_from_cstr("age")
        entry.value = span_from_cstr("0")
        return 0
    if index == 3
        entry.name = span_from_cstr("content-disposition")
        return 0
    if index == 4
        entry.name = span_from_cstr("content-length")
        entry.value = span_from_cstr("0")
        return 0
    if index == 5
        entry.name = span_from_cstr("cookie")
        return 0
    if index == 6
        entry.name = span_from_cstr("date")
        return 0
    if index == 7
        entry.name = span_from_cstr("etag")
        return 0
    if index == 8
        entry.name = span_from_cstr("if-modified-since")
        return 0
    if index == 9
        entry.name = span_from_cstr("if-none-match")
        return 0
    if index == 10
        entry.name = span_from_cstr("last-modified")
        return 0
    if index == 11
        entry.name = span_from_cstr("link")
        return 0
    if index == 12
        entry.name = span_from_cstr("location")
        return 0
    if index == 13
        entry.name = span_from_cstr("referer")
        return 0
    if index == 14
        entry.name = span_from_cstr("set-cookie")
        return 0
    if index == 15
        entry.name = span_from_cstr(":method")
        entry.value = span_from_cstr("CONNECT")
        return 0
    if index == 16
        entry.name = span_from_cstr(":method")
        entry.value = span_from_cstr("DELETE")
        return 0
    if index == 17
        entry.name = span_from_cstr(":method")
        entry.value = span_from_cstr("GET")
        return 0
    if index == 18
        entry.name = span_from_cstr(":method")
        entry.value = span_from_cstr("HEAD")
        return 0
    if index == 19
        entry.name = span_from_cstr(":method")
        entry.value = span_from_cstr("OPTIONS")
        return 0
    if index == 20
        entry.name = span_from_cstr(":method")
        entry.value = span_from_cstr("POST")
        return 0
    if index == 21
        entry.name = span_from_cstr(":method")
        entry.value = span_from_cstr("PUT")
        return 0
    if index == 22
        entry.name = span_from_cstr(":scheme")
        entry.value = span_from_cstr("http")
        return 0
    if index == 23
        entry.name = span_from_cstr(":scheme")
        entry.value = span_from_cstr("https")
        return 0
    if index == 24
        entry.name = span_from_cstr(":status")
        entry.value = span_from_cstr("103")
        return 0
    if index == 25
        entry.name = span_from_cstr(":status")
        entry.value = span_from_cstr("200")
        return 0
    if index == 26
        entry.name = span_from_cstr(":status")
