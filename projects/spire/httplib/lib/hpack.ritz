# lib/hpack.ritz - HPACK header compression for HTTP/2
#
# HPACK is the header compression format used by HTTP/2, defined in RFC 7541.
# It uses a static table of 61 common header field entries and a dynamic table
# that is maintained by the encoder and decoder.
#
# This module provides:
# - Static table with 61 pre-defined header fields
# - Dynamic table with FIFO eviction
# - Integer encoding/decoding (prefix encoding)
# - String encoding/decoding (literal and Huffman)
# - Header field encoding/decoding

import ritzlib.span
import ritzlib.str

# ============================================================================
# Error Codes
# ============================================================================

pub const HPACK_OK: i32 = 0
pub const HPACK_ERR_INCOMPLETE: i32 = -1
pub const HPACK_ERR_INVALID: i32 = -2
pub const HPACK_ERR_OVERFLOW: i32 = -3
pub const HPACK_ERR_HUFFMAN: i32 = -4
pub const HPACK_ERR_INDEX: i32 = -5

# ============================================================================
# Static Table
# ============================================================================
#
# The static table consists of 61 entries indexed from 1 to 61.
# Index 0 is not used.
#
# Entry format: (name, value)
# Some entries have empty values (just the header name).

pub struct HpackEntry
    name: Span<u8>
    value: Span<u8>

# Static table size (indices 1-61)
pub const HPACK_STATIC_TABLE_SIZE: i32 = 61

# Static table entries (indexed 1-61 per RFC 7541 Appendix A)
# Index 0 is unused, so we have 62 entries total.

pub fn hpack_static_table_get(index: i32, entry: *HpackEntry) -> i32
    if index < 1 || index > HPACK_STATIC_TABLE_SIZE
        return HPACK_ERR_INDEX

    # Pseudo-headers and common headers
    if index == 1
        entry.name = span_from_cstr(c":authority")
        entry.value = span_empty<u8>()
    else if index == 2
        entry.name = span_from_cstr(c":method")
        entry.value = span_from_cstr(c"GET")
    else if index == 3
        entry.name = span_from_cstr(c":method")
        entry.value = span_from_cstr(c"POST")
    else if index == 4
        entry.name = span_from_cstr(c":path")
        entry.value = span_from_cstr(c"/")
    else if index == 5
        entry.name = span_from_cstr(c":path")
        entry.value = span_from_cstr(c"/index.html")
    else if index == 6
        entry.name = span_from_cstr(c":scheme")
        entry.value = span_from_cstr(c"http")
    else if index == 7
        entry.name = span_from_cstr(c":scheme")
        entry.value = span_from_cstr(c"https")
    else if index == 8
        entry.name = span_from_cstr(c":status")
        entry.value = span_from_cstr(c"200")
    else if index == 9
        entry.name = span_from_cstr(c":status")
        entry.value = span_from_cstr(c"204")
    else if index == 10
        entry.name = span_from_cstr(c":status")
        entry.value = span_from_cstr(c"206")
    else if index == 11
        entry.name = span_from_cstr(c":status")
        entry.value = span_from_cstr(c"304")
    else if index == 12
        entry.name = span_from_cstr(c":status")
        entry.value = span_from_cstr(c"400")
    else if index == 13
        entry.name = span_from_cstr(c":status")
        entry.value = span_from_cstr(c"404")
    else if index == 14
        entry.name = span_from_cstr(c":status")
        entry.value = span_from_cstr(c"500")
    else if index == 15
        entry.name = span_from_cstr(c"accept-charset")
        entry.value = span_empty<u8>()
    else if index == 16
        entry.name = span_from_cstr(c"accept-encoding")
        entry.value = span_from_cstr(c"gzip, deflate")
    else if index == 17
        entry.name = span_from_cstr(c"accept-language")
        entry.value = span_empty<u8>()
    else if index == 18
        entry.name = span_from_cstr(c"accept-ranges")
        entry.value = span_empty<u8>()
    else if index == 19
        entry.name = span_from_cstr(c"accept")
        entry.value = span_empty<u8>()
    else if index == 20
        entry.name = span_from_cstr(c"access-control-allow-origin")
        entry.value = span_empty<u8>()
    else if index == 21
        entry.name = span_from_cstr(c"age")
        entry.value = span_empty<u8>()
    else if index == 22
        entry.name = span_from_cstr(c"allow")
        entry.value = span_empty<u8>()
    else if index == 23
        entry.name = span_from_cstr(c"authorization")
        entry.value = span_empty<u8>()
    else if index == 24
        entry.name = span_from_cstr(c"cache-control")
        entry.value = span_empty<u8>()
    else if index == 25
        entry.name = span_from_cstr(c"content-disposition")
        entry.value = span_empty<u8>()
    else if index == 26
        entry.name = span_from_cstr(c"content-encoding")
        entry.value = span_empty<u8>()
    else if index == 27
        entry.name = span_from_cstr(c"content-language")
        entry.value = span_empty<u8>()
    else if index == 28
        entry.name = span_from_cstr(c"content-length")
        entry.value = span_empty<u8>()
    else if index == 29
        entry.name = span_from_cstr(c"content-location")
        entry.value = span_empty<u8>()
    else if index == 30
        entry.name = span_from_cstr(c"content-range")
        entry.value = span_empty<u8>()
    else if index == 31
        entry.name = span_from_cstr(c"content-type")
        entry.value = span_empty<u8>()
    else if index == 32
        entry.name = span_from_cstr(c"cookie")
        entry.value = span_empty<u8>()
    else if index == 33
        entry.name = span_from_cstr(c"date")
        entry.value = span_empty<u8>()
    else if index == 34
        entry.name = span_from_cstr(c"etag")
        entry.value = span_empty<u8>()
    else if index == 35
        entry.name = span_from_cstr(c"expect")
        entry.value = span_empty<u8>()
    else if index == 36
        entry.name = span_from_cstr(c"expires")
        entry.value = span_empty<u8>()
    else if index == 37
        entry.name = span_from_cstr(c"from")
        entry.value = span_empty<u8>()
    else if index == 38
        entry.name = span_from_cstr(c"host")
        entry.value = span_empty<u8>()
    else if index == 39
        entry.name = span_from_cstr(c"if-match")
        entry.value = span_empty<u8>()
    else if index == 40
        entry.name = span_from_cstr(c"if-modified-since")
        entry.value = span_empty<u8>()
    else if index == 41
        entry.name = span_from_cstr(c"if-none-match")
        entry.value = span_empty<u8>()
    else if index == 42
        entry.name = span_from_cstr(c"if-range")
        entry.value = span_empty<u8>()
    else if index == 43
        entry.name = span_from_cstr(c"if-unmodified-since")
        entry.value = span_empty<u8>()
    else if index == 44
        entry.name = span_from_cstr(c"last-modified")
        entry.value = span_empty<u8>()
    else if index == 45
        entry.name = span_from_cstr(c"link")
        entry.value = span_empty<u8>()
    else if index == 46
        entry.name = span_from_cstr(c"location")
        entry.value = span_empty<u8>()
    else if index == 47
        entry.name = span_from_cstr(c"max-forwards")
        entry.value = span_empty<u8>()
    else if index == 48
        entry.name = span_from_cstr(c"proxy-authenticate")
        entry.value = span_empty<u8>()
    else if index == 49
        entry.name = span_from_cstr(c"proxy-authorization")
        entry.value = span_empty<u8>()
    else if index == 50
        entry.name = span_from_cstr(c"range")
        entry.value = span_empty<u8>()
    else if index == 51
        entry.name = span_from_cstr(c"referer")
        entry.value = span_empty<u8>()
    else if index == 52
        entry.name = span_from_cstr(c"refresh")
        entry.value = span_empty<u8>()
    else if index == 53
        entry.name = span_from_cstr(c"retry-after")
        entry.value = span_empty<u8>()
    else if index == 54
        entry.name = span_from_cstr(c"server")
        entry.value = span_empty<u8>()
    else if index == 55
        entry.name = span_from_cstr(c"set-cookie")
        entry.value = span_empty<u8>()
    else if index == 56
        entry.name = span_from_cstr(c"strict-transport-security")
        entry.value = span_empty<u8>()
    else if index == 57
        entry.name = span_from_cstr(c"transfer-encoding")
        entry.value = span_empty<u8>()
    else if index == 58
        entry.name = span_from_cstr(c"user-agent")
        entry.value = span_empty<u8>()
    else if index == 59
        entry.name = span_from_cstr(c"vary")
        entry.value = span_empty<u8>()
    else if index == 60
        entry.name = span_from_cstr(c"via")
        entry.value = span_empty<u8>()
    else if index == 61
        entry.name = span_from_cstr(c"www-authenticate")
        entry.value = span_empty<u8>()
    else
        return HPACK_ERR_INDEX

    return HPACK_OK

# Search static table for name match
# Returns index (1-61) if found, 0 if not found
pub fn hpack_static_table_find_name(name: *Span<u8>) -> i32
    var entry: HpackEntry
    var i: i32 = 1
    while i <= HPACK_STATIC_TABLE_SIZE
        hpack_static_table_get(i, @entry)
        if span_eq(name, @entry.name) == 1
            return i
        i += 1
    return 0

# Search static table for exact name+value match
# Returns index (1-61) if found, 0 if not found
pub fn hpack_static_table_find(name: *Span<u8>, value: *Span<u8>) -> i32
    var entry: HpackEntry
    var i: i32 = 1
    while i <= HPACK_STATIC_TABLE_SIZE
        hpack_static_table_get(i, @entry)
        if span_eq(name, @entry.name) == 1 && span_eq(value, @entry.value) == 1
            return i
        i += 1
    return 0

# ============================================================================
# Integer Encoding/Decoding (RFC 7541 Section 5.1)
# ============================================================================
#
# HPACK uses a variable-length integer encoding with a prefix.
# The prefix length N determines the maximum value that fits in the first byte.
# If the value is less than 2^N - 1, it fits in the prefix bits.
# Otherwise, 2^N - 1 is stored in the prefix and the remaining value is
# encoded in subsequent bytes using 7 bits per byte with a continuation bit.

# Decode an integer with N-bit prefix
# Returns bytes consumed, or negative error code
pub fn hpack_decode_int(input: *Span<u8>, prefix_bits: i32, value: *i64) -> i32
    if input.len < 1
        return HPACK_ERR_INCOMPLETE

    let prefix_mask: i32 = (1 << prefix_bits) - 1
    let first_byte: i32 = *(input.ptr) as i32
    let prefix_value: i32 = first_byte & prefix_mask

    if prefix_value < prefix_mask
        # Value fits in prefix
        *value = prefix_value as i64
        return 1

    # Value doesn't fit, read continuation bytes
    var result: i64 = prefix_mask as i64
    var shift: i32 = 0
    var pos: i64 = 1

    while pos < input.len
        let byte: i32 = *(input.ptr + pos) as i32
        let chunk: i64 = (byte & 0x7F) as i64
        result = result + (chunk << shift)
        pos += 1

        if (byte & 0x80) == 0
            # No more continuation bytes
            *value = result
            return pos as i32

        shift += 7

        # Check for overflow (max 8 continuation bytes = 56 bits)
        if shift > 56
            return HPACK_ERR_OVERFLOW

    return HPACK_ERR_INCOMPLETE

# Encode an integer with N-bit prefix
# Returns bytes written, or negative error code
pub fn hpack_encode_int(buf: *u8, buf_len: i32, value: i64, prefix_bits: i32, prefix_byte: i32) -> i32
    if buf_len < 1
        return HPACK_ERR_INCOMPLETE

    let prefix_mask: i32 = (1 << prefix_bits) - 1

    if value < prefix_mask as i64
        # Value fits in prefix
        *buf = (prefix_byte | (value as i32)) as u8
        return 1

    # Value doesn't fit, use continuation bytes
    *buf = (prefix_byte | prefix_mask) as u8
    var pos: i32 = 1
    var remaining: i64 = value - (prefix_mask as i64)

    while remaining >= 128
        if pos >= buf_len
            return HPACK_ERR_INCOMPLETE
        *(buf + pos) = ((remaining & 0x7F) | 0x80) as u8
        remaining = remaining >> 7
        pos += 1

    if pos >= buf_len
        return HPACK_ERR_INCOMPLETE
    *(buf + pos) = (remaining & 0x7F) as u8
    pos += 1

    return pos

# ============================================================================
# String Encoding/Decoding (RFC 7541 Section 5.2)
# ============================================================================
#
# Strings can be encoded as either:
# - Literal (first bit = 0): length followed by raw bytes
# - Huffman (first bit = 1): length followed by Huffman-encoded bytes
#
# For now, we only support literal strings. Huffman encoding can be added later.

# Decode a string (literal only for now)
# Returns bytes consumed, or negative error code
pub fn hpack_decode_string(input: *Span<u8>, output: *Span<u8>) -> i32
    if input.len < 1
        return HPACK_ERR_INCOMPLETE

    let first_byte: i32 = *(input.ptr) as i32
    let huffman: i32 = (first_byte >> 7) & 1

    # Decode length (7-bit prefix)
    var length: i64 = 0
    var sub_input: Span<u8> = *input
    let len_bytes: i32 = hpack_decode_int(@sub_input, 7, @length)
    if len_bytes < 0
        return len_bytes

    # Check we have enough data
    let total_bytes: i64 = (len_bytes as i64) + length
    if input.len < total_bytes
        return HPACK_ERR_INCOMPLETE

    if huffman == 1
        # Huffman decoding not implemented yet
        return HPACK_ERR_HUFFMAN

    # Literal string - just point to the data
    output.ptr = input.ptr + len_bytes
    output.len = length

    return total_bytes as i32

# Encode a string (literal, no Huffman)
# Returns bytes written, or negative error code
pub fn hpack_encode_string(buf: *u8, buf_len: i32, input: *Span<u8>) -> i32
    # Encode length with 7-bit prefix, high bit = 0 for literal
    let len_bytes: i32 = hpack_encode_int(buf, buf_len, input.len, 7, 0)
    if len_bytes < 0
        return len_bytes

    # Copy string data
    if (len_bytes as i64) + input.len > buf_len as i64
        return HPACK_ERR_INCOMPLETE

    var i: i64 = 0
    while i < input.len
        *(buf + len_bytes + i) = *(input.ptr + i)
        i += 1

    return len_bytes + (input.len as i32)

# ============================================================================
# Dynamic Table (RFC 7541 Section 2.3)
# ============================================================================
#
# The dynamic table is a FIFO (newest at front, oldest at back).
# Entries are indexed starting at STATIC_TABLE_SIZE + 1.
# When the table size exceeds the max, oldest entries are evicted.
#
# Each entry has an overhead of 32 bytes per RFC 7541 Section 4.1.

pub const HPACK_ENTRY_OVERHEAD: i64 = 32

# Maximum entries in dynamic table (practical limit)
# Reduced from 256 to 64 for smaller struct size
pub const HPACK_MAX_DYNAMIC_ENTRIES: i32 = 64

pub struct HpackDynamicTable
    entries: [64]HpackEntry     # Ring buffer of entries
    # Storage for name/value data (reduced from 64KB to 8KB for smaller struct)
    storage: [8192]u8
    storage_pos: i64            # Next write position in storage
    head: i32                   # Index of newest entry
    count: i32                  # Number of entries
    size: i64                   # Current size in bytes (including overhead)
    max_size: i64               # Maximum size in bytes

pub fn hpack_dynamic_table_init(table: *HpackDynamicTable, max_size: i64)
    table.storage_pos = 0
    table.head = 0
    table.count = 0
    table.size = 0
    table.max_size = max_size

# Get entry from dynamic table
# Index is 1-based (1 = newest entry)
pub fn hpack_dynamic_table_get(table: *HpackDynamicTable, index: i32, entry: *HpackEntry) -> i32
    if index < 1 || index > table.count
        return HPACK_ERR_INDEX

    # Calculate actual position in ring buffer
    let pos: i32 = (table.head - index + 1 + HPACK_MAX_DYNAMIC_ENTRIES) % HPACK_MAX_DYNAMIC_ENTRIES
    entry.name = table.entries[pos].name
    entry.value = table.entries[pos].value

    return HPACK_OK

# Calculate size of an entry (name + value + overhead)
fn hpack_entry_size(name: *Span<u8>, value: *Span<u8>) -> i64
    return name.len + value.len + HPACK_ENTRY_OVERHEAD

# Evict oldest entries until size <= max_size
fn hpack_dynamic_table_evict(table: *HpackDynamicTable)
    while table.size > table.max_size && table.count > 0
        # Calculate oldest entry position
        let oldest: i32 = (table.head - table.count + 1 + HPACK_MAX_DYNAMIC_ENTRIES) % HPACK_MAX_DYNAMIC_ENTRIES
        let entry_size: i64 = hpack_entry_size(@table.entries[oldest].name, @table.entries[oldest].value)
        table.size -= entry_size
        table.count -= 1

# Add entry to dynamic table (at front)
pub fn hpack_dynamic_table_add(table: *HpackDynamicTable, name: *Span<u8>, value: *Span<u8>) -> i32
    let entry_size: i64 = hpack_entry_size(name, value)

    # If entry is larger than max table size, clear table and return
    if entry_size > table.max_size
        table.count = 0
        table.size = 0
        table.storage_pos = 0
        return HPACK_OK

    # Evict until we have space
    table.size += entry_size
    hpack_dynamic_table_evict(table)

    # Check if we have storage space (wrap around if needed)
    let needed: i64 = name.len + value.len
    if table.storage_pos + needed > 8192
        # Simple approach: reset storage (real implementation would be smarter)
        table.storage_pos = 0

    # Copy name
    var name_start: i64 = table.storage_pos
    var i: i64 = 0
    while i < name.len
        table.storage[table.storage_pos] = *(name.ptr + i)
        table.storage_pos += 1
        i += 1

    # Copy value
    var value_start: i64 = table.storage_pos
    i = 0
    while i < value.len
        table.storage[table.storage_pos] = *(value.ptr + i)
        table.storage_pos += 1
        i += 1

    # Move head forward
    table.head = (table.head + 1) % HPACK_MAX_DYNAMIC_ENTRIES
    table.count += 1

    # Store entry
    table.entries[table.head].name.ptr = @table.storage[name_start]
    table.entries[table.head].name.len = name.len
    table.entries[table.head].value.ptr = @table.storage[value_start]
    table.entries[table.head].value.len = value.len

    return HPACK_OK

# Update maximum table size (may cause evictions)
pub fn hpack_dynamic_table_set_max_size(table: *HpackDynamicTable, max_size: i64)
    table.max_size = max_size
    hpack_dynamic_table_evict(table)

# Search dynamic table for name match
# Returns dynamic index (1-based) if found, 0 if not found
pub fn hpack_dynamic_table_find_name(table: *HpackDynamicTable, name: *Span<u8>) -> i32
    var i: i32 = 1
    while i <= table.count
        var entry: HpackEntry
        hpack_dynamic_table_get(table, i, @entry)
        if span_eq(name, @entry.name) == 1
            return i
        i += 1
    return 0

# Search dynamic table for exact name+value match
# Returns dynamic index (1-based) if found, 0 if not found
pub fn hpack_dynamic_table_find(table: *HpackDynamicTable, name: *Span<u8>, value: *Span<u8>) -> i32
    var i: i32 = 1
    while i <= table.count
        var entry: HpackEntry
        hpack_dynamic_table_get(table, i, @entry)
        if span_eq(name, @entry.name) == 1 && span_eq(value, @entry.value) == 1
            return i
        i += 1
    return 0

# ============================================================================
# HPACK Decoder (RFC 7541 Section 6)
# ============================================================================
#
# Header field representations:
# - 1xxxxxxx: Indexed header field (index in 7 bits)
# - 01xxxxxx: Literal with incremental indexing (name index in 6 bits)
# - 0000xxxx: Literal without indexing (name index in 4 bits)
# - 0001xxxx: Literal never indexed (name index in 4 bits)
# - 001xxxxx: Dynamic table size update (size in 5 bits)

# Decoded header representation
pub struct HpackHeader
    name: Span<u8>
    value: Span<u8>

# Maximum headers we can decode
# Maximum headers we can decode (reduced from 128 to 64 for smaller struct)
pub const HPACK_MAX_HEADERS: i32 = 64

# Decoder context
pub struct HpackDecoder
    table: HpackDynamicTable
    headers: [64]HpackHeader
    header_count: i32

pub fn hpack_decoder_init(decoder: *HpackDecoder, max_table_size: i64)
    hpack_dynamic_table_init(@decoder.table, max_table_size)
    decoder.header_count = 0

# Get entry from combined static+dynamic table
# Index 1-61: static table
# Index 62+: dynamic table (62 = newest dynamic entry)
fn hpack_get_entry(decoder: *HpackDecoder, index: i32, entry: *HpackEntry) -> i32
    if index < 1
        return HPACK_ERR_INDEX

    if index <= HPACK_STATIC_TABLE_SIZE
        return hpack_static_table_get(index, entry)

    # Dynamic table index (1-based from static table end)
    let dyn_index: i32 = index - HPACK_STATIC_TABLE_SIZE
    return hpack_dynamic_table_get(@decoder.table, dyn_index, entry)

# Decode a single header field representation
# Returns bytes consumed, or negative error code
fn hpack_decode_header_field(decoder: *HpackDecoder, input: *Span<u8>, header: *HpackHeader) -> i32
    if input.len < 1
        return HPACK_ERR_INCOMPLETE

    let first_byte: i32 = *(input.ptr) as i32
    var pos: i32 = 0

    if (first_byte & 0x80) != 0
        # Indexed header field (1xxxxxxx)
        var index: i64 = 0
        let consumed: i32 = hpack_decode_int(input, 7, @index)
        if consumed < 0
            return consumed

        if index == 0
            return HPACK_ERR_INDEX

        var entry: HpackEntry
        let result: i32 = hpack_get_entry(decoder, index as i32, @entry)
        if result < 0
            return result

        header.name = entry.name
        header.value = entry.value
        return consumed

    else if (first_byte & 0xC0) == 0x40
        # Literal with incremental indexing (01xxxxxx)
        var index: i64 = 0
        var sub_input: Span<u8> = *input
        let idx_consumed: i32 = hpack_decode_int(@sub_input, 6, @index)
        if idx_consumed < 0
            return idx_consumed
        pos += idx_consumed

        if index > 0
            # Name from table
            var entry: HpackEntry
            let result: i32 = hpack_get_entry(decoder, index as i32, @entry)
            if result < 0
                return result
            header.name = entry.name
        else
            # Literal name
            sub_input.ptr = input.ptr + pos
            sub_input.len = input.len - (pos as i64)
            let name_consumed: i32 = hpack_decode_string(@sub_input, @header.name)
            if name_consumed < 0
                return name_consumed
            pos += name_consumed

        # Literal value
        sub_input.ptr = input.ptr + pos
        sub_input.len = input.len - (pos as i64)
        let val_consumed: i32 = hpack_decode_string(@sub_input, @header.value)
        if val_consumed < 0
            return val_consumed
        pos += val_consumed

        # Add to dynamic table
        hpack_dynamic_table_add(@decoder.table, @header.name, @header.value)

        return pos

    else if (first_byte & 0xF0) == 0x00
        # Literal without indexing (0000xxxx)
        var index: i64 = 0
        var sub_input: Span<u8> = *input
        let idx_consumed: i32 = hpack_decode_int(@sub_input, 4, @index)
        if idx_consumed < 0
            return idx_consumed
        pos += idx_consumed

        if index > 0
            var entry: HpackEntry
            let result: i32 = hpack_get_entry(decoder, index as i32, @entry)
            if result < 0
                return result
            header.name = entry.name
        else
            sub_input.ptr = input.ptr + pos
            sub_input.len = input.len - (pos as i64)
            let name_consumed: i32 = hpack_decode_string(@sub_input, @header.name)
            if name_consumed < 0
                return name_consumed
            pos += name_consumed

        sub_input.ptr = input.ptr + pos
        sub_input.len = input.len - (pos as i64)
        let val_consumed: i32 = hpack_decode_string(@sub_input, @header.value)
        if val_consumed < 0
            return val_consumed
        pos += val_consumed

        # Do NOT add to dynamic table
        return pos

    else if (first_byte & 0xF0) == 0x10
        # Literal never indexed (0001xxxx)
        # Same as without indexing, but signals sensitive data
        var index: i64 = 0
        var sub_input: Span<u8> = *input
        let idx_consumed: i32 = hpack_decode_int(@sub_input, 4, @index)
        if idx_consumed < 0
            return idx_consumed
        pos += idx_consumed

        if index > 0
            var entry: HpackEntry
            let result: i32 = hpack_get_entry(decoder, index as i32, @entry)
            if result < 0
                return result
            header.name = entry.name
        else
            sub_input.ptr = input.ptr + pos
            sub_input.len = input.len - (pos as i64)
            let name_consumed: i32 = hpack_decode_string(@sub_input, @header.name)
            if name_consumed < 0
                return name_consumed
            pos += name_consumed

        sub_input.ptr = input.ptr + pos
        sub_input.len = input.len - (pos as i64)
        let val_consumed: i32 = hpack_decode_string(@sub_input, @header.value)
        if val_consumed < 0
            return val_consumed
        pos += val_consumed

        return pos

    else if (first_byte & 0xE0) == 0x20
        # Dynamic table size update (001xxxxx)
        var new_size: i64 = 0
        let consumed: i32 = hpack_decode_int(input, 5, @new_size)
        if consumed < 0
            return consumed

        hpack_dynamic_table_set_max_size(@decoder.table, new_size)

        # Signal that this wasn't a header (caller should continue)
        header.name.ptr = null
        header.name.len = 0
        header.value.ptr = null
        header.value.len = 0
        return consumed

    return HPACK_ERR_INVALID

# Decode a complete header block
# Returns HPACK_OK on success, or negative error code
pub fn hpack_decode(decoder: *HpackDecoder, input: *Span<u8>) -> i32
    decoder.header_count = 0
    var pos: i64 = 0

    while pos < input.len
        if decoder.header_count >= HPACK_MAX_HEADERS
            return HPACK_ERR_OVERFLOW

        var sub_input: Span<u8>
        sub_input.ptr = input.ptr + pos
        sub_input.len = input.len - pos

        var header: HpackHeader
        let consumed: i32 = hpack_decode_header_field(decoder, @sub_input, @header)
        if consumed < 0
            return consumed

        pos += consumed as i64

        # Skip table size updates (they set name.ptr to null)
        if header.name.ptr != null
            decoder.headers[decoder.header_count] = header
            decoder.header_count += 1

    return HPACK_OK

# ============================================================================
# HPACK Encoder (RFC 7541 Section 6)
# ============================================================================

# Encoder context
pub struct HpackEncoder
    table: HpackDynamicTable

pub fn hpack_encoder_init(encoder: *HpackEncoder, max_table_size: i64)
    hpack_dynamic_table_init(@encoder.table, max_table_size)

# Get index from combined static+dynamic table for exact match
# Returns index (1+) if found, 0 if not found
fn hpack_encoder_find(encoder: *HpackEncoder, name: *Span<u8>, value: *Span<u8>) -> i32
    # Check static table first
    let static_idx: i32 = hpack_static_table_find(name, value)
    if static_idx > 0
        return static_idx

    # Check dynamic table
    let dyn_idx: i32 = hpack_dynamic_table_find(@encoder.table, name, value)
    if dyn_idx > 0
        return HPACK_STATIC_TABLE_SIZE + dyn_idx

    return 0

# Get index for name-only match
fn hpack_encoder_find_name(encoder: *HpackEncoder, name: *Span<u8>) -> i32
    let static_idx: i32 = hpack_static_table_find_name(name)
    if static_idx > 0
        return static_idx

    let dyn_idx: i32 = hpack_dynamic_table_find_name(@encoder.table, name)
    if dyn_idx > 0
        return HPACK_STATIC_TABLE_SIZE + dyn_idx

    return 0

# Encode a header using indexed representation
# Returns bytes written, or negative error code
pub fn hpack_encode_indexed(buf: *u8, buf_len: i32, index: i32) -> i32
    return hpack_encode_int(buf, buf_len, index as i64, 7, 0x80)

# Encode a header with incremental indexing
# Returns bytes written, or negative error code
pub fn hpack_encode_literal_indexed(encoder: *HpackEncoder, buf: *u8, buf_len: i32, name: *Span<u8>, value: *Span<u8>) -> i32
    var pos: i32 = 0

    # Try to find name in table
    let name_idx: i32 = hpack_encoder_find_name(encoder, name)

    if name_idx > 0
        # Name indexed, value literal
        let idx_written: i32 = hpack_encode_int(buf, buf_len, name_idx as i64, 6, 0x40)
        if idx_written < 0
            return idx_written
        pos += idx_written
    else
        # Both literal
        if buf_len < 1
            return HPACK_ERR_INCOMPLETE
        *buf = 0x40
        pos += 1

        let name_written: i32 = hpack_encode_string(buf + pos, buf_len - pos, name)
        if name_written < 0
            return name_written
        pos += name_written

    # Encode value
    let val_written: i32 = hpack_encode_string(buf + pos, buf_len - pos, value)
    if val_written < 0
        return val_written
    pos += val_written

    # Add to dynamic table
    hpack_dynamic_table_add(@encoder.table, name, value)

    return pos

# Encode a header without indexing
# Returns bytes written, or negative error code
pub fn hpack_encode_literal(buf: *u8, buf_len: i32, name_idx: i32, name: *Span<u8>, value: *Span<u8>) -> i32
    var pos: i32 = 0

    if name_idx > 0
        let idx_written: i32 = hpack_encode_int(buf, buf_len, name_idx as i64, 4, 0x00)
        if idx_written < 0
            return idx_written
        pos += idx_written
    else
        if buf_len < 1
            return HPACK_ERR_INCOMPLETE
        *buf = 0x00
        pos += 1

        let name_written: i32 = hpack_encode_string(buf + pos, buf_len - pos, name)
        if name_written < 0
            return name_written
        pos += name_written

    let val_written: i32 = hpack_encode_string(buf + pos, buf_len - pos, value)
    if val_written < 0
        return val_written
    pos += val_written

    return pos

# Encode a header never indexed (sensitive data)
pub fn hpack_encode_never_indexed(buf: *u8, buf_len: i32, name_idx: i32, name: *Span<u8>, value: *Span<u8>) -> i32
    var pos: i32 = 0

    if name_idx > 0
        let idx_written: i32 = hpack_encode_int(buf, buf_len, name_idx as i64, 4, 0x10)
        if idx_written < 0
            return idx_written
        pos += idx_written
    else
        if buf_len < 1
            return HPACK_ERR_INCOMPLETE
        *buf = 0x10
        pos += 1

        let name_written: i32 = hpack_encode_string(buf + pos, buf_len - pos, name)
        if name_written < 0
            return name_written
        pos += name_written

    let val_written: i32 = hpack_encode_string(buf + pos, buf_len - pos, value)
    if val_written < 0
        return val_written
    pos += val_written

    return pos

# Encode a dynamic table size update
pub fn hpack_encode_table_size_update(buf: *u8, buf_len: i32, new_size: i64) -> i32
    return hpack_encode_int(buf, buf_len, new_size, 5, 0x20)

# Encode a header automatically choosing the best representation
# Returns bytes written, or negative error code
pub fn hpack_encode_header(encoder: *HpackEncoder, buf: *u8, buf_len: i32, name: *Span<u8>, value: *Span<u8>) -> i32
    # Try to find exact match
    let exact_idx: i32 = hpack_encoder_find(encoder, name, value)
    if exact_idx > 0
        # Use indexed representation
        return hpack_encode_indexed(buf, buf_len, exact_idx)

    # Use literal with incremental indexing
    return hpack_encode_literal_indexed(encoder, buf, buf_len, name, value)
