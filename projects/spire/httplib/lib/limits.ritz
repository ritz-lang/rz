# lib/limits.ritz - Consolidated protocol limits and magic numbers
#
# This module provides common limits used across the HTTP library.
# Protocol-specific constants remain in their respective modules,
# but shared values are consolidated here for consistency.

# ============================================================================
# HTTP/1.x Limits
# ============================================================================

# Maximum number of headers in a single HTTP/1.x request or response
pub const H1_MAX_HEADERS: i32 = 64

# ============================================================================
# HTTP/2 Limits
# ============================================================================

# Maximum concurrent streams per connection (RFC 7540 default: unlimited)
# We use a reasonable limit for implementation
pub const H2_MAX_STREAMS: i32 = 128

# HPACK dynamic table limits
pub const HPACK_MAX_DYNAMIC_ENTRIES: i32 = 64
pub const HPACK_DEFAULT_TABLE_SIZE: i32 = 4096

# Maximum headers per HPACK block
pub const HPACK_MAX_HEADERS: i32 = 64

# ============================================================================
# HTTP/3 Limits
# ============================================================================

# Maximum concurrent streams for HTTP/3
pub const H3_MAX_STREAMS: i32 = 64

# Maximum settings per SETTINGS frame
pub const H3_MAX_SETTINGS: i32 = 16

# QPACK table limits (RFC 9204)
pub const QPACK_MAX_DYNAMIC_TABLE_SIZE: i32 = 4096
pub const QPACK_MAX_ENTRIES: i32 = 64

# ============================================================================
# QUIC Transport Limits
# ============================================================================

# Maximum Connection ID length (RFC 9000 Section 17.2)
pub const QUIC_MAX_CID_LEN: i32 = 20

# Minimum Connection ID length
pub const QUIC_MIN_CID_LEN: i32 = 0

# Maximum active Connection IDs per endpoint
pub const QUIC_MAX_ACTIVE_CIDS: i32 = 8

# Maximum concurrent paths for connection migration
pub const QUIC_MAX_PATHS: i32 = 4

# Maximum sent packets to track for loss detection
pub const QUIC_MAX_SENT_PACKETS: i32 = 256

# Maximum datagram size (RFC 9000 recommends 1200 for initial packets)
pub const QUIC_MAX_DATAGRAM_SIZE: i64 = 1200

# ============================================================================
# Async I/O Limits
# ============================================================================

# Default buffer sizes for async HTTP connections
pub const ASYNC_READ_BUF_SIZE: i32 = 8192
pub const ASYNC_WRITE_BUF_SIZE: i32 = 8192

