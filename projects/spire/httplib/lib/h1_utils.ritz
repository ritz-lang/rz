# lib/h1_utils.ritz - Shared utility functions for HTTP/1.x parsing
#
# These functions are used by both h1_request.ritz and h1_response.ritz

import ritzlib.span

# ============================================================================
# Common Error Codes for HTTP/1.x parsing
# ============================================================================

pub const H1_OK: i32 = 0
pub const H1_ERR_INCOMPLETE: i32 = -1
pub const H1_ERR_INVALID: i32 = -2
pub const H1_ERR_TOO_MANY_HEADERS: i32 = -3

# Find a byte in a span starting at position start
# Returns the index or -1 if not found
pub fn find_byte(s: *Span<u8>, start: i64, c: u8) -> i64
    var i: i64 = start
    while i < s.len
        if *(s.ptr + i) == c
            return i
        i = i + 1
    return -1

# Find CRLF (\r\n) in a span starting at position start
# Returns the index of \r or -1 if not found
pub fn find_crlf(s: *Span<u8>, start: i64) -> i64
    var i: i64 = start
    while i < s.len - 1
        if *(s.ptr + i) == '\r' && *(s.ptr + i + 1) == '\n'
            return i
        i = i + 1
    return -1

# Check if a byte is ASCII whitespace (space or tab)
pub fn is_whitespace(c: u8) -> i32
    if c == ' ' || c == '\t'
        return 1
    return 0

# Convert a byte to lowercase (ASCII only)
pub fn to_lower(c: u8) -> u8
    if c >= 'A' && c <= 'Z'
        return c + 32
    return c

# Case-insensitive comparison of span to C string
# Returns 1 if equal, 0 otherwise
pub fn span_eq_cstr_ci(s: *Span<u8>, cstr: *u8) -> i32
    var i: i64 = 0
    while i < s.len
        let c1: u8 = to_lower(*(s.ptr + i))
        let c2: u8 = to_lower(*(cstr + i))
        if c2 == 0
            # C string ended early
            return 0
        if c1 != c2
            return 0
        i = i + 1
    # Check that C string also ended
    if *(cstr + i) != 0
        return 0
    return 1

# Parse a decimal integer from a span
# Returns the value on success, -1 on error (non-numeric or overflow)
# Note: Valid Content-Length values are non-negative, so -1 is unambiguous
pub fn parse_content_length(s: *Span<u8>) -> i64
    # Empty span is an error
    if s.len == 0
        return -1

    var result: i64 = 0
    var i: i64 = 0

    # Maximum safe value before multiplication: (2^63 - 1) / 10 = 922337203685477580
    let max_before_mul: i64 = 922337203685477580

    while i < s.len
        let c: u8 = *(s.ptr + i)
        if c < '0' || c > '9'
            return -1

        # Check for overflow before multiplying
        if result > max_before_mul
            return -1

        let digit: i64 = (c - '0') as i64
        let new_result: i64 = result * 10 + digit

        # Check for overflow after addition (if result wrapped negative)
        if new_result < result
            return -1

        result = new_result
        i = i + 1

    return result
