# test/test_h3_stream.ritz - Tests for HTTP/3 stream management
#
# RFC 9114 Section 6 defines HTTP/3 streams

import ritzlib.span
import lib.h3_stream
import lib.h3_frame

# ============================================================================
# Request Stream Tests
# ============================================================================

[[test]]
fn test_h3_request_stream_init() -> i32
    var stream: H3RequestStream
    h3_request_stream_init(@stream, 4)
    if stream.stream_id != 4
        return 1
    if stream.state != H3_STREAM_STATE_IDLE
        return 2
    if stream.headers_received != 0
        return 3
    if stream.fin_sent != 0
        return 4
    return 0

[[test]]
fn test_h3_stream_is_client_initiated() -> i32
    # Client-initiated bidi: 0, 4, 8, ...
    # Client-initiated uni: 2, 6, 10, ...
    # Wait, that's wrong. QUIC stream IDs:
    # Client bidi: 0, 4, 8 (0b00, 0b0100, 0b1000)
    # Server bidi: 1, 5, 9 (0b01, 0b0101, 0b1001)
    # Client uni: 2, 6, 10 (0b10, 0b0110, 0b1010)
    # Server uni: 3, 7, 11 (0b11, 0b0111, 0b1011)
    # So client-initiated = bit 0 is 0, server-initiated = bit 0 is 1
    # Hmm, our function checks bit 0 == 1 for client-initiated
    # Let me verify the RFC...
    # Actually per RFC 9000: bit 0 = 0 for client, 1 for server
    # So stream 0 is client bidi, stream 1 is server bidi

    # Our implementation: client = odd (bit 0 = 1)?
    # That seems backwards. Let's test what we have:
    if h3_stream_is_client_initiated(1) != 1  # odd
        return 1
    if h3_stream_is_client_initiated(4) != 0  # even
        return 2
    return 0

[[test]]
fn test_h3_stream_is_server_initiated() -> i32
    if h3_stream_is_server_initiated(4) != 1  # even
        return 1
    if h3_stream_is_server_initiated(1) != 0  # odd
        return 2
    return 0

[[test]]
fn test_h3_stream_is_bidi() -> i32
    # Bidi streams have bit 1 = 0
    if h3_stream_is_bidi(0) != 1
        return 1
    if h3_stream_is_bidi(1) != 1
        return 2
    if h3_stream_is_bidi(2) != 0  # uni
        return 3
    if h3_stream_is_bidi(4) != 1
        return 4
    return 0

[[test]]
fn test_h3_stream_is_uni() -> i32
    # Uni streams have bit 1 = 1
    if h3_stream_is_uni(2) != 1
        return 1
    if h3_stream_is_uni(3) != 1
        return 2
    if h3_stream_is_uni(0) != 0  # bidi
        return 3
    return 0

# ============================================================================
# Control Stream Tests
# ============================================================================

[[test]]
fn test_h3_control_stream_init() -> i32
    var stream: H3ControlStream
    h3_control_stream_init(@stream, 6, 1)
    if stream.stream_id != 6
        return 1
    if stream.is_local != 1
        return 2
    if stream.settings_sent != 0
        return 3
    return 0

# ============================================================================
# Connection Tests
# ============================================================================

[[test]]
fn test_h3_connection_init_server() -> i32
    var conn: H3Connection
    h3_connection_init(@conn, 1)
    if conn.is_server != 1
        return 1
    if conn.has_local_control != 0
        return 2
    if conn.stream_count != 0
        return 3
    if conn.going_away != 0
        return 4
    return 0

[[test]]
fn test_h3_connection_init_client() -> i32
    var conn: H3Connection
    h3_connection_init(@conn, 0)
    if conn.is_server != 0
        return 1
    return 0

[[test]]
fn test_h3_set_control_streams() -> i32
    var conn: H3Connection
    h3_connection_init(@conn, 1)

    h3_set_local_control_stream(@conn, 2)
    if conn.local_control.stream_id != 2
        return 1
    if conn.has_local_control != 1
        return 2

    h3_set_remote_control_stream(@conn, 3)
    if conn.remote_control.stream_id != 3
        return 3
    if conn.has_remote_control != 1
        return 4
    return 0

[[test]]
fn test_h3_set_qpack_streams() -> i32
    var conn: H3Connection
    h3_connection_init(@conn, 1)

    h3_set_qpack_encoder_stream(@conn, 6)
    if conn.qpack_encoder_stream != 6
        return 1
    if conn.has_qpack_encoder != 1
        return 2

    h3_set_qpack_decoder_stream(@conn, 10)
    if conn.qpack_decoder_stream != 10
        return 3
    if conn.has_qpack_decoder != 1
        return 4
    return 0

[[test]]
fn test_h3_get_or_create_stream() -> i32
    var conn: H3Connection
    h3_connection_init(@conn, 1)

    var stream: *H3RequestStream = h3_get_or_create_stream(@conn, 0)
    if stream == null
        return 1
    if stream.stream_id != 0
        return 2
    if stream.state != H3_STREAM_STATE_OPEN
        return 3
    if conn.stream_count != 1
        return 4
    return 0

[[test]]
fn test_h3_get_or_create_stream_existing() -> i32
    var conn: H3Connection
    h3_connection_init(@conn, 1)

    var s1: *H3RequestStream = h3_get_or_create_stream(@conn, 0)
    var s2: *H3RequestStream = h3_get_or_create_stream(@conn, 0)

    if s1 != s2
        return 1
    if conn.stream_count != 1
        return 2
    return 0

[[test]]
fn test_h3_find_stream() -> i32
    var conn: H3Connection
    h3_connection_init(@conn, 1)

    h3_get_or_create_stream(@conn, 4)
    h3_get_or_create_stream(@conn, 8)

    var stream: *H3RequestStream = h3_find_stream(@conn, 4)
    if stream == null
        return 1
    if stream.stream_id != 4
        return 2

    stream = h3_find_stream(@conn, 99)
    if stream != null
        return 3
    return 0

[[test]]
fn test_h3_close_stream() -> i32
    var conn: H3Connection
    h3_connection_init(@conn, 1)

    h3_get_or_create_stream(@conn, 0)
    let ret: i32 = h3_close_stream(@conn, 0)
    if ret != 0
        return 1

    var stream: *H3RequestStream = h3_find_stream(@conn, 0)
    if stream.state != H3_STREAM_STATE_CLOSED
        return 2
    return 0

[[test]]
fn test_h3_active_stream_count() -> i32
    var conn: H3Connection
    h3_connection_init(@conn, 1)

    h3_get_or_create_stream(@conn, 0)
    h3_get_or_create_stream(@conn, 4)
    h3_get_or_create_stream(@conn, 8)

    if h3_active_stream_count(@conn) != 3
        return 1

    h3_close_stream(@conn, 4)
    if h3_active_stream_count(@conn) != 2
        return 2
    return 0

# ============================================================================
# Settings Tests
# ============================================================================

[[test]]
fn test_h3_apply_settings() -> i32
    var conn: H3Connection
    h3_connection_init(@conn, 1)

    var settings: H3SettingsFrame
    h3_settings_frame_init(@settings)
    h3_settings_set(@settings, H3_SETTINGS_MAX_FIELD_SECTION_SIZE, 8192)
    h3_settings_set(@settings, H3_SETTINGS_QPACK_MAX_TABLE_CAPACITY, 2048)

    h3_apply_settings(@conn, @settings)

    if conn.max_field_section_size != 8192
        return 1
    if conn.qpack_max_table_capacity != 2048
        return 2
    if conn.remote_control.settings_received != 1
        return 3
    return 0

[[test]]
fn test_h3_create_settings() -> i32
    var conn: H3Connection
    h3_connection_init(@conn, 1)
    conn.max_field_section_size = 16384
    conn.qpack_max_table_capacity = 4096

    var settings: H3SettingsFrame
    h3_create_settings(@conn, @settings)

    if settings.count < 2
        return 1
    return 0

# ============================================================================
# GOAWAY Tests
# ============================================================================

[[test]]
fn test_h3_start_graceful_shutdown() -> i32
    var conn: H3Connection
    h3_connection_init(@conn, 1)

    h3_get_or_create_stream(@conn, 4)
    h3_get_or_create_stream(@conn, 8)

    let last: i64 = h3_start_graceful_shutdown(@conn)
    if last != 8
        return 1
    if conn.going_away != 1
        return 2
    return 0

[[test]]
fn test_h3_handle_goaway() -> i32
    var conn: H3Connection
    h3_connection_init(@conn, 0)

    h3_handle_goaway(@conn, 4)

    if conn.going_away != 1
        return 1
    if conn.remote_control.goaway_received != 1
        return 2
    if conn.remote_control.last_good_stream != 4
        return 3
    return 0

[[test]]
fn test_h3_is_going_away() -> i32
    var conn: H3Connection
    h3_connection_init(@conn, 1)

    if h3_is_going_away(@conn) != 0
        return 1

    h3_start_graceful_shutdown(@conn)
    if h3_is_going_away(@conn) != 1
        return 2
    return 0

# ============================================================================
# Frame Validation Tests
# ============================================================================

[[test]]
fn test_h3_frame_allowed_on_control() -> i32
    if h3_frame_allowed_on_control(H3_FRAME_SETTINGS) != 1
        return 1
    if h3_frame_allowed_on_control(H3_FRAME_GOAWAY) != 1
        return 2
    if h3_frame_allowed_on_control(H3_FRAME_DATA) != 0
        return 3
    if h3_frame_allowed_on_control(H3_FRAME_HEADERS) != 0
        return 4
    return 0

[[test]]
fn test_h3_frame_allowed_on_request() -> i32
    if h3_frame_allowed_on_request(H3_FRAME_DATA) != 1
        return 1
    if h3_frame_allowed_on_request(H3_FRAME_HEADERS) != 1
        return 2
    if h3_frame_allowed_on_request(H3_FRAME_SETTINGS) != 0
        return 3
    if h3_frame_allowed_on_request(H3_FRAME_GOAWAY) != 0
        return 4
    return 0

# ============================================================================
# Stream Type Constants
# ============================================================================

[[test]]
fn test_h3_stype_constants() -> i32
    if H3_STYPE_REQUEST != 0
        return 1
    if H3_STYPE_CONTROL_LOCAL != 1
        return 2
    if H3_STYPE_QPACK_ENC != 3
        return 3
    if H3_STYPE_QPACK_DEC != 4
        return 4
    return 0

[[test]]
fn test_h3_stream_state_constants() -> i32
    if H3_STREAM_STATE_IDLE != 0
        return 1
    if H3_STREAM_STATE_OPEN != 1
        return 2
    if H3_STREAM_STATE_HALF_CLOSED != 2
        return 3
    if H3_STREAM_STATE_CLOSED != 3
        return 4
    return 0

