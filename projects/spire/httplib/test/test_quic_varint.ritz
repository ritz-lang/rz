# test/test_quic_varint.ritz - Tests for QUIC variable-length integer encoding
#
# RFC 9000 Section 16 defines the variable-length integer encoding.

import ritzlib.span
import lib.quic_varint

# ============================================================================
# Encoding Length Tests
# ============================================================================

[[test]]
fn test_varint_len_1_byte() -> i32
    if varint_encoded_len(0) != 1
        return 1
    if varint_encoded_len(1) != 1
        return 2
    if varint_encoded_len(37) != 1
        return 3
    if varint_encoded_len(63) != 1
        return 4
    if varint_encoded_len(VARINT_MAX_1) != 1
        return 5
    return 0

[[test]]
fn test_varint_len_2_byte() -> i32
    if varint_encoded_len(64) != 2
        return 1
    if varint_encoded_len(100) != 2
        return 2
    if varint_encoded_len(16383) != 2
        return 3
    if varint_encoded_len(VARINT_MAX_2) != 2
        return 4
    return 0

[[test]]
fn test_varint_len_4_byte() -> i32
    if varint_encoded_len(16384) != 4
        return 1
    if varint_encoded_len(100000) != 4
        return 2
    if varint_encoded_len(1073741823) != 4
        return 3
    if varint_encoded_len(VARINT_MAX_4) != 4
        return 4
    return 0

[[test]]
fn test_varint_len_8_byte() -> i32
    if varint_encoded_len(1073741824) != 8
        return 1
    if varint_encoded_len(1000000000000) != 8
        return 2
    if varint_encoded_len(VARINT_MAX_8) != 8
        return 3
    return 0

[[test]]
fn test_varint_len_invalid() -> i32
    if varint_encoded_len(-1) != 0
        return 1
    return 0

# ============================================================================
# Parsing 1-byte Values
# ============================================================================

[[test]]
fn test_parse_1_byte_zero() -> i32
    var buf: [8]u8
    buf[0] = 0x00
    var result: VarintResult
    let ret: i32 = varint_parse(@buf[0], 8, @result)
    if ret != VARINT_OK
        return 1
    if result.ok != 1
        return 2
    if result.value != 0
        return 3
    if result.bytes_consumed != 1
        return 4
    return 0

[[test]]
fn test_parse_1_byte_one() -> i32
    var buf: [8]u8
    buf[0] = 0x01
    var result: VarintResult
    let ret: i32 = varint_parse(@buf[0], 8, @result)
    if ret != VARINT_OK
        return 1
    if result.value != 1
        return 2
    if result.bytes_consumed != 1
        return 3
    return 0

[[test]]
fn test_parse_1_byte_max() -> i32
    # 0x3F = 63 with prefix 00
    var buf: [8]u8
    buf[0] = 0x3F
    var result: VarintResult
    let ret: i32 = varint_parse(@buf[0], 8, @result)
    if ret != VARINT_OK
        return 1
    if result.value != 63
        return 2
    if result.bytes_consumed != 1
        return 3
    return 0

# ============================================================================
# Parsing 2-byte Values
# ============================================================================

[[test]]
fn test_parse_2_byte_min() -> i32
    # 0x40 0x40 = prefix 01, value 64
    var buf: [8]u8
    buf[0] = 0x40
    buf[1] = 0x40
    var result: VarintResult
    let ret: i32 = varint_parse(@buf[0], 8, @result)
    if ret != VARINT_OK
        return 1
    if result.value != 64
        return 2
    if result.bytes_consumed != 2
        return 3
    return 0

[[test]]
fn test_parse_2_byte_max() -> i32
    # 0x7F 0xFF = prefix 01, value 16383 (0x3FFF)
    var buf: [8]u8
    buf[0] = 0x7F
    buf[1] = 0xFF
    var result: VarintResult
    let ret: i32 = varint_parse(@buf[0], 8, @result)
    if ret != VARINT_OK
        return 1
    if result.value != 16383
        return 2
    if result.bytes_consumed != 2
        return 3
    return 0

[[test]]
fn test_parse_2_byte_insufficient() -> i32
    var buf: [8]u8
    buf[0] = 0x40  # 2-byte prefix but only 1 byte available
    var result: VarintResult
    let ret: i32 = varint_parse(@buf[0], 1, @result)
    if ret != VARINT_ERR_INCOMPLETE
        return 1
    if result.ok != 0
        return 2
    return 0

# ============================================================================
# Parsing 4-byte Values
# ============================================================================

[[test]]
fn test_parse_4_byte_value() -> i32
    # 0x80 0x00 0x40 0x00 = prefix 10, value 16384 (0x4000)
    var buf: [8]u8
    buf[0] = 0x80
    buf[1] = 0x00
    buf[2] = 0x40
    buf[3] = 0x00
    var result: VarintResult
    let ret: i32 = varint_parse(@buf[0], 8, @result)
    if ret != VARINT_OK
        return 1
    if result.value != 16384
        return 2
    if result.bytes_consumed != 4
        return 3
    return 0

[[test]]
fn test_parse_4_byte_max() -> i32
    # 0xBF 0xFF 0xFF 0xFF = prefix 10, value 1073741823 (0x3FFFFFFF)
    var buf: [8]u8
    buf[0] = 0xBF
    buf[1] = 0xFF
    buf[2] = 0xFF
    buf[3] = 0xFF
    var result: VarintResult
    let ret: i32 = varint_parse(@buf[0], 8, @result)
    if ret != VARINT_OK
        return 1
    if result.value != 1073741823
        return 2
    if result.bytes_consumed != 4
        return 3
    return 0

# ============================================================================
# Parsing 8-byte Values
# ============================================================================

[[test]]
fn test_parse_8_byte_value() -> i32
    # 0xC0 0x00 0x00 0x00 0x40 0x00 0x00 0x00 = prefix 11, value 1073741824
    var buf: [8]u8
    buf[0] = 0xC0
    buf[1] = 0x00
    buf[2] = 0x00
    buf[3] = 0x00
    buf[4] = 0x40
    buf[5] = 0x00
    buf[6] = 0x00
    buf[7] = 0x00
    var result: VarintResult
    let ret: i32 = varint_parse(@buf[0], 8, @result)
    if ret != VARINT_OK
        return 1
    if result.value != 1073741824
        return 2
    if result.bytes_consumed != 8
        return 3
    return 0

# ============================================================================
# Encoding Tests
# ============================================================================

[[test]]
fn test_encode_1_byte_zero() -> i32
    var buf: [8]u8
    let ret: i32 = varint_encode(0, @buf[0], 8)
    if ret != 1
        return 1
    if buf[0] != 0x00
        return 2
    return 0

[[test]]
fn test_encode_1_byte_max() -> i32
    var buf: [8]u8
    let ret: i32 = varint_encode(63, @buf[0], 8)
    if ret != 1
        return 1
    if buf[0] != 0x3F
        return 2
    return 0

[[test]]
fn test_encode_2_byte_min() -> i32
    var buf: [8]u8
    let ret: i32 = varint_encode(64, @buf[0], 8)
    if ret != 2
        return 1
    # 64 = 0x40, with prefix 01: 0x40 0x40
    if buf[0] != 0x40
        return 2
    if buf[1] != 0x40
        return 3
    return 0

[[test]]
fn test_encode_2_byte_max() -> i32
    var buf: [8]u8
    let ret: i32 = varint_encode(16383, @buf[0], 8)
    if ret != 2
        return 1
    # 16383 = 0x3FFF, with prefix 01: 0x7F 0xFF
    if buf[0] != 0x7F
        return 2
    if buf[1] != 0xFF
        return 3
    return 0

[[test]]
fn test_encode_4_byte() -> i32
    var buf: [8]u8
    let ret: i32 = varint_encode(16384, @buf[0], 8)
    if ret != 4
        return 1
    # 16384 = 0x4000, with prefix 10: 0x80 0x00 0x40 0x00
    if buf[0] != 0x80
        return 2
    if buf[1] != 0x00
        return 3
    if buf[2] != 0x40
        return 4
    if buf[3] != 0x00
        return 5
    return 0

[[test]]
fn test_encode_8_byte() -> i32
    var buf: [8]u8
    let ret: i32 = varint_encode(1073741824, @buf[0], 8)
    if ret != 8
        return 1
    # 1073741824 = 0x40000000, with prefix 11
    if buf[0] != 0xC0
        return 2
    if buf[4] != 0x40
        return 3
    return 0

[[test]]
fn test_encode_buffer_too_small() -> i32
    var buf: [1]u8
    let ret: i32 = varint_encode(64, @buf[0], 1)  # Needs 2 bytes
    if ret != VARINT_ERR_INVALID
        return 1
    return 0

# ============================================================================
# Roundtrip Tests
# ============================================================================

[[test]]
fn test_roundtrip_1_byte() -> i32
    var buf: [8]u8
    let ret: i32 = varint_encode(37, @buf[0], 8)
    if ret != 1
        return 1
    var result: VarintResult
    let pret: i32 = varint_parse(@buf[0], 8, @result)
    if pret != VARINT_OK
        return 2
    if result.value != 37
        return 3
    return 0

[[test]]
fn test_roundtrip_2_byte() -> i32
    var buf: [8]u8
    let ret: i32 = varint_encode(500, @buf[0], 8)
    if ret != 2
        return 1
    var result: VarintResult
    let pret: i32 = varint_parse(@buf[0], 8, @result)
    if pret != VARINT_OK
        return 2
    if result.value != 500
        return 3
    return 0

[[test]]
fn test_roundtrip_4_byte() -> i32
    var buf: [8]u8
    let ret: i32 = varint_encode(100000, @buf[0], 8)
    if ret != 4
        return 1
    var result: VarintResult
    let pret: i32 = varint_parse(@buf[0], 8, @result)
    if pret != VARINT_OK
        return 2
    if result.value != 100000
        return 3
    return 0

[[test]]
fn test_roundtrip_8_byte() -> i32
    var buf: [8]u8
    let ret: i32 = varint_encode(VARINT_MAX_8, @buf[0], 8)
    if ret != 8
        return 1
    var result: VarintResult
    let pret: i32 = varint_parse(@buf[0], 8, @result)
    if pret != VARINT_OK
        return 2
    if result.value != VARINT_MAX_8
        return 3
    return 0

[[test]]
fn test_parse_empty() -> i32
    var buf: [1]u8
    var result: VarintResult
    let ret: i32 = varint_parse(@buf[0], 0, @result)
    if ret != VARINT_ERR_INCOMPLETE
        return 1
    return 0
