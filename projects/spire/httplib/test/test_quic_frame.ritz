# test/test_quic_frame.ritz - Tests for QUIC frame parsing
#
# RFC 9000 Section 19 defines frame formats

import ritzlib.span
import lib.quic_frame
import lib.quic_varint

# ============================================================================
# Frame Type Detection
# ============================================================================

[[test]]
fn test_is_stream_frame_base() -> i32
    if is_stream_frame(QUIC_FRAME_STREAM) != 1
        return 1
    return 0

[[test]]
fn test_is_stream_frame_with_flags() -> i32
    if is_stream_frame(0x0F) != 1
        return 1
    return 0

[[test]]
fn test_is_stream_frame_not_stream() -> i32
    if is_stream_frame(QUIC_FRAME_CRYPTO) != 0
        return 1
    return 0

[[test]]
fn test_stream_frame_flags_none() -> i32
    if stream_frame_flags(0x08) != 0
        return 1
    return 0

[[test]]
fn test_stream_frame_flags_fin() -> i32
    if stream_frame_flags(0x09) != STREAM_FLAG_FIN
        return 1
    return 0

[[test]]
fn test_stream_frame_flags_all() -> i32
    # 0x0F = 0x08 | FIN | LEN | OFF
    let flags: i64 = stream_frame_flags(0x0F)
    if (flags & STREAM_FLAG_FIN) == 0
        return 1
    if (flags & STREAM_FLAG_LEN) == 0
        return 2
    if (flags & STREAM_FLAG_OFF) == 0
        return 3
    return 0

# ============================================================================
# Frame Header Parsing
# ============================================================================

[[test]]
fn test_parse_frame_type_padding() -> i32
    var buf: [8]u8
    buf[0] = 0x00

    var header: QuicFrameHeader
    let ret: i32 = quic_parse_frame_type(@buf[0], 8, @header)
    if ret != QFRAME_OK
        return 1
    if header.frame_type != QUIC_FRAME_PADDING
        return 2
    if header.bytes_consumed != 1
        return 3
    return 0

[[test]]
fn test_parse_frame_type_crypto() -> i32
    var buf: [8]u8
    buf[0] = 0x06

    var header: QuicFrameHeader
    let ret: i32 = quic_parse_frame_type(@buf[0], 8, @header)
    if ret != QFRAME_OK
        return 1
    if header.frame_type != QUIC_FRAME_CRYPTO
        return 2
    return 0

[[test]]
fn test_parse_frame_type_stream() -> i32
    var buf: [8]u8
    buf[0] = 0x0F  # STREAM with all flags

    var header: QuicFrameHeader
    let ret: i32 = quic_parse_frame_type(@buf[0], 8, @header)
    if ret != QFRAME_OK
        return 1
    if is_stream_frame(header.frame_type) != 1
        return 2
    return 0

# ============================================================================
# PADDING Frame Parsing
# ============================================================================

[[test]]
fn test_parse_padding_single() -> i32
    var buf: [8]u8
    buf[0] = 0x00
    buf[1] = 0x01  # Not padding

    var frame: PaddingFrame
    let ret: i32 = quic_parse_padding(@buf[0], 8, @frame)
    if ret != 1
        return 1
    if frame.count != 1
        return 2
    return 0

[[test]]
fn test_parse_padding_multiple() -> i32
    var buf: [8]u8
    buf[0] = 0x00
    buf[1] = 0x00
    buf[2] = 0x00
    buf[3] = 0x00
    buf[4] = 0x01  # Not padding

    var frame: PaddingFrame
    let ret: i32 = quic_parse_padding(@buf[0], 8, @frame)
    if ret != 4
        return 1
    if frame.count != 4
        return 2
    return 0

[[test]]
fn test_parse_padding_all() -> i32
    var buf: [8]u8
    buf[0] = 0x00
    buf[1] = 0x00
    buf[2] = 0x00
    buf[3] = 0x00
    buf[4] = 0x00
    buf[5] = 0x00
    buf[6] = 0x00
    buf[7] = 0x00

    var frame: PaddingFrame
    let ret: i32 = quic_parse_padding(@buf[0], 8, @frame)
    if ret != 8
        return 1
    if frame.count != 8
        return 2
    return 0

# ============================================================================
# ACK Frame Parsing
# ============================================================================

[[test]]
fn test_parse_ack_simple() -> i32
    # ACK frame: largest=10, delay=5, range_count=0, first_range=5
    var buf: [16]u8
    buf[0] = 10   # Largest Ack
    buf[1] = 5    # ACK Delay
    buf[2] = 0    # Range Count
    buf[3] = 5    # First ACK Range

    var frame: AckFrame
    let ret: i32 = quic_parse_ack(@buf[0], 16, 0, @frame)
    if ret < 0
        return 1
    if frame.largest_ack != 10
        return 2
    if frame.ack_delay != 5
        return 3
    if frame.ack_range_count != 0
        return 4
    if frame.first_ack_range != 5
        return 5
    if frame.has_ecn != 0
        return 6
    return 0

[[test]]
fn test_parse_ack_with_ecn() -> i32
    # ACK-ECN frame
    var buf: [16]u8
    buf[0] = 10   # Largest Ack
    buf[1] = 5    # ACK Delay
    buf[2] = 0    # Range Count
    buf[3] = 5    # First ACK Range
    buf[4] = 1    # ECT0 count
    buf[5] = 2    # ECT1 count
    buf[6] = 3    # ECN-CE count

    var frame: AckFrame
    let ret: i32 = quic_parse_ack(@buf[0], 16, 1, @frame)
    if ret < 0
        return 1
    if frame.has_ecn != 1
        return 2
    if frame.ect0_count != 1
        return 3
    if frame.ect1_count != 2
        return 4
    if frame.ecn_ce_count != 3
        return 5
    return 0

# ============================================================================
# CRYPTO Frame Parsing
# ============================================================================

[[test]]
fn test_parse_crypto_simple() -> i32
    # CRYPTO: offset=0, length=5, data="hello"
    var buf: [16]u8
    buf[0] = 0    # Offset
    buf[1] = 5    # Length
    buf[2] = 'h'
    buf[3] = 'e'
    buf[4] = 'l'
    buf[5] = 'l'
    buf[6] = 'o'

    var frame: CryptoFrame
    let ret: i32 = quic_parse_crypto(@buf[0], 16, @frame)
    if ret < 0
        return 1
    if frame.offset != 0
        return 2
    if frame.length != 5
        return 3
    if frame.data_offset != 2
        return 4
    return 0

[[test]]
fn test_parse_crypto_with_offset() -> i32
    # CRYPTO: offset=100, length=3, data="abc"
    var buf: [16]u8
    buf[0] = 0x40  # Offset = 100 (2-byte varint)
    buf[1] = 0x64
    buf[2] = 3     # Length
    buf[3] = 'a'
    buf[4] = 'b'
    buf[5] = 'c'

    var frame: CryptoFrame
    let ret: i32 = quic_parse_crypto(@buf[0], 16, @frame)
    if ret < 0
        return 1
    if frame.offset != 100
        return 2
    if frame.length != 3
        return 3
    if frame.data_offset != 3
        return 4
    return 0

[[test]]
fn test_parse_crypto_incomplete() -> i32
    # CRYPTO frame claiming 100 bytes but buffer only has 10
    var buf: [16]u8
    buf[0] = 0     # Offset
    buf[1] = 100   # Length = 100

    var frame: CryptoFrame
    let ret: i32 = quic_parse_crypto(@buf[0], 16, @frame)
    if ret != QFRAME_ERR_INCOMPLETE
        return 1
    return 0

# ============================================================================
# STREAM Frame Parsing
# ============================================================================

[[test]]
fn test_parse_stream_minimal() -> i32
    # STREAM frame type 0x08 (no flags): stream_id only, data to end
    var buf: [16]u8
    buf[0] = 4     # Stream ID
    buf[1] = 'H'
    buf[2] = 'I'

    var frame: StreamFrame
    let ret: i32 = quic_parse_stream(@buf[0], 3, 0x08, @frame, 3)
    if ret < 0
        return 1
    if frame.stream_id != 4
        return 2
    if frame.offset != 0
        return 3
    if frame.fin != 0
        return 4
    if frame.length != 2  # Remaining after stream_id
        return 5
    return 0

[[test]]
fn test_parse_stream_with_fin() -> i32
    # STREAM frame type 0x09 (FIN flag): stream_id, data to end
    var buf: [16]u8
    buf[0] = 4     # Stream ID

    var frame: StreamFrame
    let ret: i32 = quic_parse_stream(@buf[0], 1, 0x09, @frame, 1)
    if ret < 0
        return 1
    if frame.fin != 1
        return 2
    return 0

[[test]]
fn test_parse_stream_with_length() -> i32
    # STREAM frame type 0x0A (LEN flag): stream_id, length, data
    var buf: [16]u8
    buf[0] = 4     # Stream ID
    buf[1] = 3     # Length = 3
    buf[2] = 'a'
    buf[3] = 'b'
    buf[4] = 'c'

    var frame: StreamFrame
    let ret: i32 = quic_parse_stream(@buf[0], 16, 0x0A, @frame, 100)
    if ret < 0
        return 1
    if frame.stream_id != 4
        return 2
    if frame.length != 3
        return 3
    if frame.data_offset != 2
        return 4
    return 0

[[test]]
fn test_parse_stream_with_offset() -> i32
    # STREAM frame type 0x0C (OFF flag): stream_id, offset, data
    var buf: [16]u8
    buf[0] = 4     # Stream ID
    buf[1] = 50    # Offset = 50
    buf[2] = 'x'
    buf[3] = 'y'

    var frame: StreamFrame
    let ret: i32 = quic_parse_stream(@buf[0], 4, 0x0C, @frame, 4)
    if ret < 0
        return 1
    if frame.stream_id != 4
        return 2
    if frame.offset != 50
        return 3
    if frame.length != 2
        return 4
    return 0

[[test]]
fn test_parse_stream_all_flags() -> i32
    # STREAM frame type 0x0F (FIN|LEN|OFF): stream_id, offset, length, data
    var buf: [16]u8
    buf[0] = 8     # Stream ID
    buf[1] = 50    # Offset = 50 (fits in 1-byte varint)
    buf[2] = 4     # Length = 4
    buf[3] = 'T'
    buf[4] = 'E'
    buf[5] = 'S'
    buf[6] = 'T'

    var frame: StreamFrame
    let ret: i32 = quic_parse_stream(@buf[0], 16, 0x0F, @frame, 100)
    if ret < 0
        return 1
    if frame.stream_id != 8
        return 2
    if frame.offset != 50
        return 3
    if frame.length != 4
        return 4
    if frame.fin != 1
        return 5
    if frame.data_offset != 3
        return 6
    return 0

# ============================================================================
# MAX_DATA Frame Parsing
# ============================================================================

[[test]]
fn test_parse_max_data() -> i32
    # 1-byte varint: just use value <= 63
    var buf: [8]u8
    buf[0] = 50    # Max Data = 50

    var frame: MaxDataFrame
    let ret: i32 = quic_parse_max_data(@buf[0], 8, @frame)
    if ret < 0
        return 1
    if frame.max_data != 50
        return 2
    return 0

# ============================================================================
# MAX_STREAM_DATA Frame Parsing
# ============================================================================

[[test]]
fn test_parse_max_stream_data() -> i32
    var buf: [8]u8
    buf[0] = 4     # Stream ID
    buf[1] = 60    # Max Stream Data = 60 (fits in 1-byte varint)

    var frame: MaxStreamDataFrame
    let ret: i32 = quic_parse_max_stream_data(@buf[0], 8, @frame)
    if ret < 0
        return 1
    if frame.stream_id != 4
        return 2
    if frame.max_stream_data != 60
        return 3
    return 0

# ============================================================================
# CONNECTION_CLOSE Frame Parsing
# ============================================================================

[[test]]
fn test_parse_connection_close_transport() -> i32
    # CONNECTION_CLOSE (transport): error=0x0a, frame_type=0x06, reason="test"
    var buf: [16]u8
    buf[0] = 0x0A  # Error code
    buf[1] = 0x06  # Frame type
    buf[2] = 4     # Reason length
    buf[3] = 't'
    buf[4] = 'e'
    buf[5] = 's'
    buf[6] = 't'

    var frame: ConnectionCloseFrame
    let ret: i32 = quic_parse_connection_close(@buf[0], 16, 0, @frame)
    if ret < 0
        return 1
    if frame.error_code != 0x0A
        return 2
    if frame.frame_type != 0x06
        return 3
    if frame.reason_length != 4
        return 4
    if frame.is_app_error != 0
        return 5
    return 0

[[test]]
fn test_parse_connection_close_app() -> i32
    # CONNECTION_CLOSE (app): error=0x01, reason=""
    var buf: [8]u8
    buf[0] = 0x01  # Error code
    buf[1] = 0     # Reason length = 0

    var frame: ConnectionCloseFrame
    let ret: i32 = quic_parse_connection_close(@buf[0], 8, 1, @frame)
    if ret < 0
        return 1
    if frame.error_code != 0x01
        return 2
    if frame.reason_length != 0
        return 3
    if frame.is_app_error != 1
        return 4
    return 0
