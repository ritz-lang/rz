# test/test_h3_frame.ritz - Tests for HTTP/3 frame types
#
# RFC 9114 Section 7.2 defines HTTP/3 frames

import ritzlib.span
import lib.h3_frame
import lib.quic_varint

# ============================================================================
# Frame Header Tests
# ============================================================================

[[test]]
fn test_h3_frame_header_init() -> i32
    var hdr: H3FrameHeader
    h3_frame_header_init(@hdr)
    if hdr.frame_type != 0
        return 1
    if hdr.length != 0
        return 2
    return 0

[[test]]
fn test_h3_parse_frame_header_data() -> i32
    # DATA frame (type=0x00), length=10
    var buf: [8]u8
    buf[0] = 0x00  # type = DATA
    buf[1] = 0x0A  # length = 10

    var hdr: H3FrameHeader
    let ret: i32 = h3_parse_frame_header(@buf[0], 8, @hdr)
    if ret != 2
        return 1
    if hdr.frame_type != H3_FRAME_DATA
        return 2
    if hdr.length != 10
        return 3
    return 0

[[test]]
fn test_h3_parse_frame_header_headers() -> i32
    # HEADERS frame (type=0x01), length=100
    var buf: [8]u8
    buf[0] = 0x01  # type = HEADERS
    buf[1] = 0x40  # 2-byte varint for 100
    buf[2] = 0x64  # 100 = 0x64

    var hdr: H3FrameHeader
    let ret: i32 = h3_parse_frame_header(@buf[0], 8, @hdr)
    if ret != 3
        return 1
    if hdr.frame_type != H3_FRAME_HEADERS
        return 2
    if hdr.length != 100
        return 3
    return 0

[[test]]
fn test_h3_parse_frame_header_settings() -> i32
    # SETTINGS frame (type=0x04), length=6
    var buf: [8]u8
    buf[0] = 0x04  # type = SETTINGS
    buf[1] = 0x06  # length = 6

    var hdr: H3FrameHeader
    let ret: i32 = h3_parse_frame_header(@buf[0], 8, @hdr)
    if ret != 2
        return 1
    if hdr.frame_type != H3_FRAME_SETTINGS
        return 2
    if hdr.length != 6
        return 3
    return 0

[[test]]
fn test_h3_parse_frame_header_incomplete() -> i32
    var buf: [1]u8
    buf[0] = 0x00

    var hdr: H3FrameHeader
    let ret: i32 = h3_parse_frame_header(@buf[0], 1, @hdr)
    if ret != H3_ERR_INCOMPLETE
        return 1
    return 0

[[test]]
fn test_h3_write_frame_header() -> i32
    var buf: [8]u8
    let ret: i32 = h3_write_frame_header(@buf[0], 8, H3_FRAME_DATA, 50)
    if ret != 2
        return 1
    if buf[0] != 0x00  # DATA
        return 2
    if buf[1] != 50
        return 3
    return 0

[[test]]
fn test_h3_write_frame_header_large_length() -> i32
    var buf: [8]u8
    let ret: i32 = h3_write_frame_header(@buf[0], 8, H3_FRAME_HEADERS, 1000)
    if ret != 3  # 1 byte type + 2 byte length
        return 1
    if buf[0] != 0x01  # HEADERS
        return 2
    # 1000 = 0x3E8, 2-byte varint = 0x43 0xE8
    if buf[1] != 0x43
        return 3
    if buf[2] != 0xE8
        return 4
    return 0

# ============================================================================
# DATA Frame Tests
# ============================================================================

[[test]]
fn test_h3_data_frame_init() -> i32
    var frame: H3DataFrame
    h3_data_frame_init(@frame)
    if frame.data.ptr != null
        return 1
    if frame.data.len != 0
        return 2
    return 0

[[test]]
fn test_h3_parse_data_frame() -> i32
    var buf: [16]u8
    buf[0] = 0x48  # 'H'
    buf[1] = 0x65  # 'e'
    buf[2] = 0x6C  # 'l'
    buf[3] = 0x6C  # 'l'
    buf[4] = 0x6F  # 'o'

    var frame: H3DataFrame
    let ret: i32 = h3_parse_data_frame(@buf[0], 5, @frame)
    if ret != 5
        return 1
    if frame.data.len != 5
        return 2
    return 0

# ============================================================================
# HEADERS Frame Tests
# ============================================================================

[[test]]
fn test_h3_headers_frame_init() -> i32
    var frame: H3HeadersFrame
    h3_headers_frame_init(@frame)
    if frame.encoded_field_section.ptr != null
        return 1
    if frame.encoded_field_section.len != 0
        return 2
    return 0

[[test]]
fn test_h3_parse_headers_frame() -> i32
    var buf: [32]u8
    # Some QPACK-encoded data
    buf[0] = 0x00
    buf[1] = 0x00
    buf[2] = 0xD1  # Indexed :status 200

    var frame: H3HeadersFrame
    let ret: i32 = h3_parse_headers_frame(@buf[0], 3, @frame)
    if ret != 3
        return 1
    if frame.encoded_field_section.len != 3
        return 2
    return 0

