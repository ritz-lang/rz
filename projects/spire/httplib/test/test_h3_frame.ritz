# CANCEL_PUSH Frame Tests
# ============================================================================

[[test]]
fn test_h3_cancel_push_frame_init() -> i32
    var frame: H3CancelPushFrame
    h3_cancel_push_frame_init(@frame)
    if frame.push_id != 0
        return 1
    return 0

[[test]]
fn test_h3_parse_cancel_push_frame() -> i32
    var buf: [8]u8
    buf[0] = 0x05  # push_id = 5

    var frame: H3CancelPushFrame
    let ret: i32 = h3_parse_cancel_push_frame(@buf[0], 1, @frame)
    if ret != 1
        return 1
    if frame.push_id != 5
        return 2
    return 0

# ============================================================================
# SETTINGS Frame Tests
# ============================================================================

[[test]]
fn test_h3_settings_frame_init() -> i32
    var frame: H3SettingsFrame
    h3_settings_frame_init(@frame)
    if frame.count != 0
        return 1
    return 0

[[test]]
fn test_h3_parse_settings_frame_single() -> i32
    # QPACK_MAX_TABLE_CAPACITY (0x01) = 4096
    var buf: [8]u8
    buf[0] = 0x01  # identifier
    buf[1] = 0x50  # 2-byte varint for 4096: 0x50 0x00
    buf[2] = 0x00

    var frame: H3SettingsFrame
    let ret: i32 = h3_parse_settings_frame(@buf[0], 3, @frame)
    if ret != 3
        return 1
    if frame.count != 1
        return 2
    if frame.settings[0].identifier != H3_SETTINGS_QPACK_MAX_TABLE_CAPACITY
        return 3
    if frame.settings[0].value != 4096
        return 4
    return 0

[[test]]
fn test_h3_parse_settings_frame_multiple() -> i32
    # Two settings
    var buf: [16]u8
    buf[0] = 0x01  # QPACK_MAX_TABLE_CAPACITY
    buf[1] = 0x40  # 2-byte varint for 100
    buf[2] = 0x64
    buf[3] = 0x06  # MAX_FIELD_SECTION_SIZE
    buf[4] = 0x41  # 2-byte varint for 256
    buf[5] = 0x00

    var frame: H3SettingsFrame
    let ret: i32 = h3_parse_settings_frame(@buf[0], 6, @frame)
    if ret != 6
        return 1
    if frame.count != 2
        return 2
    if frame.settings[0].value != 100
        return 3
    if frame.settings[1].identifier != H3_SETTINGS_MAX_FIELD_SECTION_SIZE
        return 4
    if frame.settings[1].value != 256
        return 5
    return 0

[[test]]
fn test_h3_settings_get() -> i32
    var frame: H3SettingsFrame
    h3_settings_frame_init(@frame)

    h3_settings_set(@frame, H3_SETTINGS_QPACK_MAX_TABLE_CAPACITY, 4096)
    h3_settings_set(@frame, H3_SETTINGS_MAX_FIELD_SECTION_SIZE, 8192)

    let val1: i64 = h3_settings_get(@frame, H3_SETTINGS_QPACK_MAX_TABLE_CAPACITY)
    if val1 != 4096
        return 1

    let val2: i64 = h3_settings_get(@frame, H3_SETTINGS_MAX_FIELD_SECTION_SIZE)
    if val2 != 8192
        return 2

    let val3: i64 = h3_settings_get(@frame, 0xFF)
    if val3 != -1
        return 3
    return 0

[[test]]
fn test_h3_settings_set_update() -> i32
    var frame: H3SettingsFrame
    h3_settings_frame_init(@frame)

    h3_settings_set(@frame, H3_SETTINGS_QPACK_MAX_TABLE_CAPACITY, 1000)
    h3_settings_set(@frame, H3_SETTINGS_QPACK_MAX_TABLE_CAPACITY, 2000)

    if frame.count != 1
        return 1
    if h3_settings_get(@frame, H3_SETTINGS_QPACK_MAX_TABLE_CAPACITY) != 2000
        return 2
    return 0

[[test]]
fn test_h3_write_settings_payload() -> i32
    var frame: H3SettingsFrame
    h3_settings_frame_init(@frame)

    h3_settings_set(@frame, H3_SETTINGS_QPACK_MAX_TABLE_CAPACITY, 50)
    h3_settings_set(@frame, H3_SETTINGS_QPACK_BLOCKED_STREAMS, 10)

    var buf: [32]u8
    let ret: i32 = h3_write_settings_payload(@buf[0], 32, @frame)
    if ret != 4  # 1+1 + 1+1
        return 1

    # Parse back to verify
    var frame2: H3SettingsFrame
    let ret2: i32 = h3_parse_settings_frame(@buf[0], ret as i64, @frame2)
    if ret2 != ret
        return 2
    if frame2.count != 2
        return 3
    return 0

# ============================================================================
# PUSH_PROMISE Frame Tests
# ============================================================================

[[test]]
fn test_h3_push_promise_frame_init() -> i32
    var frame: H3PushPromiseFrame
    h3_push_promise_frame_init(@frame)
    if frame.push_id != 0
        return 1
    if frame.encoded_field_section.ptr != null
        return 2
    return 0

[[test]]
fn test_h3_parse_push_promise_frame() -> i32
    var buf: [16]u8
    buf[0] = 0x03  # push_id = 3
    buf[1] = 0xD1  # QPACK data
    buf[2] = 0x00

    var frame: H3PushPromiseFrame
    let ret: i32 = h3_parse_push_promise_frame(@buf[0], 3, @frame)
    if ret != 3
        return 1
    if frame.push_id != 3
        return 2
    if frame.encoded_field_section.len != 2
        return 3
    return 0

