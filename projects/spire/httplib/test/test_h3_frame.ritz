# ============================================================================
# Utility Function Tests
# ============================================================================

[[test]]
fn test_h3_is_reserved_frame_type() -> i32
    # Normal frame types
    if h3_is_reserved_frame_type(H3_FRAME_DATA) != 0
        return 1
    if h3_is_reserved_frame_type(H3_FRAME_HEADERS) != 0
        return 2
    if h3_is_reserved_frame_type(H3_FRAME_SETTINGS) != 0
        return 3

    # Reserved: 0x21, 0x40, 0x5F, ...
    if h3_is_reserved_frame_type(0x21) != 1
        return 4
    if h3_is_reserved_frame_type(0x40) != 1  # 0x1f + 0x21
        return 5
    return 0

[[test]]
fn test_h3_is_reserved_setting() -> i32
    # Normal settings
    if h3_is_reserved_setting(H3_SETTINGS_QPACK_MAX_TABLE_CAPACITY) != 0
        return 1
    if h3_is_reserved_setting(H3_SETTINGS_MAX_FIELD_SECTION_SIZE) != 0
        return 2

    # Reserved: 0x21, 0x40, ...
    if h3_is_reserved_setting(0x21) != 1
        return 3
    return 0

[[test]]
fn test_h3_stream_type_constants() -> i32
    if H3_STREAM_CONTROL != 0x00
        return 1
    if H3_STREAM_PUSH != 0x01
        return 2
    if H3_STREAM_QPACK_ENCODER != 0x02
        return 3
    if H3_STREAM_QPACK_DECODER != 0x03
        return 4
    return 0

[[test]]
fn test_h3_error_code_constants() -> i32
    if H3_NO_ERROR != 0x100
        return 1
    if H3_FRAME_UNEXPECTED != 0x105
        return 2
    if H3_SETTINGS_ERROR != 0x109
        return 3
    return 0

