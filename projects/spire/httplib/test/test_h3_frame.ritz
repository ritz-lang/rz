fn test_h3_parse_max_push_id_frame() -> i32
    var buf: [8]u8
    buf[0] = 0x0F  # push_id = 15

    var frame: H3MaxPushIdFrame
    let ret: i32 = h3_parse_max_push_id_frame(@buf[0], 1, @frame)
    if ret != 1
