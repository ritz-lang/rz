# ============================================================================

[[test]]
fn test_h3_goaway_frame_init() -> i32
    var frame: H3GoawayFrame
    h3_goaway_frame_init(@frame)
    if frame.stream_id != 0
        return 1
    return 0

[[test]]
fn test_h3_parse_goaway_frame() -> i32
    var buf: [8]u8
    buf[0] = 0x40  # 2-byte varint for 100
    buf[1] = 0x64

    var frame: H3GoawayFrame
    let ret: i32 = h3_parse_goaway_frame(@buf[0], 2, @frame)
    if ret != 2
        return 1
    if frame.stream_id != 100
        return 2
    return 0

