# test/test_h2_frame.ritz - Tests for HTTP/2 frame parsing and serialization
#
# HTTP/2 uses binary framing with a 9-byte header:
# - Length (24 bits)
# - Type (8 bits)
# - Flags (8 bits)
# - Reserved (1 bit)
# - Stream ID (31 bits)

import ritzlib.span
import ritzlib.str
import lib.h2_frame

# ============================================================================
# Frame Header Parsing Tests
# ============================================================================

[[test]]
fn test_parse_frame_header_data() -> i32
    # DATA frame: length=5, type=0, flags=0, stream=1
    var buf: [9]u8
    buf[0] = 0    # length high
    buf[1] = 0    # length mid
    buf[2] = 5    # length low = 5
    buf[3] = 0    # type = DATA
    buf[4] = 0    # flags
    buf[5] = 0    # reserved + stream high
    buf[6] = 0    # stream
    buf[7] = 0    # stream
    buf[8] = 1    # stream low = 1

    var header: H2FrameHeader
    let result: i32 = h2_parse_frame_header(@buf[0], 9, @header)

    if result != 0
        return 1

    if header.length != 5
        return 2

    if header.frame_type != H2_FRAME_DATA
        return 3

    if header.stream_id != 1
        return 4

    return 0

[[test]]
fn test_parse_frame_header_headers() -> i32
    # HEADERS frame: length=100, type=1, flags=END_HEADERS, stream=3
    var buf: [9]u8
    buf[0] = 0
    buf[1] = 0
    buf[2] = 100   # length = 100
    buf[3] = 1     # type = HEADERS
    buf[4] = 0x04  # flags = END_HEADERS
    buf[5] = 0
    buf[6] = 0
    buf[7] = 0
    buf[8] = 3     # stream = 3

    var header: H2FrameHeader
    let result: i32 = h2_parse_frame_header(@buf[0], 9, @header)

    if result != 0
        return 1

    if header.frame_type != H2_FRAME_HEADERS
        return 2

    if header.flags != H2_FLAG_END_HEADERS
        return 3

    if header.stream_id != 3
        return 4

    return 0

[[test]]
fn test_parse_frame_header_settings() -> i32
    # SETTINGS frame: length=12, type=4, flags=0, stream=0
    var buf: [9]u8
    buf[0] = 0
    buf[1] = 0
    buf[2] = 12   # length = 12 (2 settings)
    buf[3] = 4    # type = SETTINGS
    buf[4] = 0    # flags
    buf[5] = 0
    buf[6] = 0
    buf[7] = 0
    buf[8] = 0    # stream = 0 (required for SETTINGS)

    var header: H2FrameHeader
    let result: i32 = h2_parse_frame_header(@buf[0], 9, @header)

    if result != 0
        return 1

    if header.frame_type != H2_FRAME_SETTINGS
        return 2

    if header.stream_id != 0
        return 3

    return 0

[[test]]
fn test_parse_frame_header_goaway() -> i32
    # GOAWAY frame: length=8, type=7, stream=0
    var buf: [9]u8
    buf[0] = 0
    buf[1] = 0
    buf[2] = 8    # length = 8
    buf[3] = 7    # type = GOAWAY
    buf[4] = 0
    buf[5] = 0
    buf[6] = 0
    buf[7] = 0
    buf[8] = 0    # stream = 0

    var header: H2FrameHeader
    let result: i32 = h2_parse_frame_header(@buf[0], 9, @header)

    if result != 0
        return 1

    if header.frame_type != H2_FRAME_GOAWAY
        return 2

    return 0

[[test]]
fn test_parse_frame_header_large_length() -> i32
    # Large frame: length=16384 (max default)
    var buf: [9]u8
    buf[0] = 0
    buf[1] = 0x40  # 0x4000 = 16384
    buf[2] = 0
    buf[3] = 0     # DATA
    buf[4] = 0
    buf[5] = 0
    buf[6] = 0
    buf[7] = 0
    buf[8] = 1

    var header: H2FrameHeader
    let result: i32 = h2_parse_frame_header(@buf[0], 9, @header)

    if result != 0
        return 1

    if header.length != 16384
        return 2

    return 0

[[test]]
fn test_parse_frame_header_too_short() -> i32
    var buf: [5]u8
    var header: H2FrameHeader

    let result: i32 = h2_parse_frame_header(@buf[0], 5, @header)

    if result != H2_ERR_INCOMPLETE
        return 1

    return 0

# ============================================================================
# Frame Header Serialization Tests
# ============================================================================

[[test]]
fn test_write_frame_header_data() -> i32
    var buf: [9]u8
    var header: H2FrameHeader
    header.length = 100
    header.frame_type = H2_FRAME_DATA
    header.flags = H2_FLAG_END_STREAM
    header.stream_id = 5

    let result: i32 = h2_write_frame_header(@buf[0], 9, @header)

    if result != 9
        return 1

    # Check length (24-bit big-endian)
    if buf[0] != 0 || buf[1] != 0 || buf[2] != 100
        return 2

    # Check type
    if buf[3] != H2_FRAME_DATA as u8
        return 3

    # Check flags
    if buf[4] != H2_FLAG_END_STREAM as u8
        return 4

    # Check stream ID (31-bit big-endian, high bit reserved)
    if buf[8] != 5
        return 5

    return 0

[[test]]
fn test_write_frame_header_ping() -> i32
    var buf: [9]u8
    var header: H2FrameHeader
    header.length = 8
    header.frame_type = H2_FRAME_PING
    header.flags = H2_FLAG_ACK
    header.stream_id = 0

    let result: i32 = h2_write_frame_header(@buf[0], 9, @header)

    if result != 9
        return 1

    if buf[3] != H2_FRAME_PING as u8
        return 2

    if buf[4] != H2_FLAG_ACK as u8
        return 3

    return 0

# ============================================================================
# Settings Frame Tests
# ============================================================================

[[test]]
fn test_parse_settings_frame() -> i32
    # SETTINGS frame with HEADER_TABLE_SIZE=4096, MAX_CONCURRENT_STREAMS=100
    var buf: [12]u8
    # Setting 1: HEADER_TABLE_SIZE (0x01) = 4096
    buf[0] = 0
    buf[1] = 1      # id = 1
    buf[2] = 0
    buf[3] = 0
    buf[4] = 0x10   # 0x1000 = 4096
    buf[5] = 0
    # Setting 2: MAX_CONCURRENT_STREAMS (0x03) = 100
    buf[6] = 0
    buf[7] = 3      # id = 3
    buf[8] = 0
    buf[9] = 0
    buf[10] = 0
    buf[11] = 100

    var settings: H2Settings
    h2_settings_init(@settings)

    var input: Span<u8> = span_from_ptr<u8>(@buf[0], 12)
    let result: i32 = h2_parse_settings(@input, @settings)

    if result != 0
        return 1

    if settings.header_table_size != 4096
        return 2

    if settings.max_concurrent_streams != 100
        return 3

    return 0

[[test]]
fn test_settings_defaults() -> i32
    var settings: H2Settings
    h2_settings_init(@settings)

    if settings.header_table_size != 4096
        return 1

    if settings.enable_push != 1
        return 2

    if settings.max_concurrent_streams != 0xFFFFFFFF as i64
        return 3

    if settings.initial_window_size != 65535
        return 4

    if settings.max_frame_size != 16384
        return 5

    if settings.max_header_list_size != 0xFFFFFFFF as i64
        return 6

    return 0

# ============================================================================
# Window Update Frame Tests
# ============================================================================

[[test]]
fn test_parse_window_update() -> i32
    var buf: [4]u8
    buf[0] = 0
    buf[1] = 0
    buf[2] = 0x10  # 0x1000 = 4096
    buf[3] = 0

    var increment: i32 = 0
    var input: Span<u8> = span_from_ptr<u8>(@buf[0], 4)
    let result: i32 = h2_parse_window_update(@input, @increment)

    if result != 0
        return 1

    if increment != 4096
        return 2

    return 0

# ============================================================================
# Priority Frame Tests
# ============================================================================

[[test]]
fn test_parse_priority() -> i32
    # Priority: exclusive=1, dependency=3, weight=16
    var buf: [5]u8
    buf[0] = 0x80  # exclusive bit + stream high
    buf[1] = 0
    buf[2] = 0
    buf[3] = 3     # dependency stream = 3
    buf[4] = 15    # weight = 16 (stored as weight-1)

    var priority: H2Priority
    var input: Span<u8> = span_from_ptr<u8>(@buf[0], 5)
    let result: i32 = h2_parse_priority(@input, @priority)

    if result != 0
        return 1

    if priority.exclusive != 1
        return 2

    if priority.stream_dependency != 3
        return 3

    if priority.weight != 16
        return 4

    return 0

# ============================================================================
# RST_STREAM Frame Tests
# ============================================================================

[[test]]
fn test_parse_rst_stream() -> i32
    # RST_STREAM with error code CANCEL (0x08)
    var buf: [4]u8
    buf[0] = 0
    buf[1] = 0
    buf[2] = 0
    buf[3] = 8  # CANCEL

    var error_code: i32 = 0
    var input: Span<u8> = span_from_ptr<u8>(@buf[0], 4)
    let result: i32 = h2_parse_rst_stream(@input, @error_code)

    if result != 0
        return 1

    if error_code != H2_ERROR_CANCEL
        return 2

    return 0

# ============================================================================
# GOAWAY Frame Tests
# ============================================================================

[[test]]
fn test_parse_goaway() -> i32
    # GOAWAY: last_stream=5, error=NO_ERROR
    var buf: [8]u8
    buf[0] = 0
    buf[1] = 0
    buf[2] = 0
    buf[3] = 5   # last stream = 5
    buf[4] = 0
    buf[5] = 0
    buf[6] = 0
    buf[7] = 0   # NO_ERROR

    var goaway: H2Goaway
    var input: Span<u8> = span_from_ptr<u8>(@buf[0], 8)
    let result: i32 = h2_parse_goaway(@input, @goaway)

    if result != 0
        return 1

    if goaway.last_stream_id != 5
        return 2

    if goaway.error_code != H2_ERROR_NO_ERROR
        return 3

    return 0
