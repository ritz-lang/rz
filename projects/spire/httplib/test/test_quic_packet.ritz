# test/test_quic_packet.ritz - Tests for QUIC packet header parsing
#
# RFC 9000 Section 17 defines packet header formats

import ritzlib.span
import lib.quic_packet
import lib.quic_varint

# ============================================================================
# Header Form Detection
# ============================================================================

[[test]]
fn test_is_long_header_initial() -> i32
    # 0xC0 = 1100 0000 (form=1, fixed=1, type=00)
    if quic_is_long_header(0xC0) != 1
        return 1
    return 0

[[test]]
fn test_is_long_header_handshake() -> i32
    # 0xE0 = 1110 0000 (form=1, fixed=1, type=10)
    if quic_is_long_header(0xE0) != 1
        return 1
    return 0

[[test]]
fn test_is_short_header() -> i32
    # 0x40 = 0100 0000 (form=0, fixed=1)
    if quic_is_long_header(0x40) != 0
        return 1
    return 0

[[test]]
fn test_long_packet_type_initial() -> i32
    if quic_long_packet_type(0xC0) != QUIC_PKT_INITIAL
        return 1
    return 0

[[test]]
fn test_long_packet_type_0rtt() -> i32
    # 0xD0 = 1101 0000 (type=01)
    if quic_long_packet_type(0xD0) != QUIC_PKT_0RTT
        return 1
    return 0

[[test]]
fn test_long_packet_type_handshake() -> i32
    # 0xE0 = 1110 0000 (type=10)
    if quic_long_packet_type(0xE0) != QUIC_PKT_HANDSHAKE
        return 1
    return 0

[[test]]
fn test_long_packet_type_retry() -> i32
    # 0xF0 = 1111 0000 (type=11)
    if quic_long_packet_type(0xF0) != QUIC_PKT_RETRY
        return 1
    return 0

# ============================================================================
# Long Header Parsing
# ============================================================================

[[test]]
fn test_parse_long_header_minimal() -> i32
    # Minimal Handshake packet (no token, 0-length payload)
    # First byte: 0xE0 (form=1, fixed=1, type=Handshake)
    # Version: 0x00000001
    # DCID len: 0
    # SCID len: 0
    # Payload len: 0 (varint 0x00)
    var buf: [32]u8
    buf[0] = 0xE0  # Handshake
    buf[1] = 0x00  # Version high
    buf[2] = 0x00
    buf[3] = 0x00
    buf[4] = 0x01  # Version = 1
    buf[5] = 0x00  # DCID len = 0
    buf[6] = 0x00  # SCID len = 0
    buf[7] = 0x00  # Payload len = 0

    var h: QuicLongHeader
    let ret: i32 = quic_parse_long_header(@buf[0], 8, @h)
    if ret < 0
        return 1
    if h.packet_type != QUIC_PKT_HANDSHAKE
        return 2
    if h.version != QUIC_VERSION_1
        return 3
    if h.dcid_len != 0
        return 4
    if h.scid_len != 0
        return 5
    if h.payload_len != 0
        return 6
    return 0

[[test]]
fn test_parse_long_header_with_cids() -> i32
    # Initial packet with connection IDs
    var buf: [64]u8
    buf[0] = 0xC0  # Initial
    buf[1] = 0x00  # Version
    buf[2] = 0x00
    buf[3] = 0x00
    buf[4] = 0x01
    buf[5] = 0x08  # DCID len = 8
    # DCID: 01 02 03 04 05 06 07 08
    buf[6] = 0x01
    buf[7] = 0x02
    buf[8] = 0x03
    buf[9] = 0x04
    buf[10] = 0x05
    buf[11] = 0x06
    buf[12] = 0x07
    buf[13] = 0x08
    buf[14] = 0x04  # SCID len = 4
    # SCID: AA BB CC DD
    buf[15] = 0xAA
    buf[16] = 0xBB
    buf[17] = 0xCC
    buf[18] = 0xDD
    buf[19] = 0x00  # Token len = 0 (Initial packet has token field)
    buf[20] = 0x00  # Payload len = 0

    var h: QuicLongHeader
    let ret: i32 = quic_parse_long_header(@buf[0], 32, @h)
    if ret < 0
        return 1
    if h.packet_type != QUIC_PKT_INITIAL
        return 2
    if h.dcid_len != 8
        return 3
    if h.scid_len != 4
        return 4
    # Check DCID
    if h.dcid[0] != 0x01 || h.dcid[7] != 0x08
        return 5
    # Check SCID
    if h.scid[0] != 0xAA || h.scid[3] != 0xDD
        return 6
    return 0

[[test]]
fn test_parse_long_header_with_token() -> i32
    # Initial packet with a 5-byte token
    var buf: [64]u8
    buf[0] = 0xC0  # Initial
    buf[1] = 0x00  # Version
    buf[2] = 0x00
    buf[3] = 0x00
    buf[4] = 0x01
    buf[5] = 0x00  # DCID len = 0
    buf[6] = 0x00  # SCID len = 0
    buf[7] = 0x05  # Token len = 5 (1-byte varint)
    # Token: DE AD BE EF 00
    buf[8] = 0xDE
    buf[9] = 0xAD
    buf[10] = 0xBE
    buf[11] = 0xEF
    buf[12] = 0x00
    buf[13] = 0x00  # Payload len = 0

    var h: QuicLongHeader
    let ret: i32 = quic_parse_long_header(@buf[0], 32, @h)
    if ret < 0
        return 1
    if h.token_len != 5
        return 2
    if h.token_offset != 8
        return 3
    return 0

[[test]]
fn test_parse_long_header_incomplete() -> i32
    var buf: [4]u8
    buf[0] = 0xC0  # Initial
    buf[1] = 0x00
    buf[2] = 0x00
    buf[3] = 0x00

    var h: QuicLongHeader
    let ret: i32 = quic_parse_long_header(@buf[0], 4, @h)
    if ret != QUIC_ERR_INCOMPLETE
        return 1
    return 0

[[test]]
fn test_parse_long_header_invalid_form() -> i32
    # Short header form (bit 7 = 0)
    var buf: [32]u8
    buf[0] = 0x40  # Short header

    var h: QuicLongHeader
    let ret: i32 = quic_parse_long_header(@buf[0], 32, @h)
    if ret != QUIC_ERR_INVALID
        return 1
    return 0

[[test]]
fn test_parse_long_header_invalid_fixed_bit() -> i32
    # Fixed bit = 0 (invalid)
    var buf: [32]u8
    buf[0] = 0x80  # form=1, fixed=0

    var h: QuicLongHeader
    let ret: i32 = quic_parse_long_header(@buf[0], 32, @h)
    if ret != QUIC_ERR_INVALID
        return 1
    return 0

# ============================================================================
# Short Header Parsing
# ============================================================================

[[test]]
fn test_parse_short_header_minimal() -> i32
    # Short header with no DCID
    var buf: [16]u8
    buf[0] = 0x40  # form=0, fixed=1, spin=0, reserved=0, key_phase=0, pn_len=0

    var h: QuicShortHeader
    let ret: i32 = quic_parse_short_header(@buf[0], 16, 0, @h)
    if ret < 0
        return 1
    if h.spin_bit != 0
        return 2
    if h.key_phase != 0
        return 3
    if h.pn_len != 1  # pn_len encoded as 0 means 1 byte
        return 4
    if h.dcid_len != 0
        return 5
    return 0

[[test]]
fn test_parse_short_header_with_dcid() -> i32
    # Short header with 8-byte DCID
    var buf: [16]u8
    buf[0] = 0x43  # form=0, fixed=1, spin=0, reserved=0, key_phase=0, pn_len=3 (4 bytes)
    buf[1] = 0x01
    buf[2] = 0x02
    buf[3] = 0x03
    buf[4] = 0x04
    buf[5] = 0x05
    buf[6] = 0x06
    buf[7] = 0x07
    buf[8] = 0x08

    var h: QuicShortHeader
    let ret: i32 = quic_parse_short_header(@buf[0], 16, 8, @h)
    if ret != 9  # 1 + 8
        return 1
    if h.pn_len != 4
        return 2
    if h.dcid[0] != 0x01 || h.dcid[7] != 0x08
        return 3
    return 0

[[test]]
fn test_parse_short_header_spin_key() -> i32
    # Short header with spin=1, key_phase=1
    var buf: [8]u8
    buf[0] = 0x64  # form=0, fixed=1, spin=1, reserved=0, key_phase=1, pn_len=0

    var h: QuicShortHeader
    let ret: i32 = quic_parse_short_header(@buf[0], 8, 0, @h)
    if ret < 0
        return 1
    if h.spin_bit != 1
        return 2
    if h.key_phase != 1
        return 3
    return 0

[[test]]
fn test_parse_short_header_invalid_form() -> i32
    # Long header form (bit 7 = 1)
    var buf: [16]u8
    buf[0] = 0xC0  # Long header

    var h: QuicShortHeader
    let ret: i32 = quic_parse_short_header(@buf[0], 16, 0, @h)
    if ret != QUIC_ERR_INVALID
        return 1
    return 0

# ============================================================================
# Long Header Writing
# ============================================================================

[[test]]
fn test_write_long_header_handshake() -> i32
    var h: QuicLongHeader
    quic_long_header_init(@h)
    h.packet_type = QUIC_PKT_HANDSHAKE
    h.version = QUIC_VERSION_1
    h.dcid_len = 0
    h.scid_len = 0
    h.payload_len = 0

    var buf: [64]u8
    let ret: i32 = quic_write_long_header(@h, @buf[0], 64)
    if ret < 0
        return 1

    # Verify first byte
    if buf[0] != 0xE0  # Handshake type
        return 2

    # Verify version
    if buf[1] != 0x00 || buf[2] != 0x00 || buf[3] != 0x00 || buf[4] != 0x01
        return 3

    # Verify CID lengths
    if buf[5] != 0x00 || buf[6] != 0x00
        return 4

    return 0

[[test]]
fn test_write_long_header_with_cids() -> i32
    var h: QuicLongHeader
    quic_long_header_init(@h)
    h.packet_type = QUIC_PKT_HANDSHAKE
    h.version = QUIC_VERSION_1
    h.dcid_len = 4
    h.dcid[0] = 0x11
    h.dcid[1] = 0x22
    h.dcid[2] = 0x33
    h.dcid[3] = 0x44
    h.scid_len = 2
    h.scid[0] = 0xAA
    h.scid[1] = 0xBB
    h.payload_len = 100

    var buf: [64]u8
    let ret: i32 = quic_write_long_header(@h, @buf[0], 64)
    if ret < 0
        return 1

    # Check DCID
    if buf[5] != 4  # DCID len
        return 2
    if buf[6] != 0x11 || buf[9] != 0x44
        return 3

    # Check SCID
    if buf[10] != 2  # SCID len
        return 4
    if buf[11] != 0xAA || buf[12] != 0xBB
        return 5

    return 0

[[test]]
fn test_write_long_header_roundtrip() -> i32
    # Create a header, write it, parse it back
    var h1: QuicLongHeader
    quic_long_header_init(@h1)
    h1.packet_type = QUIC_PKT_HANDSHAKE
    h1.version = QUIC_VERSION_1
    h1.dcid_len = 8
    h1.dcid[0] = 0x01
    h1.dcid[7] = 0x08
    h1.scid_len = 4
    h1.scid[0] = 0xAA
    h1.scid[3] = 0xDD
    h1.payload_len = 256

    var buf: [64]u8
    let wret: i32 = quic_write_long_header(@h1, @buf[0], 64)
    if wret < 0
        return 1

    var h2: QuicLongHeader
    let pret: i32 = quic_parse_long_header(@buf[0], 64, @h2)
    if pret < 0
        return 2

    if h2.packet_type != h1.packet_type
        return 3
    if h2.version != h1.version
        return 4
    if h2.dcid_len != h1.dcid_len
        return 5
    if h2.scid_len != h1.scid_len
        return 6
    if h2.payload_len != h1.payload_len
        return 7

    return 0
