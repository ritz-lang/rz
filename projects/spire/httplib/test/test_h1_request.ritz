    let result: i32 = h1_parse_request_line(@req, @input)
    if result < 0
        return 1

    var expected_path: Span<u8> = span_from_cstr(c"/api/users")
    if span_eq(@req.path, @expected_path) != 1
        return 2

    return 0

[[test]]
fn test_parse_request_line_post() -> i32
    var input: Span<u8> = span_from_cstr(c"POST /submit HTTP/1.0\r\n")
    var req: H1Request
    h1_request_init(@req)

    let result: i32 = h1_parse_request_line(@req, @input)
    if result < 0
        return 1

    if req.method != METHOD_POST
        return 2

    if req.version != VERSION_HTTP10
        return 3

    return 0

[[test]]
fn test_parse_request_line_with_query() -> i32
    var input: Span<u8> = span_from_cstr(c"GET /search?q=hello@page=1 HTTP/1.1\r\n")
    var req: H1Request
    h1_request_init(@req)

    let result: i32 = h1_parse_request_line(@req, @input)
    if result < 0
        return 1

    var expected_path: Span<u8> = span_from_cstr(c"/search?q=hello@page=1")
    if span_eq(@req.path, @expected_path) != 1
        return 2

    return 0

[[test]]
fn test_parse_request_line_invalid_empty() -> i32
    var input: Span<u8> = span_from_cstr(c"")
    var req: H1Request
    h1_request_init(@req)

    let result: i32 = h1_parse_request_line(@req, @input)
    if result >= 0
        return 1  # Should fail

    return 0

[[test]]
fn test_parse_request_line_invalid_no_space() -> i32
    var input: Span<u8> = span_from_cstr(c"GET\r\n")
    var req: H1Request
    h1_request_init(@req)

    let result: i32 = h1_parse_request_line(@req, @input)
    if result >= 0
        return 1  # Should fail

    return 0

# ============================================================================
# Header Parsing Tests
# ============================================================================

[[test]]
fn test_parse_header_content_length() -> i32
    var input: Span<u8> = span_from_cstr(c"Content-Length: 42\r\n")
    var name: Span<u8>
    var value: Span<u8>

    let result: i32 = h1_parse_header(@input, @name, @value)
    if result < 0
        return 1

    var expected_name: Span<u8> = span_from_cstr(c"Content-Length")
    var expected_value: Span<u8> = span_from_cstr(c"42")

    if span_eq(@name, @expected_name) != 1
        return 2

    if span_eq(@value, @expected_value) != 1
        return 3

    return 0

[[test]]
fn test_parse_header_content_type() -> i32
    var input: Span<u8> = span_from_cstr(c"Content-Type: application/json\r\n")
    var name: Span<u8>
    var value: Span<u8>

    let result: i32 = h1_parse_header(@input, @name, @value)
    if result < 0
        return 1

    var expected_value: Span<u8> = span_from_cstr(c"application/json")
    if span_eq(@value, @expected_value) != 1
        return 2

    return 0

[[test]]
fn test_parse_header_with_spaces() -> i32
    var input: Span<u8> = span_from_cstr(c"Host:   example.com  \r\n")
    var name: Span<u8>
    var value: Span<u8>

    let result: i32 = h1_parse_header(@input, @name, @value)
    if result < 0
        return 1

    # Value should be trimmed
    var expected_value: Span<u8> = span_from_cstr(c"example.com")
    if span_eq(@value, @expected_value) != 1
        return 2

    return 0

[[test]]
fn test_parse_header_empty_line() -> i32
    var input: Span<u8> = span_from_cstr(c"\r\n")
    var name: Span<u8>
    var value: Span<u8>

    let result: i32 = h1_parse_header(@input, @name, @value)
    # Empty line signals end of headers - should return 0 with empty name
    if result != 0
        return 1

    if name.len != 0
        return 2

    return 0

# ============================================================================
# Full Request Parsing Tests
# ============================================================================

[[test]]
fn test_parse_full_request_no_body() -> i32
    var input: Span<u8> = span_from_cstr(c"GET / HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n")
    var req: H1Request
    h1_request_init(@req)

    let result: i32 = h1_parse_request(@req, @input)
    if result < 0
        return 1

    if req.method != METHOD_GET
        return 2

    if req.header_count != 2
        return 3

    return 0

[[test]]
fn test_parse_full_request_with_body() -> i32
    var input: Span<u8> = span_from_cstr(c"POST /api HTTP/1.1\r\nContent-Length: 13\r\n\r\nHello, World!")
    var req: H1Request
    h1_request_init(@req)

    let result: i32 = h1_parse_request(@req, @input)
    if result < 0
        return 1

    if req.method != METHOD_POST
        return 2

    if req.content_length != 13
        return 3

    var expected_body: Span<u8> = span_from_cstr(c"Hello, World!")
    if span_eq(@req.body, @expected_body) != 1
        return 4

    return 0

[[test]]
fn test_parse_request_get_header() -> i32
    var input: Span<u8> = span_from_cstr(c"GET / HTTP/1.1\r\nHost: localhost:8080\r\nUser-Agent: test\r\n\r\n")
    var req: H1Request
    h1_request_init(@req)

    let result: i32 = h1_parse_request(@req, @input)
    if result < 0
        return 1

    var host: Span<u8> = h1_request_get_header(@req, c"Host")
    var expected: Span<u8> = span_from_cstr(c"localhost:8080")
    if span_eq(@host, @expected) != 1
        return 2

    var ua: Span<u8> = h1_request_get_header(@req, c"User-Agent")
    var expected_ua: Span<u8> = span_from_cstr(c"test")
    if span_eq(@ua, @expected_ua) != 1
        return 3

    return 0

[[test]]
fn test_parse_request_header_case_insensitive() -> i32
    var input: Span<u8> = span_from_cstr(c"GET / HTTP/1.1\r\nhost: localhost\r\ncontent-type: text/html\r\n\r\n")
    var req: H1Request
    h1_request_init(@req)

    let result: i32 = h1_parse_request(@req, @input)
    if result < 0
        return 1

    # Should find headers regardless of case
    var host: Span<u8> = h1_request_get_header(@req, c"HOST")
    if host.len == 0
        return 2

    var ct: Span<u8> = h1_request_get_header(@req, c"Content-Type")
    if ct.len == 0
        return 3

    return 0

[[test]]
fn test_parse_request_keep_alive_http11() -> i32
    var input: Span<u8> = span_from_cstr(c"GET / HTTP/1.1\r\nHost: test\r\n\r\n")
    var req: H1Request
    h1_request_init(@req)

    let result: i32 = h1_parse_request(@req, @input)
    if result < 0
        return 1

    # HTTP/1.1 defaults to keep-alive
    if h1_request_is_keep_alive(@req) != 1
        return 2

    return 0

[[test]]
fn test_parse_request_keep_alive_http10() -> i32
    var input: Span<u8> = span_from_cstr(c"GET / HTTP/1.0\r\nHost: test\r\n\r\n")
    var req: H1Request
    h1_request_init(@req)

    let result: i32 = h1_parse_request(@req, @input)
    if result < 0
        return 1

    # HTTP/1.0 defaults to close
    if h1_request_is_keep_alive(@req) != 0
        return 2

    return 0

[[test]]
fn test_parse_request_connection_close() -> i32
    var input: Span<u8> = span_from_cstr(c"GET / HTTP/1.1\r\nConnection: close\r\n\r\n")
    var req: H1Request
    h1_request_init(@req)

    let result: i32 = h1_parse_request(@req, @input)
    if result < 0
        return 1

    # Explicit close overrides default
    if h1_request_is_keep_alive(@req) != 0
        return 2

    return 0
