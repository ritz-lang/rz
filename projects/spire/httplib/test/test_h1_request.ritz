# test/test_h1_request.ritz - Tests for HTTP/1.x request parsing
#
# Tests request line parsing, header parsing, and body handling.

import ritzlib.span
import ritzlib.str
import lib.types
import lib.h1_request

# ============================================================================
# Request Line Parsing Tests
# ============================================================================

[[test]]
fn test_parse_request_line_get_root() -> i32
    var input: Span<u8> = span_from_cstr(c"GET / HTTP/1.1\r\n")
    var req: H1Request
    h1_request_init(@req)

    let result: i32 = h1_parse_request_line(@req, @input)
    if result < 0
        return 1

    if req.method != METHOD_GET
        return 2

    var expected_path: Span<u8> = span_from_cstr(c"/")
    if span_eq(@req.path, @expected_path) != 1
        return 3

    if req.version != VERSION_HTTP11
        return 4

    return 0

[[test]]
fn test_parse_request_line_get_path() -> i32
    var input: Span<u8> = span_from_cstr(c"GET /api/users HTTP/1.1\r\n")
    var req: H1Request
