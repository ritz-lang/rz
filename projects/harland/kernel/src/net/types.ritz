# ============================================================================

pub const ARP_HW_ETHERNET: u16 = 1
pub const ARP_PROTO_IPV4: u16 = 0x0800
pub const ARP_OP_REQUEST: u16 = 1
pub const ARP_OP_REPLY: u16 = 2
pub const ARP_PACKET_SIZE: u32 = 28     # Size of ARP packet (Ethernet/IPv4)

