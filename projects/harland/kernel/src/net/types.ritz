# ============================================================================
# Utility Functions
# ============================================================================

# Copy MAC address (6 bytes)
pub fn mac_copy(dst: *u8, src: *u8)
    var i: i32 = 0
    while i < 6
        *(dst + i as i64) = *(src + i as i64)
        i = i + 1

# Copy IPv4 address (4 bytes)
pub fn ip_copy(dst: *u8, src: *u8)
    var i: i32 = 0
    while i < 4
        *(dst + i as i64) = *(src + i as i64)
        i = i + 1

# Compare IPv4 addresses (returns true if equal)
pub fn ip_eq(a: *u8, b: *u8) -> bool
    var i: i32 = 0
    while i < 4
        if *(a + i as i64) != *(b + i as i64)
            return false
        i = i + 1
    return true

# Compare MAC addresses (returns true if equal)
pub fn mac_eq(a: *u8, b: *u8) -> bool
    var i: i32 = 0
    while i < 6
        if *(a + i as i64) != *(b + i as i64)
            return false
        i = i + 1
    return true

# Check if MAC is broadcast (FF:FF:FF:FF:FF:FF)
pub fn mac_is_broadcast(mac: *u8) -> bool
    var i: i32 = 0
    while i < 6
        if *(mac + i as i64) != 0xFF
            return false
        i = i + 1
    return true

# Zero out a buffer
pub fn memzero(buf: *u8, len: u32)
    var i: u32 = 0
    while i < len
        *(buf + i as i64) = 0
        i = i + 1

# Copy memory
pub fn memcpy(dst: *u8, src: *u8, len: u32)
    var i: u32 = 0
    while i < len
        *(dst + i as i64) = *(src + i as i64)
        i = i + 1
