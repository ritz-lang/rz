# net/types.ritz - Common Network Types and Utilities
#
# Foundation for the network stack:
# - Byte order conversions (host <-> network)
# - Protocol constants
# - Shared types used across layers

# ============================================================================
# Byte Order Conversion
# ============================================================================
#
# Network byte order is big-endian. x86 is little-endian.
# These functions convert between the two.

# Convert 16-bit value from host to network byte order (big-endian)
pub fn htons(val: u16) -> u16
    let high: u16 = (val >> 8) & 0xFF
    let low: u16 = val & 0xFF
    return (low << 8) | high

# Convert 16-bit value from network to host byte order
pub fn ntohs(val: u16) -> u16
    return htons(val)  # Same operation (symmetric)

# Convert 32-bit value from host to network byte order
pub fn htonl(val: u32) -> u32
    let b0: u32 = (val >> 24) & 0xFF
    let b1: u32 = (val >> 16) & 0xFF
    let b2: u32 = (val >> 8) & 0xFF
    let b3: u32 = val & 0xFF
    return (b3 << 24) | (b2 << 16) | (b1 << 8) | b0

# Convert 32-bit value from network to host byte order
pub fn ntohl(val: u32) -> u32
    return htonl(val)  # Same operation (symmetric)

# ============================================================================
# Ethernet Constants (Layer 2)
# ============================================================================

# EtherType values (in host byte order - convert with htons before wire)
pub const ETHERTYPE_IPV4: u16 = 0x0800
pub const ETHERTYPE_ARP: u16 = 0x0806
pub const ETHERTYPE_IPV6: u16 = 0x86DD

# Frame sizes
pub const ETH_HEADER_SIZE: u32 = 14
pub const ETH_MIN_FRAME: u32 = 60       # Minimum frame size (excluding FCS)
pub const ETH_MAX_FRAME: u32 = 1514     # Maximum frame size (excluding FCS)
pub const ETH_MTU: u32 = 1500           # Maximum transmission unit

