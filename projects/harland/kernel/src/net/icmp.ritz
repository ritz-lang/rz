# net/icmp.ritz - Internet Control Message Protocol
#
# Handles ICMP echo (ping) request and reply.

import serial { prints, serial_print_dec }
import net.types { IP_PROTO_ICMP, ETHERTYPE_IPV4, ICMP_ECHO_REQUEST, ICMP_ECHO_REPLY, ICMP_HEADER_SIZE }
import net.ip { ip_checksum, ip_build_header, ip_get_gateway, ip_is_local, ip_get_next_hop }
import net.arp { arp_cache_lookup, arp_send_request }
import net.eth { eth_build_frame }

# Forward declaration - send through active network device
extern fn net_send(data: *u8, len: u32) -> i32

# ============================================================================
# ICMP State
# ============================================================================

var icmp_seq: u16 = 0
var icmp_waiting: u8 = 0
var icmp_last_rtt: u64 = 0

# ============================================================================
# ICMP Echo Header Structure
# ============================================================================

pub struct IcmpEchoHeader
    type_code: u8       # Type (8=request, 0=reply)
    code: u8            # Code (always 0 for echo)
    checksum: u16
    id: u16
    seq: u16

# ============================================================================
# Send ICMP Echo Request (Ping)
# ============================================================================

pub fn icmp_ping(dst_ip: *u8) -> i32
    var frame: [128]u8
    var ip_buf: [64]u8
    var icmp_buf: [40]u8

    # Build ICMP header
    icmp_buf[0] = ICMP_ECHO_REQUEST
    icmp_buf[1] = 0
    icmp_buf[2] = 0  # Checksum placeholder
    icmp_buf[3] = 0
    icmp_buf[4] = 0  # ID high
    icmp_buf[5] = 1  # ID low
    icmp_seq = icmp_seq + 1
    icmp_buf[6] = ((icmp_seq >> 8) & 0xFF) as u8
    icmp_buf[7] = (icmp_seq & 0xFF) as u8

    # Add some data payload
    var i: i32 = 8
    while i < 40
        icmp_buf[i] = ((i - 8) as u8)
        i = i + 1

    let icmp_len: u32 = 40

    # Calculate ICMP checksum
    let cksum: u16 = ip_checksum(@icmp_buf[0], icmp_len)
    icmp_buf[2] = ((cksum >> 8) & 0xFF) as u8
    icmp_buf[3] = (cksum & 0xFF) as u8

    # Build IP header
    let ip_len: u32 = ip_build_header(@ip_buf[0], dst_ip, IP_PROTO_ICMP, icmp_len)

    # Copy ICMP after IP header
    var j: i32 = 0
    while j < icmp_len as i32
        ip_buf[ip_len as i32 + j] = icmp_buf[j]
        j = j + 1

    # Get next hop IP (gateway if not local, direct if local)
    let next_hop: *u8 = ip_get_next_hop(dst_ip)

    # Look up MAC address
    var dst_mac: [6]u8
    if arp_cache_lookup(next_hop, @dst_mac[0]) < 0
        # Need to ARP for next hop
        prints("[icmp] ARP lookup needed for next hop\n")
        arp_send_request(next_hop)
        return -1  # Caller should retry

    # Build Ethernet frame
    let frame_len: u32 = eth_build_frame(@frame[0], @dst_mac[0], ETHERTYPE_IPV4, @ip_buf[0], ip_len + icmp_len)

    icmp_waiting = 1

    # Send
    return net_send(@frame[0], frame_len)

# ============================================================================
# Handle Received ICMP Packet
# ============================================================================

pub fn icmp_handle_packet(icmp_buf: *u8, len: u32, src_ip: *u8)
    if len < ICMP_HEADER_SIZE
        return

    let icmp_type: u8 = *(icmp_buf + 0)

    if icmp_type == ICMP_ECHO_REPLY
        prints("[icmp] Reply from ")
        icmp_print_ip(src_ip)
        prints(" seq=")
        let seq: u16 = ((*(icmp_buf + 6) as u16) << 8) | (*(icmp_buf + 7) as u16)
        serial_print_dec(seq as u64)
        prints("\n")
        icmp_waiting = 0

    else if icmp_type == ICMP_ECHO_REQUEST
        # Respond to ping
        prints("[icmp] Echo request from ")
        icmp_print_ip(src_ip)
        prints("\n")

        # Send echo reply
        icmp_send_reply(icmp_buf, len, src_ip)

# ============================================================================
# Send ICMP Echo Reply
# ============================================================================

fn icmp_send_reply(request_buf: *u8, request_len: u32, dst_ip: *u8)
    var frame: [128]u8
    var ip_buf: [64]u8
    var icmp_buf: [64]u8

    # Copy the request data
    var i: i32 = 0
    while i < request_len as i32 and i < 64
        icmp_buf[i] = *(request_buf + i as i64)
        i = i + 1

    let icmp_len: u32 = request_len
    if icmp_len > 64
        return  # Too large

    # Change type to reply
    icmp_buf[0] = ICMP_ECHO_REPLY
    icmp_buf[1] = 0

    # Zero checksum and recalculate
    icmp_buf[2] = 0
    icmp_buf[3] = 0
    let cksum: u16 = ip_checksum(@icmp_buf[0], icmp_len)
    icmp_buf[2] = ((cksum >> 8) & 0xFF) as u8
    icmp_buf[3] = (cksum & 0xFF) as u8

    # Build IP header
    let ip_len: u32 = ip_build_header(@ip_buf[0], dst_ip, IP_PROTO_ICMP, icmp_len)

    # Copy ICMP after IP header
    var j: i32 = 0
    while j < icmp_len as i32
        ip_buf[ip_len as i32 + j] = icmp_buf[j]
        j = j + 1

    # Get next hop IP
    let next_hop: *u8 = ip_get_next_hop(dst_ip)

    # Look up MAC address
    var dst_mac: [6]u8
    if arp_cache_lookup(next_hop, @dst_mac[0]) < 0
        # Can't send reply without MAC - ARP cache should have it from request
        prints("[icmp] Cannot send reply: no MAC for sender\n")
        return

    # Build Ethernet frame
    let frame_len: u32 = eth_build_frame(@frame[0], @dst_mac[0], ETHERTYPE_IPV4, @ip_buf[0], ip_len + icmp_len)

    # Send
    net_send(@frame[0], frame_len)
    prints("[icmp] Sent reply to ")
    icmp_print_ip(dst_ip)
    prints("\n")

# ============================================================================
# Query State
# ============================================================================

pub fn icmp_is_waiting() -> bool
    return icmp_waiting == 1

pub fn icmp_get_last_rtt() -> u64
    return icmp_last_rtt

pub fn icmp_clear_waiting()
    icmp_waiting = 0

# ============================================================================
# Debug
# ============================================================================

fn icmp_print_ip(ip: *u8)
    serial_print_dec(*(ip + 0) as u64)
    prints(".")
    serial_print_dec(*(ip + 1) as u64)
    prints(".")
    serial_print_dec(*(ip + 2) as u64)
    prints(".")
    serial_print_dec(*(ip + 3) as u64)
