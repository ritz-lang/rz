# Storage Backend Types
#
# Defines the different storage backends that can back namespace nodes.
# This separates "where things appear" from "how they're stored".

import serial { StrView, prints, print_hex }

# Backend types - how data is actually stored
pub const BACKEND_NONE: u8 = 0       # Pure namespace node (no data)
pub const BACKEND_GOLIATH: u8 = 1    # Content-addressed blob store (persistent)
pub const BACKEND_MEMORY: u8 = 2     # Kernel heap (volatile/ephemeral)
pub const BACKEND_DEVICE: u8 = 3     # Device driver managed

# Visibility levels - who can see this node
pub const VIS_PUBLIC: u8 = 0         # Everyone can see AND access
pub const VIS_VISIBLE: u8 = 1        # Everyone sees it, needs caps to access
pub const VIS_HIDDEN: u8 = 2         # Only those with caps can see it
pub const VIS_KERNEL_ONLY: u8 = 3    # Only kernel can see it

# Node types - what kind of resource this is
pub const NODE_FILE: u8 = 0          # Regular file
pub const NODE_DIRECTORY: u8 = 1     # Directory
pub const NODE_DEVICE: u8 = 2        # Block or character device
pub const NODE_PIPE: u8 = 3          # Anonymous pipe
pub const NODE_SOCKET: u8 = 4        # Unix domain socket
pub const NODE_SYMLINK: u8 = 5       # Symbolic link
pub const NODE_MOUNT: u8 = 6         # Mount point

# Capability flags for access control
pub const CAP_READ: u64 = 1
pub const CAP_WRITE: u64 = 2
pub const CAP_EXECUTE: u64 = 4
pub const CAP_DELETE: u64 = 8
pub const CAP_CREATE: u64 = 16
pub const CAP_ADMIN: u64 = 32
pub const CAP_BLOCK_DEVICE: u64 = 64
pub const CAP_CHAR_DEVICE: u64 = 128
pub const CAP_NET: u64 = 256
pub const CAP_MOUNT: u64 = 512

# Backend handle - union of different backend references
pub struct BackendHandle
    # For BACKEND_GOLIATH: blob hash
    # For BACKEND_MEMORY: pointer to MemoryFile
    # For BACKEND_DEVICE: device ID
    handle: u64
    handle_high: u64  # For 128-bit blob hashes

# Memory-backed file structure (for pipes, tmpfs, etc.)
pub struct MemoryFile
    data: *u8
    capacity: u64
    size: u64

    # For pipes: ring buffer semantics
    read_pos: u64
    write_pos: u64

    # Reference counting
    readers: u32
    writers: u32

    # Owner process (for cleanup on exit)
    owner_pid: u32

    # Flags
    flags: u32

# Memory file flags
pub const MEMFILE_PIPE: u32 = 1      # Ring buffer semantics
pub const MEMFILE_GROWABLE: u32 = 2  # Can grow beyond initial capacity
pub const MEMFILE_SHARED: u32 = 4    # Shared between processes

# Print backend type name
pub fn backend_name(backend: u8) -> StrView
    if backend == BACKEND_NONE
        return "none" as StrView
    if backend == BACKEND_GOLIATH
        return "goliath" as StrView
    if backend == BACKEND_MEMORY
        return "memory" as StrView
    if backend == BACKEND_DEVICE
        return "device" as StrView
    "unknown" as StrView

# Print visibility level name
pub fn visibility_name(vis: u8) -> StrView
    if vis == VIS_PUBLIC
        return "public" as StrView
    if vis == VIS_VISIBLE
        return "visible" as StrView
    if vis == VIS_HIDDEN
        return "hidden" as StrView
    if vis == VIS_KERNEL_ONLY
        return "kernel-only" as StrView
    "unknown" as StrView

# Print node type name
pub fn node_type_name(ntype: u8) -> StrView
    if ntype == NODE_FILE
        return "file" as StrView
    if ntype == NODE_DIRECTORY
        return "dir" as StrView
    if ntype == NODE_DEVICE
        return "device" as StrView
    if ntype == NODE_PIPE
        return "pipe" as StrView
    if ntype == NODE_SOCKET
        return "socket" as StrView
    if ntype == NODE_SYMLINK
        return "symlink" as StrView
    if ntype == NODE_MOUNT
        return "mount" as StrView
    "unknown" as StrView

# Check if a capability set includes required capabilities
pub fn caps_check(have: u64, need: u64) -> bool
    (have & need) == need

# Create a read-only derived capability
pub fn caps_derive_readonly(caps: u64) -> u64
    caps & CAP_READ
