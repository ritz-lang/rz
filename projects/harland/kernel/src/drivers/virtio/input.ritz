# VirtIO Input Device Driver
#
# Implements a driver for VirtIO input devices (keyboard, mouse, tablet).
# Uses Linux evdev event format over VirtIO transport.
#
# References:
# - https://docs.oasis-open.org/virtio/virtio/v1.1/virtio-v1.1.html#x1-3850008
# - https://www.kernel.org/doc/html/latest/input/event-codes.html

import serial { prints, println, serial_print_hex, serial_print_hex8, serial_print_dec }
import drivers.pci { PciDevice, pci_find_virtio, pci_find_virtio_nth, pci_enable_bus_master, pci_enable_io, VIRTIO_DEVICE_INPUT }
import drivers.virtio.common { VirtioDevice, Virtqueue, VringDesc, vio_init_device, vio_device_ready, vio_get_features, vio_set_features, vio_features_ok, vio_setup_queue, vq_alloc_desc, vq_free_desc, vq_get_desc, vq_submit, vq_notify, vq_has_used, vq_get_used, vq_get_used_len, VRING_DESC_F_WRITE }
import mm.heap { kalloc, kfree }
import mm.vmm { vmm_virt_to_phys }
import mm.pmm { pmm_alloc_page, PAGE_SIZE }

# ============================================================================
# VirtIO Input Config Select Values
# ============================================================================

const VIRTIO_INPUT_CFG_UNSET: u8 = 0x00
const VIRTIO_INPUT_CFG_ID_NAME: u8 = 0x01
const VIRTIO_INPUT_CFG_ID_SERIAL: u8 = 0x02
const VIRTIO_INPUT_CFG_ID_DEVIDS: u8 = 0x03
const VIRTIO_INPUT_CFG_PROP_BITS: u8 = 0x10
const VIRTIO_INPUT_CFG_EV_BITS: u8 = 0x11
const VIRTIO_INPUT_CFG_ABS_INFO: u8 = 0x12

# ============================================================================
# Linux Input Event Types
# ============================================================================

pub const EV_SYN: u16 = 0x00    # Synchronization events
pub const EV_KEY: u16 = 0x01    # Key/button events
pub const EV_REL: u16 = 0x02    # Relative axis (mouse movement)
pub const EV_ABS: u16 = 0x03    # Absolute axis (touchscreen, tablet)

# Synchronization codes
pub const SYN_REPORT: u16 = 0   # End of event packet

# ============================================================================
# Key Codes (Linux input-event-codes.h subset)
# ============================================================================

