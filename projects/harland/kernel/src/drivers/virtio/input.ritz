# ============================================================================
# Relative Axis Codes (for mouse)
# ============================================================================

pub const REL_X: u16 = 0x00
pub const REL_Y: u16 = 0x01
pub const REL_WHEEL: u16 = 0x08

# ============================================================================
# Mouse Button Codes
# ============================================================================

pub const BTN_LEFT: u16 = 0x110
pub const BTN_RIGHT: u16 = 0x111
pub const BTN_MIDDLE: u16 = 0x112

# ============================================================================
# VirtIO Input Event Structure (8 bytes)
# ============================================================================

pub struct VirtioInputEvent
    event_type: u16     # EV_KEY, EV_REL, etc.
    code: u16           # Key code or axis
    value: i32          # 0=release, 1=press, 2=repeat, or axis value

const VIRTIO_INPUT_EVENT_SIZE: u64 = 8

# ============================================================================
# Input Event Ring Buffer (for userspace)
# ============================================================================

const INPUT_RING_SIZE: i32 = 256

struct InputRing
    events: [256]VirtioInputEvent
    head: i32       # Next slot to write
    tail: i32       # Next slot to read
    count: i32      # Number of events in buffer

var g_input_ring: InputRing

# ============================================================================
# VirtIO Input Device Structure
# ============================================================================

pub struct VirtioInputDevice
    virtio_dev: *VirtioDevice   # Underlying VirtIO device
    event_queue: *Virtqueue     # Event virtqueue (queue 0)
    status_queue: *Virtqueue    # Status virtqueue (queue 1)
    event_buffers: *u8          # Pre-allocated event buffers
    event_buffer_phys: u64      # Physical address of buffers
    device_type: u8             # 0=unknown, 1=keyboard, 2=mouse, 3=tablet
    _padding: [7]u8

const VIRTIO_INPUT_DEVICE_SIZE: u64 = 48
const NUM_EVENT_BUFFERS: i32 = 64

# ============================================================================
# Global Input Device
# ============================================================================

var input_device: *VirtioInputDevice = 0 as *VirtioInputDevice

# ============================================================================
# Ring Buffer Operations
# ============================================================================

fn ring_init()
    g_input_ring.head = 0
    g_input_ring.tail = 0
    g_input_ring.count = 0

fn ring_push(event: *VirtioInputEvent) -> bool
    if g_input_ring.count >= INPUT_RING_SIZE
        return false  # Buffer full

    g_input_ring.events[g_input_ring.head] = *event
    g_input_ring.head = (g_input_ring.head + 1) % INPUT_RING_SIZE
    g_input_ring.count = g_input_ring.count + 1
    return true

pub fn ring_pop(event: *VirtioInputEvent) -> bool
    if g_input_ring.count == 0
        return false  # Buffer empty

    *event = g_input_ring.events[g_input_ring.tail]
    g_input_ring.tail = (g_input_ring.tail + 1) % INPUT_RING_SIZE
    g_input_ring.count = g_input_ring.count - 1
    return true

pub fn ring_count() -> i32
    return g_input_ring.count

# ============================================================================
# Device Initialization
# ============================================================================

pub fn virtio_input_init() -> i32
    prints("[virtio-input] Initializing...\n")

    # Initialize ring buffer
    ring_init()

    # Find VirtIO Input device
    let pci_dev: *PciDevice = pci_find_virtio(VIRTIO_DEVICE_INPUT)
    if pci_dev == 0 as *PciDevice
        prints("[virtio-input] No device found\n")
        return -1

    prints("[virtio-input] Found device at PCI ")
    serial_print_hex8((*pci_dev).bus)
    prints(":")
    serial_print_hex8((*pci_dev).device)
    prints(".")
    serial_print_hex8((*pci_dev).function)
    prints("\n")

    # Enable bus mastering and I/O space
    pci_enable_bus_master(pci_dev)
    pci_enable_io(pci_dev)

    # Get I/O base address
    let io_base: u16 = ((*pci_dev).bar[0] & 0xFFFC) as u16
    prints("[virtio-input] I/O base: 0x")
    serial_print_hex(io_base as u64)
    prints("\n")

    # Initialize VirtIO device
    let virtio_dev: *VirtioDevice = vio_init_device(pci_dev)
    if virtio_dev == 0 as *VirtioDevice
        prints("[virtio-input] Failed to init VirtIO device\n")
        return -1

    # Allocate input device structure
    input_device = kalloc(VIRTIO_INPUT_DEVICE_SIZE) as *VirtioInputDevice
    if input_device == 0 as *VirtioInputDevice
        prints("[virtio-input] Failed to allocate device struct\n")
        return -1

    (*input_device).virtio_dev = virtio_dev
    (*input_device).device_type = 0

    # Get device features (we don't need any special features for input)
    let features: u32 = vio_get_features(virtio_dev)
    vio_set_features(virtio_dev, 0)

    # Complete feature negotiation (required for modern transport)
    if vio_features_ok(virtio_dev) != 0
        prints("[virtio-input] Feature negotiation failed\n")
        kfree(input_device)
        input_device = 0 as *VirtioInputDevice
        return -1

    # Setup event queue (queue 0) - receives events from device
    let event_queue: *Virtqueue = vio_setup_queue(virtio_dev, 0)
    if event_queue == 0 as *Virtqueue
        prints("[virtio-input] Failed to setup event queue\n")
        kfree(input_device)
        input_device = 0 as *VirtioInputDevice
        return -1

    (*input_device).event_queue = event_queue

    # Setup status queue (queue 1) - for LED status etc.
    let status_queue: *Virtqueue = vio_setup_queue(virtio_dev, 1)
    (*input_device).status_queue = status_queue

    # Allocate event buffers for receiving events
    let buf_size: u64 = (NUM_EVENT_BUFFERS as u64) * VIRTIO_INPUT_EVENT_SIZE
    let buf_pages: u64 = (buf_size + PAGE_SIZE - 1) / PAGE_SIZE
    let buf_phys: u64 = pmm_alloc_page()
    if buf_phys == 0
        prints("[virtio-input] Failed to allocate event buffers\n")
        kfree(input_device)
        input_device = 0 as *VirtioInputDevice
        return -1

    (*input_device).event_buffers = buf_phys as *u8
    (*input_device).event_buffer_phys = buf_phys

    # Pre-populate event queue with empty buffers
    var i: i32 = 0
    while i < NUM_EVENT_BUFFERS
        let buf_offset: u64 = (i as u64) * VIRTIO_INPUT_EVENT_SIZE
        let desc_idx: i32 = vq_alloc_desc(event_queue)
        if desc_idx < 0
            break

        let desc: *VringDesc = vq_get_desc(event_queue, desc_idx as u16)
        (*desc).addr = buf_phys + buf_offset
        (*desc).len = VIRTIO_INPUT_EVENT_SIZE as u32
        (*desc).flags = VRING_DESC_F_WRITE  # Device writes to this buffer
        (*desc).next = 0

        vq_submit(event_queue, desc_idx as u16)
        i = i + 1

    # Notify device that buffers are available
    vq_notify(event_queue)

    # Mark device as ready
    vio_device_ready(virtio_dev)

    prints("[virtio-input] Initialized with ")
    serial_print_dec(i)
    prints(" event buffers\n")

    return 0

# ============================================================================
# Poll for Input Events
# ============================================================================

pub fn virtio_input_poll() -> i32
    if input_device == 0 as *VirtioInputDevice
        return 0

    let vq: *Virtqueue = (*input_device).event_queue
    var events_processed: i32 = 0

    # Process all used buffers
    while vq_has_used(vq)
        let desc_idx: i32 = vq_get_used(vq)
        if desc_idx < 0
            break

        let len: u32 = vq_get_used_len(vq)

        # Get the event from the buffer
        let buf_offset: u64 = (desc_idx as u64) * VIRTIO_INPUT_EVENT_SIZE
        let event_ptr: *VirtioInputEvent = ((*input_device).event_buffer_phys + buf_offset) as *VirtioInputEvent

        # Push to ring buffer (skip SYN_REPORT events)
        if (*event_ptr).event_type != EV_SYN
            ring_push(event_ptr)
            events_processed = events_processed + 1

        # Re-submit the buffer
        let desc: *VringDesc = vq_get_desc(vq, desc_idx as u16)
        (*desc).addr = (*input_device).event_buffer_phys + buf_offset
        (*desc).len = VIRTIO_INPUT_EVENT_SIZE as u32
        (*desc).flags = VRING_DESC_F_WRITE
        (*desc).next = 0

        vq_submit(vq, desc_idx as u16)

    # Notify device if we re-submitted any buffers
    if events_processed > 0
        vq_notify(vq)

    return events_processed

# ============================================================================
# Get Next Input Event (for syscall)
# ============================================================================

pub fn virtio_input_get_event(event: *VirtioInputEvent) -> bool
    # First poll for new events
    virtio_input_poll()

    # Then try to get from ring buffer
    return ring_pop(event)

# ============================================================================
# Check if Input Device is Available
# ============================================================================

pub fn virtio_input_available() -> bool
    return input_device != 0 as *VirtioInputDevice

# ============================================================================
# Convert Key Code to ASCII (basic mapping)
# ============================================================================

pub fn keycode_to_ascii(code: u16, shift: bool) -> u8
    # Number row
    if code >= KEY_1 and code <= KEY_9
        if shift
            # Shift symbols: !@#$%^&*(
            let symbols: [9]u8 = [33, 64, 35, 36, 37, 94, 38, 42, 40]
            return symbols[(code - KEY_1) as i32]
        return (48 + (code - KEY_1 + 1)) as u8  # '1' to '9'

    if code == KEY_0
        if shift
            return 41  # ')'
        return 48  # '0'

    # Letters (QWERTY layout)
    let qwerty_map: [26]u16 = [
        KEY_Q, KEY_W, KEY_E, KEY_R, KEY_T, KEY_Y, KEY_U, KEY_I, KEY_O, KEY_P,
        KEY_A, KEY_S, KEY_D, KEY_F, KEY_G, KEY_H, KEY_J, KEY_K, KEY_L,
        KEY_Z, KEY_X, KEY_C, KEY_V, KEY_B, KEY_N, KEY_M
    ]

    var i: i32 = 0
    while i < 26
        if qwerty_map[i] == code
            var base: u8 = 97  # 'a'
            if shift
                base = 65  # 'A'
            return base + (i as u8)
        i = i + 1

    # Special keys
    if code == KEY_SPACE
        return 32
    if code == KEY_ENTER
        return 10  # '\n'
    if code == KEY_TAB
        return 9
    if code == KEY_BACKSPACE
        return 8
    if code == KEY_ESC
        return 27

    # Punctuation - return shift or normal variant
    if code == KEY_MINUS
        if shift
            return 95  # '_'
        return 45  # '-'
    if code == KEY_EQUAL
        if shift
            return 43  # '+'
        return 61  # '='
    if code == KEY_LEFTBRACE
        if shift
            return 123  # '{'
        return 91  # '['
    if code == KEY_RIGHTBRACE
        if shift
            return 125  # '}'
        return 93  # ']'
    if code == KEY_SEMICOLON
        if shift
            return 58  # ':'
        return 59  # ';'
    if code == KEY_APOSTROPHE
        if shift
            return 34  # '"'
        return 39  # '\''
    if code == KEY_GRAVE
        if shift
            return 126  # '~'
        return 96  # '`'
    if code == KEY_BACKSLASH
        if shift
            return 124  # '|'
        return 92  # '\'
    if code == KEY_COMMA
        if shift
            return 60  # '<'
        return 44  # ','
    if code == KEY_DOT
        if shift
            return 62  # '>'
        return 46  # '.'
    if code == KEY_SLASH
        if shift
            return 63  # '?'
        return 47  # '/'

    return 0  # Unknown
