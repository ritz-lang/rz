# ============================================================================
# Kernel Ring Buffer (Early Boot Debug)
# ============================================================================
#
# A statically-allocated, lock-free ring buffer for early boot debugging.
# Captures debug messages that can be dumped on crash/panic.
#
# Design:
# - Fixed 4KB buffer (1 page, fits in BSS)
# - No dynamic allocation (kernel can use before heap exists)
# - Circular overwrite when full (keeps most recent messages)
# - Lock-free single-producer (interrupts disabled during write)

# Buffer size: 4KB (1 page)
const RING_BUFFER_SIZE: u64 = 4096

# Static ring buffer - lives in BSS, no allocation needed
var ring_buffer: [4096]u8
var ring_head: u64 = 0      # Write position
var ring_wrapped: u8 = 0    # Has buffer wrapped around?

# Write a single byte to the ring buffer
fn ring_write_byte(c: u8) -> i32
    ring_buffer[ring_head as i32] = c
    ring_head = ring_head + 1
    if ring_head >= RING_BUFFER_SIZE
        ring_head = 0
        ring_wrapped = 1
    return 0

# Write a null-terminated string to the ring buffer
fn ring_write(s: *u8) -> i32
    var p: *u8 = s
    while *p != 0
        ring_write_byte(*p)
        p = p + 1
    return 0

# Write a hex value to the ring buffer (ASCII representation)
fn ring_write_hex(value: u64) -> i32
    let hex_chars: *u8 = c"0123456789ABCDEF"
    var i: i32 = 15
    while i >= 0
        let nibble: u8 = ((value >> (i * 4)) & 0xF) as u8
        ring_write_byte(*(hex_chars + nibble as i64))
        i = i - 1
    return 0

# Clear the ring buffer
fn ring_clear() -> i32
    ring_head = 0
    ring_wrapped = 0
    return 0

# Get the current number of valid bytes in the buffer
fn ring_len() -> u64
    if ring_wrapped != 0
        return RING_BUFFER_SIZE
    return ring_head

# Dump the entire ring buffer contents to serial
# Outputs in chronological order (oldest to newest)
pub fn ring_dump() -> i32
    serial_print(c"\n=== RING BUFFER DUMP (last 4KB of kernel log) ===\n")

    if ring_wrapped != 0
        # Buffer has wrapped: print from head to end, then start to head
        var pos: u64 = ring_head
        while pos < RING_BUFFER_SIZE
            serial_write_byte(ring_buffer[pos as i32])
            pos = pos + 1
        # Then from beginning to head
        pos = 0
        while pos < ring_head
            serial_write_byte(ring_buffer[pos as i32])
            pos = pos + 1
    else
        # Buffer hasn't wrapped: just print from start to head
        var pos: u64 = 0
        while pos < ring_head
            serial_write_byte(ring_buffer[pos as i32])
            pos = pos + 1

    serial_print(c"\n=== END RING BUFFER ===\n")
    return 0

# ============================================================================
# Kernel Logging (klog) - Writes to BOTH serial AND ring buffer
# ============================================================================
#
# Use these for all kernel logging. Output goes to:
# 1. Serial immediately (for live debugging)
# 2. Ring buffer (for crash analysis)

# Log a null-terminated string
pub fn klog(s: *u8) -> i32
    serial_print(s)
    ring_write(s)
    return 0

# Log a StrView string
pub fn klogs(s: StrView) -> i32
    # Extract ptr and len before any move
    let ptr: *u8 = s.ptr
    let len: i64 = s.len
    # Write to serial
    serial_write(ptr, len)
    # Write to ring buffer
    var i: i64 = 0
    while i < len
        ring_write_byte(*(ptr + i))
        i = i + 1
    return 0

# Log with hex value
pub fn klog_hex(prefix: *u8, value: u64, suffix: *u8) -> i32
    serial_print(prefix)
    serial_print_hex(value)
    serial_print(suffix)
    ring_write(prefix)
    ring_write_hex(value)
    ring_write(suffix)
    return 0

# ============================================================================
# Boot Protocol State (global runtime detection)
# ============================================================================

var boot_protocol: u32 = 0  # BOOT_PROTOCOL_UNKNOWN
var harland_boot_info: *HarlandBootInfo = 0 as *HarlandBootInfo

# ============================================================================
# GDT (Global Descriptor Table)
# ============================================================================

# Segment selectors
const GDT_KERNEL_CODE: u16 = 0x08
const GDT_KERNEL_DATA: u16 = 0x10
const GDT_USER_CODE: u16 = 0x1B
const GDT_USER_DATA: u16 = 0x23
const GDT_TSS: u16 = 0x28

# Access flags
const GDT_ACCESS_PRESENT: u8 = 0x80
const GDT_ACCESS_RING0: u8 = 0x00
const GDT_ACCESS_RING3: u8 = 0x60
const GDT_ACCESS_CODE: u8 = 0x1A
const GDT_ACCESS_DATA: u8 = 0x12
const GDT_ACCESS_TSS: u8 = 0x89

# GDT flags
const GDT_FLAG_LONG: u8 = 0x20
const GDT_FLAG_GRANULARITY: u8 = 0x80

struct GdtEntry
    limit_low: u16
    base_low: u16
    base_mid: u8
    access: u8
    flags_limit: u8
    base_high: u8

# GdtDescriptor must be packed (10 bytes total, no padding)
# Format: u16 limit, u64 base (no alignment padding!)
# We use a byte array and set fields manually
struct GdtDescriptor
    data: [10]u8

# TSS must be packed to match x86-64 hardware layout
# RSP0 must be at offset 4, not aligned to 8!
[[packed]]
struct Tss
    reserved0: u32
    rsp0: u64
    rsp1: u64
    rsp2: u64
    reserved1: u64
    ist1: u64
    ist2: u64
    ist3: u64
    ist4: u64
    ist5: u64
    ist6: u64
    ist7: u64
    reserved2: u64
    reserved3: u16
    iopb_offset: u16

# Global storage
var gdt: [7]GdtEntry
var tss: Tss
var gdt_descriptor: GdtDescriptor
var kernel_stack: [4096]u8
var interrupt_stack: [4096]u8
var irq_stack: [4096]u8  # IST2 for hardware IRQs during syscall

fn make_gdt_entry(base: u32, limit: u32, access: u8, flags: u8) -> GdtEntry
    var entry: GdtEntry
    entry.limit_low = (limit & 0xFFFF) as u16
    entry.base_low = (base & 0xFFFF) as u16
    entry.base_mid = ((base >> 16) & 0xFF) as u8
    entry.access = access
    let limit_hi: u8 = ((limit >> 16) & 0x0F) as u8
    let flags_hi: u8 = flags & 0xF0
    entry.flags_limit = limit_hi | flags_hi
    entry.base_high = ((base >> 24) & 0xFF) as u8
    return entry

fn set_tss_entry(gdt_index: i32, tss_addr: u64) -> i32
    let base: u64 = tss_addr
    let limit: u32 = 103

    gdt[gdt_index].limit_low = (limit & 0xFFFF) as u16
    gdt[gdt_index].base_low = (base & 0xFFFF) as u16
    gdt[gdt_index].base_mid = ((base >> 16) & 0xFF) as u8
    gdt[gdt_index].access = GDT_ACCESS_TSS
    gdt[gdt_index].flags_limit = ((limit >> 16) & 0x0F) as u8
    gdt[gdt_index].base_high = ((base >> 24) & 0xFF) as u8

    let next_entry: *u8 = @gdt[gdt_index + 1] as *u8
    let base_upper: u32 = ((base >> 32) & 0xFFFFFFFF) as u32
    *(next_entry as *u32) = base_upper
    *((next_entry + 4) as *u32) = 0

    return 0

fn tss_init() -> i32
    let tss_ptr: *u8 = @tss as *u8
    var i: i32 = 0
    while i < 104
        *(tss_ptr + i as i64) = 0
        i = i + 1

    let stack_top: u64 = (@kernel_stack[0] as u64) + 4096
    tss.rsp0 = stack_top

    # IST1: Critical exceptions (NMI, double fault, stack fault, machine check)
    let ist1_top: u64 = (@interrupt_stack[0] as u64) + 4096
    tss.ist1 = ist1_top

    # IST2: Reserved for future use (hardware IRQs)
    # Currently, IRQs use IST=0 which works better with our syscall stack
    let ist2_top: u64 = (@irq_stack[0] as u64) + 4096
    tss.ist2 = ist2_top

    tss.iopb_offset = 104
    return 0

# GDT reload is done in assembly (boot.s already set up segments)
# We just need to load our new GDT and TSS here
extern fn gdt_flush(gdt_ptr: u64) -> i32

fn gdt_load() -> i32
    let gdt_ptr: *GdtDescriptor = @gdt_descriptor
    var gdt_ptr_val: u64 = gdt_ptr as u64
    gdt_flush(gdt_ptr_val)
    return 0

fn tss_load() -> i32
    let tss_seg: u16 = 0x28
    asm x86_64:
        movw {tss_seg}, %ax
        ltr %ax
    return 0

fn gdt_init() -> i32
    # Null descriptor
    gdt[0] = make_gdt_entry(0, 0, 0, 0)

    # Kernel code segment (selector 0x08)
    let kcode_access: u8 = GDT_ACCESS_PRESENT | GDT_ACCESS_RING0 | GDT_ACCESS_CODE
    let kcode_flags: u8 = GDT_FLAG_LONG | GDT_FLAG_GRANULARITY
    gdt[1] = make_gdt_entry(0, 0xFFFFF, kcode_access, kcode_flags)

    # Kernel data segment (selector 0x10)
    let kdata_access: u8 = GDT_ACCESS_PRESENT | GDT_ACCESS_RING0 | GDT_ACCESS_DATA
    let kdata_flags: u8 = GDT_FLAG_GRANULARITY
    gdt[2] = make_gdt_entry(0, 0xFFFFF, kdata_access, kdata_flags)

    # User code segment (selector 0x18)
    let ucode_access: u8 = GDT_ACCESS_PRESENT | GDT_ACCESS_RING3 | GDT_ACCESS_CODE
    let ucode_flags: u8 = GDT_FLAG_LONG | GDT_FLAG_GRANULARITY
    gdt[3] = make_gdt_entry(0, 0xFFFFF, ucode_access, ucode_flags)

    # User data segment (selector 0x20)
    let udata_access: u8 = GDT_ACCESS_PRESENT | GDT_ACCESS_RING3 | GDT_ACCESS_DATA
    let udata_flags: u8 = GDT_FLAG_GRANULARITY
    gdt[4] = make_gdt_entry(0, 0xFFFFF, udata_access, udata_flags)

    # Initialize TSS
    tss_init()
    let tss_addr: u64 = @tss as u64
    set_tss_entry(5, tss_addr)

    # Set GDT descriptor (packed format: u16 limit, u64 base)
    let gdt_limit: u16 = (7 * 8 - 1) as u16
    let gdt_base: u64 = @gdt[0] as u64
    let desc_ptr: *u8 = @gdt_descriptor.data[0]
    *(desc_ptr as *u16) = gdt_limit
    *((desc_ptr + 2) as *u64) = gdt_base

    # Load GDT and TSS
    gdt_load()
    tss_load()

    return 0

# ============================================================================
# IDT (Interrupt Descriptor Table)
# ============================================================================

const IDT_GATE_INTERRUPT: u8 = 0x8E
const IDT_GATE_TRAP: u8 = 0x8F
const IDT_GATE_USER: u8 = 0xEE

struct IdtEntry
    offset_low: u16
    selector: u16
    ist: u8
    type_attr: u8
    offset_mid: u16
    offset_high: u32
    reserved: u32

# IdtDescriptor must be packed (10 bytes total, no padding)
# Format: u16 size, u64 offset (no alignment padding!)
# We use a byte array and set fields manually (same as GdtDescriptor)
struct IdtDescriptor
    data: [10]u8

var idt: [256]IdtEntry
var idt_descriptor: IdtDescriptor

fn idt_set_gate(vector: u8, handler: u64, selector: u16, ist: u8, type_attr: u8) -> i32
    let idx: i32 = vector as i32
    idt[idx].offset_low = (handler & 0xFFFF) as u16
    idt[idx].selector = selector
    idt[idx].ist = ist
    idt[idx].type_attr = type_attr
    idt[idx].offset_mid = ((handler >> 16) & 0xFFFF) as u16
    idt[idx].offset_high = ((handler >> 32) & 0xFFFFFFFF) as u32
    idt[idx].reserved = 0
    return 0

# External ISR stubs (defined in isr_stubs.s)
extern fn isr_stub_0() -> i32
extern fn isr_stub_1() -> i32
extern fn isr_stub_2() -> i32
extern fn isr_stub_3() -> i32
extern fn isr_stub_4() -> i32
extern fn isr_stub_5() -> i32
extern fn isr_stub_6() -> i32
extern fn isr_stub_7() -> i32
extern fn isr_stub_8() -> i32
extern fn isr_stub_9() -> i32
extern fn isr_stub_10() -> i32
extern fn isr_stub_11() -> i32
extern fn isr_stub_12() -> i32
extern fn isr_stub_13() -> i32
extern fn isr_stub_14() -> i32
extern fn isr_stub_15() -> i32
extern fn isr_stub_16() -> i32
extern fn isr_stub_17() -> i32
extern fn isr_stub_18() -> i32
extern fn isr_stub_19() -> i32
extern fn isr_stub_20() -> i32
extern fn isr_stub_21() -> i32
extern fn isr_stub_22() -> i32
extern fn isr_stub_23() -> i32
extern fn isr_stub_24() -> i32
extern fn isr_stub_25() -> i32
extern fn isr_stub_26() -> i32
extern fn isr_stub_27() -> i32
extern fn isr_stub_28() -> i32
extern fn isr_stub_29() -> i32
extern fn isr_stub_30() -> i32
extern fn isr_stub_31() -> i32

extern fn irq_stub_0() -> i32
extern fn irq_stub_1() -> i32
extern fn irq_stub_2() -> i32
extern fn irq_stub_3() -> i32
extern fn irq_stub_4() -> i32
extern fn irq_stub_5() -> i32
extern fn irq_stub_6() -> i32
extern fn irq_stub_7() -> i32
extern fn irq_stub_8() -> i32
extern fn irq_stub_9() -> i32
extern fn irq_stub_10() -> i32
extern fn irq_stub_11() -> i32
extern fn irq_stub_12() -> i32
extern fn irq_stub_13() -> i32
extern fn irq_stub_14() -> i32
extern fn irq_stub_15() -> i32

fn idt_load() -> i32
    let idt_ptr: *IdtDescriptor = @idt_descriptor
    var idt_ptr_val: u64 = idt_ptr as u64

    asm x86_64:
        movq {idt_ptr_val}, %rax
        lidt (%rax)

    return 0

fn idt_init() -> i32
    var i: i32 = 0
    while i < 256
        idt[i].offset_low = 0
        idt[i].selector = 0
        idt[i].ist = 0
        idt[i].type_attr = 0
        idt[i].offset_mid = 0
        idt[i].offset_high = 0
        idt[i].reserved = 0
        i = i + 1

    let cs: u16 = 0x08

    # Exception handlers (0-31)
    idt_set_gate(0, isr_stub_0 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(1, isr_stub_1 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(2, isr_stub_2 as u64, cs, 1, IDT_GATE_INTERRUPT)
    idt_set_gate(3, isr_stub_3 as u64, cs, 0, IDT_GATE_TRAP)
    idt_set_gate(4, isr_stub_4 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(5, isr_stub_5 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(6, isr_stub_6 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(7, isr_stub_7 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(8, isr_stub_8 as u64, cs, 1, IDT_GATE_INTERRUPT)
    idt_set_gate(9, isr_stub_9 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(10, isr_stub_10 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(11, isr_stub_11 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(12, isr_stub_12 as u64, cs, 1, IDT_GATE_INTERRUPT)  # SS fault - use IST1 for safety
    idt_set_gate(13, isr_stub_13 as u64, cs, 1, IDT_GATE_INTERRUPT)  # GP fault - use IST1 for safety
    idt_set_gate(14, isr_stub_14 as u64, cs, 1, IDT_GATE_INTERRUPT)  # Page fault - use IST1 for safety
    idt_set_gate(15, isr_stub_15 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(16, isr_stub_16 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(17, isr_stub_17 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(18, isr_stub_18 as u64, cs, 1, IDT_GATE_INTERRUPT)
    idt_set_gate(19, isr_stub_19 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(20, isr_stub_20 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(21, isr_stub_21 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(22, isr_stub_22 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(23, isr_stub_23 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(24, isr_stub_24 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(25, isr_stub_25 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(26, isr_stub_26 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(27, isr_stub_27 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(28, isr_stub_28 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(29, isr_stub_29 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(30, isr_stub_30 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(31, isr_stub_31 as u64, cs, 0, IDT_GATE_INTERRUPT)

    # IRQ handlers (32-47)
    # Using IST=0 for all IRQs - they use the current stack (syscall_stack during syscall)
    # This allows interrupts to fire during syscall execution via STI
    # NOTE: IST2 is configured but not currently used due to unexplained triple-faults
    idt_set_gate(32, irq_stub_0 as u64, cs, 0, IDT_GATE_INTERRUPT)   # Timer
    idt_set_gate(33, irq_stub_1 as u64, cs, 2, IDT_GATE_INTERRUPT)   # Keyboard
    idt_set_gate(34, irq_stub_2 as u64, cs, 2, IDT_GATE_INTERRUPT)
    idt_set_gate(35, irq_stub_3 as u64, cs, 2, IDT_GATE_INTERRUPT)
    idt_set_gate(36, irq_stub_4 as u64, cs, 2, IDT_GATE_INTERRUPT)   # COM1
    idt_set_gate(37, irq_stub_5 as u64, cs, 2, IDT_GATE_INTERRUPT)
    idt_set_gate(38, irq_stub_6 as u64, cs, 2, IDT_GATE_INTERRUPT)
    idt_set_gate(39, irq_stub_7 as u64, cs, 2, IDT_GATE_INTERRUPT)
    idt_set_gate(40, irq_stub_8 as u64, cs, 2, IDT_GATE_INTERRUPT)
    idt_set_gate(41, irq_stub_9 as u64, cs, 2, IDT_GATE_INTERRUPT)
    idt_set_gate(42, irq_stub_10 as u64, cs, 2, IDT_GATE_INTERRUPT)
    idt_set_gate(43, irq_stub_11 as u64, cs, 2, IDT_GATE_INTERRUPT)
    idt_set_gate(44, irq_stub_12 as u64, cs, 2, IDT_GATE_INTERRUPT)
    idt_set_gate(45, irq_stub_13 as u64, cs, 2, IDT_GATE_INTERRUPT)
    idt_set_gate(46, irq_stub_14 as u64, cs, 2, IDT_GATE_INTERRUPT)
    idt_set_gate(47, irq_stub_15 as u64, cs, 2, IDT_GATE_INTERRUPT)

# Set IDT descriptor (packed format: u16 size, u64 base)
    let idt_size: u16 = (256 * 16 - 1) as u16
    let idt_base: u64 = @idt[0] as u64
    let idt_desc_ptr: *u8 = @idt_descriptor.data[0]
    *(idt_desc_ptr as *u16) = idt_size
    *((idt_desc_ptr + 2) as *u64) = idt_base

    idt_load()

    return 0

# ============================================================================
# Interrupt Frame (for exception/IRQ handlers)
# ============================================================================

struct InterruptFrame
    r15: u64
    r14: u64
    r13: u64
    r12: u64
    r11: u64
    r10: u64
    r9: u64
    r8: u64
    rbp: u64
    rdi: u64
    rsi: u64
    rdx: u64
    rcx: u64
    rbx: u64
    rax: u64
    vector: u64
    error_code: u64
    rip: u64
    cs: u64
    rflags: u64
    rsp: u64
    ss: u64

# ============================================================================
# Stack Trace Support
# ============================================================================

# Stack frame structure for x86_64 SysV ABI
# Each frame contains:
#   [rbp+0]  = previous rbp (saved frame pointer)
#   [rbp+8]  = return address (rip)
struct StackFrame
    prev_rbp: *StackFrame
    return_addr: u64

# Maximum stack frames to print (prevent infinite loops on corrupted stacks)
const MAX_STACK_FRAMES: u64 = 16

# Check if an address looks like a valid kernel code address
fn is_valid_code_address(addr: u64) -> bool
    # Kernel code is in higher-half, 0xFFFFFFFF80100000 - 0xFFFFFFFF80200000 typically
    if addr >= 0xFFFFFFFF80100000 and addr < 0xFFFFFFFF80400000
        return true
    # Identity-mapped kernel during early boot (around 1MB)
    if addr >= 0x100000 and addr < 0x400000
        return true
    return false

# Check if a stack frame pointer looks valid
fn is_valid_frame_ptr(rbp: u64) -> bool
    # Must be non-null
    if rbp == 0
        return false
    # Must be 8-byte aligned
    if (rbp & 7) != 0
        return false
    # Check for reasonable kernel stack range
    # Kernel stacks are either in identity-mapped region or higher-half
    if rbp >= 0xFFFFFFFF80000000
        return true
    if rbp >= 0x100000 and rbp < 0x10000000
        return true
    return false

# Test crash functions - for debugging exception handler
# Uncomment the call in kernel_main to test
fn test_crash_page_fault() -> i32
    prints("\n[TEST] Triggering page fault via null pointer dereference...\n")
    crash_helper_1()
    return 0

fn crash_helper_1() -> i32
    crash_helper_2()
    return 0

fn crash_helper_2() -> i32
    crash_helper_3()
    return 0

fn crash_helper_3() -> i32
    # Dereference unmapped address (guaranteed page fault)
    # Using 0xDEAD0000 which should be unmapped in kernel address space
    let ptr: *u64 = 0xDEAD0000 as *u64
    let value: u64 = *ptr  # This will fault
    return value as i32

# Print a stack trace starting from the given RBP and RIP
fn print_stack_trace(rbp: u64, rip: u64) -> i32
    prints("\nStack Trace:\n")

    # First frame: the faulting instruction
    prints("  #0  ")
    serial_print_hex(rip)
    prints("  <faulting instruction>\n")

    var frame_ptr: u64 = rbp
    var frame_num: u64 = 1

    while frame_num < MAX_STACK_FRAMES
        # Validate frame pointer
        if not is_valid_frame_ptr(frame_ptr)
            if frame_num == 1
                prints("  (no valid stack frames - frame pointer invalid)\n")
            else
                prints("  (end of stack)\n")
            break

        # Read the stack frame
        let frame: *StackFrame = frame_ptr as *StackFrame
        let return_addr: u64 = (*frame).return_addr
        let prev_rbp: u64 = (*frame).prev_rbp as u64

        # Validate return address
        if not is_valid_code_address(return_addr)
            prints("  (invalid return address - end of trace)\n")
            break

        # Print this frame
        prints("  #")
        serial_print_dec(frame_num)
        prints("  ")
        serial_print_hex(return_addr)
        prints("\n")

        # Check for progress (stack grows down, so prev_rbp should be >= frame_ptr)
        if prev_rbp != 0 and prev_rbp <= frame_ptr
            prints("  (stack corruption detected - frame pointer going wrong direction)\n")
            break

        frame_ptr = prev_rbp
        frame_num = frame_num + 1

    if frame_num >= MAX_STACK_FRAMES
        prints("  ... (max frames reached)\n")

    return 0

fn exception_name(vector: u8) -> *u8
    if vector == 0
        return c"Divide Error"
    if vector == 1
        return c"Debug"
    if vector == 2
        return c"NMI"
    if vector == 3
        return c"Breakpoint"
    if vector == 4
        return c"Overflow"
    if vector == 5
        return c"Bound Range"
    if vector == 6
        return c"Invalid Opcode"
    if vector == 7
        return c"Device Not Available"
    if vector == 8
        return c"Double Fault"
    if vector == 10
        return c"Invalid TSS"
    if vector == 11
        return c"Segment Not Present"
    if vector == 12
        return c"Stack Fault"
    if vector == 13
        return c"General Protection"
    if vector == 14
        return c"Page Fault"
    if vector == 16
        return c"x87 FP Exception"
    if vector == 17
        return c"Alignment Check"
    if vector == 18
        return c"Machine Check"
    if vector == 19
        return c"SIMD FP Exception"
    return c"Unknown"

# Exception handler (called from isr_stubs.s)
pub fn exception_handler(frame: *InterruptFrame) -> i32
    prints("\n!!! EXCEPTION !!!\n")
    prints("Vector: ")
    serial_print_hex((*frame).vector)
    prints(" (")
    serial_print(exception_name((*frame).vector as u8))
    prints(")\n")

    prints("Error Code: ")
    serial_print_hex((*frame).error_code)
    prints("\n")

    prints("RIP: ")
    serial_print_hex((*frame).rip)
    prints("\n")

    prints("CS: ")
    serial_print_hex((*frame).cs)
    prints("  SS: ")
    serial_print_hex((*frame).ss)
    prints("\n")

    prints("RFLAGS: ")
    serial_print_hex((*frame).rflags)
    prints("\n")

    prints("RSP: ")
    serial_print_hex((*frame).rsp)
    prints("\n")

    # For page faults, print CR2 and decode error code
    if (*frame).vector == 14
        var cr2: u64 = 0
        var cr2_ptr: *u64 = @cr2
        asm x86_64:
            movq %cr2, %rax
            movq {cr2_ptr}, %rcx
            movq %rax, (%rcx)
        prints("CR2: ")
        serial_print_hex(cr2)
        prints(" (fault address)\n")

        # Decode error code
        prints("Error Code Bits:\n")
        if ((*frame).error_code & 1) != 0
            prints("  [P] Page present\n")
        else
            prints("  [P] Page not present\n")
        if ((*frame).error_code & 2) != 0
            prints("  [W] Write operation\n")
        else
            prints("  [W] Read operation\n")
        if ((*frame).error_code & 4) != 0
            prints("  [U] User mode\n")
        else
            prints("  [U] Kernel mode\n")
        if ((*frame).error_code & 8) != 0
            prints("  [R] Reserved bit violation\n")
        if ((*frame).error_code & 16) != 0
            prints("  [I] Instruction fetch\n")

        # Walk page tables to show the issue
        prints("\nPage Table Walk:\n")
        vmm_debug_page_tables(cr2)

    prints("\nRegisters:\n")
    prints("  RAX=")
    serial_print_hex((*frame).rax)
    prints(" RBX=")
    serial_print_hex((*frame).rbx)
    prints("\n")
    prints("  RCX=")
    serial_print_hex((*frame).rcx)
    prints(" RDX=")
    serial_print_hex((*frame).rdx)
    prints("\n")
    prints("  RSI=")
    serial_print_hex((*frame).rsi)
    prints(" RDI=")
    serial_print_hex((*frame).rdi)
    prints("\n")
    prints("  RBP=")
    serial_print_hex((*frame).rbp)
    prints("\n")

    # Print stack trace
    print_stack_trace((*frame).rbp, (*frame).rip)

    # Dump ring buffer (shows recent kernel activity before crash)
    ring_dump()

    prints("\n*** KERNEL PANIC ***\n")
    prints("System halted.\n")
    halt_loop()
    return 0

# IRQ handler (called from isr_stubs.s)
pub fn irq_handler(frame: *InterruptFrame) -> i32
    let irq_num: u64 = (*frame).vector - 32

    # Handle specific IRQs
    if irq_num == 0
        # Timer interrupt - just acknowledge for now
        # (scheduler runs via timer_handler which is called separately)
        lapic_eoi()
        return 0

    if irq_num == 4
        # COM1 serial port interrupt
        serial_poll()

    # Send EOI to LAPIC (for APIC-delivered interrupts)
    lapic_eoi()

    return 0

# ============================================================================
# PIC (Programmable Interrupt Controller) - Remap to vectors 32-47
# ============================================================================

fn pic_remap() -> i32
    # Save masks
    let mask1: u8 = inb(0x21)
    let mask2: u8 = inb(0xA1)

    # Start initialization sequence
    outb(0x20, 0x11)  # ICW1: init + ICW4 needed
    outb(0xA0, 0x11)

    # ICW2: Vector offsets
    outb(0x21, 0x20)  # PIC1 starts at vector 32
    outb(0xA1, 0x28)  # PIC2 starts at vector 40

    # ICW3: Cascade configuration
    outb(0x21, 0x04)  # PIC1: slave on IRQ2
    outb(0xA1, 0x02)  # PIC2: cascade identity

    # ICW4: 8086 mode
    outb(0x21, 0x01)
    outb(0xA1, 0x01)

    # Restore masks (mask all for now)
    outb(0x21, 0xFF)
    outb(0xA1, 0xFF)

    return 0

# ============================================================================
# ACPI Tables
# ============================================================================

# ACPI table signatures
const ACPI_SIG_RSDP: u64 = 0x2052545020445352  # "RSD PTR " in little endian
const ACPI_SIG_RSDT: u32 = 0x54445352  # "RSDT"
const ACPI_SIG_XSDT: u32 = 0x54445358  # "XSDT"
const ACPI_SIG_MADT: u32 = 0x43495041  # "APIC"
const ACPI_SIG_FADT: u32 = 0x50434146  # "FACP" (Fixed ACPI Description Table)

# RSDP (Root System Description Pointer) - ACPI 1.0
struct AcpiRsdp
    signature: [8]u8
    checksum: u8
    oem_id: [6]u8
    revision: u8
    rsdt_addr: u32

# RSDP Extended (ACPI 2.0+)
struct AcpiRsdpExt
    signature: [8]u8
    checksum: u8
    oem_id: [6]u8
    revision: u8
    rsdt_addr: u32
    length: u32
    xsdt_addr: u64
    ext_checksum: u8
    reserved: [3]u8

# Standard ACPI table header
struct AcpiTableHeader
    signature: u32
    length: u32
    revision: u8
    checksum: u8
    oem_id: [6]u8
    oem_table_id: [8]u8
    oem_revision: u32
    creator_id: u32
    creator_revision: u32

# MADT entry types
const MADT_LOCAL_APIC: u8 = 0
const MADT_IO_APIC: u8 = 1
const MADT_INT_SRC_OVERRIDE: u8 = 2
const MADT_NMI_SOURCE: u8 = 3
const MADT_LOCAL_APIC_NMI: u8 = 4
const MADT_LOCAL_APIC_OVERRIDE: u8 = 5
const MADT_IO_SAPIC: u8 = 6
const MADT_LOCAL_SAPIC: u8 = 7
const MADT_X2APIC: u8 = 9

# MADT header
struct MadtHeader
    header: AcpiTableHeader
    local_apic_addr: u32
    flags: u32
    # Followed by variable-length entries

# MADT entry header
struct MadtEntryHeader
    entry_type: u8
    length: u8

# MADT Local APIC entry
struct MadtLocalApic
    header: MadtEntryHeader
    processor_id: u8
    apic_id: u8
    flags: u32

# MADT I/O APIC entry
struct MadtIoApic
    header: MadtEntryHeader
    io_apic_id: u8
    reserved: u8
    io_apic_addr: u32
    gsi_base: u32

# MADT Interrupt Source Override entry
struct MadtIntSrcOverride
    header: MadtEntryHeader
    bus: u8
    source: u8
    gsi: u32
    flags: u16

# FADT (Fixed ACPI Description Table) - Contains PM1a/PM1b control block addresses
# Note: This is a simplified structure - full FADT is much larger
struct AcpiFadt
    header: AcpiTableHeader
    firmware_ctrl: u32      # Physical address of FACS
    dsdt: u32               # Physical address of DSDT
    reserved1: u8
    preferred_pm_profile: u8
    sci_int: u16            # SCI interrupt vector
    smi_cmd: u32            # SMI command port
    acpi_enable: u8         # Value to write to SMI_CMD to enable ACPI
    acpi_disable: u8        # Value to write to SMI_CMD to disable ACPI
    s4bios_req: u8
    pstate_cnt: u8
    pm1a_evt_blk: u32       # PM1a Event Block address
    pm1b_evt_blk: u32       # PM1b Event Block address
    pm1a_cnt_blk: u32       # PM1a Control Block address (for shutdown)
    pm1b_cnt_blk: u32       # PM1b Control Block address (for shutdown)
    pm2_cnt_blk: u32
    pm_tmr_blk: u32
    gpe0_blk: u32
    gpe1_blk: u32
    pm1_evt_len: u8
    pm1_cnt_len: u8
    pm2_cnt_len: u8
    pm_tmr_len: u8
    gpe0_blk_len: u8
    gpe1_blk_len: u8
    gpe1_base: u8
    cst_cnt: u8
    p_lvl2_lat: u16
    p_lvl3_lat: u16
    flush_size: u16
    flush_stride: u16
    duty_offset: u8
    duty_width: u8
    day_alarm: u8
    mon_alarm: u8
    century: u8
    iapc_boot_arch: u16     # IA-PC Boot Architecture Flags (ACPI 2.0+)
    reserved2: u8
    flags: u32
    # ACPI 2.0+ extended fields follow...
    reset_reg: [12]u8       # Generic Address Structure
    reset_value: u8
    arm_boot_arch: u16      # ARM Boot Architecture Flags (ACPI 5.1+)
    fadt_minor_version: u8
    x_firmware_ctrl: u64
    x_dsdt: u64
    x_pm1a_evt_blk: [12]u8
    x_pm1b_evt_blk: [12]u8
    x_pm1a_cnt_blk: [12]u8  # Extended PM1a Control Block
    x_pm1b_cnt_blk: [12]u8  # Extended PM1b Control Block

# ACPI PM1 control register bits
const ACPI_SLP_TYP_S5: u16 = 0x1C00  # Sleep type for S5 (shutdown) - varies by system
const ACPI_SLP_EN: u16 = 0x2000     # Sleep enable bit

# Global ACPI state
var acpi_rsdp_addr: u64 = 0  # Set from Multiboot2 or BIOS scan
var acpi_rsdt_addr: u32 = 0
var acpi_xsdt_addr: u64 = 0
var acpi_madt_addr: u64 = 0
var acpi_fadt_addr: u64 = 0
var local_apic_addr: u64 = 0
var io_apic_addr: u64 = 0
var num_cpus: u32 = 0
var cpu_apic_ids: [16]u8

# ACPI power management state (from FADT)
var acpi_pm1a_cnt_blk: u32 = 0  # PM1a Control Block I/O port
var acpi_pm1b_cnt_blk: u32 = 0  # PM1b Control Block I/O port (optional)
var acpi_slp_typa: u16 = 0      # Sleep type value for S5 (from \_S5 DSDT object)
var acpi_slp_typb: u16 = 0      # Sleep type value for S5 PM1b (from \_S5 DSDT object)

# Find ACPI RSDP from Multiboot2 tags
fn acpi_find_from_multiboot(mb_info: *Mb2BootInfo) -> u64
    let info_end: u64 = (mb_info as u64) + (*mb_info).total_size as u64
    var tag_ptr: u64 = (mb_info as u64) + 8

    while tag_ptr < info_end
        let tag: *Mb2Tag = tag_ptr as *Mb2Tag

        if (*tag).tag_type == MB2_TAG_END
            break

        if (*tag).tag_type == MB2_TAG_ACPI_NEW
            # ACPI 2.0+ RSDP follows tag header
            return tag_ptr + 8
        else if (*tag).tag_type == MB2_TAG_ACPI_OLD
            # ACPI 1.0 RSDP follows tag header
            return tag_ptr + 8

        # Move to next tag (8-byte aligned)
        tag_ptr = (tag_ptr + (*tag).size as u64 + 7) & 18446744073709551608

    return 0

# Search for RSDP in EBDA and BIOS ROM area
fn acpi_find_rsdp() -> u64
    # Search EBDA (Extended BIOS Data Area)
    # EBDA segment is at 0x40:0x0E (physical 0x40E)
    let ebda_seg_ptr: *u16 = 0x40E as *u16
    let ebda_addr: u64 = (*ebda_seg_ptr as u64) << 4

    if ebda_addr != 0
        var addr: u64 = ebda_addr
        while addr < ebda_addr + 1024
            let sig: *u64 = addr as *u64
            if *sig == ACPI_SIG_RSDP
                return addr
            addr = addr + 16

    # Search BIOS ROM area (0xE0000 - 0xFFFFF)
    var addr: u64 = 0xE0000
    while addr < 0x100000
        let sig: *u64 = addr as *u64
        if *sig == ACPI_SIG_RSDP
            return addr
        addr = addr + 16

    return 0

# Parse RSDP and find RSDT/XSDT
fn acpi_parse_rsdp(rsdp_addr: u64) -> i32
    let rsdp: *AcpiRsdpExt = rsdp_addr as *AcpiRsdpExt

    # Check revision - 0 = ACPI 1.0 (RSDT only), 2+ = ACPI 2.0+ (XSDT)
    if (*rsdp).revision >= 2
        acpi_xsdt_addr = (*rsdp).xsdt_addr
        prints("      XSDT at: ")
        serial_print_hex(acpi_xsdt_addr)
        prints("\n")

        # Ensure XSDT is mapped (may be beyond identity-mapped region)
        # Map at least 4KB to read the header, then we'll know the real size
        if vmm_ensure_mapped(acpi_xsdt_addr, 4096) != 0
            prints("      ERROR: Failed to map XSDT!\n")
            return -1
    else
        acpi_rsdt_addr = (*rsdp).rsdt_addr
        prints("      RSDT at: ")
        serial_print_hex(acpi_rsdt_addr as u64)
        prints("\n")

        # Ensure RSDT is mapped (may be beyond identity-mapped region)
        if vmm_ensure_mapped(acpi_rsdt_addr as u64, 4096) != 0
            prints("      ERROR: Failed to map RSDT!\n")
            return -1

    return 0

# Find MADT in RSDT/XSDT
fn acpi_find_madt() -> u64
    if acpi_xsdt_addr != 0
        # Use XSDT (64-bit pointers)
        let xsdt: *AcpiTableHeader = acpi_xsdt_addr as *AcpiTableHeader
        let num_entries: u32 = ((*xsdt).length - 36) / 8
        let entries: *u64 = (acpi_xsdt_addr + 36) as *u64

        var i: u32 = 0
        while i < num_entries
            let entry_addr: u64 = *(entries + i as i64)
            # Ensure this table is mapped before reading
            if vmm_ensure_mapped(entry_addr, 64) != 0
                prints(" map error")
                i = i + 1
                continue
            let table: *AcpiTableHeader = entry_addr as *AcpiTableHeader
            if (*table).signature == ACPI_SIG_MADT
                return entry_addr
            i = i + 1
    else if acpi_rsdt_addr != 0
        # Use RSDT (32-bit pointers)
        let rsdt: *AcpiTableHeader = acpi_rsdt_addr as u64 as *AcpiTableHeader
        let num_entries: u32 = ((*rsdt).length - 36) / 4
        let entries: *u32 = (acpi_rsdt_addr as u64 + 36) as *u32

        var i: u32 = 0
        while i < num_entries
            let entry_addr: u32 = *(entries + i as i64)
            # Ensure this table is mapped before reading
            if vmm_ensure_mapped(entry_addr as u64, 64) != 0
                prints(" map error")
                i = i + 1
                continue
            let table: *AcpiTableHeader = entry_addr as u64 as *AcpiTableHeader
            if (*table).signature == ACPI_SIG_MADT
                return entry_addr as u64
            i = i + 1

    return 0

# Find FADT in RSDT/XSDT
fn acpi_find_fadt() -> u64
    if acpi_xsdt_addr != 0
        # Use XSDT (64-bit pointers)
        let xsdt: *AcpiTableHeader = acpi_xsdt_addr as *AcpiTableHeader
        let num_entries: u32 = ((*xsdt).length - 36) / 8
        let entries: *u64 = (acpi_xsdt_addr + 36) as *u64

        var i: u32 = 0
        while i < num_entries
            let entry_addr: u64 = *(entries + i as i64)
            # Ensure this table is mapped before reading
            if vmm_ensure_mapped(entry_addr, 64) != 0
                i = i + 1
                continue
            let table: *AcpiTableHeader = entry_addr as *AcpiTableHeader
            if (*table).signature == ACPI_SIG_FADT
                return entry_addr
            i = i + 1
    else if acpi_rsdt_addr != 0
        # Use RSDT (32-bit pointers)
        let rsdt: *AcpiTableHeader = acpi_rsdt_addr as u64 as *AcpiTableHeader
        let num_entries: u32 = ((*rsdt).length - 36) / 4
        let entries: *u32 = (acpi_rsdt_addr as u64 + 36) as *u32

        var i: u32 = 0
        while i < num_entries
            let entry_addr: u32 = *(entries + i as i64)
            # Ensure this table is mapped before reading
            if vmm_ensure_mapped(entry_addr as u64, 64) != 0
                i = i + 1
                continue
            let table: *AcpiTableHeader = entry_addr as u64 as *AcpiTableHeader
            if (*table).signature == ACPI_SIG_FADT
                return entry_addr as u64
            i = i + 1

    return 0

# Parse FADT to get PM1 control block addresses
fn acpi_parse_fadt(fadt_addr: u64) -> i32
    let fadt: *AcpiFadt = fadt_addr as *AcpiFadt

    # Ensure the full FADT is mapped
    let fadt_length: u64 = (*fadt).header.length as u64
    if vmm_ensure_mapped(fadt_addr, fadt_length) != 0
        prints("      ERROR: Failed to map FADT!\n")
        return -1

    # Get PM1a/PM1b Control Block addresses
    acpi_pm1a_cnt_blk = (*fadt).pm1a_cnt_blk
    acpi_pm1b_cnt_blk = (*fadt).pm1b_cnt_blk

    prints("      PM1a Control Block: ")
    serial_print_hex(acpi_pm1a_cnt_blk as u64)
    prints("\n")

    if acpi_pm1b_cnt_blk != 0
        prints("      PM1b Control Block: ")
        serial_print_hex(acpi_pm1b_cnt_blk as u64)
        prints("\n")

    # For QEMU, we need to determine SLP_TYP for S5 state
    # The proper way is to parse DSDT's \_S5 object, but that requires AML parsing
    # QEMU typically uses SLP_TYP = 0 for S5, but we'll try common values
    # QEMU default: SLP_TYP_S5 = 0 (bits 10-12 = 0)
    # Some systems: SLP_TYP_S5 = 5 (bits 10-12 = 5, so 0x1400)
    # We'll use QEMU's default (SLP_TYP = 0)
    acpi_slp_typa = 0  # SLP_TYP for PM1a (QEMU default)
    acpi_slp_typb = 0  # SLP_TYP for PM1b

    return 0

# Perform ACPI S5 (shutdown) power off
pub fn acpi_poweroff() -> i32
    if acpi_pm1a_cnt_blk == 0
        prints("[ACPI] ERROR: PM1a control block not found!\n")
        return -1

    prints("[ACPI] Initiating S5 shutdown...\n")

    # Disable interrupts before shutdown
    disable_interrupts()

    # Write SLP_TYP + SLP_EN to PM1a_CNT
    # SLP_EN is bit 13 (0x2000)
    # SLP_TYP is bits 10-12
    let pm1a_value: u16 = (acpi_slp_typa << 10) | ACPI_SLP_EN
    outw(acpi_pm1a_cnt_blk as u16, pm1a_value)

    # If PM1b exists, write to it too
    if acpi_pm1b_cnt_blk != 0
        let pm1b_value: u16 = (acpi_slp_typb << 10) | ACPI_SLP_EN
        outw(acpi_pm1b_cnt_blk as u16, pm1b_value)

    # If we get here, shutdown didn't work
    # Try alternative SLP_TYP values (some systems need different values)
    var slp_typ: u16 = 1
    while slp_typ < 8
        let pm1a_value: u16 = (slp_typ << 10) | ACPI_SLP_EN
        outw(acpi_pm1a_cnt_blk as u16, pm1a_value)

        # Small delay
        var delay: i32 = 0
        while delay < 100000
            delay = delay + 1

        slp_typ = slp_typ + 1

    prints("[ACPI] ERROR: Shutdown failed!\n")
    return -1

# Parse MADT to find APIC info
fn acpi_parse_madt(madt_addr: u64) -> i32
    let madt: *MadtHeader = madt_addr as *MadtHeader

    # Ensure the full MADT is mapped (header already mapped, but may span pages)
    let madt_length: u64 = (*madt).header.length as u64
    if vmm_ensure_mapped(madt_addr, madt_length) != 0
        prints("      ERROR: Failed to map MADT!\n")
        return -1

    # Get Local APIC address
    local_apic_addr = (*madt).local_apic_addr as u64
    prints("      Local APIC at: ")
    serial_print_hex(local_apic_addr)
    prints("\n")

    # Parse MADT entries
    let madt_end: u64 = madt_addr + (*madt).header.length as u64
    var entry_addr: u64 = madt_addr + 44  # After header

    num_cpus = 0

    while entry_addr < madt_end
        let entry: *MadtEntryHeader = entry_addr as *MadtEntryHeader

        if (*entry).entry_type == MADT_LOCAL_APIC
            let lapic: *MadtLocalApic = entry_addr as *MadtLocalApic
            # Check if processor is enabled (bit 0) or can be enabled (bit 1)
            if ((*lapic).flags & 3) != 0
                if num_cpus < 16
                    cpu_apic_ids[num_cpus as i32] = (*lapic).apic_id
                    num_cpus = num_cpus + 1
        else if (*entry).entry_type == MADT_IO_APIC
            let ioapic: *MadtIoApic = entry_addr as *MadtIoApic
            if io_apic_addr == 0
                io_apic_addr = (*ioapic).io_apic_addr as u64
                prints("      I/O APIC at: ")
                serial_print_hex(io_apic_addr)
                prints("\n")
        else if (*entry).entry_type == MADT_LOCAL_APIC_OVERRIDE
            # Update Local APIC address with 64-bit version
            let override_addr: *u64 = (entry_addr + 4) as *u64
            local_apic_addr = *override_addr
            prints("      Local APIC override: ")
            serial_print_hex(local_apic_addr)
            prints("\n")

        entry_addr = entry_addr + (*entry).length as u64

    prints("      CPUs found: ")
    serial_print_dec(num_cpus as u64)
    prints("\n")

    return 0

# Initialize ACPI (takes Multiboot2 info to find ACPI tables)
fn acpi_init_with_mb(mb_info: *Mb2BootInfo) -> i32
    prints("    Searching for RSDP...")

    # First try Multiboot2 ACPI tags (required for UEFI boot)
    var rsdp_addr: u64 = acpi_find_from_multiboot(mb_info)

    # Fall back to legacy BIOS scan
    if rsdp_addr == 0
        rsdp_addr = acpi_find_rsdp()

    if rsdp_addr == 0
        prints(" not found!\n")
        return -1

    prints(" found at ")
    serial_print_hex(rsdp_addr)
    prints("\n")

    acpi_rsdp_addr = rsdp_addr
    acpi_parse_rsdp(rsdp_addr)

    prints("    Searching for MADT...")
    acpi_madt_addr = acpi_find_madt()

    if acpi_madt_addr == 0
        prints(" not found!\n")
        return -1

    prints(" found at ")
    serial_print_hex(acpi_madt_addr)
    prints("\n")

    acpi_parse_madt(acpi_madt_addr)

    # Also find FADT for power management (shutdown support)
    prints("    Searching for FADT...")
    acpi_fadt_addr = acpi_find_fadt()

    if acpi_fadt_addr == 0
        prints(" not found (shutdown disabled)\n")
    else
        prints(" found at ")
        serial_print_hex(acpi_fadt_addr)
        prints("\n")
        acpi_parse_fadt(acpi_fadt_addr)

    return 0

# Initialize ACPI from Harland boot info (UEFI boot path - RSDP already known)
fn acpi_init_from_bootinfo(info: *HarlandBootInfo) -> i32
    let rsdp_addr: u64 = (*info).rsdp_addr

    prints("    RSDP from bootloader: ")
    serial_print_hex(rsdp_addr)
    prints("\n")

    if rsdp_addr == 0
        prints("    RSDP not found in boot info!\n")
        return -1

    acpi_rsdp_addr = rsdp_addr
    acpi_parse_rsdp(rsdp_addr)

    prints("    Searching for MADT...")
    acpi_madt_addr = acpi_find_madt()

    if acpi_madt_addr == 0
        prints(" not found!\n")
        return -1

    prints(" found at ")
    serial_print_hex(acpi_madt_addr)
    prints("\n")

    acpi_parse_madt(acpi_madt_addr)

    # Also find FADT for power management (shutdown support)
    prints("    Searching for FADT...")
    acpi_fadt_addr = acpi_find_fadt()

    if acpi_fadt_addr == 0
        prints(" not found (shutdown disabled)\n")
    else
        prints(" found at ")
        serial_print_hex(acpi_fadt_addr)
        prints("\n")
        acpi_parse_fadt(acpi_fadt_addr)

    return 0

# ============================================================================
# Local APIC
# ============================================================================

# LAPIC register offsets (memory-mapped)
const LAPIC_ID: u64 = 0x020          # APIC ID
const LAPIC_VERSION: u64 = 0x030     # Version
const LAPIC_TPR: u64 = 0x080         # Task Priority Register
const LAPIC_EOI: u64 = 0x0B0         # End of Interrupt
const LAPIC_LDR: u64 = 0x0D0         # Logical Destination
const LAPIC_DFR: u64 = 0x0E0         # Destination Format
const LAPIC_SVR: u64 = 0x0F0         # Spurious Interrupt Vector
const LAPIC_ESR: u64 = 0x280         # Error Status
const LAPIC_ICR_LO: u64 = 0x300      # Interrupt Command (low 32 bits)
const LAPIC_ICR_HI: u64 = 0x310      # Interrupt Command (high 32 bits)
const LAPIC_TIMER: u64 = 0x320       # Timer LVT
const LAPIC_THERMAL: u64 = 0x330     # Thermal LVT
const LAPIC_PERFCNT: u64 = 0x340     # Performance Counter LVT
const LAPIC_LINT0: u64 = 0x350       # LINT0 LVT
const LAPIC_LINT1: u64 = 0x360       # LINT1 LVT
const LAPIC_ERROR: u64 = 0x370       # Error LVT
const LAPIC_TIMER_INITIAL: u64 = 0x380  # Timer Initial Count
const LAPIC_TIMER_CURRENT: u64 = 0x390  # Timer Current Count
const LAPIC_TIMER_DIVIDE: u64 = 0x3E0   # Timer Divide Configuration

# LAPIC SVR flags
const LAPIC_SVR_ENABLE: u32 = 0x100  # Bit 8: Enable APIC
const LAPIC_SPURIOUS_VEC: u32 = 0xFF # Spurious vector (255)

# Read LAPIC register
fn lapic_read(offset: u64) -> u32
    let addr: *u32 = (local_apic_addr + offset) as *u32
    return *addr

# Write LAPIC register
fn lapic_write(offset: u64, value: u32) -> i32
    let addr: *u32 = (local_apic_addr + offset) as *u32
    *addr = value
    return 0

# Get current CPU's APIC ID
pub fn lapic_id() -> u32
    return lapic_read(LAPIC_ID) >> 24

# Send EOI (End of Interrupt) to LAPIC
pub fn lapic_eoi() -> i32
    lapic_write(LAPIC_EOI, 0)
    return 0

# Initialize Local APIC
fn lapic_init() -> i32
    # Enable LAPIC via SVR (Spurious Vector Register)
    # Set spurious vector to 0xFF and enable bit
    lapic_write(LAPIC_SVR, LAPIC_SVR_ENABLE | LAPIC_SPURIOUS_VEC)

    # Clear task priority to accept all interrupts
    lapic_write(LAPIC_TPR, 0)

    # Clear error status (write twice to clear)
    lapic_write(LAPIC_ESR, 0)
    lapic_write(LAPIC_ESR, 0)

    # Acknowledge any pending interrupts
    lapic_write(LAPIC_EOI, 0)

    # Set up timer - we'll configure this properly later
    # For now, mask it
    lapic_write(LAPIC_TIMER, 0x10000)  # Masked

    # Mask thermal, performance counter
    lapic_write(LAPIC_THERMAL, 0x10000)
    lapic_write(LAPIC_PERFCNT, 0x10000)

    # LINT0/LINT1 - keep default (ExtINT/NMI)
    lapic_write(LAPIC_LINT0, 0x08700)   # ExtINT, unmasked
    lapic_write(LAPIC_LINT1, 0x00400)   # NMI

    # Mask error LVT
    lapic_write(LAPIC_ERROR, 0x10000)

    # Clear error status again
    lapic_write(LAPIC_ESR, 0)

    prints("      LAPIC ID: ")
    serial_print_dec(lapic_id() as u64)
    prints(", Version: ")
    serial_print_hex(lapic_read(LAPIC_VERSION) as u64)
    prints("\n")

    return 0

# ============================================================================
# I/O APIC
# ============================================================================

# I/O APIC registers
const IOAPIC_REGSEL: u64 = 0x00   # Register select
const IOAPIC_WINDOW: u64 = 0x10   # Register data window

# I/O APIC register indices
const IOAPIC_ID: u8 = 0x00
const IOAPIC_VER: u8 = 0x01
const IOAPIC_ARB: u8 = 0x02
const IOAPIC_REDTBL: u8 = 0x10    # Redirection table (0x10 + 2*n for entry n)

# Read I/O APIC register
fn ioapic_read(reg: u8) -> u32
    let regsel: *u32 = io_apic_addr as *u32
    let window: *u32 = (io_apic_addr + IOAPIC_WINDOW) as *u32
    *regsel = reg as u32
    return *window

# Write I/O APIC register
fn ioapic_write(reg: u8, value: u32) -> i32
    let regsel: *u32 = io_apic_addr as *u32
    let window: *u32 = (io_apic_addr + IOAPIC_WINDOW) as *u32
    *regsel = reg as u32
    *window = value
    return 0

# Set up an I/O APIC redirection entry
fn ioapic_set_irq(irq: u8, vector: u8, dest_apic: u8, masked: bool) -> i32
    let reg_lo: u8 = IOAPIC_REDTBL + irq * 2
    let reg_hi: u8 = IOAPIC_REDTBL + irq * 2 + 1

    # High 32 bits: destination APIC ID in bits 24-31
    ioapic_write(reg_hi, (dest_apic as u32) << 24)

    # Low 32 bits:
    # Bits 0-7: Vector
    # Bit 8-10: Delivery mode (000 = Fixed)
    # Bit 11: Destination mode (0 = Physical)
    # Bit 12: Delivery status (read-only)
    # Bit 13: Pin polarity (0 = High active)
    # Bit 14: Remote IRR (read-only)
    # Bit 15: Trigger mode (0 = Edge)
    # Bit 16: Mask (1 = masked)
    var value: u32 = vector as u32
    if masked
        value = value | 0x10000
    ioapic_write(reg_lo, value)

    return 0

# Initialize I/O APIC
fn ioapic_init() -> i32
    if io_apic_addr == 0
        prints("      No I/O APIC!\n")
        return -1

    let version: u32 = ioapic_read(IOAPIC_VER)
    let max_irqs: u32 = ((version >> 16) & 0xFF) + 1

    prints("      I/O APIC version: ")
    serial_print_hex((version & 0xFF) as u64)
    prints(", max IRQs: ")
    serial_print_dec(max_irqs as u64)
    prints("\n")

    # Mask all IRQs initially
    var i: u8 = 0
    while i < max_irqs as u8
        ioapic_set_irq(i, 32 + i, 0, true)  # Vector 32+, masked
        i = i + 1

    # Unmask keyboard (IRQ 1) - route to vector 33, CPU 0
    ioapic_set_irq(1, 33, 0, false)

    # Unmask COM1 (IRQ 4) - route to vector 36, CPU 0
    ioapic_set_irq(4, 36, 0, false)

    return 0

# Disable legacy 8259 PIC
fn pic_disable() -> i32
    # Mask all interrupts on both PICs
    outb(0xA1, 0xFF)
    outb(0x21, 0xFF)
    return 0

# ============================================================================
# AP (Application Processor) Bootstrap
# ============================================================================

# AP bootstrap state
var ap_started: [16]u8          # Flag for each AP
var ap_stacks: [16][4096]u8     # Stack for each AP
var ap_count: u32 = 0           # Number of APs that have started
var bsp_apic_id: u8 = 0         # BSP's APIC ID

# Trampoline code location (must be in low memory, <1MB)
const AP_TRAMPOLINE_ADDR: u64 = 0x8000

# External symbols from ap_trampoline.s
extern fn ap_trampoline_start() -> i32
extern fn ap_trampoline_end() -> i32

# IPI delivery modes
const IPI_DELIVERY_FIXED: u8 = 0
const IPI_DELIVERY_INIT: u8 = 5
const IPI_DELIVERY_SIPI: u8 = 6

# Send IPI (Inter-Processor Interrupt)
fn lapic_send_ipi(dest_apic: u8, vector: u8, delivery_mode: u8) -> i32
    # Wait for previous IPI to complete
    while (lapic_read(LAPIC_ICR_LO) & 0x1000) != 0
        asm x86_64:
            pause

    # Set destination in ICR high
    lapic_write(LAPIC_ICR_HI, (dest_apic as u32) << 24)

    # Send IPI via ICR low
    # Bits 0-7: Vector
    # Bits 8-10: Delivery mode (000=Fixed, 101=INIT, 110=Startup)
    # Bit 11: Destination mode (0=Physical)
    # Bit 12: Delivery status (read-only)
    # Bit 14: Level (1 for INIT)
    # Bit 15: Trigger mode (0=Edge, 1=Level)
    let icr_lo: u32 = (vector as u32) | ((delivery_mode as u32) << 8)
    lapic_write(LAPIC_ICR_LO, icr_lo)

    return 0

# Delay in microseconds (rough, using busy loop)
fn delay_us(us: u32) -> i32
    # Very rough delay - assumes ~1GHz CPU
    var i: u32 = 0
    while i < us * 100
        asm x86_64:
            pause
        i = i + 1
    return 0

# AP entry point (called by ap_trampoline.s after transition to long mode)
pub fn ap_entry() -> i32
    # Get our APIC ID
    let my_apic_id: u32 = lapic_id()

    # Initialize our local APIC
    lapic_write(LAPIC_SVR, LAPIC_SVR_ENABLE | LAPIC_SPURIOUS_VEC)
    lapic_write(LAPIC_TPR, 0)

    # Print message (need mutex for serial, but for now just try)
    prints("    AP ")
    serial_print_dec(my_apic_id as u64)
    prints(" started!\n")

    # Mark ourselves as started
    ap_started[my_apic_id as i32] = 1
    ap_count = ap_count + 1

    # For now, just halt - scheduler will give us work later
    while true
        asm x86_64:
            hlt

    return 0

# Copy trampoline code to low memory and set up parameters
fn ap_setup_trampoline(ap_index: u32) -> i32
    # Calculate trampoline size
    let tramp_start: u64 = ap_trampoline_start as u64
    let tramp_end: u64 = ap_trampoline_end as u64
    let tramp_size: u64 = tramp_end - tramp_start

    # Copy trampoline to 0x8000
    var src: *u8 = tramp_start as *u8
    var dst: *u8 = AP_TRAMPOLINE_ADDR as *u8
    var i: u64 = 0
    while i < tramp_size
        *(dst + i as i64) = *(src + i as i64)
        i = i + 1

    # Set up trampoline parameters at fixed locations
    # See ap_trampoline.s for layout:
    #   0x8FF0: PML4 address (u32)
    #   0x8FF8: Stack pointer (u64)
    #   0x9000: Entry point (u64)

    # PML4 address (32-bit at 0x8FF0)
    let pml4_ptr: *u32 = 0x8FF0 as *u32
    *pml4_ptr = vmm_pml4_phys as u32

    # Stack pointer (64-bit at 0x8FF8)
    let stack_ptr: *u64 = 0x8FF8 as *u64
    # Stack top is the address of the END of the AP's stack (stacks grow down)
    # @ap_stacks[ap_index][0] gives the start, add 4096 for the top
    let stack_top: u64 = (@ap_stacks[ap_index as i32][0] as u64) + 4096
    *stack_ptr = stack_top

    # Entry point (64-bit at 0x9000)
    let entry_ptr: *u64 = 0x9000 as *u64
    *entry_ptr = ap_entry as u64

    return 0

# Boot a single AP
fn ap_boot_one(apic_id: u8, ap_index: u32) -> i32
    prints("    Booting AP ")
    serial_print_dec(apic_id as u64)
    prints("...")

    # Set up trampoline for this AP
    ap_setup_trampoline(ap_index)

    # Send INIT IPI
    lapic_send_ipi(apic_id, 0, IPI_DELIVERY_INIT)
    delay_us(10000)  # 10ms delay

    # Send INIT de-assert (level=0, trigger=level)
    # This is done by setting level bit low
    lapic_write(LAPIC_ICR_HI, (apic_id as u32) << 24)
    lapic_write(LAPIC_ICR_LO, 0x8500)  # INIT, level, de-assert
    delay_us(200)

    # Send SIPI (Startup IPI) - vector is page number (0x08 for 0x8000)
    let sipi_vector: u8 = (AP_TRAMPOLINE_ADDR / 4096) as u8
    lapic_send_ipi(apic_id, sipi_vector, IPI_DELIVERY_SIPI)
    delay_us(200)

    # Send second SIPI (recommended by Intel)
    lapic_send_ipi(apic_id, sipi_vector, IPI_DELIVERY_SIPI)
    delay_us(200)

    # Wait for AP to start (with timeout)
    var timeout: u32 = 1000
    while ap_started[apic_id as i32] == 0 && timeout > 0
        delay_us(1000)
        timeout = timeout - 1

    if ap_started[apic_id as i32] != 0
        prints(" OK\n")
        return 0
    else
        prints(" TIMEOUT\n")
        return -1

# Boot all APs
fn ap_boot_all() -> i32
    # Record BSP's APIC ID
    bsp_apic_id = lapic_id() as u8

    prints("  [..] Boot APs\n")
    prints("    BSP APIC ID: ")
    serial_print_dec(bsp_apic_id as u64)
    prints("\n")

    # Clear started flags
    var i: i32 = 0
    while i < 16
        ap_started[i] = 0
        i = i + 1

    # Boot each AP (skip BSP)
    var ap_index: u32 = 0
    i = 0
    while i < num_cpus as i32
        let apic_id: u8 = cpu_apic_ids[i]
        if apic_id != bsp_apic_id
            ap_boot_one(apic_id, ap_index)
            ap_index = ap_index + 1
        i = i + 1

    prints("  [OK] Boot APs (")
    serial_print_dec(ap_count as u64)
    prints(" APs started)\n")

    return 0

# Initialize APIC system (requires Multiboot info for ACPI tables)
fn apic_init_with_mb(mb_info: *Mb2BootInfo) -> i32
    prints("  [..] ACPI/APIC\n")

    # Parse ACPI tables to find APIC info
    let acpi_result: i32 = acpi_init_with_mb(mb_info)
    if acpi_result != 0
        prints("\r  [!!] ACPI/APIC (ACPI not found)\n")
        return -1

    # Map Local APIC and I/O APIC to identity addresses
    # These are memory-mapped I/O regions above 1GB, outside our initial mapping
    prints("    Mapping APIC regions...")
    if local_apic_addr != 0
        let lapic_result: i32 = vmm_map_page(local_apic_addr, local_apic_addr, PTE_WRITABLE | PTE_CACHE_DISABLE)
        if lapic_result != 0
            prints(" LAPIC map failed!\n")
            return -1
    if io_apic_addr != 0
        let ioapic_result: i32 = vmm_map_page(io_apic_addr, io_apic_addr, PTE_WRITABLE | PTE_CACHE_DISABLE)
        if ioapic_result != 0
            prints(" IOAPIC map failed!\n")
            return -1
    prints(" done\n")

    # Initialize Local APIC on BSP
    prints("    Initializing Local APIC...")
    lapic_init()
    prints(" done\n")

    # Initialize I/O APIC
    prints("    Initializing I/O APIC...")
    ioapic_init()
    prints(" done\n")

    # Disable legacy PIC
    prints("    Disabling legacy PIC...")
    pic_disable()
    prints(" done\n")

    prints("\r  [OK] ACPI/APIC\n")

    return 0

# Initialize APIC from Harland boot info (UEFI boot path)
fn apic_init_from_bootinfo(info: *HarlandBootInfo) -> i32
    prints("  [..] ACPI/APIC\n")

    # Parse ACPI tables using RSDP from bootloader
    let acpi_result: i32 = acpi_init_from_bootinfo(info)
    if acpi_result != 0
        prints("\r  [!!] ACPI/APIC (ACPI not found)\n")
        return -1

    # Map Local APIC and I/O APIC to identity addresses
    prints("    Mapping APIC regions...")
    if local_apic_addr != 0
        let lapic_result: i32 = vmm_map_page(local_apic_addr, local_apic_addr, PTE_WRITABLE | PTE_CACHE_DISABLE)
        if lapic_result != 0
            prints(" LAPIC map failed!\n")
            return -1
    if io_apic_addr != 0
        let ioapic_result: i32 = vmm_map_page(io_apic_addr, io_apic_addr, PTE_WRITABLE | PTE_CACHE_DISABLE)
        if ioapic_result != 0
            prints(" IOAPIC map failed!\n")
            return -1
    prints(" done\n")

    # Initialize Local APIC on BSP
    prints("    Initializing Local APIC...")
    lapic_init()
    prints(" done\n")

    # Initialize I/O APIC
    prints("    Initializing I/O APIC...")
    ioapic_init()
    prints(" done\n")

    # Disable legacy PIC
    prints("    Disabling legacy PIC...")
    pic_disable()
    prints(" done\n")

    prints("\r  [OK] ACPI/APIC\n")

    return 0

# ============================================================================
# Scheduler
# ============================================================================

# Task states
const TASK_STATE_DEAD: u8 = 0
const TASK_STATE_READY: u8 = 1
const TASK_STATE_RUNNING: u8 = 2
const TASK_STATE_BLOCKED: u8 = 3

# Maximum tasks and CPUs
const MAX_TASKS: i32 = 64
const MAX_CPUS: i32 = 16

# CPU context - all registers saved on context switch
# Must match the layout in context_switch assembly
struct CpuContext
    # Callee-saved registers (System V AMD64 ABI)
    rbx: u64
    rbp: u64
    r12: u64
    r13: u64
    r14: u64
    r15: u64
    rsp: u64        # Stack pointer
    rip: u64        # Return address (set to task entry point initially)
    rflags: u64     # Flags register

# Task Control Block (TCB)
struct Task
    id: u32
    state: u8
    cpu_id: u8          # Which CPU is running this (if RUNNING)
    priority: u8
    pad: u8
    context: CpuContext
    stack_base: u64     # Base of kernel stack
    stack_size: u64     # Stack size
    name: [16]u8        # Task name for debugging

# Per-CPU scheduler state
struct CpuSched
    cpu_id: u8
    pad: [7]u8
    current_task: u32   # Index of currently running task (or 0xFFFFFFFF if idle)
    idle_task: u32      # Index of this CPU's idle task

# Global scheduler state
var tasks: [64]Task                 # All tasks
var task_count: u32 = 0             # Number of tasks created
var next_task_id: u32 = 1           # Next task ID to assign

var cpu_sched: [16]CpuSched         # Per-CPU scheduler state
var ready_queue: [64]u32            # Ready task indices (simple FIFO)
var ready_head: u32 = 0
var ready_tail: u32 = 0
var ready_count: u32 = 0

var scheduler_initialized: u8 = 0
var scheduler_lock: u32 = 0         # Simple spinlock

# APIC Timer constants
const LAPIC_TIMER_PERIODIC: u32 = 0x20000   # Periodic mode
const LAPIC_TIMER_VECTOR: u32 = 32          # IRQ 0 (vector 32 after PIC remap)
const TIMER_DIVISOR: u32 = 16               # Divide by 16
const TIMER_INITIAL_COUNT: u32 = 10000000   # ~10ms at typical frequencies

# Spinlock acquire
fn sched_lock() -> i32
    # Simple spinlock using atomic CAS
    # Load the lock address and use RIP-relative addressing
    while true
        var result: u32 = 0
        var one: u32 = 1
        # Try to atomically swap: set lock to 1 and get old value
        asm x86_64:
            lea scheduler_lock(%rip), %rsi
            movl {one}, %eax
            xchgl %eax, (%rsi)
            movl %eax, {result}
        if result == 0
            return 0  # Got the lock (was unlocked)
    return 0

# Spinlock release
fn sched_unlock() -> i32
    scheduler_lock = 0
    return 0

# Add task to ready queue
fn ready_queue_push(task_idx: u32) -> i32
    if ready_count >= 64
        return -1
    ready_queue[ready_tail as i32] = task_idx
    ready_tail = (ready_tail + 1) % 64
    ready_count = ready_count + 1
    return 0

# Remove task from ready queue
fn ready_queue_pop() -> u32
    if ready_count == 0
        return 0xFFFFFFFF  # No tasks
    let task_idx: u32 = ready_queue[ready_head as i32]
    ready_head = (ready_head + 1) % 64
    ready_count = ready_count - 1
    return task_idx

# Initialize a task's context for first run
fn task_init_context(task: *Task, entry: u64, stack_top: u64) -> i32
    (*task).context.rbx = 0
    (*task).context.rbp = stack_top
    (*task).context.r12 = 0
    (*task).context.r13 = 0
    (*task).context.r14 = 0
    (*task).context.r15 = 0
    (*task).context.rsp = stack_top - 8  # Room for return address
    (*task).context.rip = entry
    (*task).context.rflags = 0x202       # IF=1, reserved bit 1

    # Push the return address onto the stack
    let ret_ptr: *u64 = (stack_top - 8) as *u64
    *ret_ptr = entry

    return 0

# Create a new kernel task
pub fn task_create(name: *u8, entry: u64) -> i32
    sched_lock()

    if task_count >= MAX_TASKS as u32
        sched_unlock()
        return -1

    let task_idx: u32 = task_count
    task_count = task_count + 1

    let task: *Task = @tasks[task_idx as i32]

    # Initialize task
    (*task).id = next_task_id
    next_task_id = next_task_id + 1
    (*task).state = TASK_STATE_READY
    (*task).cpu_id = 0
    (*task).priority = 128  # Default priority

    # Copy name
    var i: i32 = 0
    var src: *u8 = name
    while i < 15 && *src != 0
        (*task).name[i] = *src
        src = src + 1
        i = i + 1
    (*task).name[i] = 0

    # Allocate stack (4KB)
    let stack_pages: u64 = 1
    let stack_phys: u64 = pmm_alloc_page()
    if stack_phys == 0
        sched_unlock()
        return -1

    # Map stack (use a high virtual address range for task stacks)
    let stack_virt: u64 = 0x200000000 + (task_idx as u64) * 0x2000
    let map_result: i32 = vmm_map_page(stack_virt, stack_phys, PTE_WRITABLE)
    if map_result != 0
        pmm_free_page(stack_phys)
        sched_unlock()
        return -1

    (*task).stack_base = stack_virt
    (*task).stack_size = PAGE_SIZE

    let stack_top: u64 = stack_virt + PAGE_SIZE

    # Initialize context
    task_init_context(task, entry, stack_top)

    # Add to ready queue
    ready_queue_push(task_idx)

    sched_unlock()

    return (*task).id as i32

# External assembly function for context switch
extern fn context_switch(old_ctx: *CpuContext, new_ctx: *CpuContext)

# External assembly functions for syscalls and userspace
extern fn syscall_entry()
extern fn jump_to_userspace(entry: u64, stack: u64)
extern fn jump_to_userspace_with_retval(entry: u64, stack: u64, retval: i64)
extern fn jump_to_userspace_with_args(entry: u64, stack: u64, argc: i64, argv: u64)
extern fn user_program_start()
extern fn user_program_end()
extern fn user_program_minimal()

# Embedded Ritz ELF binary (from user/hello.ritz)
# These symbols are defined in kernel/user_elf.s
extern fn user_elf_start()
extern fn user_elf_end()

# ============================================================================
# Syscall Interface
# ============================================================================

# MSR numbers for SYSCALL/SYSRET
const MSR_EFER: u32 = 0xC0000080
const MSR_STAR: u32 = 0xC0000081
const MSR_LSTAR: u32 = 0xC0000082
const MSR_SFMASK: u32 = 0xC0000084
const EFER_SCE: u64 = 1

# Harland syscall numbers
# Note: Some syscall numbers are imported from cap.syscall and ipc.syscall
# These are the core syscalls not defined elsewhere:
const SYS_READ: u64 = 0
const SYS_WRITE: u64 = 1
const SYS_OPEN: u64 = 2
const SYS_CLOSE: u64 = 3
const SYS_READDIR: u64 = 17
const SYS_EXIT: u64 = 20
const SYS_SPAWN: u64 = 21
const SYS_WAIT: u64 = 22
const SYS_GETPID: u64 = 23
const SYS_YIELD: u64 = 24
const SYS_SPAWN_ARGS: u64 = 25
const SYS_ACPI_POWEROFF: u64 = 200
const SYS_DEBUG_PRINT: u64 = 255

# ============================================================================
# Process State for Spawn/Exit
# ============================================================================
#
# When a parent process calls spawn(), we save its execution context here.
# When the child calls exit(), we restore the parent context and return.
#
# This implements simple "blocking spawn" - parent waits for child to exit.

struct ParentContext
    # User-mode return state (saved from syscall entry)
    user_rip: u64           # Where parent was when it called spawn
    user_rsp: u64           # Parent's user stack pointer
    user_rflags: u64        # Parent's RFLAGS
    user_pml4: u64          # Parent's page table (CR3)
    # We don't need to save GPRs - they're on the syscall stack

# Global parent context (single process system for now)
var g_parent_ctx: ParentContext
var g_has_parent: u8 = 0           # 1 if we're in a child process
var g_child_pid: u64 = 1           # Current PID (1 = init)
var g_child_pml4: u64 = 0          # Child's page table (for cleanup)
var g_child_exit_code: i64 = 0     # Exit code from child

# External functions from syscall_entry.s for accessing user context
extern fn get_syscall_user_rip() -> u64
extern fn get_syscall_user_rsp() -> u64
extern fn get_syscall_user_rflags() -> u64

# ============================================================================
# New Syscall Implementations
# ============================================================================

# Helper to get string length
fn syscall_strlen(s: *u8) -> i64
    var len: i64 = 0
    var p: *u8 = s
    while *p != 0
        len = len + 1
        p = p + 1
    return len

# sys_readdir: List directory contents
# Returns bytes written to buffer as null-terminated strings
fn sys_readdir_impl(dir_path: *u8, buf: *u8, buf_size: i64) -> i64
    let ns: *KNamespace = knamespace_get()
    if ns == 0 as *KNamespace
        return -1

    # Create StrView from path
    let path_len: i64 = syscall_strlen(dir_path)
    let path_view: StrView = strview_from_ptr(dir_path, path_len)

    # Allocate entries array on stack (max 64)
    var entries: [64]KDirEntry
    let count: i32 = knamespace_list(ns, @path_view, @entries[0], 64)

    if count < 0
        return -1

    # Copy names to buffer as null-terminated strings
    var bytes_written: i64 = 0
    var i: i32 = 0

    while i < count
        let entry: *KDirEntry = @entries[i]

        # Find name length
        var name_len: i32 = (*entry).name_len as i32
        if name_len == 0
            # Fallback: count until null
            while name_len < 255 and (*entry).name[name_len] != 0
                name_len = name_len + 1

        # Check buffer space
        if bytes_written + name_len as i64 + 1 > buf_size
            break

        # Copy name
        var j: i32 = 0
        while j < name_len
            *(buf + bytes_written) = (*entry).name[j]
            bytes_written = bytes_written + 1
            j = j + 1

        # Null terminator
        *(buf + bytes_written) = 0
        bytes_written = bytes_written + 1

        i = i + 1

    return bytes_written

# sys_spawn: Load and execute a binary from the filesystem
# This is a BLOCKING spawn - we save parent state, run child, and when
# child exits, we restore parent state and return with child's exit code.
#
# ISOLATION: Each child process gets its own page table (CR3), providing
# full memory isolation from the parent. The child cannot read or write
# the parent's user-space memory.
fn sys_spawn_impl(path: *u8) -> i64
    # Look up the file in the namespace
    let ns: *KNamespace = knamespace_get()
    if ns == 0 as *KNamespace
        return -1

    # Read file from namespace (using kernel's page table)
    let path_len: i64 = syscall_strlen(path)
    let path_view: StrView = strview_from_ptr(path, path_len)
    var file_size: u64 = 0
    let elf_data: *u8 = knamespace_read(ns, @path_view, @file_size)

    if elf_data == 0 as *u8
        return -1

    # Save parent's execution context
    # When the child calls sys_exit(), we'll restore this and return here
    g_parent_ctx.user_rip = get_syscall_user_rip()
    g_parent_ctx.user_rsp = get_syscall_user_rsp()
    g_parent_ctx.user_rflags = get_syscall_user_rflags()
    g_parent_ctx.user_pml4 = vmm_get_current_pml4()  # Save parent's page table
    g_has_parent = 1
    g_child_pid = 2  # Simple: parent=1, child=2

    # Create an isolated address space for the child
    # This copies kernel mappings but starts with empty user space
    let child_pml4: u64 = vmm_create_user_pml4()
    if child_pml4 == 0
        g_has_parent = 0
        return -1

    g_child_pml4 = child_pml4  # Save for cleanup on exit

    # Debug: Print parent PML4[511] before switch
    prints("[spawn] Parent PML4[511] = 0x")
    serial_print_hex(vmm_read_pml4_entry(g_parent_ctx.user_pml4, 511))
    prints("\n")
    prints("[spawn] Child  PML4[511] = 0x")
    serial_print_hex(vmm_read_pml4_entry(child_pml4, 511))
    prints("\n")

    # Switch to child's address space for ELF loading
    # This way, elf_load will map pages directly into the child's page table
    vmm_switch_pml4(child_pml4)

    # Load the child ELF into the child's address space
    # For PIE executables, we can load at any address in userspace.
    # With isolated address spaces, we can use the same base as init!
    let child_load_base: u64 = 0x100000000  # 4GB - same as init, no conflict due to isolation
    let load_result: ElfLoadResult = elf_load(elf_data, file_size, child_load_base)

    if load_result.error != ELF_OK
        # Switch back to parent before cleanup
        vmm_switch_pml4(g_parent_ctx.user_pml4)
        vmm_free_pml4(child_pml4)
        g_has_parent = 0
        g_child_pml4 = 0
        return -1

    # Allocate child stack in the child's address space
    let child_stack_page: u64 = pmm_alloc_page()
    if child_stack_page == 0
        vmm_switch_pml4(g_parent_ctx.user_pml4)
        vmm_free_pml4(child_pml4)
        g_has_parent = 0
        g_child_pml4 = 0
        return -1

    # Map stack at standard location (no conflict with parent - separate address space!)
    let child_stack_vaddr: u64 = 0x7FFFFFFFE000  # Same as init's stack
    let map_result: i32 = vmm_map_page(child_stack_vaddr, child_stack_page, PTE_WRITABLE | PTE_USER)
    if map_result != 0
        pmm_free_page(child_stack_page)
        vmm_switch_pml4(g_parent_ctx.user_pml4)
        vmm_free_pml4(child_pml4)
        g_has_parent = 0
        g_child_pml4 = 0
        return -1

    let child_stack_top: u64 = child_stack_vaddr + PAGE_SIZE - 16

    # Jump to child! This does NOT return.
    # We're already in the child's address space (CR3 was switched above).
    # When child calls sys_exit(), sys_exit_impl will detect g_has_parent
    # and restore parent context including switching back to parent's CR3.
    jump_to_userspace(load_result.entry_point, child_stack_top)

    # Never reached - child will call sys_exit which handles return to parent
    return -1

# sys_spawn_args: Load and execute a binary with command-line arguments
# Similar to sys_spawn_impl but passes argc/argv to the child process.
#
# Arguments:
#   path: Path to the executable
#   argv: Array of null-terminated argument strings (in parent's address space)
#   argc: Number of arguments
#
# The child's main() receives: fn main(argc: i32, argv: **u8) -> i32
fn sys_spawn_args_impl(path: *u8, argv: **u8, argc: i32) -> i64
    prints("[spawn_args] spawn_args(")
    prints_str(path)
    prints(", argc=")
    serial_print_dec(argc as u64)
    prints(")\n")

    # Look up the file in the namespace
    let ns: *KNamespace = knamespace_get()
    if ns == 0 as *KNamespace
        prints("[spawn_args] No namespace\n")
        return -1

    # Read file from namespace (using kernel's page table)
    let path_len: i64 = syscall_strlen(path)
    let path_view: StrView = strview_from_ptr(path, path_len)
    var file_size: u64 = 0
    let elf_data: *u8 = knamespace_read(ns, @path_view, @file_size)

    if elf_data == 0 as *u8
        prints("[spawn_args] File not found: ")
        prints_str(path)
        prints("\n")
        return -1

    prints("[spawn_args] Loading ELF (")
    serial_print_dec(file_size)
    prints(" bytes)...\n")

    # Save parent's execution context
    g_parent_ctx.user_rip = get_syscall_user_rip()
    g_parent_ctx.user_rsp = get_syscall_user_rsp()
    g_parent_ctx.user_rflags = get_syscall_user_rflags()
    g_parent_ctx.user_pml4 = vmm_get_current_pml4()
    g_has_parent = 1
    g_child_pid = 2

    # Create an isolated address space for the child
    let child_pml4: u64 = vmm_create_user_pml4()
    if child_pml4 == 0
        prints("[spawn_args] Failed to create child page table\n")
        g_has_parent = 0
        return -1

    g_child_pml4 = child_pml4

    # Copy argv strings from parent's address space before switching
    # We need to measure total space needed and copy while we can still read parent memory
    var total_string_bytes: i64 = 0
    var i: i32 = 0
    while i < argc
        let arg: *u8 = *(argv + i)
        total_string_bytes = total_string_bytes + syscall_strlen(arg) + 1  # +1 for null
        i = i + 1

    # Allocate temporary kernel buffer to hold copies of argv strings
    # For simplicity, use a static buffer (max 4KB of arguments)
    var argv_copy: [4096]u8
    var argv_offsets: [64]i64  # Store offset of each arg in argv_copy

    if total_string_bytes > 4096
        prints("[spawn_args] argv too large\n")
        vmm_free_pml4(child_pml4)
        g_has_parent = 0
        g_child_pml4 = 0
        return -1

    if argc > 64
        prints("[spawn_args] too many arguments\n")
        vmm_free_pml4(child_pml4)
        g_has_parent = 0
        g_child_pml4 = 0
        return -1

    # Copy all strings into argv_copy
    var copy_pos: i64 = 0
    i = 0
    while i < argc
        argv_offsets[i] = copy_pos
        let arg: *u8 = *(argv + i)
        var j: i64 = 0
        while *(arg + j) != 0
            argv_copy[(copy_pos + j) as i32] = *(arg + j)
            j = j + 1
        argv_copy[(copy_pos + j) as i32] = 0  # Null terminate
        copy_pos = copy_pos + j + 1
        i = i + 1

    # Switch to child's address space
    vmm_switch_pml4(child_pml4)

    # Load the child ELF
    let child_load_base: u64 = 0x100000000
    let load_result: ElfLoadResult = elf_load(elf_data, file_size, child_load_base)

    if load_result.error != ELF_OK
        prints("[spawn_args] Failed to load ELF\n")
        vmm_switch_pml4(g_parent_ctx.user_pml4)
        vmm_free_pml4(child_pml4)
        g_has_parent = 0
        g_child_pml4 = 0
        return -1

    # Allocate child stack
    let child_stack_page: u64 = pmm_alloc_page()
    if child_stack_page == 0
        prints("[spawn_args] Failed to allocate child stack\n")
        vmm_switch_pml4(g_parent_ctx.user_pml4)
        vmm_free_pml4(child_pml4)
        g_has_parent = 0
        g_child_pml4 = 0
        return -1

    let child_stack_vaddr: u64 = 0x7FFFFFFFE000
    let map_result: i32 = vmm_map_page(child_stack_vaddr, child_stack_page, PTE_WRITABLE | PTE_USER)
    if map_result != 0
        prints("[spawn_args] Failed to map child stack\n")
        pmm_free_page(child_stack_page)
        vmm_switch_pml4(g_parent_ctx.user_pml4)
        vmm_free_pml4(child_pml4)
        g_has_parent = 0
        g_child_pml4 = 0
        return -1

    # Set up the stack with argv data
    # Layout from top of stack going down:
    #   1. String data (argv[0] content, argv[1] content, ...)
    #   2. argv[argc] = NULL
    #   3. argv[argc-1] pointer
    #   4. ...
    #   5. argv[0] pointer
    #   6. (16-byte aligned) <- RSP points here

    let stack_base: u64 = child_stack_vaddr
    var stack_ptr: u64 = stack_base + PAGE_SIZE

    # Copy string data to top of stack (working down)
    stack_ptr = stack_ptr - (total_string_bytes as u64)
    stack_ptr = stack_ptr & 0xFFFFFFFFFFFFFFF0  # Align to 16 bytes
    let strings_base: u64 = stack_ptr

    # Copy argv strings to child stack
    i = 0
    var child_argv_ptrs: [64]u64
    var dst_offset: i64 = 0
    while i < argc
        child_argv_ptrs[i] = strings_base + (dst_offset as u64)
        let src_offset: i64 = argv_offsets[i]
        var j: i64 = 0
        while argv_copy[(src_offset + j) as i32] != 0
            *((strings_base + dst_offset as u64 + j as u64) as *u8) = argv_copy[(src_offset + j) as i32]
            j = j + 1
        *((strings_base + dst_offset as u64 + j as u64) as *u8) = 0
        dst_offset = dst_offset + j + 1
        i = i + 1

    # Push argv array (including NULL terminator)
    let argv_array_size: u64 = ((argc + 1) as u64) * 8  # pointers + NULL
    stack_ptr = stack_ptr - argv_array_size
    stack_ptr = stack_ptr & 0xFFFFFFFFFFFFFFF0  # Align
    let child_argv: u64 = stack_ptr

    # Write argv pointers
    i = 0
    while i < argc
        *((child_argv + (i as u64) * 8) as *u64) = child_argv_ptrs[i]
        i = i + 1
    # NULL terminator
    *((child_argv + (argc as u64) * 8) as *u64) = 0

    # Final stack alignment for SysV ABI (RSP must be 16-byte aligned before call)
    stack_ptr = stack_ptr & 0xFFFFFFFFFFFFFFF0

    prints("[spawn_args] Child argv at 0x")
    serial_print_hex(child_argv)
    prints(", stack=0x")
    serial_print_hex(stack_ptr)
    prints("\n")

    # Debug: print first arg
    if argc > 0
        prints("[spawn_args] argv[0] = ")
        prints_str(child_argv_ptrs[0] as *u8)
        prints("\n")

    prints("[spawn_args] Jumping to child with args...\n\n")

    # Jump to child with argc/argv!
    jump_to_userspace_with_args(load_result.entry_point, stack_ptr, argc as i64, child_argv)

    # Never reached
    prints("[spawn_args] ERROR: jump returned!\n")
    return -1

# sys_exit: Exit the current process
# If we're a child (spawned by blocking spawn), restore parent and return
# with the exit code. Otherwise, halt the system.
fn sys_exit_impl(code: i32) -> i64
    if g_has_parent != 0
        # We're a child! Restore parent context
        # Save exit code for sys_wait
        g_child_exit_code = code as i64
        g_has_parent = 0

        # IMPORTANT: Switch back to parent's address space BEFORE jumping!
        # The parent's user code and stack are only accessible in the parent's
        # page table. If we jump while still in the child's CR3, we'll page fault.
        vmm_switch_pml4(g_parent_ctx.user_pml4)

        # Free the child's page table and all its user-space pages
        if g_child_pml4 != 0
            vmm_free_pml4(g_child_pml4)
            g_child_pml4 = 0

        # For blocking spawn, we return to the parent's sys_spawn() call.
        # The parent expects a positive PID on success.
        # We return 2 (child PID) on success, or -1 on failure.
        # The actual exit code is stored in g_child_exit_code for sys_wait().
        var retval: i64 = 2  # Child PID = 2 on success
        if code < 0
            retval = -1  # Error if child exited with negative code

        jump_to_userspace_with_retval(g_parent_ctx.user_rip, g_parent_ctx.user_rsp, retval)

        # Never reached

    # No parent - this is init exiting or a system halt
    prints(" - halting system\n")
    halt_loop()
    return 0

# sys_wait: Wait for a child process to exit
# For blocking spawn, the child has already exited by the time spawn returns.
# This can be used to get the exit code if needed.
fn sys_wait_impl(pid: i32) -> i64
    # For blocking spawn, the exit code is already available
    if g_child_pid == 2
        let code: i64 = g_child_exit_code
        # Reset state after collecting exit code
        g_child_exit_code = 0
        g_child_pid = 1  # Back to init only
        return code

    # No child to wait for
    return -1

# Helper to print null-terminated string
fn prints_str(s: *u8)
    var p: *u8 = s
    while *p != 0
        serial_write_byte(*p)
        p = p + 1

# rdmsr and wrmsr are imported from io module

pub fn syscall_init() -> i32
    # Enable SYSCALL/SYSRET in EFER
    let efer: u64 = rdmsr(MSR_EFER)
    wrmsr(MSR_EFER, efer | EFER_SCE)

    # Set up STAR MSR
    # Bits 47:32 = kernel CS (used on SYSCALL entry)
    # Bits 63:48 = user segment base (used for SYSRET to compute user CS/SS)
    #   SYSRET sets CS = STAR[63:48] + 16, SS = STAR[63:48] + 8
    #   Our user code is selector 0x18+3=0x1B, user data is 0x20+3=0x23
    #   So we need STAR[63:48] = 0x10 (0x10+16=0x20, but with RPL 3 = 0x23 for data)
    #   Actually SYSRET adds RPL 3 automatically, so:
    #     User CS = (STAR[63:48] + 16) | 3 = should give 0x1B
    #     User SS = (STAR[63:48] + 8) | 3 = should give 0x23
    #   0x1B = 0x18 | 3 = (0x10 + 8) | 3, so STAR[63:48] should be 0x10? No wait...
    #   Actually: (STAR[63:48] + 16) | 3 = 0x1B means STAR[63:48] = 0x08
    #   Because (0x08 + 16) | 3 = (0x08 + 0x10) | 3 = 0x18 | 3 = 0x1B  ✓
    #   And user SS = (0x08 + 8) | 3 = 0x10 | 3 = 0x13... but we want 0x23!
    #
    # Wait, this is wrong. Let me reconsider.
    # In our GDT: user code = index 3 (selector 0x18), user data = index 4 (selector 0x20)
    # SYSRET computes:
    #   CS = (STAR[63:48] + 16) | 3
    #   SS = (STAR[63:48] + 8) | 3
    # For CS = 0x1B = 0x18 | 3, we need STAR[63:48] + 16 = 0x18, so STAR[63:48] = 0x08
    # For SS = 0x23 = 0x20 | 3, we need STAR[63:48] + 8 = 0x20, so STAR[63:48] = 0x18
    # These are inconsistent! Our GDT layout doesn't match SYSRET's expectations.
    #
    # SYSRET expects:
    #   Index N: 32-bit user code
    #   Index N+1: user data  (used for SS)
    #   Index N+2: 64-bit user code (used for CS)
    #
    # But our GDT is:
    #   Index 0: NULL
    #   Index 1: kernel code (0x08)
    #   Index 2: kernel data (0x10)
    #   Index 3: user code (0x18/0x1B)
    #   Index 4: user data (0x20/0x23)
    #
    # We could use SYSRET with STAR[63:48] = 0x10, giving:
    #   CS = 0x10 + 16 | 3 = 0x20 | 3 = 0x23 (wrong - that's our data segment!)
    #   SS = 0x10 + 8 | 3 = 0x18 | 3 = 0x1B (wrong - that's our code segment!)
    #
    # Our GDT doesn't support SYSRET! We use IRETQ instead (which is fine).
    # For SYSCALL entry, we only need bits 47:32 (kernel CS).
    let star: u64 = (0x08 as u64) << 32
    wrmsr(MSR_STAR, star)

    # Set LSTAR to syscall entry point
    let entry_addr: u64 = syscall_entry as u64
    wrmsr(MSR_LSTAR, entry_addr)

    # Set SFMASK - clear IF on syscall entry
    let sfmask: u64 = 0x200
    wrmsr(MSR_SFMASK, sfmask)

    # DEBUG: Read back MSRs to verify they're set correctly
    let efer_check: u64 = rdmsr(MSR_EFER)
    let star_check: u64 = rdmsr(MSR_STAR)
    let lstar_check: u64 = rdmsr(MSR_LSTAR)
    let sfmask_check: u64 = rdmsr(MSR_SFMASK)

    prints("      EFER:   ")
    serial_print_hex(efer_check)
    prints(" (SCE=")
    if (efer_check & EFER_SCE) != 0
        prints("1")
    else
        prints("0")
    prints(")\n")
    prints("      STAR:   ")
    serial_print_hex(star_check)
    prints("\n")
    prints("      LSTAR:  ")
    serial_print_hex(lstar_check)
    prints("\n")
    prints("      SFMASK: ")
    serial_print_hex(sfmask_check)
    prints("\n")

    return 0

# Syscall handler (called from assembly)
pub fn syscall_handler(rax: u64, rdi: u64, rsi: u64, rdx: u64) -> i64
    # Handle exit specially - it may not return!
    if rax == SYS_EXIT
        # sys_exit_impl handles both child exit (return to parent) and
        # init exit (halt system). It may not return!
        return sys_exit_impl(rdi as i32)

    # SYS_OPEN - Open a file
    # WORKAROUND: knamespace_resolve returns a 32-byte struct which triggers
    # a compiler bug that corrupts kernel globals. Save/restore the affected
    # globals around the call. TODO: Fix the Ritz compiler's large struct return.
    if rax == SYS_OPEN
        # rdi = path pointer
        # rsi = path length
        # rdx = flags
        let saved_child_pid: u64 = g_child_pid
        let saved_has_parent: u8 = g_has_parent
        let result: i64 = sys_open(rdi as *u8, rsi, rdx as i32)
        g_child_pid = saved_child_pid
        g_has_parent = saved_has_parent
        return result

    # SYS_CLOSE - Close a file descriptor
    if rax == SYS_CLOSE
        let fd: i32 = rdi as i32
        # Check if it's a filesystem fd
        if is_fs_fd(fd)
            return sys_close(fd)
        # Otherwise, return success (stdin/stdout/stderr don't close)
        return 0

    if rax == SYS_WRITE or rax == SYS_DEBUG_PRINT
        # Linux/POSIX write convention:
        #   rdi = fd
        #   rsi = buf
        #   rdx = count
        let fd: i32 = rdi as i32
        let buf: *u8 = rsi as *u8
        let len: i64 = rdx as i64

        # Check if it's a filesystem fd
        if is_fs_fd(fd)
            return sys_fs_write(fd, buf, len as u64)

        # Otherwise, write to serial (fd 1 = stdout, fd 2 = stderr)
        var i: i64 = 0
        while i < len
            serial_write_byte(*(buf + i))
            i = i + 1
        return len

    if rax == SYS_READ
        # Linux/POSIX read convention:
        #   rdi = fd
        #   rsi = buf
        #   rdx = count
        let fd: i32 = rdi as i32
        let buf: *u8 = rsi as *u8
        let count: i64 = rdx as i64

        # Check if it's a filesystem fd
        if is_fs_fd(fd)
            return sys_fs_read(fd, buf, count as u64)

        # Only support stdin (fd 0) for serial input
        if fd != 0
            return -1  # EBADF

        # First, poll for any new data
        serial_poll()

        # Read from the serial input buffer
        let bytes_read: i64 = serial_buf_read_many(buf, count)
        return bytes_read

    if rax == SYS_YIELD
        # Yield to scheduler
        yield_task()
        return 0

    if rax == SYS_GETPID
        # Return current process ID (1 for now - single process)
        return 1

    if rax == SYS_READDIR
        # rdi = path pointer, rsi = buffer, rdx = buffer size
        return sys_readdir_impl(rdi as *u8, rsi as *u8, rdx as i64)

    if rax == SYS_SPAWN
        # rdi = path pointer
        return sys_spawn_impl(rdi as *u8)

    if rax == SYS_SPAWN_ARGS
        # rdi = path pointer, rsi = argv, rdx = argc
        return sys_spawn_args_impl(rdi as *u8, rsi as **u8, rdx as i32)

    if rax == SYS_WAIT
        # rdi = pid
        return sys_wait_impl(rdi as i32)

    # IPC syscalls
    if rax == SYS_CHANNEL_CREATE
        return sys_channel_create(1)  # PID 1 for now

    if rax == SYS_IPC_SEND
        return sys_ipc_send(1, rdi as i32, rsi as *Message)

    if rax == SYS_IPC_RECV
        return sys_ipc_recv(1, rdi as i32, rsi as *Message, rdx as *u32)

    if rax == SYS_IPC_CLOSE
        return sys_ipc_close(1, rdi as i32)

    # Capability syscalls
    if rax == SYS_CAP_GRANT
        return sys_cap_grant(1, rdi, rsi as u32, rdx as u32)

    if rax == SYS_CAP_REVOKE
        return sys_cap_revoke(1, rdi)

    if rax == SYS_CAP_DERIVE
        return sys_cap_derive(1, rdi, rsi as u32)

    if rax == SYS_CAP_INFO
        return sys_cap_info(1, rdi, rsi as *CapInfo)

    if rax == SYS_CAP_CHECK
        return sys_cap_check(1, rdi, rsi as u32)

    # ACPI power management syscalls
    if rax == SYS_ACPI_POWEROFF
        prints("[syscall] ACPI poweroff requested\n")
        let result: i32 = acpi_poweroff()
        # If we get here, poweroff failed
        return result as i64

    # Unknown syscall
    prints("[syscall] unknown: ")
    serial_print_dec(rax)
    prints("\n")
    return -1

# ============================================================================
# ELF Loader
# ============================================================================
#
# Parses and loads ELF64 executables for user processes.
# Supports:
#   - ELF64 format (x86-64)
#   - PT_LOAD segments (code, data, bss)
#   - Position-independent executables (PIE) or static
#
# ELF Header Format (64-bit):
#   0x00: e_ident[16]     - Magic number and other info
#   0x10: e_type          - Object file type (u16)
#   0x12: e_machine       - Architecture (u16)
#   0x14: e_version       - Object file version (u32)
#   0x18: e_entry         - Entry point virtual address (u64)
#   0x20: e_phoff         - Program header table file offset (u64)
#   0x28: e_shoff         - Section header table file offset (u64)
#   0x30: e_flags         - Processor-specific flags (u32)
#   0x34: e_ehsize        - ELF header size in bytes (u16)
#   0x36: e_phentsize     - Program header table entry size (u16)
#   0x38: e_phnum         - Program header table entry count (u16)
#   0x3A: e_shentsize     - Section header table entry size (u16)
#   0x3C: e_shnum         - Section header table entry count (u16)
#   0x3E: e_shstrndx      - Section header string table index (u16)

# ELF magic bytes: 0x7F 'E' 'L' 'F'
const ELF_MAGIC_0: u8 = 0x7F
const ELF_MAGIC_1: u8 = 0x45  # 'E'
const ELF_MAGIC_2: u8 = 0x4C  # 'L'
const ELF_MAGIC_3: u8 = 0x46  # 'F'

# e_ident indices
const EI_MAG0: i32 = 0
const EI_MAG1: i32 = 1
const EI_MAG2: i32 = 2
const EI_MAG3: i32 = 3
const EI_CLASS: i32 = 4     # 1=32-bit, 2=64-bit
const EI_DATA: i32 = 5      # 1=little-endian, 2=big-endian
const EI_VERSION: i32 = 6
const EI_OSABI: i32 = 7
const EI_ABIVERSION: i32 = 8

# ELF class values
const ELFCLASS64: u8 = 2

# ELF data encoding
const ELFDATA2LSB: u8 = 1  # Little-endian

# e_type values
const ET_EXEC: u16 = 2   # Executable file
const ET_DYN: u16 = 3    # Shared object file (PIE)

# e_machine values
const EM_X86_64: u16 = 62

# Program header types
const PT_NULL: u32 = 0
const PT_LOAD: u32 = 1    # Loadable segment
const PT_DYNAMIC: u32 = 2
const PT_INTERP: u32 = 3
const PT_NOTE: u32 = 4
const PT_PHDR: u32 = 6
const PT_GNU_STACK: u32 = 0x6474E551
const PT_GNU_RELRO: u32 = 0x6474E552

# Program header flags
const PF_X: u32 = 1       # Execute
const PF_W: u32 = 2       # Write
const PF_R: u32 = 4       # Read

# ELF64 Header structure (64 bytes)
struct Elf64Ehdr
    e_ident: [16]u8       # Magic number and other info
    e_type: u16           # Object file type
    e_machine: u16        # Architecture
    e_version: u32        # Object file version
    e_entry: u64          # Entry point virtual address
    e_phoff: u64          # Program header table file offset
    e_shoff: u64          # Section header table file offset
    e_flags: u32          # Processor-specific flags
    e_ehsize: u16         # ELF header size in bytes
    e_phentsize: u16      # Program header table entry size
    e_phnum: u16          # Program header table entry count
    e_shentsize: u16      # Section header table entry size
    e_shnum: u16          # Section header table entry count
    e_shstrndx: u16       # Section header string table index

# ELF64 Program Header structure (56 bytes)
struct Elf64Phdr
    p_type: u32           # Segment type
    p_flags: u32          # Segment flags
    p_offset: u64         # Segment file offset
    p_vaddr: u64          # Segment virtual address
    p_paddr: u64          # Segment physical address
    p_filesz: u64         # Segment size in file
    p_memsz: u64          # Segment size in memory
    p_align: u64          # Segment alignment

# ELF loader result
struct ElfLoadResult
    entry_point: u64      # Entry point address
    load_base: u64        # Base address where ELF was loaded
    error: i32            # 0 = success, <0 = error code

# ELF error codes
const ELF_OK: i32 = 0
const ELF_ERR_INVALID_MAGIC: i32 = -1
const ELF_ERR_NOT_64BIT: i32 = -2
const ELF_ERR_NOT_LITTLE_ENDIAN: i32 = -3
const ELF_ERR_NOT_EXECUTABLE: i32 = -4
const ELF_ERR_WRONG_MACHINE: i32 = -5
const ELF_ERR_NO_SEGMENTS: i32 = -6
const ELF_ERR_ALLOC_FAILED: i32 = -7
const ELF_ERR_MAP_FAILED: i32 = -8

# Validate ELF header
fn elf_validate_header(ehdr: *Elf64Ehdr) -> i32
    # Check magic number
    if (*ehdr).e_ident[EI_MAG0] != ELF_MAGIC_0
        return ELF_ERR_INVALID_MAGIC
    if (*ehdr).e_ident[EI_MAG1] != ELF_MAGIC_1
        return ELF_ERR_INVALID_MAGIC
    if (*ehdr).e_ident[EI_MAG2] != ELF_MAGIC_2
        return ELF_ERR_INVALID_MAGIC
    if (*ehdr).e_ident[EI_MAG3] != ELF_MAGIC_3
        return ELF_ERR_INVALID_MAGIC

    # Check 64-bit class
    if (*ehdr).e_ident[EI_CLASS] != ELFCLASS64
        return ELF_ERR_NOT_64BIT

    # Check little-endian encoding
    if (*ehdr).e_ident[EI_DATA] != ELFDATA2LSB
        return ELF_ERR_NOT_LITTLE_ENDIAN

    # Check executable type (accept both ET_EXEC and ET_DYN for PIE)
    if (*ehdr).e_type != ET_EXEC and (*ehdr).e_type != ET_DYN
        return ELF_ERR_NOT_EXECUTABLE

    # Check x86-64 architecture
    if (*ehdr).e_machine != EM_X86_64
        return ELF_ERR_WRONG_MACHINE

    # Check program headers exist
    if (*ehdr).e_phnum == 0
        return ELF_ERR_NO_SEGMENTS

    return ELF_OK

# Convert ELF flags to page table flags
fn elf_flags_to_pte(p_flags: u32) -> u64
    var pte_flags: u64 = PTE_USER  # Always user accessible

    # Writable
    if (p_flags & PF_W) != 0
        pte_flags = pte_flags | PTE_WRITABLE

    # Note: x86-64 doesn't have page-level execute disable by default
    # NX bit requires checking EFER.NXE - for now, all pages are executable

    return pte_flags

# Load an ELF executable from memory
#
# Parameters:
#   elf_data: Pointer to ELF file in memory
#   elf_size: Size of ELF file in bytes
#   load_base: Virtual address base for loading (0 to use ELF's addresses)
#
# Returns:
#   ElfLoadResult with entry point and error code
pub fn elf_load(elf_data: *u8, elf_size: u64, load_base: u64) -> ElfLoadResult
    var result: ElfLoadResult
    result.entry_point = 0
    result.load_base = load_base
    result.error = ELF_OK

    # Parse ELF header
    let ehdr: *Elf64Ehdr = elf_data as *Elf64Ehdr

    # Validate header
    let validate_result: i32 = elf_validate_header(ehdr)
    if validate_result != ELF_OK
        result.error = validate_result
        return result

    # Calculate adjusted entry point
    # For PIE executables (ET_DYN), add load_base offset
    # For static executables (ET_EXEC), use as-is
    if (*ehdr).e_type == ET_DYN and load_base != 0
        result.entry_point = (*ehdr).e_entry + load_base
    else
        result.entry_point = (*ehdr).e_entry

    # Process program headers
    let phdr_base: *u8 = elf_data + (*ehdr).e_phoff as i64
    var phdr_idx: u16 = 0

    while phdr_idx < (*ehdr).e_phnum
        let phdr: *Elf64Phdr = (phdr_base + (phdr_idx as i64 * (*ehdr).e_phentsize as i64)) as *Elf64Phdr

        # Only process PT_LOAD segments
        if (*phdr).p_type == PT_LOAD
            # Calculate virtual address (apply load_base for PIE)
            var seg_vaddr: u64 = (*phdr).p_vaddr
            if (*ehdr).e_type == ET_DYN and load_base != 0
                seg_vaddr = seg_vaddr + load_base

            # Calculate number of pages needed
            let seg_start_page: u64 = seg_vaddr & 0xFFFFFFFFFFFFF000  # Page-align down
            let seg_end: u64 = seg_vaddr + (*phdr).p_memsz
            let seg_end_page: u64 = (seg_end + 0xFFF) & 0xFFFFFFFFFFFFF000  # Page-align up
            let num_pages: u64 = (seg_end_page - seg_start_page) / PAGE_SIZE

            # Get page table flags for this segment
            let pte_flags: u64 = elf_flags_to_pte((*phdr).p_flags)

            # Allocate, map, and copy data for this segment
            # We need to copy data through the physical addresses (identity-mapped)
            # since the virtual addresses may be outside the identity-mapped region
            let src: *u8 = elf_data + (*phdr).p_offset as i64
            var bytes_copied: u64 = 0
            var page_offset: u64 = 0

            while page_offset < num_pages * PAGE_SIZE
                let page_vaddr: u64 = seg_start_page + page_offset

                # For user ELF segments, we always need to allocate NEW physical
                # pages and map them with USER permissions. The identity mapping
                # of low memory is kernel-only and would cause page faults.
                #
                # Check if we already allocated this page for a previous segment
                var page_phys: u64 = 0
                var need_map: bool = true
                var need_upgrade: bool = false

                # Check if WE already mapped this page (with USER bit)
                # For the ELF loader, we track pages we've allocated by checking
                # if the physical address differs from the virtual address.
                # Identity mapping has phys == virt, our allocations have phys > 32MB
                # (where PMM allocates from available RAM)
                let existing_phys: u64 = vmm_virt_to_phys(page_vaddr)
                # If physical != virtual, we already mapped it (not identity mapped)
                # Also check it's a reasonable physical address (our allocations
                # come from PMM which allocates from free RAM, typically above kernel)
                if existing_phys != page_vaddr and existing_phys >= 0x200000
                    # We already allocated and mapped this page for a previous segment
                    page_phys = existing_phys
                    need_map = false
                    # Check if we need to upgrade permissions (e.g., R -> RW)
                    # Multiple segments can share a page with different permissions;
                    # we need to use the most permissive combination
                    if (pte_flags & PTE_WRITABLE) != 0
                        need_upgrade = true
                else
                    # Need to allocate a new physical page
                    page_phys = pmm_alloc_page()
                    if page_phys == 0
                        prints("[elf] Failed to allocate page!\n")
                        result.error = ELF_ERR_ALLOC_FAILED
                        return result

                    # Zero the new page (through physical/identity-mapped address)
                    var zero_ptr: *u8 = page_phys as *u8
                    var zero_i: u64 = 0
                    while zero_i < PAGE_SIZE
                        *(zero_ptr + zero_i as i64) = 0
                        zero_i = zero_i + 1

                # Copy data to this page (through physical address)
                var copy_ptr: *u8 = page_phys as *u8

                # Calculate where in the page this segment's data should go
                let page_base: u64 = page_vaddr
                let seg_start_in_page: u64 = 0
                if seg_vaddr > page_base
                    # Segment starts partway into this page
                    let offset: u64 = seg_vaddr - page_base
                    if offset < PAGE_SIZE
                        # Copy starting at offset
                        var copy_i: u64 = 0
                        while copy_i < (*phdr).p_filesz and (offset + copy_i) < PAGE_SIZE
                            *(copy_ptr + (offset + copy_i) as i64) = *(src + copy_i as i64)
                            copy_i = copy_i + 1
                        bytes_copied = copy_i
                else
                    # Segment started before or at this page
                    # Calculate how many bytes we've already copied
                    let already_copied: u64 = page_vaddr - seg_vaddr
                    if already_copied < (*phdr).p_filesz
                        var copy_i: u64 = 0
                        let remaining: u64 = (*phdr).p_filesz - already_copied
                        while copy_i < remaining and copy_i < PAGE_SIZE
                            *(copy_ptr + copy_i as i64) = *(src + (already_copied + copy_i) as i64)
                            copy_i = copy_i + 1
                        bytes_copied = already_copied + copy_i

                # Map the page if needed
                if need_map
                    let map_result: i32 = vmm_map_page(page_vaddr, page_phys, pte_flags)
                    if map_result != 0
                        prints("[elf] Failed to map page at 0x")
                        serial_print_hex(page_vaddr)
                        prints("!\n")
                        pmm_free_page(page_phys)
                        result.error = ELF_ERR_MAP_FAILED
                        return result
                else if need_upgrade
                    # Page was already mapped but we need to upgrade permissions
                    # (e.g., a read-only segment followed by a writable segment sharing the same page)
                    let map_result: i32 = vmm_map_page(page_vaddr, page_phys, pte_flags)
                    if map_result != 0
                        prints("[elf] Failed to upgrade page permissions at 0x")
                        serial_print_hex(page_vaddr)
                        prints("!\n")
                        result.error = ELF_ERR_MAP_FAILED
                        return result

                page_offset = page_offset + PAGE_SIZE

            # The rest (from p_filesz to p_memsz) is already zeroed

        phdr_idx = phdr_idx + 1

    # Flush TLB for the new mappings
    vmm_flush_tlb_all()

    return result

# Load an ELF and execute it in userspace
pub fn elf_exec(elf_data: *u8, elf_size: u64) -> i32
    # Default load base for PIE executables
    # Using a user-space address that's easy to debug
    let default_load_base: u64 = 0x400000

    # Load the ELF
    let load_result: ElfLoadResult = elf_load(elf_data, elf_size, default_load_base)
    if load_result.error != ELF_OK
        prints("[elf] Load failed with error ")
        serial_print_dec((0 - load_result.error) as u64)
        prints("\n")
        return load_result.error

    # Allocate user stack
    let stack_page: u64 = pmm_alloc_page()
    if stack_page == 0
        prints("[elf] Failed to allocate user stack!\n")
        return ELF_ERR_ALLOC_FAILED

    let stack_vaddr: u64 = 0x7FFFFFFFE000
    let map_result: i32 = vmm_map_page(stack_vaddr, stack_page, PTE_WRITABLE | PTE_USER)
    if map_result != 0
        prints("[elf] Failed to map user stack!\n")
        pmm_free_page(stack_page)
        return ELF_ERR_MAP_FAILED

    let stack_top: u64 = stack_vaddr + PAGE_SIZE

    # Flush TLB
    vmm_flush_tlb_all()

    # Jump to userspace
    jump_to_userspace(load_result.entry_point, stack_top)

    # Should not return
    return 0

# Test ELF loader with embedded binary
fn test_elf_loader() -> i32
    prints("\n=== Testing ELF Loader ===\n")

    # Show we have the ELF structures defined
    prints("  Elf64Ehdr size: 64 bytes\n")
    prints("  Elf64Phdr size: 56 bytes\n")

    # Create a minimal ELF header for testing validation
    var test_ehdr: Elf64Ehdr
    test_ehdr.e_ident[0] = ELF_MAGIC_0
    test_ehdr.e_ident[1] = ELF_MAGIC_1
    test_ehdr.e_ident[2] = ELF_MAGIC_2
    test_ehdr.e_ident[3] = ELF_MAGIC_3
    test_ehdr.e_ident[4] = ELFCLASS64
    test_ehdr.e_ident[5] = ELFDATA2LSB
    test_ehdr.e_type = ET_EXEC
    test_ehdr.e_machine = EM_X86_64
    test_ehdr.e_phnum = 1

    let validate_result: i32 = elf_validate_header(@test_ehdr)
    prints("  Validation test: ")
    if validate_result == ELF_OK
        prints("PASSED\n")
    else
        prints("FAILED (error=")
        serial_print_dec((0 - validate_result) as u64)
        prints(")\n")

    # Test invalid magic
    test_ehdr.e_ident[0] = 0x00
    let invalid_result: i32 = elf_validate_header(@test_ehdr)
    prints("  Invalid magic test: ")
    if invalid_result == ELF_ERR_INVALID_MAGIC
        prints("PASSED (correctly rejected)\n")
    else
        prints("FAILED\n")

    prints("=== ELF Loader Test Complete ===\n\n")
    return 0

# Test loading and running the embedded Ritz ELF binary
fn test_elf_userspace() -> i32
    prints("\n=== Testing ELF Userspace ===\n")

    # Get the embedded ELF binary
    let elf_data: *u8 = user_elf_start as *u8
    let elf_end: u64 = user_elf_end as u64
    let elf_size: u64 = elf_end - (elf_data as u64)

    prints("  Embedded ELF: ")
    serial_print_dec(elf_size)
    prints(" bytes at 0x")
    serial_print_hex(elf_data as u64)
    prints("\n")

    # Validate it's a real ELF
    let ehdr: *Elf64Ehdr = elf_data as *Elf64Ehdr
    let validate: i32 = elf_validate_header(ehdr)
    if validate != ELF_OK
        prints("  Invalid ELF header!\n")
        return -1

    prints("  Valid ELF64 header\n")
    prints("  Entry point: 0x")
    serial_print_hex((*ehdr).e_entry)
    prints("\n")

    # Load the ELF
    # For static executables (ET_EXEC), use load_base=0 to use the embedded addresses
    # For PIE executables (ET_DYN), the loader adds load_base to each address
    var load_base: u64 = 0
    if (*ehdr).e_type == ET_DYN
        load_base = 0x100000000  # 4GB for PIE
    let load_result: ElfLoadResult = elf_load(elf_data, elf_size, load_base)
    if load_result.error != ELF_OK
        prints("  ELF load failed!\n")
        return -1

    # Allocate user stack
    let stack_page: u64 = pmm_alloc_page()
    if stack_page == 0
        prints("  Failed to allocate stack!\n")
        return -1

    let stack_vaddr: u64 = 0x7FFFFFFFE000
    let stack_map: i32 = vmm_map_page(stack_vaddr, stack_page, PTE_WRITABLE | PTE_USER)
    if stack_map != 0
        prints("  Failed to map stack!\n")
        pmm_free_page(stack_page)
        return -1

    # Stack top should point INTO the mapped page, not one byte past it!
    # The stack grows down, so first push will go to (RSP - 8).
    # We want that to land within the mapped page [stack_vaddr, stack_vaddr + PAGE_SIZE).
    # So RSP should be at most (stack_vaddr + PAGE_SIZE), and first push lands at
    # (stack_vaddr + PAGE_SIZE - 8) = 0x7FFFFFFFEFF8 which IS in the page.
    # BUT: The IRET itself doesn't push anything. The issue is that when we LOAD
    # RSP = 0x7FFFFFFFF000, that address must be accessible (for some operations).
    # Let's set it to 0x7FFFFFFFEFF0 (16-byte aligned, well within the page).
    let stack_top: u64 = stack_vaddr + PAGE_SIZE - 16

    # Flush TLB for the new mappings
    vmm_flush_tlb_all()

    prints("  Jumping to ELF entry at 0x")
    serial_print_hex(load_result.entry_point)
    prints(", stack=0x")
    serial_print_hex(stack_top)
    prints("\n")

    # Jump to userspace
    jump_to_userspace(load_result.entry_point, stack_top)

    # This should never execute
    prints("  ERROR: Returned from jump_to_userspace!\n")

    # Should not return
    return 0

# Test userspace execution
fn test_userspace() -> i32
    # Use the minimal user program for initial test (just calls exit)
    let user_start: u64 = user_program_minimal as u64
    let user_size: u64 = 16  # Just a few instructions

    # Allocate a user stack (4KB)
    let user_stack_page: u64 = pmm_alloc_page()
    if user_stack_page == 0
        prints("  Failed to allocate user stack!\n")
        return -1

    # Map the stack at a user-accessible address
    let user_stack_vaddr: u64 = 0x7FFFFFFFE000  # High canonical user address
    let map_result: i32 = vmm_map_page(user_stack_vaddr, user_stack_page, PTE_WRITABLE | PTE_USER)
    if map_result != 0
        prints("  Failed to map user stack!\n")
        pmm_free_page(user_stack_page)
        return -1

    let user_stack_top: u64 = user_stack_vaddr + 4096

    # Allocate and copy user code to a new page
    let user_code_page: u64 = pmm_alloc_page()
    if user_code_page == 0
        prints("  Failed to allocate user code page!\n")
        vmm_unmap_page(user_stack_vaddr)
        pmm_free_page(user_stack_page)
        return -1

    # Copy user program to new page
    var src: *u8 = user_start as *u8
    var dst: *u8 = user_code_page as *u8
    var i: i64 = 0
    while i < user_size as i64
        *(dst + i) = *(src + i)
        i = i + 1

    # Map code at user-accessible address (beyond identity region)
    let user_code_vaddr: u64 = 0x100000000  # 4GB
    let code_map_result: i32 = vmm_map_page(user_code_vaddr, user_code_page, PTE_USER)
    if code_map_result != 0
        prints("  Failed to map user code!\n")
        vmm_unmap_page(user_stack_vaddr)
        pmm_free_page(user_stack_page)
        pmm_free_page(user_code_page)
        return -1

    let user_entry: u64 = user_code_vaddr

    # Flush TLB for new mappings
    vmm_flush_tlb_all()

    prints("  Jumping to userspace (Ring 3)...\n")

    # This will transition to Ring 3 and execute the user program
    # When the user program calls exit(0), syscall_handler will halt
    jump_to_userspace(user_entry, user_stack_top)

    # We should NOT reach here - exit() halts the system
    prints("  Returned from userspace unexpectedly!\n")

    # Cleanup (shouldn't happen)
    vmm_unmap_page(user_code_vaddr)
    vmm_unmap_page(user_stack_vaddr)
    pmm_free_page(user_stack_page)
    pmm_free_page(user_code_page)

    return 0

# Get the current CPU's scheduler state
fn get_cpu_sched() -> *CpuSched
    let cpu_id: u32 = lapic_id()
    # Find the CPU in our list by APIC ID
    var i: i32 = 0
    while i < num_cpus as i32
        if cpu_apic_ids[i] == cpu_id as u8
            return @cpu_sched[i]
        i = i + 1
    # Fallback to CPU 0 if not found
    return @cpu_sched[0]

# Schedule next task (called from timer interrupt or yield)
pub fn schedule() -> i32
    if scheduler_initialized == 0
        return 0

    sched_lock()

    let cpu: *CpuSched = get_cpu_sched()
    let old_task_idx: u32 = (*cpu).current_task

    # If we have a current task, save it and put it back on ready queue
    if old_task_idx != 0xFFFFFFFF
        let old_task: *Task = @tasks[old_task_idx as i32]
        if (*old_task).state == TASK_STATE_RUNNING
            (*old_task).state = TASK_STATE_READY
            ready_queue_push(old_task_idx)

    # Get next task from ready queue
    let new_task_idx: u32 = ready_queue_pop()

    if new_task_idx == 0xFFFFFFFF
        # No tasks ready - run idle task
        (*cpu).current_task = (*cpu).idle_task
        let idle: *Task = @tasks[(*cpu).idle_task as i32]
        (*idle).state = TASK_STATE_RUNNING

        sched_unlock()

        # If switching from a real task to idle, do context switch
        if old_task_idx != 0xFFFFFFFF && old_task_idx != (*cpu).idle_task
            let old_ctx: *CpuContext = @(tasks[old_task_idx as i32].context)
            let new_ctx: *CpuContext = @((*idle).context)
            context_switch(old_ctx, new_ctx)

        return 0

    # Switch to new task
    let new_task: *Task = @tasks[new_task_idx as i32]
    (*new_task).state = TASK_STATE_RUNNING
    (*new_task).cpu_id = (*cpu).cpu_id
    (*cpu).current_task = new_task_idx

    sched_unlock()

    # Perform context switch if task actually changed
    if old_task_idx != new_task_idx
        if old_task_idx == 0xFFFFFFFF
            # First switch - no old context to save, just restore new
            let new_ctx: *CpuContext = @((*new_task).context)
            # Jump to new task (special case - no old context)
            asm x86_64:
                movq {new_ctx}, %rdi
                movq 48(%rdi), %rsp        # Restore RSP
                movq 64(%rdi), %rax        # Get RFLAGS
                pushq %rax
                popfq                       # Restore RFLAGS
                movq 0(%rdi), %rbx
                movq 8(%rdi), %rbp
                movq 16(%rdi), %r12
                movq 24(%rdi), %r13
                movq 32(%rdi), %r14
                movq 40(%rdi), %r15
                movq 56(%rdi), %rax        # Get RIP
                jmpq *%rax                  # Jump to task
        else
            let old_ctx: *CpuContext = @(tasks[old_task_idx as i32].context)
            let new_ctx: *CpuContext = @((*new_task).context)
            context_switch(old_ctx, new_ctx)

    return 0

# Yield current task
pub fn yield_task() -> i32
    schedule()
    return 0

# Idle task function (one per CPU)
fn idle_task_func() -> i32
    while true
        asm x86_64:
            sti
            hlt
    return 0

# Create idle task for a CPU
fn create_idle_task(cpu_idx: i32) -> i32
    sched_lock()

    let task_idx: u32 = task_count
    task_count = task_count + 1

    let task: *Task = @tasks[task_idx as i32]

    (*task).id = 0  # Idle tasks have ID 0
    (*task).state = TASK_STATE_READY
    (*task).cpu_id = cpu_idx as u8
    (*task).priority = 0  # Lowest priority

    # Name: "idle-N"
    (*task).name[0] = 105  # 'i'
    (*task).name[1] = 100  # 'd'
    (*task).name[2] = 108  # 'l'
    (*task).name[3] = 101  # 'e'
    (*task).name[4] = 45   # '-'
    (*task).name[5] = (48 + cpu_idx) as u8  # '0' + cpu_idx
    (*task).name[6] = 0

    # Allocate stack based on CPU
    var stack_top: u64 = 0
    if cpu_idx == 0
        # Allocate a page for BSP idle task stack
        let stack_phys: u64 = pmm_alloc_page()
        (*task).stack_base = stack_phys
        (*task).stack_size = PAGE_SIZE
        stack_top = stack_phys + PAGE_SIZE
    else
        # For APs, use their bootstrap stacks
        stack_top = (@ap_stacks[(cpu_idx - 1) as i32][0] as u64) + 4096
        (*task).stack_base = stack_top - 4096
        (*task).stack_size = 4096

    task_init_context(task, idle_task_func as u64, stack_top)

    cpu_sched[cpu_idx].idle_task = task_idx
    cpu_sched[cpu_idx].cpu_id = cpu_idx as u8
    cpu_sched[cpu_idx].current_task = 0xFFFFFFFF

    sched_unlock()

    return task_idx as i32

# Timer interrupt handler (vector 32)
pub fn timer_handler() -> i32
    # Acknowledge interrupt
    lapic_eoi()

    # Trigger scheduler
    schedule()

    return 0

# Configure APIC timer for scheduler
fn apic_timer_init(cpu_idx: i32) -> i32
    # Set timer divider
    lapic_write(LAPIC_TIMER_DIVIDE, 3)  # Divide by 16

    # Configure timer: periodic mode, vector 32 (IRQ 0)
    let timer_config: u32 = LAPIC_TIMER_PERIODIC | LAPIC_TIMER_VECTOR
    lapic_write(LAPIC_TIMER, timer_config)

    # Set initial count (determines frequency)
    lapic_write(LAPIC_TIMER_INITIAL, TIMER_INITIAL_COUNT)

    prints("      APIC timer configured for CPU ")
    serial_print_dec(cpu_idx as u64)
    prints("\n")

    return 0

# Initialize scheduler
pub fn scheduler_init() -> i32
    prints("  [..] Scheduler\n")

    # Initialize task array
    var i: i32 = 0
    while i < MAX_TASKS
        tasks[i].id = 0
        tasks[i].state = TASK_STATE_DEAD
        i = i + 1

    # Initialize CPU scheduler state
    i = 0
    while i < MAX_CPUS
        cpu_sched[i].cpu_id = i as u8
        cpu_sched[i].current_task = 0xFFFFFFFF
        cpu_sched[i].idle_task = 0
        i = i + 1

    # Create idle task for BSP
    create_idle_task(0)

    # Create idle tasks for APs
    i = 1
    while i < num_cpus as i32
        create_idle_task(i)
        i = i + 1

    prints("      Created ")
    serial_print_dec(num_cpus as u64)
    prints(" idle tasks\n")

    # Configure APIC timer on BSP
    apic_timer_init(0)

    scheduler_initialized = 1
    prints("\r  [OK] Scheduler\n")

    return 0

# Test task function 1
fn test_task_a() -> i32
    var count: i32 = 0
    while count < 5
        prints("[Task A] count=")
        serial_print_dec(count as u64)
        prints("\n")
        count = count + 1

        # Yield to other tasks
        yield_task()

    prints("[Task A] done!\n")

    # Mark ourselves as dead
    let cpu: *CpuSched = get_cpu_sched()
    let task: *Task = @tasks[(*cpu).current_task as i32]
    (*task).state = TASK_STATE_DEAD

    # Final yield (won't return)
    while true
        yield_task()

    return 0

