# Harland Microkernel - Main Entry Point
#
# This is the kernel entry point, called by the bootloader after
# setting up the initial page tables and passing boot information.
#
# All hardware interaction uses native Ritz inline assembly.

# ============================================================================
# x86_64 Port I/O
# ============================================================================

pub fn outb(port: u16, value: u8) -> i32
    asm x86_64:
        movw {port}, %dx
        movb {value}, %al
        outb %al, %dx
    return 0

pub fn inb(port: u16) -> u8
    # Use stack-based approach with pointer to work around constraint bug
    var result: u8 = 0
    var result_ptr: *u8 = @result
    asm x86_64:
        movw {port}, %dx
        inb %dx, %al
        movq {result_ptr}, %rcx
        movb %al, (%rcx)
    return result

# ============================================================================
# x86_64 CPU Control
# ============================================================================

pub fn halt() -> i32
    asm x86_64:
        cli
        hlt
    return 0

pub fn halt_loop() -> i32
    asm x86_64:
        cli
    while true
        asm x86_64:
            hlt
    return 0

pub fn enable_interrupts() -> i32
    asm x86_64:
        sti
    return 0

pub fn disable_interrupts() -> i32
    asm x86_64:
        cli
    return 0

# ============================================================================
# Serial Port Driver (COM1)
# ============================================================================

const COM1: u16 = 0x3F8
const COM1_DATA: u16 = 0x3F8
const COM1_IER: u16 = 0x3F9
const COM1_FCR: u16 = 0x3FA
const COM1_LCR: u16 = 0x3FB
const COM1_MCR: u16 = 0x3FC
const COM1_LSR: u16 = 0x3FD
const LSR_THRE: u8 = 0x20

# ============================================================================
# StrView - Zero-copy string view (kernel-local, matches ritzlib layout)
#
# This enables using "hello" string literals which produce StrView with
# compile-time embedded length. No null terminator scanning needed.
# ============================================================================

pub struct StrView
    ptr: *u8
    len: i64

pub fn serial_init() -> i32
    outb(COM1_IER, 0x00)      # Disable interrupts
    outb(COM1_LCR, 0x80)      # Enable DLAB
    outb(COM1_DATA, 0x01)     # Divisor low (115200 baud)
    outb(COM1_IER, 0x00)      # Divisor high
    outb(COM1_LCR, 0x03)      # 8N1
    outb(COM1_FCR, 0xC7)      # Enable FIFO
    outb(COM1_MCR, 0x0B)      # Enable IRQs, RTS/DSR
    return 0

pub fn serial_write_byte(c: u8) -> i32
    while (inb(COM1_LSR) & LSR_THRE) == 0
        asm x86_64:
            pause
    outb(COM1_DATA, c)
    return 0

# Legacy: null-terminated C string (use c"..." literals)
pub fn serial_print(s: *u8) -> i32
    var p: *u8 = s
    while *p != 0
        serial_write_byte(*p)
        p = p + 1
    return 0

# Preferred: explicit length (syscall-style, no null scanning)
pub fn serial_write(buf: *u8, len: i64) -> i32
    var i: i64 = 0
    while i < len
        serial_write_byte(*(buf + i))
        i = i + 1
    return 0

# Preferred: StrView wrapper (use "..." literals - compile-time length)
pub fn prints(s: StrView) -> i32
    return serial_write(s.ptr, s.len)

pub fn serial_print_hex(value: u64) -> i32
    let hex_chars: *u8 = c"0123456789ABCDEF"
    var i: i32 = 15
    while i >= 0
        let nibble: u8 = ((value >> (i * 4)) & 0xF) as u8
        serial_write_byte(*(hex_chars + nibble as i64))
        i = i - 1
    return 0

pub fn serial_print_dec(value: u64) -> i32
    if value == 0
        serial_write_byte(48)
        return 0
    var buf: [20]u8
    var i: i32 = 0
    var v: u64 = value
    while v > 0
        buf[i] = ((v % 10) + 48) as u8
        v = v / 10
        i = i + 1
    while i > 0
        i = i - 1
        serial_write_byte(buf[i])
    return 0

# ============================================================================
# Kernel Ring Buffer (Early Boot Debug)
# ============================================================================
#
# A statically-allocated, lock-free ring buffer for early boot debugging.
# Captures debug messages that can be dumped on crash/panic.
#
# Design:
# - Fixed 4KB buffer (1 page, fits in BSS)
# - No dynamic allocation (kernel can use before heap exists)
# - Circular overwrite when full (keeps most recent messages)
# - Lock-free single-producer (interrupts disabled during write)

# Buffer size: 4KB (1 page)
const RING_BUFFER_SIZE: u64 = 4096

# Static ring buffer - lives in BSS, no allocation needed
var ring_buffer: [4096]u8
var ring_head: u64 = 0      # Write position
var ring_wrapped: u8 = 0    # Has buffer wrapped around?

# Write a single byte to the ring buffer
fn ring_write_byte(c: u8) -> i32
    ring_buffer[ring_head as i32] = c
    ring_head = ring_head + 1
    if ring_head >= RING_BUFFER_SIZE
        ring_head = 0
        ring_wrapped = 1
    return 0

# Write a null-terminated string to the ring buffer
fn ring_write(s: *u8) -> i32
    var p: *u8 = s
    while *p != 0
        ring_write_byte(*p)
        p = p + 1
    return 0

# Write a hex value to the ring buffer (ASCII representation)
fn ring_write_hex(value: u64) -> i32
    let hex_chars: *u8 = c"0123456789ABCDEF"
    var i: i32 = 15
    while i >= 0
        let nibble: u8 = ((value >> (i * 4)) & 0xF) as u8
        ring_write_byte(*(hex_chars + nibble as i64))
        i = i - 1
    return 0

# Clear the ring buffer
fn ring_clear() -> i32
    ring_head = 0
    ring_wrapped = 0
    return 0

# Get the current number of valid bytes in the buffer
fn ring_len() -> u64
    if ring_wrapped != 0
        return RING_BUFFER_SIZE
    return ring_head

# Dump the entire ring buffer contents to serial
# Outputs in chronological order (oldest to newest)
pub fn ring_dump() -> i32
    serial_print(c"\n=== RING BUFFER DUMP (last 4KB of kernel log) ===\n")

    if ring_wrapped != 0
        # Buffer has wrapped: print from head to end, then start to head
        var pos: u64 = ring_head
        while pos < RING_BUFFER_SIZE
            serial_write_byte(ring_buffer[pos as i32])
            pos = pos + 1
        # Then from beginning to head
        pos = 0
        while pos < ring_head
            serial_write_byte(ring_buffer[pos as i32])
            pos = pos + 1
    else
        # Buffer hasn't wrapped: just print from start to head
        var pos: u64 = 0
        while pos < ring_head
            serial_write_byte(ring_buffer[pos as i32])
            pos = pos + 1

    serial_print(c"\n=== END RING BUFFER ===\n")
    return 0

# ============================================================================
# Kernel Logging (klog) - Writes to BOTH serial AND ring buffer
# ============================================================================
#
# Use these for all kernel logging. Output goes to:
# 1. Serial immediately (for live debugging)
# 2. Ring buffer (for crash analysis)

# Log a null-terminated string
pub fn klog(s: *u8) -> i32
    serial_print(s)
    ring_write(s)
    return 0

# Log a StrView string
pub fn klogs(s: StrView) -> i32
    # Extract ptr and len before any move
    let ptr: *u8 = s.ptr
    let len: i64 = s.len
    # Write to serial
    serial_write(ptr, len)
    # Write to ring buffer
    var i: i64 = 0
    while i < len
        ring_write_byte(*(ptr + i))
        i = i + 1
    return 0

# Log with hex value
pub fn klog_hex(prefix: *u8, value: u64, suffix: *u8) -> i32
    serial_print(prefix)
    serial_print_hex(value)
    serial_print(suffix)
    ring_write(prefix)
    ring_write_hex(value)
    ring_write(suffix)
    return 0

# ============================================================================
# Multiboot2 Information Structures
# ============================================================================

# Multiboot2 tag types
const MB2_TAG_END: u32 = 0
const MB2_TAG_CMDLINE: u32 = 1
const MB2_TAG_BOOTLOADER_NAME: u32 = 2
const MB2_TAG_MODULE: u32 = 3
const MB2_TAG_BASIC_MEMINFO: u32 = 4
const MB2_TAG_BOOTDEV: u32 = 5
const MB2_TAG_MMAP: u32 = 6
const MB2_TAG_VBE: u32 = 7
const MB2_TAG_FRAMEBUFFER: u32 = 8
const MB2_TAG_ELF_SECTIONS: u32 = 9
const MB2_TAG_APM: u32 = 10
const MB2_TAG_EFI32: u32 = 11
const MB2_TAG_EFI64: u32 = 12
const MB2_TAG_SMBIOS: u32 = 13
const MB2_TAG_ACPI_OLD: u32 = 14
const MB2_TAG_ACPI_NEW: u32 = 15
const MB2_TAG_NETWORK: u32 = 16
const MB2_TAG_EFI_MMAP: u32 = 17
const MB2_TAG_EFI_BS: u32 = 18
const MB2_TAG_EFI32_IH: u32 = 19
const MB2_TAG_EFI64_IH: u32 = 20
const MB2_TAG_LOAD_BASE_ADDR: u32 = 21

# Memory map entry types
const MB2_MEMORY_AVAILABLE: u32 = 1
const MB2_MEMORY_RESERVED: u32 = 2
const MB2_MEMORY_ACPI_RECLAIMABLE: u32 = 3
const MB2_MEMORY_NVS: u32 = 4
const MB2_MEMORY_BADRAM: u32 = 5

# Multiboot2 fixed boot info header
struct Mb2BootInfo
    total_size: u32
    reserved: u32

# Generic tag header (all tags start with this)
struct Mb2Tag
    tag_type: u32
    size: u32

# Basic memory info tag
struct Mb2BasicMemInfo
    tag_type: u32
    size: u32
    mem_lower: u32
    mem_upper: u32

# Memory map tag header
struct Mb2MmapTag
    tag_type: u32
    size: u32
    entry_size: u32
    entry_version: u32
    # Followed by variable number of Mb2MmapEntry

# Memory map entry (e820-style)
struct Mb2MmapEntry
    base_addr: u64
    length: u64
    entry_type: u32
    reserved: u32

# ============================================================================
# Harland Boot Protocol (UEFI bootloader native format)
# ============================================================================

const HARLAND_BOOT_MAGIC: u32 = 0x4841524C   # "HARL"
const HARLAND_BOOT_VERSION: u32 = 1

# Memory types for Harland boot protocol
const HARLAND_MEM_USABLE: u32 = 1
const HARLAND_MEM_RESERVED: u32 = 2
const HARLAND_MEM_ACPI_RECLAIMABLE: u32 = 3

# Harland memory map entry
[[packed]]
struct HarlandMemEntry
    base: u64
    length: u64
    mem_type: u32
    reserved: u32

# Harland boot info structure (passed by UEFI bootloader)
[[packed]]
struct HarlandBootInfo
    magic: u32                       # 0x4841524C ("HARL")
    version: u32                     # Boot protocol version
    memory_map: *HarlandMemEntry     # Simplified memory map
    memory_map_entries: u32          # Number of entries
    _pad1: u32
    framebuffer_addr: u64            # Framebuffer address (0 if none)
    framebuffer_width: u32
    framebuffer_height: u32
    framebuffer_pitch: u32
    framebuffer_bpp: u8
    _pad2: [3]u8
    rsdp_addr: u64                   # ACPI RSDP address
    kernel_phys: u64                 # Kernel physical address
    kernel_size: u64                 # Kernel size in bytes
    pml4_phys: u64                   # Page table physical address

# Boot protocol type detected at runtime
const BOOT_PROTOCOL_UNKNOWN: u32 = 0
const BOOT_PROTOCOL_MULTIBOOT2: u32 = 1
const BOOT_PROTOCOL_HARLAND: u32 = 2

var boot_protocol: u32 = 0  # BOOT_PROTOCOL_UNKNOWN
var harland_boot_info: *HarlandBootInfo = 0 as *HarlandBootInfo

# ============================================================================
# Physical Memory Manager (Bitmap Allocator)
# ============================================================================

# Page size: 4KB
const PAGE_SIZE: u64 = 4096
const PAGE_SHIFT: u64 = 12

# Maximum memory we support (for now, 256MB - fits in 8KB bitmap)
# 256MB = 268435456 bytes, 65536 pages
const MAX_MEMORY: u64 = 268435456
const MAX_PAGES: u64 = 65536

# Bitmap: 1 bit per page, 1 = free, 0 = used
# 65536 pages / 8 bits per byte = 8192 bytes
var pmm_bitmap: [8192]u8
var pmm_total_pages: u64 = 0
var pmm_free_pages: u64 = 0
var pmm_initialized: u8 = 0

# Set a bit (mark page as free)
fn pmm_set_bit(page: u64) -> i32
    let byte_idx: u64 = page / 8
    let bit_idx: u8 = (page % 8) as u8
    pmm_bitmap[byte_idx as i32] = pmm_bitmap[byte_idx as i32] | (1 << bit_idx)
    return 0

# Clear a bit (mark page as used)
fn pmm_clear_bit(page: u64) -> i32
    let byte_idx: u64 = page / 8
    let bit_idx: u8 = (page % 8) as u8
    pmm_bitmap[byte_idx as i32] = pmm_bitmap[byte_idx as i32] & ~(1 << bit_idx)
    return 0

# Test if a bit is set (page is free)
fn pmm_test_bit(page: u64) -> bool
    let byte_idx: u64 = page / 8
    let bit_idx: u8 = (page % 8) as u8
    return (pmm_bitmap[byte_idx as i32] & (1 << bit_idx)) != 0

# Initialize the PMM - mark everything as used initially
fn pmm_init() -> i32
    var i: i32 = 0
    while i < 8192
        pmm_bitmap[i] = 0
        i = i + 1
    pmm_total_pages = 0
    pmm_free_pages = 0
    pmm_initialized = 1
    return 0

# Mark a range of physical memory as available
fn pmm_mark_region_free(base: u64, length: u64) -> i32
    let start_page: u64 = (base + PAGE_SIZE - 1) / PAGE_SIZE
    let end_page: u64 = (base + length) / PAGE_SIZE

    if start_page >= MAX_PAGES
        return 0

    var page: u64 = start_page
    while page < end_page
        if page >= MAX_PAGES
            break
        pmm_set_bit(page)
        pmm_free_pages = pmm_free_pages + 1
        page = page + 1

    if end_page > pmm_total_pages
        if end_page > MAX_PAGES
            pmm_total_pages = MAX_PAGES
        else
            pmm_total_pages = end_page

    return 0

# Mark a range of physical memory as used (reserved)
fn pmm_mark_region_used(base: u64, length: u64) -> i32
    let start_page: u64 = base / PAGE_SIZE
    let end_page: u64 = (base + length + PAGE_SIZE - 1) / PAGE_SIZE

    var page: u64 = start_page
    while page < end_page
        if page >= MAX_PAGES
            break
        if pmm_test_bit(page)
            pmm_clear_bit(page)
            if pmm_free_pages > 0
                pmm_free_pages = pmm_free_pages - 1
        page = page + 1

    return 0

# Allocate a single physical page
# Returns physical address or 0 on failure
pub fn pmm_alloc_page() -> u64
    if pmm_initialized == 0
        return 0

    if pmm_free_pages == 0
        return 0

    # Linear search for free page
    var page: u64 = 0
    while page < pmm_total_pages
        if pmm_test_bit(page)
            pmm_clear_bit(page)
            pmm_free_pages = pmm_free_pages - 1
            return page * PAGE_SIZE
        page = page + 1

    return 0

# Free a physical page
pub fn pmm_free_page(addr: u64) -> i32
    if pmm_initialized == 0
        return -1

    let page: u64 = addr / PAGE_SIZE
    if page >= MAX_PAGES
        return -1

    if pmm_test_bit(page)
        return -1

    pmm_set_bit(page)
    pmm_free_pages = pmm_free_pages + 1
    return 0

# Get free memory statistics
pub fn pmm_get_free_pages() -> u64
    return pmm_free_pages

pub fn pmm_get_total_pages() -> u64
    return pmm_total_pages

# Parse Multiboot2 memory map and initialize PMM
fn pmm_init_from_multiboot(mb_info: *Mb2BootInfo) -> i32
    pmm_init()

    let info_end: u64 = (mb_info as u64) + (*mb_info).total_size as u64
    var tag_ptr: u64 = (mb_info as u64) + 8

    while tag_ptr < info_end
        let tag: *Mb2Tag = tag_ptr as *Mb2Tag

        if (*tag).tag_type == MB2_TAG_END
            break

        if (*tag).tag_type == MB2_TAG_MMAP
            let mmap_tag: *Mb2MmapTag = tag_ptr as *Mb2MmapTag
            let entry_size: u32 = (*mmap_tag).entry_size
            var entry_ptr: u64 = tag_ptr + 16
            let entries_end: u64 = tag_ptr + (*mmap_tag).size as u64

            while entry_ptr < entries_end
                let entry: *Mb2MmapEntry = entry_ptr as *Mb2MmapEntry

                if (*entry).entry_type == MB2_MEMORY_AVAILABLE
                    pmm_mark_region_free((*entry).base_addr, (*entry).length)

                entry_ptr = entry_ptr + entry_size as u64

        tag_ptr = (tag_ptr + (*tag).size as u64 + 7) & ~7

    return 0

# Initialize PMM from Harland boot info (UEFI boot path)
fn pmm_init_from_bootinfo(info: *HarlandBootInfo) -> i32
    pmm_init()

    let num_entries: u32 = (*info).memory_map_entries
    let mmap: *HarlandMemEntry = (*info).memory_map
    var i: u32 = 0

    while i < num_entries
        let entry: *HarlandMemEntry = (mmap as u64 + (i as u64 * 24)) as *HarlandMemEntry

        if (*entry).mem_type == HARLAND_MEM_USABLE
            pmm_mark_region_free((*entry).base, (*entry).length)

        i = i + 1

    return 0

# Reserve kernel memory regions (call after pmm_init_from_multiboot or pmm_init_from_bootinfo)
fn pmm_reserve_kernel() -> i32
    pmm_mark_region_used(0, 0x100000)
    pmm_mark_region_used(0x100000, 0x100000)
    return 0

# ============================================================================
# Virtual Memory Manager (Paging)
# ============================================================================

# Page table entry flags (x86-64)
const PTE_PRESENT: u64 = 1
const PTE_WRITABLE: u64 = 2
const PTE_USER: u64 = 4
const PTE_WRITE_THROUGH: u64 = 8
const PTE_CACHE_DISABLE: u64 = 16
const PTE_ACCESSED: u64 = 32
const PTE_DIRTY: u64 = 64
const PTE_HUGE: u64 = 128
const PTE_GLOBAL: u64 = 256
const PTE_NO_EXECUTE: u64 = 9223372036854775808

# Address masks
# Physical address mask (bits 12-51) = 0x000FFFFFFFFFF000
const PTE_ADDR_MASK: u64 = 4503599627366400

# Current PML4 physical address (set from CR3)
var vmm_pml4_phys: u64 = 0

# Initialize VMM - read current CR3
fn vmm_init() -> i32
    var cr3_val: u64 = 0
    var cr3_ptr: *u64 = @cr3_val
    asm x86_64:
        movq %cr3, %rax
        movq {cr3_ptr}, %rcx
        movq %rax, (%rcx)
    vmm_pml4_phys = cr3_val & PTE_ADDR_MASK
    return 0

# Flush TLB for a single page
fn vmm_flush_tlb(vaddr: u64) -> i32
    asm x86_64:
        movq {vaddr}, %rax
        invlpg (%rax)
    return 0

# Flush entire TLB (reload CR3)
fn vmm_flush_tlb_all() -> i32
    var cr3_val: u64 = 0
    var cr3_ptr: *u64 = @cr3_val
    asm x86_64:
        movq %cr3, %rax
        movq {cr3_ptr}, %rcx
        movq %rax, (%rcx)
        movq %rax, %cr3
    return 0

# Get entry from a page table level
# table_phys: physical address of table
# index: entry index (0-511)
fn vmm_get_entry(table_phys: u64, index: u64) -> u64
    let entry_ptr: *u64 = (table_phys + index * 8) as *u64
    return *entry_ptr

# Set entry in a page table level
fn vmm_set_entry(table_phys: u64, index: u64, value: u64) -> i32
    let entry_ptr: *u64 = (table_phys + index * 8) as *u64
    *entry_ptr = value
    return 0

# Extract page table indices from virtual address
fn vmm_pml4_index(vaddr: u64) -> u64
    return (vaddr >> 39) & 511

fn vmm_pdpt_index(vaddr: u64) -> u64
    return (vaddr >> 30) & 511

fn vmm_pd_index(vaddr: u64) -> u64
    return (vaddr >> 21) & 511

fn vmm_pt_index(vaddr: u64) -> u64
    return (vaddr >> 12) & 511

# Debug function: dump page table entries for a virtual address
fn vmm_debug_page_tables(vaddr: u64) -> i32
    prints("  Page table walk for vaddr=")
    serial_print_hex(vaddr)
    prints(":\n")

    let pml4i: u64 = vmm_pml4_index(vaddr)
    let pdpti: u64 = vmm_pdpt_index(vaddr)
    let pdi: u64 = vmm_pd_index(vaddr)
    let pti: u64 = vmm_pt_index(vaddr)

    prints("    PML4 index: ")
    serial_print_dec(pml4i)
    prints("\n")

    let pml4_entry: u64 = vmm_get_entry(vmm_pml4_phys, pml4i)
    prints("    PML4[")
    serial_print_dec(pml4i)
    prints("] = ")
    serial_print_hex(pml4_entry)
    if (pml4_entry & PTE_PRESENT) == 0
        prints(" (NOT PRESENT)\n")
        return -1
    prints("\n")

    let pdpt_phys: u64 = pml4_entry & PTE_ADDR_MASK
    prints("    PDPT index: ")
    serial_print_dec(pdpti)
    prints(" at ")
    serial_print_hex(pdpt_phys)
    prints("\n")

    let pdpt_entry: u64 = vmm_get_entry(pdpt_phys, pdpti)
    prints("    PDPT[")
    serial_print_dec(pdpti)
    prints("] = ")
    serial_print_hex(pdpt_entry)
    if (pdpt_entry & PTE_PRESENT) == 0
        prints(" (NOT PRESENT)\n")
        return -1
    prints("\n")

    let pd_phys: u64 = pdpt_entry & PTE_ADDR_MASK
    prints("    PD index: ")
    serial_print_dec(pdi)
    prints(" at ")
    serial_print_hex(pd_phys)
    prints("\n")

    let pd_entry: u64 = vmm_get_entry(pd_phys, pdi)
    prints("    PD[")
    serial_print_dec(pdi)
    prints("] = ")
    serial_print_hex(pd_entry)
    if (pd_entry & PTE_PRESENT) == 0
        prints(" (NOT PRESENT)\n")
        return -1
    prints("\n")

    let pt_phys: u64 = pd_entry & PTE_ADDR_MASK
    prints("    PT index: ")
    serial_print_dec(pti)
    prints(" at ")
    serial_print_hex(pt_phys)
    prints("\n")

    let pt_entry: u64 = vmm_get_entry(pt_phys, pti)
    prints("    PT[")
    serial_print_dec(pti)
    prints("] = ")
    serial_print_hex(pt_entry)
    if (pt_entry & PTE_PRESENT) == 0
        prints(" (NOT PRESENT)\n")
        return -1
    prints("\n")

    return 0

# Map a single 4KB page
# Returns 0 on success, -1 on error (e.g., out of memory for page tables)
pub fn vmm_map_page(vaddr: u64, paddr: u64, flags: u64) -> i32
    # Calculate indices
    let pml4i: u64 = vmm_pml4_index(vaddr)
    let pdpti: u64 = vmm_pdpt_index(vaddr)
    let pdi: u64 = vmm_pd_index(vaddr)
    let pti: u64 = vmm_pt_index(vaddr)

    # Walk/create page tables
    var pml4_entry: u64 = vmm_get_entry(vmm_pml4_phys, pml4i)
    var pdpt_phys: u64 = 0

    # Check if we need to add USER bit to existing entries
    let need_user: u64 = flags & PTE_USER

    if (pml4_entry & PTE_PRESENT) == 0
        # Allocate new PDPT
        pdpt_phys = pmm_alloc_page()
        if pdpt_phys == 0
            return -1
        # Zero the new table
        var i: i32 = 0
        while i < 512
            vmm_set_entry(pdpt_phys, i as u64, 0)
            i = i + 1
        # Set PML4 entry
        vmm_set_entry(vmm_pml4_phys, pml4i, pdpt_phys | PTE_PRESENT | PTE_WRITABLE | PTE_USER)
    else
        pdpt_phys = pml4_entry & PTE_ADDR_MASK
        # If mapping a user page, ensure PML4 entry has USER bit
        if need_user != 0 && (pml4_entry & PTE_USER) == 0
            vmm_set_entry(vmm_pml4_phys, pml4i, pml4_entry | PTE_USER)

    var pdpt_entry: u64 = vmm_get_entry(pdpt_phys, pdpti)
    var pd_phys: u64 = 0

    if (pdpt_entry & PTE_PRESENT) == 0
        # Allocate new PD
        pd_phys = pmm_alloc_page()
        if pd_phys == 0
            return -1
        # Zero the new table
        var i: i32 = 0
        while i < 512
            vmm_set_entry(pd_phys, i as u64, 0)
            i = i + 1
        # Set PDPT entry
        vmm_set_entry(pdpt_phys, pdpti, pd_phys | PTE_PRESENT | PTE_WRITABLE | PTE_USER)
    else
        if (pdpt_entry & PTE_HUGE) != 0
            return -1
        pd_phys = pdpt_entry & PTE_ADDR_MASK
        # If mapping a user page, ensure PDPT entry has USER bit
        if need_user != 0 && (pdpt_entry & PTE_USER) == 0
            vmm_set_entry(pdpt_phys, pdpti, pdpt_entry | PTE_USER)

    var pd_entry: u64 = vmm_get_entry(pd_phys, pdi)
    var pt_phys: u64 = 0

    if (pd_entry & PTE_PRESENT) == 0
        # Allocate new PT
        pt_phys = pmm_alloc_page()
        if pt_phys == 0
            return -1
        # Zero the new table
        var i: i32 = 0
        while i < 512
            vmm_set_entry(pt_phys, i as u64, 0)
            i = i + 1
        # Set PD entry
        vmm_set_entry(pd_phys, pdi, pt_phys | PTE_PRESENT | PTE_WRITABLE | PTE_USER)
    else
        if (pd_entry & PTE_HUGE) != 0
            return -1
        pt_phys = pd_entry & PTE_ADDR_MASK
        # If mapping a user page, ensure PD entry has USER bit
        if need_user != 0 && (pd_entry & PTE_USER) == 0
            vmm_set_entry(pd_phys, pdi, pd_entry | PTE_USER)

    # Set the final page table entry
    vmm_set_entry(pt_phys, pti, paddr | flags | PTE_PRESENT)

    # Flush TLB for this page
    vmm_flush_tlb(vaddr)

    return 0

# Unmap a single 4KB page
# Returns the physical address that was mapped, or 0 if not mapped
pub fn vmm_unmap_page(vaddr: u64) -> u64
    let pml4i: u64 = vmm_pml4_index(vaddr)
    let pdpti: u64 = vmm_pdpt_index(vaddr)
    let pdi: u64 = vmm_pd_index(vaddr)
    let pti: u64 = vmm_pt_index(vaddr)

    let pml4_entry: u64 = vmm_get_entry(vmm_pml4_phys, pml4i)
    if (pml4_entry & PTE_PRESENT) == 0
        return 0

    let pdpt_phys: u64 = pml4_entry & PTE_ADDR_MASK
    let pdpt_entry: u64 = vmm_get_entry(pdpt_phys, pdpti)
    if (pdpt_entry & PTE_PRESENT) == 0
        return 0

    if (pdpt_entry & PTE_HUGE) != 0
        return 0

    let pd_phys: u64 = pdpt_entry & PTE_ADDR_MASK
    let pd_entry: u64 = vmm_get_entry(pd_phys, pdi)
    if (pd_entry & PTE_PRESENT) == 0
        return 0

    if (pd_entry & PTE_HUGE) != 0
        return 0

    let pt_phys: u64 = pd_entry & PTE_ADDR_MASK
    let pt_entry: u64 = vmm_get_entry(pt_phys, pti)
    if (pt_entry & PTE_PRESENT) == 0
        return 0

    let paddr: u64 = pt_entry & PTE_ADDR_MASK

    # Clear the entry
    vmm_set_entry(pt_phys, pti, 0)
    vmm_flush_tlb(vaddr)

    return paddr

# Get physical address for a virtual address
# Returns 0 if not mapped (NOTE: 0 is a valid physical address!)
pub fn vmm_virt_to_phys(vaddr: u64) -> u64
    let pml4i: u64 = vmm_pml4_index(vaddr)
    let pdpti: u64 = vmm_pdpt_index(vaddr)
    let pdi: u64 = vmm_pd_index(vaddr)
    let pti: u64 = vmm_pt_index(vaddr)

    let pml4_entry: u64 = vmm_get_entry(vmm_pml4_phys, pml4i)
    if (pml4_entry & PTE_PRESENT) == 0
        return 0

    let pdpt_phys: u64 = pml4_entry & PTE_ADDR_MASK
    let pdpt_entry: u64 = vmm_get_entry(pdpt_phys, pdpti)
    if (pdpt_entry & PTE_PRESENT) == 0
        return 0

    # 1GB page?
    if (pdpt_entry & PTE_HUGE) != 0
        let base: u64 = pdpt_entry & PTE_ADDR_MASK
        let offset: u64 = vaddr & 1073741823
        return base + offset

    let pd_phys: u64 = pdpt_entry & PTE_ADDR_MASK
    let pd_entry: u64 = vmm_get_entry(pd_phys, pdi)
    if (pd_entry & PTE_PRESENT) == 0
        return 0

    # 2MB page?
    if (pd_entry & PTE_HUGE) != 0
        let base: u64 = pd_entry & PTE_ADDR_MASK
        let offset: u64 = vaddr & 2097151
        return base + offset

    let pt_phys: u64 = pd_entry & PTE_ADDR_MASK
    let pt_entry: u64 = vmm_get_entry(pt_phys, pti)
    if (pt_entry & PTE_PRESENT) == 0
        return 0

    let base: u64 = pt_entry & PTE_ADDR_MASK
    let offset: u64 = vaddr & 4095
    return base + offset

# Check if a physical address is already accessible (identity mapped)
# Returns 1 if mapped, 0 if not
fn vmm_is_accessible(paddr: u64) -> i32
    # Our boot.s identity maps the first 1GB using 2MB huge pages
    # Addresses above 1GB need explicit mapping
    let one_gb: u64 = 1073741824
    if paddr < one_gb
        return 1

    # Check if we've explicitly mapped this address
    let vaddr: u64 = paddr  # We use identity mapping
    let mapped: u64 = vmm_virt_to_phys(vaddr)
    if mapped == paddr
        return 1

    return 0

# Ensure a physical memory region is accessible
# Maps pages if they're not in the identity-mapped region
# Returns 0 on success, -1 on error
fn vmm_ensure_mapped(paddr: u64, size: u64) -> i32
    let one_gb: u64 = 1073741824

    # If entirely within identity-mapped region, nothing to do
    if paddr + size <= one_gb
        return 0

    # Map each 4KB page in the region
    let page_mask: u64 = 0xFFFFFFFFFFFFF000
    var addr: u64 = paddr & page_mask
    let end: u64 = (paddr + size + 4095) & page_mask

    while addr < end
        # Skip if in identity-mapped region
        if addr < one_gb
            addr = addr + 4096
            continue

        # Check if already mapped
        if vmm_is_accessible(addr) == 1
            addr = addr + 4096
            continue

        # Map this page (identity mapping - vaddr = paddr)
        let result: i32 = vmm_map_page(addr, addr, PTE_WRITABLE)
        if result != 0
            prints("vmm_ensure_mapped: failed to map ")
            serial_print_hex(addr)
            prints("\n")
            return -1

        addr = addr + 4096

    return 0

# ============================================================================
# Kernel Heap Allocator (First-Fit Free List)
# ============================================================================

# Heap configuration
# The boot.s maps 0-1GB physical to both:
#   - Identity: 0x0 - 0x40000000
#   - Higher-half: 0xFFFFFFFF80000000 - 0xFFFFFFFFC0000000
#
# These use 2MB huge pages, so we can't use 4KB pages within them.
# For the heap, we use addresses PAST the pre-mapped 1GB region:
#   0xFFFFFFFFC0000000 - 0xFFFFFFFFD0000000: Kernel heap (256MB)
#
# This region is not pre-mapped, so vmm_map_page creates new 4KB page tables.
const KERNEL_VIRT_BASE: u64 = 0xFFFFFFFF80000000
const HEAP_START: u64 = 0xFFFFFFFFC0000000
const HEAP_MAX_SIZE: u64 = 0x10000000  # 256MB
const HEAP_BLOCK_MAGIC: u64 = 0x4845415042434B21

# Block header (placed before each allocation)
# next: pointer to next free block (0 if end or allocated)
# size: size of this block including header (minimum 32 bytes)
# magic: validation magic number
# flags: bit 0 = free (1) or allocated (0)
struct HeapBlock
    next: u64
    size: u64
    magic: u64
    flags: u64

# Heap state
var heap_start: u64 = 0
var heap_end: u64 = 0
var heap_free_list: u64 = 0
var heap_initialized: u8 = 0

# Minimum block size (header + 8 bytes of data)
const HEAP_MIN_BLOCK: u64 = 40

# Initialize the heap with an initial size
fn heap_init(initial_pages: u64) -> i32
    if heap_initialized != 0
        return -1

    heap_start = HEAP_START
    heap_end = heap_start

    # Map initial pages
    var i: u64 = 0
    while i < initial_pages
        let phys: u64 = pmm_alloc_page()
        if phys == 0
            return -1
        let virt: u64 = heap_end
        let result: i32 = vmm_map_page(virt, phys, PTE_WRITABLE)
        if result != 0
            pmm_free_page(phys)
            return -1
        heap_end = heap_end + PAGE_SIZE
        i = i + 1

    # Create initial free block
    let block: *HeapBlock = heap_start as *HeapBlock
    (*block).next = 0
    (*block).size = heap_end - heap_start
    (*block).magic = HEAP_BLOCK_MAGIC
    (*block).flags = 1

    heap_free_list = heap_start
    heap_initialized = 1

    return 0

# Expand heap by adding more pages
fn heap_expand(pages: u64) -> i32
    var i: u64 = 0
    while i < pages
        let phys: u64 = pmm_alloc_page()
        if phys == 0
            return -1
        let virt: u64 = heap_end
        let result: i32 = vmm_map_page(virt, phys, PTE_WRITABLE)
        if result != 0
            pmm_free_page(phys)
            return -1
        heap_end = heap_end + PAGE_SIZE
        i = i + 1

    return 0

# Allocate memory from the heap
pub fn kalloc(size: u64) -> *u8
    if heap_initialized == 0
        return 0 as *u8

    # Calculate actual size needed (header + data, aligned to 8 bytes)
    let aligned_size: u64 = (size + 7) & 18446744073709551608
    var total_size: u64 = aligned_size + 32

    if total_size < HEAP_MIN_BLOCK
        total_size = HEAP_MIN_BLOCK

    # Search free list (first fit)
    var prev: u64 = 0
    var curr: u64 = heap_free_list

    while curr != 0
        let block: *HeapBlock = curr as *HeapBlock

        # Validate block
        if (*block).magic != HEAP_BLOCK_MAGIC
            return 0 as *u8

        if ((*block).flags & 1) != 0
            if (*block).size >= total_size
                # Found a suitable block
                let remaining: u64 = (*block).size - total_size

                if remaining >= HEAP_MIN_BLOCK
                    # Split the block
                    let new_block_addr: u64 = curr + total_size
                    let new_block: *HeapBlock = new_block_addr as *HeapBlock
                    (*new_block).next = (*block).next
                    (*new_block).size = remaining
                    (*new_block).magic = HEAP_BLOCK_MAGIC
                    (*new_block).flags = 1

                    (*block).size = total_size
                    (*block).next = new_block_addr

                    # Update free list
                    if prev == 0
                        heap_free_list = new_block_addr
                    else
                        let prev_block: *HeapBlock = prev as *HeapBlock
                        (*prev_block).next = new_block_addr
                else
                    # Use entire block
                    if prev == 0
                        heap_free_list = (*block).next
                    else
                        let prev_block: *HeapBlock = prev as *HeapBlock
                        (*prev_block).next = (*block).next

                # Mark as allocated
                (*block).flags = 0
                (*block).next = 0

                # Return pointer to data (after header)
                return (curr + 32) as *u8

        prev = curr
        curr = (*block).next

    # No suitable block found - expand heap
    let pages_needed: u64 = (total_size + PAGE_SIZE - 1) / PAGE_SIZE
    let expand_pages: u64 = pages_needed
    if expand_pages < 4
        let four: u64 = 4
        if four > pages_needed
            let pages_to_expand: u64 = 4
            let result: i32 = heap_expand(pages_to_expand)
            if result != 0
                return 0 as *u8
        else
            let result: i32 = heap_expand(pages_needed)
            if result != 0
                return 0 as *u8
    else
        let result: i32 = heap_expand(pages_needed)
        if result != 0
            return 0 as *u8

    # Create new free block at end
    let new_start: u64 = heap_end - pages_needed * PAGE_SIZE
    let new_block: *HeapBlock = new_start as *HeapBlock
    (*new_block).next = 0
    (*new_block).size = pages_needed * PAGE_SIZE
    (*new_block).magic = HEAP_BLOCK_MAGIC
    (*new_block).flags = 1

    # Add to free list
    if heap_free_list == 0
        heap_free_list = new_start
    else
        # Find end of free list
        var curr2: u64 = heap_free_list
        while curr2 != 0
            let b: *HeapBlock = curr2 as *HeapBlock
            if (*b).next == 0
                (*b).next = new_start
                break
            curr2 = (*b).next

    # Try allocation again (recursive)
    return kalloc(size)

# Free allocated memory
pub fn kfree(ptr: *u8) -> i32
    if ptr == (0 as *u8)
        return -1

    if heap_initialized == 0
        return -1

    # Get block header
    let block_addr: u64 = (ptr as u64) - 32
    let block: *HeapBlock = block_addr as *HeapBlock

    # Validate
    if (*block).magic != HEAP_BLOCK_MAGIC
        return -1

    if ((*block).flags & 1) != 0
        return -1

    # Mark as free
    (*block).flags = 1

    # Add to free list (at head for simplicity)
    (*block).next = heap_free_list
    heap_free_list = block_addr

    # TODO: Coalesce adjacent free blocks

    return 0

# Get heap statistics
pub fn heap_get_used() -> u64
    if heap_initialized == 0
        return 0
    return heap_end - heap_start

pub fn heap_get_free() -> u64
    if heap_initialized == 0
        return 0

    var total_free: u64 = 0
    var curr: u64 = heap_free_list

    while curr != 0
        let block: *HeapBlock = curr as *HeapBlock
        if (*block).magic == HEAP_BLOCK_MAGIC
            if ((*block).flags & 1) != 0
                total_free = total_free + (*block).size - 32
        curr = (*block).next

    return total_free

# ============================================================================
# GDT (Global Descriptor Table)
# ============================================================================

# Segment selectors
const GDT_KERNEL_CODE: u16 = 0x08
const GDT_KERNEL_DATA: u16 = 0x10
const GDT_USER_CODE: u16 = 0x1B
const GDT_USER_DATA: u16 = 0x23
const GDT_TSS: u16 = 0x28

# Access flags
const GDT_ACCESS_PRESENT: u8 = 0x80
const GDT_ACCESS_RING0: u8 = 0x00
const GDT_ACCESS_RING3: u8 = 0x60
const GDT_ACCESS_CODE: u8 = 0x1A
const GDT_ACCESS_DATA: u8 = 0x12
const GDT_ACCESS_TSS: u8 = 0x89

# GDT flags
const GDT_FLAG_LONG: u8 = 0x20
const GDT_FLAG_GRANULARITY: u8 = 0x80

struct GdtEntry
    limit_low: u16
    base_low: u16
    base_mid: u8
    access: u8
    flags_limit: u8
    base_high: u8

# GdtDescriptor must be packed (10 bytes total, no padding)
# Format: u16 limit, u64 base (no alignment padding!)
# We use a byte array and set fields manually
struct GdtDescriptor
    data: [10]u8

struct Tss
    reserved0: u32
    rsp0: u64
    rsp1: u64
    rsp2: u64
    reserved1: u64
    ist1: u64
    ist2: u64
    ist3: u64
    ist4: u64
    ist5: u64
    ist6: u64
    ist7: u64
    reserved2: u64
    reserved3: u16
    iopb_offset: u16

# Global storage
var gdt: [7]GdtEntry
var tss: Tss
var gdt_descriptor: GdtDescriptor
var kernel_stack: [4096]u8
var interrupt_stack: [4096]u8

fn make_gdt_entry(base: u32, limit: u32, access: u8, flags: u8) -> GdtEntry
    var entry: GdtEntry
    entry.limit_low = (limit & 0xFFFF) as u16
    entry.base_low = (base & 0xFFFF) as u16
    entry.base_mid = ((base >> 16) & 0xFF) as u8
    entry.access = access
    let limit_hi: u8 = ((limit >> 16) & 0x0F) as u8
    let flags_hi: u8 = flags & 0xF0
    entry.flags_limit = limit_hi | flags_hi
    entry.base_high = ((base >> 24) & 0xFF) as u8
    return entry

fn set_tss_entry(gdt_index: i32, tss_addr: u64) -> i32
    let base: u64 = tss_addr
    let limit: u32 = 103

    gdt[gdt_index].limit_low = (limit & 0xFFFF) as u16
    gdt[gdt_index].base_low = (base & 0xFFFF) as u16
    gdt[gdt_index].base_mid = ((base >> 16) & 0xFF) as u8
    gdt[gdt_index].access = GDT_ACCESS_TSS
    gdt[gdt_index].flags_limit = ((limit >> 16) & 0x0F) as u8
    gdt[gdt_index].base_high = ((base >> 24) & 0xFF) as u8

    let next_entry: *u8 = @gdt[gdt_index + 1] as *u8
    let base_upper: u32 = ((base >> 32) & 0xFFFFFFFF) as u32
    *(next_entry as *u32) = base_upper
    *((next_entry + 4) as *u32) = 0

    return 0

fn tss_init() -> i32
    let tss_ptr: *u8 = @tss as *u8
    var i: i32 = 0
    while i < 104
        *(tss_ptr + i as i64) = 0
        i = i + 1

    let stack_top: u64 = (@kernel_stack[0] as u64) + 4096
    tss.rsp0 = stack_top

    let ist_top: u64 = (@interrupt_stack[0] as u64) + 4096
    tss.ist1 = ist_top

    tss.iopb_offset = 104
    return 0

# GDT reload is done in assembly (boot.s already set up segments)
# We just need to load our new GDT and TSS here
extern fn gdt_flush(gdt_ptr: u64) -> i32

fn gdt_load() -> i32
    let gdt_ptr: *GdtDescriptor = @gdt_descriptor
    var gdt_ptr_val: u64 = gdt_ptr as u64
    gdt_flush(gdt_ptr_val)
    return 0

fn tss_load() -> i32
    let tss_seg: u16 = 0x28
    asm x86_64:
        movw {tss_seg}, %ax
        ltr %ax
    return 0

fn gdt_init() -> i32
    # Null descriptor
    gdt[0] = make_gdt_entry(0, 0, 0, 0)

    # Kernel code segment (selector 0x08)
    let kcode_access: u8 = GDT_ACCESS_PRESENT | GDT_ACCESS_RING0 | GDT_ACCESS_CODE
    let kcode_flags: u8 = GDT_FLAG_LONG | GDT_FLAG_GRANULARITY
    gdt[1] = make_gdt_entry(0, 0xFFFFF, kcode_access, kcode_flags)

    # Kernel data segment (selector 0x10)
    let kdata_access: u8 = GDT_ACCESS_PRESENT | GDT_ACCESS_RING0 | GDT_ACCESS_DATA
    let kdata_flags: u8 = GDT_FLAG_GRANULARITY
    gdt[2] = make_gdt_entry(0, 0xFFFFF, kdata_access, kdata_flags)

    # User code segment (selector 0x18)
    let ucode_access: u8 = GDT_ACCESS_PRESENT | GDT_ACCESS_RING3 | GDT_ACCESS_CODE
    let ucode_flags: u8 = GDT_FLAG_LONG | GDT_FLAG_GRANULARITY
    gdt[3] = make_gdt_entry(0, 0xFFFFF, ucode_access, ucode_flags)

    # User data segment (selector 0x20)
    let udata_access: u8 = GDT_ACCESS_PRESENT | GDT_ACCESS_RING3 | GDT_ACCESS_DATA
    let udata_flags: u8 = GDT_FLAG_GRANULARITY
    gdt[4] = make_gdt_entry(0, 0xFFFFF, udata_access, udata_flags)

    # Initialize TSS
    tss_init()
    let tss_addr: u64 = @tss as u64
    set_tss_entry(5, tss_addr)

    # Set GDT descriptor (packed format: u16 limit, u64 base)
    let gdt_limit: u16 = (7 * 8 - 1) as u16
    let gdt_base: u64 = @gdt[0] as u64
    let desc_ptr: *u8 = @gdt_descriptor.data[0]
    *(desc_ptr as *u16) = gdt_limit
    *((desc_ptr + 2) as *u64) = gdt_base

    # Load GDT and TSS
    gdt_load()
    tss_load()

    return 0

# ============================================================================
# IDT (Interrupt Descriptor Table)
# ============================================================================

const IDT_GATE_INTERRUPT: u8 = 0x8E
const IDT_GATE_TRAP: u8 = 0x8F
const IDT_GATE_USER: u8 = 0xEE

struct IdtEntry
    offset_low: u16
    selector: u16
    ist: u8
    type_attr: u8
    offset_mid: u16
    offset_high: u32
    reserved: u32

# IdtDescriptor must be packed (10 bytes total, no padding)
# Format: u16 size, u64 offset (no alignment padding!)
# We use a byte array and set fields manually (same as GdtDescriptor)
struct IdtDescriptor
    data: [10]u8

var idt: [256]IdtEntry
var idt_descriptor: IdtDescriptor

fn idt_set_gate(vector: u8, handler: u64, selector: u16, ist: u8, type_attr: u8) -> i32
    let idx: i32 = vector as i32
    idt[idx].offset_low = (handler & 0xFFFF) as u16
    idt[idx].selector = selector
    idt[idx].ist = ist
    idt[idx].type_attr = type_attr
    idt[idx].offset_mid = ((handler >> 16) & 0xFFFF) as u16
    idt[idx].offset_high = ((handler >> 32) & 0xFFFFFFFF) as u32
    idt[idx].reserved = 0
    return 0

# External ISR stubs (defined in isr_stubs.s)
extern fn isr_stub_0() -> i32
extern fn isr_stub_1() -> i32
extern fn isr_stub_2() -> i32
extern fn isr_stub_3() -> i32
extern fn isr_stub_4() -> i32
extern fn isr_stub_5() -> i32
extern fn isr_stub_6() -> i32
extern fn isr_stub_7() -> i32
extern fn isr_stub_8() -> i32
extern fn isr_stub_9() -> i32
extern fn isr_stub_10() -> i32
extern fn isr_stub_11() -> i32
extern fn isr_stub_12() -> i32
extern fn isr_stub_13() -> i32
extern fn isr_stub_14() -> i32
extern fn isr_stub_15() -> i32
extern fn isr_stub_16() -> i32
extern fn isr_stub_17() -> i32
extern fn isr_stub_18() -> i32
extern fn isr_stub_19() -> i32
extern fn isr_stub_20() -> i32
extern fn isr_stub_21() -> i32
extern fn isr_stub_22() -> i32
extern fn isr_stub_23() -> i32
extern fn isr_stub_24() -> i32
extern fn isr_stub_25() -> i32
extern fn isr_stub_26() -> i32
extern fn isr_stub_27() -> i32
extern fn isr_stub_28() -> i32
extern fn isr_stub_29() -> i32
extern fn isr_stub_30() -> i32
extern fn isr_stub_31() -> i32

extern fn irq_stub_0() -> i32
extern fn irq_stub_1() -> i32
extern fn irq_stub_2() -> i32
extern fn irq_stub_3() -> i32
extern fn irq_stub_4() -> i32
extern fn irq_stub_5() -> i32
extern fn irq_stub_6() -> i32
extern fn irq_stub_7() -> i32
extern fn irq_stub_8() -> i32
extern fn irq_stub_9() -> i32
extern fn irq_stub_10() -> i32
extern fn irq_stub_11() -> i32
extern fn irq_stub_12() -> i32
extern fn irq_stub_13() -> i32
extern fn irq_stub_14() -> i32
extern fn irq_stub_15() -> i32

fn idt_load() -> i32
    let idt_ptr: *IdtDescriptor = @idt_descriptor
    var idt_ptr_val: u64 = idt_ptr as u64

    asm x86_64:
        movq {idt_ptr_val}, %rax
        lidt (%rax)

    return 0

fn idt_init() -> i32
    var i: i32 = 0
    while i < 256
        idt[i].offset_low = 0
        idt[i].selector = 0
        idt[i].ist = 0
        idt[i].type_attr = 0
        idt[i].offset_mid = 0
        idt[i].offset_high = 0
        idt[i].reserved = 0
        i = i + 1

    let cs: u16 = 0x08

    # Exception handlers (0-31)
    idt_set_gate(0, isr_stub_0 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(1, isr_stub_1 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(2, isr_stub_2 as u64, cs, 1, IDT_GATE_INTERRUPT)
    idt_set_gate(3, isr_stub_3 as u64, cs, 0, IDT_GATE_TRAP)
    idt_set_gate(4, isr_stub_4 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(5, isr_stub_5 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(6, isr_stub_6 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(7, isr_stub_7 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(8, isr_stub_8 as u64, cs, 1, IDT_GATE_INTERRUPT)
    idt_set_gate(9, isr_stub_9 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(10, isr_stub_10 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(11, isr_stub_11 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(12, isr_stub_12 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(13, isr_stub_13 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(14, isr_stub_14 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(15, isr_stub_15 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(16, isr_stub_16 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(17, isr_stub_17 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(18, isr_stub_18 as u64, cs, 1, IDT_GATE_INTERRUPT)
    idt_set_gate(19, isr_stub_19 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(20, isr_stub_20 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(21, isr_stub_21 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(22, isr_stub_22 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(23, isr_stub_23 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(24, isr_stub_24 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(25, isr_stub_25 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(26, isr_stub_26 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(27, isr_stub_27 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(28, isr_stub_28 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(29, isr_stub_29 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(30, isr_stub_30 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(31, isr_stub_31 as u64, cs, 0, IDT_GATE_INTERRUPT)

    # IRQ handlers (32-47)
    idt_set_gate(32, irq_stub_0 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(33, irq_stub_1 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(34, irq_stub_2 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(35, irq_stub_3 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(36, irq_stub_4 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(37, irq_stub_5 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(38, irq_stub_6 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(39, irq_stub_7 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(40, irq_stub_8 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(41, irq_stub_9 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(42, irq_stub_10 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(43, irq_stub_11 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(44, irq_stub_12 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(45, irq_stub_13 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(46, irq_stub_14 as u64, cs, 0, IDT_GATE_INTERRUPT)
    idt_set_gate(47, irq_stub_15 as u64, cs, 0, IDT_GATE_INTERRUPT)

# Set IDT descriptor (packed format: u16 size, u64 base)
    let idt_size: u16 = (256 * 16 - 1) as u16
    let idt_base: u64 = @idt[0] as u64
    let idt_desc_ptr: *u8 = @idt_descriptor.data[0]
    *(idt_desc_ptr as *u16) = idt_size
    *((idt_desc_ptr + 2) as *u64) = idt_base

    idt_load()

    return 0

# ============================================================================
# Interrupt Frame (for exception/IRQ handlers)
# ============================================================================

struct InterruptFrame
    r15: u64
    r14: u64
    r13: u64
    r12: u64
    r11: u64
    r10: u64
    r9: u64
    r8: u64
    rbp: u64
    rdi: u64
    rsi: u64
    rdx: u64
    rcx: u64
    rbx: u64
    rax: u64
    vector: u64
    error_code: u64
    rip: u64
    cs: u64
    rflags: u64
    rsp: u64
    ss: u64

fn exception_name(vector: u8) -> *u8
    if vector == 0
        return c"Divide Error"
    if vector == 1
        return c"Debug"
    if vector == 2
        return c"NMI"
    if vector == 3
        return c"Breakpoint"
    if vector == 4
        return c"Overflow"
    if vector == 5
        return c"Bound Range"
    if vector == 6
        return c"Invalid Opcode"
    if vector == 7
        return c"Device Not Available"
    if vector == 8
        return c"Double Fault"
    if vector == 10
        return c"Invalid TSS"
    if vector == 11
        return c"Segment Not Present"
    if vector == 12
        return c"Stack Fault"
    if vector == 13
        return c"General Protection"
    if vector == 14
        return c"Page Fault"
    if vector == 16
        return c"x87 FP Exception"
    if vector == 17
        return c"Alignment Check"
    if vector == 18
        return c"Machine Check"
    if vector == 19
        return c"SIMD FP Exception"
    return c"Unknown"

# Exception handler (called from isr_stubs.s)
pub fn exception_handler(frame: *InterruptFrame) -> i32
    prints("\n!!! EXCEPTION !!!\n")
    prints("Vector: ")
    serial_print_hex((*frame).vector)
    prints(" (")
    serial_print(exception_name((*frame).vector as u8))
    prints(")\n")

    prints("Error Code: ")
    serial_print_hex((*frame).error_code)
    prints("\n")

    prints("RIP: ")
    serial_print_hex((*frame).rip)
    prints("\n")

    prints("CS: ")
    serial_print_hex((*frame).cs)
    prints("  SS: ")
    serial_print_hex((*frame).ss)
    prints("\n")

    prints("RFLAGS: ")
    serial_print_hex((*frame).rflags)
    prints("\n")

    prints("RSP: ")
    serial_print_hex((*frame).rsp)
    prints("\n")

    # For page faults, print CR2 and decode error code
    if (*frame).vector == 14
        var cr2: u64 = 0
        var cr2_ptr: *u64 = @cr2
        asm x86_64:
            movq %cr2, %rax
            movq {cr2_ptr}, %rcx
            movq %rax, (%rcx)
        prints("CR2: ")
        serial_print_hex(cr2)
        prints(" (fault address)\n")

        # Decode error code
        prints("Error Code Bits:\n")
        if ((*frame).error_code & 1) != 0
            prints("  [P] Page present\n")
        else
            prints("  [P] Page not present\n")
        if ((*frame).error_code & 2) != 0
            prints("  [W] Write operation\n")
        else
            prints("  [W] Read operation\n")
        if ((*frame).error_code & 4) != 0
            prints("  [U] User mode\n")
        else
            prints("  [U] Kernel mode\n")
        if ((*frame).error_code & 8) != 0
            prints("  [R] Reserved bit violation\n")
        if ((*frame).error_code & 16) != 0
            prints("  [I] Instruction fetch\n")

        # Walk page tables to show the issue
        prints("\nPage Table Walk:\n")
        vmm_debug_page_tables(cr2)

    prints("\nRegisters:\n")
    prints("  RAX=")
    serial_print_hex((*frame).rax)
    prints(" RBX=")
    serial_print_hex((*frame).rbx)
    prints("\n")
    prints("  RCX=")
    serial_print_hex((*frame).rcx)
    prints(" RDX=")
    serial_print_hex((*frame).rdx)
    prints("\n")
    prints("  RSI=")
    serial_print_hex((*frame).rsi)
    prints(" RDI=")
    serial_print_hex((*frame).rdi)
    prints("\n")
    prints("  RBP=")
    serial_print_hex((*frame).rbp)
    prints("\n")

    # Dump ring buffer (shows recent kernel activity before crash)
    ring_dump()

    prints("\n*** KERNEL PANIC ***\n")
    prints("System halted.\n")
    halt_loop()
    return 0

# IRQ handler (called from isr_stubs.s)
pub fn irq_handler(frame: *InterruptFrame) -> i32
    let irq_num: u64 = (*frame).vector - 32

    # Send EOI to PIC
    if irq_num >= 8
        outb(0xA0, 0x20)
    outb(0x20, 0x20)

    return 0

# ============================================================================
# PIC (Programmable Interrupt Controller) - Remap to vectors 32-47
# ============================================================================

fn pic_remap() -> i32
    # Save masks
    let mask1: u8 = inb(0x21)
    let mask2: u8 = inb(0xA1)

    # Start initialization sequence
    outb(0x20, 0x11)  # ICW1: init + ICW4 needed
    outb(0xA0, 0x11)

    # ICW2: Vector offsets
    outb(0x21, 0x20)  # PIC1 starts at vector 32
    outb(0xA1, 0x28)  # PIC2 starts at vector 40

    # ICW3: Cascade configuration
    outb(0x21, 0x04)  # PIC1: slave on IRQ2
    outb(0xA1, 0x02)  # PIC2: cascade identity

    # ICW4: 8086 mode
    outb(0x21, 0x01)
    outb(0xA1, 0x01)

    # Restore masks (mask all for now)
    outb(0x21, 0xFF)
    outb(0xA1, 0xFF)

    return 0

# ============================================================================
# ACPI Tables
# ============================================================================

# ACPI table signatures
const ACPI_SIG_RSDP: u64 = 0x2052545020445352  # "RSD PTR " in little endian
const ACPI_SIG_RSDT: u32 = 0x54445352  # "RSDT"
const ACPI_SIG_XSDT: u32 = 0x54445358  # "XSDT"
const ACPI_SIG_MADT: u32 = 0x43495041  # "APIC"

# RSDP (Root System Description Pointer) - ACPI 1.0
struct AcpiRsdp
    signature: [8]u8
    checksum: u8
    oem_id: [6]u8
    revision: u8
    rsdt_addr: u32

# RSDP Extended (ACPI 2.0+)
struct AcpiRsdpExt
    signature: [8]u8
    checksum: u8
    oem_id: [6]u8
    revision: u8
    rsdt_addr: u32
    length: u32
    xsdt_addr: u64
    ext_checksum: u8
    reserved: [3]u8

# Standard ACPI table header
struct AcpiTableHeader
    signature: u32
    length: u32
    revision: u8
    checksum: u8
    oem_id: [6]u8
    oem_table_id: [8]u8
    oem_revision: u32
    creator_id: u32
    creator_revision: u32

# MADT entry types
const MADT_LOCAL_APIC: u8 = 0
const MADT_IO_APIC: u8 = 1
const MADT_INT_SRC_OVERRIDE: u8 = 2
const MADT_NMI_SOURCE: u8 = 3
const MADT_LOCAL_APIC_NMI: u8 = 4
const MADT_LOCAL_APIC_OVERRIDE: u8 = 5
const MADT_IO_SAPIC: u8 = 6
const MADT_LOCAL_SAPIC: u8 = 7
const MADT_X2APIC: u8 = 9

# MADT header
struct MadtHeader
    header: AcpiTableHeader
    local_apic_addr: u32
    flags: u32
    # Followed by variable-length entries

# MADT entry header
struct MadtEntryHeader
    entry_type: u8
    length: u8

# MADT Local APIC entry
struct MadtLocalApic
    header: MadtEntryHeader
    processor_id: u8
    apic_id: u8
    flags: u32

# MADT I/O APIC entry
struct MadtIoApic
    header: MadtEntryHeader
    io_apic_id: u8
    reserved: u8
    io_apic_addr: u32
    gsi_base: u32

# MADT Interrupt Source Override entry
struct MadtIntSrcOverride
    header: MadtEntryHeader
    bus: u8
    source: u8
    gsi: u32
    flags: u16

# Global ACPI state
var acpi_rsdp_addr: u64 = 0  # Set from Multiboot2 or BIOS scan
var acpi_rsdt_addr: u32 = 0
var acpi_xsdt_addr: u64 = 0
var acpi_madt_addr: u64 = 0
var local_apic_addr: u64 = 0
var io_apic_addr: u64 = 0
var num_cpus: u32 = 0
var cpu_apic_ids: [16]u8

# Find ACPI RSDP from Multiboot2 tags
fn acpi_find_from_multiboot(mb_info: *Mb2BootInfo) -> u64
    let info_end: u64 = (mb_info as u64) + (*mb_info).total_size as u64
    var tag_ptr: u64 = (mb_info as u64) + 8

    while tag_ptr < info_end
        let tag: *Mb2Tag = tag_ptr as *Mb2Tag

        if (*tag).tag_type == MB2_TAG_END
            break

        if (*tag).tag_type == MB2_TAG_ACPI_NEW
            # ACPI 2.0+ RSDP follows tag header
            return tag_ptr + 8
        else if (*tag).tag_type == MB2_TAG_ACPI_OLD
            # ACPI 1.0 RSDP follows tag header
            return tag_ptr + 8

        # Move to next tag (8-byte aligned)
        tag_ptr = (tag_ptr + (*tag).size as u64 + 7) & 18446744073709551608

    return 0

# Search for RSDP in EBDA and BIOS ROM area
fn acpi_find_rsdp() -> u64
    # Search EBDA (Extended BIOS Data Area)
    # EBDA segment is at 0x40:0x0E (physical 0x40E)
    let ebda_seg_ptr: *u16 = 0x40E as *u16
    let ebda_addr: u64 = (*ebda_seg_ptr as u64) << 4

    if ebda_addr != 0
        var addr: u64 = ebda_addr
        while addr < ebda_addr + 1024
            let sig: *u64 = addr as *u64
            if *sig == ACPI_SIG_RSDP
                return addr
            addr = addr + 16

    # Search BIOS ROM area (0xE0000 - 0xFFFFF)
    var addr: u64 = 0xE0000
    while addr < 0x100000
        let sig: *u64 = addr as *u64
        if *sig == ACPI_SIG_RSDP
            return addr
        addr = addr + 16

    return 0

# Parse RSDP and find RSDT/XSDT
fn acpi_parse_rsdp(rsdp_addr: u64) -> i32
    let rsdp: *AcpiRsdpExt = rsdp_addr as *AcpiRsdpExt

    # Check revision - 0 = ACPI 1.0 (RSDT only), 2+ = ACPI 2.0+ (XSDT)
    if (*rsdp).revision >= 2
        acpi_xsdt_addr = (*rsdp).xsdt_addr
        prints("      XSDT at: ")
        serial_print_hex(acpi_xsdt_addr)
        prints("\n")

        # Ensure XSDT is mapped (may be beyond identity-mapped region)
        # Map at least 4KB to read the header, then we'll know the real size
        if vmm_ensure_mapped(acpi_xsdt_addr, 4096) != 0
            prints("      ERROR: Failed to map XSDT!\n")
            return -1
    else
        acpi_rsdt_addr = (*rsdp).rsdt_addr
        prints("      RSDT at: ")
        serial_print_hex(acpi_rsdt_addr as u64)
        prints("\n")

        # Ensure RSDT is mapped (may be beyond identity-mapped region)
        if vmm_ensure_mapped(acpi_rsdt_addr as u64, 4096) != 0
            prints("      ERROR: Failed to map RSDT!\n")
            return -1

    return 0

# Find MADT in RSDT/XSDT
fn acpi_find_madt() -> u64
    if acpi_xsdt_addr != 0
        # Use XSDT (64-bit pointers)
        let xsdt: *AcpiTableHeader = acpi_xsdt_addr as *AcpiTableHeader
        let num_entries: u32 = ((*xsdt).length - 36) / 8
        let entries: *u64 = (acpi_xsdt_addr + 36) as *u64

        var i: u32 = 0
        while i < num_entries
            let entry_addr: u64 = *(entries + i as i64)
            # Ensure this table is mapped before reading
            if vmm_ensure_mapped(entry_addr, 64) != 0
                prints(" map error")
                i = i + 1
                continue
            let table: *AcpiTableHeader = entry_addr as *AcpiTableHeader
            if (*table).signature == ACPI_SIG_MADT
                return entry_addr
            i = i + 1
    else if acpi_rsdt_addr != 0
        # Use RSDT (32-bit pointers)
        let rsdt: *AcpiTableHeader = acpi_rsdt_addr as u64 as *AcpiTableHeader
        let num_entries: u32 = ((*rsdt).length - 36) / 4
        let entries: *u32 = (acpi_rsdt_addr as u64 + 36) as *u32

        var i: u32 = 0
        while i < num_entries
            let entry_addr: u32 = *(entries + i as i64)
            # Ensure this table is mapped before reading
            if vmm_ensure_mapped(entry_addr as u64, 64) != 0
                prints(" map error")
                i = i + 1
                continue
            let table: *AcpiTableHeader = entry_addr as u64 as *AcpiTableHeader
            if (*table).signature == ACPI_SIG_MADT
                return entry_addr as u64
            i = i + 1

    return 0

# Parse MADT to find APIC info
fn acpi_parse_madt(madt_addr: u64) -> i32
    let madt: *MadtHeader = madt_addr as *MadtHeader

    # Ensure the full MADT is mapped (header already mapped, but may span pages)
    let madt_length: u64 = (*madt).header.length as u64
    if vmm_ensure_mapped(madt_addr, madt_length) != 0
        prints("      ERROR: Failed to map MADT!\n")
        return -1

    # Get Local APIC address
    local_apic_addr = (*madt).local_apic_addr as u64
    prints("      Local APIC at: ")
    serial_print_hex(local_apic_addr)
    prints("\n")

    # Parse MADT entries
    let madt_end: u64 = madt_addr + (*madt).header.length as u64
    var entry_addr: u64 = madt_addr + 44  # After header

    num_cpus = 0

    while entry_addr < madt_end
        let entry: *MadtEntryHeader = entry_addr as *MadtEntryHeader

        if (*entry).entry_type == MADT_LOCAL_APIC
            let lapic: *MadtLocalApic = entry_addr as *MadtLocalApic
            # Check if processor is enabled (bit 0) or can be enabled (bit 1)
            if ((*lapic).flags & 3) != 0
                if num_cpus < 16
                    cpu_apic_ids[num_cpus as i32] = (*lapic).apic_id
                    num_cpus = num_cpus + 1
        else if (*entry).entry_type == MADT_IO_APIC
            let ioapic: *MadtIoApic = entry_addr as *MadtIoApic
            if io_apic_addr == 0
                io_apic_addr = (*ioapic).io_apic_addr as u64
                prints("      I/O APIC at: ")
                serial_print_hex(io_apic_addr)
                prints("\n")
        else if (*entry).entry_type == MADT_LOCAL_APIC_OVERRIDE
            # Update Local APIC address with 64-bit version
            let override_addr: *u64 = (entry_addr + 4) as *u64
            local_apic_addr = *override_addr
            prints("      Local APIC override: ")
            serial_print_hex(local_apic_addr)
            prints("\n")

        entry_addr = entry_addr + (*entry).length as u64

    prints("      CPUs found: ")
    serial_print_dec(num_cpus as u64)
    prints("\n")

    return 0

# Initialize ACPI (takes Multiboot2 info to find ACPI tables)
fn acpi_init_with_mb(mb_info: *Mb2BootInfo) -> i32
    prints("    Searching for RSDP...")

    # First try Multiboot2 ACPI tags (required for UEFI boot)
    var rsdp_addr: u64 = acpi_find_from_multiboot(mb_info)

    # Fall back to legacy BIOS scan
    if rsdp_addr == 0
        rsdp_addr = acpi_find_rsdp()

    if rsdp_addr == 0
        prints(" not found!\n")
        return -1

    prints(" found at ")
    serial_print_hex(rsdp_addr)
    prints("\n")

    acpi_rsdp_addr = rsdp_addr
    acpi_parse_rsdp(rsdp_addr)

    prints("    Searching for MADT...")
    acpi_madt_addr = acpi_find_madt()

    if acpi_madt_addr == 0
        prints(" not found!\n")
        return -1

    prints(" found at ")
    serial_print_hex(acpi_madt_addr)
    prints("\n")

    acpi_parse_madt(acpi_madt_addr)

    return 0

# Initialize ACPI from Harland boot info (UEFI boot path - RSDP already known)
fn acpi_init_from_bootinfo(info: *HarlandBootInfo) -> i32
    let rsdp_addr: u64 = (*info).rsdp_addr

    prints("    RSDP from bootloader: ")
    serial_print_hex(rsdp_addr)
    prints("\n")

    if rsdp_addr == 0
        prints("    RSDP not found in boot info!\n")
        return -1

    acpi_rsdp_addr = rsdp_addr
    acpi_parse_rsdp(rsdp_addr)

    prints("    Searching for MADT...")
    acpi_madt_addr = acpi_find_madt()

    if acpi_madt_addr == 0
        prints(" not found!\n")
        return -1

    prints(" found at ")
    serial_print_hex(acpi_madt_addr)
    prints("\n")

    acpi_parse_madt(acpi_madt_addr)

    return 0

# ============================================================================
# Local APIC
# ============================================================================

# LAPIC register offsets (memory-mapped)
const LAPIC_ID: u64 = 0x020          # APIC ID
const LAPIC_VERSION: u64 = 0x030     # Version
const LAPIC_TPR: u64 = 0x080         # Task Priority Register
const LAPIC_EOI: u64 = 0x0B0         # End of Interrupt
const LAPIC_LDR: u64 = 0x0D0         # Logical Destination
const LAPIC_DFR: u64 = 0x0E0         # Destination Format
const LAPIC_SVR: u64 = 0x0F0         # Spurious Interrupt Vector
const LAPIC_ESR: u64 = 0x280         # Error Status
const LAPIC_ICR_LO: u64 = 0x300      # Interrupt Command (low 32 bits)
const LAPIC_ICR_HI: u64 = 0x310      # Interrupt Command (high 32 bits)
const LAPIC_TIMER: u64 = 0x320       # Timer LVT
const LAPIC_THERMAL: u64 = 0x330     # Thermal LVT
const LAPIC_PERFCNT: u64 = 0x340     # Performance Counter LVT
const LAPIC_LINT0: u64 = 0x350       # LINT0 LVT
const LAPIC_LINT1: u64 = 0x360       # LINT1 LVT
const LAPIC_ERROR: u64 = 0x370       # Error LVT
const LAPIC_TIMER_INITIAL: u64 = 0x380  # Timer Initial Count
const LAPIC_TIMER_CURRENT: u64 = 0x390  # Timer Current Count
const LAPIC_TIMER_DIVIDE: u64 = 0x3E0   # Timer Divide Configuration

# LAPIC SVR flags
const LAPIC_SVR_ENABLE: u32 = 0x100  # Bit 8: Enable APIC
const LAPIC_SPURIOUS_VEC: u32 = 0xFF # Spurious vector (255)

# Read LAPIC register
fn lapic_read(offset: u64) -> u32
    let addr: *u32 = (local_apic_addr + offset) as *u32
    return *addr

# Write LAPIC register
fn lapic_write(offset: u64, value: u32) -> i32
    let addr: *u32 = (local_apic_addr + offset) as *u32
    *addr = value
    return 0

# Get current CPU's APIC ID
pub fn lapic_id() -> u32
    return lapic_read(LAPIC_ID) >> 24

# Send EOI (End of Interrupt) to LAPIC
pub fn lapic_eoi() -> i32
    lapic_write(LAPIC_EOI, 0)
    return 0

# Initialize Local APIC
fn lapic_init() -> i32
    # Enable LAPIC via SVR (Spurious Vector Register)
    # Set spurious vector to 0xFF and enable bit
    lapic_write(LAPIC_SVR, LAPIC_SVR_ENABLE | LAPIC_SPURIOUS_VEC)

    # Clear task priority to accept all interrupts
    lapic_write(LAPIC_TPR, 0)

    # Clear error status (write twice to clear)
    lapic_write(LAPIC_ESR, 0)
    lapic_write(LAPIC_ESR, 0)

    # Acknowledge any pending interrupts
    lapic_write(LAPIC_EOI, 0)

    # Set up timer - we'll configure this properly later
    # For now, mask it
    lapic_write(LAPIC_TIMER, 0x10000)  # Masked

    # Mask thermal, performance counter
    lapic_write(LAPIC_THERMAL, 0x10000)
    lapic_write(LAPIC_PERFCNT, 0x10000)

    # LINT0/LINT1 - keep default (ExtINT/NMI)
    lapic_write(LAPIC_LINT0, 0x08700)   # ExtINT, unmasked
    lapic_write(LAPIC_LINT1, 0x00400)   # NMI

    # Mask error LVT
    lapic_write(LAPIC_ERROR, 0x10000)

    # Clear error status again
    lapic_write(LAPIC_ESR, 0)

    prints("      LAPIC ID: ")
    serial_print_dec(lapic_id() as u64)
    prints(", Version: ")
    serial_print_hex(lapic_read(LAPIC_VERSION) as u64)
    prints("\n")

    return 0

# ============================================================================
# I/O APIC
# ============================================================================

# I/O APIC registers
const IOAPIC_REGSEL: u64 = 0x00   # Register select
const IOAPIC_WINDOW: u64 = 0x10   # Register data window

# I/O APIC register indices
const IOAPIC_ID: u8 = 0x00
const IOAPIC_VER: u8 = 0x01
const IOAPIC_ARB: u8 = 0x02
const IOAPIC_REDTBL: u8 = 0x10    # Redirection table (0x10 + 2*n for entry n)

# Read I/O APIC register
fn ioapic_read(reg: u8) -> u32
    let regsel: *u32 = io_apic_addr as *u32
    let window: *u32 = (io_apic_addr + IOAPIC_WINDOW) as *u32
    *regsel = reg as u32
    return *window

# Write I/O APIC register
fn ioapic_write(reg: u8, value: u32) -> i32
    let regsel: *u32 = io_apic_addr as *u32
    let window: *u32 = (io_apic_addr + IOAPIC_WINDOW) as *u32
    *regsel = reg as u32
    *window = value
    return 0

# Set up an I/O APIC redirection entry
fn ioapic_set_irq(irq: u8, vector: u8, dest_apic: u8, masked: bool) -> i32
    let reg_lo: u8 = IOAPIC_REDTBL + irq * 2
    let reg_hi: u8 = IOAPIC_REDTBL + irq * 2 + 1

    # High 32 bits: destination APIC ID in bits 24-31
    ioapic_write(reg_hi, (dest_apic as u32) << 24)

    # Low 32 bits:
    # Bits 0-7: Vector
    # Bit 8-10: Delivery mode (000 = Fixed)
    # Bit 11: Destination mode (0 = Physical)
    # Bit 12: Delivery status (read-only)
    # Bit 13: Pin polarity (0 = High active)
    # Bit 14: Remote IRR (read-only)
    # Bit 15: Trigger mode (0 = Edge)
    # Bit 16: Mask (1 = masked)
    var value: u32 = vector as u32
    if masked
        value = value | 0x10000
    ioapic_write(reg_lo, value)

    return 0

# Initialize I/O APIC
fn ioapic_init() -> i32
    if io_apic_addr == 0
        prints("      No I/O APIC!\n")
        return -1

    let version: u32 = ioapic_read(IOAPIC_VER)
    let max_irqs: u32 = ((version >> 16) & 0xFF) + 1

    prints("      I/O APIC version: ")
    serial_print_hex((version & 0xFF) as u64)
    prints(", max IRQs: ")
    serial_print_dec(max_irqs as u64)
    prints("\n")

    # Mask all IRQs initially
    var i: u8 = 0
    while i < max_irqs as u8
        ioapic_set_irq(i, 32 + i, 0, true)  # Vector 32+, masked
        i = i + 1

    # Unmask keyboard (IRQ 1) - route to vector 33, CPU 0
    ioapic_set_irq(1, 33, 0, false)

    # Unmask COM1 (IRQ 4) - route to vector 36, CPU 0
    ioapic_set_irq(4, 36, 0, false)

    return 0

# Disable legacy 8259 PIC
fn pic_disable() -> i32
    # Mask all interrupts on both PICs
    outb(0xA1, 0xFF)
    outb(0x21, 0xFF)
    return 0

# ============================================================================
# AP (Application Processor) Bootstrap
# ============================================================================

# AP bootstrap state
var ap_started: [16]u8          # Flag for each AP
var ap_stacks: [16][4096]u8     # Stack for each AP
var ap_count: u32 = 0           # Number of APs that have started
var bsp_apic_id: u8 = 0         # BSP's APIC ID

# Trampoline code location (must be in low memory, <1MB)
const AP_TRAMPOLINE_ADDR: u64 = 0x8000

# External symbols from ap_trampoline.s
extern fn ap_trampoline_start() -> i32
extern fn ap_trampoline_end() -> i32

# IPI delivery modes
const IPI_DELIVERY_FIXED: u8 = 0
const IPI_DELIVERY_INIT: u8 = 5
const IPI_DELIVERY_SIPI: u8 = 6

# Send IPI (Inter-Processor Interrupt)
fn lapic_send_ipi(dest_apic: u8, vector: u8, delivery_mode: u8) -> i32
    # Wait for previous IPI to complete
    while (lapic_read(LAPIC_ICR_LO) & 0x1000) != 0
        asm x86_64:
            pause

    # Set destination in ICR high
    lapic_write(LAPIC_ICR_HI, (dest_apic as u32) << 24)

    # Send IPI via ICR low
    # Bits 0-7: Vector
    # Bits 8-10: Delivery mode (000=Fixed, 101=INIT, 110=Startup)
    # Bit 11: Destination mode (0=Physical)
    # Bit 12: Delivery status (read-only)
    # Bit 14: Level (1 for INIT)
    # Bit 15: Trigger mode (0=Edge, 1=Level)
    let icr_lo: u32 = (vector as u32) | ((delivery_mode as u32) << 8)
    lapic_write(LAPIC_ICR_LO, icr_lo)

    return 0

# Delay in microseconds (rough, using busy loop)
fn delay_us(us: u32) -> i32
    # Very rough delay - assumes ~1GHz CPU
    var i: u32 = 0
    while i < us * 100
        asm x86_64:
            pause
        i = i + 1
    return 0

# AP entry point (called by ap_trampoline.s after transition to long mode)
pub fn ap_entry() -> i32
    # Get our APIC ID
    let my_apic_id: u32 = lapic_id()

    # Initialize our local APIC
    lapic_write(LAPIC_SVR, LAPIC_SVR_ENABLE | LAPIC_SPURIOUS_VEC)
    lapic_write(LAPIC_TPR, 0)

    # Print message (need mutex for serial, but for now just try)
    prints("    AP ")
    serial_print_dec(my_apic_id as u64)
    prints(" started!\n")

    # Mark ourselves as started
    ap_started[my_apic_id as i32] = 1
    ap_count = ap_count + 1

    # For now, just halt - scheduler will give us work later
    while true
        asm x86_64:
            hlt

    return 0

# Copy trampoline code to low memory and set up parameters
fn ap_setup_trampoline(ap_index: u32) -> i32
    # Calculate trampoline size
    let tramp_start: u64 = ap_trampoline_start as u64
    let tramp_end: u64 = ap_trampoline_end as u64
    let tramp_size: u64 = tramp_end - tramp_start

    # Copy trampoline to 0x8000
    var src: *u8 = tramp_start as *u8
    var dst: *u8 = AP_TRAMPOLINE_ADDR as *u8
    var i: u64 = 0
    while i < tramp_size
        *(dst + i as i64) = *(src + i as i64)
        i = i + 1

    # Set up trampoline parameters at fixed locations
    # See ap_trampoline.s for layout:
    #   0x8FF0: PML4 address (u32)
    #   0x8FF8: Stack pointer (u64)
    #   0x9000: Entry point (u64)

    # PML4 address (32-bit at 0x8FF0)
    let pml4_ptr: *u32 = 0x8FF0 as *u32
    *pml4_ptr = vmm_pml4_phys as u32

    # Stack pointer (64-bit at 0x8FF8)
    let stack_ptr: *u64 = 0x8FF8 as *u64
    # Stack top is the address of the END of the AP's stack (stacks grow down)
    # @ap_stacks[ap_index][0] gives the start, add 4096 for the top
    let stack_top: u64 = (@ap_stacks[ap_index as i32][0] as u64) + 4096
    *stack_ptr = stack_top

    # Entry point (64-bit at 0x9000)
    let entry_ptr: *u64 = 0x9000 as *u64
    *entry_ptr = ap_entry as u64

    return 0

# Boot a single AP
fn ap_boot_one(apic_id: u8, ap_index: u32) -> i32
    prints("    Booting AP ")
    serial_print_dec(apic_id as u64)
    prints("...")

    # Set up trampoline for this AP
    ap_setup_trampoline(ap_index)

    # Send INIT IPI
    lapic_send_ipi(apic_id, 0, IPI_DELIVERY_INIT)
    delay_us(10000)  # 10ms delay

    # Send INIT de-assert (level=0, trigger=level)
    # This is done by setting level bit low
    lapic_write(LAPIC_ICR_HI, (apic_id as u32) << 24)
    lapic_write(LAPIC_ICR_LO, 0x8500)  # INIT, level, de-assert
    delay_us(200)

    # Send SIPI (Startup IPI) - vector is page number (0x08 for 0x8000)
    let sipi_vector: u8 = (AP_TRAMPOLINE_ADDR / 4096) as u8
    lapic_send_ipi(apic_id, sipi_vector, IPI_DELIVERY_SIPI)
    delay_us(200)

    # Send second SIPI (recommended by Intel)
    lapic_send_ipi(apic_id, sipi_vector, IPI_DELIVERY_SIPI)
    delay_us(200)

    # Wait for AP to start (with timeout)
    var timeout: u32 = 1000
    while ap_started[apic_id as i32] == 0 && timeout > 0
        delay_us(1000)
        timeout = timeout - 1

    if ap_started[apic_id as i32] != 0
        prints(" OK\n")
        return 0
    else
        prints(" TIMEOUT\n")
        return -1

# Boot all APs
fn ap_boot_all() -> i32
    # Record BSP's APIC ID
    bsp_apic_id = lapic_id() as u8

    prints("  [..] Boot APs\n")
    prints("    BSP APIC ID: ")
    serial_print_dec(bsp_apic_id as u64)
    prints("\n")

    # Clear started flags
    var i: i32 = 0
    while i < 16
        ap_started[i] = 0
        i = i + 1

    # Boot each AP (skip BSP)
    var ap_index: u32 = 0
    i = 0
    while i < num_cpus as i32
        let apic_id: u8 = cpu_apic_ids[i]
        if apic_id != bsp_apic_id
            ap_boot_one(apic_id, ap_index)
            ap_index = ap_index + 1
        i = i + 1

    prints("  [OK] Boot APs (")
    serial_print_dec(ap_count as u64)
    prints(" APs started)\n")

    return 0

# Initialize APIC system (requires Multiboot info for ACPI tables)
fn apic_init_with_mb(mb_info: *Mb2BootInfo) -> i32
    prints("  [..] ACPI/APIC\n")

    # Parse ACPI tables to find APIC info
    let acpi_result: i32 = acpi_init_with_mb(mb_info)
    if acpi_result != 0
        prints("\r  [!!] ACPI/APIC (ACPI not found)\n")
        return -1

    # Map Local APIC and I/O APIC to identity addresses
    # These are memory-mapped I/O regions above 1GB, outside our initial mapping
    prints("    Mapping APIC regions...")
    if local_apic_addr != 0
        let lapic_result: i32 = vmm_map_page(local_apic_addr, local_apic_addr, PTE_WRITABLE | PTE_CACHE_DISABLE)
        if lapic_result != 0
            prints(" LAPIC map failed!\n")
            return -1
    if io_apic_addr != 0
        let ioapic_result: i32 = vmm_map_page(io_apic_addr, io_apic_addr, PTE_WRITABLE | PTE_CACHE_DISABLE)
        if ioapic_result != 0
            prints(" IOAPIC map failed!\n")
            return -1
    prints(" done\n")

    # Initialize Local APIC on BSP
    prints("    Initializing Local APIC...")
    lapic_init()
    prints(" done\n")

    # Initialize I/O APIC
    prints("    Initializing I/O APIC...")
    ioapic_init()
    prints(" done\n")

    # Disable legacy PIC
    prints("    Disabling legacy PIC...")
    pic_disable()
    prints(" done\n")

    prints("\r  [OK] ACPI/APIC\n")

    return 0

# Initialize APIC from Harland boot info (UEFI boot path)
fn apic_init_from_bootinfo(info: *HarlandBootInfo) -> i32
    prints("  [..] ACPI/APIC\n")

    # Parse ACPI tables using RSDP from bootloader
    let acpi_result: i32 = acpi_init_from_bootinfo(info)
    if acpi_result != 0
        prints("\r  [!!] ACPI/APIC (ACPI not found)\n")
        return -1

    # Map Local APIC and I/O APIC to identity addresses
    prints("    Mapping APIC regions...")
    if local_apic_addr != 0
        let lapic_result: i32 = vmm_map_page(local_apic_addr, local_apic_addr, PTE_WRITABLE | PTE_CACHE_DISABLE)
        if lapic_result != 0
            prints(" LAPIC map failed!\n")
            return -1
    if io_apic_addr != 0
        let ioapic_result: i32 = vmm_map_page(io_apic_addr, io_apic_addr, PTE_WRITABLE | PTE_CACHE_DISABLE)
        if ioapic_result != 0
            prints(" IOAPIC map failed!\n")
            return -1
    prints(" done\n")

    # Initialize Local APIC on BSP
    prints("    Initializing Local APIC...")
    lapic_init()
    prints(" done\n")

    # Initialize I/O APIC
    prints("    Initializing I/O APIC...")
    ioapic_init()
    prints(" done\n")

    # Disable legacy PIC
    prints("    Disabling legacy PIC...")
    pic_disable()
    prints(" done\n")

    prints("\r  [OK] ACPI/APIC\n")

    return 0

# ============================================================================
# Scheduler
# ============================================================================

# Task states
const TASK_STATE_DEAD: u8 = 0
const TASK_STATE_READY: u8 = 1
const TASK_STATE_RUNNING: u8 = 2
const TASK_STATE_BLOCKED: u8 = 3

# Maximum tasks and CPUs
const MAX_TASKS: i32 = 64
const MAX_CPUS: i32 = 16

# CPU context - all registers saved on context switch
# Must match the layout in context_switch assembly
struct CpuContext
    # Callee-saved registers (System V AMD64 ABI)
    rbx: u64
    rbp: u64
    r12: u64
    r13: u64
    r14: u64
    r15: u64
    rsp: u64        # Stack pointer
    rip: u64        # Return address (set to task entry point initially)
    rflags: u64     # Flags register

# Task Control Block (TCB)
struct Task
    id: u32
    state: u8
    cpu_id: u8          # Which CPU is running this (if RUNNING)
    priority: u8
    pad: u8
    context: CpuContext
    stack_base: u64     # Base of kernel stack
    stack_size: u64     # Stack size
    name: [16]u8        # Task name for debugging

# Per-CPU scheduler state
struct CpuSched
    cpu_id: u8
    pad: [7]u8
    current_task: u32   # Index of currently running task (or 0xFFFFFFFF if idle)
    idle_task: u32      # Index of this CPU's idle task

# Global scheduler state
var tasks: [64]Task                 # All tasks
var task_count: u32 = 0             # Number of tasks created
var next_task_id: u32 = 1           # Next task ID to assign

var cpu_sched: [16]CpuSched         # Per-CPU scheduler state
var ready_queue: [64]u32            # Ready task indices (simple FIFO)
var ready_head: u32 = 0
var ready_tail: u32 = 0
var ready_count: u32 = 0

var scheduler_initialized: u8 = 0
var scheduler_lock: u32 = 0         # Simple spinlock

# APIC Timer constants
const LAPIC_TIMER_PERIODIC: u32 = 0x20000   # Periodic mode
const LAPIC_TIMER_VECTOR: u32 = 32          # IRQ 0 (vector 32 after PIC remap)
const TIMER_DIVISOR: u32 = 16               # Divide by 16
const TIMER_INITIAL_COUNT: u32 = 10000000   # ~10ms at typical frequencies

# Spinlock acquire
fn sched_lock() -> i32
    # Simple spinlock using atomic CAS
    # Load the lock address and use RIP-relative addressing
    while true
        var result: u32 = 0
        var one: u32 = 1
        # Try to atomically swap: set lock to 1 and get old value
        asm x86_64:
            lea scheduler_lock(%rip), %rsi
            movl {one}, %eax
            xchgl %eax, (%rsi)
            movl %eax, {result}
        if result == 0
            return 0  # Got the lock (was unlocked)
    return 0

# Spinlock release
fn sched_unlock() -> i32
    scheduler_lock = 0
    return 0

# Add task to ready queue
fn ready_queue_push(task_idx: u32) -> i32
    if ready_count >= 64
        return -1
    ready_queue[ready_tail as i32] = task_idx
    ready_tail = (ready_tail + 1) % 64
    ready_count = ready_count + 1
    return 0

# Remove task from ready queue
fn ready_queue_pop() -> u32
    if ready_count == 0
        return 0xFFFFFFFF  # No tasks
    let task_idx: u32 = ready_queue[ready_head as i32]
    ready_head = (ready_head + 1) % 64
    ready_count = ready_count - 1
    return task_idx

# Initialize a task's context for first run
fn task_init_context(task: *Task, entry: u64, stack_top: u64) -> i32
    (*task).context.rbx = 0
    (*task).context.rbp = stack_top
    (*task).context.r12 = 0
    (*task).context.r13 = 0
    (*task).context.r14 = 0
    (*task).context.r15 = 0
    (*task).context.rsp = stack_top - 8  # Room for return address
    (*task).context.rip = entry
    (*task).context.rflags = 0x202       # IF=1, reserved bit 1

    # Push the return address onto the stack
    let ret_ptr: *u64 = (stack_top - 8) as *u64
    *ret_ptr = entry

    return 0

# Create a new kernel task
pub fn task_create(name: *u8, entry: u64) -> i32
    sched_lock()

    if task_count >= MAX_TASKS as u32
        sched_unlock()
        return -1

    let task_idx: u32 = task_count
    task_count = task_count + 1

    let task: *Task = @tasks[task_idx as i32]

    # Initialize task
    (*task).id = next_task_id
    next_task_id = next_task_id + 1
    (*task).state = TASK_STATE_READY
    (*task).cpu_id = 0
    (*task).priority = 128  # Default priority

    # Copy name
    var i: i32 = 0
    var src: *u8 = name
    while i < 15 && *src != 0
        (*task).name[i] = *src
        src = src + 1
        i = i + 1
    (*task).name[i] = 0

    # Allocate stack (4KB)
    let stack_pages: u64 = 1
    let stack_phys: u64 = pmm_alloc_page()
    if stack_phys == 0
        sched_unlock()
        return -1

    # Map stack (use a high virtual address range for task stacks)
    let stack_virt: u64 = 0x200000000 + (task_idx as u64) * 0x2000
    let map_result: i32 = vmm_map_page(stack_virt, stack_phys, PTE_WRITABLE)
    if map_result != 0
        pmm_free_page(stack_phys)
        sched_unlock()
        return -1

    (*task).stack_base = stack_virt
    (*task).stack_size = PAGE_SIZE

    let stack_top: u64 = stack_virt + PAGE_SIZE

    # Initialize context
    task_init_context(task, entry, stack_top)

    # Add to ready queue
    ready_queue_push(task_idx)

    sched_unlock()

    return (*task).id as i32

# External assembly function for context switch
extern fn context_switch(old_ctx: *CpuContext, new_ctx: *CpuContext)

# External assembly functions for syscalls and userspace
extern fn syscall_entry()
extern fn jump_to_userspace(entry: u64, stack: u64)
extern fn user_program_start()
extern fn user_program_end()
extern fn user_program_minimal()

# ============================================================================
# Syscall Interface
# ============================================================================

# MSR numbers for SYSCALL/SYSRET
const MSR_EFER: u32 = 0xC0000080
const MSR_STAR: u32 = 0xC0000081
const MSR_LSTAR: u32 = 0xC0000082
const MSR_SFMASK: u32 = 0xC0000084
const EFER_SCE: u64 = 1

# Harland syscall numbers
const SYS_READ: u64 = 0
const SYS_WRITE: u64 = 1
const SYS_EXIT: u64 = 20
const SYS_DEBUG_PRINT: u64 = 255

fn rdmsr(msr: u32) -> u64
    var lo: u32 = 0
    var hi: u32 = 0
    asm x86_64:
        movl {msr}, %ecx
        rdmsr
        movl %eax, {lo}
        movl %edx, {hi}
    return (hi as u64 << 32) | (lo as u64)

fn wrmsr(msr: u32, value: u64) -> i32
    let lo: u32 = (value & 0xFFFFFFFF) as u32
    let hi: u32 = (value >> 32) as u32
    asm x86_64:
        movl {msr}, %ecx
        movl {lo}, %eax
        movl {hi}, %edx
        wrmsr
    return 0

pub fn syscall_init() -> i32
    # Enable SYSCALL/SYSRET in EFER
    let efer: u64 = rdmsr(MSR_EFER)
    wrmsr(MSR_EFER, efer | EFER_SCE)

    # Set up STAR MSR - kernel CS in bits 47:32
    let star: u64 = (0x08 as u64) << 32
    wrmsr(MSR_STAR, star)

    # Set LSTAR to syscall entry point
    let entry_addr: u64 = syscall_entry as u64
    wrmsr(MSR_LSTAR, entry_addr)

    # Set SFMASK - clear IF on syscall entry
    let sfmask: u64 = 0x200
    wrmsr(MSR_SFMASK, sfmask)

    prints("      LSTAR: ")
    serial_print_hex(entry_addr)
    prints("\n")

    return 0

# Syscall handler (called from assembly)
pub fn syscall_handler(rax: u64, rdi: u64, rsi: u64, rdx: u64) -> i64
    if rax == SYS_EXIT
        prints("[syscall] exit(")
        serial_print_dec(rdi)
        prints(")\n")
        # For now, halt
        halt_loop()
        return 0

    if rax == SYS_WRITE || rax == SYS_DEBUG_PRINT
        # Write to serial
        let buf: *u8 = rdi as *u8
        let len: i64 = rsi as i64
        var i: i64 = 0
        while i < len
            serial_write_byte(*(buf + i))
            i = i + 1
        return len

    return -1

# Test userspace execution
fn test_userspace() -> i32
    # Use the minimal user program for initial test (just calls exit)
    let user_start: u64 = user_program_minimal as u64
    let user_size: u64 = 16  # Just a few instructions

    # Allocate a user stack (4KB)
    let user_stack_page: u64 = pmm_alloc_page()
    if user_stack_page == 0
        prints("  Failed to allocate user stack!\n")
        return -1

    # Map the stack at a user-accessible address
    let user_stack_vaddr: u64 = 0x7FFFFFFFE000  # High canonical user address
    let map_result: i32 = vmm_map_page(user_stack_vaddr, user_stack_page, PTE_WRITABLE | PTE_USER)
    if map_result != 0
        prints("  Failed to map user stack!\n")
        pmm_free_page(user_stack_page)
        return -1

    let user_stack_top: u64 = user_stack_vaddr + 4096

    # Allocate and copy user code to a new page
    let user_code_page: u64 = pmm_alloc_page()
    if user_code_page == 0
        prints("  Failed to allocate user code page!\n")
        vmm_unmap_page(user_stack_vaddr)
        pmm_free_page(user_stack_page)
        return -1

    # Copy user program to new page
    var src: *u8 = user_start as *u8
    var dst: *u8 = user_code_page as *u8
    var i: i64 = 0
    while i < user_size as i64
        *(dst + i) = *(src + i)
        i = i + 1

    # Map code at user-accessible address (beyond identity region)
    let user_code_vaddr: u64 = 0x100000000  # 4GB
    let code_map_result: i32 = vmm_map_page(user_code_vaddr, user_code_page, PTE_USER)
    if code_map_result != 0
        prints("  Failed to map user code!\n")
        vmm_unmap_page(user_stack_vaddr)
        pmm_free_page(user_stack_page)
        pmm_free_page(user_code_page)
        return -1

    let user_entry: u64 = user_code_vaddr

    # Flush TLB for new mappings
    vmm_flush_tlb_all()

    prints("  Jumping to userspace (Ring 3)...\n")

    # This will transition to Ring 3 and execute the user program
    # When the user program calls exit(0), syscall_handler will halt
    jump_to_userspace(user_entry, user_stack_top)

    # We should NOT reach here - exit() halts the system
    prints("  Returned from userspace unexpectedly!\n")

    # Cleanup (shouldn't happen)
    vmm_unmap_page(user_code_vaddr)
    vmm_unmap_page(user_stack_vaddr)
    pmm_free_page(user_stack_page)
    pmm_free_page(user_code_page)

    return 0

# Get the current CPU's scheduler state
fn get_cpu_sched() -> *CpuSched
    let cpu_id: u32 = lapic_id()
    # Find the CPU in our list by APIC ID
    var i: i32 = 0
    while i < num_cpus as i32
        if cpu_apic_ids[i] == cpu_id as u8
            return @cpu_sched[i]
        i = i + 1
    # Fallback to CPU 0 if not found
    return @cpu_sched[0]

# Schedule next task (called from timer interrupt or yield)
pub fn schedule() -> i32
    if scheduler_initialized == 0
        return 0

    sched_lock()

    let cpu: *CpuSched = get_cpu_sched()
    let old_task_idx: u32 = (*cpu).current_task

    # If we have a current task, save it and put it back on ready queue
    if old_task_idx != 0xFFFFFFFF
        let old_task: *Task = @tasks[old_task_idx as i32]
        if (*old_task).state == TASK_STATE_RUNNING
            (*old_task).state = TASK_STATE_READY
            ready_queue_push(old_task_idx)

    # Get next task from ready queue
    let new_task_idx: u32 = ready_queue_pop()

    if new_task_idx == 0xFFFFFFFF
        # No tasks ready - run idle task
        (*cpu).current_task = (*cpu).idle_task
        let idle: *Task = @tasks[(*cpu).idle_task as i32]
        (*idle).state = TASK_STATE_RUNNING

        sched_unlock()

        # If switching from a real task to idle, do context switch
        if old_task_idx != 0xFFFFFFFF && old_task_idx != (*cpu).idle_task
            let old_ctx: *CpuContext = @(tasks[old_task_idx as i32].context)
            let new_ctx: *CpuContext = @((*idle).context)
            context_switch(old_ctx, new_ctx)

        return 0

    # Switch to new task
    let new_task: *Task = @tasks[new_task_idx as i32]
    (*new_task).state = TASK_STATE_RUNNING
    (*new_task).cpu_id = (*cpu).cpu_id
    (*cpu).current_task = new_task_idx

    sched_unlock()

    # Perform context switch if task actually changed
    if old_task_idx != new_task_idx
        if old_task_idx == 0xFFFFFFFF
            # First switch - no old context to save, just restore new
            let new_ctx: *CpuContext = @((*new_task).context)
            # Jump to new task (special case - no old context)
            asm x86_64:
                movq {new_ctx}, %rdi
                movq 48(%rdi), %rsp        # Restore RSP
                movq 64(%rdi), %rax        # Get RFLAGS
                pushq %rax
                popfq                       # Restore RFLAGS
                movq 0(%rdi), %rbx
                movq 8(%rdi), %rbp
                movq 16(%rdi), %r12
                movq 24(%rdi), %r13
                movq 32(%rdi), %r14
                movq 40(%rdi), %r15
                movq 56(%rdi), %rax        # Get RIP
                jmpq *%rax                  # Jump to task
        else
            let old_ctx: *CpuContext = @(tasks[old_task_idx as i32].context)
            let new_ctx: *CpuContext = @((*new_task).context)
            context_switch(old_ctx, new_ctx)

    return 0

# Yield current task
pub fn yield_task() -> i32
    schedule()
    return 0

# Idle task function (one per CPU)
fn idle_task_func() -> i32
    while true
        asm x86_64:
            sti
            hlt
    return 0

# Create idle task for a CPU
fn create_idle_task(cpu_idx: i32) -> i32
    sched_lock()

    let task_idx: u32 = task_count
    task_count = task_count + 1

    let task: *Task = @tasks[task_idx as i32]

    (*task).id = 0  # Idle tasks have ID 0
    (*task).state = TASK_STATE_READY
    (*task).cpu_id = cpu_idx as u8
    (*task).priority = 0  # Lowest priority

    # Name: "idle-N"
    (*task).name[0] = 105  # 'i'
    (*task).name[1] = 100  # 'd'
    (*task).name[2] = 108  # 'l'
    (*task).name[3] = 101  # 'e'
    (*task).name[4] = 45   # '-'
    (*task).name[5] = (48 + cpu_idx) as u8  # '0' + cpu_idx
    (*task).name[6] = 0

    # Allocate stack based on CPU
    var stack_top: u64 = 0
    if cpu_idx == 0
        # Allocate a page for BSP idle task stack
        let stack_phys: u64 = pmm_alloc_page()
        (*task).stack_base = stack_phys
        (*task).stack_size = PAGE_SIZE
        stack_top = stack_phys + PAGE_SIZE
    else
        # For APs, use their bootstrap stacks
        stack_top = (@ap_stacks[(cpu_idx - 1) as i32][0] as u64) + 4096
        (*task).stack_base = stack_top - 4096
        (*task).stack_size = 4096

    task_init_context(task, idle_task_func as u64, stack_top)

    cpu_sched[cpu_idx].idle_task = task_idx
    cpu_sched[cpu_idx].cpu_id = cpu_idx as u8
    cpu_sched[cpu_idx].current_task = 0xFFFFFFFF

    sched_unlock()

    return task_idx as i32

# Timer interrupt handler (vector 32)
pub fn timer_handler() -> i32
    # Acknowledge interrupt
    lapic_eoi()

    # Trigger scheduler
    schedule()

    return 0

# Configure APIC timer for scheduler
fn apic_timer_init(cpu_idx: i32) -> i32
    # Set timer divider
    lapic_write(LAPIC_TIMER_DIVIDE, 3)  # Divide by 16

    # Configure timer: periodic mode, vector 32 (IRQ 0)
    let timer_config: u32 = LAPIC_TIMER_PERIODIC | LAPIC_TIMER_VECTOR
    lapic_write(LAPIC_TIMER, timer_config)

    # Set initial count (determines frequency)
    lapic_write(LAPIC_TIMER_INITIAL, TIMER_INITIAL_COUNT)

    prints("      APIC timer configured for CPU ")
    serial_print_dec(cpu_idx as u64)
    prints("\n")

    return 0

# Initialize scheduler
pub fn scheduler_init() -> i32
    prints("  [..] Scheduler\n")

    # Initialize task array
    var i: i32 = 0
    while i < MAX_TASKS
        tasks[i].id = 0
        tasks[i].state = TASK_STATE_DEAD
        i = i + 1

    # Initialize CPU scheduler state
    i = 0
    while i < MAX_CPUS
        cpu_sched[i].cpu_id = i as u8
        cpu_sched[i].current_task = 0xFFFFFFFF
        cpu_sched[i].idle_task = 0
        i = i + 1

    # Create idle task for BSP
    create_idle_task(0)

    # Create idle tasks for APs
    i = 1
    while i < num_cpus as i32
        create_idle_task(i)
        i = i + 1

    prints("      Created ")
    serial_print_dec(num_cpus as u64)
    prints(" idle tasks\n")

    # Configure APIC timer on BSP
    apic_timer_init(0)

    scheduler_initialized = 1
    prints("\r  [OK] Scheduler\n")

    return 0

# Test task function 1
fn test_task_a() -> i32
    var count: i32 = 0
    while count < 5
        prints("[Task A] count=")
        serial_print_dec(count as u64)
        prints("\n")
        count = count + 1

        # Yield to other tasks
        yield_task()

    prints("[Task A] done!\n")

    # Mark ourselves as dead
    let cpu: *CpuSched = get_cpu_sched()
    let task: *Task = @tasks[(*cpu).current_task as i32]
    (*task).state = TASK_STATE_DEAD

    # Final yield (won't return)
    while true
        yield_task()

    return 0

# Test task function 2
fn test_task_b() -> i32
    var count: i32 = 0
    while count < 5
        prints("[Task B] count=")
        serial_print_dec(count as u64)
        prints("\n")
        count = count + 1

        yield_task()

    prints("[Task B] done!\n")

    let cpu: *CpuSched = get_cpu_sched()
    let task: *Task = @tasks[(*cpu).current_task as i32]
    (*task).state = TASK_STATE_DEAD

    while true
        yield_task()

    return 0

# Test task function 3
fn test_task_c() -> i32
    var count: i32 = 0
    while count < 5
        prints("[Task C] count=")
        serial_print_dec(count as u64)
        prints("\n")
        count = count + 1

        yield_task()

    prints("[Task C] done!\n")

    let cpu: *CpuSched = get_cpu_sched()
    let task: *Task = @tasks[(*cpu).current_task as i32]
    (*task).state = TASK_STATE_DEAD

    while true
        yield_task()

    return 0

# ============================================================================
# Kernel Entry Point
# ============================================================================

pub fn kernel_main(boot_info_addr: u64) -> i32
    # Initialize serial for early debug output
    serial_init()

    # Clear ring buffer for fresh boot log
    ring_clear()

    # Banner (use klog to capture in ring buffer)
    klog(c"\n")
    klog(c"========================================\n")
    klog(c"    Hello from Harland!\n")
    klog(c"========================================\n")
    klog(c"\n")

    klog(c"Harland kernel starting...\n")

    # Detect boot protocol by checking magic value
    # Harland boot info starts with magic 0x4841524C ("HARL")
    # Multiboot2 starts with total_size (small 32-bit value)
    prints("Boot info at: ")
    serial_print_hex(boot_info_addr)
    prints("\n")

    var has_boot_info: bool = false

    if boot_info_addr != 0
        let potential_magic: *u32 = boot_info_addr as *u32
        if *potential_magic == HARLAND_BOOT_MAGIC
            boot_protocol = BOOT_PROTOCOL_HARLAND
            harland_boot_info = boot_info_addr as *HarlandBootInfo
            prints("Boot protocol: Harland (UEFI)\n")
            has_boot_info = true
        else
            boot_protocol = BOOT_PROTOCOL_MULTIBOOT2
            prints("Boot protocol: Multiboot2 (BIOS/GRUB)\n")
            has_boot_info = true
    else
        boot_protocol = BOOT_PROTOCOL_UNKNOWN
        prints("Boot protocol: Unknown (no boot info)\n")

    # Initialize GDT
    klog(c"\nInitialization:\n")
    klog(c"  [..] GDT")
    gdt_init()
    klog(c"\r  [OK] GDT\n")

    # Remap PIC temporarily (will be replaced by APIC later)
    pic_remap()

    # Initialize IDT
    klog(c"  [..] IDT")
    idt_init()
    klog(c"\r  [OK] IDT\n")

    # Initialize Physical Memory Manager based on boot protocol
    klog(c"  [..] Physical memory")
    if boot_protocol == BOOT_PROTOCOL_HARLAND
        pmm_init_from_bootinfo(harland_boot_info)
        pmm_reserve_kernel()
        klog(c"\r  [OK] Physical memory\n")
    else if boot_protocol == BOOT_PROTOCOL_MULTIBOOT2
        let mb_info: *Mb2BootInfo = boot_info_addr as *Mb2BootInfo
        pmm_init_from_multiboot(mb_info)
        pmm_reserve_kernel()
        klog(c"\r  [OK] Physical memory\n")
    else
        klog(c"\r  [!!] Physical memory (no boot info)\n")

    if has_boot_info
        # Print memory statistics
        prints("      Total pages: ")
        serial_print_dec(pmm_get_total_pages())
        prints(" (")
        let total_mb: u64 = (pmm_get_total_pages() * 4) / 1024
        serial_print_dec(total_mb)
        prints(" MB)\n")

        prints("      Free pages:  ")
        serial_print_dec(pmm_get_free_pages())
        prints(" (")
        let free_mb: u64 = (pmm_get_free_pages() * 4) / 1024
        serial_print_dec(free_mb)
        prints(" MB)\n")

    # Initialize Virtual Memory Manager
    klog(c"  [..] Virtual memory")
    vmm_init()
    klog(c"\r  [OK] Virtual memory\n")
    prints("      PML4 at: ")
    serial_print_hex(vmm_pml4_phys)
    prints("\n")

    # Initialize Kernel Heap
    klog(c"  [..] Kernel heap")
    let heap_result: i32 = heap_init(4)
    if heap_result == 0
        klog(c"\r  [OK] Kernel heap\n")
        prints("      Initial size: ")
        serial_print_dec(heap_get_used())
        prints(" bytes (")
        serial_print_dec(heap_get_used() / 1024)
        prints(" KB)\n")
    else
        klog(c"\r  [!!] Kernel heap (init failed)\n")

    # Initialize APIC based on boot protocol
    if boot_protocol == BOOT_PROTOCOL_HARLAND
        apic_init_from_bootinfo(harland_boot_info)

        # Boot Application Processors (APs)
        if num_cpus > 1
            ap_boot_all()
    else if boot_protocol == BOOT_PROTOCOL_MULTIBOOT2
        let mb_info: *Mb2BootInfo = boot_info_addr as *Mb2BootInfo
        apic_init_with_mb(mb_info)

        # Boot Application Processors (APs)
        if num_cpus > 1
            ap_boot_all()

    # Initialize scheduler
    scheduler_init()

    # Test VMM operations
    if has_boot_info
        prints("\nTesting Virtual Memory...\n")

        # Verify identity mapping for kernel
        let test_vaddr: u64 = 0x100000
        let resolved: u64 = vmm_virt_to_phys(test_vaddr)
        prints("  virt_to_phys(0x100000) = ")
        serial_print_hex(resolved)
        prints("\n")

        # Allocate a new page and map it at a high address
        let new_page: u64 = pmm_alloc_page()
        prints("  Allocated page: ")
        serial_print_hex(new_page)
        prints("\n")

        # Map at a test virtual address in higher-half kernel space
        # Using address past the 1GB pre-mapped region (which uses 2MB huge pages)
        let test_map_vaddr: u64 = 0xFFFFFFFFD0000000
        let map_result: i32 = vmm_map_page(test_map_vaddr, new_page, PTE_WRITABLE)
        prints("  Map 0xFFFFFFFFD0000000 -> result: ")
        serial_print_dec(map_result as u64)
        prints("\n")

        if map_result == 0
            # Verify the mapping
            let verify_phys: u64 = vmm_virt_to_phys(test_map_vaddr)
            prints("  virt_to_phys(0xFFFFFFFFD0000000) = ")
            serial_print_hex(verify_phys)
            prints("\n")

            # Write to the mapped page (via identity-mapped physical address)
            let data_ptr: *u64 = new_page as *u64
            *data_ptr = 0xDEADBEEFCAFEBABE

            # Read via the new virtual mapping
            let mapped_ptr: *u64 = test_map_vaddr as *u64
            let read_val: u64 = *mapped_ptr
            prints("  Wrote 0xDEADBEEFCAFEBABE, read: ")
            serial_print_hex(read_val)
            prints("\n")

            if read_val == 0xDEADBEEFCAFEBABE
                prints("  VMM test PASSED!\n")
            else
                prints("  VMM test FAILED!\n")

            # Unmap and free
            vmm_unmap_page(test_map_vaddr)
            pmm_free_page(new_page)
        else
            prints("  Mapping failed!\n")

        # Test higher-half mapping
        prints("\nTesting Higher-Half Mapping...\n")

        # The kernel physical address 0x100000 should also be accessible
        # at virtual address 0xFFFFFFFF80100000 (higher-half)
        let kernel_virt_base: u64 = 0xFFFFFFFF80000000
        let kernel_phys: u64 = 0x100000
        let hh_vaddr: u64 = kernel_virt_base + kernel_phys

        # Read from physical address (identity mapped)
        let phys_ptr: *u64 = kernel_phys as *u64
        let phys_val: u64 = *phys_ptr

        # Read from higher-half virtual address
        let hh_ptr: *u64 = hh_vaddr as *u64
        let hh_val: u64 = *hh_ptr

        prints("  Read from 0x100000: ")
        serial_print_hex(phys_val)
        prints("\n")
        prints("  Read from 0xFFFFFFFF80100000: ")
        serial_print_hex(hh_val)
        prints("\n")

        if phys_val == hh_val
            prints("  Higher-half mapping PASSED!\n")
        else
            prints("  Higher-half mapping FAILED!\n")

        # Test heap allocations
        prints("\nTesting Kernel Heap...\n")

        let alloc1: *u8 = kalloc(64)
        prints("  kalloc(64) = ")
        serial_print_hex(alloc1 as u64)
        prints("\n")

        let alloc2: *u8 = kalloc(128)
        prints("  kalloc(128) = ")
        serial_print_hex(alloc2 as u64)
        prints("\n")

        let alloc3: *u8 = kalloc(256)
        prints("  kalloc(256) = ")
        serial_print_hex(alloc3 as u64)
        prints("\n")

        prints("  Free space: ")
        serial_print_dec(heap_get_free())
        prints(" bytes\n")

        # Write to allocated memory
        let test_ptr: *u64 = alloc1 as *u64
        *test_ptr = 0x1234567890ABCDEF
        let read_back: u64 = *test_ptr
        prints("  Write/read test: ")
        serial_print_hex(read_back)
        prints("\n")

        # Free middle allocation
        kfree(alloc2)
        prints("  Freed alloc2\n")
        prints("  Free space: ")
        serial_print_dec(heap_get_free())
        prints(" bytes\n")

        # Reallocate should reuse freed block
        let alloc4: *u8 = kalloc(100)
        prints("  kalloc(100) = ")
        serial_print_hex(alloc4 as u64)
        prints("\n")

        if read_back == 0x1234567890ABCDEF
            prints("  Heap test PASSED!\n")
        else
            prints("  Heap test FAILED!\n")

        # Cleanup
        kfree(alloc1)
        kfree(alloc3)
        kfree(alloc4)

    prints("\nKernel initialized successfully.\n")

    # Initialize syscall interface
    prints("\n  [..] Syscall interface")
    syscall_init()
    prints("\r  [OK] Syscall interface\n")

    # Test userspace execution
    prints("\nTesting Userspace...\n")
    test_userspace()

    # Test scheduler with some tasks
    prints("\nTesting Scheduler...\n")
    prints("  Creating test tasks...\n")

    let task_a: i32 = task_create(c"task-a", test_task_a as u64)
    prints("    Created Task A (ID=")
    serial_print_dec(task_a as u64)
    prints(")\n")

    let task_b: i32 = task_create(c"task-b", test_task_b as u64)
    prints("    Created Task B (ID=")
    serial_print_dec(task_b as u64)
    prints(")\n")

    let task_c: i32 = task_create(c"task-c", test_task_c as u64)
    prints("    Created Task C (ID=")
    serial_print_dec(task_c as u64)
    prints(")\n")

    prints("  Starting scheduler...\n\n")

    # Enable interrupts and start scheduling
    enable_interrupts()

    # Enter scheduler - this starts running tasks
    schedule()

    # We should only get here when all tasks are done
    prints("\nAll tasks completed!\n")
    prints("Scheduler test PASSED!\n")

    halt_loop()
    return 0
