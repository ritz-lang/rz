# ============================================================================
# Capability System Test
# ============================================================================
#
# Tests the capability table operations.

fn test_capability_system() -> i32
    # Allocate a capability table for PID 1 (kernel)
    let table: *CapTable = cap_table_alloc(1)
    if table == 0 as *CapTable
        prints("  FAILED: Could not allocate capability table\n")
        return -1

    prints("  [1] Allocated capability table for PID 1\n")

    # Insert a memory capability
    let mem_handle: CapHandle = cap_table_insert(table, CAP_TYPE_MEMORY, CAP_RIGHT_READ | CAP_RIGHT_WRITE | CAP_RIGHT_GRANT, 0x100000)
    let mem_idx: u32 = mem_handle.index
    let mem_gen: u32 = mem_handle.generation

    if mem_idx == 0xFFFFFFFF
        prints("  FAILED: Could not insert memory capability\n")
        return -1

    prints("  [2] Inserted memory capability: handle=")
    serial_print_dec(mem_idx as u64)
    prints(", gen=")
    serial_print_dec(mem_gen as u64)
    prints("\n")

    # Insert a channel capability
    let chan_handle: CapHandle = cap_table_insert(table, CAP_TYPE_CHANNEL, CAP_RIGHT_SEND | CAP_RIGHT_RECV | CAP_RIGHT_DERIVE, 1)
    let chan_idx: u32 = chan_handle.index
    let chan_gen: u32 = chan_handle.generation

    if chan_idx == 0xFFFFFFFF
        prints("  FAILED: Could not insert channel capability\n")
        return -1

    prints("  [3] Inserted channel capability: handle=")
    serial_print_dec(chan_idx as u64)
    prints(", gen=")
    serial_print_dec(chan_gen as u64)
    prints("\n")

    # Look up the memory capability
    var lookup_handle: CapHandle
    lookup_handle.index = mem_idx
    lookup_handle.generation = mem_gen

    let entry: *CapEntry = cap_table_lookup(table, lookup_handle)
    if entry == 0 as *CapEntry
        prints("  FAILED: Could not look up memory capability\n")
        return -1

    prints("  [4] Looked up memory cap: type=")
    serial_print_dec((*entry).cap_type as u64)
    prints(", rights=")
    serial_print_hex((*entry).rights as u64)
    prints(", object_id=")
    serial_print_hex((*entry).object_id)
    prints("\n")

    # Check rights
    var check_handle: CapHandle
    check_handle.index = mem_idx
    check_handle.generation = mem_gen

    let has_rw: bool = cap_has_rights(table, check_handle, CAP_RIGHT_READ | CAP_RIGHT_WRITE)

    var check_handle2: CapHandle
    check_handle2.index = mem_idx
    check_handle2.generation = mem_gen

    let has_exec: bool = cap_has_rights(table, check_handle2, CAP_RIGHT_EXECUTE)

    prints("  [5] Rights check: has READ|WRITE=")
    if has_rw
        prints("yes")
    else
        prints("no")
    prints(", has EXECUTE=")
    if has_exec
        prints("yes")
    else
        prints("no")
    prints("\n")

    if not has_rw or has_exec
        prints("  FAILED: Rights check incorrect\n")
        return -1

    # Derive a read-only capability from the memory cap
    var derive_handle: CapHandle
    derive_handle.index = mem_idx
    derive_handle.generation = mem_gen

    # Need to add DERIVE right first - the mem_handle has GRANT but not DERIVE
    # So let's test with a capability that has DERIVE right
    let derive_cap: CapHandle = cap_table_insert(table, CAP_TYPE_MEMORY, CAP_RIGHT_READ | CAP_RIGHT_WRITE | CAP_RIGHT_DERIVE, 0x200000)
    let derive_cap_idx: u32 = derive_cap.index
    let derive_cap_gen: u32 = derive_cap.generation

    var derive_src: CapHandle
    derive_src.index = derive_cap_idx
    derive_src.generation = derive_cap_gen

    let derived: CapHandle = cap_table_derive(table, derive_src, CAP_RIGHT_READ)
    let derived_idx: u32 = derived.index
    let derived_gen: u32 = derived.generation

    if derived_idx == 0xFFFFFFFF
        prints("  [6] Derive test skipped (DERIVE right required)\n")
    else
        prints("  [6] Derived read-only capability: handle=")
        serial_print_dec(derived_idx as u64)
        prints(", gen=")
        serial_print_dec(derived_gen as u64)
        prints("\n")

        # Verify derived cap has only READ
        var derived_lookup: CapHandle
        derived_lookup.index = derived_idx
        derived_lookup.generation = derived_gen

        let derived_entry: *CapEntry = cap_table_lookup(table, derived_lookup)
        if derived_entry != 0 as *CapEntry
            prints("  [7] Derived cap rights=")
            serial_print_hex((*derived_entry).rights as u64)
            prints(" (should be 0x1 = READ only)\n")

    # Remove a capability
    var remove_handle: CapHandle
    remove_handle.index = chan_idx
    remove_handle.generation = chan_gen

    let remove_result: i32 = cap_table_remove(table, remove_handle)
    if remove_result != 0
        prints("  FAILED: Could not remove capability\n")
        return -1

    prints("  [8] Removed channel capability\n")

    # Verify it's gone
    var stale_handle: CapHandle
    stale_handle.index = chan_idx
    stale_handle.generation = chan_gen

    let stale_entry: *CapEntry = cap_table_lookup(table, stale_handle)
    if stale_entry != 0 as *CapEntry
        prints("  FAILED: Removed capability still exists\n")
        return -1

    prints("  [9] Verified capability was removed\n")

    # Free the table
    cap_table_free(table)
    prints("  [10] Freed capability table\n")

    cap_system_debug_print()

    prints("  Capability test PASSED!\n")
    return 0

# ============================================================================
# Filesystem Quick Test
# ============================================================================

fn fs_quick_test() -> i32
    prints("\n  Testing filesystem...\n")

    let ns: *fs.knamespace.KNamespace = knamespace_get()
    if ns == 0 as *fs.knamespace.KNamespace
        prints("    FAIL: No namespace\n")
        return -1

    # Test 1: Create a directory
    let mkdir_path: StrView = "/test" as StrView
    let mkdir_result: i32 = knamespace_mkdir(ns, @mkdir_path)
    if mkdir_result == KNS_OK
        prints("    [OK] mkdir /test\n")
    else
        prints("    [!!] mkdir /test failed\n")

    # Test 2: Create a file
    var test_data: [12]u8
    test_data[0] = 72   # H
    test_data[1] = 101  # e
    test_data[2] = 108  # l
    test_data[3] = 108  # l
    test_data[4] = 111  # o
    test_data[5] = 32   # (space)
    test_data[6] = 70   # F
    test_data[7] = 83   # S
    test_data[8] = 33   # !
    test_data[9] = 10   # \n
    test_data[10] = 0

    let write_path: StrView = "/test/hello.txt" as StrView
    let write_result: i32 = knamespace_write(ns, @write_path, @test_data[0], 10)
    if write_result == KNS_OK
        prints("    [OK] write /test/hello.txt\n")
    else
        prints("    [!!] write /test/hello.txt failed\n")

    # Test 3: Check file exists
    if knamespace_exists(ns, @write_path)
        prints("    [OK] exists /test/hello.txt\n")
    else
        prints("    [!!] exists /test/hello.txt failed\n")

    # Test 4: Read file back
    var read_size: u64 = 0
    let read_data: *u8 = knamespace_read(ns, @write_path, @read_size)
    if read_data != 0 as *u8 and read_size == 10
        prints("    [OK] read /test/hello.txt (")
        serial_print_dec(read_size)
        prints(" bytes)\n")
        # Verify content
        var content_ok: u8 = 1
        var i: u64 = 0
        while i < read_size
            if *(read_data + i) != test_data[i]
                content_ok = 0
                break
            i = i + 1
        if content_ok != 0
            prints("    [OK] content verified\n")
        else
            prints("    [!!] content mismatch\n")
    else
        prints("    [!!] read /test/hello.txt failed\n")

    prints("  Filesystem test complete.\n")
    0

# ============================================================================
# Kernel Entry Point
# ============================================================================

pub fn kernel_main(boot_info_addr: u64) -> i32
    # Initialize serial for early debug output
    serial_init()

    # Clear ring buffer for fresh boot log
    ring_clear()

    # Banner (use klog to capture in ring buffer)
    klog(c"\n")
    klog(c"========================================\n")
    klog(c"    Hello from Harland!\n")
    klog(c"========================================\n")
    klog(c"\n")

    klog(c"Harland kernel starting...\n")

    # Detect boot protocol by checking magic value
    # Harland boot info starts with magic 0x4841524C ("HARL")
    # Multiboot2 starts with total_size (small 32-bit value)
    prints("Boot info at: ")
    serial_print_hex(boot_info_addr)
    prints("\n")

    var has_boot_info: bool = false

    if boot_info_addr != 0
        let potential_magic: *u32 = boot_info_addr as *u32
        if *potential_magic == HARLAND_BOOT_MAGIC
            boot_protocol = BOOT_PROTOCOL_HARLAND
            harland_boot_info = boot_info_addr as *HarlandBootInfo
            prints("Boot protocol: Harland (UEFI)\n")
            has_boot_info = true
        else
            boot_protocol = BOOT_PROTOCOL_MULTIBOOT2
            prints("Boot protocol: Multiboot2 (BIOS/GRUB)\n")
            has_boot_info = true
    else
        boot_protocol = BOOT_PROTOCOL_UNKNOWN
        prints("Boot protocol: Unknown (no boot info)\n")

    # Initialize GDT
    klog(c"\nInitialization:\n")
    klog(c"  [..] GDT")
    gdt_init()
    klog(c"\r  [OK] GDT\n")

    # Remap PIC temporarily (will be replaced by APIC later)
    pic_remap()

    # Initialize IDT
    klog(c"  [..] IDT")
    idt_init()
    klog(c"\r  [OK] IDT\n")

    # Initialize Physical Memory Manager based on boot protocol
    klog(c"  [..] Physical memory")
    if boot_protocol == BOOT_PROTOCOL_HARLAND
        pmm_init_from_bootinfo(harland_boot_info)
        pmm_reserve_kernel()
        klog(c"\r  [OK] Physical memory\n")
    else if boot_protocol == BOOT_PROTOCOL_MULTIBOOT2
        let mb_info: *Mb2BootInfo = boot_info_addr as *Mb2BootInfo
        pmm_init_from_multiboot(mb_info)
        pmm_reserve_kernel()
        klog(c"\r  [OK] Physical memory\n")
    else
        klog(c"\r  [!!] Physical memory (no boot info)\n")

    if has_boot_info
        # Print memory statistics
        prints("      Total pages: ")
        serial_print_dec(pmm_get_total_pages())
        prints(" (")
        let total_mb: u64 = (pmm_get_total_pages() * 4) / 1024
        serial_print_dec(total_mb)
        prints(" MB)\n")

        prints("      Free pages:  ")
        serial_print_dec(pmm_get_free_pages())
        prints(" (")
        let free_mb: u64 = (pmm_get_free_pages() * 4) / 1024
        serial_print_dec(free_mb)
        prints(" MB)\n")

    # Initialize Virtual Memory Manager
    klog(c"  [..] Virtual memory")
    vmm_init()
    klog(c"\r  [OK] Virtual memory\n")
    prints("      PML4 at: ")
    serial_print_hex(vmm_pml4_phys)
    prints("\n")

    # Initialize Kernel Heap
    klog(c"  [..] Kernel heap")
    let heap_result: i32 = heap_init(16384)  # 64MB heap (content-addressed FS needs space for version history)
    if heap_result == 0
        klog(c"\r  [OK] Kernel heap\n")
        prints("      Size: ")
        serial_print_dec(heap_get_used() / 1024)
        prints(" KB\n")
    else
        klog(c"\r  [!!] Kernel heap (init failed)\n")

    # Reserve all page table pages in PMM so they won't be reallocated
    # Must be after heap_init since heap creates new page table entries
    vmm_reserve_page_tables()

    # Initialize Kernel Filesystem Layer
    klog(c"  [..] Kernel blob store")
    kblob_init()
    klog(c"\r  [OK] Kernel blob store\n")

    klog(c"  [..] VFS layer")
    vfs_init()
    fd_table_init()
    klog(c"\r  [OK] VFS layer\n")

    # Initialize PCI early (needed for VirtIO block device)
    klog(c"  [..] PCI enumeration (early)")
    let pci_count_early: i32 = pci_init()
    klog(c"\r  [OK] PCI enumeration (early)\n")

    # Initialize VirtIO block device (needed for initramfs loading)
    klog(c"  [..] VirtIO block device")
    let early_blk_dev: *VirtioBlkDevice = virtio_blk_init()
    if early_blk_dev != 0 as *VirtioBlkDevice
        klog(c"\r  [OK] VirtIO block device\n")
    else
        klog(c"\r  [..] VirtIO block device (not found)\n")

    # Initialize kernel namespace (Goliath integration)
    klog(c"  [..] Kernel namespace")
    let kns_store: *fs.kblob.KBlobStore = kblob_get_store()
    if kns_store != 0 as *fs.kblob.KBlobStore
        knamespace_init(kns_store)
        klog(c"\r  [OK] Kernel namespace\n")

        # Initialize filesystem syscalls
        klog(c"  [..] Filesystem syscalls")
        fs_syscall_init()
        klog(c"\r  [OK] Filesystem syscalls\n")

        # Load initial filesystem
        # Now using disk-based TAR loading with 64MB heap
        klog(c"  [..] Initial filesystem")
        initramfs_load()
        klog(c"\r  [OK] Initial filesystem\n")

        # Test filesystem operations
        fs_quick_test()
    else
        klog(c"\r  [!!] Kernel namespace (no store)\n")

    # Initialize APIC based on boot protocol
    if boot_protocol == BOOT_PROTOCOL_HARLAND
        apic_init_from_bootinfo(harland_boot_info)

        # Boot Application Processors (APs)
        if num_cpus > 1
            ap_boot_all()
    else if boot_protocol == BOOT_PROTOCOL_MULTIBOOT2
        let mb_info: *Mb2BootInfo = boot_info_addr as *Mb2BootInfo
        apic_init_with_mb(mb_info)

        # Boot Application Processors (APs)
        if num_cpus > 1
            ap_boot_all()

    # Enable serial port receive interrupts (IRQ 4 already routed by ioapic_init)
    serial_enable_rx_interrupt()
    klog(c"  [OK] Serial input enabled\n")

    # Initialize IPC subsystem
    klog(c"  [..] IPC channels")
    channel_init()
    ipc_syscall_init()
    klog(c"\r  [OK] IPC channels\n")

    # Initialize capability subsystem
    klog(c"  [..] Capability tables")
    cap_table_init()
    klog(c"\r  [OK] Capability tables\n")

    # Note: SHM and DMA modules are WIP - skipped for now

    # Initialize scheduler
    scheduler_init()

    # Test VMM operations
    if has_boot_info
        prints("\nTesting Virtual Memory...\n")

        # Verify identity mapping for kernel
        let test_vaddr: u64 = 0x100000
        let resolved: u64 = vmm_virt_to_phys(test_vaddr)
        prints("  virt_to_phys(0x100000) = ")
        serial_print_hex(resolved)
        prints("\n")

        # Allocate a new page and map it at a high address
        let new_page: u64 = pmm_alloc_page()
        prints("  Allocated page: ")
        serial_print_hex(new_page)
        prints("\n")

        # Map at a test virtual address in higher-half kernel space
        # Using address past the 1GB pre-mapped region (which uses 2MB huge pages)
        let test_map_vaddr: u64 = 0xFFFFFFFFD0000000
        let map_result: i32 = vmm_map_page(test_map_vaddr, new_page, PTE_WRITABLE)
        prints("  Map 0xFFFFFFFFD0000000 -> result: ")
        serial_print_dec(map_result as u64)
        prints("\n")

        if map_result == 0
            # Verify the mapping
            let verify_phys: u64 = vmm_virt_to_phys(test_map_vaddr)
            prints("  virt_to_phys(0xFFFFFFFFD0000000) = ")
            serial_print_hex(verify_phys)
            prints("\n")

            # Write to the mapped page (via identity-mapped physical address)
            let data_ptr: *u64 = new_page as *u64
            *data_ptr = 0xDEADBEEFCAFEBABE

            # Read via the new virtual mapping
            let mapped_ptr: *u64 = test_map_vaddr as *u64
            let read_val: u64 = *mapped_ptr
            prints("  Wrote 0xDEADBEEFCAFEBABE, read: ")
            serial_print_hex(read_val)
            prints("\n")

            if read_val == 0xDEADBEEFCAFEBABE
                prints("  VMM test PASSED!\n")
            else
                prints("  VMM test FAILED!\n")

            # Unmap and free
            vmm_unmap_page(test_map_vaddr)
            pmm_free_page(new_page)
        else
            prints("  Mapping failed!\n")

        # Test higher-half mapping
        prints("\nTesting Higher-Half Mapping...\n")

        # The kernel physical address 0x100000 should also be accessible
        # at virtual address 0xFFFFFFFF80100000 (higher-half)
        let kernel_virt_base: u64 = 0xFFFFFFFF80000000
        let kernel_phys: u64 = 0x100000
        let hh_vaddr: u64 = kernel_virt_base + kernel_phys

        # Read from physical address (identity mapped)
        let phys_ptr: *u64 = kernel_phys as *u64
        let phys_val: u64 = *phys_ptr

        # Read from higher-half virtual address
        let hh_ptr: *u64 = hh_vaddr as *u64
        let hh_val: u64 = *hh_ptr

        prints("  Read from 0x100000: ")
        serial_print_hex(phys_val)
        prints("\n")
        prints("  Read from 0xFFFFFFFF80100000: ")
        serial_print_hex(hh_val)
        prints("\n")

        if phys_val == hh_val
            prints("  Higher-half mapping PASSED!\n")
        else
            prints("  Higher-half mapping FAILED!\n")

        # Test heap allocations
        prints("\nTesting Kernel Heap...\n")

        let alloc1: *u8 = kalloc(64)
        prints("  kalloc(64) = ")
        serial_print_hex(alloc1 as u64)
        prints("\n")

        let alloc2: *u8 = kalloc(128)
        prints("  kalloc(128) = ")
        serial_print_hex(alloc2 as u64)
        prints("\n")

        let alloc3: *u8 = kalloc(256)
        prints("  kalloc(256) = ")
        serial_print_hex(alloc3 as u64)
        prints("\n")

        prints("  Free space: ")
        serial_print_dec(heap_get_free())
        prints(" bytes\n")

        # Write to allocated memory
        let test_ptr: *u64 = alloc1 as *u64
        *test_ptr = 0x1234567890ABCDEF
        let read_back: u64 = *test_ptr
        prints("  Write/read test: ")
        serial_print_hex(read_back)
        prints("\n")

        # Free middle allocation
        kfree(alloc2)
        prints("  Freed alloc2\n")
        prints("  Free space: ")
        serial_print_dec(heap_get_free())
        prints(" bytes\n")

        # Reallocate should reuse freed block
        let alloc4: *u8 = kalloc(100)
        prints("  kalloc(100) = ")
        serial_print_hex(alloc4 as u64)
        prints("\n")

        if read_back == 0x1234567890ABCDEF
            prints("  Heap test PASSED!\n")
        else
            prints("  Heap test FAILED!\n")

        # Cleanup
        kfree(alloc1)
        kfree(alloc3)
        kfree(alloc4)

        # Test IPC channels
        prints("\nTesting IPC Channels...\n")
        prints("  [1] Creating channel...\n")

        # Create a channel pair
        let pair: ChannelPair = channel_create(1, 2)
        prints("  [2] Channel created\n")
        if pair.endpoint_a != 0 as *ChannelEndpoint
            prints("  Channel created, id=")
            serial_print_dec(pair.channel_id as u64)
            prints("\n")

            # Allocate message on heap (4KB struct is too big for stack)
            prints("  [3] Allocating send message on heap...\n")
            let send_msg: *Message = kalloc(4096) as *Message
            if send_msg == 0 as *Message
                prints("  Failed to allocate send_msg!\n")
            else
                # Initialize the message
                (*send_msg).header.msg_type = 42
                (*send_msg).header.flags = MSG_FLAG_NONE
                (*send_msg).header.seq = 0
                (*send_msg).header.payload_len = 10

                let payload_str: *u8 = c"Hello IPC!"
                var i: i32 = 0
                while i < 10
                    (*send_msg).payload[i] = *(payload_str + i as i64)
                    i = i + 1

                prints("  [4] Sending message...\n")
                let send_result: i32 = channel_send(pair.endpoint_a, send_msg, 1)
                prints("  Send result: ")
                serial_print_dec(send_result as u64)
                prints("\n")

                # Allocate receive buffer
                prints("  [5] Allocating recv message on heap...\n")
                let recv_msg: *Message = kalloc(4096) as *Message
                if recv_msg == 0 as *Message
                    prints("  Failed to allocate recv_msg!\n")
                else
                    var sender: u32 = 0
                    prints("  [6] Receiving message...\n")
                    let recv_result: i32 = channel_recv(pair.endpoint_b, recv_msg, @sender)
                    prints("  Recv result: ")
                    serial_print_dec(recv_result as u64)
                    prints(", msg_type=")
                    serial_print_dec((*recv_msg).header.msg_type as u64)
                    prints(", sender=")
                    serial_print_dec(sender as u64)
                    prints("\n")

                    # Check payload
                    prints("  Payload: ")
                    var k: i32 = 0
                    while k < (*recv_msg).header.payload_len as i32 and k < 20
                        serial_write_byte((*recv_msg).payload[k])
                        k = k + 1
                    prints("\n")

                    if (*recv_msg).header.msg_type == 42 and sender == 1
                        prints("  IPC test PASSED!\n")
                    else
                        prints("  IPC test FAILED!\n")

                    kfree(recv_msg as *u8)

                kfree(send_msg as *u8)

            # Close channels - skip for now due to page fault
            # channel_close(pair.endpoint_a)
            # channel_close(pair.endpoint_b)
            prints("  (channel close skipped)\n")
        else
            prints("  Channel creation failed!\n")

        # Note: channel_debug_print causes page fault - skipped for now
        # channel_debug_print()

    # Test capability system
    prints("\nTesting Capability System...\n")
    test_capability_system()

    prints("\nKernel initialized successfully.\n")

    # Uncomment to test exception handler with stack trace:
    # test_crash_page_fault()

    # Initialize syscall interface
    prints("\n  [..] Syscall interface")
    syscall_init()
    prints("\r  [OK] Syscall interface\n")

    # PCI already initialized early - just print discovered devices
    prints("\n=== PCI Devices ===\n")
    pci_print_all_devices()

    # Initialize network stack (includes VirtIO-net driver)
    prints("\n=== Initializing Network Stack ===\n")
    let net_result: i32 = net_stack_init()
    if net_result == 0
        prints("  Network stack ready!\n")

        # Start DHCP configuration
        prints("  Starting DHCP...\n")
        net_configure_dhcp()

        # Poll for packets until configured or timeout
        prints("  Polling for network packets...\n")
        var poll_count: i32 = 0
        var ping_sent: u8 = 0
        var arp_pending: u8 = 0
        while poll_count < 1000
            net_poll()
            poll_count = poll_count + 1

            # Small delay
            var delay: i32 = 0
            while delay < 100000
                delay = delay + 1

            # If we got configured, try a ping
            if net_is_configured() and ping_sent == 0 and poll_count >= 100
                if arp_pending == 0
                    prints("\n  Got IP! Pinging gateway...\n")
                let gateway: *u8 = ip_get_gateway()
                let ping_result: i32 = icmp_ping(gateway)
                if ping_result < 0
                    # ARP lookup needed, wait for ARP reply
                    arp_pending = 1
                else
                    ping_sent = 1
                    prints("  ICMP echo request sent!\n")

        if net_is_configured()
            prints("\n  Network configured!\n")
            ip_print_config()
        else
            prints("\n  DHCP timeout (no response in test window)\n")
    else
        prints("  Network stack initialization failed\n")

    # VirtIO Block device already initialized early (for initramfs loading)
    # Just run a test if it's available
    prints("\n=== VirtIO Block Device ===\n")
    let blk_dev: *VirtioBlkDevice = virtio_blk_get_device()
    if blk_dev != 0 as *VirtioBlkDevice
        prints("  (already initialized for initramfs)\n")
        # Run a basic read test to verify it's still working
        virtio_blk_test(blk_dev)
    else
        prints("  No VirtIO Block device found (add -drive to QEMU)\n")

    # Test ELF loader (validates structures and parsing)
    test_elf_loader()

    # Test userspace execution
    # First try loading the embedded Ritz ELF binary
    # If that's not available, fall back to raw assembly test
    prints("\nTesting Userspace...\n")

    let elf_data: *u8 = user_elf_start as *u8
    let elf_end: u64 = user_elf_end as u64
    let elf_size: u64 = elf_end - (elf_data as u64)

    if elf_size > 0
        prints("  Using embedded Ritz ELF binary\n")
        test_elf_userspace()
    else
        prints("  Using raw assembly test\n")
        test_userspace()

    # Test scheduler with some tasks
    prints("\nTesting Scheduler...\n")
    prints("  Creating test tasks...\n")

    let task_a: i32 = task_create(c"task-a", test_task_a as u64)
    prints("    Created Task A (ID=")
    serial_print_dec(task_a as u64)
    prints(")\n")

    let task_b: i32 = task_create(c"task-b", test_task_b as u64)
    prints("    Created Task B (ID=")
    serial_print_dec(task_b as u64)
    prints(")\n")

    let task_c: i32 = task_create(c"task-c", test_task_c as u64)
    prints("    Created Task C (ID=")
    serial_print_dec(task_c as u64)
    prints(")\n")

    prints("  Starting scheduler...\n\n")

    # Enable interrupts and start scheduling
    enable_interrupts()

    # Enter scheduler - this starts running tasks
    schedule()

    # We should only get here when all tasks are done
    prints("\nAll tasks completed!\n")
    prints("Scheduler test PASSED!\n")

    halt_loop()
    return 0
