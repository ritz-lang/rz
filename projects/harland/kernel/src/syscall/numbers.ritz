# Harland Syscall Numbers
#
# This is the SINGLE SOURCE OF TRUTH for all syscall numbers.
# All kernel subsystems should import from this file.
# DO NOT define syscall numbers anywhere else!
#
# Syscall numbering follows Linux conventions where practical,
# but diverges for Harland-specific syscalls.

# ============================================================================
# File Operations (0-19)
# ============================================================================

pub const SYS_READ: u64 = 0          # read(fd, buf, count) -> bytes_read
pub const SYS_WRITE: u64 = 1         # write(fd, buf, count) -> bytes_written
pub const SYS_OPEN: u64 = 2          # open(path, len, flags) -> fd
pub const SYS_CLOSE: u64 = 3         # close(fd) -> 0
pub const SYS_STAT: u64 = 4          # stat(path, buf) -> 0
pub const SYS_LSEEK: u64 = 8         # lseek(fd, offset, whence) -> position
pub const SYS_MMAP: u64 = 9          # mmap(addr, len, prot, flags) -> addr
pub const SYS_MUNMAP: u64 = 11       # munmap(addr, len) -> 0
pub const SYS_READDIR: u64 = 17      # readdir(path, buf, size) -> bytes

# ============================================================================
# Process Management (20-29)
# ============================================================================

pub const SYS_EXIT: u64 = 20         # exit(code) -> noreturn
pub const SYS_SPAWN: u64 = 21        # spawn(path) -> pid
pub const SYS_WAIT: u64 = 22         # wait(pid) -> exit_code
pub const SYS_GETPID: u64 = 23       # getpid() -> pid
pub const SYS_YIELD: u64 = 24        # yield() -> 0
pub const SYS_SPAWN_ARGS: u64 = 25   # spawn_args(path, argv, argc) -> pid
pub const SYS_GETCWD: u64 = 26       # getcwd(buf, size) -> len
pub const SYS_CHDIR: u64 = 27        # chdir(path) -> 0
pub const SYS_SPAWN_EX: u64 = 28     # spawn_ex(path, argv, argc, stdin, stdout) -> pid
pub const SYS_PIPE: u64 = 29         # pipe() -> packed_fds

# ============================================================================
# IPC - Inter-Process Communication (30-39)
# ============================================================================

pub const SYS_IPC_SEND: u64 = 30     # ipc_send(handle, msg) -> 0
pub const SYS_IPC_RECV: u64 = 31     # ipc_recv(handle, msg, sender) -> 0
pub const SYS_IPC_CALL: u64 = 32     # ipc_call(handle, msg) -> 0 (send+recv)
pub const SYS_IPC_CLOSE: u64 = 33    # ipc_close(handle) -> 0

# ============================================================================
# Capabilities (40-49)
# ============================================================================

pub const SYS_CAP_GRANT: u64 = 40    # cap_grant(handle, target, rights) -> new_handle
pub const SYS_CAP_REVOKE: u64 = 41   # cap_revoke(handle) -> 0
pub const SYS_CAP_DERIVE: u64 = 42   # cap_derive(handle, rights) -> new_handle
pub const SYS_CAP_INFO: u64 = 43     # cap_info(handle, info_buf) -> 0
pub const SYS_CAP_CHECK: u64 = 44    # cap_check(handle, rights) -> 0 or -1

# ============================================================================
# Input Devices (50-59)
# ============================================================================

pub const SYS_INPUT_POLL: u64 = 50   # input_poll() -> count
pub const SYS_INPUT_READ: u64 = 51   # input_read(event) -> 0 or -1

# ============================================================================
# Network (60-69)
# ============================================================================

pub const SYS_NET_INFO: u64 = 60     # net_info(info_buf) -> 0
pub const SYS_NET_PING: u64 = 61     # net_ping(ip_addr, seq, timeout) -> rtt_ms

# ============================================================================
# Filesystem Extended (80-89)
# ============================================================================

pub const SYS_MKDIR: u64 = 83        # mkdir(path, mode) -> 0

# ============================================================================
# Channels (100-109)
# ============================================================================

pub const SYS_CHANNEL_CREATE: u64 = 100  # channel_create() -> handle

# ============================================================================
# Hardware/Power Management (200-209)
# ============================================================================

pub const SYS_ACPI_POWEROFF: u64 = 200   # acpi_poweroff() -> noreturn

# ============================================================================
# Framebuffer/Graphics (210-219)
# ============================================================================

pub const SYS_FB_INFO: u64 = 210     # fb_info(info_buf) -> 0
pub const SYS_FB_MAP: u64 = 211      # fb_map() -> addr

# ============================================================================
# Debug (250-255)
# ============================================================================

pub const SYS_DEBUG_PRINT: u64 = 255 # debug_print(buf, len) -> len
