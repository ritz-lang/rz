# ============================================================================
# Page Table Setup
# ============================================================================

# Page table entry flags
PTE_PRESENT: u64 = 1 << 0
PTE_WRITABLE: u64 = 1 << 1
PTE_USER: u64 = 1 << 2
PTE_WRITE_THROUGH: u64 = 1 << 3
PTE_CACHE_DISABLE: u64 = 1 << 4
PTE_HUGE: u64 = 1 << 7

