# Harland Kernel - Stub Implementation
#
# This is a minimal kernel stub that compiles with the current ritz compiler.
# It uses extern declarations for functions that will need inline assembly.
# Once ritz supports `asm x86_64:` blocks, these will be replaced with
# actual implementations.

# ============================================================================
# External Assembly Functions (to be implemented in assembly)
# ============================================================================

# Port I/O - requires inline asm
extern fn outb(port: u16, value: u8)
extern fn inb(port: u16) -> u8
extern fn outw(port: u16, value: u16)
extern fn inw(port: u16) -> u16
extern fn outl(port: u32, value: u32)
extern fn inl(port: u32) -> u32

# CPU control - requires privileged instructions
extern fn halt()
extern fn enable_interrupts()
extern fn disable_interrupts()

# CR register access
extern fn read_cr0() -> u64
extern fn write_cr0(value: u64)
extern fn read_cr3() -> u64
extern fn write_cr3(value: u64)
extern fn read_cr4() -> u64
extern fn write_cr4(value: u64)

# MSR access
extern fn rdmsr(msr: u32) -> u64
extern fn wrmsr(msr: u32, value: u64)

# ============================================================================
# Boot Information Structures
# ============================================================================

# Note: @packed attribute not yet supported - these will need adjustment
# once we have proper packed struct support

struct BootInfo
    magic: u32                  # 0x4841524C "HARL"
    version: u32                # Boot protocol version
    memory_map: *MemoryMapEntry # Physical memory map
    memory_map_entries: u32     # Number of entries
    framebuffer: *Framebuffer   # Optional framebuffer
    initrd_start: u64           # Initial ramdisk physical address
    initrd_size: u64            # Initial ramdisk size
    kernel_phys: u64            # Kernel physical load address
    kernel_virt: u64            # Kernel virtual base address
    pml4_phys: u64              # Page table root physical address

struct MemoryMapEntry
    base: u64
    length: u64
    mem_type: u32               # 1=usable, 2=reserved, 3=ACPI, etc.
    reserved: u32

struct Framebuffer
    addr: u64
    width: u32
    height: u32
    pitch: u32      # Bytes per row
    bpp: u8         # Bits per pixel

# ============================================================================
# Serial Port Driver
# ============================================================================

const COM1: u16 = 0x3F8

fn serial_init() -> i32
    # Disable interrupts
    outb(COM1 + 1, 0x00)
    # Set baud rate divisor (115200 baud)
    outb(COM1 + 3, 0x80)    # Enable DLAB
    outb(COM1 + 0, 0x01)    # Divisor low byte
    outb(COM1 + 1, 0x00)    # Divisor high byte
    outb(COM1 + 3, 0x03)    # 8 bits, no parity, 1 stop
    outb(COM1 + 2, 0xC7)    # Enable FIFO
    outb(COM1 + 4, 0x0B)    # IRQs enabled, RTS/DSR set
    return 0

fn serial_write_byte(c: u8) -> i32
    # Wait for transmit buffer empty
    while (inb(COM1 + 5) & 0x20) == 0
        # spin - ritz needs a statement here
        let _ = 0
    outb(COM1, c)
    return 0

fn serial_print(s: *u8) -> i32
    var p: *u8 = s
    while *p != 0
        serial_write_byte(*p)
        p = p + 1
    return 0

fn serial_print_hex(value: u64) -> i32
    let digits: *u8 = c"0123456789ABCDEF"
    var i: i32 = 15
    while i >= 0
        let nibble: u8 = ((value >> (i * 4)) & 0xF) as u8
        serial_write_byte(*(digits + nibble as i64))
        i = i - 1
    return 0

# ============================================================================
# Kernel Entry Point
# ============================================================================

const BOOT_MAGIC: u32 = 0x4841524C  # "HARL"

pub fn kernel_main(boot_info: *BootInfo) -> i32
    # Validate boot magic
    if (*boot_info).magic != BOOT_MAGIC
        # Invalid boot info - just halt
        halt()
        return 1

    # Initialize serial for early debug output
    serial_init()
    serial_print(c"Harland kernel starting...\n")

    # Print boot info
    serial_print(c"  Boot magic: 0x")
    serial_print_hex((*boot_info).magic as u64)
    serial_print(c"\n")

    serial_print(c"  Memory map entries: ")
    serial_print_hex((*boot_info).memory_map_entries as u64)
    serial_print(c"\n")

    # Print initialization checklist
    serial_print(c"\nInitialization:\n")

    serial_print(c"  [  ] GDT\n")
    # gdt_init()

    serial_print(c"  [  ] IDT\n")
    # idt_init()

    serial_print(c"  [  ] Physical memory\n")
    # pmm_init(boot_info.memory_map, boot_info.memory_map_entries)

    serial_print(c"  [  ] Virtual memory\n")
    # vmm_init()

    serial_print(c"  [  ] Kernel heap\n")
    # heap_init()

    serial_print(c"  [  ] APIC\n")
    # apic_init()

    serial_print(c"  [  ] Scheduler\n")
    # scheduler_init()

    # Success!
    serial_print(c"\nHello from Harland!\n")
    serial_print(c"Kernel initialized. Halting.\n")

    halt()
    return 0
