# Harland Kernel - x86_64 CPU Control
#
# CPU control instructions using inline assembly.
# Includes halt, interrupts, and control register access.

# ============================================================================
# CPU Control
# ============================================================================

pub fn halt() -> i32
    asm x86_64:
        cli
        hlt
    return 0

pub fn halt_loop() -> i32
    # Infinite halt loop - cli then hlt in a Ritz loop
    # Note: Labels not yet supported in inline asm, so we use a while loop
    asm x86_64:
        cli
    while true
        asm x86_64:
            hlt
    return 0  # Never reached

pub fn enable_interrupts() -> i32
    asm x86_64:
        sti
    return 0

pub fn disable_interrupts() -> i32
    asm x86_64:
        cli
    return 0

pub fn pause() -> i32
    # CPU hint for spin-wait loops
    asm x86_64:
        pause
    return 0

# ============================================================================
# Control Register Access
# ============================================================================

pub fn read_cr0() -> u64
    var result: u64 = 0
    asm x86_64:
        movq %cr0, %rax
        movq %rax, {result}
    return result

pub fn write_cr0(value: u64) -> i32
    asm x86_64:
        movq {value}, %rax
        movq %rax, %cr0
    return 0

pub fn read_cr2() -> u64
    # CR2 contains the page fault linear address
    var result: u64 = 0
    asm x86_64:
        movq %cr2, %rax
        movq %rax, {result}
    return result

pub fn read_cr3() -> u64
    var result: u64 = 0
    asm x86_64:
        movq %cr3, %rax
        movq %rax, {result}
    return result

pub fn write_cr3(value: u64) -> i32
    asm x86_64:
        movq {value}, %rax
        movq %rax, %cr3
    return 0

pub fn read_cr4() -> u64
    var result: u64 = 0
    asm x86_64:
        movq %cr4, %rax
        movq %rax, {result}
    return result

pub fn write_cr4(value: u64) -> i32
    asm x86_64:
        movq {value}, %rax
        movq %rax, %cr4
    return 0

# ============================================================================
# Model Specific Registers (MSR)
# ============================================================================

pub fn rdmsr(msr: u32) -> u64
    var lo: u32 = 0
    var hi: u32 = 0
    asm x86_64:
        movl {msr}, %ecx
        rdmsr
        movl %eax, {lo}
        movl %edx, {hi}
    return (hi as u64 << 32) | (lo as u64)

pub fn wrmsr(msr: u32, value: u64) -> i32
    let lo: u32 = (value & 0xFFFFFFFF) as u32
    let hi: u32 = (value >> 32) as u32
    asm x86_64:
        movl {msr}, %ecx
        movl {lo}, %eax
        movl {hi}, %edx
        wrmsr
    return 0

# ============================================================================
# Descriptor Table Loading
# ============================================================================

pub fn lgdt(gdtr_ptr: u64) -> i32
    asm x86_64:
        movq {gdtr_ptr}, %rax
        lgdt (%rax)
    return 0

pub fn lidt(idtr_ptr: u64) -> i32
    asm x86_64:
        movq {idtr_ptr}, %rax
        lidt (%rax)
    return 0

pub fn ltr(selector: u16) -> i32
    asm x86_64:
        movw {selector}, %ax
        ltr %ax
    return 0
