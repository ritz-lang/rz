# test_args.ritz - Tests for argument parsing
#
# TDD: Write tests first, then implement.

import ritzlib.sys
import ritzlib.io
import ritzlib.str

# Test infrastructure
var g_passed: i32 = 0
var g_failed: i32 = 0

fn assert_eq(name: *u8, got: i32, expected: i32)
    if got == expected
        g_passed += 1
    else
        prints_cstr("FAIL: ")
        prints_cstr(name)
        prints_cstr(" - expected ")
        print_int(expected as i64)
        prints_cstr(", got ")
        print_int(got as i64)
        prints_cstr("\n")
        g_failed += 1

fn assert_streq(name: *u8, got: *u8, expected: *u8)
    if strcmp(got, expected) == 0
        g_passed += 1
    else
        prints_cstr("FAIL: ")
        prints_cstr(name)
        prints_cstr(" - expected '")
        prints_cstr(expected)
        prints_cstr("', got '")
        prints_cstr(got)
        prints_cstr("'\n")
        g_failed += 1

# ============================================================================
# Command Parsing Tests
# ============================================================================

# Command enum values (to be defined in main.ritz)
const CMD_NONE: i32 = 0
const CMD_BUILD: i32 = 1
const CMD_TEST: i32 = 2
const CMD_RUN: i32 = 3
const CMD_LIST: i32 = 4
const CMD_CLEAN: i32 = 5
const CMD_COMPARE: i32 = 6
const CMD_HELP: i32 = 7

[[test]]
fn test_parse_no_args() -> i32
    # With no arguments, should return CMD_HELP
    # Simulated: argc=1, argv=["rz"]
    let cmd: i32 = CMD_HELP  # Expected result
    assert_eq(c"no_args_returns_help", cmd, CMD_HELP)
    0

[[test]]
fn test_parse_build_command() -> i32
    # "rz build" should return CMD_BUILD
    let cmd: i32 = CMD_BUILD
    assert_eq(c"build_command", cmd, CMD_BUILD)
    0

[[test]]
fn test_parse_test_command() -> i32
    # "rz test" should return CMD_TEST
    let cmd: i32 = CMD_TEST
    assert_eq(c"test_command", cmd, CMD_TEST)
    0

[[test]]
fn test_parse_list_command() -> i32
    # "rz list" should return CMD_LIST
    let cmd: i32 = CMD_LIST
    assert_eq(c"list_command", cmd, CMD_LIST)
    0

# ============================================================================
# Main test runner
# ============================================================================

fn main(argc: i32, argv: **u8) -> i32
    prints_cstr("Running rz-cli argument parsing tests...\n\n")

    test_parse_no_args()
    test_parse_build_command()
    test_parse_test_command()
    test_parse_list_command()

    prints_cstr("\n")
    print_int(g_passed as i64)
    prints_cstr(" passed, ")
    print_int(g_failed as i64)
    prints_cstr(" failed\n")

    if g_failed > 0
        return 1
    0
