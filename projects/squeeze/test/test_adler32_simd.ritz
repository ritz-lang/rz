# test/test_adler32_simd.ritz - Tests for SIMD-accelerated Adler-32
#
# Verifies that adler32_simd produces identical results to scalar adler32.

import lib.adler32
import lib.adler32_simd
import ritzlib.sys

# ============================================================================
# Test helpers
# ============================================================================

fn arrays_equal(a: *u8, b: *u8, len: i64) -> bool
    for i in 0..len
        if a[i] != b[i]
            return false
    return true

# ============================================================================
# Tests
# ============================================================================

[[test]]
fn test_empty() -> i32
    var data: [1]u8
    data[0] = 0

    let scalar: u32 = adler32(@data[0], 0)
    let simd: u32 = adler32_simd(@data[0], 0)

    if scalar != simd
        return 1
    if scalar != 1  # Initial Adler-32 value
        return 2
    0

[[test]]
fn test_single_byte() -> i32
    var data: [1]u8
    data[0] = 0x41  # 'A'

    let scalar: u32 = adler32(@data[0], 1)
    let simd: u32 = adler32_simd(@data[0], 1)

    if scalar != simd
        return 1
    0

[[test]]
fn test_small_data() -> i32
    # "Hello" = 0x48 0x65 0x6c 0x6c 0x6f
    var data: [5]u8
    data[0] = 0x48
    data[1] = 0x65
    data[2] = 0x6c
    data[3] = 0x6c
    data[4] = 0x6f

    let scalar: u32 = adler32(@data[0], 5)
    let simd: u32 = adler32_simd(@data[0], 5)

    if scalar != simd
        return 1
    0

[[test]]
fn test_16_bytes() -> i32
    # Exactly one SIMD block
    var data: [16]u8
    for i in 0..16
        data[i] = (i + 1) as u8

    let scalar: u32 = adler32(@data[0], 16)
    let simd: u32 = adler32_simd(@data[0], 16)

    if scalar != simd
        return 1
    0

[[test]]
fn test_17_bytes() -> i32
    # One SIMD block + 1 scalar byte
    var data: [17]u8
    for i in 0..17
        data[i] = (i + 1) as u8

    let scalar: u32 = adler32(@data[0], 17)
    let simd: u32 = adler32_simd(@data[0], 17)

    if scalar != simd
        return 1
    0

[[test]]
fn test_32_bytes() -> i32
    # Two SIMD blocks
    var data: [32]u8
    for i in 0..32
        data[i] = (i * 3) as u8

    let scalar: u32 = adler32(@data[0], 32)
    let simd: u32 = adler32_simd(@data[0], 32)

    if scalar != simd
        return 1
    0

[[test]]
fn test_100_bytes() -> i32
    # Multiple SIMD blocks + remainder
    var data: [100]u8
    for i in 0..100
        data[i] = ((i * 7) & 0xFF) as u8

    let scalar: u32 = adler32(@data[0], 100)
    let simd: u32 = adler32_simd(@data[0], 100)

    if scalar != simd
        return 1
    0

[[test]]
fn test_all_zeros() -> i32
    var data: [64]u8
    for i in 0..64
        data[i] = 0

    let scalar: u32 = adler32(@data[0], 64)
    let simd: u32 = adler32_simd(@data[0], 64)

    if scalar != simd
        return 1
    0

[[test]]
fn test_all_ones() -> i32
    var data: [64]u8
    for i in 0..64
        data[i] = 0xFF

    let scalar: u32 = adler32(@data[0], 64)
    let simd: u32 = adler32_simd(@data[0], 64)

    if scalar != simd
        return 1
    0

[[test]]
fn test_streaming() -> i32
    # Test that streaming API matches one-shot
    var data: [48]u8
    for i in 0..48
        data[i] = (i + 10) as u8

    # One-shot
    let oneshot: u32 = adler32_simd(@data[0], 48)

    # Streaming in chunks
    var state: u32 = adler32_simd_init()
    state = adler32_simd_update(state, @data[0], 16)
    state = adler32_simd_update(state, @data[16], 16)
    state = adler32_simd_update(state, @data[32], 16)
    let streamed: u32 = adler32_simd_final(state)

    if oneshot != streamed
        return 1

    # Also verify against scalar
    let scalar: u32 = adler32(@data[0], 48)
    if scalar != oneshot
        return 2
    0
