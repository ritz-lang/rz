# test/test_adler32.ritz - Adler-32 checksum tests
#
# Tests for Adler-32 algorithm (RFC 1950 Appendix C):
# - Known test vectors
# - Streaming API (multi-chunk updates)
# - Edge cases (empty input, single byte)

import ritzlib.sys
import ritzlib.io

import lib.adler32


# ============================================================================
# Basic Tests
# ============================================================================

[[test]]
fn test_adler32_empty() -> i32
    # Empty input should return initial value: A=1, B=0 -> 0x00000001
    var input: [1]u8
    let result: u32 = adler32(@input[0], 0)

    if result != 0x00000001
        print("Expected 0x00000001, got 0x")
        print_hex_u32(result)
        print("\n")
        return 1

    return 0


[[test]]
fn test_adler32_single_byte_zero() -> i32
    # Single byte 0x00: A = 1 + 0 = 1, B = 1 -> 0x00010001
    var input: [1]u8 = [0x00]
    let result: u32 = adler32(@input[0], 1)

    if result != 0x00010001
        print("Expected 0x00010001, got 0x")
        print_hex_u32(result)
        print("\n")
        return 1

    return 0


[[test]]
fn test_adler32_single_byte_ff() -> i32
    # Single byte 0xFF: A = 1 + 255 = 256, B = 256 -> 0x01000100
    var input: [1]u8 = [0xFF]
    let result: u32 = adler32(@input[0], 1)

    if result != 0x01000100
        print("Expected 0x01000100, got 0x")
        print_hex_u32(result)
        print("\n")
        return 1

    return 0


[[test]]
fn test_adler32_wikipedia() -> i32
    # Wikipedia example: "Wikipedia" = 0x11E60398
    var input: [9]u8 = ['W', 'i', 'k', 'i', 'p', 'e', 'd', 'i', 'a']
    let result: u32 = adler32(@input[0], 9)

    if result != 0x11E60398
        print("Expected 0x11E60398, got 0x")
        print_hex_u32(result)
        print("\n")
        return 1

    return 0


[[test]]
fn test_adler32_hello() -> i32
    # "hello" - verified with Python: zlib.adler32(b"hello") = 0x062c0215
    var input: [5]u8 = ['h', 'e', 'l', 'l', 'o']
    let result: u32 = adler32(@input[0], 5)

    if result != 0x062c0215
        print("Expected 0x062c0215, got 0x")
        print_hex_u32(result)
        print("\n")
        return 1

    return 0


[[test]]
fn test_adler32_abc() -> i32
    # "ab" - verified with Python: zlib.adler32(b"abc") = 0x024d0127
    var input: [3]u8 = ['a', 'b', 'c']
    let result: u32 = adler32(@input[0], 3)

    if result != 0x024d0127
        print("Expected 0x024d0127, got 0x")
        print_hex_u32(result)
        print("\n")
        return 1

    return 0


# ============================================================================
# Streaming API Tests
# ============================================================================

[[test]]
fn test_adler32_streaming_hello() -> i32
    # "hello" processed in chunks should give same result
    var h: [1]u8 = ['h']
    var ello: [4]u8 = ['e', 'l', 'l', 'o']

    var state: u32 = adler32_init()
    state = adler32_update(state, @h[0], 1)
    state = adler32_update(state, @ello[0], 4)
    let result: u32 = adler32_final(state)

    if result != 0x062c0215
        print("Expected 0x062c0215, got 0x")
        print_hex_u32(result)
        print("\n")
        return 1

    return 0


[[test]]
fn test_adler32_streaming_byte_by_byte() -> i32
    # Process "hello" one byte at a time
    var input: [5]u8 = ['h', 'e', 'l', 'l', 'o']

    var state: u32 = adler32_init()
    for i in 0..5
        state = adler32_update(state, @input[i], 1)
    let result: u32 = adler32_final(state)

    if result != 0x062c0215
        print("Expected 0x062c0215, got 0x")
        print_hex_u32(result)
        print("\n")
        return 1

    return 0


[[test]]
fn test_adler32_streaming_empty_update() -> i32
    # Empty updates should not change state
    var input: [5]u8 = ['h', 'e', 'l', 'l', 'o']

    var state: u32 = adler32_init()
    state = adler32_update(state, @input[0], 0)  # Empty update
    state = adler32_update(state, @input[0], 5)
    state = adler32_update(state, @input[0], 0)  # Empty update
    let result: u32 = adler32_final(state)

    if result != 0x062c0215
        print("Expected 0x062c0215, got 0x")
        print_hex_u32(result)
        print("\n")
        return 1

    return 0


# ============================================================================
# Large Input Tests
# ============================================================================

[[test]]
fn test_adler32_256_bytes() -> i32
    # 256 bytes with values 0-255
    # Verified with Python: zlib.adler32(bytes(range(256))) = 0xadf67f81
    var input: [256]u8
    for i in 0..256
        input[i] = i as u8

    let result: u32 = adler32(@input[0], 256)

    if result != 0xadf67f81
        print("Expected 0xadf67f81, got 0x")
        print_hex_u32(result)
        print("\n")
        return 1

    return 0


[[test]]
fn test_adler32_1000_zeros() -> i32
    # 1000 zero bytes
    # A = 1 + 0*1000 = 1
    # B = 1*1000 = 1000 = 0x3E8
    # Result = 0x03E80001
    var input: [1000]u8
    for i in 0..1000
        input[i] = 0

    let result: u32 = adler32(@input[0], 1000)

    if result != 0x03E80001
        print("Expected 0x03E80001, got 0x")
        print_hex_u32(result)
        print("\n")
        return 1

    return 0


[[test]]
fn test_adler32_1000_ff() -> i32
    # 1000 bytes of 0xFF
    # Verified with Python: zlib.adler32(b"\xff" * 1000) = 0xe6e9e446
    var input: [1000]u8
    for i in 0..1000
        input[i] = 0xFF

    let result: u32 = adler32(@input[0], 1000)

    if result != 0xe6e9e446
        print("Expected 0xe6e9e446, got 0x")
        print_hex_u32(result)
        print("\n")
        return 1

    return 0


# ============================================================================
# Helper Functions
# ============================================================================

fn print_hex_u32(value: u32) -> void
    var hex: [8]u8
    for i in 0..8
        let nibble: u32 = (value >> ((7 - i) * 4)) & 0xF
        if nibble < 10
            hex[i] = ('0' as u8) + (nibble as u8)
        else
            hex[i] = ('A' as u8) + ((nibble - 10) as u8)
    write(1, @hex[0], 8)
