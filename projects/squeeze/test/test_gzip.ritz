# test/test_gzip.ritz - Gzip format tests (RFC 1952)
#
# Tests for gzip compression and decompression, including:
# - Header parsing (magic bytes, flags, OS, timestamp)
# - Trailer validation (CRC32, ISIZE)
# - Round-trip compression/decompression
# - Error handling (invalid headers, CRC mismatch)

import ritzlib.sys
import ritzlib.io

import lib.gzip


# ============================================================================
# Decompression Tests
# ============================================================================

[[test]]
fn test_gzip_decompress_hello() -> i32
    # "hello" compressed with gzip -n (no filename, no timestamp)
    # printf "hello" | gzip -n | xxd
    # Header: 1f8b 0800 00000000 00 03
    # Trailer: CRC32=0x3610a686, ISIZE=5
    var input: [25]u8 = [
        0x1f, 0x8b, 0x08, 0x00,  # Magic + CM + FLG
        0x00, 0x00, 0x00, 0x00,  # MTIME = 0
        0x00, 0x03,              # XFL + OS (Unix)
        # Deflate data
        0xcb, 0x48, 0xcd, 0xc9, 0xc9, 0x07, 0x00,
        # Trailer: CRC32 (LE) + ISIZE (LE)
        0x86, 0xa6, 0x10, 0x36,  # CRC32 = 0x3610a686
        0x05, 0x00, 0x00, 0x00   # ISIZE = 5
    ]
    var output: [64]u8
    let result: i64 = gzip_decompress(@input[0], 25, @output[0], 64)

    if result != 5
        print(c"Expected 5 bytes, got ")
        print_i64(result)
        print(c"\n")
        return 1

    # Verify content: "hello"
    if output[0] != 'h'
        print(c"Content mismatch at 0\n")
        return 1
    if output[1] != 'e'
        print(c"Content mismatch at 1\n")
        return 1
    if output[2] != 'l'
        print(c"Content mismatch at 2\n")
        return 1
    if output[3] != 'l'
        print(c"Content mismatch at 3\n")
        return 1
    if output[4] != 'o'
        print(c"Content mismatch at 4\n")
        return 1

    return 0


[[test]]
fn test_gzip_decompress_empty() -> i32
    # Empty input compressed with gzip -n
    # printf "" | gzip -n | xxd
    var input: [20]u8 = [
        0x1f, 0x8b, 0x08, 0x00,  # Magic + CM + FLG
        0x00, 0x00, 0x00, 0x00,  # MTIME = 0
        0x00, 0x03,              # XFL + OS (Unix)
        # Deflate data (empty block)
        0x03, 0x00,
        # Trailer
        0x00, 0x00, 0x00, 0x00,  # CRC32 = 0
        0x00, 0x00, 0x00, 0x00   # ISIZE = 0
    ]
    var output: [64]u8
    let result: i64 = gzip_decompress(@input[0], 20, @output[0], 64)

    if result != 0
        print(c"Expected 0 bytes, got ")
        print_i64(result)
        print(c"\n")
        return 1

    return 0


[[test]]
fn test_gzip_decompress_hello_world() -> i32
    # "hello world\n" compressed (from echo "hello world" | gzip -n)
    var input: [32]u8 = [
        0x1f, 0x8b, 0x08, 0x00,  # Magic + CM + FLG
        0x00, 0x00, 0x00, 0x00,  # MTIME = 0
        0x00, 0x03,              # XFL + OS (Unix)
        # Deflate data
        0xcb, 0x48, 0xcd, 0xc9, 0xc9, 0x57, 0x28, 0xcf,
        0x2f, 0xca, 0x49, 0xe1, 0x02, 0x00,
        # Trailer
        0x2d, 0x3b, 0x08, 0xaf,  # CRC32 = 0xaf083b2d
        0x0c, 0x00, 0x00, 0x00   # ISIZE = 12
    ]
    var output: [64]u8
    let result: i64 = gzip_decompress(@input[0], 32, @output[0], 64)

    if result != 12
        print(c"Expected 12 bytes, got ")
        print_i64(result)
        print(c"\n")
        return 1

    # Verify content: "hello world\n"
    if output[0] != 'h'
        print(c"Content mismatch at 0\n")
        return 1
    if output[1] != 'e'
        print(c"Content mismatch at 1\n")
        return 1
    if output[5] != ' '
        print(c"Content mismatch at 5\n")
        return 1
    if output[6] != 'w'
        print(c"Content mismatch at 6\n")
        return 1
    if output[11] != '\n'
        print(c"Content mismatch at 11\n")
        return 1

    return 0


[[test]]
fn test_gzip_decompress_invalid_magic() -> i32
    # Invalid magic bytes
    var bad_magic: [20]u8 = [
        0x1f, 0x8a, 0x08, 0x00,  # Wrong second magic byte
        0x00, 0x00, 0x00, 0x00,
        0x00, 0x03,
        0x03, 0x00,
        0x00, 0x00, 0x00, 0x00,
        0x00, 0x00, 0x00, 0x00
    ]
    var output: [64]u8
    let result: i64 = gzip_decompress(@bad_magic[0], 20, @output[0], 64)

    if result != GZIP_ERR_BAD_MAGIC
        print(c"Expected GZIP_ERR_BAD_MAGIC, got ")
        print_i64(result)
        print(c"\n")
        return 1

    return 0


[[test]]
fn test_gzip_decompress_invalid_method() -> i32
    # Invalid compression method (not deflate)
    var bad_method: [20]u8 = [
        0x1f, 0x8b, 0x09, 0x00,  # CM = 9 (invalid, should be 8)
        0x00, 0x00, 0x00, 0x00,
        0x00, 0x03,
        0x03, 0x00,
        0x00, 0x00, 0x00, 0x00,
        0x00, 0x00, 0x00, 0x00
    ]
    var output: [64]u8
    let result: i64 = gzip_decompress(@bad_method[0], 20, @output[0], 64)

    if result != GZIP_ERR_BAD_METHOD
        print(c"Expected GZIP_ERR_BAD_METHOD, got ")
        print_i64(result)
        print(c"\n")
        return 1

    return 0


[[test]]
fn test_gzip_decompress_truncated() -> i32
    # Valid start but truncated (only 10 bytes header, no data or trailer)
    var truncated: [10]u8 = [
        0x1f, 0x8b, 0x08, 0x00,
        0x00, 0x00, 0x00, 0x00,
        0x00, 0x03
    ]
    var output: [64]u8
    let result: i64 = gzip_decompress(@truncated[0], 10, @output[0], 64)

    # Should fail due to missing data/trailer (input < 20 bytes minimum)
    if result >= 0
        print(c"Expected error for truncated input, got ")
        print_i64(result)
        print(c"\n")
        return 1

    return 0


[[test]]
fn test_gzip_decompress_crc_mismatch() -> i32
    # "hello" compressed, but with corrupted CRC
    var bad_crc: [25]u8 = [
        0x1f, 0x8b, 0x08, 0x00,
        0x00, 0x00, 0x00, 0x00,
        0x00, 0x03,
        0xcb, 0x48, 0xcd, 0xc9, 0xc9, 0x07, 0x00,
        0xFF, 0xFF, 0xFF, 0xFF,  # Corrupted CRC32
        0x05, 0x00, 0x00, 0x00
    ]
    var output: [64]u8
    let result: i64 = gzip_decompress(@bad_crc[0], 25, @output[0], 64)

    if result != GZIP_ERR_CRC_MISMATCH
        print(c"Expected GZIP_ERR_CRC_MISMATCH, got ")
        print_i64(result)
        print(c"\n")
        return 1

    return 0


[[test]]
fn test_gzip_decompress_size_mismatch() -> i32
    # "hello" compressed, but with wrong ISIZE
    var bad_size: [25]u8 = [
        0x1f, 0x8b, 0x08, 0x00,
        0x00, 0x00, 0x00, 0x00,
        0x00, 0x03,
        0xcb, 0x48, 0xcd, 0xc9, 0xc9, 0x07, 0x00,
        0x86, 0xa6, 0x10, 0x36,  # Correct CRC32
        0xFF, 0x00, 0x00, 0x00   # Wrong ISIZE (255 instead of 5)
    ]
    var output: [64]u8
    let result: i64 = gzip_decompress(@bad_size[0], 25, @output[0], 64)

    if result != GZIP_ERR_SIZE_MISMATCH
        print(c"Expected GZIP_ERR_SIZE_MISMATCH, got ")
        print_i64(result)
        print(c"\n")
        return 1

    return 0


# ============================================================================
# Compression Tests
# ============================================================================

[[test]]
fn test_gzip_compress_hello() -> i32
    var input: [5]u8 = ['h', 'e', 'l', 'l', 'o']
    var output: [128]u8
    let result: i64 = gzip_compress(@input[0], 5, @output[0], 128)

    if result < 0
        print(c"Compression failed: ")
        print_i64(result)
        print(c"\n")
        return 1

    # Verify header
    if output[0] != 0x1f
        print(c"Bad magic byte 0\n")
        return 1
    if output[1] != 0x8b
        print(c"Bad magic byte 1\n")
        return 1
    if output[2] != 0x08
        print(c"Bad compression method\n")
        return 1

    return 0


[[test]]
fn test_gzip_compress_empty() -> i32
    var input: [1]u8
    var output: [128]u8
    let result: i64 = gzip_compress(@input[0], 0, @output[0], 128)

    if result < 0
        print(c"Compression failed: ")
        print_i64(result)
        print(c"\n")
        return 1

    # Should have header (10) + empty deflate block (at least 2) + trailer (8)
    if result < 20
        print(c"Output too small: ")
        print_i64(result)
        print(c"\n")
        return 1

    return 0


# ============================================================================
# Round-trip Tests
# ============================================================================

[[test]]
fn test_gzip_roundtrip_hello() -> i32
    var input: [5]u8 = ['h', 'e', 'l', 'l', 'o']
    var compressed: [128]u8
    var decompressed: [64]u8

    let comp_len: i64 = gzip_compress(@input[0], 5, @compressed[0], 128)
    if comp_len < 0
        print(c"Compression failed\n")
        return 1

    let decomp_len: i64 = gzip_decompress(@compressed[0], comp_len, @decompressed[0], 64)
    if decomp_len != 5
        print(c"Decompression length mismatch: ")
        print_i64(decomp_len)
        print(c"\n")
        return 1

    # Verify content
    for i in 0..5
        if decompressed[i] != input[i]
            print(c"Content mismatch at position ")
            print_i64(i)
            print(c"\n")
            return 1

    return 0


[[test]]
fn test_gzip_roundtrip_text() -> i32
    var input: [43]u8 = [
        'T', 'h', 'e', ' ', 'q', 'u', 'i', 'c', 'k', ' ',
        'b', 'r', 'o', 'w', 'n', ' ', 'f', 'o', 'x', ' ',
        'j', 'u', 'm', 'p', 's', ' ', 'o', 'v', 'e', 'r',
        ' ', 't', 'h', 'e', ' ', 'l', 'a', 'z', 'y', ' ',
        'd', 'o', 'g'
    ]
    var compressed: [256]u8
    var decompressed: [64]u8

    let comp_len: i64 = gzip_compress(@input[0], 43, @compressed[0], 256)
    if comp_len < 0
        print(c"Compression failed\n")
        return 1

    let decomp_len: i64 = gzip_decompress(@compressed[0], comp_len, @decompressed[0], 64)
    if decomp_len != 43
        print(c"Decompression length mismatch: ")
        print_i64(decomp_len)
        print(c"\n")
        return 1

    # Verify content
    for i in 0..43
        if decompressed[i] != input[i]
            print(c"Content mismatch at position ")
            print_i64(i)
            print(c"\n")
            return 1

    return 0


[[test]]
fn test_gzip_roundtrip_binary() -> i32
    # Binary data with all byte values 0-255
    var input: [256]u8
    for i in 0..256
        input[i] = i as u8

    var compressed: [512]u8
    var decompressed: [512]u8

    let comp_len: i64 = gzip_compress(@input[0], 256, @compressed[0], 512)
    if comp_len < 0
        print(c"Compression failed\n")
        return 1

    let decomp_len: i64 = gzip_decompress(@compressed[0], comp_len, @decompressed[0], 512)
    if decomp_len != 256
        print(c"Decompression length mismatch: ")
        print_i64(decomp_len)
        print(c"\n")
        return 1

    # Verify content
    for i in 0..256
        if decompressed[i] != input[i]
            print(c"Content mismatch at position ")
            print_i64(i)
            print(c"\n")
            return 1

    return 0
