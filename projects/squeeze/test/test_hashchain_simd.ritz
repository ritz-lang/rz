# test/test_hashchain_simd.ritz - Tests for SIMD-accelerated hash chain match finding

import ritzlib.sys
import ritzlib.io

import lib.deflate
import lib.deflate_simd
import lib.inflate

fn hashchain_bytes_equal(a: *u8, b: *u8, len: i64) -> i32
    for i in 0..len
        if a[i] != b[i]
            return 0
    return 1

[[test]]
fn test_hash4_simd_matches_scalar() -> i32
    var data: [16]u8
    for i in 0..16
        data[i] = (i * 7 + 3) as u8

    var scalar_hashes: [4]i32
    for i in 0..4
        scalar_hashes[i] = hash3(@data[0], i as i64)

    var simd_hashes: [4]i32
    hash4_simd(@data[0], 0, @simd_hashes[0])

    for i in 0..4
        if scalar_hashes[i] != simd_hashes[i]
            print("FAIL: test_hash4_simd_matches_scalar\n")
            return 1
    0

[[test]]
fn test_hash8_simd_matches_scalar() -> i32
    var data: [24]u8
    for i in 0..24
        data[i] = (i * 11 + 5) as u8

    var scalar_hashes: [8]i32
    for i in 0..8
        scalar_hashes[i] = hash3(@data[0], i as i64)

    var simd_hashes: [8]i32
    hash8_simd(@data[0], 0, @simd_hashes[0])

    for i in 0..8
        if scalar_hashes[i] != simd_hashes[i]
            print("FAIL: test_hash8_simd_matches_scalar\n")
            return 1
    0

[[test]]
fn test_deflate_simd_empty() -> i32
    var input: [1]u8 = [0; 1]
    var comp_scalar: [16]u8 = [0; 16]
    var comp_simd: [16]u8 = [0; 16]

    let len_scalar: i64 = deflate(@input[0], 0, @comp_scalar[0], 16, 6)
    let len_simd: i64 = deflate_simd(@input[0], 0, @comp_simd[0], 16, 6)

    if len_scalar != len_simd
        print("FAIL: test_deflate_simd_empty - length mismatch\n")
        return 1

    if hashchain_bytes_equal(@comp_scalar[0], @comp_simd[0], len_scalar) == 0
        print("FAIL: test_deflate_simd_empty - output mismatch\n")
        return 1
    0

[[test]]
fn test_deflate_simd_small() -> i32
    var input: [8]u8
    input[0] = 'h' as u8
    input[1] = 'e' as u8
    input[2] = 'l' as u8
    input[3] = 'l' as u8
    input[4] = 'o' as u8
    input[5] = '!' as u8
    input[6] = '!' as u8
    input[7] = '!' as u8

    var comp_scalar: [64]u8 = [0; 64]
    var comp_simd: [64]u8 = [0; 64]

    let len_scalar: i64 = deflate(@input[0], 8, @comp_scalar[0], 64, 6)
    let len_simd: i64 = deflate_simd(@input[0], 8, @comp_simd[0], 64, 6)

    if len_scalar != len_simd
        print("FAIL: test_deflate_simd_small - length mismatch\n")
        return 1

    if hashchain_bytes_equal(@comp_scalar[0], @comp_simd[0], len_scalar) == 0
        print("FAIL: test_deflate_simd_small - output mismatch\n")
        return 1
    0

[[test]]
fn test_deflate_simd_medium() -> i32
    var input: [64]u8
    for i in 0..64
        input[i] = ((i % 26) + 'a' as i64) as u8

    var comp_scalar: [128]u8 = [0; 128]
    var comp_simd: [128]u8 = [0; 128]

    let len_scalar: i64 = deflate(@input[0], 64, @comp_scalar[0], 128, 6)
    let len_simd: i64 = deflate_simd(@input[0], 64, @comp_simd[0], 128, 6)

    if len_scalar != len_simd
        print("FAIL: test_deflate_simd_medium - length mismatch\n")
        return 1

    if hashchain_bytes_equal(@comp_scalar[0], @comp_simd[0], len_scalar) == 0
        print("FAIL: test_deflate_simd_medium - output mismatch\n")
        return 1
    0

[[test]]
fn test_deflate_simd_roundtrip() -> i32
    var input: [32]u8
    for i in 0..32
        input[i] = ((i * 3 + 1) % 26 + 'a' as i64) as u8

    var compressed: [64]u8 = [0; 64]
    var decompressed: [64]u8 = [0; 64]

    let comp_len: i64 = deflate_simd(@input[0], 32, @compressed[0], 64, 6)

    if comp_len < 0
        print("FAIL: test_deflate_simd_roundtrip - compression failed\n")
        return 1

    let decomp_len: i64 = inflate(@compressed[0], comp_len, @decompressed[0], 64)

    if decomp_len != 32
        print("FAIL: test_deflate_simd_roundtrip - wrong decompressed length\n")
        return 1

    if hashchain_bytes_equal(@input[0], @decompressed[0], 32) == 0
        print("FAIL: test_deflate_simd_roundtrip - data mismatch\n")
        return 1
    0
