# test/test_squeeze.ritz - Tests for the unified squeeze API

import ritzlib.sys
import ritzlib.io

import lib.squeeze


# ============================================================================
# Helper
# ============================================================================

fn squeeze_bytes_equal(a: *u8, b: *u8, len: i64) -> i32
    for i in 0..len
        if a[i] != b[i]
            return 0
    return 1


# ============================================================================
# Buffer Size Tests
# ============================================================================

[[test]]
fn test_gzip_compress_bound() -> i32
    # Empty data: header (10) + no blocks + trailer (8) = 18
    let empty_bound: i64 = gzip_compress_bound(0)
    if empty_bound < 18
        print("FAIL: test_gzip_compress_bound - empty\n")
        return 1

    # 100 bytes: should fit in one block
    let small_bound: i64 = gzip_compress_bound(100)
    if small_bound < 123  # 100 + 5 (block header) + 18 (header/trailer)
        print("FAIL: test_gzip_compress_bound - small\n")
        return 1

    # Large: multiple blocks
    let large_bound: i64 = gzip_compress_bound(100000)
    if large_bound < 100028  # 100000 + 2*5 (2 blocks) + 18
        print("FAIL: test_gzip_compress_bound - large\n")
        return 1
    0


[[test]]
fn test_zlib_compress_bound() -> i32
    # Empty data: header (2) + no blocks + trailer (4) = 6
    let empty_bound: i64 = zlib_compress_bound(0)
    if empty_bound < 6
        print("FAIL: test_zlib_compress_bound - empty\n")
        return 1

    # 100 bytes
    let small_bound: i64 = zlib_compress_bound(100)
    if small_bound < 111  # 100 + 5 + 6
        print("FAIL: test_zlib_compress_bound - small\n")
        return 1
    0


# ============================================================================
# Format Detection Tests
# ============================================================================

[[test]]
fn test_is_gzip() -> i32
    # Valid gzip header
    var gzip_data: [2]u8
    gzip_data[0] = 0x1F
    gzip_data[1] = 0x8B

    if is_gzip(@gzip_data[0], 2) != true
        print("FAIL: test_is_gzip - should be gzip\n")
        return 1

    # Not gzip
    var other_data: [2]u8
    other_data[0] = 0x78
    other_data[1] = 0x9C

    if is_gzip(@other_data[0], 2) == true
        print("FAIL: test_is_gzip - should not be gzip\n")
        return 1

    # Too short
    if is_gzip(@gzip_data[0], 1) == true
        print("FAIL: test_is_gzip - too short should return false\n")
        return 1
    0


[[test]]
fn test_is_zlib() -> i32
    # Common zlib headers
    var zlib_default: [2]u8
    zlib_default[0] = 0x78
    zlib_default[1] = 0x9C

    if is_zlib(@zlib_default[0], 2) != true
        print("FAIL: test_is_zlib - 78 9C should be zlib\n")
        return 1

    var zlib_best: [2]u8
    zlib_best[0] = 0x78
    zlib_best[1] = 0xDA

    if is_zlib(@zlib_best[0], 2) != true
        print("FAIL: test_is_zlib - 78 DA should be zlib\n")
        return 1

    # Not zlib
    var gzip_data: [2]u8
    gzip_data[0] = 0x1F
    gzip_data[1] = 0x8B

    if is_zlib(@gzip_data[0], 2) == true
        print("FAIL: test_is_zlib - gzip should not be zlib\n")
        return 1
    0


# ============================================================================
# Auto-Decompress Tests
# ============================================================================

[[test]]
fn test_decompress_auto_gzip() -> i32
    # gzip-compressed "hello" from Python
    var input: [25]u8
    input[0] = 0x1f
    input[1] = 0x8b
    input[2] = 0x08
    input[3] = 0x00
    input[4] = 0x00
    input[5] = 0x00
    input[6] = 0x00
    input[7] = 0x00
    input[8] = 0x02
    input[9] = 0xff
    input[10] = 0xcb
    input[11] = 0x48
    input[12] = 0xcd
    input[13] = 0xc9
    input[14] = 0xc9
    input[15] = 0x07
    input[16] = 0x00
    input[17] = 0x86
    input[18] = 0xa6
    input[19] = 0x10
    input[20] = 0x36
    input[21] = 0x05
    input[22] = 0x00
    input[23] = 0x00
    input[24] = 0x00

    var output: [16]u8 = [0; 16]
    let result: i64 = decompress_auto(@input[0], 25, @output[0], 16)

    if result != 5
        print("FAIL: test_decompress_auto_gzip - expected 5 bytes, got ")
        print_int(result)
        print("\n")
        return 1

    var expected: [5]u8
    expected[0] = 'h' as u8
    expected[1] = 'e' as u8
    expected[2] = 'l' as u8
    expected[3] = 'l' as u8
    expected[4] = 'o' as u8

    if squeeze_bytes_equal(@output[0], @expected[0], 5) == 0
        print("FAIL: test_decompress_auto_gzip - wrong content\n")
        return 1
    0


[[test]]
fn test_decompress_auto_zlib() -> i32
    # zlib-compressed "hello" from Python
    var input: [13]u8
    input[0] = 0x78
    input[1] = 0x9c
    input[2] = 0xcb
    input[3] = 0x48
    input[4] = 0xcd
    input[5] = 0xc9
    input[6] = 0xc9
    input[7] = 0x07
    input[8] = 0x00
    input[9] = 0x06
    input[10] = 0x2c
    input[11] = 0x02
    input[12] = 0x15

    var output: [16]u8 = [0; 16]
    let result: i64 = decompress_auto(@input[0], 13, @output[0], 16)

    if result != 5
        print("FAIL: test_decompress_auto_zlib - expected 5 bytes, got ")
        print_int(result)
        print("\n")
        return 1

    var expected: [5]u8
    expected[0] = 'h' as u8
    expected[1] = 'e' as u8
    expected[2] = 'l' as u8
    expected[3] = 'l' as u8
    expected[4] = 'o' as u8

    if squeeze_bytes_equal(@output[0], @expected[0], 5) == 0
        print("FAIL: test_decompress_auto_zlib - wrong content\n")
        return 1
    0


[[test]]
fn test_decompress_auto_invalid() -> i32
    # Unknown format - should return error
    var input: [4]u8
    input[0] = 0x00
    input[1] = 0x00
    input[2] = 0x00
    input[3] = 0x00

    var output: [16]u8 = [0; 16]
    let result: i64 = decompress_auto(@input[0], 4, @output[0], 16)

    if result != SQUEEZE_ERR_INVALID_HEADER
        print("FAIL: test_decompress_auto_invalid - expected error\n")
        return 1
    0


# ============================================================================
# Constants Tests
# ============================================================================

[[test]]
fn test_compression_level_constants() -> i32
    # Verify constants are in expected range
    if SQUEEZE_NO_COMPRESSION != 0
        print("FAIL: SQUEEZE_NO_COMPRESSION != 0\n")
        return 1
    if SQUEEZE_FAST_COMPRESSION != 1
        print("FAIL: SQUEEZE_FAST_COMPRESSION != 1\n")
        return 1
    if SQUEEZE_DEFAULT_COMPRESSION != 6
        print("FAIL: SQUEEZE_DEFAULT_COMPRESSION != 6\n")
        return 1
    if SQUEEZE_BEST_COMPRESSION != 9
        print("FAIL: SQUEEZE_BEST_COMPRESSION != 9\n")
        return 1
    0


# Note: Tests are automatically discovered and run by ritzunit.
# Each @test function is found via ELF symbol table scanning.
