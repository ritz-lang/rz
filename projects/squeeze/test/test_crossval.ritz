[[test]]
fn test_crossval_gzip_hello() -> i32
    # Python: gzip.compress(b'hello', mtime=0)
    # Result: 1f 8b 08 00 00 00 00 00 02 ff cb 48 cd c9 c9 07 00 86 a6 10 36 05 00 00 00
    var input: [25]u8
    input[0] = 0x1f
    input[1] = 0x8b
    input[2] = 0x08
    input[3] = 0x00
    input[4] = 0x00
    input[5] = 0x00
    input[6] = 0x00
    input[7] = 0x00
    input[8] = 0x02
    input[9] = 0xff
    input[10] = 0xcb
    input[11] = 0x48
    input[12] = 0xcd
    input[13] = 0xc9
    input[14] = 0xc9
    input[15] = 0x07
    input[16] = 0x00
    input[17] = 0x86
    input[18] = 0xa6
    input[19] = 0x10
    input[20] = 0x36
    input[21] = 0x05
    input[22] = 0x00
    input[23] = 0x00
    input[24] = 0x00

    var output: [16]u8 = [0; 16]
    let result: i64 = gzip_decompress(@input[0], 25, @output[0], 16)

    if result != 5
        print("FAIL: test_crossval_gzip_hello - expected 5 bytes, got ")
        print_int(result)
        print("\n")
        return 1

    var expected: [5]u8
    expected[0] = 'h' as u8
    expected[1] = 'e' as u8
    expected[2] = 'l' as u8
    expected[3] = 'l' as u8
    expected[4] = 'o' as u8

    if crossval_bytes_equal(@output[0], @expected[0], 5) == 0
        print("FAIL: test_crossval_gzip_hello - wrong content\n")
        return 1
    0


