# test/test_crossval.ritz - Cross-validation tests with Python zlib/gzip
#
# These tests verify that squeeze can:
# 1. Decompress data produced by Python's zlib/gzip
# 2. Produce compressed data that Python can decompress (roundtrip)
#
# Test vectors generated with Python 3.x using:
#   import zlib, gzip
#   zlib.compress(data, level=6)
#   gzip.compress(data, mtime=0)

import ritzlib.sys
import ritzlib.io

import lib.zlib
import lib.gzip


# ============================================================================
# Helper: Compare byte arrays
# ============================================================================

fn crossval_bytes_equal(a: *u8, b: *u8, len: i64) -> i32
    for i in 0..len
        if a[i] != b[i]
            return 0
    return 1


fn print_hex_byte(b: u8)
    let hi: u8 = b >> 4
    let lo: u8 = b & 0x0F
    if hi < 10
        print_char(('0' as u8 + hi) as i32)
    else
        print_char(('a' as u8 + hi - 10) as i32)
    if lo < 10
        print_char(('0' as u8 + lo) as i32)
    else
        print_char(('a' as u8 + lo - 10) as i32)
    return


# ============================================================================
# zlib Decompression Tests (data from Python zlib.compress)
# ============================================================================

[[test]]
fn test_crossval_zlib_empty() -> i32
    # Python: zlib.compress(b'', level=6)
    # Result: 78 9c 03 00 00 00 00 01
    var input: [8]u8
    input[0] = 0x78
    input[1] = 0x9c
    input[2] = 0x03
    input[3] = 0x00
    input[4] = 0x00
    input[5] = 0x00
    input[6] = 0x00
    input[7] = 0x01

    var output: [16]u8 = [0; 16]
    let result: i64 = zlib_decompress(@input[0], 8, @output[0], 16)

    if result != 0
        print("FAIL: test_crossval_zlib_empty - expected 0 bytes, got ")
        print_int(result)
        print("\n")
        return 1
    0


[[test]]
fn test_crossval_zlib_single_byte() -> i32
    # Python: zlib.compress(b'a', level=6)
    # Result: 78 9c 4b 04 00 00 62 00 62
    var input: [9]u8
    input[0] = 0x78
    input[1] = 0x9c
    input[2] = 0x4b
    input[3] = 0x04
    input[4] = 0x00
    input[5] = 0x00
    input[6] = 0x62
    input[7] = 0x00
    input[8] = 0x62

    var output: [16]u8 = [0; 16]
    let result: i64 = zlib_decompress(@input[0], 9, @output[0], 16)

    if result != 1
        print("FAIL: test_crossval_zlib_single_byte - expected 1 byte, got ")
        print_int(result)
        print("\n")
        return 1

    if output[0] != 'a' as u8
        print("FAIL: test_crossval_zlib_single_byte - wrong byte\n")
        return 1
    0


[[test]]
fn test_crossval_zlib_hello() -> i32
    # Python: zlib.compress(b'hello', level=6)
    # Result: 78 9c cb 48 cd c9 c9 07 00 06 2c 02 15
    var input: [13]u8
    input[0] = 0x78
    input[1] = 0x9c
    input[2] = 0xcb
    input[3] = 0x48
    input[4] = 0xcd
    input[5] = 0xc9
    input[6] = 0xc9
    input[7] = 0x07
    input[8] = 0x00
    input[9] = 0x06
    input[10] = 0x2c
    input[11] = 0x02
    input[12] = 0x15

    var output: [16]u8 = [0; 16]
    let result: i64 = zlib_decompress(@input[0], 13, @output[0], 16)

    if result != 5
        print("FAIL: test_crossval_zlib_hello - expected 5 bytes, got ")
        print_int(result)
        print("\n")
        return 1

    var expected: [5]u8
    expected[0] = 'h' as u8
    expected[1] = 'e' as u8
    expected[2] = 'l' as u8
    expected[3] = 'l' as u8
    expected[4] = 'o' as u8

    if crossval_bytes_equal(@output[0], @expected[0], 5) == 0
        print("FAIL: test_crossval_zlib_hello - wrong content\n")
        return 1
    0


[[test]]
fn test_crossval_zlib_repeated_char() -> i32
    # Python: zlib.compress(b'A' * 100, level=6)
    # Result: 78 9c 73 74 a4 3d 00 00 02 e9 19 65
    var input: [12]u8
    input[0] = 0x78
    input[1] = 0x9c
    input[2] = 0x73
    input[3] = 0x74
    input[4] = 0xa4
    input[5] = 0x3d
    input[6] = 0x00
    input[7] = 0x00
    input[8] = 0x02
    input[9] = 0xe9
    input[10] = 0x19
    input[11] = 0x65

    var output: [128]u8 = [0; 128]
    let result: i64 = zlib_decompress(@input[0], 12, @output[0], 128)

    if result != 100
        print("FAIL: test_crossval_zlib_repeated_char - expected 100 bytes, got ")
        print_int(result)
        print("\n")
        return 1

    # Verify all 100 bytes are 'A'
    for i in 0..100
        if output[i] != 'A' as u8
            print("FAIL: test_crossval_zlib_repeated_char - byte ")
            print_int(i as i64)
            print(" != 'A'\n")
            return 1
    0


[[test]]
fn test_crossval_zlib_pangram() -> i32
    # Python: zlib.compress(b'The quick brown fox jumps over the lazy dog', level=6)
    # Result: 50 bytes
    var input: [50]u8
    input[0] = 0x78
    input[1] = 0x9c
    input[2] = 0x0b
    input[3] = 0xc9
    input[4] = 0x48
    input[5] = 0x55
    input[6] = 0x28
    input[7] = 0x2c
    input[8] = 0xcd
    input[9] = 0x4c
    input[10] = 0xce
    input[11] = 0x56
    input[12] = 0x48
    input[13] = 0x2a
    input[14] = 0xca
    input[15] = 0x2f
    input[16] = 0xcf
    input[17] = 0x53
    input[18] = 0x48
    input[19] = 0xcb
    input[20] = 0xaf
    input[21] = 0x50
    input[22] = 0xc8
    input[23] = 0x2a
    input[24] = 0xcd
    input[25] = 0x2d
    input[26] = 0x28
    input[27] = 0x56
    input[28] = 0xc8
    input[29] = 0x2f
    input[30] = 0x4b
    input[31] = 0x2d
    input[32] = 0x52
    input[33] = 0x28
    input[34] = 0x01
    input[35] = 0x4a
    input[36] = 0xe7
    input[37] = 0x24
    input[38] = 0x56
    input[39] = 0x55
    input[40] = 0x2a
    input[41] = 0xa4
    input[42] = 0xe4
    input[43] = 0xa7
    input[44] = 0x03
    input[45] = 0x00
    input[46] = 0x5b
    input[47] = 0xdc
    input[48] = 0x0f
    input[49] = 0xda

    var output: [64]u8 = [0; 64]
    let result: i64 = zlib_decompress(@input[0], 50, @output[0], 64)

    if result != 43
        print("FAIL: test_crossval_zlib_pangram - expected 43 bytes, got ")
        print_int(result)
        print("\n")
        return 1

    # Verify first bytes: "The "
    if output[0] != 'T' as u8
        print("FAIL: test_crossval_zlib_pangram - byte 0\n")
        return 1
    if output[1] != 'h' as u8
        print("FAIL: test_crossval_zlib_pangram - byte 1\n")
        return 1
    if output[2] != 'e' as u8
        print("FAIL: test_crossval_zlib_pangram - byte 2\n")
        return 1
    if output[3] != ' ' as u8
        print("FAIL: test_crossval_zlib_pangram - byte 3\n")
        return 1
    0


