    var input: [20]u8
    input[0] = 0x1f
    input[1] = 0x8b
    input[2] = 0x08
    input[3] = 0x00
    input[4] = 0x00
    input[5] = 0x00
    input[6] = 0x00
    input[7] = 0x00
    input[8] = 0x02
    input[9] = 0xff
    input[10] = 0x03
    input[11] = 0x00
    input[12] = 0x00
    input[13] = 0x00
    input[14] = 0x00
    input[15] = 0x00
    input[16] = 0x00
    input[17] = 0x00
    input[18] = 0x00
    input[19] = 0x00

    var output: [16]u8 = [0; 16]
    let result: i64 = gzip_decompress(@input[0], 20, @output[0], 16)

    if result != 0
        print("FAIL: test_crossval_gzip_empty - expected 0 bytes, got ")
        print_int(result)
        print("\n")
        return 1
    0


