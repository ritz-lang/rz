# test/test_crc32_simd.ritz - Tests for SIMD-accelerated CRC-32
#
# Verifies that SIMD implementation produces identical results to scalar.
# Tests various input sizes including edge cases around SIMD thresholds.

import ritzlib.sys
import ritzlib.io

import lib.crc32
import lib.crc32_simd

# ============================================================================
# Small Input Tests (below SIMD threshold - uses scalar fallback)
# ============================================================================

[[test]]
fn test_crc32_simd_empty() -> i32
    # Empty input should return 0
    let simd_result: u32 = crc32_simd("", 0)
    let scalar_result: u32 = crc32("", 0)
    if simd_result != scalar_result
        print("FAIL: test_crc32_simd_empty\n")
        print("  simd: ")
        print_hex32_simd(simd_result)
        print(", scalar: ")
        print_hex32_simd(scalar_result)
        print("\n")
        return 1
    0

[[test]]
fn test_crc32_simd_small() -> i32
    # "hello" = 5 bytes (below threshold)
    let simd_result: u32 = crc32_simd("hello", 5)
    let scalar_result: u32 = crc32("hello", 5)
    if simd_result != scalar_result
        print("FAIL: test_crc32_simd_small\n")
        return 1
    0

[[test]]
fn test_crc32_simd_check_value() -> i32
    # Standard CRC32 test vector: "123456789" = 0xCBF43926
    let simd_result: u32 = crc32_simd("123456789", 9)
    if simd_result != 0xCBF43926
        print("FAIL: test_crc32_simd_check_value\n")
        print("  expected: 0xCBF43926\n")
        print("  got: ")
        print_hex32_simd(simd_result)
        print("\n")
        return 1
    0

# ============================================================================
# Exact Threshold Tests (64 bytes)
# ============================================================================

[[test]]
fn test_crc32_simd_64_bytes() -> i32
    # Exactly 64 bytes - minimum for SIMD path
    var buf: [64]u8
    for i in 0..64
        buf[i] = i as u8
    let simd_result: u32 = crc32_simd(@buf[0], 64)
    let scalar_result: u32 = crc32(@buf[0], 64)
    if simd_result != scalar_result
        print("FAIL: test_crc32_simd_64_bytes\n")
        print("  simd: ")
        print_hex32_simd(simd_result)
        print(", scalar: ")
        print_hex32_simd(scalar_result)
        print("\n")
        return 1
    0

[[test]]
fn test_crc32_simd_65_bytes() -> i32
    # 65 bytes - SIMD + 1 byte remainder
    var buf: [65]u8
    for i in 0..65
        buf[i] = (i * 7) as u8
    let simd_result: u32 = crc32_simd(@buf[0], 65)
    let scalar_result: u32 = crc32(@buf[0], 65)
    if simd_result != scalar_result
        print("FAIL: test_crc32_simd_65_bytes\n")
        return 1
    0

# ============================================================================
# Larger Input Tests
# ============================================================================

[[test]]
fn test_crc32_simd_128_bytes() -> i32
    # 128 bytes - two full 64-byte SIMD iterations
    var buf: [128]u8
    for i in 0..128
        buf[i] = (i * 13 + 7) as u8
    let simd_result: u32 = crc32_simd(@buf[0], 128)
    let scalar_result: u32 = crc32(@buf[0], 128)
    if simd_result != scalar_result
        print("FAIL: test_crc32_simd_128_bytes\n")
        return 1
    0

[[test]]
fn test_crc32_simd_256_bytes() -> i32
    # 256 bytes - multiple SIMD iterations
    var buf: [256]u8
    for i in 0..256
        buf[i] = i as u8
    let simd_result: u32 = crc32_simd(@buf[0], 256)
    let scalar_result: u32 = crc32(@buf[0], 256)
    if simd_result != scalar_result
        print("FAIL: test_crc32_simd_256_bytes\n")
        return 1
    0

[[test]]
fn test_crc32_simd_1000_bytes() -> i32
    # 1000 bytes - stress test
    var buf: [1000]u8
    for i in 0..1000
        buf[i] = (i % 256) as u8
    let simd_result: u32 = crc32_simd(@buf[0], 1000)
    let scalar_result: u32 = crc32(@buf[0], 1000)
    if simd_result != scalar_result
        print("FAIL: test_crc32_simd_1000_bytes\n")
        return 1
    0

# ============================================================================
# Special Pattern Tests
# ============================================================================

[[test]]
fn test_crc32_simd_all_zeros() -> i32
    # 64 zero bytes
    var buf: [64]u8 = [0; 64]
    let simd_result: u32 = crc32_simd(@buf[0], 64)
    let scalar_result: u32 = crc32(@buf[0], 64)
    if simd_result != scalar_result
        print("FAIL: test_crc32_simd_all_zeros\n")
        return 1
    0

[[test]]
fn test_crc32_simd_all_ones() -> i32
    # 64 bytes of 0xFF
    var buf: [64]u8
    for i in 0..64
        buf[i] = 0xFF
    let simd_result: u32 = crc32_simd(@buf[0], 64)
    let scalar_result: u32 = crc32(@buf[0], 64)
    if simd_result != scalar_result
        print("FAIL: test_crc32_simd_all_ones\n")
        return 1
    0

[[test]]
fn test_crc32_simd_alternating() -> i32
    # Alternating 0x55, 0xAA pattern
    var buf: [128]u8
    for i in 0..128
        if i % 2 == 0
            buf[i] = 0x55
        else
            buf[i] = 0xAA
    let simd_result: u32 = crc32_simd(@buf[0], 128)
    let scalar_result: u32 = crc32(@buf[0], 128)
    if simd_result != scalar_result
        print("FAIL: test_crc32_simd_alternating\n")
        return 1
    0

# ============================================================================
# Streaming API Tests
# ============================================================================

[[test]]
fn test_crc32_simd_streaming() -> i32
    # Process 256 bytes in chunks
    var buf: [256]u8
    for i in 0..256
        buf[i] = i as u8

    # One-shot
    let oneshot: u32 = crc32_simd(@buf[0], 256)

    # Streaming: 64 + 64 + 64 + 64
    var state: u32 = crc32_simd_init()
    state = crc32_simd_update(state, @buf[0], 64)
    state = crc32_simd_update(state, @buf[64], 64)
    state = crc32_simd_update(state, @buf[128], 64)
    state = crc32_simd_update(state, @buf[192], 64)
    let streamed: u32 = crc32_simd_final(state)

    if oneshot != streamed
        print("FAIL: test_crc32_simd_streaming\n")
        return 1
    0

# ============================================================================
# Alignment Tests (data may not be 16-byte aligned)
# ============================================================================

[[test]]
fn test_crc32_simd_unaligned() -> i32
    # Create buffer and use offset pointer
    var buf: [128]u8
    for i in 0..128
        buf[i] = (i * 3) as u8

    # Test from offset 1 (unaligned)
    let simd_result: u32 = crc32_simd(@buf[1], 64)
    let scalar_result: u32 = crc32(@buf[1], 64)
    if simd_result != scalar_result
        print("FAIL: test_crc32_simd_unaligned\n")
        return 1
    0

# ============================================================================
# Helper Functions
# ============================================================================

fn print_hex32_simd(val: u32)
    print("0x")
    var hex: [8]u8
    for i in 0..8
        let nibble: u32 = (val >> ((7 - i) * 4)) & 0xF
        if nibble < 10
            hex[i] = ('0' as u32 + nibble) as u8
        else
            hex[i] = ('A' as u32 + nibble - 10) as u8
    sys_write(1, @hex[0], 8)

# Note: Tests are automatically discovered and run by ritzunit.
