# lib/crc32.ritz - CRC-32 checksum implementation
#
# Implements CRC-32 (ISO 3309) as used by Gzip, PNG, ZIP, and Ethernet.
#
# Parameters:
# - Polynomial: 0xEDB88320 (reflected form of 0x04C11DB7)
# - Initial value: 0xFFFFFFFF
# - Final XOR: 0xFFFFFFFF
# - Input/output reflected: Yes (handled by table-driven algorithm)
#
# API:
# - crc32_init(): Initialize CRC state (returns 0xFFFFFFFF)
# - crc32_update(state, data, len): Process data chunk
# - crc32_final(state): Get final checksum (XOR with 0xFFFFFFFF)
# - crc32(data, len): One-shot convenience function

import ritzlib.sys

# ============================================================================
# Constants
# ============================================================================

const CRC32_POLYNOMIAL: u32 = 0xEDB88320
const CRC32_INIT: u32 = 0xFFFFFFFF

# ============================================================================
# Lookup Table
# ============================================================================
# Pre-computed table for byte-at-a-time CRC calculation.
# Table[i] = CRC of byte i (0-255) processed through the polynomial.

var g_crc32_table: [256]u32
var g_table_initialized: i32 = 0

pub fn crc32_init_table()
    if g_table_initialized != 0
        return

    for i in 0..256
        var crc: u32 = i as u32
        for j in 0..8
            if (crc & 1) != 0
                crc = (crc >> 1) ^ CRC32_POLYNOMIAL
            else
                crc = crc >> 1
        g_crc32_table[i] = crc

    g_table_initialized = 1

# ============================================================================
# Core API
# ============================================================================

# Initialize CRC state
pub fn crc32_init() -> u32
    crc32_init_table()
    return CRC32_INIT


# Update CRC with data chunk
# Uses table-driven algorithm for efficiency.
# For each byte: crc = table[(crc ^ byte) & 0xFF] ^ (crc >> 8)
pub fn crc32_update(state: u32, data: *u8, len: i64) -> u32
    var crc: u32 = state

    for i in 0..len
        let byte: u32 = data[i] as u32
        let index: u32 = (crc ^ byte) & 0xFF
        crc = g_crc32_table[index] ^ (crc >> 8)

    return crc


# Finalize and get checksum
# XOR with 0xFFFFFFFF to get final CRC value
pub fn crc32_final(state: u32) -> u32
    return state ^ CRC32_INIT


# One-shot convenience function
pub fn crc32(data: *u8, len: i64) -> u32
    var state: u32 = crc32_init()
    state = crc32_update(state, data, len)
    return crc32_final(state)
