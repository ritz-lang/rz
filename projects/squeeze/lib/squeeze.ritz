# lib/squeeze.ritz - Unified compression/decompression API
#
# This module provides a simplified, unified interface to the squeeze library.
# It re-exports the main compression functions and provides convenience wrappers.
#
# Quick Start:
#   # One-shot compression/decompression
#   gzip_compress(input, input_len, output, output_cap)    -> compressed bytes
#   gzip_decompress(input, input_len, output, output_cap)  -> decompressed bytes
#   zlib_compress(input, input_len, output, output_cap)    -> compressed bytes
#   zlib_decompress(input, input_len, output, output_cap)  -> decompressed bytes
#
#   # Raw DEFLATE (without headers/trailers)
#   deflate(input, len, output, cap, level)  -> compressed bytes
#   inflate(input, len, output, cap)         -> decompressed bytes
#
#   # Streaming compression (for large data or incremental processing)
#   See: lib/gzip_stream.ritz and lib/zlib_stream.ritz
#
# Compression Levels:
#   0     : No compression (stored)
#   1-3   : Fast compression
#   4-6   : Default/balanced compression
#   7-9   : Best compression (slower)
#
# Return Values:
#   >= 0 : Number of bytes written to output buffer
#   < 0  : Error code
#
# Error Codes:
#   -1   : Invalid header/format
#   -2   : Truncated input
#   -3   : Checksum mismatch
#   -4   : Output buffer too small
#   -5   : Invalid Huffman code
#   -6   : Invalid distance reference
#
# Buffer Sizing:
#   For compression, output buffer should be at least input_len + 18 (gzip)
#   or input_len + 6 (zlib) to handle worst-case (incompressible data).
#   For decompression, you need to know or estimate the uncompressed size.
#
# References:
#   RFC 1950 - ZLIB Compressed Data Format
#   RFC 1951 - DEFLATE Compressed Data Format
#   RFC 1952 - GZIP File Format

import ritzlib.sys

# Re-export main APIs from individual modules
import lib.gzip
import lib.zlib
import lib.deflate
import lib.inflate

# Re-export streaming APIs
import lib.gzip_stream
import lib.zlib_stream


# ============================================================================
# Error Codes (unified across all formats)
# ============================================================================

pub const SQUEEZE_OK: i64 = 0
pub const SQUEEZE_ERR_INVALID_HEADER: i64 = -1
pub const SQUEEZE_ERR_TRUNCATED: i64 = -2
pub const SQUEEZE_ERR_CHECKSUM: i64 = -3
pub const SQUEEZE_ERR_OUTPUT_FULL: i64 = -4
pub const SQUEEZE_ERR_INVALID_CODE: i64 = -5
pub const SQUEEZE_ERR_INVALID_DISTANCE: i64 = -6


# ============================================================================
# Compression Level Constants
# ============================================================================

pub const SQUEEZE_NO_COMPRESSION: i32 = 0
pub const SQUEEZE_FAST_COMPRESSION: i32 = 1
pub const SQUEEZE_DEFAULT_COMPRESSION: i32 = 6
pub const SQUEEZE_BEST_COMPRESSION: i32 = 9


# ============================================================================
# Buffer Size Helpers
# ============================================================================

# Calculate minimum buffer size needed for gzip compression.
# Returns the worst-case compressed size (incompressible data + header/trailer).
pub fn gzip_compress_bound(input_len: i64) -> i64
    # gzip header (10 bytes min) + stored blocks + trailer (8 bytes)
    # Stored blocks: 5 bytes header per 65535 bytes of data
    let num_blocks: i64 = (input_len + 65534) / 65535
    return input_len + (num_blocks * 5) + 18


# Calculate minimum buffer size needed for zlib compression.
# Returns the worst-case compressed size (incompressible data + header/trailer).
pub fn zlib_compress_bound(input_len: i64) -> i64
    # zlib header (2 bytes) + stored blocks + trailer (4 bytes)
    let num_blocks: i64 = (input_len + 65534) / 65535
    return input_len + (num_blocks * 5) + 6


# Calculate minimum buffer size needed for raw deflate compression.
pub fn deflate_compress_bound(input_len: i64) -> i64
    # Stored blocks: 5 bytes header per 65535 bytes of data
    let num_blocks: i64 = (input_len + 65534) / 65535
    return input_len + (num_blocks * 5)


# ============================================================================
# Convenience Wrappers
# ============================================================================

# Compress data with gzip format using default compression level.
pub fn gzip_compress_default(input: *u8, input_len: i64, output: *u8, output_cap: i64) -> i64
    return gzip_compress(input, input_len, output, output_cap)


# Compress data with zlib format using default compression level.
pub fn zlib_compress_default(input: *u8, input_len: i64, output: *u8, output_cap: i64) -> i64
    return zlib_compress(input, input_len, output, output_cap)


# Check if data appears to be gzip-compressed (starts with 1f 8b).
pub fn is_gzip(data: *u8, len: i64) -> bool
    if len < 2
        return false
    return data[0] == 0x1F and data[1] == 0x8B


# Check if data appears to be zlib-compressed (common headers: 78 01/9c/da).
pub fn is_zlib(data: *u8, len: i64) -> bool
    if len < 2
        return false
    if data[0] != 0x78
        return false
    # Check for common zlib compression levels
    let second: u8 = data[1]
    if second == 0x01
        return true  # No compression
    if second == 0x5E
        return true  # Fast compression
    if second == 0x9C
        return true  # Default compression
    if second == 0xDA
        return true  # Best compression
    return false


# Auto-detect format and decompress.
# Supports gzip and zlib formats. Returns error if format not recognized.
pub fn decompress_auto(input: *u8, input_len: i64, output: *u8, output_cap: i64) -> i64
    if is_gzip(input, input_len)
        return gzip_decompress(input, input_len, output, output_cap)
    if is_zlib(input, input_len)
        return zlib_decompress(input, input_len, output, output_cap)
    return SQUEEZE_ERR_INVALID_HEADER


# Note: For streaming operations, use the GzipWriter/GzipReader and
# ZlibWriter/ZlibReader types from lib/gzip_stream.ritz and lib/zlib_stream.ritz.
