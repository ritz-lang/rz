# render_test.ritz - Render "Hello" to a PPM bitmap
#
# This is a standalone test that renders text using a simple built-in
# bitmap font and writes it to a PPM file for visual inspection.
#
# Uses only ritz0-compatible features (no impl blocks, no generics).

import ritzlib.sys

# ============================================================================
# Constants
# ============================================================================

const WIDTH: u32 = 200
const HEIGHT: u32 = 50
const BUFFER_SIZE: i64 = 30000  # 200 * 50 * 3 = 30000 bytes for RGB

# Colors (ARGB format)
const BG_COLOR: u32 = 0xFF2D2D2D    # Dark gray background
const TEXT_COLOR: u32 = 0xFFFFFFFF  # White text

# ============================================================================
# 5x7 Bitmap Font for Basic ASCII
# ============================================================================
# Each character is 5 pixels wide, 7 pixels tall
# Stored as 7 bytes per character (1 byte per row, bits = pixels)

# H - 0b00000 patterns for 'H' (72 = 'H', 101 = 'e', etc.)
fn get_char_row(ch: u8, row: i32) -> u8
    # Simple 5x7 bitmap font
    # Each character has 7 rows, each row is 5 bits (stored in lower 5 bits of u8)

    # 'H' = 72
    if ch as u32 == 72
        if row == 0
            return 0b10001
        if row == 1
            return 0b10001
        if row == 2
            return 0b10001
        if row == 3
            return 0b11111
        if row == 4
            return 0b10001
        if row == 5
            return 0b10001
        if row == 6
            return 0b10001
        return 0

    # 'e' = 101
    if ch as u32 == 101
        if row == 0
            return 0b00000
        if row == 1
            return 0b00000
        if row == 2
            return 0b01110
        if row == 3
            return 0b10001
        if row == 4
            return 0b11111
        if row == 5
            return 0b10000
        if row == 6
            return 0b01110
        return 0

    # 'l' = 108
    if ch as u32 == 108
        if row == 0
            return 0b01100
        if row == 1
            return 0b00100
        if row == 2
            return 0b00100
        if row == 3
            return 0b00100
        if row == 4
            return 0b00100
        if row == 5
            return 0b00100
        if row == 6
            return 0b01110
        return 0

    # 'o' = 111
    if ch as u32 == 111
        if row == 0
            return 0b00000
        if row == 1
            return 0b00000
        if row == 2
            return 0b01110
        if row == 3
            return 0b10001
        if row == 4
            return 0b10001
        if row == 5
            return 0b10001
        if row == 6
            return 0b01110
        return 0

    # ' ' = 32 (space)
    if ch as u32 == 32
        return 0

    # 'W' = 87
    if ch as u32 == 87
        if row == 0
            return 0b10001
        if row == 1
            return 0b10001
        if row == 2
            return 0b10001
        if row == 3
            return 0b10101
        if row == 4
            return 0b10101
        if row == 5
            return 0b10101
        if row == 6
            return 0b01010
        return 0

    # 'r' = 114
    if ch as u32 == 114
        if row == 0
            return 0b00000
        if row == 1
            return 0b00000
        if row == 2
            return 0b10110
        if row == 3
            return 0b11001
        if row == 4
            return 0b10000
        if row == 5
            return 0b10000
        if row == 6
            return 0b10000
        return 0

    # 'd' = 100
    if ch as u32 == 100
        if row == 0
            return 0b00001
        if row == 1
            return 0b00001
        if row == 2
            return 0b01101
        if row == 3
            return 0b10011
        if row == 4
            return 0b10001
        if row == 5
            return 0b10011
        if row == 6
            return 0b01101
        return 0

    # '!' = 33
    if ch as u32 == 33
        if row == 0
            return 0b00100
        if row == 1
            return 0b00100
        if row == 2
            return 0b00100
        if row == 3
            return 0b00100
        if row == 4
            return 0b00100
        if row == 5
            return 0b00000
        if row == 6
            return 0b00100
        return 0

    # Unknown character - return block
    return 0b11111

# ============================================================================
# Pixel buffer operations
# ============================================================================

fn set_pixel(buffer: *u8, x: u32, y: u32, color: u32)
    if x >= WIDTH || y >= HEIGHT
        return

    let offset: i64 = ((y * WIDTH + x) * 3) as i64
    let r: u8 = ((color >> 16) / 256 * 256 + (color >> 16) % 256) as u8
    let g: u8 = ((color >> 8) % 256) as u8
    let b: u8 = (color % 256) as u8

    # Correct extraction
    *(buffer + offset) = ((color >> 16) as u32 % 256) as u8      # R
    *(buffer + offset + 1) = ((color >> 8) as u32 % 256) as u8   # G
    *(buffer + offset + 2) = (color as u32 % 256) as u8          # B

fn fill_rect(buffer: *u8, x: u32, y: u32, w: u32, h: u32, color: u32)
    var py: u32 = 0
    while py < h
        var px: u32 = 0
        while px < w
            set_pixel(buffer, x + px, y + py, color)
            px = px + 1
        py = py + 1

fn draw_char(buffer: *u8, ch: u8, x: u32, y: u32, color: u32, scale: u32)
    var row: i32 = 0
    while row < 7
        let row_bits: u8 = get_char_row(ch, row)
        var col: i32 = 0
        while col < 5
            # Check if bit is set (MSB first)
            let bit_pos: i32 = 4 - col
            let mask: u8 = 1
            var shifted: u8 = mask
            var i: i32 = 0
            while i < bit_pos
                shifted = shifted * 2
                i = i + 1

            if (row_bits as u32 / shifted as u32) % 2 == 1
                # Draw a scaled pixel
                var sy: u32 = 0
                while sy < scale
                    var sx: u32 = 0
                    while sx < scale
                        set_pixel(buffer, x + col as u32 * scale + sx, y + row as u32 * scale + sy, color)
                        sx = sx + 1
                    sy = sy + 1
            col = col + 1
        row = row + 1

fn draw_string(buffer: *u8, text: *u8, text_len: i64, x: u32, y: u32, color: u32, scale: u32)
    var cursor_x: u32 = x
    var i: i64 = 0
    while i < text_len
        let ch: u8 = *(text + i)
        draw_char(buffer, ch, cursor_x, y, color, scale)
        cursor_x = cursor_x + (6 * scale)  # 5 pixels + 1 pixel gap
        i = i + 1

# ============================================================================
# PPM file writing
# ============================================================================

fn write_ppm_header(fd: i32, width: u32, height: u32)
    # Write "P6\n"
    var header: [3]u8
    header[0] = 80   # 'P'
    header[1] = 54   # '6'
    header[2] = 10   # '\n'
    sys_write(fd, @header[0], 3)

    # Write width
    write_number(fd, width)

    # Write space
    var space: u8 = 32
    sys_write(fd, @space, 1)

    # Write height
    write_number(fd, height)

    # Write "\n255\n"
    var trailer: [5]u8
    trailer[0] = 10   # '\n'
    trailer[1] = 50   # '2'
    trailer[2] = 53   # '5'
    trailer[3] = 53   # '5'
    trailer[4] = 10   # '\n'
    sys_write(fd, @trailer[0], 5)

fn write_number(fd: i32, n: u32)
    if n == 0
        var zero: u8 = 48  # '0'
        sys_write(fd, @zero, 1)
        return

    # Count digits and build buffer
    var buf: [10]u8
    var temp: u32 = n
    var count: i64 = 0

    while temp > 0
        buf[count] = (48 + (temp % 10)) as u8  # '0' + digit
        temp = temp / 10
        count = count + 1

    # Write digits in reverse order
    while count > 0
        count = count - 1
        sys_write(fd, @buf[count], 1)

# ============================================================================
# Main
# ============================================================================

pub fn main() -> i32
    # Allocate pixel buffer using mmap (RGB format, 3 bytes per pixel)
    let buffer: *u8 = sys_mmap(0, BUFFER_SIZE, 3, 34, -1, 0)  # PROT_READ|PROT_WRITE, MAP_PRIVATE|MAP_ANONYMOUS
    if buffer as i64 < 0
        return 1

    # Fill background
    fill_rect(buffer, 0, 0, WIDTH, HEIGHT, BG_COLOR)

    # Draw "Hello World!" at scale 2 (each font pixel = 2x2 screen pixels)
    # 5x7 font * 2 scale = 10x14 pixels per character
    # Position: centered vertically, starting at x=10

    # "Hello World!" - stored as bytes
    var text: [12]u8
    text[0] = 72    # 'H'
    text[1] = 101   # 'e'
    text[2] = 108   # 'l'
    text[3] = 108   # 'l'
    text[4] = 111   # 'o'
    text[5] = 32    # ' '
    text[6] = 87    # 'W'
    text[7] = 111   # 'o'
    text[8] = 114   # 'r'
    text[9] = 108   # 'l'
    text[10] = 100  # 'd'
    text[11] = 33   # '!'

    draw_string(buffer, @text[0], 12, 10, 18, TEXT_COLOR, 2)

    # Open output file
    # O_WRONLY | O_CREAT | O_TRUNC = 1 + 64 + 512 = 577
    var path: [32]u8
    path[0] = 104   # 'h'
    path[1] = 101   # 'e'
    path[2] = 108   # 'l'
    path[3] = 108   # 'l'
    path[4] = 111   # 'o'
    path[5] = 46    # '.'
    path[6] = 112   # 'p'
    path[7] = 112   # 'p'
    path[8] = 109   # 'm'
    path[9] = 0     # null terminator

    let fd: i32 = sys_open3(@path[0], 577, 420)  # 0644 octal = 420
    if fd < 0
        sys_munmap(buffer, BUFFER_SIZE)
        return 2

    # Write PPM header
    write_ppm_header(fd, WIDTH, HEIGHT)

    # Write pixel data
    sys_write(fd, buffer, BUFFER_SIZE)

    # Cleanup
    sys_close(fd)
    sys_munmap(buffer, BUFFER_SIZE)

    return 0
