# simple_test.ritz - Standalone tests without ritzunit framework
#
# Each test is a function that returns 0 for PASS, non-zero for FAIL.
# We'll run these directly without the ritzunit test runner.

import ritzlib.sys

# ============================================================================
# Test: Point creation and access
# ============================================================================

struct Point
    x: i32
    y: i32

fn test_point_creation() -> i32
    let p = Point { x: 10, y: 20 }
    if p.x != 10
        return 1
    if p.y != 20
        return 2
    0

fn test_point_zero() -> i32
    let p = Point { x: 0, y: 0 }
    if p.x != 0
        return 1
    if p.y != 0
        return 2
    0

# ============================================================================
# Test: Size struct
# ============================================================================

struct Size
    width: u32
    height: u32

fn test_size_creation() -> i32
    let s = Size { width: 800, height: 600 }
    if s.width != 800
        return 1
    if s.height != 600
        return 2
    0

fn test_size_area() -> i32
    let s = Size { width: 10, height: 20 }
    let area = s.width * s.height
    if area != 200
        return 1
    0

# ============================================================================
# Test: Rect struct
# ============================================================================

struct Rect
    x: i32
    y: i32
    width: u32
    height: u32

fn test_rect_creation() -> i32
    let r = Rect { x: 10, y: 20, width: 100, height: 50 }
    if r.x != 10
        return 1
    if r.y != 20
        return 2
    if r.width != 100
        return 3
    if r.height != 50
        return 4
    0

fn test_rect_contains_point() -> i32
    let r = Rect { x: 0, y: 0, width: 100, height: 100 }
    
    # Point inside
    let px: i32 = 50
    let py: i32 = 50
    if px < r.x or px >= r.x + r.width as i32
        return 1
    if py < r.y or py >= r.y + r.height as i32
        return 2
    
    # Point outside (should fail the contains check)
    let ox: i32 = 150
    if ox >= r.x and ox < r.x + r.width as i32
        return 3  # Should NOT be inside
    
    0

# ============================================================================
# Test: Color struct (ARGB)
# ============================================================================

struct Color
    value: u32

fn color_rgb(r: u8, g: u8, b: u8) -> Color
    let rv: u32 = r as u32
    let gv: u32 = g as u32
    let bv: u32 = b as u32
    Color { value: 0xFF000000 + (rv << 16) + (gv << 8) + bv }

fn color_r(c: @Color) -> u8
    ((c.value >> 16) % 256) as u8

fn color_g(c: @Color) -> u8
    ((c.value >> 8) % 256) as u8

fn color_b(c: @Color) -> u8
    (c.value % 256) as u8

fn test_color_rgb() -> i32
    let c = color_rgb(255, 128, 64)
    if color_r(@c) as u32 != 255
        return 1
    if color_g(@c) as u32 != 128
        return 2
    if color_b(@c) as u32 != 64
        return 3
    0

fn test_color_black() -> i32
    let c = color_rgb(0, 0, 0)
    if color_r(@c) as u32 != 0
        return 1
    if color_g(@c) as u32 != 0
        return 2
    if color_b(@c) as u32 != 0
        return 3
    0

fn test_color_white() -> i32
    let c = color_rgb(255, 255, 255)
    if color_r(@c) as u32 != 255
        return 1
    if color_g(@c) as u32 != 255
        return 2
    if color_b(@c) as u32 != 255
        return 3
    0

# ============================================================================
# Test: DamageRegion - accumulates dirty rectangles
# ============================================================================

struct DamageRegion
    rects: [16]Rect  # Fixed-size array of damage rects
    count: u32       # Number of valid rects

fn damage_region_new() -> DamageRegion
    DamageRegion {
        rects: [Rect { x: 0, y: 0, width: 0, height: 0 }; 16],
        count: 0
    }

fn damage_region_add(region:& DamageRegion, r: Rect)
    if region.count < 16
        region.rects[region.count as i64] = r
        region.count = region.count + 1

fn damage_region_clear(region:& DamageRegion)
    region.count = 0

fn damage_region_is_empty(region: @DamageRegion) -> bool
    region.count == 0

fn rects_intersect(a: @Rect, b: @Rect) -> bool
    # Two rects intersect if they overlap in both x and y
    let a_right = a.x + a.width as i32
    let a_bottom = a.y + a.height as i32
    let b_right = b.x + b.width as i32
    let b_bottom = b.y + b.height as i32

    a.x < b_right and a_right > b.x and a.y < b_bottom and a_bottom > b.y

fn min_i32(a: i32, b: i32) -> i32
    if a < b
        return a
    b

fn max_i32(a: i32, b: i32) -> i32
    if a > b
        return a
    b

fn rect_union(a: @Rect, b: @Rect) -> Rect
    let min_x = min_i32(a.x, b.x)
    let min_y = min_i32(a.y, b.y)
    let a_right = a.x + a.width as i32
    let b_right = b.x + b.width as i32
    let a_bottom = a.y + a.height as i32
    let b_bottom = b.y + b.height as i32
    let max_x = max_i32(a_right, b_right)
    let max_y = max_i32(a_bottom, b_bottom)

    Rect {
        x: min_x,
        y: min_y,
        width: (max_x - min_x) as u32,
        height: (max_y - min_y) as u32
    }

fn damage_region_bounds(region: @DamageRegion) -> Rect
    if region.count == 0
        return Rect { x: 0, y: 0, width: 0, height: 0 }

    var bounds = region.rects[0]
    var i: u32 = 1
    while i < region.count
        bounds = rect_union(@bounds, @region.rects[i as i64])
        i = i + 1
    bounds

fn test_damage_region_new() -> i32
    let region = damage_region_new()
    if region.count != 0
        return 1
    if not damage_region_is_empty(@region)
        return 2
    0

fn test_damage_region_add() -> i32
    var region = damage_region_new()
    let r = Rect { x: 10, y: 20, width: 30, height: 40 }

    # Add rect
    region.rects[region.count as i64] = r
    region.count = region.count + 1

    if region.count != 1
        return 1
    if region.count == 0
        return 2
    if region.rects[0].x != 10
        return 3
    if region.rects[0].y != 20
        return 4
    0

fn test_damage_region_clear() -> i32
    var region = damage_region_new()

    # Add two rects directly
    region.rects[0] = Rect { x: 0, y: 0, width: 10, height: 10 }
    region.count = 1
    region.rects[1] = Rect { x: 20, y: 20, width: 10, height: 10 }
    region.count = 2

    if region.count != 2
        return 1

    # Clear
    region.count = 0

    if region.count != 0
        return 2
    if region.count != 0  # is_empty check
        return 3
    0

fn test_rects_intersect() -> i32
    let a = Rect { x: 0, y: 0, width: 100, height: 100 }
    let b = Rect { x: 50, y: 50, width: 100, height: 100 }
    let c = Rect { x: 200, y: 200, width: 10, height: 10 }

    # a and b overlap
    if not rects_intersect(@a, @b)
        return 1

    # a and c don't overlap
    if rects_intersect(@a, @c)
        return 2

    # b and c don't overlap
    if rects_intersect(@b, @c)
        return 3

    0

fn test_rect_union() -> i32
    let a = Rect { x: 0, y: 0, width: 50, height: 50 }
    let b = Rect { x: 25, y: 25, width: 50, height: 50 }

    let u = rect_union(@a, @b)

    if u.x != 0
        return 1
    if u.y != 0
        return 2
    if u.width != 75
        return 3
    if u.height != 75
        return 4
    0

fn test_damage_region_bounds() -> i32
    var region = damage_region_new()

    # Add rects directly
    region.rects[0] = Rect { x: 10, y: 10, width: 20, height: 20 }
    region.rects[1] = Rect { x: 50, y: 50, width: 30, height: 30 }
    region.count = 2

    let bounds = damage_region_bounds(@region)

    # Bounds should encompass both rects: (10,10) to (80,80)
    if bounds.x != 10
        return 1
    if bounds.y != 10
        return 2
    if bounds.width != 70  # 80 - 10
        return 3
    if bounds.height != 70  # 80 - 10
        return 4
    0

# ============================================================================
# Main - run all tests
# ============================================================================

fn print_result(name: *u8, result: i32)
    if result == 0
        sys_write(1, name, 30)
        sys_write(1, c" PASS\n", 6)
    else
        sys_write(1, name, 30)
        sys_write(1, c" FAIL (", 7)
        # Print error code
        var buf: [10]u8
        var n: i32 = result
        var i: i64 = 0
        if n == 0
            buf[0] = 48  # '0'
            i = 1
        else
            while n > 0
                buf[i] = (48 + (n % 10)) as u8
                n = n / 10
                i = i + 1
            # Reverse
            var j: i64 = 0
            while j < i / 2
                let tmp = buf[j]
                buf[j] = buf[i - 1 - j]
                buf[i - 1 - j] = tmp
                j = j + 1
        sys_write(1, @buf[0], i)
        sys_write(1, c")\n", 2)

pub fn main() -> i32
    var failed: i32 = 0
    var total: i32 = 0
    var result: i32 = 0
    
    sys_write(1, c"\n=== Prism Core Tests ===\n\n", 27)
    
    result = test_point_creation()
    print_result(c"test_point_creation       ", result)
    if result != 0
        failed = failed + 1
    total = total + 1
    
    result = test_point_zero()
    print_result(c"test_point_zero           ", result)
    if result != 0
        failed = failed + 1
    total = total + 1
    
    result = test_size_creation()
    print_result(c"test_size_creation        ", result)
    if result != 0
        failed = failed + 1
    total = total + 1
    
    result = test_size_area()
    print_result(c"test_size_area            ", result)
    if result != 0
        failed = failed + 1
    total = total + 1
    
    result = test_rect_creation()
    print_result(c"test_rect_creation        ", result)
    if result != 0
        failed = failed + 1
    total = total + 1
    
    result = test_rect_contains_point()
    print_result(c"test_rect_contains_point  ", result)
    if result != 0
        failed = failed + 1
    total = total + 1
    
    result = test_color_rgb()
    print_result(c"test_color_rgb            ", result)
    if result != 0
        failed = failed + 1
    total = total + 1
    
    result = test_color_black()
    print_result(c"test_color_black          ", result)
    if result != 0
        failed = failed + 1
    total = total + 1
    
    result = test_color_white()
    print_result(c"test_color_white          ", result)
    if result != 0
        failed = failed + 1
    total = total + 1
    
    # Damage region tests
    result = test_damage_region_new()
    print_result(c"test_damage_region_new    ", result)
    if result != 0
        failed = failed + 1
    total = total + 1

    result = test_damage_region_add()
    print_result(c"test_damage_region_add    ", result)
    if result != 0
        failed = failed + 1
    total = total + 1

    result = test_damage_region_clear()
    print_result(c"test_damage_region_clear  ", result)
    if result != 0
        failed = failed + 1
    total = total + 1

    result = test_rects_intersect()
    print_result(c"test_rects_intersect      ", result)
    if result != 0
        failed = failed + 1
    total = total + 1

    result = test_rect_union()
    print_result(c"test_rect_union           ", result)
    if result != 0
        failed = failed + 1
    total = total + 1

    result = test_damage_region_bounds()
    print_result(c"test_damage_region_bounds ", result)
    if result != 0
        failed = failed + 1
    total = total + 1

    sys_write(1, c"\n--------------------------\n", 28)
    if failed == 0
        sys_write(1, c"All tests passed!\n\n", 19)
    else
        sys_write(1, c"Some tests failed!\n\n", 20)

    failed
