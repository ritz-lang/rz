# Prism Core Tests
#
# Basic tests for core types that don't depend on external libraries.
# These tests can run standalone to verify the build system works.

import ritzlib.sys

# ============================================================================
# Type definitions
# ============================================================================

struct Point
    x: i32
    y: i32

struct Size
    width: u32
    height: u32

struct Rect
    x: i32
    y: i32
    width: u32
    height: u32

struct Color
    value: u32

# ============================================================================
# Helper functions
# ============================================================================

fn point_zero() -> Point
    var p: Point
    p.x = 0
    p.y = 0
    return p

fn point_new(x: i32, y: i32) -> Point
    var p: Point
    p.x = x
    p.y = y
    return p

fn point_add(a: Point, b: Point) -> Point
    var p: Point
    p.x = a.x + b.x
    p.y = a.y + b.y
    return p

fn size_area(s: *Size) -> u32
    return s.width * s.height

fn rect_contains_point(r: *Rect, px: i32, py: i32) -> i32
    if px >= r.x && px < r.x + r.width as i32
        if py >= r.y && py < r.y + r.height as i32
            return 1
    return 0

fn rect_intersects(a: *Rect, b: *Rect) -> i32
    if a.x < b.x + b.width as i32
        if a.x + a.width as i32 > b.x
            if a.y < b.y + b.height as i32
                if a.y + a.height as i32 > b.y
                    return 1
    return 0

fn max_i32(a: i32, b: i32) -> i32
    if a > b
        return a
    return b

fn min_i32(a: i32, b: i32) -> i32
    if a < b
        return a
    return b

fn rect_intersection(a: *Rect, b: *Rect, out: *Rect)
    let x1: i32 = max_i32(a.x, b.x)
    let y1: i32 = max_i32(a.y, b.y)
    let x2: i32 = min_i32(a.x + a.width as i32, b.x + b.width as i32)
    let y2: i32 = min_i32(a.y + a.height as i32, b.y + b.height as i32)

    if x2 <= x1 || y2 <= y1
        out.x = 0
        out.y = 0
        out.width = 0
        out.height = 0
    else
        out.x = x1
        out.y = y1
        out.width = (x2 - x1) as u32
        out.height = (y2 - y1) as u32

fn color_rgb(r: u8, g: u8, b: u8) -> Color
    return color_rgba(r, g, b, 255)

fn color_rgba(r: u8, g: u8, b: u8, a: u8) -> Color
    # Use + since bits don't overlap (each shifted to different position)
    let value: u32 = ((a as u32) << 24) + ((r as u32) << 16) + ((g as u32) << 8) + (b as u32)
    var c: Color
    c.value = value
    return c

fn color_r(c: *Color) -> u8
    return ((c.value >> 16) & 0xFF) as u8

fn color_g(c: *Color) -> u8
    return ((c.value >> 8) & 0xFF) as u8

fn color_b(c: *Color) -> u8
    return (c.value & 0xFF) as u8

fn color_a(c: *Color) -> u8
    return ((c.value >> 24) & 0xFF) as u8

fn prism_color_black() -> Color
    return color_rgb(0, 0, 0)

fn prism_color_white() -> Color
    return color_rgb(255, 255, 255)

fn prism_color_red() -> Color
    return color_rgb(255, 0, 0)

fn color_from_argb(value: u32) -> Color
    var c: Color
    c.value = value
    return c

fn color_lerp(a: *Color, b: *Color, t: u8) -> Color
    let t32: u32 = t as u32
    let inv_t: u32 = 255 - t32

    let r: u32 = ((color_r(a) as u32 * inv_t) + (color_r(b) as u32 * t32)) / 255
    let g: u32 = ((color_g(a) as u32 * inv_t) + (color_g(b) as u32 * t32)) / 255
    let b_val: u32 = ((color_b(a) as u32 * inv_t) + (color_b(b) as u32 * t32)) / 255
    let alpha: u32 = ((color_a(a) as u32 * inv_t) + (color_a(b) as u32 * t32)) / 255

    return color_rgba(r as u8, g as u8, b_val as u8, alpha as u8)

# ============================================================================
# Point Tests
# ============================================================================

[[test]]
fn test_point_creation() -> i32
    let p: Point = point_new(10, 20)
    if p.x != 10
        return 1
    if p.y != 20
        return 2
    return 0

[[test]]
fn test_point_zero() -> i32
    let p: Point = point_zero()
    if p.x != 0
        return 1
    if p.y != 0
        return 2
    return 0

[[test]]
fn test_point_add() -> i32
    let a: Point = point_new(10, 20)
    let b: Point = point_new(5, 15)
    let c: Point = point_add(a, b)
    if c.x != 15
        return 1
    if c.y != 35
        return 2
    return 0

# ============================================================================
# Size Tests
# ============================================================================

[[test]]
fn test_size_creation() -> i32
    var s: Size
    s.width = 100
    s.height = 200
    if s.width != 100
        return 1
    if s.height != 200
        return 2
    return 0

[[test]]
fn test_size_area() -> i32
    var s: Size
    s.width = 10
    s.height = 20
    if size_area(&s) != 200
        return 1
    return 0

# ============================================================================
# Rect Tests
# ============================================================================

[[test]]
fn test_rect_creation() -> i32
    var r: Rect
    r.x = 10
    r.y = 20
    r.width = 100
    r.height = 50
    if r.x != 10
        return 1
    if r.y != 20
        return 2
    if r.width != 100
        return 3
    if r.height != 50
        return 4
    return 0

[[test]]
fn test_rect_contains_point() -> i32
    var r: Rect
    r.x = 10
    r.y = 10
    r.width = 100
    r.height = 100

    # Point inside
    if rect_contains_point(&r, 50, 50) != 1
        return 1

    # Point outside (left)
    if rect_contains_point(&r, 5, 50) != 0
        return 2

    # Point outside (right)
    if rect_contains_point(&r, 150, 50) != 0
        return 3

    # Point on edge (should be inside)
    if rect_contains_point(&r, 10, 10) != 1
        return 4

    return 0

[[test]]
fn test_rect_intersects() -> i32
    var a: Rect
    a.x = 0
    a.y = 0
    a.width = 100
    a.height = 100

    var b: Rect
    b.x = 50
    b.y = 50
    b.width = 100
    b.height = 100

    var c: Rect
    c.x = 200
    c.y = 200
    c.width = 50
    c.height = 50

    # a and b overlap
    if rect_intersects(&a, &b) != 1
        return 1

    # a and c don't overlap
    if rect_intersects(&a, &c) != 0
        return 2

    return 0

[[test]]
fn test_rect_intersection() -> i32
    var a: Rect
    a.x = 0
    a.y = 0
    a.width = 100
    a.height = 100

    var b: Rect
    b.x = 50
    b.y = 50
    b.width = 100
    b.height = 100

    var i: Rect
    rect_intersection(&a, &b, &i)

    if i.x != 50
        return 1
    if i.y != 50
        return 2
    if i.width != 50
        return 3
    if i.height != 50
        return 4

    return 0

# ============================================================================
# Color Tests
# ============================================================================

[[test]]
fn test_color_rgb() -> i32
    var c: Color = color_rgb(255, 128, 64)
    # Cast to u32 before comparison to avoid sign extension issues
    if color_r(&c) as u32 != 255
        return 1
    if color_g(&c) as u32 != 128
        return 2
    if color_b(&c) as u32 != 64
        return 3
    if color_a(&c) as u32 != 255
        return 4
    return 0

[[test]]
fn test_color_rgba() -> i32
    var c: Color = color_rgba(100, 150, 200, 128)
    # Cast to u32 before comparison to avoid sign extension issues
    if color_r(&c) as u32 != 100
        return 1
    if color_g(&c) as u32 != 150
        return 2
    if color_b(&c) as u32 != 200
        return 3
    if color_a(&c) as u32 != 128
        return 4
    return 0

[[test]]
fn test_color_predefined() -> i32
    var black: Color = prism_color_black()
    var white: Color = prism_color_white()
    var red: Color = prism_color_red()

    # Cast to u32 before comparison to avoid sign extension issues
    if color_r(&black) as u32 != 0 || color_g(&black) as u32 != 0 || color_b(&black) as u32 != 0
        return 1

    if color_r(&white) as u32 != 255 || color_g(&white) as u32 != 255 || color_b(&white) as u32 != 255
        return 2

    if color_r(&red) as u32 != 255 || color_g(&red) as u32 != 0 || color_b(&red) as u32 != 0
        return 3

    return 0

[[test]]
fn test_color_argb_packing() -> i32
    var c: Color = color_rgba(0xAA, 0xBB, 0xCC, 0xDD)
    let packed: u32 = c.value

    # ARGB format: 0xDDAABBCC
    if packed != 0xDDAABBCC
        return 1

    # Round-trip - cast to u32 to avoid sign extension issues
    var unpacked: Color = color_from_argb(packed)
    if color_r(&unpacked) as u32 != 0xAA
        return 2
    if color_g(&unpacked) as u32 != 0xBB
        return 3
    if color_b(&unpacked) as u32 != 0xCC
        return 4
    if color_a(&unpacked) as u32 != 0xDD
        return 5

    return 0

[[test]]
fn test_color_lerp() -> i32
    var black: Color = color_rgb(0, 0, 0)
    var white: Color = color_rgb(255, 255, 255)

    # 50% blend should give gray
    var gray: Color = color_lerp(&black, &white, 128)

    # Should be approximately 127-128
    # Cast to u32 to avoid sign extension issues
    let r: u32 = color_r(&gray) as u32
    if r < 125 || r > 130
        return 1

    return 0
