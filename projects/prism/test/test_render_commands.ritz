# Prism - Render Command Tests
#
# Tests for StrokeRect, DrawLine, and other render commands.

import types { Rect, Point, Color, WindowId }
import compositor { Compositor }
import protocol.command { RenderCommand, CommandBuilder, StrokeRectCmd, DrawLineCmd }

[[test]]
fn test_stroke_rect_draws_outline() -> i32
    var comp = Compositor.new(200, 200)

    let win_id = comp.create_window(0, 0, 100, 100)

    # Stroke a rect with width 2
    let cmd = RenderCommand.StrokeRect(StrokeRectCmd.new(
        Rect.new(10, 10, 50, 50),
        Color.red(),
        2
    ))
    comp.process_command(win_id, cmd)
    comp.render_frame()

    let backend = comp.backend()

    # Top edge should be red
    let top_edge = backend.color_at(35, 10)
    assert top_edge.r == 255
    assert top_edge.g == 0
    assert top_edge.b == 0

    # Left edge should be red
    let left_edge = backend.color_at(10, 35)
    assert left_edge.r == 255

    # Center should be black (not filled)
    let center = backend.color_at(35, 35)
    assert center.r == 0
    assert center.g == 0
    assert center.b == 0

    0

[[test]]
fn test_stroke_rect_with_different_widths() -> i32
    var comp = Compositor.new(200, 200)

    let win_id = comp.create_window(0, 0, 200, 200)

    # Stroke with width 5
    let cmd = RenderCommand.StrokeRect(StrokeRectCmd.new(
        Rect.new(50, 50, 100, 100),
        Color.blue(),
        5
    ))
    comp.process_command(win_id, cmd)
    comp.render_frame()

    let backend = comp.backend()

    # Check multiple points along the stroke
    # At y=50 (top edge), pixels from x=50 to x=149 should be blue
    assert backend.color_at(50, 50).b == 255
    assert backend.color_at(100, 50).b == 255
    assert backend.color_at(149, 50).b == 255

    # Inside the stroke width (y=52) should still be blue
    assert backend.color_at(50, 52).b == 255

    # Outside stroke (y=56 in center) should be black
    assert backend.color_at(100, 100).b == 0

    0

[[test]]
fn test_draw_line_horizontal() -> i32
    var comp = Compositor.new(200, 200)

    let win_id = comp.create_window(0, 0, 200, 200)

    # Draw horizontal line
    let cmd = RenderCommand.DrawLine(DrawLineCmd.new(
        Point.new(10, 50),
        Point.new(100, 50),
        Color.green(),
        1
    ))
    comp.process_command(win_id, cmd)
    comp.render_frame()

    let backend = comp.backend()

    # Points along the line should be green
    assert backend.color_at(10, 50).g == 255
    assert backend.color_at(50, 50).g == 255
    assert backend.color_at(100, 50).g == 255

    # Points off the line should be black
    assert backend.color_at(50, 49).g == 0
    assert backend.color_at(50, 51).g == 0

    0

[[test]]
fn test_draw_line_vertical() -> i32
    var comp = Compositor.new(200, 200)

    let win_id = comp.create_window(0, 0, 200, 200)

    # Draw vertical line
    let cmd = RenderCommand.DrawLine(DrawLineCmd.new(
        Point.new(75, 20),
        Point.new(75, 150),
        Color.red(),
        1
    ))
    comp.process_command(win_id, cmd)
    comp.render_frame()

    let backend = comp.backend()

    # Points along the line should be red
    assert backend.color_at(75, 20).r == 255
    assert backend.color_at(75, 85).r == 255
    assert backend.color_at(75, 150).r == 255

    # Points off the line should be black
    assert backend.color_at(74, 85).r == 0
    assert backend.color_at(76, 85).r == 0

    0

[[test]]
fn test_draw_line_diagonal() -> i32
    var comp = Compositor.new(200, 200)

    let win_id = comp.create_window(0, 0, 200, 200)

    # Draw diagonal line from (10,10) to (90,90)
    let cmd = RenderCommand.DrawLine(DrawLineCmd.new(
        Point.new(10, 10),
        Point.new(90, 90),
        Color.white(),
        1
    ))
    comp.process_command(win_id, cmd)
    comp.render_frame()

    let backend = comp.backend()

    # Start and end points
    assert backend.color_at(10, 10).r == 255
    assert backend.color_at(90, 90).r == 255

    # Middle of diagonal (approximately 50,50)
    assert backend.color_at(50, 50).r == 255

    # Off the diagonal
    assert backend.color_at(10, 90).r == 0

    0

[[test]]
fn test_draw_thick_line() -> i32
    var comp = Compositor.new(200, 200)

    let win_id = comp.create_window(0, 0, 200, 200)

    # Draw thick horizontal line (width 6)
    let cmd = RenderCommand.DrawLine(DrawLineCmd.new(
        Point.new(20, 100),
        Point.new(180, 100),
        Color.blue(),
        6
    ))
    comp.process_command(win_id, cmd)
    comp.render_frame()

    let backend = comp.backend()

    # Center of line
    assert backend.color_at(100, 100).b == 255

    # Above and below center (within thickness)
    assert backend.color_at(100, 98).b == 255
    assert backend.color_at(100, 102).b == 255

    # Outside thickness
    assert backend.color_at(100, 95).b == 0
    assert backend.color_at(100, 105).b == 0

    0

[[test]]
fn test_multiple_render_commands() -> i32
    var comp = Compositor.new(300, 300)

    let win_id = comp.create_window(0, 0, 300, 300)

    # Fill background
    let fill = CommandBuilder.fill_rect(
        Rect.new(0, 0, 300, 300),
        Color.rgb(50, 50, 50)  # Dark gray
    )
    comp.process_command(win_id, fill)

    # Draw a stroked rectangle
    let stroke = RenderCommand.StrokeRect(StrokeRectCmd.new(
        Rect.new(50, 50, 200, 200),
        Color.white(),
        3
    ))
    comp.process_command(win_id, stroke)

    # Draw diagonal lines
    let line1 = RenderCommand.DrawLine(DrawLineCmd.new(
        Point.new(50, 50),
        Point.new(250, 250),
        Color.red(),
        2
    ))
    comp.process_command(win_id, line1)

    let line2 = RenderCommand.DrawLine(DrawLineCmd.new(
        Point.new(250, 50),
        Point.new(50, 250),
        Color.green(),
        2
    ))
    comp.process_command(win_id, line2)

    comp.render_frame()

    let backend = comp.backend()

    # Check background
    assert backend.color_at(10, 10).r == 50

    # Check stroke (top-left corner)
    assert backend.color_at(50, 50).r == 255  # White stroke

    # The intersection of diagonals at center might be either red or green
    # depending on draw order - just check it's not gray background
    let center = backend.color_at(150, 150)
    assert center.r > 50 or center.g > 50

    0
