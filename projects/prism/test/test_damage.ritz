# test_damage.ritz - Tests for damage tracking module
#
# Tests the DamageRegion and Rect types used for efficient
# screen repainting in the compositor.

import ritzlib.sys
import src.damage { Rect, DamageRegion, rect_new, rect_zero, rect_union, rect_intersection, rect_contains_point, rect_area, rect_is_empty, rects_intersect, damage_region_new, damage_region_add, damage_region_clear, damage_region_is_empty, damage_region_count, damage_region_bounds }

# ============================================================================
# Rect Tests
# ============================================================================

fn test_rect_new() -> i32
    let r = rect_new(10, 20, 100, 50)
    if r.x != 10
        return 1
    if r.y != 20
        return 2
    if r.width != 100
        return 3
    if r.height != 50
        return 4
    0

fn test_rect_zero() -> i32
    let r = rect_zero()
    if r.x != 0
        return 1
    if r.y != 0
        return 2
    if r.width != 0
        return 3
    if r.height != 0
        return 4
    0

fn test_rect_area() -> i32
    let r = rect_new(0, 0, 10, 20)
    if rect_area(@r) != 200
        return 1

    let empty = rect_zero()
    if rect_area(@empty) != 0
        return 2
    0

fn test_rect_is_empty() -> i32
    let r = rect_new(0, 0, 10, 20)
    if rect_is_empty(@r)
        return 1

    let zero_width = rect_new(0, 0, 0, 10)
    if not rect_is_empty(@zero_width)
        return 2

    let zero_height = rect_new(0, 0, 10, 0)
    if not rect_is_empty(@zero_height)
        return 3
    0

fn test_rect_contains_point_inside() -> i32
    let r = rect_new(10, 10, 100, 100)

    # Center point
    if not rect_contains_point(@r, 60, 60)
        return 1

    # Top-left corner (inclusive)
    if not rect_contains_point(@r, 10, 10)
        return 2

    # Just inside bottom-right
    if not rect_contains_point(@r, 109, 109)
        return 3
    0

fn test_rect_contains_point_outside() -> i32
    let r = rect_new(10, 10, 100, 100)

    # Before left edge
    if rect_contains_point(@r, 9, 50)
        return 1

    # After right edge (exclusive)
    if rect_contains_point(@r, 110, 50)
        return 2

    # Before top edge
    if rect_contains_point(@r, 50, 9)
        return 3

    # After bottom edge
    if rect_contains_point(@r, 50, 110)
        return 4
    0

fn test_rects_intersect_overlapping() -> i32
    let a = rect_new(0, 0, 100, 100)
    let b = rect_new(50, 50, 100, 100)

    if not rects_intersect(@a, @b)
        return 1
    if not rects_intersect(@b, @a)  # Symmetric
        return 2
    0

fn test_rects_intersect_adjacent() -> i32
    let a = rect_new(0, 0, 100, 100)
    let b = rect_new(100, 0, 100, 100)  # Exactly adjacent

    # Adjacent rects should NOT intersect (exclusive right edge)
    if rects_intersect(@a, @b)
        return 1
    0

fn test_rects_intersect_separate() -> i32
    let a = rect_new(0, 0, 50, 50)
    let b = rect_new(100, 100, 50, 50)

    if rects_intersect(@a, @b)
        return 1
    0

fn test_rect_union_overlapping() -> i32
    let a = rect_new(0, 0, 50, 50)
    let b = rect_new(25, 25, 50, 50)

    let u = rect_union(@a, @b)

    if u.x != 0
        return 1
    if u.y != 0
        return 2
    if u.width != 75
        return 3
    if u.height != 75
        return 4
    0

fn test_rect_union_separate() -> i32
    let a = rect_new(0, 0, 10, 10)
    let b = rect_new(90, 90, 10, 10)

    let u = rect_union(@a, @b)

    if u.x != 0
        return 1
    if u.y != 0
        return 2
    if u.width != 100
        return 3
    if u.height != 100
        return 4
    0

fn test_rect_intersection_overlapping() -> i32
    let a = rect_new(0, 0, 100, 100)
    let b = rect_new(50, 50, 100, 100)

    let i = rect_intersection(@a, @b)

    if i.x != 50
        return 1
    if i.y != 50
        return 2
    if i.width != 50
        return 3
    if i.height != 50
        return 4
    0

fn test_rect_intersection_no_overlap() -> i32
    let a = rect_new(0, 0, 50, 50)
    let b = rect_new(100, 100, 50, 50)

    let i = rect_intersection(@a, @b)

    if not rect_is_empty(@i)
        return 1
    0

# ============================================================================
# DamageRegion Tests
# ============================================================================

fn test_damage_region_new_empty() -> i32
    let region = damage_region_new()

    if not damage_region_is_empty(@region)
        return 1
    if damage_region_count(@region) != 0
        return 2
    0

fn test_damage_region_add_single() -> i32
    var region = damage_region_new()
    let r = rect_new(10, 20, 30, 40)

    region.rects[0] = r
    region.count = 1

    if damage_region_is_empty(@region)
        return 1
    if damage_region_count(@region) != 1
        return 2
    if region.rects[0].x != 10
        return 3
    0

fn test_damage_region_add_multiple() -> i32
    var region = damage_region_new()

    region.rects[0] = rect_new(0, 0, 10, 10)
    region.rects[1] = rect_new(20, 20, 10, 10)
    region.rects[2] = rect_new(40, 40, 10, 10)
    region.count = 3

    if damage_region_count(@region) != 3
        return 1
    0

fn test_damage_region_clear_removes_all() -> i32
    var region = damage_region_new()

    region.rects[0] = rect_new(0, 0, 10, 10)
    region.rects[1] = rect_new(20, 20, 10, 10)
    region.count = 2

    region.count = 0  # Clear

    if not damage_region_is_empty(@region)
        return 1
    if damage_region_count(@region) != 0
        return 2
    0

fn test_damage_region_bounds_single() -> i32
    var region = damage_region_new()
    region.rects[0] = rect_new(10, 20, 30, 40)
    region.count = 1

    let bounds = damage_region_bounds(@region)

    if bounds.x != 10
        return 1
    if bounds.y != 20
        return 2
    if bounds.width != 30
        return 3
    if bounds.height != 40
        return 4
    0

fn test_damage_region_bounds_multiple() -> i32
    var region = damage_region_new()
    region.rects[0] = rect_new(10, 10, 20, 20)  # 10,10 to 30,30
    region.rects[1] = rect_new(50, 50, 30, 30)  # 50,50 to 80,80
    region.count = 2

    let bounds = damage_region_bounds(@region)

    # Should be 10,10 to 80,80 = 70x70
    if bounds.x != 10
        return 1
    if bounds.y != 10
        return 2
    if bounds.width != 70
        return 3
    if bounds.height != 70
        return 4
    0

fn test_damage_region_bounds_empty() -> i32
    let region = damage_region_new()
    let bounds = damage_region_bounds(@region)

    if not rect_is_empty(@bounds)
        return 1
    0

# ============================================================================
# Test Runner
# ============================================================================

fn print_result(name: *u8, result: i32)
    if result == 0
        sys_write(1, name, 40)
        sys_write(1, c" PASS\n", 6)
    else
        sys_write(1, name, 40)
        sys_write(1, c" FAIL (", 7)
        var buf: [10]u8
        var n: i32 = result
        var i: i64 = 0
        if n == 0
            buf[0] = 48
            i = 1
        else
            while n > 0
                buf[i] = (48 + (n % 10)) as u8
                n = n / 10
                i = i + 1
            var j: i64 = 0
            while j < i / 2
                let tmp = buf[j]
                buf[j] = buf[i - 1 - j]
                buf[i - 1 - j] = tmp
                j = j + 1
        sys_write(1, @buf[0], i)
        sys_write(1, c")\n", 2)

pub fn main() -> i32
    var failed: i32 = 0
    var result: i32 = 0

    sys_write(1, c"\n=== Damage Tracking Tests ===\n\n", 33)

    # Rect tests
    result = test_rect_new()
    print_result(c"test_rect_new                           ", result)
    if result != 0
        failed = failed + 1

    result = test_rect_zero()
    print_result(c"test_rect_zero                          ", result)
    if result != 0
        failed = failed + 1

    result = test_rect_area()
    print_result(c"test_rect_area                          ", result)
    if result != 0
        failed = failed + 1

    result = test_rect_is_empty()
    print_result(c"test_rect_is_empty                      ", result)
    if result != 0
        failed = failed + 1

    result = test_rect_contains_point_inside()
    print_result(c"test_rect_contains_point_inside         ", result)
    if result != 0
        failed = failed + 1

    result = test_rect_contains_point_outside()
    print_result(c"test_rect_contains_point_outside        ", result)
    if result != 0
        failed = failed + 1

    result = test_rects_intersect_overlapping()
    print_result(c"test_rects_intersect_overlapping        ", result)
    if result != 0
        failed = failed + 1

    result = test_rects_intersect_adjacent()
    print_result(c"test_rects_intersect_adjacent           ", result)
    if result != 0
        failed = failed + 1

    result = test_rects_intersect_separate()
    print_result(c"test_rects_intersect_separate           ", result)
    if result != 0
        failed = failed + 1

    result = test_rect_union_overlapping()
    print_result(c"test_rect_union_overlapping             ", result)
    if result != 0
        failed = failed + 1

    result = test_rect_union_separate()
    print_result(c"test_rect_union_separate                ", result)
    if result != 0
        failed = failed + 1

    result = test_rect_intersection_overlapping()
    print_result(c"test_rect_intersection_overlapping      ", result)
    if result != 0
        failed = failed + 1

    result = test_rect_intersection_no_overlap()
    print_result(c"test_rect_intersection_no_overlap       ", result)
    if result != 0
        failed = failed + 1

    # DamageRegion tests
    result = test_damage_region_new_empty()
    print_result(c"test_damage_region_new_empty            ", result)
    if result != 0
        failed = failed + 1

    result = test_damage_region_add_single()
    print_result(c"test_damage_region_add_single           ", result)
    if result != 0
        failed = failed + 1

    result = test_damage_region_add_multiple()
    print_result(c"test_damage_region_add_multiple         ", result)
    if result != 0
        failed = failed + 1

    result = test_damage_region_clear_removes_all()
    print_result(c"test_damage_region_clear_removes_all    ", result)
    if result != 0
        failed = failed + 1

    result = test_damage_region_bounds_single()
    print_result(c"test_damage_region_bounds_single        ", result)
    if result != 0
        failed = failed + 1

    result = test_damage_region_bounds_multiple()
    print_result(c"test_damage_region_bounds_multiple      ", result)
    if result != 0
        failed = failed + 1

    result = test_damage_region_bounds_empty()
    print_result(c"test_damage_region_bounds_empty         ", result)
    if result != 0
        failed = failed + 1

    sys_write(1, c"\n----------------------------------------------\n", 48)
    if failed == 0
        sys_write(1, c"All tests passed!\n\n", 19)
    else
        sys_write(1, c"Some tests failed!\n\n", 20)

    failed
