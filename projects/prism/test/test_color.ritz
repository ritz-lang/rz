# Prism - Color Tests
#
# Unit tests for the Color type.

import types.color { Color }

[[test]]
fn test_color_rgb() -> i32
    let c = Color.rgb(255, 128, 64)
    assert c.r == 255
    assert c.g == 128
    assert c.b == 64
    assert c.a == 255  # Default alpha
    0

[[test]]
fn test_color_rgba() -> i32
    let c = Color.rgba(255, 128, 64, 128)
    assert c.r == 255
    assert c.g == 128
    assert c.b == 64
    assert c.a == 128
    0

[[test]]
fn test_color_common() -> i32
    let black = Color.black()
    assert black.r == 0 and black.g == 0 and black.b == 0 and black.a == 255

    let white = Color.white()
    assert white.r == 255 and white.g == 255 and white.b == 255 and white.a == 255

    let red = Color.red()
    assert red.r == 255 and red.g == 0 and red.b == 0 and red.a == 255

    let green = Color.green()
    assert green.r == 0 and green.g == 255 and green.b == 0 and green.a == 255

    let blue = Color.blue()
    assert blue.r == 0 and blue.g == 0 and blue.b == 255 and blue.a == 255

    let transparent = Color.transparent()
    assert transparent.a == 0

    0

[[test]]
fn test_color_to_u32() -> i32
    let c = Color.rgba(0xAA, 0xBB, 0xCC, 0xDD)
    let packed = c.to_u32()

    # Format is 0xRRGGBBAA
    assert packed == 0xAABBCCDD

    0

[[test]]
fn test_color_from_u32() -> i32
    let c = Color.from_u32(0xAABBCCDD)
    assert c.r == 0xAA
    assert c.g == 0xBB
    assert c.b == 0xCC
    assert c.a == 0xDD
    0

[[test]]
fn test_color_to_argb() -> i32
    let c = Color.rgba(0xAA, 0xBB, 0xCC, 0xDD)
    let packed = c.to_argb()

    # Format is 0xAARRGGBB
    assert packed == 0xDDAABBCC

    0

[[test]]
fn test_color_from_argb() -> i32
    let c = Color.from_argb(0xDDAABBCC)
    assert c.a == 0xDD
    assert c.r == 0xAA
    assert c.g == 0xBB
    assert c.b == 0xCC
    0

[[test]]
fn test_color_with_alpha() -> i32
    let c = Color.red().with_alpha(128)
    assert c.r == 255
    assert c.g == 0
    assert c.b == 0
    assert c.a == 128
    0

[[test]]
fn test_color_is_transparent() -> i32
    assert Color.transparent().is_transparent()
    assert not Color.red().is_transparent()
    assert not Color.rgba(0, 0, 0, 1).is_transparent()
    0

[[test]]
fn test_color_is_opaque() -> i32
    assert Color.red().is_opaque()
    assert Color.black().is_opaque()
    assert not Color.transparent().is_opaque()
    assert not Color.rgba(255, 255, 255, 254).is_opaque()
    0

[[test]]
fn test_color_blend_opaque() -> i32
    let fg = Color.red()    # Fully opaque
    let bg = Color.blue()

    let result = fg.blend_over(bg)

    # Opaque foreground should completely replace background
    assert result.r == 255
    assert result.g == 0
    assert result.b == 0

    0

[[test]]
fn test_color_blend_transparent() -> i32
    let fg = Color.transparent()
    let bg = Color.blue()

    let result = fg.blend_over(bg)

    # Transparent foreground should show background
    assert result.r == 0
    assert result.g == 0
    assert result.b == 255

    0

[[test]]
fn test_color_blend_half_alpha() -> i32
    let fg = Color.rgba(255, 0, 0, 128)  # Half-transparent red
    let bg = Color.rgba(0, 0, 255, 255)  # Opaque blue

    let result = fg.blend_over(bg)

    # Should be roughly purple (half red, half blue)
    # With 128/255 ≈ 0.5 alpha:
    # r = 255 * 0.5 + 0 * 0.5 ≈ 127
    # b = 0 * 0.5 + 255 * 0.5 ≈ 127
    assert result.r > 120 and result.r < 135
    assert result.g < 10
    assert result.b > 120 and result.b < 135

    0

[[test]]
fn test_color_lerp() -> i32
    let a = Color.black()
    let b = Color.white()

    # Midpoint should be gray
    let mid = a.lerp(b, 0.5)
    assert mid.r > 120 and mid.r < 135
    assert mid.g > 120 and mid.g < 135
    assert mid.b > 120 and mid.b < 135

    # t=0 should give a
    let at_zero = a.lerp(b, 0.0)
    assert at_zero.r == 0 and at_zero.g == 0 and at_zero.b == 0

    # t=1 should give b
    let at_one = a.lerp(b, 1.0)
    assert at_one.r == 255 and at_one.g == 255 and at_one.b == 255

    0

[[test]]
fn test_color_lerp_clamped() -> i32
    let a = Color.black()
    let b = Color.white()

    # Values outside 0-1 should be clamped
    let below = a.lerp(b, -0.5)
    assert below.r == 0

    let above = a.lerp(b, 1.5)
    assert above.r == 255

    0
