# Prism - Rectangle Tests
#
# Unit tests for the Rect type and geometric operations.

import types.rect { Point, Size, Rect }

[[test]]
fn test_point_new() -> i32
    let p = Point.new(10, 20)
    assert p.x == 10
    assert p.y == 20
    0

[[test]]
fn test_point_offset() -> i32
    let p = Point.new(10, 20)
    let q = p.offset(5, -3)
    assert q.x == 15
    assert q.y == 17
    0

[[test]]
fn test_size_area() -> i32
    let s = Size.new(10, 20)
    assert s.area() == 200
    0

[[test]]
fn test_rect_accessors() -> i32
    let r = Rect.new(10, 20, 100, 50)
    assert r.left() == 10
    assert r.top() == 20
    assert r.right() == 110
    assert r.bottom() == 70
    assert r.area() == 5000
    0

[[test]]
fn test_rect_contains_point() -> i32
    let r = Rect.new(10, 10, 100, 100)

    # Inside
    assert r.contains_point(Point.new(50, 50))
    assert r.contains_point(Point.new(10, 10))  # Top-left corner

    # Outside
    assert not r.contains_point(Point.new(5, 50))    # Left of rect
    assert not r.contains_point(Point.new(150, 50))  # Right of rect
    assert not r.contains_point(Point.new(50, 5))    # Above rect
    assert not r.contains_point(Point.new(50, 150))  # Below rect

    # Edge cases (exclusive right/bottom)
    assert not r.contains_point(Point.new(110, 50))  # On right edge
    assert not r.contains_point(Point.new(50, 110))  # On bottom edge

    0

[[test]]
fn test_rect_contains_rect() -> i32
    let outer = Rect.new(0, 0, 100, 100)
    let inner = Rect.new(10, 10, 50, 50)
    let partial = Rect.new(50, 50, 100, 100)

    assert outer.contains_rect(inner)
    assert not outer.contains_rect(partial)
    assert not inner.contains_rect(outer)

    # Rect contains itself
    assert outer.contains_rect(outer)

    0

[[test]]
fn test_rect_intersects() -> i32
    let a = Rect.new(0, 0, 50, 50)
    let b = Rect.new(25, 25, 50, 50)   # Overlaps
    let c = Rect.new(60, 60, 50, 50)   # No overlap
    let d = Rect.new(50, 0, 50, 50)    # Touching but not overlapping

    assert a.intersects(b)
    assert b.intersects(a)
    assert not a.intersects(c)
    assert not a.intersects(d)  # Touching edge is not intersection

    0

[[test]]
fn test_rect_intersection() -> i32
    let a = Rect.new(0, 0, 100, 100)
    let b = Rect.new(50, 50, 100, 100)

    let i = a.intersection(b)
    assert i.x == 50
    assert i.y == 50
    assert i.width == 50
    assert i.height == 50

    # Non-overlapping gives empty rect
    let c = Rect.new(200, 200, 50, 50)
    let empty = a.intersection(c)
    assert empty.is_empty()

    0

[[test]]
fn test_rect_union() -> i32
    let a = Rect.new(0, 0, 50, 50)
    let b = Rect.new(100, 100, 50, 50)

    let u = a.union(b)
    assert u.x == 0
    assert u.y == 0
    assert u.width == 150
    assert u.height == 150

    # Union with empty rect returns the non-empty rect
    let empty = Rect.zero()
    let u2 = a.union(empty)
    assert u2.x == a.x
    assert u2.width == a.width

    0

[[test]]
fn test_rect_inset() -> i32
    let r = Rect.new(10, 10, 100, 100)
    let inset = r.inset(5)

    assert inset.x == 15
    assert inset.y == 15
    assert inset.width == 90
    assert inset.height == 90

    # Inset larger than half the size gives empty rect
    let small = Rect.new(0, 0, 10, 10)
    let over_inset = small.inset(10)
    assert over_inset.is_empty()

    0

[[test]]
fn test_rect_outset() -> i32
    let r = Rect.new(10, 10, 100, 100)
    let outset = r.outset(5)

    assert outset.x == 5
    assert outset.y == 5
    assert outset.width == 110
    assert outset.height == 110

    0
