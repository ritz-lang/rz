# Prism - Render Commands
#
# Commands that clients send to Prism for rendering.
# Designed to be serializable for remote display support.

import types { Point, Size, Rect, Color, FontId, ImageId }

# All commands a client can send to Prism
pub enum RenderCommand
    # No operation (useful for padding/alignment)
    Nop

    # --- Primitive Drawing ---

    # Fill a rectangle with a solid color
    FillRect(FillRectCmd)

    # Stroke (outline) a rectangle
    StrokeRect(StrokeRectCmd)

    # Draw a line between two points
    DrawLine(DrawLineCmd)

    # Fill a triangle with three vertices
    FillTriangle(FillTriangleCmd)

    # --- Text Rendering ---

    # Draw text at a position (uses Angelo)
    DrawText(DrawTextCmd)

    # --- Image/Buffer Operations ---

    # Blit an image at a position
    BlitImage(BlitImageCmd)

    # Submit a client-rendered buffer with damage regions
    SubmitBuffer(SubmitBufferCmd)

    # --- Control Commands ---

    # Mark a region as needing redraw
    Invalidate(InvalidateCmd)

    # Request to close the window
    RequestClose

    # Set window title
    SetTitle(SetTitleCmd)

    # Resize request from client
    RequestResize(RequestResizeCmd)

# --- Command Structs ---

pub struct FillRectCmd
    rect: Rect
    color: Color

impl FillRectCmd
    pub fn new(rect: Rect, color: Color) -> FillRectCmd
        FillRectCmd { rect: rect, color: color }

pub struct StrokeRectCmd
    rect: Rect
    color: Color
    width: u32

impl StrokeRectCmd
    pub fn new(rect: Rect, color: Color, width: u32) -> StrokeRectCmd
        StrokeRectCmd { rect: rect, color: color, width: width }

pub struct DrawLineCmd
    from: Point
    to: Point
    color: Color
    width: u32

impl DrawLineCmd
    pub fn new(from: Point, to: Point, color: Color, width: u32) -> DrawLineCmd
        DrawLineCmd { from: from, to: to, color: color, width: width }

pub struct FillTriangleCmd
    p0: Point
    p1: Point
    p2: Point
    color: Color

impl FillTriangleCmd
    pub fn new(p0: Point, p1: Point, p2: Point, color: Color) -> FillTriangleCmd
        FillTriangleCmd { p0: p0, p1: p1, p2: p2, color: color }

pub struct DrawTextCmd
    pos: Point
    text_offset: u32    # Offset into shared text buffer
    text_len: u32       # Length of text
    font: FontId
    size: u32
    color: Color

impl DrawTextCmd
    pub fn new(pos: Point, text_offset: u32, text_len: u32, font: FontId, size: u32, color: Color) -> DrawTextCmd
        DrawTextCmd {
            pos: pos,
            text_offset: text_offset,
            text_len: text_len,
            font: font,
            size: size,
            color: color
        }

pub struct BlitImageCmd
    pos: Point
    image: ImageId
    src_rect: Rect      # Region of the image to blit (for sprite sheets)

impl BlitImageCmd
    pub fn new(pos: Point, image: ImageId, src_rect: Rect) -> BlitImageCmd
        BlitImageCmd { pos: pos, image: image, src_rect: src_rect }

pub struct SubmitBufferCmd
    damage_count: u32   # Number of damage rects following
    # Followed by damage_count Rect structures in the ringbuffer

impl SubmitBufferCmd
    pub fn new(damage_count: u32) -> SubmitBufferCmd
        SubmitBufferCmd { damage_count: damage_count }

pub struct InvalidateCmd
    region: Rect

impl InvalidateCmd
    pub fn new(region: Rect) -> InvalidateCmd
        InvalidateCmd { region: region }

pub struct SetTitleCmd
    title_offset: u32   # Offset into shared text buffer
    title_len: u32

impl SetTitleCmd
    pub fn new(title_offset: u32, title_len: u32) -> SetTitleCmd
        SetTitleCmd { title_offset: title_offset, title_len: title_len }

pub struct RequestResizeCmd
    width: u32
    height: u32

impl RequestResizeCmd
    pub fn new(width: u32, height: u32) -> RequestResizeCmd
        RequestResizeCmd { width: width, height: height }

# --- Command Builder (Convenience) ---

pub struct CommandBuilder

impl CommandBuilder
    pub fn fill_rect(rect: Rect, color: Color) -> RenderCommand
        RenderCommand.FillRect(FillRectCmd.new(rect, color))

    pub fn stroke_rect(rect: Rect, color: Color, width: u32) -> RenderCommand
        RenderCommand.StrokeRect(StrokeRectCmd.new(rect, color, width))

    pub fn draw_line(from: Point, to: Point, color: Color, width: u32) -> RenderCommand
        RenderCommand.DrawLine(DrawLineCmd.new(from, to, color, width))

    pub fn fill_triangle(p0: Point, p1: Point, p2: Point, color: Color) -> RenderCommand
        RenderCommand.FillTriangle(FillTriangleCmd.new(p0, p1, p2, color))

    pub fn invalidate(region: Rect) -> RenderCommand
        RenderCommand.Invalidate(InvalidateCmd.new(region))
