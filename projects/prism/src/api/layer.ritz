# Prism - Layer API
#
# Layers are compositing units that can have their own surfaces,
# transforms, opacity, and blend modes. Used for:
# - CSS transforms
# - Opacity
# - Fixed/sticky positioning
# - Overflow scrolling
# - Canvas/video elements

import types { Point, Size, Rect, Color }
import api.surface { SurfaceId }

# Unique identifier for a layer
pub struct LayerId
    value: u64

impl LayerId
    pub fn new(value: u64) -> LayerId
        LayerId { value: value }

    pub fn raw(self) -> u64
        self.value

    pub fn is_valid(self) -> bool
        self.value != 0

# Configuration for creating a layer
pub struct LayerConfig
    # Size of the layer's content
    width: u32
    height: u32

    # Position relative to parent layer
    x: i32
    y: i32

    # Transform origin (for CSS transform-origin)
    transform_origin_x: f32
    transform_origin_y: f32

    # Initial properties
    opacity: f32
    blend_mode: BlendMode

    # Scrolling
    scroll_offset_x: i32
    scroll_offset_y: i32
    scrollable: bool

impl LayerConfig
    pub fn new(width: u32, height: u32) -> LayerConfig
        LayerConfig {
            width: width,
            height: height,
            x: 0,
            y: 0,
            transform_origin_x: 0.5,  # center
            transform_origin_y: 0.5,  # center
            opacity: 1.0,
            blend_mode: BlendMode.Normal,
            scroll_offset_x: 0,
            scroll_offset_y: 0,
            scrollable: false
        }

    pub fn at(self, x: i32, y: i32) -> LayerConfig
        LayerConfig {
            width: self.width,
            height: self.height,
            x: x,
            y: y,
            transform_origin_x: self.transform_origin_x,
            transform_origin_y: self.transform_origin_y,
            opacity: self.opacity,
            blend_mode: self.blend_mode,
            scroll_offset_x: self.scroll_offset_x,
            scroll_offset_y: self.scroll_offset_y,
            scrollable: self.scrollable
        }

    pub fn with_opacity(self, opacity: f32) -> LayerConfig
        LayerConfig {
            width: self.width,
            height: self.height,
            x: self.x,
            y: self.y,
            transform_origin_x: self.transform_origin_x,
            transform_origin_y: self.transform_origin_y,
            opacity: opacity,
            blend_mode: self.blend_mode,
            scroll_offset_x: self.scroll_offset_x,
            scroll_offset_y: self.scroll_offset_y,
            scrollable: self.scrollable
        }

    pub fn scrollable(self) -> LayerConfig
        LayerConfig {
            width: self.width,
            height: self.height,
            x: self.x,
            y: self.y,
            transform_origin_x: self.transform_origin_x,
            transform_origin_y: self.transform_origin_y,
            opacity: self.opacity,
            blend_mode: self.blend_mode,
            scroll_offset_x: self.scroll_offset_x,
            scroll_offset_y: self.scroll_offset_y,
            scrollable: true
        }

# A compositing layer
pub struct Layer
    id: LayerId
    surface: SurfaceId

    # Geometry
    bounds: Rect

    # Transform
    transform: LayerTransform
    transform_origin: Point

    # Compositing
    opacity: f32
    blend_mode: BlendMode

    # Clipping
    clip_rect: Option<Rect>

    # Scrolling
    scroll_offset: Point
    scrollable: bool

    # Layer tree
    parent: Option<LayerId>
    children: Vec<LayerId>
    z_index: i32

impl Layer
    # Position and size
    pub fn set_position(self:&, x: i32, y: i32)
        self.bounds.x = x
        self.bounds.y = y

    pub fn set_size(self:&, width: u32, height: u32)
        self.bounds.width = width
        self.bounds.height = height

    pub fn position(self) -> Point
        Point.new(self.bounds.x, self.bounds.y)

    pub fn size(self) -> Size
        Size.new(self.bounds.width, self.bounds.height)

    # Transform
    pub fn set_transform(self:&, transform: LayerTransform)
        self.transform = transform

    pub fn clear_transform(self:&)
        self.transform = LayerTransform.identity()

    # Opacity
    pub fn set_opacity(self:&, opacity: f32)
        self.opacity = if opacity < 0.0 { 0.0 }
                      else if opacity > 1.0 { 1.0 }
                      else { opacity }

    # Blend mode
    pub fn set_blend_mode(self:&, mode: BlendMode)
        self.blend_mode = mode

    # Clipping
    pub fn set_clip(self:&, rect: Rect)
        self.clip_rect = Some(rect)

    pub fn clear_clip(self:&)
        self.clip_rect = None

    # Scrolling
    pub fn set_scroll_offset(self:&, x: i32, y: i32)
        self.scroll_offset = Point.new(x, y)

    pub fn scroll_by(self:&, dx: i32, dy: i32)
        self.scroll_offset.x += dx
        self.scroll_offset.y += dy

    # Z-ordering
    pub fn set_z_index(self:&, z: i32)
        self.z_index = z

# CSS-style blend modes
pub enum BlendMode
    Normal
    Multiply
    Screen
    Overlay
    Darken
    Lighten
    ColorDodge
    ColorBurn
    HardLight
    SoftLight
    Difference
    Exclusion
    Hue
    Saturation
    Color
    Luminosity

# Layer transform (3D capable for CSS transforms)
pub struct LayerTransform
    # 4x4 matrix stored in column-major order
    m: [16]f32

impl LayerTransform
    pub fn identity() -> LayerTransform
        var m: [16]f32 = [0.0; 16]
        m[0] = 1.0   # m11
        m[5] = 1.0   # m22
        m[10] = 1.0  # m33
        m[15] = 1.0  # m44
        LayerTransform { m: m }

    pub fn translate(x: f32, y: f32, z: f32) -> LayerTransform
        var t = LayerTransform.identity()
        t.m[12] = x
        t.m[13] = y
        t.m[14] = z
        t

    pub fn scale(sx: f32, sy: f32, sz: f32) -> LayerTransform
        var t = LayerTransform.identity()
        t.m[0] = sx
        t.m[5] = sy
        t.m[10] = sz
        t

    pub fn rotate_z(angle: f32) -> LayerTransform
        var t = LayerTransform.identity()
        let c = cos_f32(angle)
        let s = sin_f32(angle)
        t.m[0] = c
        t.m[1] = s
        t.m[4] = -s
        t.m[5] = c
        t

    # Is this just an identity transform?
    pub fn is_identity(self) -> bool
        self.m[0] == 1.0 and self.m[5] == 1.0 and self.m[10] == 1.0 and
        self.m[15] == 1.0 and self.m[12] == 0.0 and self.m[13] == 0.0 and
        self.m[14] == 0.0

    # Is this a simple 2D transform? (no 3D effects)
    pub fn is_2d(self) -> bool
        self.m[2] == 0.0 and self.m[3] == 0.0 and
        self.m[6] == 0.0 and self.m[7] == 0.0 and
        self.m[8] == 0.0 and self.m[9] == 0.0 and
        self.m[10] == 1.0 and self.m[11] == 0.0 and
        self.m[14] == 0.0 and self.m[15] == 1.0

# Placeholder for trig functions
fn cos_f32(angle: f32) -> f32
    1.0

fn sin_f32(angle: f32) -> f32
    0.0
