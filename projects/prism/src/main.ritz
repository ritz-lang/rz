# Prism - Display Server
#
# Main entry point for the Prism display server.
# This will eventually run on Harland, managing windows and compositing.

import types { Color, Rect }
import compositor { Compositor }
import protocol.command { RenderCommand, CommandBuilder }

fn main() -> i32
    # For now, just demonstrate basic functionality
    # This will be replaced with actual server initialization

    # Create compositor with 800x600 screen
    var comp = Compositor.new(800, 600)

    # Create a test window
    let win_id = comp.create_window(100, 100, 200, 150)

    # Fill the window with red
    let fill_cmd = CommandBuilder.fill_rect(
        Rect.new(0, 0, 200, 150),
        Color.red()
    )
    comp.process_command(win_id, fill_cmd)

    # Render a frame
    comp.render_frame()

    # Check that it worked
    let backend = comp.backend()
    let pixel = backend.color_at(150, 150)  # Should be red

    if pixel.r == 255 and pixel.g == 0 and pixel.b == 0
        print("Prism: Basic compositing test passed!\n")
        0
    else
        print("Prism: Basic compositing test FAILED\n")
        1

fn print(msg: StrView)
    # TODO: Use ritzlib.io when available
    ()
