# Prism - Glyph Cache
#
# Caches rasterized glyphs to avoid re-rendering.
# Uses Angelo's GlyphCache internally.

import angelo { GlyphCache as AngeloCache }
import angelo.types { GlyphCacheKey, RasterizedGlyph }
import text.font_manager { FontId }

# A cached glyph ready for blitting
pub struct CachedGlyph
    # Rasterized bitmap (alpha values 0-255)
    bitmap: Vec<u8>
    width: u32
    height: u32

    # Positioning
    bearing_x: i32  # Offset from pen position to left edge
    bearing_y: i32  # Offset from baseline to top edge

    # Advance to next glyph
    advance: u32

impl CachedGlyph
    pub fn new(rasterized: @RasterizedGlyph) -> CachedGlyph
        CachedGlyph {
            bitmap: rasterized.bitmap,
            width: rasterized.width,
            height: rasterized.height,
            bearing_x: rasterized.bearing_x,
            bearing_y: rasterized.bearing_y,
            advance: rasterized.advance
        }

    pub fn is_empty(self) -> bool
        self.width == 0 or self.height == 0

    # Get alpha value at pixel position
    pub fn alpha_at(self, x: u32, y: u32) -> u8
        if x >= self.width or y >= self.height
            return 0
        self.bitmap[(y * self.width + x) as usize]

# Glyph cache wrapping Angelo's implementation
pub struct GlyphCache
    cache: AngeloCache
    hit_count: u64
    miss_count: u64

impl GlyphCache
    pub fn new(capacity: usize) -> GlyphCache
        GlyphCache {
            cache: AngeloCache.new(capacity),
            hit_count: 0,
            miss_count: 0
        }

    pub fn with_default_size() -> GlyphCache
        GlyphCache.new(1024)

    # Create a cache key (note: Angelo uses u16 for glyph_id and size_px)
    pub fn make_key(font_id: FontId, glyph_id: u32, size_px: u32) -> GlyphCacheKey
        GlyphCacheKey.new(font_id.raw(), glyph_id as u16, size_px as u16)

    # Create a cache key with subpixel positioning
    pub fn make_key_subpixel(font_id: FontId, glyph_id: u32, size_px: u32, subpixel_x: u8) -> GlyphCacheKey
        GlyphCacheKey.with_subpixel(font_id.raw(), glyph_id as u16, size_px as u16, subpixel_x)

    # Get a glyph from cache
    pub fn get(self:&, key: GlyphCacheKey) -> Option<CachedGlyph>
        match self.cache.get(key)
            Some(glyph) =>
                self.hit_count = self.hit_count + 1
                Some(CachedGlyph.new(glyph))
            None =>
                self.miss_count = self.miss_count + 1
                None

    # Insert a glyph into cache
    pub fn insert(self:&, key: GlyphCacheKey, glyph: RasterizedGlyph)
        self.cache.insert(key, glyph)

    # Get or insert a glyph
    pub fn get_or_insert(self:&, key: GlyphCacheKey, glyph: RasterizedGlyph) -> CachedGlyph
        let cached = self.cache.get_or_insert(key, glyph)
        CachedGlyph.new(cached)

    # Cache statistics
    pub fn hit_rate(self) -> f32
        let total = self.hit_count + self.miss_count
        if total == 0
            0.0
        else
            self.hit_count as f32 / total as f32

    pub fn clear(self:&)
        self.cache.clear()
        self.hit_count = 0
        self.miss_count = 0

# Tests

[[test]]
fn test_glyph_cache_creation() -> i32
    let cache = GlyphCache.with_default_size()
    assert cache.hit_rate() < 0.01  # Should be 0 (no hits yet)
    0

[[test]]
fn test_cache_key_creation() -> i32
    let key = GlyphCache.make_key(FontId.new(1), 65, 16)
    # Just verify it doesn't crash
    0
