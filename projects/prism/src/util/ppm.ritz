# Prism - PPM Image Writer
#
# Writes pixel buffers to PPM format for debugging.
# PPM is a simple ASCII/binary image format that most image viewers can open.
#
# Format: P6 (binary PPM)
# - Header: "P6\n{width} {height}\n255\n"
# - Data: RGB bytes (no alpha)

import types { Color }

# Write a pixel buffer (ARGB u32 format) to a PPM file
pub fn write_ppm(path: StrView, pixels: @Vec<u32>, width: u32, height: u32) -> bool
    # PPM format:
    # P6
    # width height
    # 255
    # <binary RGB data>

    # TODO: Use actual file I/O when available
    # For now, this is a placeholder that shows the format

    # Header
    let header = format_header(width, height)

    # Convert ARGB to RGB bytes
    var rgb_data = Vec<u8>.with_capacity((width * height * 3) as usize)

    for i in 0..(width * height) as usize
        let argb = pixels[i]
        let r = ((argb >> 16) and 0xFF) as u8
        let g = ((argb >> 8) and 0xFF) as u8
        let b = (argb and 0xFF) as u8
        rgb_data.push(r)
        rgb_data.push(g)
        rgb_data.push(b)

    # Would write to file here
    true

# Format PPM header
fn format_header(width: u32, height: u32) -> String
    # "P6\n{width} {height}\n255\n"
    var header = String.from("P6\n")
    header.push_str(width.to_string())
    header.push_str(" ")
    header.push_str(height.to_string())
    header.push_str("\n255\n")
    header

# Write from a MockBackend's front buffer
pub fn write_ppm_from_buffer(path: StrView, buffer: @Vec<u32>, width: u32, height: u32) -> bool
    write_ppm(path, buffer, width, height)

# Generate PPM bytes (for when we can write to files)
pub fn generate_ppm_bytes(pixels: @Vec<u32>, width: u32, height: u32) -> Vec<u8>
    var result = Vec<u8>.new()

    # Header: "P6\n{width} {height}\n255\n"
    result.push_str("P6\n")
    push_number(@&result, width)
    result.push(' ' as u8)
    push_number(@&result, height)
    result.push_str("\n255\n")

    # RGB data
    for i in 0..(width * height) as usize
        let argb = pixels[i]
        result.push(((argb >> 16) and 0xFF) as u8)  # R
        result.push(((argb >> 8) and 0xFF) as u8)   # G
        result.push((argb and 0xFF) as u8)          # B

    result

# Helper to push a string to byte vec
fn push_str(vec:& Vec<u8>, s: StrView)
    for b in s.as_bytes()
        vec.push(b)

# Helper to push a number as ASCII digits
fn push_number(vec:& Vec<u8>, n: u32)
    if n == 0
        vec.push('0' as u8)
        return

    # Count digits
    var temp = n
    var digits = 0u32
    while temp > 0
        digits = digits + 1
        temp = temp / 10

    # Push digits in reverse order by building a small buffer
    var buf: [10]u8 = [0; 10]
    var i = digits
    temp = n
    while temp > 0
        i = i - 1
        buf[i as usize] = ('0' as u8) + (temp % 10) as u8
        temp = temp / 10

    for j in 0..digits as usize
        vec.push(buf[j])
