# Prism - Backend module
#
# Abstraction over display hardware. Backends provide:
# - A framebuffer to render to
# - Buffer swapping for multi-buffering
# - Display timing information

pub import backend.mock { MockBackend }
# pub import backend.virtio { VirtioGpuBackend }  # Future

import types { Size }

# Backend trait - implemented by each display backend
pub trait Backend
    # Get the display dimensions
    fn dimensions(self) -> Size

    # Get a mutable reference to the current draw buffer
    # Caller renders to this buffer
    fn get_draw_buffer(self:&) -> @&[u32]

    # Swap buffers (for double/triple buffering)
    # Called after a frame is complete
    fn swap_buffers(self:&)

    # Get the current frame number
    fn frame_count(self) -> u64

    # For testing: check if a specific pixel has a value
    fn pixel_at(self, x: u32, y: u32) -> u32
