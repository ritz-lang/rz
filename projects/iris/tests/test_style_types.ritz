# tests/test_style_types.ritz - Style types unit tests

import ritzlib.sys
import lib.style.types

# =============================================================================
# NodeId Tests
# =============================================================================

[[test]]
fn test_node_id_new() -> i32
    let id = node_id_new(42)
    if id.value != 42
        return 1
    0

[[test]]
fn test_node_id_invalid() -> i32
    let id = node_id_invalid()
    if node_id_is_valid(@id) != 0
        return 1  # Should NOT be valid
    0

[[test]]
fn test_node_id_valid() -> i32
    let id = node_id_new(1)
    if node_id_is_valid(@id) == 0
        return 1  # Should be valid
    0

# =============================================================================
# Dimension Tests
# =============================================================================

[[test]]
fn test_dimension_px() -> i32
    let d = dimension_px(100.0)
    if d.value != 100.0
        return 1
    if d.unit != UNIT_PX
        return 2
    0

[[test]]
fn test_dimension_percent() -> i32
    let d = dimension_percent(50.0)
    if d.value != 50.0
        return 1
    if d.unit != UNIT_PERCENT
        return 2
    0

[[test]]
fn test_dimension_auto() -> i32
    let d = dimension_auto()
    if dimension_is_auto(d) == 0
        return 1
    0

[[test]]
fn test_dimension_is_auto_false() -> i32
    let d = dimension_px(10.0)
    if dimension_is_auto(d) != 0
        return 1  # Should NOT be auto
    0

# =============================================================================
# Transform Tests
# =============================================================================

[[test]]
fn test_transform_identity() -> i32
    let t = transform_identity()
    if t.a != 1.0
        return 1
    if t.d != 1.0
        return 2
    if t.b != 0.0
        return 3
    if t.c != 0.0
        return 4
    if t.e != 0.0
        return 5
    if t.f != 0.0
        return 6
    0

[[test]]
fn test_transform_is_identity() -> i32
    let t = transform_identity()
    if transform_is_identity(t) == 0
        return 1
    0

[[test]]
fn test_transform_translate() -> i32
    let t = transform_translate(10.0, 20.0)
    if t.e != 10.0
        return 1
    if t.f != 20.0
        return 2
    if transform_is_identity(t) != 0
        return 3  # Should NOT be identity
    0

# =============================================================================
# ComputedStyle Tests
# =============================================================================

[[test]]
fn test_computed_style_default() -> i32
    let style = computed_style_default()

    # Check display default
    if style.display != DISPLAY_BLOCK
        return 1

    # Check position default
    if style.position != POSITION_STATIC
        return 2

    # Check opacity default
    if style.opacity != 1.0
        return 3

    # Check font size default
    if style.text.font_size != 16.0
        return 4

    0

# Tests are discovered by ritzunit via [[test]] attribute
