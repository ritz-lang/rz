# tests/test_render_tree.ritz - Render tree unit tests

import ritzlib.sys
import lib.style.types
import lib.tree.render_node

# =============================================================================
# RenderNode Tests
# =============================================================================

[[test]]
fn test_render_node_new() -> i32
    let id = node_id_new(1)
    let style = computed_style_default()
    let node = render_node_new(id, TAG_DIV, style)

    if node.id.value != 1
        return 1
    if node.tag != TAG_DIV
        return 2
    # New nodes should be fully dirty
    if dirty_flags_is_clean(node.dirty) != 0
        return 3
    0

[[test]]
fn test_render_node_new_text() -> i32
    let id = node_id_new(2)
    let style = computed_style_default()
    let text: *u8 = c"Hello"
    let node = render_node_new_text(id, text, 5, style)

    if render_node_is_text(node) == 0
        return 1
    0

# =============================================================================
# RenderTree Tests
# =============================================================================

[[test]]
fn test_render_tree_new() -> i32
    let tree = render_tree_new()
    if render_tree_is_empty(@tree) == 0
        return 1
    if render_tree_count(@tree) != 0
        return 2
    0

[[test]]
fn test_render_tree_insert_and_get() -> i32
    var tree = render_tree_new()
    let id = node_id_new(42)
    let style = computed_style_default()
    let node = render_node_new(id, TAG_SPAN, style)

    render_tree_insert(@&tree, node)

    # Create new id for lookup since original was moved into node
    let lookup_id = node_id_new(42)
    let found = render_tree_get(@tree, @lookup_id)
    if found == null
        return 1
    if found.id.value != 42
        return 2
    0

[[test]]
fn test_render_tree_set_root() -> i32
    var tree = render_tree_new()
    let id = node_id_new(1)
    let style = computed_style_default()
    let node = render_node_new(id, TAG_DIV, style)

    render_tree_insert(@&tree, node)
    # Create new id for set_root since original was moved
    render_tree_set_root(@&tree, node_id_new(1))

    let root = render_tree_root(@tree)
    if root == null
        return 1
    if root.id.value != 1
        return 2
    0

[[test]]
fn test_render_tree_count() -> i32
    var tree = render_tree_new()

    let id1 = node_id_new(1)
    let id2 = node_id_new(2)
    let style = computed_style_default()

    render_tree_insert(@&tree, render_node_new(id1, TAG_DIV, style))
    let style2 = computed_style_default()
    render_tree_insert(@&tree, render_node_new(id2, TAG_DIV, style2))

    if render_tree_count(@tree) != 2
        return 1
    0

# =============================================================================
# Dirty Flags Tests
# =============================================================================

[[test]]
fn test_dirty_flags_none() -> i32
    let flags = dirty_flags_none()
    if dirty_flags_is_clean(flags) == 0
        return 1
    0

[[test]]
fn test_dirty_flags_all() -> i32
    let flags = dirty_flags_all()
    # Check fields first since dirty_flags_is_clean consumes flags
    if flags.structure == 0
        return 2
    if flags.style == 0
        return 3
    if flags.layout == 0
        return 4
    if flags.paint == 0
        return 5
    # Now check is_clean (should fail since all dirty)
    let flags2 = dirty_flags_all()
    if dirty_flags_is_clean(flags2) != 0
        return 1
    0

[[test]]
fn test_render_tree_mark_dirty() -> i32
    var tree = render_tree_new()
    let id = node_id_new(1)
    let style = computed_style_default()
    var node = render_node_new(id, TAG_DIV, style)
    node.dirty = dirty_flags_none()  # Start clean

    render_tree_insert(@&tree, node)

    # Mark dirty (create new ids since original was moved)
    let dirty = DirtyFlags { structure: 0, style: 0, layout: 1, paint: 1 }
    render_tree_mark_dirty(@&tree, node_id_new(1), dirty)

    let lookup_id = node_id_new(1)
    let found = render_tree_get(@tree, @lookup_id)
    if found == null
        return 3
    if found.dirty.layout == 0
        return 1
    if found.dirty.paint == 0
        return 2
    0

[[test]]
fn test_render_tree_clear_dirty() -> i32
    var tree = render_tree_new()
    let id = node_id_new(1)
    let style = computed_style_default()
    let node = render_node_new(id, TAG_DIV, style)  # Starts dirty

    render_tree_insert(@&tree, node)
    render_tree_clear_dirty(@&tree, node_id_new(1))

    let lookup_id = node_id_new(1)
    let found = render_tree_get(@tree, @lookup_id)
    if found == null
        return 2
    if dirty_flags_is_clean(found.dirty) == 0
        return 1
    0

# Tests are discovered by ritzunit via [[test]] attribute
