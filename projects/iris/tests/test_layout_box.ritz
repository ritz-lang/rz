# tests/test_layout_box.ritz - Box model unit tests

import ritzlib.sys
import lib.style.types
import lib.layout.box

# =============================================================================
# Dimension Resolution Tests
# =============================================================================

[[test]]
fn test_resolve_dimension_px() -> i32
    let constraints = layout_constraints_new(800.0, 600.0, 16.0)
    let d = dimension_px(100.0)

    let resolved = resolve_dimension(@d, @constraints, 1)  # for_width=true
    if resolved != 100.0
        return 1
    0

[[test]]
fn test_resolve_dimension_percent_width() -> i32
    let constraints = layout_constraints_new(800.0, 600.0, 16.0)
    let d = dimension_percent(50.0)  # 50%

    let resolved = resolve_dimension(@d, @constraints, 1)  # for_width=true
    # 50% of 800 = 400
    if resolved != 400.0
        return 1
    0

[[test]]
fn test_resolve_dimension_percent_height() -> i32
    let constraints = layout_constraints_new(800.0, 600.0, 16.0)
    let d = dimension_percent(50.0)  # 50%

    let resolved = resolve_dimension(@d, @constraints, 0)  # for_width=false
    # 50% of 600 = 300
    if resolved != 300.0
        return 1
    0

[[test]]
fn test_resolve_dimension_auto_fallback() -> i32
    let constraints = layout_constraints_new(800.0, 600.0, 16.0)
    let d = dimension_auto()

    let resolved = resolve_dimension_or(@d, @constraints, 1, 999.0)
    if resolved != 999.0
        return 1  # Should use fallback for auto
    0

# =============================================================================
# Box Dimensions Tests
# =============================================================================

[[test]]
fn test_box_dimensions_zero() -> i32
    let box = box_dimensions_zero()
    if box.content_width != 0.0
        return 1
    if box.content_height != 0.0
        return 2
    if box.padding_top != 0.0
        return 3
    if box.margin_left != 0.0
        return 4
    0

[[test]]
fn test_box_dimensions_border_width() -> i32
    var box = box_dimensions_zero()
    box.content_width = 100.0
    box.padding_left = 10.0
    box.padding_right = 10.0
    box.border_left = 1.0
    box.border_right = 1.0

    let width = box_dimensions_border_width(@box)
    # 100 + 10 + 10 + 1 + 1 = 122
    if width != 122.0
        return 1
    0

[[test]]
fn test_box_dimensions_margin_width() -> i32
    var box = box_dimensions_zero()
    box.content_width = 100.0
    box.padding_left = 10.0
    box.padding_right = 10.0
    box.border_left = 1.0
    box.border_right = 1.0
    box.margin_left = 20.0
    box.margin_right = 20.0

    let width = box_dimensions_margin_width(@box)
    # 100 + 10 + 10 + 1 + 1 + 20 + 20 = 162
    if width != 162.0
        return 1
    0

# =============================================================================
# Box Model Resolution Tests
# =============================================================================

[[test]]
fn test_resolve_box_model_simple() -> i32
    let constraints = layout_constraints_new(800.0, 600.0, 16.0)

    var style = computed_style_default()
    style.width = dimension_px(200.0)
    style.height = dimension_px(100.0)
    style.padding = edge_sizes_all(10.0)

    let box = resolve_box_model(@style, @constraints)

    if box.content_width != 200.0
        return 1
    if box.content_height != 100.0
        return 2
    if box.padding_top != 10.0
        return 3
    if box.padding_right != 10.0
        return 4
    0

[[test]]
fn test_resolve_box_model_border_box() -> i32
    let constraints = layout_constraints_new(800.0, 600.0, 16.0)

    var style = computed_style_default()
    style.box_sizing = BOX_SIZING_BORDER_BOX
    style.width = dimension_px(200.0)  # Total width including padding/border
    style.padding = edge_sizes_all(20.0)
    style.border.top.width = 2.0
    style.border.right.width = 2.0
    style.border.bottom.width = 2.0
    style.border.left.width = 2.0

    let box = resolve_box_model(@style, @constraints)

    # Content width = 200 - (20+20) padding - (2+2) border = 156
    if box.content_width != 156.0
        return 1
    0

# Tests are discovered by ritzunit via [[test]] attribute
