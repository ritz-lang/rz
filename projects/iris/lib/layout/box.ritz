# lib/layout/box.ritz - Box model calculations
#
# Implements CSS box model: content, padding, border, margin.
# Resolves dimensions from computed styles to pixel values.

import ritzlib.sys
import lib.style.types

# =============================================================================
# Layout Constraints
# =============================================================================

# Constraints passed down during layout (available space)
pub struct LayoutConstraints
    # Available width (may be constrained or infinite)
    available_width: f64
    available_height: f64
    # Viewport size for viewport-relative units
    viewport_width: f64
    viewport_height: f64
    # Font size for em units (inherited or computed)
    font_size: f64
    # Root font size for rem units
    root_font_size: f64
    # Whether width/height is definite (not shrink-to-fit), 0 = false, 1 = true
    width_definite: i32
    height_definite: i32

pub fn layout_constraints_new(vp_width: f64, vp_height: f64, root_font_size: f64) -> LayoutConstraints
    var c: LayoutConstraints
    c.available_width = vp_width
    c.available_height = vp_height
    c.viewport_width = vp_width
    c.viewport_height = vp_height
    c.font_size = root_font_size
    c.root_font_size = root_font_size
    c.width_definite = 1
    c.height_definite = 1
    c

# =============================================================================
# Dimension Resolution
# =============================================================================

# Resolve a CSS dimension to pixels
# for_width: 1 = resolving width, 0 = resolving height (affects percentage base)
pub fn resolve_dimension(dim: @Dimension, c: @LayoutConstraints, for_width: i32) -> f64
    if dim.unit == UNIT_PX
        return dim.value
    if dim.unit == UNIT_EM
        return dim.value * c.font_size
    if dim.unit == UNIT_REM
        return dim.value * c.root_font_size
    if dim.unit == UNIT_PERCENT
        if for_width != 0
            return dim.value / 100.0 * c.available_width
        else
            return dim.value / 100.0 * c.available_height
    if dim.unit == UNIT_VW
        return dim.value / 100.0 * c.viewport_width
    if dim.unit == UNIT_VH
        return dim.value / 100.0 * c.viewport_height
    if dim.unit == UNIT_AUTO
        return 0.0  # Auto handled separately
    return 0.0

# Resolve dimension with a fallback for auto
pub fn resolve_dimension_or(dim: @Dimension, c: @LayoutConstraints, for_width: i32, fallback: f64) -> f64
    if dim.unit == UNIT_AUTO
        return fallback
    return resolve_dimension(dim, c, for_width)

# =============================================================================
# Box Size Calculation
# =============================================================================

# Computed box dimensions in pixels
pub struct BoxDimensions
    # Content area
    content_width: f64
    content_height: f64
    # Padding
    padding_top: f64
    padding_right: f64
    padding_bottom: f64
    padding_left: f64
    # Border
    border_top: f64
    border_right: f64
    border_bottom: f64
    border_left: f64
    # Margin
    margin_top: f64
    margin_right: f64
    margin_bottom: f64
    margin_left: f64

pub fn box_dimensions_zero() -> BoxDimensions
    BoxDimensions {
        content_width: 0.0, content_height: 0.0,
        padding_top: 0.0, padding_right: 0.0, padding_bottom: 0.0, padding_left: 0.0,
        border_top: 0.0, border_right: 0.0, border_bottom: 0.0, border_left: 0.0,
        margin_top: 0.0, margin_right: 0.0, margin_bottom: 0.0, margin_left: 0.0
    }

# Total width including content, padding, border
pub fn box_dimensions_border_width(b: @BoxDimensions) -> f64
    b.content_width + b.padding_left + b.padding_right + b.border_left + b.border_right

# Total height including content, padding, border
pub fn box_dimensions_border_height(b: @BoxDimensions) -> f64
    b.content_height + b.padding_top + b.padding_bottom + b.border_top + b.border_bottom

# Total width including margin
pub fn box_dimensions_margin_width(b: @BoxDimensions) -> f64
    let bw = box_dimensions_border_width(b)
    bw + b.margin_left + b.margin_right

# Total height including margin
pub fn box_dimensions_margin_height(b: @BoxDimensions) -> f64
    let bh = box_dimensions_border_height(b)
    bh + b.margin_top + b.margin_bottom

# =============================================================================
# Box Model Resolution
# =============================================================================

# Resolve padding from computed style
pub fn resolve_padding(style: @ComputedStyle, c: @LayoutConstraints) -> BoxDimensions
    var b = box_dimensions_zero()
    b.padding_top = resolve_dimension(@style.padding.top, c, 0)
    b.padding_right = resolve_dimension(@style.padding.right, c, 1)
    b.padding_bottom = resolve_dimension(@style.padding.bottom, c, 0)
    b.padding_left = resolve_dimension(@style.padding.left, c, 1)
    b

# Resolve border widths from computed style
pub fn resolve_border(style: @ComputedStyle, c: @LayoutConstraints) -> BoxDimensions
    var b = box_dimensions_zero()
    # Border widths are already in pixels in computed style
    b.border_top = style.border.top.width
    b.border_right = style.border.right.width
    b.border_bottom = style.border.bottom.width
    b.border_left = style.border.left.width
    b

# Resolve margins from computed style
pub fn resolve_margin(style: @ComputedStyle, c: @LayoutConstraints) -> BoxDimensions
    var b = box_dimensions_zero()
    b.margin_top = resolve_dimension_or(@style.margin.top, c, 0, 0.0)
    b.margin_right = resolve_dimension_or(@style.margin.right, c, 1, 0.0)
    b.margin_bottom = resolve_dimension_or(@style.margin.bottom, c, 0, 0.0)
    b.margin_left = resolve_dimension_or(@style.margin.left, c, 1, 0.0)
    b

# Resolve full box model
pub fn resolve_box_model(style: @ComputedStyle, c: @LayoutConstraints) -> BoxDimensions
    let padding = resolve_padding(style, c)
    let border = resolve_border(style, c)
    let margin = resolve_margin(style, c)

    # Calculate horizontal padding+border for width calculations
    let h_pb = padding.padding_left + padding.padding_right + border.border_left + border.border_right
    let v_pb = padding.padding_top + padding.padding_bottom + border.border_top + border.border_bottom

    # Resolve width
    var content_width: f64 = 0.0
    if style.width.unit != UNIT_AUTO
        let specified_width = resolve_dimension(@style.width, c, 1)
        if style.box_sizing == BOX_SIZING_CONTENT_BOX
            content_width = specified_width
        else
            content_width = specified_width - h_pb

    # Apply min/max width
    if style.min_width.unit != UNIT_AUTO
        let min_w = resolve_dimension(@style.min_width, c, 1)
        if content_width < min_w
            content_width = min_w
    if style.max_width.unit != UNIT_AUTO
        let max_w = resolve_dimension(@style.max_width, c, 1)
        if content_width > max_w
            content_width = max_w

    # Resolve height (similar logic)
    var content_height: f64 = 0.0
    if style.height.unit != UNIT_AUTO
        let specified_height = resolve_dimension(@style.height, c, 0)
        if style.box_sizing == BOX_SIZING_CONTENT_BOX
            content_height = specified_height
        else
            content_height = specified_height - v_pb

    # Apply min/max height
    if style.min_height.unit != UNIT_AUTO
        let min_h = resolve_dimension(@style.min_height, c, 0)
        if content_height < min_h
            content_height = min_h
    if style.max_height.unit != UNIT_AUTO
        let max_h = resolve_dimension(@style.max_height, c, 0)
        if content_height > max_h
            content_height = max_h

    BoxDimensions {
        content_width: content_width,
        content_height: content_height,
        padding_top: padding.padding_top,
        padding_right: padding.padding_right,
        padding_bottom: padding.padding_bottom,
        padding_left: padding.padding_left,
        border_top: border.border_top,
        border_right: border.border_right,
        border_bottom: border.border_bottom,
        border_left: border.border_left,
        margin_top: margin.margin_top,
        margin_right: margin.margin_right,
        margin_bottom: margin.margin_bottom,
        margin_left: margin.margin_left
    }
