        return 1
    0

[[test]]
fn test_for_loop() -> i32
    var p = parse("for (let i = 0; i < 10; i++) x")
    if expect_no_error(@p) != 0
        return 1

    let root = parser_root(@p)
    let root_node = ast_get_node(@p.ast, root)
    let stmt_idx = ast_get_child(@p.ast, root_node.children_start, 0)

    if expect_node_type(@p, stmt_idx, AST_FOR_STMT) != 0
        return 1

    let for_stmt = ast_get_node(@p.ast, stmt_idx)
    # Should have all parts
    if for_stmt.child1 == NO_CHILD
        prints("FAIL: Expected init\n")
        return 1
    if for_stmt.child2 == NO_CHILD
        prints("FAIL: Expected condition\n")
        return 1
    if for_stmt.child3 == NO_CHILD
        prints("FAIL: Expected update\n")
        return 1
    0

