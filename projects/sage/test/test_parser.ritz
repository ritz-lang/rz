# Parser Tests
# Comprehensive tests for JavaScript parsing

import ritzlib.io
import ritzlib.strview
import ritzlib.gvec
import src.token
import src.lexer
import src.ast
import src.parser

# =============================================================================
# Helper Functions
# =============================================================================

fn expect_node_type(p: @Parser, idx: i64, expected: i32) -> i32
    let node = ast_get_node(@p.ast, idx)
    if node.tag != expected
        prints("FAIL: Expected ")
        prints(ast_node_type_name(expected))
        prints(" but got ")
        prints(ast_node_type_name(node.tag))
        prints("\n")
        return 1
    0

fn expect_no_error(p: @Parser) -> i32
    if parser_had_error(p) == 1
        prints("FAIL: Parser had errors\n")
        return 1
    0

# =============================================================================
# Literal Tests
# =============================================================================

[[test]]
fn test_number_literal() -> i32
    var p = parse("42")
    if expect_no_error(@p) != 0
        return 1

    let root = parser_root(@p)
    if expect_node_type(@p, root, AST_PROGRAM) != 0
        return 1

    let root_node = ast_get_node(@p.ast, root)
    if root_node.children_count != 1
        prints("FAIL: Expected 1 statement\n")
        return 1

    let stmt_idx = ast_get_child(@p.ast, root_node.children_start, 0)
    if expect_node_type(@p, stmt_idx, AST_EXPR_STMT) != 0
        return 1

    let stmt = ast_get_node(@p.ast, stmt_idx)
    if expect_node_type(@p, stmt.child1, AST_NUMBER_LITERAL) != 0
        return 1

    let num = ast_get_node(@p.ast, stmt.child1)
    if num.num_value != 42.0
        prints("FAIL: Expected 42.0\n")
        return 1
    0

[[test]]
fn test_decimal_number() -> i32
    var p = parse("3.14159")
    if expect_no_error(@p) != 0
        return 1

    let root = parser_root(@p)
    let root_node = ast_get_node(@p.ast, root)
    let stmt_idx = ast_get_child(@p.ast, root_node.children_start, 0)
    let stmt = ast_get_node(@p.ast, stmt_idx)
    let num = ast_get_node(@p.ast, stmt.child1)

    # Check approximate equality for floating point
    if num.num_value < 3.14 or num.num_value > 3.15
        prints("FAIL: Expected ~3.14159\n")
        return 1
    0

