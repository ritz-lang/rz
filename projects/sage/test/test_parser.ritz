[[test]]
fn test_precedence_mul_over_add() -> i32
    # 2 + 3 * 4 should parse as 2 + (3 * 4)
    var p = parse("2 + 3 * 4")
    if expect_no_error(@p) != 0
        return 1

    let root = parser_root(@p)
    let root_node = ast_get_node(@p.ast, root)
    let stmt_idx = ast_get_child(@p.ast, root_node.children_start, 0)
    let stmt = ast_get_node(@p.ast, stmt_idx)

    # Root should be addition
    let add = ast_get_node(@p.ast, stmt.child1)
    if add.int_value != OP_ADD
        prints("FAIL: Expected root to be OP_ADD\n")
        return 1

    # Left should be 2
    let left = ast_get_node(@p.ast, add.child1)
    if left.tag != AST_NUMBER_LITERAL
        prints("FAIL: Expected left to be number\n")
        return 1

    # Right should be multiplication
    let right = ast_get_node(@p.ast, add.child2)
    if right.tag != AST_BINARY_EXPR or right.int_value != OP_MUL
        prints("FAIL: Expected right to be multiplication\n")
        return 1
    0

[[test]]
fn test_parentheses() -> i32
    # (2 + 3) * 4 should parse as (2 + 3) * 4
    var p = parse("(2 + 3) * 4")
    if expect_no_error(@p) != 0
        return 1

    let root = parser_root(@p)
    let root_node = ast_get_node(@p.ast, root)
    let stmt_idx = ast_get_child(@p.ast, root_node.children_start, 0)
    let stmt = ast_get_node(@p.ast, stmt_idx)

    # Root should be multiplication
    let mul = ast_get_node(@p.ast, stmt.child1)
    if mul.int_value != OP_MUL
        prints("FAIL: Expected root to be OP_MUL\n")
        return 1

    # Left should be addition
    let left = ast_get_node(@p.ast, mul.child1)
    if left.tag != AST_BINARY_EXPR or left.int_value != OP_ADD
        prints("FAIL: Expected left to be addition\n")
        return 1
    0

