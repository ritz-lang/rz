# =============================================================================
# Object Literal Tests
# =============================================================================

# Note: Empty object test skipped due to Ritz string interpolation parsing {}
# We test object with properties instead

[[test]]
fn test_object_with_property() -> i32
    # Use C string to avoid Ritz interpolation of {}
    var p = parse(strview_from_cstr(c"x = {a: 1}"))
    if expect_no_error(@p) != 0
        return 1

    let root = parser_root(@p)
    let root_node = ast_get_node(@p.ast, root)
    let stmt_idx = ast_get_child(@p.ast, root_node.children_start, 0)
    let stmt = ast_get_node(@p.ast, stmt_idx)

    # Assignment expression
    if expect_node_type(@p, stmt.child1, AST_ASSIGNMENT_EXPR) != 0
        return 1

    let assign = ast_get_node(@p.ast, stmt.child1)
    if expect_node_type(@p, assign.child2, AST_OBJECT_LITERAL) != 0
        return 1

    let obj = ast_get_node(@p.ast, assign.child2)
    if obj.children_count != 1
        prints("FAIL: Expected 1 pair\n")
        return 1
    0

# =============================================================================
# Ternary Expression Tests
# =============================================================================

[[test]]
fn test_ternary() -> i32
    var p = parse("a ? b : c")
    if expect_no_error(@p) != 0
        return 1

    let root = parser_root(@p)
    let root_node = ast_get_node(@p.ast, root)
    let stmt_idx = ast_get_child(@p.ast, root_node.children_start, 0)
    let stmt = ast_get_node(@p.ast, stmt_idx)

    if expect_node_type(@p, stmt.child1, AST_CONDITIONAL_EXPR) != 0
        return 1

    let cond = ast_get_node(@p.ast, stmt.child1)
    if expect_node_type(@p, cond.child1, AST_IDENTIFIER) != 0
        return 1
    if expect_node_type(@p, cond.child2, AST_IDENTIFIER) != 0
        return 1
    if expect_node_type(@p, cond.child3, AST_IDENTIFIER) != 0
        return 1
    0

