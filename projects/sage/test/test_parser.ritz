# =============================================================================
# Complex Expression Tests
# =============================================================================

[[test]]
fn test_complex_expression() -> i32
    # a.b().c[d] - chained access
    var p = parse("a.b().c[d]")
    if expect_no_error(@p) != 0
        return 1

    let root = parser_root(@p)
    let root_node = ast_get_node(@p.ast, root)
    let stmt_idx = ast_get_child(@p.ast, root_node.children_start, 0)
    let stmt = ast_get_node(@p.ast, stmt_idx)

    # Should be computed member access at the top
    if expect_node_type(@p, stmt.child1, AST_MEMBER_EXPR) != 0
        return 1
    0

[[test]]
fn test_operator_chaining() -> i32
    # a && b || c
    var p = parse("a && b || c")
    if expect_no_error(@p) != 0
        return 1

    let root = parser_root(@p)
    let root_node = ast_get_node(@p.ast, root)
    let stmt_idx = ast_get_child(@p.ast, root_node.children_start, 0)
    let stmt = ast_get_node(@p.ast, stmt_idx)

    # || has lower precedence, so it's at the root
    let bin = ast_get_node(@p.ast, stmt.child1)
    if bin.int_value != OP_OR
        prints("FAIL: Expected OP_OR at root\n")
        return 1

    # Left should be &&
    let left = ast_get_node(@p.ast, bin.child1)
    if left.int_value != OP_AND
        prints("FAIL: Expected OP_AND on left\n")
        return 1
    0

