    let stmt_idx = ast_get_child(@p.ast, root_node.children_start, 0)
    let stmt = ast_get_node(@p.ast, stmt_idx)

    if expect_node_type(@p, stmt.child1, AST_CALL_EXPR) != 0
        return 1
    0

[[test]]
fn test_function_with_params() -> i32
    # Test function call with params
    var p = parse("add(a, b)")
    if expect_no_error(@p) != 0
        return 1

    let root = parser_root(@p)
    let root_node = ast_get_node(@p.ast, root)
    let stmt_idx = ast_get_child(@p.ast, root_node.children_start, 0)
    let stmt = ast_get_node(@p.ast, stmt_idx)

    if expect_node_type(@p, stmt.child1, AST_CALL_EXPR) != 0
        return 1

    let call = ast_get_node(@p.ast, stmt.child1)
    if call.children_count != 2
        prints("FAIL: Expected 2 arguments\n")
        return 1
    0

