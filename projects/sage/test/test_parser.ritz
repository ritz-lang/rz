[[test]]
fn test_prefix_increment() -> i32
    var p = parse("++x")
    if expect_no_error(@p) != 0
        return 1

    let root = parser_root(@p)
    let root_node = ast_get_node(@p.ast, root)
    let stmt_idx = ast_get_child(@p.ast, root_node.children_start, 0)
    let stmt = ast_get_node(@p.ast, stmt_idx)

    if expect_node_type(@p, stmt.child1, AST_UPDATE_EXPR) != 0
        return 1

    let update = ast_get_node(@p.ast, stmt.child1)
    if update.int_value != 1
        prints("FAIL: Expected ++ (1)\n")
        return 1
    if update.bool_value != 1
        prints("FAIL: Expected prefix (1)\n")
        return 1
    0

[[test]]
fn test_postfix_increment() -> i32
    var p = parse("x++")
    if expect_no_error(@p) != 0
        return 1

    let root = parser_root(@p)
    let root_node = ast_get_node(@p.ast, root)
    let stmt_idx = ast_get_child(@p.ast, root_node.children_start, 0)
    let stmt = ast_get_node(@p.ast, stmt_idx)

    if expect_node_type(@p, stmt.child1, AST_UPDATE_EXPR) != 0
        return 1

    let update = ast_get_node(@p.ast, stmt.child1)
    if update.int_value != 1
        prints("FAIL: Expected ++ (1)\n")
        return 1
    if update.bool_value != 0
        prints("FAIL: Expected postfix (0)\n")
        return 1
    0

