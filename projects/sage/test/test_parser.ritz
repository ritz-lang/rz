# =============================================================================
# Binary Expression Tests
# =============================================================================

[[test]]
fn test_simple_addition() -> i32
    var p = parse("2 + 3")
    if expect_no_error(@p) != 0
        return 1

    let root = parser_root(@p)
    let root_node = ast_get_node(@p.ast, root)
    let stmt_idx = ast_get_child(@p.ast, root_node.children_start, 0)
    let stmt = ast_get_node(@p.ast, stmt_idx)

    if expect_node_type(@p, stmt.child1, AST_BINARY_EXPR) != 0
        return 1

    let bin = ast_get_node(@p.ast, stmt.child1)
    if bin.int_value != OP_ADD
        prints("FAIL: Expected OP_ADD\n")
        return 1

    if expect_node_type(@p, bin.child1, AST_NUMBER_LITERAL) != 0
        return 1
    if expect_node_type(@p, bin.child2, AST_NUMBER_LITERAL) != 0
        return 1
    0

