# Lexer Tests
# Basic tests for JavaScript tokenization

import ritzlib.io
import ritzlib.strview
import ritzlib.gvec
import src.token
import src.lexer

# ============================================================================
# Basic Token Tests
# ============================================================================

[[test]]
fn test_empty_source() -> i32
    let tokens = lexer_tokenize("")
    if vec_len<Token>(@tokens) != 1
        prints("FAIL: Expected 1 token for empty source\n")
        return 1
    let tok = vec_get<Token>(@tokens, 0)
    if tok.typ != TOKEN_EOF
        prints("FAIL: Expected EOF token\n")
        return 1
    0

[[test]]
fn test_single_number() -> i32
    let tokens = lexer_tokenize("42")
    if vec_len<Token>(@tokens) != 2
        prints("FAIL: Expected 2 tokens\n")
        return 1
    let tok = vec_get<Token>(@tokens, 0)
    if tok.typ != TOKEN_NUMBER
        prints("FAIL: Expected NUMBER token\n")
        return 1
    0

[[test]]
fn test_decimal_number() -> i32
    let tokens = lexer_tokenize("3.14159")
    if vec_len<Token>(@tokens) != 2
        return 1
    let tok = vec_get<Token>(@tokens, 0)
    if tok.typ != TOKEN_NUMBER
        return 1
    0

