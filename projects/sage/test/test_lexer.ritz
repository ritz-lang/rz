    0

[[test]]
fn test_equality_operators() -> i32
    let tokens = lexer_tokenize("== ===")
    if vec_len<Token>(@tokens) != 3
        return 1
    let tok0 = vec_get<Token>(@tokens, 0)
    let tok1 = vec_get<Token>(@tokens, 1)
    if tok0.typ != TOKEN_EQ_EQ
        return 1
    if tok1.typ != TOKEN_EQ_EQ_EQ
        return 1
    0

[[test]]
fn test_arrow_function() -> i32
    let tokens = lexer_tokenize("=>")
    if vec_len<Token>(@tokens) != 2
        return 1
    let tok = vec_get<Token>(@tokens, 0)
    if tok.typ != TOKEN_ARROW
        return 1
    0

[[test]]
fn test_comments() -> i32
    let tokens = lexer_tokenize("42 // comment\n43")
    # 42 43 EOF = 3 tokens
    if vec_len<Token>(@tokens) != 3
        prints("FAIL: Expected 3 tokens with comment\n")
        return 1
    let tok0 = vec_get<Token>(@tokens, 0)
    let tok1 = vec_get<Token>(@tokens, 1)
    if tok0.typ != TOKEN_NUMBER
        return 1
    if tok1.typ != TOKEN_NUMBER
        return 1
    0

[[test]]
fn test_keywords() -> i32
    # Test several keywords
    let tokens = lexer_tokenize("if else while for return")
    if vec_len<Token>(@tokens) != 6
        return 1
    let tok_if = vec_get<Token>(@tokens, 0)
    let tok_else = vec_get<Token>(@tokens, 1)
    let tok_while = vec_get<Token>(@tokens, 2)
    let tok_for = vec_get<Token>(@tokens, 3)
    let tok_return = vec_get<Token>(@tokens, 4)
    if tok_if.typ != TOKEN_IF
        return 1
    if tok_else.typ != TOKEN_ELSE
        return 1
    if tok_while.typ != TOKEN_WHILE
        return 1
    if tok_for.typ != TOKEN_FOR
        return 1
    if tok_return.typ != TOKEN_RETURN
        return 1
    0

