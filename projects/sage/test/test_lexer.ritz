[[test]]
fn test_simple_addition() -> i32
    let tokens = lexer_tokenize("2 + 2")
    # 2 + 2 EOF = 4 tokens
    if vec_len<Token>(@tokens) != 4
        prints("FAIL: Expected 4 tokens for '2 + 2'\n")
        return 1
    let tok0 = vec_get<Token>(@tokens, 0)
    let tok1 = vec_get<Token>(@tokens, 1)
    let tok2 = vec_get<Token>(@tokens, 2)
    if tok0.typ != TOKEN_NUMBER
        return 1
    if tok1.typ != TOKEN_PLUS
        return 1
    if tok2.typ != TOKEN_NUMBER
        return 1
    0

[[test]]
fn test_variable_declaration() -> i32
    let tokens = lexer_tokenize("let x = 42;")
    # let x = 42 ; EOF = 6 tokens
    if vec_len<Token>(@tokens) != 6
        prints("FAIL: Expected 6 tokens for 'let x = 42;'\n")
        return 1
    let tok0 = vec_get<Token>(@tokens, 0)
    let tok1 = vec_get<Token>(@tokens, 1)
    let tok2 = vec_get<Token>(@tokens, 2)
    if tok0.typ != TOKEN_LET
        return 1
    if tok1.typ != TOKEN_IDENTIFIER
        return 1
    if tok2.typ != TOKEN_EQ
        return 1
    0

[[test]]
fn test_parentheses() -> i32
    let tokens = lexer_tokenize("()")
    if vec_len<Token>(@tokens) != 3
        return 1
    let tok0 = vec_get<Token>(@tokens, 0)
    let tok1 = vec_get<Token>(@tokens, 1)
    if tok0.typ != TOKEN_LPAREN
        return 1
    if tok1.typ != TOKEN_RPAREN
        return 1
    0

