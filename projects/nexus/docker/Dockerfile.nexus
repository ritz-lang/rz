# Dockerfile for Nexus (Wiki Application)
#
# Phase 0: Minimal HTTP server with embedded Mausoleum/Tome clients

FROM ubuntu:22.04 AS builder

# Install build dependencies
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    llvm-14 \
    clang-14 \
    make \
    liburing-dev \
    && rm -rf /var/lib/apt/lists/*

# Install llvmlite for ritz0
RUN pip3 install llvmlite

# Set up build environment
WORKDIR /build
ENV RITZ_PATH=/build/ritz

# Copy ritz compiler and dependencies
COPY ritz /build/ritz
COPY mausoleum /build/mausoleum
COPY tome /build/tome
COPY spire /build/spire
COPY cryptosec /build/cryptosec
COPY squeeze /build/squeeze

# Copy nexus source
COPY nexus /build/nexus

# Build nexus
WORKDIR /build/nexus
RUN python3 ../ritz/build.py build nexus || \
    echo "Build failed - nexus binary may not exist yet"

# Runtime image
FROM ubuntu:22.04

RUN apt-get update && apt-get install -y \
    curl \
    liburing2 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy built binary (or placeholder)
COPY --from=builder /build/nexus/build/release/nexus /app/ 2>/dev/null || true

# Create a simple placeholder if build failed
RUN if [ ! -f /app/nexus ]; then \
    echo '#!/bin/sh' > /app/nexus && \
    echo 'echo "Nexus placeholder - not built yet"' >> /app/nexus && \
    echo 'echo "HTTP server starting on port 8080..."' >> /app/nexus && \
    echo 'while true; do' >> /app/nexus && \
    echo '  echo -e "HTTP/1.1 200 OK\r\nContent-Type: text/html\r\n\r\n<h1>Nexus</h1><p>Wiki coming soon!</p>" | nc -l -p 8080 -q 1' >> /app/nexus && \
    echo 'done' >> /app/nexus && \
    chmod +x /app/nexus; \
    fi

# Copy static assets (if any)
# COPY --from=builder /build/nexus/static /app/static

EXPOSE 8080

# Health check endpoint
HEALTHCHECK --interval=10s --timeout=5s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

CMD ["/app/nexus"]
