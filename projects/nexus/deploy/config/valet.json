{
  "server": {
    "port": 443,
    "workers": 1,
    "multishot": true,
    "backlog": 1024,
    "use_send_zc": false
  },
  "limits": {
    "max_connections": 10000,
    "max_request_size": 1048576,
    "keepalive_requests": 100,
    "idle_timeout": 60
  },
  "tls": {
    "enabled": true,
    "cert": "/etc/ritz/certs/fullchain.pem",
    "key": "/etc/ritz/certs/privkey.pem"
  },
  "zeus": {
    "enabled": true,
    "socket": "/run/zeus/zeus.sock"
  }
}
