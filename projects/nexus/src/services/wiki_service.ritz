# src/services/wiki_service.ritz - Wiki business logic
#
# Core business logic for wiki operations:
# - Page creation with slug validation
# - Page updates with version tracking
# - Cache-aside pattern with Tome
# - Slug hierarchy management

import ritzlib.str { String, str_from_view, str_concat }
import ritzlib.vec { Vec }

import models {
    WikiPage,
    wiki_page_new,
    wiki_page_update_content,
    wiki_page_update_title
}
import repos {
    WikiPageRepository,
    wiki_page_repo_get_by_slug,
    wiki_page_repo_get_by_id,
    wiki_page_repo_insert,
    wiki_page_repo_update,
    wiki_page_repo_delete,
    PageCache,
    page_cache_get,
    page_cache_set,
    page_cache_invalidate
}
import errors.service_error { ServiceError, service_error_from_repo }
import errors.repo_error { RepoError }
import mausoleum.document { DocumentId }


# Maximum page content size (1 MB)
const MAX_CONTENT_SIZE: i64 = 1048576

# Maximum title length
const MAX_TITLE_LENGTH: i64 = 256

# Maximum slug length
const MAX_SLUG_LENGTH: i64 = 128


# Wiki service - manages wiki page operations
pub struct WikiService
    repo: *WikiPageRepository
    cache: *PageCache


# Create a new wiki service
pub fn wiki_service_new(repo: *WikiPageRepository, cache: *PageCache) -> WikiService
    WikiService {
        repo: repo,
        cache: cache
    }


# Get a page by slug, using cache-aside pattern
pub fn wiki_service_get_page(svc: *WikiService, slug: Span<u8>) -> Result<WikiPage, ServiceError>
    # Check cache first
    match page_cache_get(svc.cache, slug)
        Some(page) => return Ok(page)
        None => {}

    # Cache miss - fetch from repository
    let page = wiki_page_repo_get_by_slug(svc.repo, slug)
        .map_err(|e| service_error_from_repo(e))?

    # Store in cache for next time
    let _ = page_cache_set(svc.cache, @page)  # Ignore cache errors

    Ok(page)


# Create a new page
pub fn wiki_service_create_page(svc: *WikiService, slug: Span<u8>, title: Span<u8>,
                                 content: Span<u8>) -> Result<WikiPage, ServiceError>
    # Validate inputs
    validate_slug(slug)?
    validate_title(title)?
    validate_content(content)?

    # Check if page already exists
    match wiki_page_repo_get_by_slug(svc.repo, slug)
        Ok(_) => return Err(ServiceError.AlreadyExists)
        Err(RepoError.NotFound) => {}  # Good, doesn't exist
        Err(e) => return Err(service_error_from_repo(e))

    # Create the page
    let slug_str = str_from_view(slug)
    let title_str = str_from_view(title)
    let content_str = str_from_view(content)
    var page = wiki_page_new(slug_str, title_str, content_str)

    # Insert into repository
    wiki_page_repo_insert(svc.repo, @page)
        .map_err(|e| service_error_from_repo(e))?

    # Cache the new page
    let _ = page_cache_set(svc.cache, @page)

    Ok(page)


# Update page content
pub fn wiki_service_update_content(svc: *WikiService, slug: Span<u8>,
                                    new_content: Span<u8>) -> Result<WikiPage, ServiceError>
    validate_content(new_content)?

    # Get existing page
    var page = wiki_page_repo_get_by_slug(svc.repo, slug)
        .map_err(|e| service_error_from_repo(e))?

    # Update content (increments version)
    wiki_page_update_content(@page, str_from_view(new_content))

    # Save to repository
    wiki_page_repo_update(svc.repo, @page)
        .map_err(|e| service_error_from_repo(e))?

    # Invalidate cache so next read gets fresh data
    let _ = page_cache_invalidate(svc.cache, slug)

    Ok(page)


# Update page title
pub fn wiki_service_update_title(svc: *WikiService, slug: Span<u8>,
                                  new_title: Span<u8>) -> Result<WikiPage, ServiceError>
    validate_title(new_title)?

    var page = wiki_page_repo_get_by_slug(svc.repo, slug)
        .map_err(|e| service_error_from_repo(e))?

    wiki_page_update_title(@page, str_from_view(new_title))

    wiki_page_repo_update(svc.repo, @page)
        .map_err(|e| service_error_from_repo(e))?

    let _ = page_cache_invalidate(svc.cache, slug)

    Ok(page)


# Delete a page
pub fn wiki_service_delete_page(svc: *WikiService, slug: Span<u8>) -> Result<(), ServiceError>
    # Get the page first to get its ID
    let page = wiki_page_repo_get_by_slug(svc.repo, slug)
        .map_err(|e| service_error_from_repo(e))?

    # Delete from repository
    wiki_page_repo_delete(svc.repo, page.id)
        .map_err(|e| service_error_from_repo(e))?

    # Invalidate cache
    let _ = page_cache_invalidate(svc.cache, slug)

    Ok(())


# Check if a page exists
pub fn wiki_service_page_exists(svc: *WikiService, slug: Span<u8>) -> bool
    # Check cache first
    match page_cache_get(svc.cache, slug)
        Some(_) => return true
        None => {}

    # Check repository
    match wiki_page_repo_get_by_slug(svc.repo, slug)
        Ok(_) => true
        Err(_) => false


# Get child pages of a parent slug
pub fn wiki_service_get_children(svc: *WikiService, parent_slug: Span<u8>) -> Result<Vec<WikiPage>, ServiceError>
    # TODO: Implement when Mausoleum supports prefix queries
    # This would query for all pages where slug starts with parent_slug + "/"
    Err(ServiceError.RepoError(RepoError.InvalidQuery(str_from_view(s"Children query not implemented"))))


# ============================================================================
# Validation helpers
# ============================================================================

# Validate slug format
# Valid: lowercase letters, numbers, hyphens, forward slashes
# Must start with letter, not end with slash
fn validate_slug(slug: Span<u8>) -> Result<(), ServiceError>
    if slug.len() == 0
        return Err(ServiceError.InvalidSlug(str_from_view(s"Slug cannot be empty")))

    if slug.len() > MAX_SLUG_LENGTH
        return Err(ServiceError.InvalidSlug(str_from_view(s"Slug too long")))

    # Check first character is a letter
    let first = slug.get_byte(0)
    if not is_letter(first)
        return Err(ServiceError.InvalidSlug(str_from_view(s"Slug must start with letter")))

    # Check last character is not a slash
    let last = slug.get_byte(slug.len() - 1)
    if last == '/' as u8
        return Err(ServiceError.InvalidSlug(str_from_view(s"Slug cannot end with slash")))

    # Check all characters are valid
    var i: i64 = 0
    var prev_slash = false
    while i < slug.len()
        let c = slug.get_byte(i)
        if not (is_letter(c) or is_digit(c) or c == '-' as u8 or c == '/' as u8)
            return Err(ServiceError.InvalidSlug(str_from_view(s"Invalid character in slug")))

        # No double slashes
        if c == '/' as u8
            if prev_slash
                return Err(ServiceError.InvalidSlug(str_from_view(s"Double slashes not allowed")))
            prev_slash = true
        else
            prev_slash = false

        i += 1

    Ok(())


# Validate title
fn validate_title(title: Span<u8>) -> Result<(), ServiceError>
    if title.len() == 0
        return Err(ServiceError.InvalidTitle)

    if title.len() > MAX_TITLE_LENGTH
        return Err(ServiceError.InvalidTitle)

    Ok(())


# Validate content
fn validate_content(content: Span<u8>) -> Result<(), ServiceError>
    if content.len() > MAX_CONTENT_SIZE
        return Err(ServiceError.ContentTooLarge)

    Ok(())


# Character helpers
fn is_letter(c: u8) -> bool
    (c >= 'a' as u8 and c <= 'z' as u8) or (c >= 'A' as u8 and c <= 'Z' as u8)


fn is_digit(c: u8) -> bool
    c >= '0' as u8 and c <= '9' as u8
