# Render error page
fn render_error(res: *Response, err: *ServiceError)
    let html = s"<!DOCTYPE html>
<html>
<head><title>Error</title></head>
<body>
<h1>Error</h1>
<p>An error occurred processing your request.</p>
<p><a href=\"/\">Return to home</a></p>
</body>
</html>"

    response_status(res, 500)
    response_body_html(res, html.ptr() as *u8, html.len() as i32)


# ============================================================================
# Helpers
# ============================================================================

fn span_from_raw(ptr: *u8, len: i32) -> Span<u8>
    Span<u8> { ptr: ptr, len: len as u64 }


