# src/main.ritz - Nexus HTTP server
#
# Minimal HTTP server for the Ritz Knowledge Base.
# Serves /health endpoint for Docker health checks.

import ritzlib.sys { sys_read, sys_write, sys_close }
import ritzlib.async_net { tcp_socket, set_reuseaddr, tcp_bind, tcp_listen, tcp_accept }


fn main() -> i32
    print("Nexus - The Ritz Knowledge Base\n")
    print("Starting HTTP server on port 8080...\n")

    # Create socket
    let sock = tcp_socket()
    if sock < 0
        print("Failed to create socket\n")
        return 1

    # Set SO_REUSEADDR
    set_reuseaddr(sock)

    # Bind to 0.0.0.0:8080
    let bind_result = tcp_bind(sock, 0, 8080)
    if bind_result < 0
        print("Failed to bind\n")
        sys_close(sock)
        return 1

    # Listen
    let listen_result = tcp_listen(sock, 128)
    if listen_result < 0
        print("Failed to listen\n")
        sys_close(sock)
        return 1

    print("Listening on http://0.0.0.0:8080\n")

    # Accept loop
    loop
        let client = tcp_accept(sock)
        if client < 0
            continue

        # Read request
        var buf: [4096]u8
        let n = sys_read(client, @buf[0], 4096)
        if n > 0
            # Simple routing based on first few bytes
            # GET / HTTP/1.1
            # GET /health HTTP/1.1
            if n >= 5 and buf[0] == 'G' as u8 and buf[1] == 'E' as u8 and buf[2] == 'T' as u8
                if buf[4] == '/' as u8 and buf[5] == ' ' as u8
                    # Root path
                    send_index(client)
                else if buf[4] == '/' as u8 and buf[5] == 'h' as u8 and buf[6] == 'e' as u8
                    # /health
                    send_health(client)
                else
                    send_not_found(client)
            else
                send_not_found(client)

        sys_close(client)

    0


fn send_health(fd: i32)
    let resp = c"HTTP/1.1 200 OK\r\nContent-Type: text/plain\r\nContent-Length: 2\r\nConnection: close\r\n\r\nOK"
    sys_write(fd, resp, 87)


fn send_not_found(fd: i32)
    let resp = c"HTTP/1.1 404 Not Found\r\nContent-Type: text/plain\r\nContent-Length: 9\r\nConnection: close\r\n\r\nNot Found"
    sys_write(fd, resp, 99)


fn send_index(fd: i32)
    let resp = c"HTTP/1.1 200 OK\r\nContent-Type: text/html\r\nContent-Length: 193\r\nConnection: close\r\n\r\n<!DOCTYPE html><html><head><title>Nexus</title></head><body><h1>Nexus</h1><p>The Ritz Knowledge Base</p><p>Status: Running</p><ul><li>/health - Health check</li></ul></body></html>"
    sys_write(fd, resp, 279)
