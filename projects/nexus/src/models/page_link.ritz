# src/models/page_link.ritz - PageLink model
#
# Represents links between wiki pages (graph edges).
# Used for navigation, backlinks, and relationship tracking.

import mausoleum.document { DocumentId, doc_id_eq }


# Link types between pages
pub enum LinkKind
    Reference                 # [[page]] syntax - inline reference
    SeeAlso                   # Related pages section
    Implements                # Spec -> implementation link
    Includes                  # Template inclusion
    Redirects                 # Page redirect


# Links between pages (graph edges stored in Mausoleum)
pub struct PageLink
    source_id: DocumentId     # Page containing the link
    target_id: DocumentId     # Page being linked to
    kind: LinkKind
    anchor: Option<String>    # Optional anchor within target page


# Create a new page link
pub fn page_link_new(source: DocumentId, target: DocumentId, kind: LinkKind) -> PageLink
    PageLink {
        source_id: source,
        target_id: target,
        kind: kind,
        anchor: None
    }


# Create a link with an anchor
pub fn page_link_with_anchor(source: DocumentId, target: DocumentId, kind: LinkKind,
                              anchor:= String) -> PageLink
    PageLink {
        source_id: source,
        target_id: target,
        kind: kind,
        anchor: Some(anchor)
    }


# Check if two links point to the same target
pub fn page_link_same_target(a: *PageLink, b: *PageLink) -> bool
    doc_id_eq(@a.target_id, @b.target_id) == 1


# Check if link is a reference type (inline [[link]])
pub fn page_link_is_reference(link: *PageLink) -> bool
    match link.kind
        LinkKind.Reference => true
        _ => false


# Check if link is a redirect
pub fn page_link_is_redirect(link: *PageLink) -> bool
    match link.kind
        LinkKind.Redirects => true
        _ => false
