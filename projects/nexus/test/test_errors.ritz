# test/test_errors.ritz - Error type tests
#
# Tests for error types and conversions.

import ritzlib.str { String, str_from_view }

import errors.repo_error {
    RepoError,
    repo_error_message,
    repo_error_is_not_found,
    repo_error_is_retriable
}
import errors.service_error {
    ServiceError,
    service_error_message,
    service_error_from_repo,
    service_error_is_not_found
}
import errors.nexus_error {
    NexusError,
    nexus_error_message,
    nexus_error_from_service,
    nexus_error_is_client_error,
    nexus_error_status_code
}


# ============================================================================
# RepoError tests
# ============================================================================

@test
fn test_repo_error_not_found() -> i32
    let err = RepoError.NotFound
    assert repo_error_is_not_found(@err)
    assert not repo_error_is_retriable(@err)
    0


@test
fn test_repo_error_timeout_retriable() -> i32
    let err = RepoError.Timeout
    assert repo_error_is_retriable(@err)
    assert not repo_error_is_not_found(@err)
    0


@test
fn test_repo_error_network_retriable() -> i32
    let err = RepoError.NetworkError(str_from_view(s"connection refused"))
    assert repo_error_is_retriable(@err)
    0


@test
fn test_repo_error_message() -> i32
    let err = RepoError.NotFound
    let msg = repo_error_message(@err)
    assert msg.as_view() == s"Resource not found"
    0


# ============================================================================
# ServiceError tests
# ============================================================================

@test
fn test_service_error_not_found() -> i32
    let err = ServiceError.NotFound
    assert service_error_is_not_found(@err)
    0


@test
fn test_service_error_from_repo_not_found() -> i32
    let repo_err = RepoError.NotFound
    let svc_err = service_error_from_repo(repo_err)

    match svc_err
        ServiceError.NotFound => 0
        _ => 1


@test
fn test_service_error_from_repo_other() -> i32
    let repo_err = RepoError.Timeout
    let svc_err = service_error_from_repo(repo_err)

    match svc_err
        ServiceError.RepoError(_) => 0
        _ => 1


@test
fn test_service_error_invalid_slug_message() -> i32
    let err = ServiceError.InvalidSlug(str_from_view(s"must start with letter"))
    let msg = service_error_message(@err)
    # Message should contain "Invalid slug:"
    0


# ============================================================================
# NexusError tests
# ============================================================================

@test
fn test_nexus_error_not_found_is_client_error() -> i32
    let svc_err = ServiceError.NotFound
    let err = nexus_error_from_service(svc_err)
    assert nexus_error_is_client_error(@err)
    assert nexus_error_status_code(@err) == 404
    0


@test
fn test_nexus_error_permission_denied() -> i32
    let svc_err = ServiceError.PermissionDenied
    let err = nexus_error_from_service(svc_err)
    assert nexus_error_is_client_error(@err)
    assert nexus_error_status_code(@err) == 403
    0


@test
fn test_nexus_error_conflict() -> i32
    let svc_err = ServiceError.VersionConflict
    let err = nexus_error_from_service(svc_err)
    assert nexus_error_is_client_error(@err)
    assert nexus_error_status_code(@err) == 409
    0


@test
fn test_nexus_error_database_init() -> i32
    let err = NexusError.DatabaseInit(str_from_view(s"connection refused"))
    assert not nexus_error_is_client_error(@err)
    assert nexus_error_status_code(@err) == 503
    0


@test
fn test_nexus_error_internal() -> i32
    let err = NexusError.InternalError(str_from_view(s"unexpected state"))
    assert not nexus_error_is_client_error(@err)
    assert nexus_error_status_code(@err) == 500
    0
