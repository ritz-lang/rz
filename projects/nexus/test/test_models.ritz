# test/test_models.ritz - Model tests
#
# Tests for WikiPage and PageLink models.

import ritzlib.str { String, str_from_view }

import models {
    WikiPage,
    PageLink,
    LinkKind,
    wiki_page_new,
    wiki_page_new_child,
    wiki_page_update_content,
    wiki_page_update_title,
    wiki_page_is_root,
    page_link_new,
    page_link_is_reference,
    page_link_is_redirect
}
import mausoleum.document { doc_id_new, doc_id_invalid }


@test
fn test_wiki_page_new() -> i32
    let page = wiki_page_new(
        str_from_view(s"language/syntax"),
        str_from_view(s"Syntax Guide"),
        str_from_view(s"# Syntax\n\nRitz syntax guide...")
    )

    assert page.version == 1
    assert page.parent_id.is_none()
    assert wiki_page_is_root(@page)
    0


@test
fn test_wiki_page_update_content() -> i32
    var page = wiki_page_new(
        str_from_view(s"test-page"),
        str_from_view(s"Test Page"),
        str_from_view(s"Original content")
    )

    assert page.version == 1

    wiki_page_update_content(@page, str_from_view(s"Updated content"))

    assert page.version == 2
    assert page.content.as_view() == s"Updated content"
    0


@test
fn test_wiki_page_update_title() -> i32
    var page = wiki_page_new(
        str_from_view(s"test-page"),
        str_from_view(s"Original Title"),
        str_from_view(s"Content")
    )

    assert page.version == 1

    wiki_page_update_title(@page, str_from_view(s"New Title"))

    assert page.version == 2
    assert page.title.as_view() == s"New Title"
    0


@test
fn test_wiki_page_child() -> i32
    var parent = wiki_page_new(
        str_from_view(s"language"),
        str_from_view(s"Language"),
        str_from_view(s"Language overview")
    )
    parent.id = doc_id_new(0, 42)  # Simulate assigned ID

    let child = wiki_page_new_child(
        str_from_view(s"language/syntax"),
        str_from_view(s"Syntax"),
        str_from_view(s"Syntax details"),
        @parent
    )

    assert not wiki_page_is_root(@child)
    match child.parent_id
        Some(id) => assert id.value == 42
        None => assert false
    0


@test
fn test_page_link_new() -> i32
    let source = doc_id_new(0, 1)
    let target = doc_id_new(0, 2)
    let link = page_link_new(source, target, LinkKind.Reference)

    assert link.source_id.value == source.value
    assert link.target_id.value == target.value
    assert page_link_is_reference(@link)
    assert not page_link_is_redirect(@link)
    0


@test
fn test_link_kind_variants() -> i32
    let source = doc_id_new(0, 1)
    let target = doc_id_new(0, 2)

    let ref_link = page_link_new(source, target, LinkKind.Reference)
    assert page_link_is_reference(@ref_link)

    let see_also = page_link_new(source, target, LinkKind.SeeAlso)
    assert not page_link_is_reference(@see_also)

    let redirect = page_link_new(source, target, LinkKind.Redirects)
    assert page_link_is_redirect(@redirect)

    0
