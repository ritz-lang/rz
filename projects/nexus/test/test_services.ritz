# test/test_services.ritz - Service layer tests
#
# Tests for WikiService business logic, including slug validation.

import ritzlib.str { String, str_from_view }

import services.wiki_service {
    validate_slug,
    validate_title,
    validate_content
}
import errors.service_error { ServiceError }


# ============================================================================
# Slug validation tests
# ============================================================================

@test
fn test_valid_slug_simple() -> i32
    match validate_slug(s"hello")
        Ok(_) => 0
        Err(_) => 1


@test
fn test_valid_slug_with_hyphen() -> i32
    match validate_slug(s"hello-world")
        Ok(_) => 0
        Err(_) => 1


@test
fn test_valid_slug_with_numbers() -> i32
    match validate_slug(s"chapter1")
        Ok(_) => 0
        Err(_) => 1


@test
fn test_valid_slug_hierarchical() -> i32
    match validate_slug(s"language/syntax")
        Ok(_) => 0
        Err(_) => 1


@test
fn test_valid_slug_deep_hierarchy() -> i32
    match validate_slug(s"stdlib/io/file")
        Ok(_) => 0
        Err(_) => 1


@test
fn test_invalid_slug_empty() -> i32
    match validate_slug(s"")
        Ok(_) => 1
        Err(ServiceError.InvalidSlug(_)) => 0
        Err(_) => 1


@test
fn test_invalid_slug_starts_with_number() -> i32
    match validate_slug(s"1chapter")
        Ok(_) => 1
        Err(ServiceError.InvalidSlug(_)) => 0
        Err(_) => 1


@test
fn test_invalid_slug_ends_with_slash() -> i32
    match validate_slug(s"language/")
        Ok(_) => 1
        Err(ServiceError.InvalidSlug(_)) => 0
        Err(_) => 1


@test
fn test_invalid_slug_double_slash() -> i32
    match validate_slug(s"language//syntax")
        Ok(_) => 1
        Err(ServiceError.InvalidSlug(_)) => 0
        Err(_) => 1


@test
fn test_invalid_slug_special_chars() -> i32
    match validate_slug(s"hello@world")
        Ok(_) => 1
        Err(ServiceError.InvalidSlug(_)) => 0
        Err(_) => 1


@test
fn test_invalid_slug_spaces() -> i32
    match validate_slug(s"hello world")
        Ok(_) => 1
        Err(ServiceError.InvalidSlug(_)) => 0
        Err(_) => 1


# ============================================================================
# Title validation tests
# ============================================================================

@test
fn test_valid_title() -> i32
    match validate_title(s"Hello World")
        Ok(_) => 0
        Err(_) => 1


@test
fn test_invalid_title_empty() -> i32
    match validate_title(s"")
        Ok(_) => 1
        Err(ServiceError.InvalidTitle) => 0
        Err(_) => 1


# ============================================================================
# Content validation tests
# ============================================================================

@test
fn test_valid_content() -> i32
    match validate_content(s"# Hello\n\nThis is content.")
        Ok(_) => 0
        Err(_) => 1


@test
fn test_valid_content_empty() -> i32
    # Empty content is allowed
    match validate_content(s"")
        Ok(_) => 0
        Err(_) => 1
