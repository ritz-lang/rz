# test/test_simple.ritz - Simple verification tests
#
# Verifies the Ritz compiler works correctly.

import ritzlib.sys { print }


[[test]]
fn test_arithmetic() -> i32
    if 2 + 2 != 4
        return 1
    0


[[test]]
fn test_comparison() -> i32
    let x: i32 = 42
    if x < 40
        return 1
    if x > 50
        return 1
    0


[[test]]
fn test_string_literal() -> i32
    let msg = c"hello"
    if msg == null
        return 1
    0
