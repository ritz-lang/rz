# lib/lexis.ritz - Main Lexis API
#
# HTML5 and CSS parser for the Tempest web browser.
#
# Usage:
#   import lexis { HtmlParser, CssEngine, StyleResolver }
#
#   # Parse HTML (emits events to your sink)
#   let parser = html_parser_new(source, event_sink)
#   html_parser_run(parser)
#
#   # Parse CSS
#   let stylesheet = css_parse(css_source)
#
#   # Style resolution
#   let engine = style_engine_new()
#   style_engine_add_stylesheet(engine, stylesheet, ORIGIN_AUTHOR)
#   let computed = style_engine_compute(engine, element_info, parent_style)
#
# Lexis is a streaming parser that emits DOM events as it parses.
# Tempest receives these events to build/update its DOM tree.

