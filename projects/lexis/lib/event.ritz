# lib/event.ritz - DOM Events emitted by Lexis parser
#
# These events are emitted during streaming HTML/CSS parsing.
# Tempest receives these events and builds/updates its DOM tree.

import lib.dom.tag { Tag }
import lib.dom.attribute { Attribute }
import lib.dom.node { NodeId }

# =============================================================================
# DOM Event Types
# =============================================================================

# Event type constants
pub const DOM_EVENT_DOCUMENT_START: i32 = 0
pub const DOM_EVENT_DOCUMENT_END: i32 = 1
pub const DOM_EVENT_ELEMENT_START: i32 = 2
pub const DOM_EVENT_ELEMENT_END: i32 = 3
pub const DOM_EVENT_TEXT: i32 = 4
pub const DOM_EVENT_COMMENT: i32 = 5
pub const DOM_EVENT_DOCTYPE: i32 = 6
pub const DOM_EVENT_STYLESHEET_PARSED: i32 = 7
pub const DOM_EVENT_PARSE_ERROR: i32 = 8
pub const DOM_EVENT_PARSE_WARNING: i32 = 9

# =============================================================================
# Error/Warning Kinds
# =============================================================================

pub const PARSE_ERROR_UNEXPECTED_TOKEN: i32 = 0
pub const PARSE_ERROR_UNEXPECTED_EOF: i32 = 1
pub const PARSE_ERROR_INVALID_TAG: i32 = 2
pub const PARSE_ERROR_UNCLOSED_TAG: i32 = 3
pub const PARSE_ERROR_INVALID_ATTRIBUTE: i32 = 4
pub const PARSE_ERROR_DUPLICATE_ATTRIBUTE: i32 = 5
pub const PARSE_ERROR_INVALID_ENTITY: i32 = 6
pub const PARSE_ERROR_NESTING_ERROR: i32 = 7

pub const PARSE_WARNING_UNKNOWN_PROPERTY: i32 = 0
pub const PARSE_WARNING_INVALID_VALUE: i32 = 1
pub const PARSE_WARNING_DEPRECATED: i32 = 2
pub const PARSE_WARNING_QUIRKS_MODE: i32 = 3

# =============================================================================
# Event Data Structures
# =============================================================================

# Element start event data
pub struct ElementStartEvent
    tag: Tag
    attrs: [64]Attribute    # Fixed-size attribute array
    attr_count: u32         # Number of attributes
    self_closing: i32       # 1 if self-closing (e.g., <br/>)

# Element end event data
pub struct ElementEndEvent
    tag: Tag

# Text content event data
pub struct TextEvent
    content: StrView

# Comment event data
pub struct CommentEvent
    content: StrView

# DOCTYPE event data
pub struct DoctypeEvent
    name: StrView
    public_id: StrView
    system_id: StrView

# Parse error event data
pub struct ParseErrorEvent
    kind: i32               # PARSE_ERROR_*
    message: StrView
    line: u32
    col: u32

# Parse warning event data
pub struct ParseWarningEvent
    kind: i32               # PARSE_WARNING_*
    message: StrView
    line: u32
    col: u32

# =============================================================================
# Event Handler Trait
# =============================================================================

# The parser calls these methods to emit events.
# Tempest implements this trait to receive parsing results.
#
# Usage:
#   struct TempestDomBuilder
#       # ... DOM state ...
#
#   impl EventHandler for TempestDomBuilder
#       fn on_document_start(self:&)
#           # Handle document start
#
#       fn on_element_start(self:&, event: ElementStartEvent)
#           # Build DOM node
#
#   let handler = TempestDomBuilder.new()
#   let parser = html_parser_new(source, handler)
#   html_parser_run(parser)

pub trait EventHandler
    fn on_document_start(self:&)
    fn on_document_end(self:&)
    fn on_element_start(self:&, event: ElementStartEvent)
    fn on_element_end(self:&, event: ElementEndEvent)
    fn on_text(self:&, event: TextEvent)
    fn on_comment(self:&, event: CommentEvent)
    fn on_doctype(self:&, event: DoctypeEvent)
    fn on_error(self:&, event: ParseErrorEvent)
    fn on_warning(self:&, event: ParseWarningEvent)

# =============================================================================
# Default No-Op Handler
# =============================================================================

# A handler that does nothing - useful for testing or when you only
# care about certain events.

pub struct NoOpHandler

pub fn no_op_handler_new() -> NoOpHandler
    NoOpHandler {}

impl EventHandler for NoOpHandler
    fn on_document_start(self:&)
        # No-op
        0

    fn on_document_end(self:&)
        # No-op
        0

    fn on_element_start(self:&, event: ElementStartEvent)
        # No-op
        0

    fn on_element_end(self:&, event: ElementEndEvent)
        # No-op
        0

    fn on_text(self:&, event: TextEvent)
        # No-op
        0

    fn on_comment(self:&, event: CommentEvent)
        # No-op
        0

    fn on_doctype(self:&, event: DoctypeEvent)
        # No-op
        0

    fn on_error(self:&, event: ParseErrorEvent)
        # No-op
        0

    fn on_warning(self:&, event: ParseWarningEvent)
        # No-op
        0

# =============================================================================
# Event Emitter Helpers
# =============================================================================

# Helper functions that call the appropriate trait method
# These are used internally by the parser

pub fn emit_document_start(handler:& EventHandler)
    handler.on_document_start()

pub fn emit_document_end(handler:& EventHandler)
    handler.on_document_end()

pub fn emit_element_start(handler:& EventHandler, tag: Tag, attrs: [64]Attribute, attr_count: u32, self_closing: i32)
    let event = ElementStartEvent {
        tag: tag,
        attrs: attrs,
        attr_count: attr_count,
        self_closing: self_closing
    }
    handler.on_element_start(event)

pub fn emit_element_end(handler:& EventHandler, tag: Tag)
    let event = ElementEndEvent { tag: tag }
    handler.on_element_end(event)

pub fn emit_text(handler:& EventHandler, content: StrView)
    let event = TextEvent { content: content }
    handler.on_text(event)

pub fn emit_comment(handler:& EventHandler, content: StrView)
    let event = CommentEvent { content: content }
    handler.on_comment(event)

pub fn emit_doctype(handler:& EventHandler, name: StrView, public_id: StrView, system_id: StrView)
    let event = DoctypeEvent {
        name: name,
        public_id: public_id,
        system_id: system_id
    }
    handler.on_doctype(event)

pub fn emit_error(handler:& EventHandler, kind: i32, message: StrView, line: u32, col: u32)
    let event = ParseErrorEvent {
        kind: kind,
        message: message,
        line: line,
        col: col
    }
    handler.on_error(event)

pub fn emit_warning(handler:& EventHandler, kind: i32, message: StrView, line: u32, col: u32)
    let event = ParseWarningEvent {
        kind: kind,
        message: message,
        line: line,
        col: col
    }
    handler.on_warning(event)
