# tests/test_css_tokenizer.ritz - CSS Tokenizer Tests

import lib.css.tokenizer { CssTokenizer, css_tokenizer_new, css_tokenizer_next }
import lib.css.token

fn assert(cond: i32, msg: StrView)
    if cond == 0
        # Test failed
        0  # Would print error

fn expect_token(t:& CssTokenizer, kind: i32) -> token.CssToken
    let tok = css_tokenizer_next(t)
    assert(tok.kind == kind, "unexpected token kind")
    tok

# =============================================================================
# Basic Token Tests
# =============================================================================

[[test]]
fn test_css_whitespace() -> i32
    var t = css_tokenizer_new("   \t\n  ")
    let tok = css_tokenizer_next(t)
    assert(tok.kind == token.CSS_TOKEN_WHITESPACE, "expected whitespace")
    let eof = css_tokenizer_next(t)
    assert(eof.kind == token.CSS_TOKEN_EOF, "expected EOF")
    0

[[test]]
fn test_css_ident() -> i32
    var t = css_tokenizer_new("margin-left")
    let tok = css_tokenizer_next(t)
    assert(tok.kind == token.CSS_TOKEN_IDENT, "expected ident")
    # Would check tok.value is "margin-left"
    0

[[test]]
fn test_css_function() -> i32
    var t = css_tokenizer_new("rgb(")
    let tok = css_tokenizer_next(t)
    assert(tok.kind == token.CSS_TOKEN_FUNCTION, "expected function")
    # Would check tok.value is "rgb"
    0

[[test]]
fn test_css_hash() -> i32
    var t = css_tokenizer_new("#container")
    let tok = css_tokenizer_next(t)
    assert(tok.kind == token.CSS_TOKEN_HASH, "expected hash")
    assert(tok.hash_type == token.HASH_ID, "expected ID hash")
    0

[[test]]
fn test_css_hash_color() -> i32
    var t = css_tokenizer_new("#ff0000")
    let tok = css_tokenizer_next(t)
    assert(tok.kind == token.CSS_TOKEN_HASH, "expected hash")
    # Would check value is "ff0000"
    0

[[test]]
fn test_css_string_double() -> i32
    var t = css_tokenizer_new("\"hello world\"")
    let tok = css_tokenizer_next(t)
    assert(tok.kind == token.CSS_TOKEN_STRING, "expected string")
    # Would check value is "hello world"
    0

[[test]]
fn test_css_string_single() -> i32
    var t = css_tokenizer_new("'hello world'")
    let tok = css_tokenizer_next(t)
    assert(tok.kind == token.CSS_TOKEN_STRING, "expected string")
    0

[[test]]
fn test_css_number() -> i32
    var t = css_tokenizer_new("42")
    let tok = css_tokenizer_next(t)
    assert(tok.kind == token.CSS_TOKEN_NUMBER, "expected number")
    assert(tok.number_type == token.NUMBER_INTEGER, "expected integer")
    # Would check tok.number is 42.0
    0

[[test]]
fn test_css_number_float() -> i32
    var t = css_tokenizer_new("3.14")
    let tok = css_tokenizer_next(t)
    assert(tok.kind == token.CSS_TOKEN_NUMBER, "expected number")
    assert(tok.number_type == token.NUMBER_FLOAT, "expected float")
    0

[[test]]
fn test_css_percentage() -> i32
    var t = css_tokenizer_new("50%")
    let tok = css_tokenizer_next(t)
    assert(tok.kind == token.CSS_TOKEN_PERCENTAGE, "expected percentage")
    0

[[test]]
fn test_css_dimension_px() -> i32
    var t = css_tokenizer_new("100px")
    let tok = css_tokenizer_next(t)
    assert(tok.kind == token.CSS_TOKEN_DIMENSION, "expected dimension")
    # Would check value is "px"
    0

[[test]]
fn test_css_dimension_em() -> i32
    var t = css_tokenizer_new("1.5em")
    let tok = css_tokenizer_next(t)
    assert(tok.kind == token.CSS_TOKEN_DIMENSION, "expected dimension")
    0

# =============================================================================
# Punctuation Tests
# =============================================================================

[[test]]
fn test_css_punctuation() -> i32
    var t = css_tokenizer_new("{}")
    let open = css_tokenizer_next(t)
    assert(open.kind == token.CSS_TOKEN_OPEN_CURLY, "expected {")
    let close = css_tokenizer_next(t)
    assert(close.kind == token.CSS_TOKEN_CLOSE_CURLY, "expected }")
    0

[[test]]
fn test_css_colon_semicolon() -> i32
    var t = css_tokenizer_new(":;")
    let colon = css_tokenizer_next(t)
    assert(colon.kind == token.CSS_TOKEN_COLON, "expected :")
    let semi = css_tokenizer_next(t)
    assert(semi.kind == token.CSS_TOKEN_SEMICOLON, "expected ;")
    0

[[test]]
fn test_css_brackets() -> i32
    var t = css_tokenizer_new("[]")
    let open = css_tokenizer_next(t)
    assert(open.kind == token.CSS_TOKEN_OPEN_SQUARE, "expected [")
    let close = css_tokenizer_next(t)
    assert(close.kind == token.CSS_TOKEN_CLOSE_SQUARE, "expected ]")
    0

[[test]]
fn test_css_parens() -> i32
    var t = css_tokenizer_new("()")
    let open = css_tokenizer_next(t)
    assert(open.kind == token.CSS_TOKEN_OPEN_PAREN, "expected (")
    let close = css_tokenizer_next(t)
    assert(close.kind == token.CSS_TOKEN_CLOSE_PAREN, "expected )")
    0

# =============================================================================
# At-Rule Tests
# =============================================================================

[[test]]
fn test_css_at_keyword() -> i32
    var t = css_tokenizer_new("@media")
    let tok = css_tokenizer_next(t)
    assert(tok.kind == token.CSS_TOKEN_AT_KEYWORD, "expected at-keyword")
    # Would check value is "media"
    0

[[test]]
fn test_css_at_import() -> i32
    var t = css_tokenizer_new("@import")
    let tok = css_tokenizer_next(t)
    assert(tok.kind == token.CSS_TOKEN_AT_KEYWORD, "expected at-keyword")
    0

# =============================================================================
# Comment Tests
# =============================================================================

[[test]]
fn test_css_comment_removed() -> i32
    var t = css_tokenizer_new("/* comment */margin")
    let tok = css_tokenizer_next(t)
    # Comment should be consumed, next token is ident
    assert(tok.kind == token.CSS_TOKEN_IDENT, "expected ident after comment")
    0

[[test]]
fn test_css_comment_between_tokens() -> i32
    var t = css_tokenizer_new("margin/* comment */:/* another */0")
    let ident = css_tokenizer_next(t)
    assert(ident.kind == token.CSS_TOKEN_IDENT, "expected ident")
    let colon = css_tokenizer_next(t)
    assert(colon.kind == token.CSS_TOKEN_COLON, "expected colon")
    let num = css_tokenizer_next(t)
    assert(num.kind == token.CSS_TOKEN_NUMBER, "expected number")
    0

# =============================================================================
# URL Tests
# =============================================================================

[[test]]
fn test_css_url_unquoted() -> i32
    var t = css_tokenizer_new("url(image.png)")
    let tok = css_tokenizer_next(t)
    assert(tok.kind == token.CSS_TOKEN_URL, "expected url")
    # Would check value is "image.png"
    0

[[test]]
fn test_css_url_quoted() -> i32
    var t = css_tokenizer_new("url(\"image.png\")")
    let tok = css_tokenizer_next(t)
    # Quoted URL returns FUNCTION token, followed by STRING
    assert(tok.kind == token.CSS_TOKEN_FUNCTION, "expected function for quoted url")
    0

# =============================================================================
# Full Declaration Tests
# =============================================================================

[[test]]
fn test_css_declaration() -> i32
    var t = css_tokenizer_new("margin: 10px;")

    let ident = css_tokenizer_next(t)
    assert(ident.kind == token.CSS_TOKEN_IDENT, "expected ident")

    let colon = css_tokenizer_next(t)
    assert(colon.kind == token.CSS_TOKEN_COLON, "expected colon")

    let ws = css_tokenizer_next(t)
    assert(ws.kind == token.CSS_TOKEN_WHITESPACE, "expected whitespace")

    let dim = css_tokenizer_next(t)
    assert(dim.kind == token.CSS_TOKEN_DIMENSION, "expected dimension")

    let semi = css_tokenizer_next(t)
    assert(semi.kind == token.CSS_TOKEN_SEMICOLON, "expected semicolon")

    0

[[test]]
fn test_css_selector() -> i32
    var t = css_tokenizer_new(".container > p")

    let delim = css_tokenizer_next(t)
    assert(delim.kind == token.CSS_TOKEN_DELIM, "expected delim (.)")

    let ident = css_tokenizer_next(t)
    assert(ident.kind == token.CSS_TOKEN_IDENT, "expected ident")

    let ws1 = css_tokenizer_next(t)
    assert(ws1.kind == token.CSS_TOKEN_WHITESPACE, "expected whitespace")

    let gt = css_tokenizer_next(t)
    assert(gt.kind == token.CSS_TOKEN_DELIM, "expected delim (>)")

    let ws2 = css_tokenizer_next(t)
    assert(ws2.kind == token.CSS_TOKEN_WHITESPACE, "expected whitespace")

    let p = css_tokenizer_next(t)
    assert(p.kind == token.CSS_TOKEN_IDENT, "expected ident")

    0
