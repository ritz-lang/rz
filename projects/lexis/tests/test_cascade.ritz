# =============================================================================
# Cascade Apply Tests
# =============================================================================

[[test]]
fn test_apply_empty() -> i32
    let matched = matched_rule_list_new()
    let result = cascade_apply(matched)
    assert(result.count == 0, "empty input should give empty output")
    0

# =============================================================================
# Matched Rule List Tests
# =============================================================================

[[test]]
fn test_rule_list_add() -> i32
    var list = matched_rule_list_new()
    assert(list.count == 0, "new list should be empty")

    var rule: MatchedRule
    rule.important = 0
    rule.origin = ORIGIN_AUTHOR
    rule.specificity = make_specificity(0, 1, 0)
    rule.source_order = 0

    matched_rule_list_add(list, rule)
    assert(list.count == 1, "list should have 1 rule")
    0

[[test]]
fn test_rule_list_sort_by_specificity() -> i32
    var list = matched_rule_list_new()

    # Add low specificity first
    var low: MatchedRule
    low.important = 0
    low.origin = ORIGIN_AUTHOR
    low.specificity = make_specificity(0, 0, 1)
    low.source_order = 0
    matched_rule_list_add(list, low)

    # Add high specificity second
    var high: MatchedRule
    high.important = 0
    high.origin = ORIGIN_AUTHOR
    high.specificity = make_specificity(1, 0, 0)
    high.source_order = 1
    matched_rule_list_add(list, high)

    matched_rule_list_sort(list)

    # After sort, low specificity should be first (will be overridden by high)
    assert(list.rules[0].specificity.type_count == 1, "low specificity should be first")
    assert(list.rules[1].specificity.id_count == 1, "high specificity should be last")
    0
