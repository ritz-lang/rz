# tests/test_cascade.ritz - Cascade Algorithm Tests

import lib.style.cascade { ORIGIN_USER_AGENT, ORIGIN_USER, ORIGIN_AUTHOR,
                           MatchedRule, MatchedRuleList, matched_rule_list_new,
                           matched_rule_list_add, matched_rule_list_sort,
                           cascade_compare, cascade_apply, property_inherits,
                           get_initial_value, apply_inheritance }
import lib.css.rule { Declaration, DeclarationBlock }
import lib.css.selector { Specificity }
import lib.css.value { CssValue, CSS_VALUE_KEYWORD }

fn assert(cond: i32, msg: StrView)
    if cond == 0
        # Test failed
        0

fn make_specificity(ids: u32, classes: u32, types: u32) -> Specificity
    Specificity {
        id_count: ids,
        class_count: classes,
        type_count: types
    }

fn make_declaration(prop: StrView) -> Declaration
    var d: Declaration
    var i: u64 = 0
    while i < prop.len and i < 64
        d.property[i] = prop.data[i]
        i = i + 1
    d.property_len = i as u32
    d.value.kind = CSS_VALUE_KEYWORD
    d.value.string_len = 0
    d.value.number = 0.0
    d.value.unit = 0
    d.value.color_r = 0
    d.value.color_g = 0
    d.value.color_b = 0
    d.value.color_a = 255
    d.value.important = 0
    d

# =============================================================================
# Cascade Comparison Tests
# =============================================================================

[[test]]
fn test_cascade_important_wins() -> i32
    var a: MatchedRule
    a.important = 1
    a.origin = ORIGIN_AUTHOR
    a.specificity = make_specificity(0, 0, 1)
    a.source_order = 0

    var b: MatchedRule
    b.important = 0
    b.origin = ORIGIN_AUTHOR
    b.specificity = make_specificity(1, 0, 0)  # Higher specificity
    b.source_order = 1

    let cmp = cascade_compare(a, b)
    assert(cmp < 0, "!important should beat higher specificity")
    0

[[test]]
fn test_cascade_author_beats_user() -> i32
    var a: MatchedRule
    a.important = 0
    a.origin = ORIGIN_AUTHOR
    a.specificity = make_specificity(0, 0, 1)
    a.source_order = 0

    var b: MatchedRule
    b.important = 0
    b.origin = ORIGIN_USER
    b.specificity = make_specificity(0, 0, 1)
    b.source_order = 0

    let cmp = cascade_compare(a, b)
    assert(cmp < 0, "author should beat user for normal declarations")
    0

[[test]]
fn test_cascade_user_beats_ua() -> i32
    var a: MatchedRule
    a.important = 0
    a.origin = ORIGIN_USER
    a.specificity = make_specificity(0, 0, 1)
    a.source_order = 0

    var b: MatchedRule
    b.important = 0
    b.origin = ORIGIN_USER_AGENT
    b.specificity = make_specificity(0, 0, 1)
    b.source_order = 0

    let cmp = cascade_compare(a, b)
    assert(cmp < 0, "user should beat user-agent")
    0

[[test]]
fn test_cascade_specificity_id_beats_class() -> i32
    var a: MatchedRule
    a.important = 0
    a.origin = ORIGIN_AUTHOR
    a.specificity = make_specificity(1, 0, 0)
    a.source_order = 0

    var b: MatchedRule
    b.important = 0
    b.origin = ORIGIN_AUTHOR
    b.specificity = make_specificity(0, 10, 0)
    b.source_order = 1

    let cmp = cascade_compare(a, b)
    assert(cmp > 0, "ID selector should beat 10 classes")
    0

[[test]]
fn test_cascade_specificity_class_beats_type() -> i32
    var a: MatchedRule
    a.important = 0
    a.origin = ORIGIN_AUTHOR
    a.specificity = make_specificity(0, 1, 0)
    a.source_order = 0

    var b: MatchedRule
    b.important = 0
    b.origin = ORIGIN_AUTHOR
    b.specificity = make_specificity(0, 0, 10)
    b.source_order = 1

    let cmp = cascade_compare(a, b)
    assert(cmp > 0, "class should beat 10 types")
    0

[[test]]
fn test_cascade_source_order() -> i32
    var a: MatchedRule
    a.important = 0
    a.origin = ORIGIN_AUTHOR
    a.specificity = make_specificity(0, 1, 0)
    a.source_order = 0

    var b: MatchedRule
    b.important = 0
    b.origin = ORIGIN_AUTHOR
    b.specificity = make_specificity(0, 1, 0)
    b.source_order = 1

    let cmp = cascade_compare(a, b)
    # Later source order should win (come after in sorted order)
    assert(cmp < 0, "earlier source should come before later")
    0

