[[test]]
fn test_parse_type_selector() -> i32
    var p = css_parser_new("div { }")
    let sheet = css_parse_stylesheet(p)
    assert(sheet.rule_count == 1, "expected 1 rule")
    # Would check selector is type "div"
    0

