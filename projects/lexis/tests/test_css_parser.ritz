# =============================================================================
# Error Recovery
# =============================================================================

[[test]]
fn test_recover_missing_semicolon() -> i32
    var p = css_parser_new("p { color: red font-size: 16px; }")
    let sheet = css_parse_stylesheet(p)
    # Should still parse something
    0

[[test]]
fn test_recover_bad_selector() -> i32
    var p = css_parser_new("## { color: red; } p { margin: 0; }")
    let sheet = css_parse_stylesheet(p)
    # Should recover and parse p rule
    0
