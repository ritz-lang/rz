# =============================================================================
# Specificity Tests
# =============================================================================

[[test]]
fn test_specificity_type() -> i32
    # p has specificity (0, 0, 1)
    let s = Specificity { id_count: 0, class_count: 0, type_count: 1 }
    assert(s.type_count == 1, "expected type_count 1")
    0

[[test]]
fn test_specificity_class() -> i32
    # .foo has specificity (0, 1, 0)
    let s = Specificity { id_count: 0, class_count: 1, type_count: 0 }
    assert(s.class_count == 1, "expected class_count 1")
    0

[[test]]
fn test_specificity_id() -> i32
    # #main has specificity (1, 0, 0)
    let s = Specificity { id_count: 1, class_count: 0, type_count: 0 }
    assert(s.id_count == 1, "expected id_count 1")
    0

[[test]]
fn test_specificity_compare_id_wins() -> i32
    let a = Specificity { id_count: 1, class_count: 0, type_count: 0 }
    let b = Specificity { id_count: 0, class_count: 10, type_count: 0 }
    let cmp = specificity_compare(a, b)
    assert(cmp > 0, "ID should beat classes")
    0

[[test]]
fn test_specificity_compare_class_wins() -> i32
    let a = Specificity { id_count: 0, class_count: 1, type_count: 0 }
    let b = Specificity { id_count: 0, class_count: 0, type_count: 10 }
    let cmp = specificity_compare(a, b)
    assert(cmp > 0, "class should beat types")
    0

[[test]]
fn test_specificity_compare_equal() -> i32
    let a = Specificity { id_count: 1, class_count: 2, type_count: 3 }
    let b = Specificity { id_count: 1, class_count: 2, type_count: 3 }
    let cmp = specificity_compare(a, b)
    assert(cmp == 0, "equal specificities")
    0

