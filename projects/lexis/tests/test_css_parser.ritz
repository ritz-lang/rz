# tests/test_css_parser.ritz - CSS Parser Tests

import lib.css.parser { CssParser, css_parser_new, css_parse_stylesheet, css_parse_selector_list }
import lib.css.rule { Stylesheet, StyleRule }
import lib.css.selector { Specificity, specificity_compare }

fn assert(cond: i32, msg: StrView)
    if cond == 0
        # Test failed
        0

# =============================================================================
# Basic Rule Parsing
# =============================================================================

[[test]]
fn test_parse_empty() -> i32
    var p = css_parser_new("")
    let sheet = css_parse_stylesheet(p)
    assert(sheet.rule_count == 0, "expected 0 rules")
    0

[[test]]
fn test_parse_single_rule() -> i32
    var p = css_parser_new("p { color: red; }")
    let sheet = css_parse_stylesheet(p)
    assert(sheet.rule_count == 1, "expected 1 rule")
    0

[[test]]
fn test_parse_multiple_rules() -> i32
    var p = css_parser_new("p { color: red; } div { margin: 0; }")
    let sheet = css_parse_stylesheet(p)
    assert(sheet.rule_count == 2, "expected 2 rules")
    0

[[test]]
fn test_parse_multiple_declarations() -> i32
    var p = css_parser_new("p { color: red; font-size: 16px; margin: 10px; }")
    let sheet = css_parse_stylesheet(p)
    assert(sheet.rule_count == 1, "expected 1 rule")
    let rule = sheet.rules[0]
    assert(rule.declarations.count == 3, "expected 3 declarations")
    0

