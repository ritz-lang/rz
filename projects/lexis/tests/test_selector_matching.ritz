# tests/test_selector_matching.ritz - Selector Matching Tests

import lib.css.selector { ComplexSelector, CompoundSelector, SimpleSelector,
                          SELECTOR_UNIVERSAL, SELECTOR_TYPE, SELECTOR_ID, SELECTOR_CLASS,
                          SELECTOR_ATTRIBUTE, SELECTOR_PSEUDO_CLASS,
                          COMBINATOR_NONE, COMBINATOR_DESCENDANT, COMBINATOR_CHILD,
                          COMBINATOR_NEXT_SIBLING, COMBINATOR_SUBSEQUENT_SIBLING,
                          ATTR_EXISTS, ATTR_EQUALS, ATTR_INCLUDES }
import lib.style.matching { ElementInfo, selector_matches, element_info_has_class }
import lib.style.bloom { BloomFilter, bloom_filter_new }

fn assert(cond: i32, msg: StrView)
    if cond == 0
        # Test failed
        0

fn null_get_attr(name: StrView) -> StrView
    StrView { data: null, len: 0 }

fn make_element(tag: StrView, id: StrView, classes: StrView) -> ElementInfo
    ElementInfo {
        tag: tag,
        id: id,
        classes: classes,
        get_attribute: null_get_attr,
        parent: null,
        prev_sibling: null,
        ancestor_filter: bloom_filter_new()
    }

fn make_simple_type(name: StrView) -> SimpleSelector
    var s: SimpleSelector
    s.kind = SELECTOR_TYPE
    var i: u64 = 0
    while i < name.len and i < 256
        s.value[i] = name.data[i]
        i = i + 1
    s.value_len = i as u32
    s.attr_matcher = 0
    s.attr_value_len = 0
    s.attr_case_insensitive = 0
    s

fn make_simple_class(name: StrView) -> SimpleSelector
    var s: SimpleSelector
    s.kind = SELECTOR_CLASS
    var i: u64 = 0
    while i < name.len and i < 256
        s.value[i] = name.data[i]
        i = i + 1
    s.value_len = i as u32
    s.attr_matcher = 0
    s.attr_value_len = 0
    s.attr_case_insensitive = 0
    s

fn make_simple_id(name: StrView) -> SimpleSelector
    var s: SimpleSelector
    s.kind = SELECTOR_ID
    var i: u64 = 0
    while i < name.len and i < 256
        s.value[i] = name.data[i]
        i = i + 1
    s.value_len = i as u32
    s.attr_matcher = 0
    s.attr_value_len = 0
    s.attr_case_insensitive = 0
    s

fn make_simple_universal() -> SimpleSelector
    var s: SimpleSelector
    s.kind = SELECTOR_UNIVERSAL
    s.value_len = 0
    s.attr_matcher = 0
    s.attr_value_len = 0
    s.attr_case_insensitive = 0
    s

fn make_compound_single(simple: SimpleSelector) -> CompoundSelector
    var c: CompoundSelector
    c.simple[0] = simple
    c.simple_count = 1
    c

fn make_complex_single(compound: CompoundSelector) -> ComplexSelector
    var cx: ComplexSelector
    cx.compounds[0] = compound
    cx.compound_count = 1
    cx.combinators[0] = COMBINATOR_NONE
    cx

# =============================================================================
# Type Selector Tests
# =============================================================================

[[test]]
fn test_match_type_exact() -> i32
    let elem = make_element("div", "", "")
    let selector = make_complex_single(make_compound_single(make_simple_type("div")))
    assert(selector_matches(selector, elem) == 1, "div should match div")
    0

[[test]]
fn test_match_type_mismatch() -> i32
    let elem = make_element("span", "", "")
    let selector = make_complex_single(make_compound_single(make_simple_type("div")))
    assert(selector_matches(selector, elem) == 0, "span should not match div")
    0

[[test]]
fn test_match_type_case_insensitive() -> i32
    let elem = make_element("DIV", "", "")
    let selector = make_complex_single(make_compound_single(make_simple_type("div")))
    assert(selector_matches(selector, elem) == 1, "DIV should match div")
    0

# =============================================================================
# Universal Selector Tests
# =============================================================================

[[test]]
fn test_match_universal() -> i32
    let elem = make_element("div", "", "")
    let selector = make_complex_single(make_compound_single(make_simple_universal()))
    assert(selector_matches(selector, elem) == 1, "* should match any element")
    0

[[test]]
fn test_match_universal_any_tag() -> i32
    let elem = make_element("custom-element", "", "")
    let selector = make_complex_single(make_compound_single(make_simple_universal()))
    assert(selector_matches(selector, elem) == 1, "* should match custom elements")
    0

# =============================================================================
# Class Selector Tests
# =============================================================================

[[test]]
fn test_match_class_single() -> i32
    let elem = make_element("div", "", "container")
    let selector = make_complex_single(make_compound_single(make_simple_class("container")))
    assert(selector_matches(selector, elem) == 1, ".container should match")
    0

[[test]]
fn test_match_class_multiple() -> i32
    let elem = make_element("div", "", "foo bar baz")
    let selector = make_complex_single(make_compound_single(make_simple_class("bar")))
    assert(selector_matches(selector, elem) == 1, ".bar should match element with 'foo bar baz'")
    0

[[test]]
fn test_match_class_not_found() -> i32
    let elem = make_element("div", "", "foo bar")
    let selector = make_complex_single(make_compound_single(make_simple_class("baz")))
    assert(selector_matches(selector, elem) == 0, ".baz should not match 'foo bar'")
    0

[[test]]
fn test_match_class_partial_no_match() -> i32
    let elem = make_element("div", "", "container-fluid")
    let selector = make_complex_single(make_compound_single(make_simple_class("container")))
    assert(selector_matches(selector, elem) == 0, ".container should not match container-fluid")
    0

# =============================================================================
# ID Selector Tests
# =============================================================================

[[test]]
fn test_match_id() -> i32
    let elem = make_element("div", "main", "")
    let selector = make_complex_single(make_compound_single(make_simple_id("main")))
    assert(selector_matches(selector, elem) == 1, "#main should match")
    0

[[test]]
fn test_match_id_mismatch() -> i32
    let elem = make_element("div", "header", "")
    let selector = make_complex_single(make_compound_single(make_simple_id("main")))
    assert(selector_matches(selector, elem) == 0, "#main should not match #header")
    0

# =============================================================================
# Compound Selector Tests
# =============================================================================

[[test]]
fn test_match_compound_type_class() -> i32
    let elem = make_element("div", "", "container")

    var compound: CompoundSelector
    compound.simple[0] = make_simple_type("div")
    compound.simple[1] = make_simple_class("container")
    compound.simple_count = 2

    let selector = make_complex_single(compound)
    assert(selector_matches(selector, elem) == 1, "div.container should match")
    0

[[test]]
fn test_match_compound_type_class_mismatch_type() -> i32
    let elem = make_element("span", "", "container")

    var compound: CompoundSelector
    compound.simple[0] = make_simple_type("div")
    compound.simple[1] = make_simple_class("container")
    compound.simple_count = 2

    let selector = make_complex_single(compound)
    assert(selector_matches(selector, elem) == 0, "div.container should not match span.container")
    0

[[test]]
fn test_match_compound_type_id_class() -> i32
    let elem = make_element("div", "main", "container active")

    var compound: CompoundSelector
    compound.simple[0] = make_simple_type("div")
    compound.simple[1] = make_simple_id("main")
    compound.simple[2] = make_simple_class("container")
    compound.simple_count = 3

    let selector = make_complex_single(compound)
    assert(selector_matches(selector, elem) == 1, "div#main.container should match")
    0

# =============================================================================
# Helper Function Tests
# =============================================================================

[[test]]
fn test_element_has_class_single() -> i32
    let elem = make_element("div", "", "foo")
    assert(element_info_has_class(elem, "foo") == 1, "should have class foo")
    0

[[test]]
fn test_element_has_class_multiple() -> i32
    let elem = make_element("div", "", "foo bar baz")
    assert(element_info_has_class(elem, "foo") == 1, "should have foo")
    assert(element_info_has_class(elem, "bar") == 1, "should have bar")
    assert(element_info_has_class(elem, "baz") == 1, "should have baz")
    0

[[test]]
fn test_element_has_class_empty() -> i32
    let elem = make_element("div", "", "")
    assert(element_info_has_class(elem, "foo") == 0, "empty should not have foo")
    0

# =============================================================================
# Complex Selector Tests (would need parent/sibling setup)
# =============================================================================

# TODO: Add tests for descendant, child, sibling combinators
# These require setting up parent/sibling pointers which is more involved

[[test]]
fn test_complex_empty() -> i32
    var selector: ComplexSelector
    selector.compound_count = 0
    let elem = make_element("div", "", "")
    assert(selector_matches(selector, elem) == 0, "empty selector should not match")
    0
