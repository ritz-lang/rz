# Angelo - Simple Render Test
#
# A minimal test that renders a simple shape to PGM
# without loading external fonts.
#
# Run: ./rz run angelo
# View: feh test_output.pgm

import ritzlib.sys { sys_open, sys_write, sys_close, O_WRONLY, O_CREAT, O_TRUNC }
import ritzlib.strview { strview_as_ptr }
import ritzlib.gvec

# Write a PGM file
fn write_pgm(path: StrView, width: u32, height: u32, data: @Vec<u8>) -> i32
    # Open file
    let flags = O_WRONLY | O_CREAT | O_TRUNC
    let cstr = strview_as_ptr(@path)
    let fd = sys_open(cstr, flags)
    if fd < 0
        print("Failed to open file\n")
        return 1

    # Build header
    var header = vec_new<u8>()

    # "P5\n"
    header.push(80 as u8)   # 'P'
    header.push(53 as u8)   # '5'
    header.push(10 as u8)   # '\n'

    # Width
    append_number(@&header, width)
    header.push(32 as u8)   # ' '

    # Height
    append_number(@&header, height)
    header.push(10 as u8)   # '\n'

    # "255\n"
    header.push(50 as u8)   # '2'
    header.push(53 as u8)   # '5'
    header.push(53 as u8)   # '5'
    header.push(10 as u8)   # '\n'

    # Write header
    let h_ptr = vec_as_ptr<u8>(@header)
    let h_len = vec_len<u8>(@header)
    let w1 = sys_write(fd, h_ptr, h_len)
    if w1 < 0
        sys_close(fd)
        return 1

    # Write pixel data
    let d_ptr = vec_as_ptr<u8>(data)
    let d_len = vec_len<u8>(data)
    let w2 = sys_write(fd, d_ptr, d_len)
    if w2 < 0
        sys_close(fd)
        return 1

    sys_close(fd)
    0

# Append a number as ASCII digits
fn append_number(out:& Vec<u8>, n: u32)
    if n == 0
        out.push(48 as u8)
        return

    # Build digits in reverse
    var digits = vec_new<u8>()
    var val = n
    while val > 0
        let digit = (val % 10) as u8
        digits.push(48 as u8 + digit)
        val = val / 10

    # Output in correct order
    var i = vec_len<u8>(@digits)
    while i > 0
        i = i - 1
        out.push(vec_get<u8>(@digits, i))

# Create a simple gradient test image
fn create_gradient(width: u32, height: u32) -> Vec<u8>
    var data = vec_with_cap<u8>((width * height) as usize)

    for y in 0..height
        for x in 0..width
            # Simple diagonal gradient
            let val = ((x + y) * 255 / (width + height)) as u8
            data.push(val)

    data

# Draw a filled circle
fn draw_circle(data:& Vec<u8>, width: u32, height: u32, cx: i32, cy: i32, r: i32)
    for y in 0..height as i32
        for x in 0..width as i32
            let dx = x - cx
            let dy = y - cy
            let dist_sq = dx * dx + dy * dy
            let r_sq = r * r

            let idx = (y as u32 * width + x as u32) as i64

            if dist_sq <= r_sq
                # Inside circle - set to white
                vec_set<u8>(data, idx, 255 as u8)
            else if dist_sq <= r_sq + r * 2
                # Anti-aliased edge
                let edge_dist = dist_sq - r_sq
                let alpha = 255 - (edge_dist * 128 / (r * 2)) as u8
                if alpha > vec_get<u8>(data, idx)
                    vec_set<u8>(data, idx, alpha)

# Draw text "Hi" using simple pixel font
fn draw_text_hi(data:& Vec<u8>, width: u32, start_x: u32, start_y: u32)
    # Simple 8x8 "H" pattern
    let h_pattern: [8]u8 = [
        0b10000010,
        0b10000010,
        0b10000010,
        0b11111110,
        0b10000010,
        0b10000010,
        0b10000010,
        0b10000010
    ]

    # Simple 8x8 "i" pattern
    let i_pattern: [8]u8 = [
        0b00010000,
        0b00000000,
        0b00010000,
        0b00010000,
        0b00010000,
        0b00010000,
        0b00010000,
        0b00010000
    ]

    # Draw H
    draw_char(data, width, start_x, start_y, @h_pattern)

    # Draw i (offset by 10 pixels)
    draw_char(data, width, start_x + 10, start_y, @i_pattern)

fn draw_char(data:& Vec<u8>, width: u32, x: u32, y: u32, pattern: @[8]u8)
    var row: i32 = 0
    while row < 8
        let bits: u8 = pattern[row]
        var col: i32 = 0
        while col < 8
            let shift_amt = 7 - col
            let bit: u8 = (bits >> shift_amt) & 1
            if bit == 1
                let px = x + col as u32
                let py = y + row as u32
                let idx = (py * width + px) as i64
                if idx < vec_len<u8>(data)
                    vec_set<u8>(data, idx, 255 as u8)
            col = col + 1
        row = row + 1

pub fn main() -> i32
    print("Angelo Simple Render Test\n")
    print("=========================\n\n")

    let width: u32 = 100
    let height: u32 = 60

    # Create image with dark background
    var data = vec_with_cap<u8>((width * height) as usize)
    for i in 0..(width * height)
        data.push(32 as u8)  # Dark gray background

    # Draw a circle
    draw_circle(@&data, width, height, 30, 30, 20)

    # Draw "Hi" text
    draw_text_hi(@&data, width, 60, 25)

    # Write output
    let result = write_pgm("test_output.pgm", width, height, @data)

    if result == 0
        print("Wrote test_output.pgm successfully!\n")
        print("View with: feh test_output.pgm\n")
        print("Or: convert test_output.pgm test_output.png && display test_output.png\n")
        0
    else
        print("Failed to write output\n")
        1
