# Angelo - TrueType Instructions
#
# TrueType has ~200 instructions for manipulating glyph outlines.
# They operate on a stack machine with a graphics state.
#
# Instruction categories:
# - Stack operations (PUSH, POP, DUP, SWAP, etc.)
# - Arithmetic (ADD, SUB, MUL, DIV, etc.)
# - Comparisons (LT, GT, EQ, etc.)
# - Control flow (IF, ELSE, EIF, JMPR, etc.)
# - Point manipulation (MDAP, MIAP, MIRP, etc.)
# - Measurements (GC, SCFS, MD, etc.)
# - Function calls (CALL, FDEF, IDEF)
# - Rounding (ROUND, NROUND)
# - CVT access (RCVT, WCVT)
# - Storage access (RS, WS)

# Instruction opcodes (subset - full set has ~200)
pub const NPUSHB: u8 = 0x40    # Push N bytes
pub const NPUSHW: u8 = 0x41    # Push N words
pub const PUSHB: u8 = 0xB0     # Push bytes (B0-B7 = 1-8 bytes)
pub const PUSHW: u8 = 0xB8     # Push words (B8-BF = 1-8 words)

# Stack operations
pub const POP: u8 = 0x21       # Pop top of stack
pub const CLEAR: u8 = 0x22     # Clear stack
pub const SWAP: u8 = 0x23      # Swap top two elements
pub const DEPTH: u8 = 0x24     # Push stack depth
pub const CINDEX: u8 = 0x25    # Copy indexed element
pub const MINDEX: u8 = 0x26    # Move indexed element to top
pub const DUP: u8 = 0x20       # Duplicate top element
pub const ROLL: u8 = 0x8A      # Roll top three elements

# Arithmetic
pub const ADD: u8 = 0x60       # Add top two elements
pub const SUB: u8 = 0x61       # Subtract
pub const DIV: u8 = 0x62       # Divide
pub const MUL: u8 = 0x63       # Multiply
pub const ABS: u8 = 0x64       # Absolute value
pub const NEG: u8 = 0x65       # Negate
pub const FLOOR: u8 = 0x66     # Floor
pub const CEILING: u8 = 0x67   # Ceiling
pub const MAX: u8 = 0x8B       # Maximum
pub const MIN: u8 = 0x8C       # Minimum

# Comparisons
pub const LT: u8 = 0x50        # Less than
pub const LTEQ: u8 = 0x51      # Less than or equal
pub const GT: u8 = 0x52        # Greater than
pub const GTEQ: u8 = 0x53      # Greater than or equal
pub const EQ: u8 = 0x54        # Equal
pub const NEQ: u8 = 0x55       # Not equal
pub const AND: u8 = 0x5A       # Logical AND
pub const OR: u8 = 0x5B        # Logical OR
pub const NOT: u8 = 0x5C       # Logical NOT
pub const ODD: u8 = 0x56       # Is odd
pub const EVEN: u8 = 0x57      # Is even

# Control flow
pub const IF: u8 = 0x58        # If
pub const ELSE: u8 = 0x1B      # Else
pub const EIF: u8 = 0x59       # End if
pub const JMPR: u8 = 0x1C      # Jump relative
pub const JROT: u8 = 0x78      # Jump relative on true
pub const JROF: u8 = 0x79      # Jump relative on false

# Function calls
pub const FDEF: u8 = 0x2C      # Function definition
pub const ENDF: u8 = 0x2D      # End function
pub const CALL: u8 = 0x2B      # Call function
pub const LOOPCALL: u8 = 0x2A  # Loop and call
pub const IDEF: u8 = 0x89      # Instruction definition

# CVT (Control Value Table)
pub const RCVT: u8 = 0x45      # Read CVT
pub const WCVTP: u8 = 0x44     # Write CVT in pixel units
pub const WCVTF: u8 = 0x70     # Write CVT in FUnits

# Storage
pub const RS: u8 = 0x43        # Read storage
pub const WS: u8 = 0x42        # Write storage

# Graphics state
pub const SRP0: u8 = 0x10      # Set reference point 0
pub const SRP1: u8 = 0x11      # Set reference point 1
pub const SRP2: u8 = 0x12      # Set reference point 2
pub const SZP0: u8 = 0x13      # Set zone pointer 0
pub const SZP1: u8 = 0x14      # Set zone pointer 1
pub const SZP2: u8 = 0x15      # Set zone pointer 2
pub const SZPS: u8 = 0x16      # Set zone pointers
pub const SLOOP: u8 = 0x17     # Set loop count
pub const SMD: u8 = 0x1A       # Set minimum distance
pub const SCVTCI: u8 = 0x1D    # Set CVT cutin
pub const SSWCI: u8 = 0x1E     # Set single width cutin
pub const SSW: u8 = 0x1F       # Set single width value

# Rounding
pub const ROUND: u8 = 0x68     # Round value (68-6B for different modes)
pub const NROUND: u8 = 0x6C    # No round (6C-6F)
pub const ROFF: u8 = 0x7A      # Round off
pub const RUTG: u8 = 0x7C      # Round up to grid
pub const RDTG: u8 = 0x7D      # Round down to grid
pub const SROUND: u8 = 0x76    # Super round
pub const S45ROUND: u8 = 0x77  # Super 45° round
pub const RTG: u8 = 0x18       # Round to grid
pub const RTHG: u8 = 0x19      # Round to half grid

# Freedom and projection vectors
pub const SVTCA: u8 = 0x00     # Set freedom & projection to coord axis (00-01)
pub const SPVTCA: u8 = 0x02    # Set projection to coord axis (02-03)
pub const SFVTCA: u8 = 0x04    # Set freedom to coord axis (04-05)
pub const SPVTL: u8 = 0x06     # Set projection to line (06-07)
pub const SFVTL: u8 = 0x08     # Set freedom to line (08-09)
pub const SFVTPV: u8 = 0x0E    # Set freedom to projection
pub const SPVFS: u8 = 0x0A     # Set projection from stack
pub const SFVFS: u8 = 0x0B     # Set freedom from stack
pub const GPV: u8 = 0x0C       # Get projection vector
pub const GFV: u8 = 0x0D       # Get freedom vector

# Point manipulation
pub const SHP: u8 = 0x32       # Shift point (32-33)
pub const SHC: u8 = 0x34       # Shift contour (34-35)
pub const SHZ: u8 = 0x36       # Shift zone (36-37)
pub const SHPIX: u8 = 0x38     # Shift by pixels
pub const IP: u8 = 0x39        # Interpolate points
pub const MDAP: u8 = 0x2E      # Move direct absolute point (2E-2F)
pub const MIAP: u8 = 0x3E      # Move indirect absolute point (3E-3F)
pub const MDRP: u8 = 0xC0      # Move direct relative point (C0-DF)
pub const MIRP: u8 = 0xE0      # Move indirect relative point (E0-FF)
pub const MSIRP: u8 = 0x3A     # Move stack indirect relative point (3A-3B)
pub const ALIGNRP: u8 = 0x3C   # Align relative point
pub const ISECT: u8 = 0x0F     # Move to intersection
pub const ALIGNPTS: u8 = 0x27  # Align points
pub const UTP: u8 = 0x29       # Untouch point

# Measurements
pub const GC: u8 = 0x46        # Get coordinate (46-47)
pub const SCFS: u8 = 0x48      # Set coordinate from stack
pub const MD: u8 = 0x49        # Measure distance (49-4A)
pub const MPPEM: u8 = 0x4B     # Measure pixels per em
pub const MPS: u8 = 0x4C       # Measure point size

# Miscellaneous
pub const FLIPON: u8 = 0x4D    # Auto-flip on
pub const FLIPOFF: u8 = 0x4E   # Auto-flip off
pub const FLIPPT: u8 = 0x80    # Flip point
pub const FLIPRGON: u8 = 0x81  # Flip range on
pub const FLIPRGOFF: u8 = 0x82 # Flip range off
pub const SCANCTRL: u8 = 0x85  # Scan conversion control
pub const SCANTYPE: u8 = 0x8D  # Scan conversion type
pub const INSTCTRL: u8 = 0x8E  # Instruction control
pub const GETINFO: u8 = 0x88   # Get font info
pub const DELTAP1: u8 = 0x5D   # Delta exception P1
pub const DELTAP2: u8 = 0x71   # Delta exception P2
pub const DELTAP3: u8 = 0x72   # Delta exception P3
pub const DELTAC1: u8 = 0x73   # Delta exception C1
pub const DELTAC2: u8 = 0x74   # Delta exception C2
pub const DELTAC3: u8 = 0x75   # Delta exception C3
pub const DEBUG: u8 = 0x4F     # Debug call

# Decode an instruction mnemonic (for debugging)
pub fn instruction_name(opcode: u8) -> StrView
    match opcode
        0x40 => "NPUSHB"
        0x41 => "NPUSHW"
        0x21 => "POP"
        0x22 => "CLEAR"
        0x23 => "SWAP"
        0x24 => "DEPTH"
        0x20 => "DUP"
        0x60 => "ADD"
        0x61 => "SUB"
        0x62 => "DIV"
        0x63 => "MUL"
        0x58 => "IF"
        0x1B => "ELSE"
        0x59 => "EIF"
        0x2C => "FDEF"
        0x2D => "ENDF"
        0x2B => "CALL"
        0x2E => "MDAP[0]"
        0x2F => "MDAP[1]"
        0x3E => "MIAP[0]"
        0x3F => "MIAP[1]"
        _ =>
            if opcode >= 0xB0 and opcode <= 0xB7
                "PUSHB"
            else if opcode >= 0xB8 and opcode <= 0xBF
                "PUSHW"
            else if opcode >= 0xC0 and opcode <= 0xDF
                "MDRP"
            else if opcode >= 0xE0 and opcode <= 0xFF
                "MIRP"
            else
                "???"

# Tests

[[test]]
fn test_instruction_opcodes() -> i32
    # Verify some important opcodes
    assert NPUSHB == 0x40
    assert CALL == 0x2B
    assert IF == 0x58
    assert EIF == 0x59
    assert MDAP == 0x2E
    0

[[test]]
fn test_instruction_names() -> i32
    assert instruction_name(0x40) == "NPUSHB"
    assert instruction_name(0x2B) == "CALL"
    assert instruction_name(0xB5) == "PUSHB"
    assert instruction_name(0xE0) == "MIRP"
    0
