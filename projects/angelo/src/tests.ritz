[[test]]
fn test_composite_glyph_resolution() -> i32
    # Test that composite glyphs are resolved correctly
    # Note: aadhunik.ttf may or may not have composite glyphs,
    # but the code path should work regardless
    var font = load_font("tests/fixtures/aadhunik.ttf").unwrap()

    # Try to get outlines for all glyphs - composite resolution should not crash
    let num_glyphs = font.num_glyphs()

    for i in 0..num_glyphs as usize
        let outline = font.glyph_outline(i as u16)
        # Should return Some (possibly empty) or None, never crash
        # Even composite glyphs should resolve to valid outlines

    0

[[test]]
fn test_composite_depth_limit_protection() -> i32
    # This test verifies the depth limit protects against stack overflow
    # We can't easily create a malicious font, but we can verify:
    # 1. The depth limit constant exists (MAX_DEPTH = 10)
    # 2. All glyphs resolve without crashing
    # 3. Resolution completes in reasonable time (no infinite loops)

    var font = load_font("tests/fixtures/aadhunik.ttf").unwrap()
    let num_glyphs = font.num_glyphs()

    var resolved_count = 0
    var empty_count = 0

    for i in 0..num_glyphs as usize
        let outline = font.glyph_outline(i as u16)
        match outline
            Some(o) =>
                resolved_count = resolved_count + 1
                if o.is_empty()
                    empty_count = empty_count + 1
            None =>
                pass  # Failed to resolve

    # Most glyphs should resolve successfully
    assert resolved_count > 0

    # Some glyphs may be empty (space, etc.)
    # This test passes as long as we didn't crash or hang

    0

[[test]]
fn test_all_glyphs_render_without_crash() -> i32
    # Comprehensive test: attempt to rasterize every glyph in the font
    # This exercises composite glyph resolution under real conditions
    var font = load_font("tests/fixtures/aadhunik.ttf").unwrap()
    let metrics = font.metrics()
    let num_glyphs = font.num_glyphs()

    var render_success = 0
    var render_empty = 0

    for i in 0..num_glyphs as usize
        let glyph = font.get_glyph(i as u16)
        if glyph.is_some()
            let g = glyph.unwrap()

            # Attempt to rasterize
            let raster = rasterize_glyph(
                g.outline,
                metrics.units_per_em,
                16,
                g.metrics.advance_width,
                g.metrics.left_side_bearing,
                true
            )

            if raster.width > 0 and raster.height > 0
                render_success = render_success + 1
            else
                render_empty = render_empty + 1

    # Should render at least some glyphs successfully
    # (font has 117 glyphs, many should render)
    assert render_success > 0

    # No crashes = test passed
    0
