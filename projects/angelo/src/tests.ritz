[[test]]
fn test_shape_simple_text() -> i32
    var font = load_font("tests/fixtures/aadhunik.ttf").unwrap()

    let run = shape_text(@&font, "Hello", 1, 16.0)

    # Should have 5 glyphs for "Hello"
    assert run.glyph_count() == 5

    # Total advance should be positive
    let total = run.total_advance()
    assert total > 0.0

    # Each glyph should have a valid glyph_id
    for g in @run.glyphs
        # glyph_id 0 is .notdef, which is okay for missing chars
        # but cluster should increment
        pass

    0

[[test]]
fn test_shape_with_spaces() -> i32
    var font = load_font("tests/fixtures/aadhunik.ttf").unwrap()

    let run = shape_text(@&font, "A B C", 1, 16.0)

    # Should have 5 glyphs: A, space, B, space, C
    assert run.glyph_count() == 5

    0

[[test]]
fn test_shape_empty_string() -> i32
    var font = load_font("tests/fixtures/aadhunik.ttf").unwrap()

    let run = shape_text(@&font, "", 1, 16.0)

    assert run.is_empty()
    assert run.glyph_count() == 0

    0

[[test]]
fn test_measure_text_width() -> i32
    var font = load_font("tests/fixtures/aadhunik.ttf").unwrap()

    let width1 = measure_text_width(@&font, "A", 16.0)
    let width2 = measure_text_width(@&font, "AA", 16.0)
    let width3 = measure_text_width(@&font, "AAA", 16.0)

    # Width should increase with more characters
    assert width2 > width1
    assert width3 > width2

    # Width should roughly double for double characters
    # (not exact due to potential kerning, but close)
    let ratio = width2 / width1
    assert ratio > 1.5 and ratio < 2.5

    0

[[test]]
fn test_shape_clusters() -> i32
    var font = load_font("tests/fixtures/aadhunik.ttf").unwrap()

    let run = shape_text(@&font, "ABC", 1, 16.0)

    # Clusters should be 0, 1, 2 for simple LTR text
    assert run.glyphs[0].cluster == 0
    assert run.glyphs[1].cluster == 1
    assert run.glyphs[2].cluster == 2

    0

[[test]]
fn test_shape_different_sizes() -> i32
    var font = load_font("tests/fixtures/aadhunik.ttf").unwrap()

    let run12 = shape_text(@&font, "Test", 1, 12.0)
    let run24 = shape_text(@&font, "Test", 1, 24.0)
    let run48 = shape_text(@&font, "Test", 1, 48.0)

    # Larger sizes should have larger advances
    let w12 = run12.total_advance()
    let w24 = run24.total_advance()
    let w48 = run48.total_advance()

    assert w24 > w12
    assert w48 > w24

    # 24pt should be roughly 2x 12pt
    let ratio = w24 / w12
    assert ratio > 1.8 and ratio < 2.2

    0

[[test]]
fn test_full_text_pipeline() -> i32
    # Complete pipeline: load -> shape -> rasterize -> cache
    var font = load_font("tests/fixtures/aadhunik.ttf").unwrap()
    let metrics = font.metrics()
    var cache = GlyphCache.new(100)

    # Shape some text
    let run = shape_text(@&font, "Test", 1, 24.0)

    # Rasterize each glyph and cache it
    for shaped in @run.glyphs
        let key = GlyphCacheKey.new(1, shaped.glyph_id as u16, 24)

        # Check cache
        if cache.get(key).is_none()
            # Rasterize
            let glyph = font.get_glyph(shaped.glyph_id as u16)
            if glyph.is_some()
                let g = glyph.unwrap()
                let raster = rasterize_glyph(
                    g.outline,
                    metrics.units_per_em,
                    24,
                    g.metrics.advance_width,
                    g.metrics.left_side_bearing,
                    true
                )
                cache.insert(key, raster)

    # Should have cached some glyphs
    assert cache.len() > 0

    0

import types { GlyphOutline }
import shaper.simple { shape_text, measure_text_width }
import raster.subpixel { rasterize_subpixel, SubpixelOrder }
import cache { SubpixelCacheKey, SubpixelGlyphCache }

# ============================================================================
# Complete End-to-End Integration Tests
# ============================================================================

[[test]]
fn test_complete_text_rendering_pipeline() -> i32
    # Full pipeline test: Load -> Shape -> Rasterize (AA + Subpixel) -> Cache

    # 1. Load font
    var font = load_font("tests/fixtures/aadhunik.ttf").unwrap()
    let metrics = font.metrics()

    # Verify font loaded correctly
    assert metrics.units_per_em > 0
    assert font.num_glyphs() > 0

    # 2. Shape text
    let text = "Hello"
    let run = shape_text(@&font, text, 1, 16.0)

    # Verify shaping
    assert run.glyph_count() == 5  # "Hello" = 5 chars
    assert run.total_advance() > 0.0

    # 3. Rasterize each glyph (grayscale AA)
    var cache = GlyphCache.new(100)
    var rasterized_count = 0

    for shaped in @run.glyphs
        let glyph_id = shaped.glyph_id as u16
        let key = GlyphCacheKey.new(1, glyph_id, 16)

        # Check cache
        if cache.get(key).is_none()
            let glyph = font.get_glyph(glyph_id)
            if glyph.is_some()
                let g = glyph.unwrap()
                let raster = rasterize_glyph(
                    g.outline,
                    metrics.units_per_em,
                    16,
                    g.metrics.advance_width,
                    g.metrics.left_side_bearing,
                    true  # antialiasing
                )
                cache.insert(key, raster)
                rasterized_count = rasterized_count + 1

    # Verify we rasterized and cached glyphs
    assert cache.len() > 0

    # 4. Test subpixel rendering
    var sp_cache = SubpixelGlyphCache.new(100)

    for shaped in @run.glyphs
        let glyph_id = shaped.glyph_id as u16
        let glyph = font.get_glyph(glyph_id)
        if glyph.is_some()
            let g = glyph.unwrap()
            let sp_raster = rasterize_subpixel(
                g.outline,
                metrics.units_per_em,
                16,
                SubpixelOrder.RGB
            )
            let sp_key = SubpixelCacheKey.new(1, glyph_id, 16, SubpixelOrder.RGB)
            sp_cache.insert(sp_key, sp_raster)

    # Verify subpixel cache has entries
    assert sp_cache.len() > 0

    # 5. Verify cache hits on second pass
    for shaped in @run.glyphs
        let glyph_id = shaped.glyph_id as u16
        let key = GlyphCacheKey.new(1, glyph_id, 16)
        let cached = cache.get(key)
        # Should be a hit (we just cached these)

    # Cache hit rate should be 100% for second pass
    let hit_rate = cache.hit_rate()
    assert hit_rate > 0.4  # At least some hits

    0

[[test]]
fn test_pipeline_with_missing_glyphs() -> i32
    # Test that the pipeline handles missing characters gracefully
    var font = load_font("tests/fixtures/aadhunik.ttf").unwrap()
    let metrics = font.metrics()

    # Shape text with characters likely not in this Devanagari font
    # (Using ASCII chars that might map to .notdef)
    let run = shape_text(@&font, "XYZ123", 1, 16.0)

    # Should still get 6 glyphs (even if they're .notdef)
    assert run.glyph_count() == 6

    # Rasterize - should not crash even for .notdef
    var cache = GlyphCache.new(100)
    for shaped in @run.glyphs
        let glyph_id = shaped.glyph_id as u16
        let glyph = font.get_glyph(glyph_id)
        if glyph.is_some()
            let g = glyph.unwrap()
            let raster = rasterize_glyph(
                g.outline,
                metrics.units_per_em,
                16,
                g.metrics.advance_width,
                g.metrics.left_side_bearing,
                true
            )
            let key = GlyphCacheKey.new(1, glyph_id, 16)
            cache.insert(key, raster)

    # Pipeline completed without crashing
    0

[[test]]
fn test_pipeline_at_various_sizes() -> i32
    # Test rendering at different font sizes
    var font = load_font("tests/fixtures/aadhunik.ttf").unwrap()
    let metrics = font.metrics()

    let sizes: [4]u32 = [8, 16, 32, 64]

    for size in @sizes
        let run = shape_text(@&font, "A", 1, size as f32)

        # Shape should produce 1 glyph
        assert run.glyph_count() == 1

        # Advance should scale with size
        let advance = run.total_advance()
        assert advance > 0.0

        # Rasterize at this size
        let shaped = @run.glyphs[0]
        let glyph = font.get_glyph(shaped.glyph_id as u16)
        if glyph.is_some()
            let g = glyph.unwrap()
            let raster = rasterize_glyph(
                g.outline,
                metrics.units_per_em,
                size,
                g.metrics.advance_width,
                g.metrics.left_side_bearing,
                true
            )
            # Larger sizes should generally produce larger bitmaps
            # (unless the glyph has no outline)

    0

