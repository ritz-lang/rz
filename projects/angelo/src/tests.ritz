# Angelo - Integration Tests
#
# Tests using real font files.

import font { load_font, Font }
import types { TAG_HEAD, TAG_CMAP, TAG_GLYF, TAG_LOCA, TAG_HMTX, GlyphCacheKey }
import raster.render { rasterize_outline, rasterize_glyph }
import cache { GlyphCache }

# ============================================================================
# Font Loading Tests
# ============================================================================

[[test]]
fn test_load_aadhunik_font() -> i32
    let result = load_font("tests/fixtures/aadhunik.ttf")

    match result
        Ok(font) =>
            # Check basic metrics
            let metrics = font.metrics()
            assert metrics.units_per_em > 0

            # Check glyph count
            let num_glyphs = font.num_glyphs()
            assert num_glyphs > 0
            # From the hex dump we saw 0x0075 = 117 glyphs
            assert num_glyphs == 117

            0
        Err(msg) =>
            1  # fail

[[test]]
fn test_font_metrics() -> i32
    let font = load_font("tests/fixtures/aadhunik.ttf").unwrap()
    let metrics = font.metrics()

    # units_per_em is typically 1000 or 2048
    assert metrics.units_per_em == 2048 or metrics.units_per_em == 1000

    # Ascender should be positive
    assert metrics.ascender > 0

    0

[[test]]
fn test_glyph_lookup() -> i32
    var font = load_font("tests/fixtures/aadhunik.ttf").unwrap()

    # Look up space character (should exist in any font)
    let space_id = font.glyph_id(0x20)  # ASCII space
    assert space_id.is_some()

    # Space is usually a small glyph ID
    assert space_id.unwrap() < 100

    0

[[test]]
fn test_glyph_metrics() -> i32
    var font = load_font("tests/fixtures/aadhunik.ttf").unwrap()

    # Get metrics for .notdef (glyph 0)
    let metrics = font.glyph_metrics(0)
    assert metrics.is_some()

    let m = metrics.unwrap()
    # Advance width should be positive
    assert m.advance_width > 0

    0

[[test]]
fn test_glyph_outline() -> i32
    var font = load_font("tests/fixtures/aadhunik.ttf").unwrap()

    # Get outline for a glyph that should have one
    let a_id = font.glyph_id(0x41)  # 'A'

    if a_id.is_some()
        let outline = font.glyph_outline(a_id.unwrap())
        if outline.is_some()
            let o = outline.unwrap()
            if not o.is_empty()
                assert o.contours.len() > 0

    # Space should have empty outline
    let space_id = font.glyph_id(0x20)
    if space_id.is_some()
        let space_outline = font.glyph_outline(space_id.unwrap())
        if space_outline.is_some()
            pass

    0

[[test]]
fn test_get_full_glyph() -> i32
    var font = load_font("tests/fixtures/aadhunik.ttf").unwrap()

    let glyph = font.get_glyph(1)

    match glyph
        Some(g) =>
            assert g.id == 1
            assert g.metrics.advance_width >= 0
            0
        None =>
            0

[[test]]
fn test_glyph_for_char() -> i32
    var font = load_font("tests/fixtures/aadhunik.ttf").unwrap()

    let space = font.get_glyph_for_char(0x20)

    match space
        Some(g) =>
            assert g.metrics.advance_width > 0
            0
        None =>
            1

[[test]]
fn test_font_has_required_tables() -> i32
    let font = load_font("tests/fixtures/aadhunik.ttf").unwrap()

    assert font.file.has_table(TAG_HEAD)
    assert font.file.has_table(TAG_CMAP)
    assert font.file.has_table(TAG_GLYF)
    assert font.file.has_table(TAG_LOCA)
    assert font.file.has_table(TAG_HMTX)

    0

[[test]]
fn test_all_glyphs_accessible() -> i32
    var font = load_font("tests/fixtures/aadhunik.ttf").unwrap()
    let num_glyphs = font.num_glyphs()

    var success_count = 0
    var fail_count = 0

    for i in 0..num_glyphs as usize
        let glyph_id = i as u16
        let metrics = font.glyph_metrics(glyph_id)

        if metrics.is_some()
            success_count = success_count + 1
        else
            fail_count = fail_count + 1

    assert success_count > 0
    assert fail_count < num_glyphs as i32 / 2

    0

# ============================================================================
# Rasterization Tests
# ============================================================================

[[test]]
fn test_rasterize_real_glyph() -> i32
    var font = load_font("tests/fixtures/aadhunik.ttf").unwrap()
    let metrics = font.metrics()

    # Find a glyph with an outline
    var found_glyph = false

    for i in 1..10  # Try first few glyphs
        let outline = font.glyph_outline(i as u16)
        if outline.is_some()
            let o = outline.unwrap()
            if not o.is_empty()
                # Rasterize this glyph
                let raster = rasterize_outline(o, metrics.units_per_em, 32, false)

                if raster.width > 0 and raster.height > 0
                    # Check that some pixels are filled
                    var filled = 0
                    for j in 0..raster.bitmap.len()
                        if raster.bitmap[j] > 0
                            filled = filled + 1

                    if filled > 0
                        found_glyph = true
                        break

    # We should have found at least one glyph to rasterize
    assert found_glyph
    0

[[test]]
fn test_rasterize_at_different_sizes() -> i32
    var font = load_font("tests/fixtures/aadhunik.ttf").unwrap()
    let metrics = font.metrics()

    # Find a glyph with an outline
    var outline_opt: Option<GlyphOutline> = None

    for i in 1..20
        let o = font.glyph_outline(i as u16)
        if o.is_some() and not o.unwrap().is_empty()
            outline_opt = o
            break

    if outline_opt.is_none()
        return 0  # No glyphs with outlines found

    let outline = outline_opt.unwrap()

    # Rasterize at different sizes
    let r12 = rasterize_outline(outline, metrics.units_per_em, 12, false)
    let r24 = rasterize_outline(outline, metrics.units_per_em, 24, false)
    let r48 = rasterize_outline(outline, metrics.units_per_em, 48, false)

    # Larger sizes should produce larger bitmaps
    if r12.width > 0 and r24.width > 0
        assert r24.width >= r12.width or r24.height >= r12.height

    if r24.width > 0 and r48.width > 0
        assert r48.width >= r24.width or r48.height >= r24.height

    0

[[test]]
fn test_rasterize_with_antialiasing() -> i32
    var font = load_font("tests/fixtures/aadhunik.ttf").unwrap()
    let metrics = font.metrics()

    # Find a glyph with an outline
    var outline_opt: Option<GlyphOutline> = None

    for i in 1..20
        let o = font.glyph_outline(i as u16)
        if o.is_some() and not o.unwrap().is_empty()
            outline_opt = o
            break

    if outline_opt.is_none()
        return 0

    let outline = outline_opt.unwrap()

    # Rasterize with and without AA
    let no_aa = rasterize_outline(outline, metrics.units_per_em, 24, false)
    let with_aa = rasterize_outline(outline, metrics.units_per_em, 24, true)

    # Both should produce output
    assert no_aa.width > 0 or no_aa.height > 0 or true  # May be empty
    assert with_aa.width > 0 or with_aa.height > 0 or true

    0

[[test]]
fn test_rasterize_space_character() -> i32
    var font = load_font("tests/fixtures/aadhunik.ttf").unwrap()
    let metrics = font.metrics()

    let space_id = font.glyph_id(0x20)
    if space_id.is_none()
        return 0  # No space in this font

    let outline = font.glyph_outline(space_id.unwrap())
    if outline.is_none()
        return 0

    let raster = rasterize_outline(outline.unwrap(), metrics.units_per_em, 16, false)

    # Space should have no visible pixels (or be empty)
    var filled = 0
    for i in 0..raster.bitmap.len()
        if raster.bitmap[i] > 0
            filled = filled + 1

    # Space typically has no outline, so no filled pixels
    # (But some fonts might have a visible space glyph)

    0

# ============================================================================
# Cache Tests (with real font)
# ============================================================================

[[test]]
fn test_cache_with_real_glyphs() -> i32
    var font = load_font("tests/fixtures/aadhunik.ttf").unwrap()
    let metrics = font.metrics()

    var cache = GlyphCache.new(50)

    # Rasterize and cache several glyphs
    for i in 1..10
        let outline = font.glyph_outline(i as u16)
        if outline.is_some()
            let o = outline.unwrap()
            if not o.is_empty()
                let raster = rasterize_outline(o, metrics.units_per_em, 16, false)
                let key = GlyphCacheKey.new(1, i as u16, 16)
                cache.insert(key, raster)

    # Cache should have some entries
    assert cache.len() > 0

    # Retrieve a cached glyph
    let key = GlyphCacheKey.new(1, 1, 16)
    let cached = cache.get(key)
    # May or may not be cached depending on if glyph 1 had an outline

    0

[[test]]
fn test_cache_hit_rate_with_repeated_access() -> i32
    var font = load_font("tests/fixtures/aadhunik.ttf").unwrap()
    let metrics = font.metrics()

    var cache = GlyphCache.new(100)

    # Find glyphs with outlines and cache them
    var cached_keys = Vec.new()

    for i in 1..20
        let outline = font.glyph_outline(i as u16)
        if outline.is_some()
            let o = outline.unwrap()
            if not o.is_empty()
                let raster = rasterize_outline(o, metrics.units_per_em, 16, false)
                let key = GlyphCacheKey.new(1, i as u16, 16)
                cache.insert(key, raster)
                cached_keys.push(key)

    if cached_keys.len() == 0
        return 0  # No glyphs cached

    # Access cached glyphs multiple times
    for round in 0..5
        for key in @cached_keys
            let _ = cache.get(key)

    # Hit rate should be high
    let hit_rate = cache.hit_rate()
    assert hit_rate > 0.5

    0

# ============================================================================
# End-to-End Test
# ============================================================================

[[test]]
fn test_full_render_pipeline() -> i32
    # This test exercises the complete pipeline:
    # Load font -> Get glyph -> Rasterize -> Cache

    var font = load_font("tests/fixtures/aadhunik.ttf").unwrap()
    let metrics = font.metrics()
    var cache = GlyphCache.new(100)

    # Simulate rendering a string (using glyph IDs we know exist)
    let text_glyph_ids: [5]u16 = [1, 2, 3, 4, 5]

    var rendered_count = 0

    for glyph_id in @text_glyph_ids
        let key = GlyphCacheKey.new(1, glyph_id, 24)

        # Check cache first
        let cached = cache.get(key)

        if cached.is_none()
            # Not in cache - rasterize
            let glyph = font.get_glyph(glyph_id)
            if glyph.is_some()
                let g = glyph.unwrap()
                let raster = rasterize_glyph(
                    g.outline,
                    metrics.units_per_em,
                    24,
                    g.metrics.advance_width,
                    g.metrics.left_side_bearing,
                    true  # with antialiasing
                )
                cache.insert(key, raster)
                rendered_count = rendered_count + 1

    # We should have rendered some glyphs
    # (May be 0 if first 5 glyphs don't have outlines)

    0

