# Angelo - Shaper Types
#
# Types that match Prism's text.ritz contract.
# These are what Angelo produces and Prism consumes.

import ritzlib.gvec

# A single shaped glyph with positioning
# Matches Prism's ShapedGlyph
pub struct ShapedGlyph
    # Glyph index in the font
    glyph_id: u32

    # Position offset from the pen position
    x_offset: f32
    y_offset: f32

    # Advance to next glyph position
    x_advance: f32
    y_advance: f32

    # Cluster index (for cursor positioning, selection)
    # Maps back to the original character index
    cluster: u32

impl ShapedGlyph
    pub fn new(glyph_id: u32, x_offset: f32, y_offset: f32, x_advance: f32, y_advance: f32, cluster: u32) -> ShapedGlyph
        ShapedGlyph {
            glyph_id: glyph_id,
            x_offset: x_offset,
            y_offset: y_offset,
            x_advance: x_advance,
            y_advance: y_advance,
            cluster: cluster
        }

    pub fn simple(glyph_id: u32, x_advance: f32, cluster: u32) -> ShapedGlyph
        let zero: f32 = x_advance - x_advance
        ShapedGlyph {
            glyph_id: glyph_id,
            x_offset: zero,
            y_offset: zero,
            x_advance: x_advance,
            y_advance: zero,
            cluster: cluster
        }

# Bounding rectangle (matches Prism's Rect but with f32)
pub struct BoundsRect
    x: f32
    y: f32
    width: f32
    height: f32

impl BoundsRect
    pub fn new(x: f32, y: f32, width: f32, height: f32) -> BoundsRect
        BoundsRect { x: x, y: y, width: width, height: height }

    pub fn union(self, other: BoundsRect) -> BoundsRect
        let z = self.width - self.width
        if self.width == z and self.height == z
            other
        else if other.width == z and other.height == z
            self
        else
            let x1 = if self.x < other.x then self.x else other.x
            let y1 = if self.y < other.y then self.y else other.y
            let x2_self = self.x + self.width
            let x2_other = other.x + other.width
            let y2_self = self.y + self.height
            let y2_other = other.y + other.height
            let x2 = if x2_self > x2_other then x2_self else x2_other
            let y2 = if y2_self > y2_other then y2_self else y2_other
            BoundsRect.new(x1, y1, x2 - x1, y2 - y1)

# A run of shaped glyphs ready for rendering
# Matches Prism's GlyphRun
pub struct GlyphRun
    # Font identifier
    font_id: u32
    font_size: f32

    # Shaped glyphs
    glyphs: Vec<ShapedGlyph>

    # Bounding box (for hit testing, damage tracking)
    bounds: BoundsRect

impl GlyphRun
    pub fn new(font_id: u32, font_size: f32) -> GlyphRun
        let z = font_size - font_size
        GlyphRun {
            font_id: font_id,
            font_size: font_size,
            glyphs: vec_new<ShapedGlyph>(),
            bounds: BoundsRect { x: z, y: z, width: z, height: z }
        }

    pub fn add_glyph(self:&, glyph: ShapedGlyph)
        vec_push<ShapedGlyph>(@self.glyphs, glyph)

    pub fn glyph_count(self) -> usize
        vec_len<ShapedGlyph>(@self.glyphs) as usize

    pub fn is_empty(self) -> bool
        vec_len<ShapedGlyph>(@self.glyphs) == 0

    # Calculate total advance width
    pub fn total_advance(self) -> f32
        var total = self.font_size - self.font_size
        for i in 0..vec_len<ShapedGlyph>(@self.glyphs) as usize
            let g = vec_get<ShapedGlyph>(@self.glyphs, i as i64)
            total = total + g.x_advance
        total

    # Set bounds (called after shaping)
    pub fn set_bounds(self:&, bounds: BoundsRect)
        self.bounds = bounds
