# Angelo - File I/O
#
# File loading utilities for reading font files.
# Uses ritzlib's filesystem primitives.

import ritzlib.sys
import ritzlib.sys.sys_open
import ritzlib.sys.sys_close
import ritzlib.sys.sys_read
import ritzlib.sys.sys_fstat
import ritzlib.sys.O_RDONLY

# Read an entire file into a Vec<u8>
pub fn read_file_bytes(path: StrView) -> Result<Vec<u8>, StrView>
    # Convert to null-terminated string for syscall
    # StrView should be null-terminated when coming from literals
    let cstr = path.as_ptr()

    let fd = sys_open(cstr, O_RDONLY)
    if fd < 0
        return Err("failed to open file")

    # Get file size
    var statbuf: [144]u8
    if sys_fstat(fd, @&statbuf[0]) != 0
        sys_close(fd)
        return Err("failed to stat file")

    # Read file size from stat buffer (offset 48)
    let size_ptr = (@&statbuf[48]) as @i64
    let file_size = *size_ptr

    if file_size <= 0
        sys_close(fd)
        return Err("invalid file size")

    # Allocate buffer
    var data = Vec.with_capacity(file_size as usize)

    # Read in chunks
    var total_read: i64 = 0
    var buf: [8192]u8

    while total_read < file_size
        let remaining = file_size - total_read
        let to_read = if remaining > 8192
            8192
        else
            remaining

        let n = sys_read(fd, @&buf[0], to_read)
        if n < 0
            sys_close(fd)
            return Err("failed to read file")
        if n == 0
            break

        # Append to vector
        for i in 0..n as usize
            data.push(buf[i])

        total_read = total_read + n

    sys_close(fd)
    Ok(data)

# Tests

[[test]]
fn test_read_nonexistent_file() -> i32
    let result = read_file_bytes("nonexistent_file_12345.ttf")
    assert result.is_err()
    0
