# Tests
[[test]]
fn test_offset_table_truetype() -> i32
    let ot = OffsetTable {
        sfnt_version: SFNT_VERSION_TRUETYPE,
        num_tables: 10,
        search_range: 128,
        entry_selector: 3,
        range_shift: 32
    }
    assert ot.is_truetype()
    assert not ot.is_opentype_cff()
    0

[[test]]
fn test_offset_table_opentype() -> i32
    let ot = OffsetTable {
        sfnt_version: SFNT_VERSION_OPENTYPE_CFF,
        num_tables: 10,
        search_range: 128,
        entry_selector: 3,
        range_shift: 32
    }
    assert not ot.is_truetype()
    assert ot.is_opentype_cff()
    0

[[test]]
fn test_parse_offset_table() -> i32
    # Minimal TTF header: sfnt_version + numTables + searchRange + entrySelector + rangeShift
    let data: [12]u8 = [
        0x00, 0x01, 0x00, 0x00,  # sfnt_version = 0x00010000 (TrueType)
        0x00, 0x02,               # numTables = 2
        0x00, 0x20,               # searchRange = 32
        0x00, 0x01,               # entrySelector = 1
        0x00, 0x00                # rangeShift = 0
    ]
    var reader = Reader.new(@data)
    let ot = parse_offset_table(@&reader).unwrap()

    assert ot.sfnt_version == SFNT_VERSION_TRUETYPE
    assert ot.num_tables == 2
    assert ot.search_range == 32
    assert ot.entry_selector == 1
    assert ot.range_shift == 0
    0

[[test]]
fn test_parse_table_directory() -> i32
    # Two table entries: head and cmap
    let data: [32]u8 = [
        # Entry 1: head
        0x68, 0x65, 0x61, 0x64,  # tag = "head"
        0x12, 0x34, 0x56, 0x78,  # checksum
        0x00, 0x00, 0x00, 0x40,  # offset = 64
        0x00, 0x00, 0x00, 0x36,  # length = 54
        # Entry 2: cmap
        0x63, 0x6D, 0x61, 0x70,  # tag = "cmap"
        0xAB, 0xCD, 0xEF, 0x01,  # checksum
        0x00, 0x00, 0x00, 0x80,  # offset = 128
        0x00, 0x00, 0x01, 0x00   # length = 256
    ]
    var reader = Reader.new(@data)
    let tables = parse_table_directory(@&reader, 2).unwrap()

    assert tables.len() == 2
    assert tables[0].tag.eq(TAG_HEAD)
    assert tables[0].offset == 64
    assert tables[0].length == 54
    assert tables[1].tag.eq(TAG_CMAP)
    assert tables[1].offset == 128
    assert tables[1].length == 256
    0
