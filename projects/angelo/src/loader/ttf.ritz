# Angelo - TrueType Font Parser
#
# Parses TrueType (.ttf) font files.
# OpenType (.otf) with TrueType outlines uses the same format.

import types { Tag }
import types { TAG_HEAD }
import types { TAG_HHEA }
import types { TAG_HMTX }
import types { TAG_CMAP }
import types { TAG_MAXP }
import types { TAG_LOCA }
import types { TAG_GLYF }
import types { FontMetrics }
import loader.reader { Reader }

# TrueType sfnt version (0x00010000)
pub const SFNT_VERSION_TRUETYPE: u32 = 0x00010000

# OpenType with CFF outlines uses 'OTTO' (0x4F54544F)
pub const SFNT_VERSION_OPENTYPE_CFF: u32 = 0x4F54544F

# Magic number in the 'head' table (per TrueType spec)
pub const HEAD_TABLE_MAGIC: u32 = 0x5F0F3CF5

# Entry in the table directory
pub struct TableEntry
    tag: Tag
    checksum: u32
    offset: u32
    length: u32

impl TableEntry
    pub fn new(tag: Tag, checksum: u32, offset: u32, length: u32) -> TableEntry
        TableEntry {
            tag: tag,
            checksum: checksum,
            offset: offset,
            length: length
        }

# Offset subtable (file header)
pub struct OffsetTable
    sfnt_version: u32
    num_tables: u16
    search_range: u16
    entry_selector: u16
    range_shift: u16

impl OffsetTable
    pub fn is_truetype(self) -> bool
        self.sfnt_version == SFNT_VERSION_TRUETYPE

    pub fn is_opentype_cff(self) -> bool
        self.sfnt_version == SFNT_VERSION_OPENTYPE_CFF

# A parsed font file
pub struct FontFile
    data: Vec<u8>           # owned copy of font data
    offset_table: OffsetTable
    tables: Vec<TableEntry>
    metrics: FontMetrics
    num_glyphs: u16
    index_to_loc_format: i16  # 0 = short offsets, 1 = long offsets

impl FontFile
    # Get a table's raw data slice
    # Note: Returns a slice of the FontFile's internal data
    pub fn get_table(self, tag: Tag) -> Option<[u8]>
        for entry in @self.tables
            if entry.tag.eq(tag)
                let start = entry.offset as usize
                let end = start + entry.length as usize
                if end <= self.data.len()
                    return Some(self.data[start..end])
        None

    # Check if a table exists
    pub fn has_table(self, tag: Tag) -> bool
        self.get_table(tag).is_some()

    # Get font metrics
    pub fn metrics(self) -> FontMetrics
        self.metrics

    # Get number of glyphs
    pub fn num_glyphs(self) -> u16
        self.num_glyphs

# Parse the offset table (file header)
fn parse_offset_table(reader:& Reader) -> Result<OffsetTable, StrView>
    let sfnt_version = reader.read_u32()?
    let num_tables = reader.read_u16()?
    let search_range = reader.read_u16()?
    let entry_selector = reader.read_u16()?
    let range_shift = reader.read_u16()?

    Ok(OffsetTable {
        sfnt_version: sfnt_version,
        num_tables: num_tables,
        search_range: search_range,
        entry_selector: entry_selector,
        range_shift: range_shift
    })

# Parse the table directory
fn parse_table_directory(reader:& Reader, num_tables: u16) -> Result<Vec<TableEntry>, StrView>
    var tables = Vec.with_capacity(num_tables as usize)

    for i in 0..num_tables as usize
        let tag = reader.read_tag()?
        let checksum = reader.read_u32()?
        let offset = reader.read_u32()?
        let length = reader.read_u32()?

        tables.push(TableEntry.new(tag, checksum, offset, length))

    Ok(tables)

# Parse the 'head' table
fn parse_head_table(data: @[u8], metrics:& FontMetrics) -> Result<i16, StrView>
    var reader = Reader.new(data)

    # Skip: majorVersion, minorVersion
    reader.skip(4)
    # Skip: fontRevision (Fixed)
    reader.skip(4)
    # Skip: checksumAdjustment
    reader.skip(4)
    # Validate magic number
    let magic = reader.read_u32()?
    if magic != HEAD_TABLE_MAGIC
        return Err("invalid head table magic number")
    # Skip: flags
    reader.skip(2)
    # unitsPerEm
    metrics.units_per_em = reader.read_u16()?
    # Skip: created, modified (8 bytes each)
    reader.skip(16)
    # xMin, yMin, xMax, yMax
    metrics.x_min = reader.read_i16()?
    metrics.y_min = reader.read_i16()?
    metrics.x_max = reader.read_i16()?
    metrics.y_max = reader.read_i16()?
    # Skip: macStyle, lowestRecPPEM, fontDirectionHint
    reader.skip(6)
    # indexToLocFormat
    let index_to_loc_format = reader.read_i16()?

    Ok(index_to_loc_format)

# Parse the 'hhea' table
fn parse_hhea_table(data: @[u8], metrics:& FontMetrics) -> Result<u16, StrView>
    var reader = Reader.new(data)

    # Skip: majorVersion, minorVersion
    reader.skip(4)
    # ascender, descender, lineGap
    metrics.ascender = reader.read_i16()?
    metrics.descender = reader.read_i16()?
    metrics.line_gap = reader.read_i16()?
    # Skip: advanceWidthMax, minLeftSideBearing, minRightSideBearing
    reader.skip(6)
    # Skip: xMaxExtent, caretSlopeRise, caretSlopeRun, caretOffset
    reader.skip(8)
    # Skip: reserved (4 i16)
    reader.skip(8)
    # Skip: metricDataFormat
    reader.skip(2)
    # numberOfHMetrics
    let num_hmetrics = reader.read_u16()?

    Ok(num_hmetrics)

# Parse the 'maxp' table
fn parse_maxp_table(data: @[u8]) -> Result<u16, StrView>
    var reader = Reader.new(data)

    # Skip: version
    reader.skip(4)
    # numGlyphs
    let num_glyphs = reader.read_u16()?

    Ok(num_glyphs)

# Load a font from raw data
pub fn load_font_from_data(data:= Vec<u8>) -> Result<FontFile, StrView>
    var reader = Reader.new(@data)

    # Parse offset table
    let offset_table = parse_offset_table(@&reader)?

    # Validate sfnt version
    if not offset_table.is_truetype() and not offset_table.is_opentype_cff()
        return Err("unsupported font format")

    # Parse table directory
    let tables = parse_table_directory(@&reader, offset_table.num_tables)?

    # Create initial font file
    var font = FontFile {
        data: data,
        offset_table: offset_table,
        tables: tables,
        metrics: FontMetrics.new(),
        num_glyphs: 0,
        index_to_loc_format: 0
    }

    # Parse essential tables
    # head table
    match font.get_table(TAG_HEAD)
        Some(head_data) =>
            font.index_to_loc_format = parse_head_table(head_data, @&font.metrics)?
        None =>
            return Err("missing required 'head' table")

    # hhea table
    match font.get_table(TAG_HHEA)
        Some(hhea_data) =>
            let _ = parse_hhea_table(hhea_data, @&font.metrics)?
        None =>
            return Err("missing required 'hhea' table")

    # maxp table
    match font.get_table(TAG_MAXP)
        Some(maxp_data) =>
            font.num_glyphs = parse_maxp_table(maxp_data)?
        None =>
            return Err("missing required 'maxp' table")

    Ok(font)

