# seq10: Print numbers 1 to 10
#
# Simple test of number printing without needing argv.
# Runtime _start calls main() and then sys_exit(return_value).

import libharland { print_str, print_num }

pub fn main() -> i32
    var n: i32 = 1
    while n <= 10
        print_num(n)
        print_str(c"\n")
        n = n + 1
    return 0
