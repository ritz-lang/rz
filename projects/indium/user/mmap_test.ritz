# mmap_test.ritz - Test sys_mmap syscall
#
# This simple test allocates memory using mmap, writes to it,
# reads it back, and then unmaps it.

import libharland { print_str, print_num, sys_exit, sys_mmap, sys_munmap, PROT_READ, PROT_WRITE, MAP_PRIVATE, MAP_ANONYMOUS }

fn main() -> i32
    print_str(c"mmap test: allocating 4KB...\n")

    # Allocate one page (4KB) of anonymous memory
    let prot: i32 = PROT_READ | PROT_WRITE
    let flags: i32 = MAP_PRIVATE | MAP_ANONYMOUS
    let ptr: *u8 = sys_mmap(0, 4096, prot, flags)

    if ptr == 0 as *u8
        print_str(c"FAIL: mmap returned null\n")
        sys_exit(1)
        return 1

    # Check that the pointer is in the expected range (above USER_MMAP_START = 0x10000000)
    if (ptr as i64) < 0x10000000
        print_str(c"FAIL: mmap returned unexpected address\n")
        sys_exit(2)
        return 2

    print_str(c"mmap returned: 0x")
    # Print address in hex (simple approach - just print as decimal for now)
    print_num((ptr as i64) as i32)
    print_str(c"\n")

    # Write a pattern to the allocated memory
    print_str(c"Writing pattern...\n")
    var i: i32 = 0
    while i < 256
        *(ptr + i) = (i % 256) as u8
        i = i + 1

    # Read back and verify
    print_str(c"Verifying pattern...\n")
    i = 0
    while i < 256
        let expected: u8 = (i % 256) as u8
        let actual: u8 = *(ptr + i)
        if actual != expected
            print_str(c"FAIL: mismatch at offset ")
            print_num(i)
            print_str(c"\n")
            sys_exit(3)
            return 3
        i = i + 1

    print_str(c"Pattern verified!\n")

    # Unmap the memory
    print_str(c"Unmapping...\n")
    let result: i32 = sys_munmap(ptr, 4096)
    if result != 0
        print_str(c"FAIL: munmap returned ")
        print_num(result)
        print_str(c"\n")
        sys_exit(4)
        return 4

    print_str(c"PASS: mmap test succeeded!\n")
    sys_exit(0)
    return 0
