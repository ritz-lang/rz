# cat_motd: Print contents of /etc/motd
#
# Tests: sys_open, sys_read, sys_close, sys_write

import libharland { sys_open, sys_read, sys_close, sys_write, sys_exit, STDOUT, O_RDONLY }

pub fn main() -> i32
    # Open /etc/motd
    let fd: i32 = sys_open(c"/etc/motd", O_RDONLY)
    if fd < 0
        sys_exit(1)

    # Read and print contents
    var buf: [256]u8
    var total: i64 = 0

    var n: i64 = sys_read(fd, @buf[0], 256)
    while n > 0
        sys_write(STDOUT, @buf[0], n)
        total = total + n
        n = sys_read(fd, @buf[0], 256)

    sys_close(fd)

    # Return 0 if we read something, 1 otherwise
    if total > 0
        sys_exit(0)
    else
        sys_exit(1)
    0
