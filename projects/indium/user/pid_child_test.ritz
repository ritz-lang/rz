# PID regression test for spawned child process.
#
# Returns success only if this process is not PID 1.

import libharland { print_str, print_num, sys_getpid }

pub fn main() -> i32
    let pid: i32 = sys_getpid()
    if pid == 1
        print_str(c"[pid_child_test] FAIL: child saw pid=1\n")
        return 1

    print_str(c"[pid_child_test] PASS: pid=")
    print_num(pid)
    print_str(c"\n")
    return 0
