# Minimal syscall test - simplest possible userspace program
#
# Does a single syscall (exit) with no function calls at all.
# Entry point goes directly to main which does inline assembly.

# Harland syscall number for exit
const SYS_EXIT: i64 = 20

pub fn main() -> i32
    # Exit immediately with code 42
    # No function calls, no variables, just inline asm
    asm x86_64:
        movq $20, %rax    # SYS_EXIT = 20
        movq $42, %rdi    # exit code = 42
        syscall
        # Should never reach here
        hlt
    return 0
