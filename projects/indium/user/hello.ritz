# Harland Hello World
#
# The simplest possible userspace program for Harland.
# Writes "Hello, Harland!\n" to stdout and exits.
# Runtime _start calls main() and then sys_exit(return_value).

import ritzlib.sys { sys_write, STDOUT }

pub fn main() -> i32
    let msg: *u8 = c"Hello, Harland!\n"
    sys_write(STDOUT, msg, 16)
    return 0
