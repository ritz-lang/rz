# FD table smoke test
#
# Validates descriptor allocation/reuse semantics from userspace.

import libharland {
    print_str, print_num,
    sys_open, sys_close,
    O_RDONLY
}

fn fail(msg: *u8) -> i32
    print_str(c"[fd_table_test] FAIL: ")
    print_str(msg)
    print_str(c"\n")
    return 1

fn check_eq(actual: i32, expected: i32, label: *u8) -> i32
    if actual == expected
        return 0
    print_str(c"[fd_table_test] FAIL: ")
    print_str(label)
    print_str(c" expected=")
    print_num(expected)
    print_str(c" got=")
    print_num(actual)
    print_str(c"\n")
    return 1

pub fn main() -> i32
    print_str(c"[fd_table_test] starting\n")

    let fd1: i32 = sys_open(c"/etc/motd", O_RDONLY)
    if fd1 < 0
        return fail(c"open #1 failed")
    if check_eq(fd1, 3, c"fd1") != 0
        return 1

    let fd2: i32 = sys_open(c"/etc/motd", O_RDONLY)
    if fd2 < 0
        return fail(c"open #2 failed")
    if check_eq(fd2, 4, c"fd2") != 0
        return 1

    let close1: i32 = sys_close(fd1)
    if close1 != 0
        return fail(c"close(fd1) failed")

    let fd3: i32 = sys_open(c"/etc/motd", O_RDONLY)
    if fd3 < 0
        return fail(c"open #3 failed")
    if check_eq(fd3, 3, c"fd3 reuse") != 0
        return 1

    let close2: i32 = sys_close(fd2)
    let close3: i32 = sys_close(fd3)
    if close2 != 0 or close3 != 0
        return fail(c"final close failed")

    print_str(c"[fd_table_test] PASS\n")
    return 0
