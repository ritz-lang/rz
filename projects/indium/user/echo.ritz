# echo: Print command-line arguments
#
# Usage: echo [args...]
# Prints all arguments separated by spaces, followed by a newline.
# Tests: sys_write, argc/argv passing
#
# Exit code: 0 (always succeeds)

import libharland { print_str, sys_exit }
import ritzlib.sys { sys_write, STDOUT }

pub fn main(argc: i32, argv: **u8) -> i32
    # Skip argv[0] (program name)
    var i: i32 = 1
    while i < argc
        let arg: *u8 = *(argv + i)
        if arg != null
            # Print space before all but first arg
            if i > 1
                sys_write(STDOUT, c" ", 1)
            print_str(arg)
        i = i + 1

    # Print trailing newline
    sys_write(STDOUT, c"\n", 1)

    sys_exit(0)
    0
