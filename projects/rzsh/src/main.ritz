# rzsh - Ritz Shell
#
# A simple interactive shell that runs on both Linux and Harland.
# OS-specific details are abstracted in the 'os' module using
# [[target_os]] conditional compilation.
#
# Runtime _start calls main() and then sys_exit(return_value).

import common {
    puts, println, putchar, print_num, is_whitespace,
    g_line_buffer, g_line_len, g_line_cursor, g_line_pos,
    line_clear, line_add_char, line_backspace, line_delete,
    line_cursor_left, line_cursor_right, line_cursor_home, line_cursor_end,
    line_kill_to_end, line_kill_to_start, line_set, line_length, line_cursor_pos,
    g_argv, parse_args,
    cmd_help, cmd_exit, cmd_pid, cmd_echo, cmd_clear, print_prompt,
    MAX_LINE, MAX_ARGS, MAX_PATH,
    STDIN, STDOUT, STDERR,
    # Pipeline parsing
    has_pipe, parse_pipeline, g_pipe_count, get_pipe_argv, get_pipe_argc, get_pipe_cmd
}

import os {
    os_readdir, os_spawn_and_wait, os_yield,
    os_default_ls_path, os_bin_path_1, os_bin_path_2,
    os_enable_raw_mode, os_disable_raw_mode, os_is_raw_mode,
    # Pipeline execution
    os_create_pipe, os_close_pipe, os_spawn_with_io,
    pipe_read_fd, pipe_write_fd
}

import input {
    input_reset, input_parse_byte, input_in_escape, input_get_char,
    cursor_left, cursor_right, clear_to_eol,
    KEY_NONE, KEY_CHAR, KEY_UP, KEY_DOWN, KEY_RIGHT, KEY_LEFT,
    KEY_HOME, KEY_END, KEY_DELETE, KEY_BACKSPACE, KEY_ENTER, KEY_TAB,
    KEY_CTRL_C, KEY_CTRL_D, KEY_CTRL_A, KEY_CTRL_E,
    KEY_CTRL_K, KEY_CTRL_U, KEY_CTRL_W, KEY_CTRL_L,
    KEY_ESCAPE, KEY_UNKNOWN
}

import history {
    history_add, history_reset_nav, history_up, history_down,
    history_count
}

import ritzlib.sys { sys_read, sys_write }
import ritzlib.str { strlen, strcmp }

# ============================================================================
# Version string (selected at compile time)
# ============================================================================

[[target_os = "linux"]]
fn version_string() -> *u8
    return c"rzsh - Ritz Shell v0.1 (linux)"

[[target_os = "harland"]]
fn version_string() -> *u8
    return c"rzsh - Ritz Shell v0.1 (harland)"

# ============================================================================
# ls command
# ============================================================================

fn cmd_ls(argc: i32) -> i32
    var path: *u8 = os_default_ls_path()
    if argc > 1
        path = g_argv[1]

    var buf: [4096]u8
    let n: i64 = os_readdir(path, @buf[0], 4096)

    if n < 0
        puts(c"ls: cannot access '")
        puts(path)
        println(c"'")
        return 1

    var pos: i64 = 0
    while pos < n
        let entry: *u8 = @buf[0] + pos
        let entry_len: i64 = strlen(entry)
        if entry_len > 0
            puts(c"  ")
            println(entry)
        pos = pos + entry_len + 1

    return 0

# ============================================================================
# External Command Execution
# ============================================================================

# Build full path to command
# Returns true if found in path_buf, false if should use cmd directly
var g_path_buf: [256]u8

fn build_cmd_path(cmd: *u8) -> *u8
    # If already absolute, use as-is
    if *cmd == 47  # '/'
        return cmd

    # Try first path
    let prefix: *u8 = os_bin_path_1()
    var prefix_len: i64 = strlen(prefix)
    var i: i64 = 0

    # Copy prefix
    while i < prefix_len
        g_path_buf[i as i32] = *(prefix + i)
        i = i + 1

    # Copy command
    var j: i64 = 0
    while *(cmd + j) != 0 and (i + j) < MAX_PATH - 1
        g_path_buf[(i + j) as i32] = *(cmd + j)
        j = j + 1
    g_path_buf[(i + j) as i32] = 0

    return @g_path_buf[0]

fn exec_external(argc: i32) -> i32
    let cmd: *u8 = g_argv[0]

    var path_buf: [256]u8
    var path: *u8 = cmd

    if *cmd != 47  # Not starting with '/'
        # Build full path: prefix + cmd
        let prefix: *u8 = os_bin_path_1()
        var prefix_len: i64 = strlen(prefix)
        var i: i64 = 0

        # Copy prefix
        while i < prefix_len
            path_buf[i as i32] = *(prefix + i)
            i = i + 1

        # Copy command
        var j: i64 = 0
        while *(cmd + j) != 0 and (i + j) < MAX_PATH - 1
            path_buf[(i + j) as i32] = *(cmd + j)
            j = j + 1
        path_buf[(i + j) as i32] = 0
        path = @path_buf[0]

    let orig_argv0: *u8 = g_argv[0]
    g_argv[0] = path

    let result: i32 = os_spawn_and_wait(path, @g_argv[0], argc)

    g_argv[0] = orig_argv0

    if result < 0
        # Try second path
        let prefix2: *u8 = os_bin_path_2()
        var prefix_len: i64 = strlen(prefix2)
        var i: i64 = 0

        # Copy prefix
        while i < prefix_len
            path_buf[i as i32] = *(prefix2 + i)
            i = i + 1

        # Copy command
        var j: i64 = 0
        while *(cmd + j) != 0 and (i + j) < MAX_PATH - 1
            path_buf[(i + j) as i32] = *(cmd + j)
            j = j + 1
        path_buf[(i + j) as i32] = 0
        path = @path_buf[0]

        g_argv[0] = path
        let result2: i32 = os_spawn_and_wait(path, @g_argv[0], argc)
        g_argv[0] = orig_argv0

        if result2 < 0
            puts(c"rzsh: command not found: ")
            println(cmd)
            return 127

        return result2

    return result

# ============================================================================
# Pipeline Execution
# ============================================================================

# Per-stage path buffer (separate from g_path_buf to avoid conflicts)
var g_stage_path: [256]u8

fn build_stage_path(cmd: *u8) -> *u8
    # If already absolute, use as-is
    if *cmd == 47  # '/'
        return cmd

    # Build path with /bin/ prefix
    let prefix: *u8 = os_bin_path_1()
    var prefix_len: i64 = strlen(prefix)
    var i: i64 = 0

    while i < prefix_len
        g_stage_path[i as i32] = *(prefix + i)
        i = i + 1

    var j: i64 = 0
    while *(cmd + j) != 0 and (i + j) < 254
        g_stage_path[(i + j) as i32] = *(cmd + j)
        j = j + 1
    g_stage_path[(i + j) as i32] = 0

    return @g_stage_path[0]

# Execute a pipeline of 2 commands
# For now, only supports 2-stage pipelines (cmd1 | cmd2)
fn exec_pipeline() -> i32
    if g_pipe_count < 2
        return -1

    # Debug
    puts(c"[pipe] Executing pipeline with ")
    print_num(g_pipe_count)
    println(c" stages")

    # Create a pipe between the two commands
    let pipe_result: i64 = os_create_pipe()
    if pipe_result < 0
        println(c"[pipe] Failed to create pipe")
        return -1

    let read_fd: i32 = pipe_read_fd(pipe_result)
    let write_fd: i32 = pipe_write_fd(pipe_result)

    puts(c"[pipe] Created pipe: read_fd=")
    print_num(read_fd)
    puts(c", write_fd=")
    print_num(write_fd)
    println(c"")

    # Stage 0: Run first command with stdout redirected to pipe write end
    let cmd0: *u8 = get_pipe_cmd(0)
    let argv0: **u8 = get_pipe_argv(0)
    let argc0: i32 = get_pipe_argc(0)
    let path0: *u8 = build_stage_path(cmd0)

    puts(c"[pipe] Stage 0: ")
    puts(path0)
    puts(c" (stdout -> pipe write)")
    println(c"")

    # Set argv[0] to full path
    *argv0 = path0

    # Spawn first command with stdout redirected to pipe write end
    # stdin = 0 (serial), stdout = write_fd (pipe)
    let result0: i32 = os_spawn_with_io(path0, argv0, argc0, 0, write_fd)

    puts(c"[pipe] Stage 0 exit code: ")
    print_num(result0)
    println(c"")

    # Stage 1: Run second command with stdin redirected to pipe read end
    let cmd1: *u8 = get_pipe_cmd(1)
    let argv1: **u8 = get_pipe_argv(1)
    let argc1: i32 = get_pipe_argc(1)
    let path1: *u8 = build_stage_path(cmd1)

    puts(c"[pipe] Stage 1: ")
    puts(path1)
    puts(c" (stdin <- pipe read)")
    println(c"")

    # Set argv[0] to full path
    *argv1 = path1

    # Spawn second command with stdin redirected to pipe read end
    # stdin = read_fd (pipe), stdout = 0 (serial)
    let result1: i32 = os_spawn_with_io(path1, argv1, argc1, read_fd, 0)

    puts(c"[pipe] Stage 1 exit code: ")
    print_num(result1)
    println(c"")

    # Close pipe ends (kernel will clean up when both are closed)
    # TODO: Implement proper close

    return result1

# ============================================================================
# Command Dispatch
# ============================================================================

fn process_line() -> i32
    if g_line_pos == 0
        return 0

    g_line_buffer[g_line_pos as i32] = 0

    # Check for pipeline
    if has_pipe(@g_line_buffer[0])
        let num_stages: i32 = parse_pipeline(@g_line_buffer[0])
        if num_stages >= 2
            return exec_pipeline()
        # Fall through if parsing failed

    let argc: i32 = parse_args(@g_line_buffer[0])
    if argc == 0
        return 0

    let cmd: *u8 = g_argv[0]

    if strcmp(cmd, c"help") == 0
        return cmd_help()

    if strcmp(cmd, c"exit") == 0
        return cmd_exit(argc)

    if strcmp(cmd, c"pid") == 0
        return cmd_pid()

    if strcmp(cmd, c"echo") == 0
        return cmd_echo(argc)

    if strcmp(cmd, c"ls") == 0
        return cmd_ls(argc)

    if strcmp(cmd, c"clear") == 0
        return cmd_clear()

    return exec_external(argc)

# ============================================================================
# Help message
# ============================================================================

fn print_help()
    println(version_string())
    println(c"")
    println(c"Usage: rzsh [options]")
    println(c"")
    println(c"Options:")
    println(c"  --help    Show this help message and exit")
    println(c"")
    println(c"Built-in commands:")
    println(c"  help      Show available commands")
    println(c"  exit [N]  Exit the shell with code N (default 0)")
    println(c"  pid       Show current process ID")
    println(c"  echo ...  Print arguments")
    println(c"  ls [DIR]  List directory contents")
    println(c"  clear     Clear the screen")

# ============================================================================
# Redraw line from cursor position
# ============================================================================
# After modifying text mid-line, redraw the remainder and reposition cursor

fn redraw_line_from_cursor()
    # Save cursor position
    let cur: i64 = line_cursor_pos()
    let len: i64 = line_length()

    # Write rest of line from cursor
    if cur < len
        sys_write(STDOUT, @g_line_buffer[cur as i32], len - cur)

    # Clear anything after (in case line got shorter)
    clear_to_eol()

    # Move cursor back to where it should be
    let chars_to_move_back: i32 = (len - cur) as i32
    if chars_to_move_back > 0
        cursor_left(chars_to_move_back)

# ============================================================================
# Main
# ============================================================================

pub fn main(argc: i32, argv: **u8) -> i32
    # Check for --help flag (for non-interactive testing)
    if argc > 1
        let arg: *u8 = *(argv + 1)
        if strcmp(arg, c"--help") == 0
            print_help()
            return 0

    # Enable raw mode for escape sequence handling
    let raw_result: i32 = os_enable_raw_mode()
    if raw_result != 0
        puts(c"Warning: Could not enable raw mode (")
        print_num(raw_result)
        println(c")")

    println(c"")
    println(c"===========================================")
    println(version_string())
    println(c"  Type 'help' for available commands")
    println(c"===========================================")
    println(c"")

    var read_buf: [1]u8
    var running: i32 = 1

    while running != 0
        print_prompt()
        line_clear()
        history_reset_nav()
        input_reset()

        var reading: i32 = 1
        while reading != 0
            let n: i64 = sys_read(STDIN, @read_buf[0], 1)

            if n > 0
                let b: u8 = read_buf[0]
                let key: i32 = input_parse_byte(b)

                if key == KEY_NONE
                    # In the middle of escape sequence, continue reading
                    continue

                if key == KEY_ENTER
                    println(c"")
                    # Add to history before processing
                    if line_length() > 0
                        history_add(@g_line_buffer[0])
                    process_line()
                    reading = 0

                else if key == KEY_BACKSPACE
                    if line_cursor_pos() > 0
                        # Visual: backspace, print rest of line, clear extra, reposition
                        line_backspace()
                        # Move visual cursor back
                        cursor_left(1)
                        # Redraw from new position
                        redraw_line_from_cursor()

                else if key == KEY_DELETE
                    if line_cursor_pos() < line_length()
                        line_delete()
                        redraw_line_from_cursor()

                else if key == KEY_LEFT
                    if line_cursor_left()
                        cursor_left(1)

                else if key == KEY_RIGHT
                    if line_cursor_right()
                        cursor_right(1)

                else if key == KEY_HOME or key == KEY_CTRL_A
                    let move_amount: i32 = line_cursor_pos() as i32
                    line_cursor_home()
                    if move_amount > 0
                        cursor_left(move_amount)

                else if key == KEY_END or key == KEY_CTRL_E
                    let cur: i64 = line_cursor_pos()
                    let len: i64 = line_length()
                    let move_amount: i32 = (len - cur) as i32
                    line_cursor_end()
                    if move_amount > 0
                        cursor_right(move_amount)

                else if key == KEY_UP
                    let hist: *u8 = history_up()
                    if hist != null
                        # Clear current line visually
                        let cur: i64 = line_cursor_pos()
                        if cur > 0
                            cursor_left(cur as i32)
                        clear_to_eol()
                        # Set line to history entry
                        line_set(hist)
                        # Display it
                        puts(hist)

                else if key == KEY_DOWN
                    let hist: *u8 = history_down()
                    # Clear current line visually
                    let cur: i64 = line_cursor_pos()
                    if cur > 0
                        cursor_left(cur as i32)
                    clear_to_eol()
                    if hist != null
                        # Set line to history entry
                        line_set(hist)
                        puts(hist)
                    else
                        # Back to empty prompt
                        line_clear()

                else if key == KEY_CTRL_C
                    println(c"^C")
                    line_clear()
                    reading = 0

                else if key == KEY_CTRL_D
                    if line_length() == 0
                        println(c"")
                        running = 0
                        reading = 0
                    # If line has content, Ctrl+D does nothing (or could delete char)

                else if key == KEY_CTRL_K
                    # Kill to end of line
                    line_kill_to_end()
                    clear_to_eol()

                else if key == KEY_CTRL_U
                    # Kill to start of line
                    let cur: i64 = line_cursor_pos()
                    if cur > 0
                        cursor_left(cur as i32)
                    line_kill_to_start()
                    redraw_line_from_cursor()

                else if key == KEY_CTRL_L
                    # Clear screen: ESC [ 2 J ESC [ H
                    var clr_buf: [8]u8
                    clr_buf[0] = 27   # ESC
                    clr_buf[1] = 91   # [
                    clr_buf[2] = 50   # 2
                    clr_buf[3] = 74   # J
                    clr_buf[4] = 27   # ESC
                    clr_buf[5] = 91   # [
                    clr_buf[6] = 72   # H
                    sys_write(STDOUT, @clr_buf[0], 7)
                    print_prompt()
                    # Redraw current line
                    if line_length() > 0
                        sys_write(STDOUT, @g_line_buffer[0], line_length())
                        # Position cursor correctly
                        let cur: i64 = line_cursor_pos()
                        let len: i64 = line_length()
                        if cur < len
                            cursor_left((len - cur) as i32)

                else if (key & 0xFFFF) == KEY_CHAR
                    let c: u8 = input_get_char(key)
                    let at_end: bool = line_cursor_pos() == line_length()
                    line_add_char(c)
                    if at_end
                        # Simple case: just echo the character
                        putchar(c)
                    else
                        # Inserted in middle: need to redraw
                        putchar(c)
                        redraw_line_from_cursor()

                # Other keys (TAB, CTRL_W, etc.) can be added later

            else
                os_yield()

    os_disable_raw_mode()
    println(c"Goodbye!")
    return 0
