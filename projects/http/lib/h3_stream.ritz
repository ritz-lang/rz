# lib/h3_stream.ritz - HTTP/3 Stream Management (RFC 9114)
#
# HTTP/3 uses different QUIC stream types:
# - Bidirectional: Request/response streams
# - Unidirectional: Control, QPACK encoder/decoder streams

import ritzlib.span
import lib.h3_frame
import lib.qpack

# ============================================================================
# Internal Stream Type IDs (for stream management)
# ============================================================================

pub const H3_STYPE_REQUEST: i32 = 0      # Bidirectional request stream
pub const H3_STYPE_CONTROL_LOCAL: i32 = 1   # Local control stream (uni)
pub const H3_STYPE_CONTROL_REMOTE: i32 = 2  # Remote control stream (uni)
pub const H3_STYPE_QPACK_ENC: i32 = 3    # QPACK encoder stream (uni)
pub const H3_STYPE_QPACK_DEC: i32 = 4    # QPACK decoder stream (uni)
pub const H3_STYPE_PUSH: i32 = 5         # Push stream (uni)
pub const H3_STYPE_UNKNOWN: i32 = 6      # Unknown/grease stream

# ============================================================================
# Stream States
# ============================================================================

pub const H3_STREAM_STATE_IDLE: i32 = 0
pub const H3_STREAM_STATE_OPEN: i32 = 1
pub const H3_STREAM_STATE_HALF_CLOSED: i32 = 2
pub const H3_STREAM_STATE_CLOSED: i32 = 3

# ============================================================================
# Request Stream
# ============================================================================

pub struct H3RequestStream
    stream_id: i64
    state: i32
    stream_type: i32
    # Received data tracking
    headers_received: i32
    data_received: i64
    trailers_received: i32
    # Send state
    headers_sent: i32
    data_sent: i64
    trailers_sent: i32
    fin_sent: i32
    fin_received: i32

pub fn h3_request_stream_init(stream: *H3RequestStream, stream_id: i64)
    stream.stream_id = stream_id
    stream.state = H3_STREAM_STATE_IDLE
    stream.stream_type = H3_STYPE_REQUEST
    stream.headers_received = 0
    stream.data_received = 0
    stream.trailers_received = 0
    stream.headers_sent = 0
    stream.data_sent = 0
    stream.trailers_sent = 0
    stream.fin_sent = 0
    stream.fin_received = 0

# Check if stream is client-initiated (odd stream ID)
pub fn h3_stream_is_client_initiated(stream_id: i64) -> i32
    if (stream_id & 1) == 0
        return 0
    return 1

# Check if stream is server-initiated (even stream ID)
pub fn h3_stream_is_server_initiated(stream_id: i64) -> i32
    if (stream_id & 1) != 0
        return 0
    return 1

# Check if stream is bidirectional (bit 1 = 0)
pub fn h3_stream_is_bidi(stream_id: i64) -> i32
    if (stream_id & 2) == 0
        return 1
    return 0

# Check if stream is unidirectional (bit 1 = 1)
pub fn h3_stream_is_uni(stream_id: i64) -> i32
    if (stream_id & 2) != 0
        return 1
    return 0

# ============================================================================
# Control Stream
# ============================================================================

pub struct H3ControlStream
    stream_id: i64
    is_local: i32
    settings_sent: i32
    settings_received: i32
    goaway_sent: i32
    goaway_received: i32
    last_good_stream: i64

pub fn h3_control_stream_init(stream: *H3ControlStream, stream_id: i64, is_local: i32)
    stream.stream_id = stream_id
    stream.is_local = is_local
    stream.settings_sent = 0
    stream.settings_received = 0
    stream.goaway_sent = 0
    stream.goaway_received = 0
    stream.last_good_stream = 0

# ============================================================================
# Connection State
# ============================================================================

pub const H3_MAX_STREAMS: i32 = 64

pub struct H3Connection
    # Control streams
    local_control: H3ControlStream
    remote_control: H3ControlStream
    has_local_control: i32
    has_remote_control: i32
    # QPACK streams
    qpack_encoder_stream: i64
    qpack_decoder_stream: i64
    has_qpack_encoder: i32
    has_qpack_decoder: i32
    # Request streams
    streams: [64]H3RequestStream
    stream_count: i32
    # Settings
    max_field_section_size: i64
    qpack_max_table_capacity: i64
    qpack_blocked_streams: i64
    # QPACK state
    encoder: QpackEncoder
    decoder: QpackDecoder
    # Connection state
    is_server: i32
    going_away: i32
    last_stream_id: i64

pub fn h3_connection_init(conn: *H3Connection, is_server: i32)
    h3_control_stream_init(@conn.local_control, -1, 1)
    h3_control_stream_init(@conn.remote_control, -1, 0)
    conn.has_local_control = 0
    conn.has_remote_control = 0
    conn.qpack_encoder_stream = -1
    conn.qpack_decoder_stream = -1
    conn.has_qpack_encoder = 0
    conn.has_qpack_decoder = 0
    conn.stream_count = 0
    conn.max_field_section_size = 0  # Unlimited
    conn.qpack_max_table_capacity = QPACK_MAX_DYNAMIC_TABLE_SIZE as i64
    conn.qpack_blocked_streams = 0
    qpack_encoder_init(@conn.encoder)
    qpack_decoder_init(@conn.decoder)
    conn.is_server = is_server
    conn.going_away = 0
    conn.last_stream_id = -1
    var i: i32 = 0
    while i < H3_MAX_STREAMS
        h3_request_stream_init(@conn.streams[i], -1)
        i = i + 1

# Set local control stream
pub fn h3_set_local_control_stream(conn: *H3Connection, stream_id: i64)
    conn.local_control.stream_id = stream_id
    conn.has_local_control = 1

# Set remote control stream
pub fn h3_set_remote_control_stream(conn: *H3Connection, stream_id: i64)
    conn.remote_control.stream_id = stream_id
    conn.has_remote_control = 1

# Set QPACK encoder stream
pub fn h3_set_qpack_encoder_stream(conn: *H3Connection, stream_id: i64)
    conn.qpack_encoder_stream = stream_id
    conn.has_qpack_encoder = 1

# Set QPACK decoder stream
pub fn h3_set_qpack_decoder_stream(conn: *H3Connection, stream_id: i64)
    conn.qpack_decoder_stream = stream_id
    conn.has_qpack_decoder = 1

# Find or create a request stream
pub fn h3_get_or_create_stream(conn: *H3Connection, stream_id: i64) -> *H3RequestStream
    # Check if stream exists
    var i: i32 = 0
    while i < conn.stream_count
        if conn.streams[i].stream_id == stream_id
            return @conn.streams[i]
        i = i + 1

    # Create new stream
    if conn.stream_count >= H3_MAX_STREAMS
        return null

    let idx: i32 = conn.stream_count
    h3_request_stream_init(@conn.streams[idx], stream_id)
    conn.streams[idx].state = H3_STREAM_STATE_OPEN
    conn.stream_count = conn.stream_count + 1

    if stream_id > conn.last_stream_id
        conn.last_stream_id = stream_id

    return @conn.streams[idx]

# Find a stream by ID
pub fn h3_find_stream(conn: *H3Connection, stream_id: i64) -> *H3RequestStream
    var i: i32 = 0
    while i < conn.stream_count
        if conn.streams[i].stream_id == stream_id
            return @conn.streams[i]
        i = i + 1
    return null

# Close a stream
pub fn h3_close_stream(conn: *H3Connection, stream_id: i64) -> i32
    var stream: *H3RequestStream = h3_find_stream(conn, stream_id)
    if stream == null
        return -1
    stream.state = H3_STREAM_STATE_CLOSED
    return 0

# Count active streams
pub fn h3_active_stream_count(conn: *H3Connection) -> i32
    var count: i32 = 0
    var i: i32 = 0
    while i < conn.stream_count
        if conn.streams[i].state == H3_STREAM_STATE_OPEN || conn.streams[i].state == H3_STREAM_STATE_HALF_CLOSED
            count = count + 1
        i = i + 1
    return count

# ============================================================================
# Settings Helpers
# ============================================================================

# Apply received settings
pub fn h3_apply_settings(conn: *H3Connection, settings: *H3SettingsFrame) -> i32
    var i: i32 = 0
    while i < settings.count
        let id: i64 = settings.settings[i].identifier
        let val: i64 = settings.settings[i].value

        if id == H3_SETTINGS_MAX_FIELD_SECTION_SIZE
            conn.max_field_section_size = val
        if id == H3_SETTINGS_QPACK_MAX_TABLE_CAPACITY
            conn.qpack_max_table_capacity = val
            qpack_dynamic_table_set_max_size(@conn.decoder.dynamic_table, val as i32)
        if id == H3_SETTINGS_QPACK_BLOCKED_STREAMS
            conn.qpack_blocked_streams = val
        i = i + 1

    conn.remote_control.settings_received = 1
    return 0

# Create local settings frame
pub fn h3_create_settings(conn: *H3Connection, settings: *H3SettingsFrame)
    h3_settings_frame_init(settings)

    if conn.qpack_max_table_capacity > 0
        h3_settings_set(settings, H3_SETTINGS_QPACK_MAX_TABLE_CAPACITY, conn.qpack_max_table_capacity)
    if conn.max_field_section_size > 0
        h3_settings_set(settings, H3_SETTINGS_MAX_FIELD_SECTION_SIZE, conn.max_field_section_size)
    if conn.qpack_blocked_streams > 0
        h3_settings_set(settings, H3_SETTINGS_QPACK_BLOCKED_STREAMS, conn.qpack_blocked_streams)

# ============================================================================
# GOAWAY Handling
# ============================================================================

pub fn h3_start_graceful_shutdown(conn: *H3Connection) -> i64
    conn.going_away = 1
    # Return the last stream ID that we will process
    return conn.last_stream_id

pub fn h3_handle_goaway(conn: *H3Connection, stream_id: i64)
    conn.going_away = 1
    conn.remote_control.goaway_received = 1
    conn.remote_control.last_good_stream = stream_id

pub fn h3_is_going_away(conn: *H3Connection) -> i32
    return conn.going_away

# ============================================================================
# Frame Validation
# ============================================================================

# Check if a frame type is allowed on control stream
pub fn h3_frame_allowed_on_control(frame_type: i64) -> i32
    if frame_type == H3_FRAME_SETTINGS
        return 1
    if frame_type == H3_FRAME_GOAWAY
        return 1
    if frame_type == H3_FRAME_MAX_PUSH_ID
        return 1
    if frame_type == H3_FRAME_CANCEL_PUSH
        return 1
    # Reserved frames are allowed
    if h3_is_reserved_frame_type(frame_type) != 0
        return 1
    return 0

# Check if a frame type is allowed on request stream
pub fn h3_frame_allowed_on_request(frame_type: i64) -> i32
    if frame_type == H3_FRAME_DATA
        return 1
    if frame_type == H3_FRAME_HEADERS
        return 1
    if frame_type == H3_FRAME_PUSH_PROMISE
        return 1
    # Reserved frames are allowed
    if h3_is_reserved_frame_type(frame_type) != 0
        return 1
    return 0

