# lib/json_stub.ritz - Stub for JSON reporter functions
#
# Provides no-op implementations of json_reporter functions
# to allow building without the full json_reporter module

# Empty implementations for JSON reporting (we use text output)
pub fn json_print_report()
    return

pub fn json_record_pass(name: *u8, duration_ms: i64)
    return

pub fn json_record_fail(name: *u8, code: i32, duration_ms: i64)
    return

pub fn json_record_crash(name: *u8, duration_ms: i64)
    return

pub fn json_record_timeout(name: *u8, duration_ms: i64)
    return

