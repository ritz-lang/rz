# lib/quic_packet.ritz - QUIC Packet Types (RFC 9000)
#
# QUIC has two packet header forms:
# - Long Header: Used during connection establishment (Initial, Handshake, 0-RTT, Retry)
# - Short Header: Used after handshake (1-RTT)
#
# The first bit distinguishes them:
# - 1xxx xxxx = Long Header
# - 0xxx xxxx = Short Header

import ritzlib.span
import lib.quic_varint

# ============================================================================
# Error Codes
# ============================================================================

pub const QUIC_OK: i32 = 0
pub const QUIC_ERR_INCOMPLETE: i32 = -1
pub const QUIC_ERR_INVALID: i32 = -2

# ============================================================================
# Header Form
# ============================================================================

pub const QUIC_HEADER_FORM_SHORT: i32 = 0
pub const QUIC_HEADER_FORM_LONG: i32 = 1

# ============================================================================
# Long Header Packet Types (RFC 9000 Section 17.2)
# ============================================================================

pub const QUIC_PKT_INITIAL: i32 = 0x00
pub const QUIC_PKT_0RTT: i32 = 0x01
pub const QUIC_PKT_HANDSHAKE: i32 = 0x02
pub const QUIC_PKT_RETRY: i32 = 0x03

# ============================================================================
# Version
# ============================================================================

pub const QUIC_VERSION_1: i32 = 0x00000001
pub const QUIC_VERSION_NEGOTIATION: i32 = 0x00000000

# ============================================================================
# Connection ID Limits
# ============================================================================

pub const QUIC_MAX_CID_LEN: i32 = 20
pub const QUIC_MIN_INITIAL_PACKET_SIZE: i32 = 1200

# ============================================================================
# Long Header Structure
# ============================================================================

pub struct QuicLongHeader
    # First byte breakdown:
    # - Bit 7: Header Form (1 = Long)
    # - Bit 6: Fixed Bit (1)
    # - Bits 5-4: Long Packet Type
    # - Bits 3-2: Type-Specific Bits (Reserved or packet number length)
    # - Bits 1-0: Type-Specific Bits
    first_byte: u8
    packet_type: i32
    version: i32
    dcid_len: i32
    scid_len: i32
    dcid: [20]u8   # Destination Connection ID
    scid: [20]u8   # Source Connection ID
    # For Initial packets:
    token_len: i64
    token_offset: i64  # Offset in buffer where token starts
    # Payload info:
    payload_len: i64
    payload_offset: i64

# ============================================================================
# Short Header Structure
# ============================================================================

pub struct QuicShortHeader
    # First byte breakdown:
    # - Bit 7: Header Form (0 = Short)
    # - Bit 6: Fixed Bit (1)
    # - Bit 5: Spin Bit
    # - Bits 4-3: Reserved
    # - Bit 2: Key Phase
    # - Bits 1-0: Packet Number Length
    first_byte: u8
    spin_bit: i32
    key_phase: i32
    pn_len: i32      # Packet number length (1-4)
    dcid_len: i32    # Derived from connection state
    dcid: [20]u8     # Destination Connection ID
    payload_offset: i64

# ============================================================================
# Initialization
# ============================================================================

pub fn quic_long_header_init(h: *QuicLongHeader)
    h.first_byte = 0
    h.packet_type = 0
    h.version = 0
    h.dcid_len = 0
    h.scid_len = 0
    h.token_len = 0
    h.token_offset = 0
    h.payload_len = 0
    h.payload_offset = 0

pub fn quic_short_header_init(h: *QuicShortHeader)
    h.first_byte = 0
    h.spin_bit = 0
    h.key_phase = 0
    h.pn_len = 0
    h.dcid_len = 0
    h.payload_offset = 0

# ============================================================================
# Header Form Detection
# ============================================================================

# Check if this is a long header packet
pub fn quic_is_long_header(first_byte: u8) -> i32
    if (first_byte & 0x80) != 0
        return 1
    return 0

# Get the packet type from a long header first byte
pub fn quic_long_packet_type(first_byte: u8) -> i32
    return ((first_byte >> 4) & 0x03) as i32

# ============================================================================
# Long Header Parsing
# ============================================================================

# Parse a QUIC long header
# Returns bytes consumed on success, negative on error
pub fn quic_parse_long_header(buf: *u8, buf_len: i32, h: *QuicLongHeader) -> i32
    quic_long_header_init(h)

    # Minimum long header: 1 (flags) + 4 (version) + 1 (dcid_len) + 1 (scid_len) = 7 bytes
    if buf_len < 7
        return QUIC_ERR_INCOMPLETE

    h.first_byte = *buf

    # Check header form
    if (h.first_byte & 0x80) == 0
        return QUIC_ERR_INVALID  # Not a long header

    # Check fixed bit (must be 1)
    if (h.first_byte & 0x40) == 0
        return QUIC_ERR_INVALID

    h.packet_type = ((h.first_byte >> 4) & 0x03) as i32

    # Version (4 bytes, big-endian)
    let v0: i32 = (*(buf + 1)) as i32 & 0xFF
    let v1: i32 = (*(buf + 2)) as i32 & 0xFF
    let v2: i32 = (*(buf + 3)) as i32 & 0xFF
    let v3: i32 = (*(buf + 4)) as i32 & 0xFF
    h.version = (v0 << 24) | (v1 << 16) | (v2 << 8) | v3

    # DCID length
    h.dcid_len = (*(buf + 5)) as i32 & 0xFF
    if h.dcid_len > QUIC_MAX_CID_LEN
        return QUIC_ERR_INVALID

    # Check we have enough for DCID + SCID length byte
    var pos: i32 = 6
    if buf_len < pos + h.dcid_len + 1
        return QUIC_ERR_INCOMPLETE

    # Copy DCID
    var i: i32 = 0
    while i < h.dcid_len
        h.dcid[i] = *(buf + pos + i)
        i = i + 1
    pos = pos + h.dcid_len

    # SCID length
    h.scid_len = (*(buf + pos)) as i32 & 0xFF
    if h.scid_len > QUIC_MAX_CID_LEN
        return QUIC_ERR_INVALID
    pos = pos + 1

    # Check we have enough for SCID
    if buf_len < pos + h.scid_len
        return QUIC_ERR_INCOMPLETE

    # Copy SCID
    i = 0
    while i < h.scid_len
        h.scid[i] = *(buf + pos + i)
        i = i + 1
    pos = pos + h.scid_len

    # For Initial packets, parse token
    if h.packet_type == QUIC_PKT_INITIAL && h.version != QUIC_VERSION_NEGOTIATION
        # Token length (varint)
        var vr: VarintResult
        let vret: i32 = varint_parse(buf + pos, buf_len - pos, @vr)
        if vret != VARINT_OK
            return QUIC_ERR_INCOMPLETE
        h.token_len = vr.value
        pos = pos + vr.bytes_consumed
        h.token_offset = pos as i64

        if buf_len < pos + (h.token_len as i32)
            return QUIC_ERR_INCOMPLETE
        pos = pos + (h.token_len as i32)

    # Payload length (varint) - for all except Retry
    if h.packet_type != QUIC_PKT_RETRY
        var vr: VarintResult
        let vret: i32 = varint_parse(buf + pos, buf_len - pos, @vr)
        if vret != VARINT_OK
            return QUIC_ERR_INCOMPLETE
        h.payload_len = vr.value
        pos = pos + vr.bytes_consumed
        h.payload_offset = pos as i64

    return pos

# ============================================================================
# Short Header Parsing
# ============================================================================

# Parse a QUIC short header
# Note: dcid_len must be known from connection state
# Returns bytes consumed on success, negative on error
pub fn quic_parse_short_header(buf: *u8, buf_len: i32, dcid_len: i32, h: *QuicShortHeader) -> i32
    quic_short_header_init(h)

    # Minimum short header: 1 (flags) + dcid_len
    if buf_len < 1 + dcid_len
        return QUIC_ERR_INCOMPLETE

    h.first_byte = *buf

    # Check header form
    if (h.first_byte & 0x80) != 0
        return QUIC_ERR_INVALID  # Not a short header

    # Check fixed bit (must be 1)
    if (h.first_byte & 0x40) == 0
        return QUIC_ERR_INVALID

    h.spin_bit = ((h.first_byte >> 5) & 0x01) as i32
    h.key_phase = ((h.first_byte >> 2) & 0x01) as i32
    h.pn_len = ((h.first_byte & 0x03) + 1) as i32  # 0=1byte, 1=2bytes, etc.
    h.dcid_len = dcid_len

    # Copy DCID
    var i: i32 = 0
    while i < dcid_len
        h.dcid[i] = *(buf + 1 + i)
        i = i + 1

    h.payload_offset = (1 + dcid_len) as i64
    return 1 + dcid_len

# ============================================================================
# Long Header Writing
# ============================================================================

# Write a QUIC long header
# Returns bytes written on success, negative on error
pub fn quic_write_long_header(h: *QuicLongHeader, buf: *u8, buf_len: i32) -> i32
    # Calculate required size
    var size: i32 = 7 + h.dcid_len + h.scid_len

    # For Initial, add token
    if h.packet_type == QUIC_PKT_INITIAL
        size = size + varint_encoded_len(h.token_len) + (h.token_len as i32)

    # Add payload length field (except Retry)
    if h.packet_type != QUIC_PKT_RETRY
        size = size + varint_encoded_len(h.payload_len)

    if buf_len < size
        return QUIC_ERR_INCOMPLETE

    var pos: i32 = 0

    # First byte: form=1, fixed=1, type, reserved
    *buf = 0xC0 | ((h.packet_type as u8) << 4)
    pos = 1

    # Version
    *(buf + pos) = ((h.version >> 24) & 0xFF) as u8
    *(buf + pos + 1) = ((h.version >> 16) & 0xFF) as u8
    *(buf + pos + 2) = ((h.version >> 8) & 0xFF) as u8
    *(buf + pos + 3) = (h.version & 0xFF) as u8
    pos = pos + 4

    # DCID length and DCID
    *(buf + pos) = h.dcid_len as u8
    pos = pos + 1
    var i: i32 = 0
    while i < h.dcid_len
        *(buf + pos + i) = h.dcid[i]
        i = i + 1
    pos = pos + h.dcid_len

    # SCID length and SCID
    *(buf + pos) = h.scid_len as u8
    pos = pos + 1
    i = 0
    while i < h.scid_len
        *(buf + pos + i) = h.scid[i]
        i = i + 1
    pos = pos + h.scid_len

    # Token for Initial packets
    if h.packet_type == QUIC_PKT_INITIAL
        let vlen: i32 = varint_encode(h.token_len, buf + pos, buf_len - pos)
        if vlen < 0
            return QUIC_ERR_INCOMPLETE
        pos = pos + vlen
        # Note: caller must copy token data after this

    # Payload length (except Retry)
    if h.packet_type != QUIC_PKT_RETRY
        let vlen: i32 = varint_encode(h.payload_len, buf + pos, buf_len - pos)
        if vlen < 0
            return QUIC_ERR_INCOMPLETE
        pos = pos + vlen

    return pos
