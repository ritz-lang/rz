# test/test_quic_cid.ritz - Tests for QUIC Connection ID management
#
# RFC 9000 Section 5.1 defines connection ID usage

import ritzlib.span
import lib.quic_cid

# ============================================================================
# Connection ID Basic Operations
# ============================================================================

[[test]]
fn test_cid_init() -> i32
    var cid: ConnectionId
    cid_init(@cid)
    if cid.len != 0
        return 1
    return 0

[[test]]
fn test_cid_from_bytes() -> i32
    var buf: [8]u8
    buf[0] = 0x01
    buf[1] = 0x02
    buf[2] = 0x03
    buf[3] = 0x04

    var cid: ConnectionId
    let ret: i32 = cid_from_bytes(@cid, @buf[0], 4)
    if ret != CID_OK
        return 1
    if cid.len != 4
        return 2
    if cid.data[0] != 0x01
        return 3
    if cid.data[3] != 0x04
        return 4
    return 0

[[test]]
fn test_cid_from_bytes_max_len() -> i32
    var buf: [20]u8
    var i: i32 = 0
    while i < 20
        buf[i] = i as u8
        i = i + 1

    var cid: ConnectionId
    let ret: i32 = cid_from_bytes(@cid, @buf[0], 20)
    if ret != CID_OK
        return 1
    if cid.len != 20
        return 2
    return 0

[[test]]
fn test_cid_from_bytes_too_long() -> i32
    var buf: [24]u8
    var cid: ConnectionId
    let ret: i32 = cid_from_bytes(@cid, @buf[0], 21)
    if ret != CID_ERR_INVALID
        return 1
    return 0

[[test]]
fn test_cid_from_bytes_empty() -> i32
    var buf: [8]u8
    var cid: ConnectionId
    let ret: i32 = cid_from_bytes(@cid, @buf[0], 0)
    if ret != CID_OK
        return 1
    if cid.len != 0
        return 2
    return 0

[[test]]
fn test_cid_copy() -> i32
    var buf: [8]u8
    buf[0] = 0xAA
    buf[1] = 0xBB
    buf[2] = 0xCC

    var src: ConnectionId
    cid_from_bytes(@src, @buf[0], 3)

    var dst: ConnectionId
    cid_copy(@dst, @src)

    if dst.len != 3
        return 1
    if dst.data[0] != 0xAA
        return 2
    if dst.data[2] != 0xCC
        return 3
    return 0

[[test]]
fn test_cid_equals_same() -> i32
    var buf: [8]u8
    buf[0] = 0x11
    buf[1] = 0x22

    var a: ConnectionId
    var b: ConnectionId
    cid_from_bytes(@a, @buf[0], 2)
    cid_from_bytes(@b, @buf[0], 2)

    if cid_equals(@a, @b) != 1
        return 1
    return 0

[[test]]
fn test_cid_equals_different_data() -> i32
    var buf1: [8]u8
    var buf2: [8]u8
    buf1[0] = 0x11
    buf2[0] = 0x22

    var a: ConnectionId
    var b: ConnectionId
    cid_from_bytes(@a, @buf1[0], 1)
    cid_from_bytes(@b, @buf2[0], 1)

    if cid_equals(@a, @b) != 0
        return 1
    return 0

[[test]]
fn test_cid_equals_different_len() -> i32
    var buf: [8]u8
    buf[0] = 0x11

    var a: ConnectionId
    var b: ConnectionId
    cid_from_bytes(@a, @buf[0], 1)
    cid_from_bytes(@b, @buf[0], 2)

    if cid_equals(@a, @b) != 0
        return 1
    return 0

[[test]]
fn test_cid_is_empty() -> i32
    var cid: ConnectionId
    cid_init(@cid)
    if cid_is_empty(@cid) != 1
        return 1

    var buf: [8]u8
    buf[0] = 0x01
    cid_from_bytes(@cid, @buf[0], 1)
    if cid_is_empty(@cid) != 0
        return 2
    return 0

# ============================================================================
# CID Manager - Local CIDs
# ============================================================================

[[test]]
fn test_cid_manager_init() -> i32
    var mgr: CidManager
    cid_manager_init(@mgr)
    if mgr.local_count != 0
        return 1
    if mgr.remote_count != 0
        return 2
    if mgr.local_next_seq != 0
        return 3
    return 0

[[test]]
fn test_cid_add_local() -> i32
    var mgr: CidManager
    cid_manager_init(@mgr)

    var buf: [8]u8
    buf[0] = 0xAA
    buf[1] = 0xBB

    var cid: ConnectionId
    cid_from_bytes(@cid, @buf[0], 2)

    let seq: i64 = cid_add_local(@mgr, @cid, null)
    if seq != 0
        return 1
    if mgr.local_count != 1
        return 2
    if mgr.local_next_seq != 1
        return 3
    return 0

[[test]]
fn test_cid_add_local_multiple() -> i32
    var mgr: CidManager
    cid_manager_init(@mgr)

    var buf: [8]u8
    var cid: ConnectionId

    var i: i32 = 0
    while i < 4
        buf[0] = i as u8
        cid_from_bytes(@cid, @buf[0], 1)
        let seq: i64 = cid_add_local(@mgr, @cid, null)
        if seq != i as i64
            return 1
        i = i + 1

    if mgr.local_count != 4
        return 2
    return 0

[[test]]
fn test_cid_find_local() -> i32
    var mgr: CidManager
    cid_manager_init(@mgr)

    var buf: [8]u8
    buf[0] = 0xDE
    buf[1] = 0xAD

    var cid: ConnectionId
    cid_from_bytes(@cid, @buf[0], 2)
    cid_add_local(@mgr, @cid, null)

    let idx: i32 = cid_find_local(@mgr, @cid)
    if idx != 0
        return 1
    return 0

[[test]]
fn test_cid_find_local_not_found() -> i32
    var mgr: CidManager
    cid_manager_init(@mgr)

    var buf: [8]u8
    buf[0] = 0xFF

    var cid: ConnectionId
    cid_from_bytes(@cid, @buf[0], 1)

    let idx: i32 = cid_find_local(@mgr, @cid)
    if idx != -1
        return 1
    return 0

[[test]]
fn test_cid_retire_local() -> i32
    var mgr: CidManager
    cid_manager_init(@mgr)

    var buf: [8]u8
    buf[0] = 0x11
    var cid: ConnectionId
    cid_from_bytes(@cid, @buf[0], 1)
    cid_add_local(@mgr, @cid, null)

    let ret: i32 = cid_retire_local(@mgr, 0)
    if ret != CID_OK
        return 1

    # Should not find retired CID
    let idx: i32 = cid_find_local(@mgr, @cid)
    if idx != -1
        return 2
    return 0

# ============================================================================
# CID Manager - Remote CIDs
# ============================================================================

[[test]]
fn test_cid_add_remote() -> i32
    var mgr: CidManager
    cid_manager_init(@mgr)

    var buf: [8]u8
    buf[0] = 0xCC
    buf[1] = 0xDD

    var cid: ConnectionId
    cid_from_bytes(@cid, @buf[0], 2)

    let ret: i32 = cid_add_remote(@mgr, @cid, 0, 0, null)
    if ret != CID_OK
        return 1
    if mgr.remote_count != 1
        return 2
    return 0

[[test]]
fn test_cid_add_remote_duplicate() -> i32
    var mgr: CidManager
    cid_manager_init(@mgr)

    var buf: [8]u8
    buf[0] = 0xEE
    var cid: ConnectionId
    cid_from_bytes(@cid, @buf[0], 1)

    cid_add_remote(@mgr, @cid, 0, 0, null)
    let ret: i32 = cid_add_remote(@mgr, @cid, 0, 0, null)
    if ret != CID_ERR_DUPLICATE
        return 1
    return 0

[[test]]
fn test_cid_add_remote_retire_prior() -> i32
    var mgr: CidManager
    cid_manager_init(@mgr)

    var buf: [8]u8
    var cid: ConnectionId

    # Add CIDs with sequence 0, 1, 2
    var i: i32 = 0
    while i < 3
        buf[0] = i as u8
        cid_from_bytes(@cid, @buf[0], 1)
        cid_add_remote(@mgr, @cid, i as i64, 0, null)
        i = i + 1

    # Add CID with retire_prior_to = 2 (should retire 0 and 1)
    buf[0] = 0xFF
    cid_from_bytes(@cid, @buf[0], 1)
    cid_add_remote(@mgr, @cid, 3, 2, null)

    let active: i32 = cid_count_active_remote(@mgr)
    if active != 2  # CIDs 2 and 3 should be active
        return 1
    return 0

[[test]]
fn test_cid_get_active_remote() -> i32
    var mgr: CidManager
    cid_manager_init(@mgr)

    var buf: [8]u8
    buf[0] = 0xAA
    buf[1] = 0xBB

    var cid: ConnectionId
    cid_from_bytes(@cid, @buf[0], 2)
    cid_add_remote(@mgr, @cid, 0, 0, null)

    var active: ConnectionId
    let ret: i32 = cid_get_active_remote(@mgr, @active)
    if ret != CID_OK
        return 1
    if cid_equals(@active, @cid) != 1
        return 2
    return 0

[[test]]
fn test_cid_count_active_local() -> i32
    var mgr: CidManager
    cid_manager_init(@mgr)

    var buf: [8]u8
    var cid: ConnectionId

    # Add 3 local CIDs
    var i: i32 = 0
    while i < 3
        buf[0] = i as u8
        cid_from_bytes(@cid, @buf[0], 1)
        cid_add_local(@mgr, @cid, null)
        i = i + 1

    if cid_count_active_local(@mgr) != 3
        return 1

    # Retire one
    cid_retire_local(@mgr, 1)
    if cid_count_active_local(@mgr) != 2
        return 2
    return 0
