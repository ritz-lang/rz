# test/test_h2_settings.ritz - Tests for HTTP/2 settings management
#
# Tests settings parsing, serialization, and connection preface.

import ritzlib.span
import lib.h2_frame

# ============================================================================
# Settings Initialization Tests
# ============================================================================

[[test]]
fn test_settings_init() -> i32
    var settings: H2Settings
    h2_settings_init(@settings)

    if settings.header_table_size != 4096
        return 1

    if settings.enable_push != 1
        return 2

    if settings.initial_window_size != 65535
        return 3

    if settings.max_frame_size != 16384
        return 4

    return 0

# ============================================================================
# Settings Parsing Tests
# ============================================================================

[[test]]
fn test_settings_parse_header_table_size() -> i32
    var settings: H2Settings
    h2_settings_init(@settings)

    # Setting: HEADER_TABLE_SIZE = 8192
    # ID = 0x0001, Value = 0x00002000
    var buf: [6]u8
    buf[0] = 0x00
    buf[1] = 0x01  # ID = 1
    buf[2] = 0x00
    buf[3] = 0x00
    buf[4] = 0x20
    buf[5] = 0x00  # Value = 8192

    var input: Span<u8> = span_from_ptr<u8>(@buf[0], 6)
    let result: i32 = h2_parse_settings(@input, @settings)

    if result != H2_OK
        return 1

    if settings.header_table_size != 8192
        return 2

    return 0

[[test]]
fn test_settings_parse_max_frame_size() -> i32
    var settings: H2Settings
    h2_settings_init(@settings)

    # Setting: MAX_FRAME_SIZE = 32768
    # ID = 0x0005, Value = 0x00008000
    var buf: [6]u8
    buf[0] = 0x00
    buf[1] = 0x05  # ID = 5
    buf[2] = 0x00
    buf[3] = 0x00
    buf[4] = 0x80
    buf[5] = 0x00  # Value = 32768

    var input: Span<u8> = span_from_ptr<u8>(@buf[0], 6)
    let result: i32 = h2_parse_settings(@input, @settings)

    if result != H2_OK
        return 1

    if settings.max_frame_size != 32768 as i64
        return 2

    return 0

[[test]]
fn test_settings_parse_multiple() -> i32
    var settings: H2Settings
    h2_settings_init(@settings)

    # Two settings: HEADER_TABLE_SIZE=8192, MAX_CONCURRENT_STREAMS=200
    var buf: [12]u8
    # HEADER_TABLE_SIZE = 8192
    buf[0] = 0x00
    buf[1] = 0x01
    buf[2] = 0x00
    buf[3] = 0x00
    buf[4] = 0x20
    buf[5] = 0x00
    # MAX_CONCURRENT_STREAMS = 200
    buf[6] = 0x00
    buf[7] = 0x03
    buf[8] = 0x00
    buf[9] = 0x00
    buf[10] = 0x00
    buf[11] = 0xC8

    var input: Span<u8> = span_from_ptr<u8>(@buf[0], 12)
    let result: i32 = h2_parse_settings(@input, @settings)

    if result != H2_OK
        return 1

    if settings.header_table_size != 8192
        return 2

    if settings.max_concurrent_streams != 200 as i64
        return 3

    return 0

[[test]]
fn test_settings_parse_invalid_length() -> i32
    var settings: H2Settings
    h2_settings_init(@settings)

    # 7 bytes - not a multiple of 6
    var buf: [7]u8
    var input: Span<u8> = span_from_ptr<u8>(@buf[0], 7)
    let result: i32 = h2_parse_settings(@input, @settings)

    if result != H2_ERR_FRAME_SIZE
        return 1

    return 0

[[test]]
fn test_settings_parse_empty() -> i32
    var settings: H2Settings
    h2_settings_init(@settings)

    # Empty payload is valid (0 settings)
    var input: Span<u8>
    input.ptr = null
    input.len = 0

    let result: i32 = h2_parse_settings(@input, @settings)

    if result != H2_OK
        return 1

    return 0

# ============================================================================
# Settings Serialization Tests
# ============================================================================

[[test]]
fn test_settings_write_one() -> i32
    var buf: [6]u8
    let written: i32 = h2_write_setting(@buf[0], 6, H2_SETTINGS_MAX_FRAME_SIZE, 32768)

    if written != 6
        return 1

    if buf[0] != 0x00
        return 2
    if buf[1] != 0x05
        return 3
    if buf[2] != 0x00
        return 4
    if buf[3] != 0x00
        return 5
    if buf[4] != 0x80
        return 6
    if buf[5] != 0x00
        return 7

    return 0

[[test]]
fn test_settings_write_too_small() -> i32
    var buf: [4]u8
    let written: i32 = h2_write_setting(@buf[0], 4, H2_SETTINGS_MAX_FRAME_SIZE, 32768)

    if written != H2_ERR_INCOMPLETE
        return 1

    return 0

[[test]]
fn test_settings_roundtrip() -> i32
    # Write a setting
    var buf: [6]u8
    h2_write_setting(@buf[0], 6, H2_SETTINGS_INITIAL_WINDOW_SIZE, 131072)

    # Parse it back
    var settings: H2Settings
    h2_settings_init(@settings)

    var input: Span<u8> = span_from_ptr<u8>(@buf[0], 6)
    let result: i32 = h2_parse_settings(@input, @settings)

    if result != H2_OK
        return 1

    if settings.initial_window_size != 131072
        return 2

    return 0

# ============================================================================
# Connection Preface Tests
# ============================================================================

[[test]]
fn test_connection_preface_write() -> i32
    var buf: [24]u8
    let written: i32 = h2_write_preface(@buf[0], 24)

    if written != H2_PREFACE_LEN
        return 1

    # "PRI * HTTP/2.0\r\n\r\nSM\r\n\r\n"
    if buf[0] != 'P'
        return 2
    if buf[1] != 'R'
        return 3
    if buf[2] != 'I'
        return 4
    if buf[3] != ' '
        return 5
    if buf[4] != '*'
        return 6
    if buf[18] != 'S'
        return 7
    if buf[19] != 'M'
        return 8
    if buf[23] != '\n'
        return 9

    return 0

[[test]]
fn test_connection_preface_verify_valid() -> i32
    var buf: [24]u8
    h2_write_preface(@buf[0], 24)

    let result: i32 = h2_check_preface(@buf[0], 24)

    if result != H2_OK
        return 1

    return 0

[[test]]
fn test_connection_preface_verify_invalid() -> i32
    var buf: [24]u8
    h2_write_preface(@buf[0], 24)

    # Corrupt one byte
    buf[5] = 'X'

    let result: i32 = h2_check_preface(@buf[0], 24)

    if result != H2_ERR_INVALID
        return 1

    return 0

[[test]]
fn test_connection_preface_verify_too_short() -> i32
    var buf: [20]u8
    let result: i32 = h2_check_preface(@buf[0], 20)

    if result != H2_ERR_INCOMPLETE
        return 1

    return 0
