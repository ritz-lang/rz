fn test_method_from_span_options() -> i32
    var s: Span<u8> = span_from_cstr(c"OPTIONS")
    let m: i32 = method_from_span(@s)
    if m != METHOD_OPTIONS
        return 1
    return 0

[[test]]
fn test_method_from_span_patch() -> i32
    var s: Span<u8> = span_from_cstr(c"PATCH")
    let m: i32 = method_from_span(@s)
    if m != METHOD_PATCH
        return 1
    return 0

[[test]]
fn test_method_from_span_connect() -> i32
    var s: Span<u8> = span_from_cstr(c"CONNECT")
    let m: i32 = method_from_span(@s)
    if m != METHOD_CONNECT
        return 1
    return 0

[[test]]
fn test_method_from_span_trace() -> i32
    var s: Span<u8> = span_from_cstr(c"TRACE")
    let m: i32 = method_from_span(@s)
    if m != METHOD_TRACE
        return 1
    return 0

[[test]]
fn test_method_from_span_unknown() -> i32
    var s: Span<u8> = span_from_cstr(c"FOOBAR")
    let m: i32 = method_from_span(@s)
    if m != METHOD_UNKNOWN
        return 1
    return 0

[[test]]
fn test_method_to_span_get() -> i32
    var s: Span<u8> = method_to_span(METHOD_GET)
    var expected: Span<u8> = span_from_cstr(c"GET")
    if span_eq(@s, @expected) != 1
        return 1
    return 0

[[test]]
fn test_method_to_span_post() -> i32
    var s: Span<u8> = method_to_span(METHOD_POST)
    var expected: Span<u8> = span_from_cstr(c"POST")
    if span_eq(@s, @expected) != 1
        return 1
    return 0

# ============================================================================
# Version Tests
# ============================================================================

[[test]]
fn test_version_http10() -> i32
    let v: i32 = VERSION_HTTP10
    if v != 10
        return 1
    return 0

[[test]]
fn test_version_http11() -> i32
    let v: i32 = VERSION_HTTP11
    if v != 11
        return 1
    return 0

[[test]]
fn test_version_http2() -> i32
    let v: i32 = VERSION_HTTP2
    if v != 20
        return 1
    return 0

[[test]]
fn test_version_http3() -> i32
    let v: i32 = VERSION_HTTP3
    if v != 30
        return 1
    return 0

[[test]]
fn test_version_from_span_http10() -> i32
    var s: Span<u8> = span_from_cstr(c"HTTP/1.0")
    let v: i32 = version_from_span(@s)
    if v != VERSION_HTTP10
        return 1
    return 0

[[test]]
fn test_version_from_span_http11() -> i32
    var s: Span<u8> = span_from_cstr(c"HTTP/1.1")
    let v: i32 = version_from_span(@s)
    if v != VERSION_HTTP11
        return 1
    return 0

[[test]]
fn test_version_from_span_http2() -> i32
    var s: Span<u8> = span_from_cstr(c"HTTP/2")
    let v: i32 = version_from_span(@s)
    if v != VERSION_HTTP2
        return 1
    return 0

[[test]]
fn test_version_from_span_http2_dot_0() -> i32
    var s: Span<u8> = span_from_cstr(c"HTTP/2.0")
    let v: i32 = version_from_span(@s)
    if v != VERSION_HTTP2
        return 1
    return 0

[[test]]
fn test_version_from_span_http3() -> i32
    var s: Span<u8> = span_from_cstr(c"HTTP/3")
    let v: i32 = version_from_span(@s)
    if v != VERSION_HTTP3
        return 1
    return 0

[[test]]
fn test_version_from_span_unknown() -> i32
    var s: Span<u8> = span_from_cstr(c"HTXP/9.9")
    let v: i32 = version_from_span(@s)
    if v != VERSION_UNKNOWN
        return 1
    return 0

[[test]]
fn test_version_to_span_http11() -> i32
    var s: Span<u8> = version_to_span(VERSION_HTTP11)
    var expected: Span<u8> = span_from_cstr(c"HTTP/1.1")
    if span_eq(@s, @expected) != 1
        return 1
    return 0

# ============================================================================
# Status Tests
# ============================================================================

[[test]]
fn test_status_ok() -> i32
    let s: i32 = STATUS_OK
    if s != 200
        return 1
    return 0

[[test]]
fn test_status_not_found() -> i32
    let s: i32 = STATUS_NOT_FOUND
    if s != 404
        return 1
    return 0

[[test]]
fn test_status_reason_ok() -> i32
    var reason: Span<u8> = status_reason(STATUS_OK)
    var expected: Span<u8> = span_from_cstr(c"OK")
    if span_eq(@reason, @expected) != 1
        return 1
    return 0

[[test]]
fn test_status_reason_not_found() -> i32
    var reason: Span<u8> = status_reason(STATUS_NOT_FOUND)
    var expected: Span<u8> = span_from_cstr(c"Not Found")
    if span_eq(@reason, @expected) != 1
        return 1
    return 0

[[test]]
fn test_status_reason_internal_error() -> i32
    var reason: Span<u8> = status_reason(STATUS_INTERNAL_SERVER_ERROR)
    var expected: Span<u8> = span_from_cstr(c"Internal Server Error")
    if span_eq(@reason, @expected) != 1
        return 1
    return 0

[[test]]
fn test_status_is_info() -> i32
    if status_is_info(100) != 1
        return 1
    if status_is_info(199) != 1
        return 2
    if status_is_info(200) != 0
        return 3
    return 0

[[test]]
fn test_status_is_success() -> i32
    if status_is_success(200) != 1
        return 1
    if status_is_success(299) != 1
        return 2
    if status_is_success(300) != 0
        return 3
    return 0

[[test]]
fn test_status_is_redirect() -> i32
    if status_is_redirect(301) != 1
        return 1
    if status_is_redirect(302) != 1
        return 2
    if status_is_redirect(400) != 0
        return 3
    return 0

[[test]]
fn test_status_is_client_error() -> i32
    if status_is_client_error(400) != 1
        return 1
    if status_is_client_error(404) != 1
        return 2
    if status_is_client_error(500) != 0
        return 3
    return 0

[[test]]
fn test_status_is_server_error() -> i32
    if status_is_server_error(500) != 1
        return 1
    if status_is_server_error(503) != 1
        return 2
    if status_is_server_error(400) != 0
        return 3
    return 0
