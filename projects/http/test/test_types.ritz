# test/test_types.ritz - Tests for core HTTP types
#
# Tests Method, Status, Version, and related parsing/serialization.

import ritzlib.span
import ritzlib.str
import lib.types

# ============================================================================
# Method Tests
# ============================================================================

[[test]]
fn test_method_get() -> i32
    let m: i32 = METHOD_GET
    if m != 1
        return 1
    return 0

[[test]]
fn test_method_post() -> i32
    let m: i32 = METHOD_POST
    if m != 2
        return 1
    return 0

[[test]]
fn test_method_from_span_get() -> i32
    var s: Span<u8> = span_from_cstr(c"GET")
    let m: i32 = method_from_span(@s)
    if m != METHOD_GET
        return 1
    return 0

[[test]]
fn test_method_from_span_post() -> i32
    var s: Span<u8> = span_from_cstr(c"POST")
    let m: i32 = method_from_span(@s)
    if m != METHOD_POST
        return 1
    return 0

[[test]]
fn test_method_from_span_put() -> i32
    var s: Span<u8> = span_from_cstr(c"PUT")
    let m: i32 = method_from_span(@s)
    if m != METHOD_PUT
        return 1
    return 0

[[test]]
fn test_method_from_span_delete() -> i32
    var s: Span<u8> = span_from_cstr(c"DELETE")
    let m: i32 = method_from_span(@s)
    if m != METHOD_DELETE
        return 1
    return 0

