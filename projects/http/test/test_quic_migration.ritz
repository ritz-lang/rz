# test/test_quic_migration.ritz - Tests for QUIC connection migration
#
# RFC 9000 Section 9 defines connection migration

import ritzlib.span
import lib.quic_migration

# ============================================================================
# Address Tests
# ============================================================================

[[test]]
fn test_address_init() -> i32
    var addr: Address
    address_init(@addr)
    if addr.len != 0
        return 1
    if addr.port != 0
        return 2
    return 0

[[test]]
fn test_address_set_ipv4() -> i32
    var addr: Address
    address_set_ipv4(@addr, 192, 168, 1, 1, 443)
    if addr.len != 4
        return 1
    if addr.port != 443
        return 2
    if addr.data[0] != 192
        return 3
    if addr.data[1] != 168
        return 4
    if addr.data[2] != 1
        return 5
    if addr.data[3] != 1
        return 6
    return 0

[[test]]
fn test_address_copy() -> i32
    var src: Address
    var dst: Address
    address_set_ipv4(@src, 10, 0, 0, 1, 8080)
    address_copy(@dst, @src)
    if dst.len != 4
        return 1
    if dst.port != 8080
        return 2
    if dst.data[0] != 10
        return 3
    return 0

[[test]]
fn test_address_equals_same() -> i32
    var a: Address
    var b: Address
    address_set_ipv4(@a, 127, 0, 0, 1, 443)
    address_set_ipv4(@b, 127, 0, 0, 1, 443)
    if address_equals(@a, @b) != 1
        return 1
    return 0

[[test]]
fn test_address_equals_different_ip() -> i32
    var a: Address
    var b: Address
    address_set_ipv4(@a, 127, 0, 0, 1, 443)
    address_set_ipv4(@b, 127, 0, 0, 2, 443)
    if address_equals(@a, @b) != 0
        return 1
    return 0

[[test]]
fn test_address_equals_different_port() -> i32
    var a: Address
    var b: Address
    address_set_ipv4(@a, 127, 0, 0, 1, 443)
    address_set_ipv4(@b, 127, 0, 0, 1, 8080)
    if address_equals(@a, @b) != 0
        return 1
    return 0

[[test]]
fn test_address_is_empty() -> i32
    var addr: Address
    address_init(@addr)
    if address_is_empty(@addr) != 1
        return 1
    address_set_ipv4(@addr, 1, 2, 3, 4, 80)
    if address_is_empty(@addr) != 0
        return 2
    return 0

# ============================================================================
# Path Tests
# ============================================================================

[[test]]
fn test_path_init() -> i32
    var path: Path
    path_init(@path)
    if path.state != PATH_STATE_UNUSED
        return 1
    if path.challenge_pending != 0
        return 2
    if path.bytes_sent != 0
        return 3
    if path.bytes_recv != 0
        return 4
    if path.is_active != 0
        return 5
    return 0

[[test]]
fn test_path_is_validated() -> i32
    var path: Path
    path_init(@path)
    if path_is_validated(@path) != 0
        return 1
    path.state = PATH_STATE_VALIDATED
    if path_is_validated(@path) != 1
        return 2
    return 0

[[test]]
fn test_path_is_validating() -> i32
    var path: Path
    path_init(@path)
    if path_is_validating(@path) != 0
        return 1
    path.state = PATH_STATE_VALIDATING
    if path_is_validating(@path) != 1
        return 2
    return 0

[[test]]
fn test_path_can_send_validated() -> i32
    var path: Path
    path_init(@path)
    path.state = PATH_STATE_VALIDATED
    # Validated path can always send
    if path_can_send(@path, 10000) != 1
        return 1
    return 0

[[test]]
fn test_path_can_send_unvalidated() -> i32
    var path: Path
    path_init(@path)
    path.state = PATH_STATE_VALIDATING
    path.bytes_recv = 1000
    # Can send up to 3x received = 3000
    if path_can_send(@path, 2000) != 1
        return 1
    if path_can_send(@path, 3000) != 1
        return 2
    if path_can_send(@path, 4000) != 0
        return 3
    return 0

[[test]]
fn test_path_bytes_tracking() -> i32
    var path: Path
    path_init(@path)
    path_on_bytes_sent(@path, 1200)
    if path.bytes_sent != 1200
        return 1
    path_on_bytes_recv(@path, 800)
    if path.bytes_recv != 800
        return 2
    path_on_bytes_sent(@path, 500)
    if path.bytes_sent != 1700
        return 3
    return 0

# ============================================================================
# Path Manager Tests
# ============================================================================

[[test]]
fn test_path_manager_init() -> i32
    var mgr: PathManager
    path_manager_init(@mgr)
    if mgr.count != 0
        return 1
    if mgr.active_idx != -1
        return 2
    return 0

[[test]]
fn test_path_add() -> i32
    var mgr: PathManager
    path_manager_init(@mgr)

    var local: Address
    var remote: Address
    address_set_ipv4(@local, 192, 168, 1, 100, 12345)
    address_set_ipv4(@remote, 10, 0, 0, 1, 443)

    let idx: i32 = path_add(@mgr, @local, @remote)
    if idx != 0
        return 1
    if mgr.count != 1
        return 2
    return 0

[[test]]
fn test_path_add_multiple() -> i32
    var mgr: PathManager
    path_manager_init(@mgr)

    var local: Address
    var remote: Address
    address_init(@local)

    var i: i32 = 0
    while i < 3
        address_set_ipv4(@remote, 10, 0, 0, (i + 1) as u8, 443)
        let idx: i32 = path_add(@mgr, @local, @remote)
        if idx != i
            return 1
        i = i + 1

    if mgr.count != 3
        return 2
    return 0

[[test]]
fn test_path_add_full() -> i32
    var mgr: PathManager
    path_manager_init(@mgr)

    var local: Address
    var remote: Address
    address_init(@local)

    var i: i32 = 0
    while i < MAX_PATHS
        address_set_ipv4(@remote, 10, 0, 0, (i + 1) as u8, 443)
        path_add(@mgr, @local, @remote)
        i = i + 1

    # Should fail when full
    address_set_ipv4(@remote, 10, 0, 0, 99, 443)
    let ret: i32 = path_add(@mgr, @local, @remote)
    if ret != MIGRATION_ERR_FULL
        return 1
    return 0

[[test]]
fn test_path_find_by_remote() -> i32
    var mgr: PathManager
    path_manager_init(@mgr)

    var local: Address
    var remote1: Address
    var remote2: Address
    address_init(@local)
    address_set_ipv4(@remote1, 10, 0, 0, 1, 443)
    address_set_ipv4(@remote2, 10, 0, 0, 2, 443)

    path_add(@mgr, @local, @remote1)
    path_add(@mgr, @local, @remote2)

    let idx: i32 = path_find_by_remote(@mgr, @remote2)
    if idx != 1
        return 1

    var remote3: Address
    address_set_ipv4(@remote3, 10, 0, 0, 99, 443)
    let not_found: i32 = path_find_by_remote(@mgr, @remote3)
    if not_found != -1
        return 2
    return 0

[[test]]
fn test_path_get() -> i32
    var mgr: PathManager
    path_manager_init(@mgr)

    var local: Address
    var remote: Address
    address_init(@local)
    address_set_ipv4(@remote, 10, 0, 0, 1, 443)
    path_add(@mgr, @local, @remote)

    var path: *Path = path_get(@mgr, 0)
    if path == null
        return 1
    if address_equals(@path.remote, @remote) != 1
        return 2

    path = path_get(@mgr, 99)
    if path != null
        return 3
    return 0

[[test]]
fn test_path_set_active() -> i32
    var mgr: PathManager
    path_manager_init(@mgr)

    var local: Address
    var remote: Address
    address_init(@local)
    address_set_ipv4(@remote, 10, 0, 0, 1, 443)
    path_add(@mgr, @local, @remote)

    # Must be validated to be active
    let fail: i32 = path_set_active(@mgr, 0)
    if fail != MIGRATION_ERR_INVALID
        return 1

    mgr.paths[0].state = PATH_STATE_VALIDATED
    let ok: i32 = path_set_active(@mgr, 0)
    if ok != MIGRATION_OK
        return 2
    if mgr.active_idx != 0
        return 3
    if mgr.paths[0].is_active != 1
        return 4
    return 0

[[test]]
fn test_path_get_active() -> i32
    var mgr: PathManager
    path_manager_init(@mgr)

    # No active path initially
    var path: *Path = path_get_active(@mgr)
    if path != null
        return 1

    var local: Address
    var remote: Address
    address_init(@local)
    address_set_ipv4(@remote, 10, 0, 0, 1, 443)
    path_add(@mgr, @local, @remote)
    mgr.paths[0].state = PATH_STATE_VALIDATED
    path_set_active(@mgr, 0)

    path = path_get_active(@mgr)
    if path == null
        return 2
    if address_equals(@path.remote, @remote) != 1
        return 3
    return 0

# ============================================================================
# Path Validation Tests
# ============================================================================

[[test]]
fn test_path_start_validation() -> i32
    var mgr: PathManager
    path_manager_init(@mgr)

    var local: Address
    var remote: Address
    address_init(@local)
    address_set_ipv4(@remote, 10, 0, 0, 1, 443)
    path_add(@mgr, @local, @remote)

    var challenge: [8]u8
    challenge[0] = 0xDE
    challenge[1] = 0xAD
    challenge[2] = 0xBE
    challenge[3] = 0xEF
    challenge[4] = 0xCA
    challenge[5] = 0xFE
    challenge[6] = 0xBA
    challenge[7] = 0xBE

    let ret: i32 = path_start_validation(@mgr, 0, @challenge[0], 1000000)
    if ret != MIGRATION_OK
        return 1

    var path: *Path = path_get(@mgr, 0)
    if path == null
        return 2
    if path.state != PATH_STATE_VALIDATING
        return 3
    if path.challenge_pending != 1
        return 4
    if path.challenge_data[0] != 0xDE
        return 5
    if path.challenge_sent_time != 1000000
        return 6
    return 0

[[test]]
fn test_path_on_response_success() -> i32
    var mgr: PathManager
    path_manager_init(@mgr)

    var local: Address
    var remote: Address
    address_init(@local)
    address_set_ipv4(@remote, 10, 0, 0, 1, 443)
    path_add(@mgr, @local, @remote)

    var challenge: [8]u8
    var i: i32 = 0
    while i < 8
        challenge[i] = (i + 1) as u8
        i = i + 1

    path_start_validation(@mgr, 0, @challenge[0], 1000000)

    # Correct response
    let ret: i32 = path_on_response(@mgr, 0, @challenge[0])
    if ret != MIGRATION_OK
        return 1
    if mgr.paths[0].state != PATH_STATE_VALIDATED
        return 2
    if mgr.paths[0].challenge_pending != 0
        return 3
    return 0

[[test]]
fn test_path_on_response_wrong_data() -> i32
    var mgr: PathManager
    path_manager_init(@mgr)

    var local: Address
    var remote: Address
    address_init(@local)
    address_set_ipv4(@remote, 10, 0, 0, 1, 443)
    path_add(@mgr, @local, @remote)

    var challenge: [8]u8
    var response: [8]u8
    var i: i32 = 0
    while i < 8
        challenge[i] = i as u8
        response[i] = (i + 1) as u8  # Wrong!
        i = i + 1

    path_start_validation(@mgr, 0, @challenge[0], 1000000)
    let ret: i32 = path_on_response(@mgr, 0, @response[0])
    if ret != MIGRATION_ERR_INVALID
        return 1
    return 0

[[test]]
fn test_path_on_challenge() -> i32
    var mgr: PathManager
    path_manager_init(@mgr)

    var local: Address
    var remote: Address
    address_init(@local)
    address_set_ipv4(@remote, 10, 0, 0, 1, 443)
    path_add(@mgr, @local, @remote)

    var challenge: [8]u8
    var response: [8]u8
    var i: i32 = 0
    while i < 8
        challenge[i] = (0xAA + i) as u8
        response[i] = 0
        i = i + 1

    let ret: i32 = path_on_challenge(@mgr, 0, @challenge[0], @response[0])
    if ret != MIGRATION_OK
        return 1

    # Response should echo challenge
    i = 0
    while i < 8
        if response[i] != challenge[i]
            return 2
        i = i + 1
    return 0

[[test]]
fn test_path_check_timeout() -> i32
    var mgr: PathManager
    path_manager_init(@mgr)

    var local: Address
    var remote: Address
    address_init(@local)
    address_set_ipv4(@remote, 10, 0, 0, 1, 443)
    path_add(@mgr, @local, @remote)

    var challenge: [8]u8
    path_start_validation(@mgr, 0, @challenge[0], 1000000)

    # Not timed out yet
    if path_check_timeout(@mgr, 0, 1500000, VALIDATION_TIMEOUT_US) != 0
        return 1

    # Timed out
    if path_check_timeout(@mgr, 0, 2500000, VALIDATION_TIMEOUT_US) != 1
        return 2
    return 0

[[test]]
fn test_path_validation_failed() -> i32
    var mgr: PathManager
    path_manager_init(@mgr)

    var local: Address
    var remote: Address
    address_init(@local)
    address_set_ipv4(@remote, 10, 0, 0, 1, 443)
    path_add(@mgr, @local, @remote)

    var challenge: [8]u8
    path_start_validation(@mgr, 0, @challenge[0], 1000000)

    let ret: i32 = path_validation_failed(@mgr, 0)
    if ret != MIGRATION_OK
        return 1
    if mgr.paths[0].state != PATH_STATE_FAILED
        return 2
    if mgr.paths[0].challenge_pending != 0
        return 3
    return 0

# ============================================================================
# Migration Detection Tests
# ============================================================================

[[test]]
fn test_path_detect_migration_same_path() -> i32
    var mgr: PathManager
    path_manager_init(@mgr)

    var local: Address
    var remote: Address
    address_init(@local)
    address_set_ipv4(@remote, 10, 0, 0, 1, 443)
    path_add(@mgr, @local, @remote)
    mgr.paths[0].state = PATH_STATE_VALIDATED
    path_set_active(@mgr, 0)

    # Same address = no migration
    let result: i32 = path_detect_migration(@mgr, @remote)
    if result != 0
        return 1
    return 0

[[test]]
fn test_path_detect_migration_new_path() -> i32
    var mgr: PathManager
    path_manager_init(@mgr)

    var local: Address
    var remote1: Address
    var remote2: Address
    address_init(@local)
    address_set_ipv4(@remote1, 10, 0, 0, 1, 443)
    address_set_ipv4(@remote2, 10, 0, 0, 2, 443)

    path_add(@mgr, @local, @remote1)
    mgr.paths[0].state = PATH_STATE_VALIDATED
    path_set_active(@mgr, 0)

    # Different address = new path created
    let result: i32 = path_detect_migration(@mgr, @remote2)
    if result != 1  # Index of new path
        return 1
    if mgr.count != 2
        return 2
    return 0

[[test]]
fn test_path_detect_migration_existing_inactive() -> i32
    var mgr: PathManager
    path_manager_init(@mgr)

    var local: Address
    var remote1: Address
    var remote2: Address
    address_init(@local)
    address_set_ipv4(@remote1, 10, 0, 0, 1, 443)
    address_set_ipv4(@remote2, 10, 0, 0, 2, 443)

    path_add(@mgr, @local, @remote1)
    path_add(@mgr, @local, @remote2)
    mgr.paths[0].state = PATH_STATE_VALIDATED
    path_set_active(@mgr, 0)

    # remote2 is known but not active
    let result: i32 = path_detect_migration(@mgr, @remote2)
    if result != 1  # Index of existing path
        return 1
    if mgr.count != 2  # No new path created
        return 2
    return 0

[[test]]
fn test_path_count_validated() -> i32
    var mgr: PathManager
    path_manager_init(@mgr)

    var local: Address
    var remote: Address
    address_init(@local)

    var i: i32 = 0
    while i < 3
        address_set_ipv4(@remote, 10, 0, 0, (i + 1) as u8, 443)
        path_add(@mgr, @local, @remote)
        i = i + 1

    mgr.paths[0].state = PATH_STATE_VALIDATED
    mgr.paths[1].state = PATH_STATE_VALIDATING
    mgr.paths[2].state = PATH_STATE_VALIDATED

    if path_count_validated(@mgr) != 2
        return 1
    return 0

[[test]]
fn test_path_count_validating() -> i32
    var mgr: PathManager
    path_manager_init(@mgr)

    var local: Address
    var remote: Address
    address_init(@local)

    var i: i32 = 0
    while i < 3
        address_set_ipv4(@remote, 10, 0, 0, (i + 1) as u8, 443)
        path_add(@mgr, @local, @remote)
        i = i + 1

    mgr.paths[0].state = PATH_STATE_VALIDATING
    mgr.paths[1].state = PATH_STATE_VALIDATED
    mgr.paths[2].state = PATH_STATE_VALIDATING

    if path_count_validating(@mgr) != 2
        return 1
    return 0

