# ============================================================================
# Integer Encoding/Decoding Tests
# ============================================================================

[[test]]
fn test_decode_int_fits_in_prefix() -> i32
    # Value 10 with 5-bit prefix: 0b00001010
    var buf: [1]u8
    buf[0] = 10

    var input: Span<u8> = span_from_ptr<u8>(@buf[0], 1)
    var value: i64 = 0
    let consumed: i32 = hpack_decode_int(@input, 5, @value)

    if consumed != 1
        return 1

    if value != 10
        return 2

    return 0

[[test]]
fn test_decode_int_continuation() -> i32
    # Value 1337 with 5-bit prefix
    # 1337 = 31 + 1306
    # 1306 = 0x51a = 10 * 128 + 26
    # Encoded: 0x1F (31), 0x9A (26 + 128), 0x0A (10)
    var buf: [3]u8
    buf[0] = 0x1F
    buf[1] = 0x9A
    buf[2] = 0x0A

    var input: Span<u8> = span_from_ptr<u8>(@buf[0], 3)
    var value: i64 = 0
    let consumed: i32 = hpack_decode_int(@input, 5, @value)

    if consumed != 3
        return 1

    if value != 1337
        return 2

    return 0

[[test]]
fn test_decode_int_max_prefix() -> i32
    # Value 31 (max for 5-bit) followed by 0
    var buf: [2]u8
    buf[0] = 0x1F
    buf[1] = 0x00

    var input: Span<u8> = span_from_ptr<u8>(@buf[0], 2)
    var value: i64 = 0
    let consumed: i32 = hpack_decode_int(@input, 5, @value)

    if consumed != 2
        return 1

    if value != 31
        return 2

    return 0

[[test]]
fn test_encode_int_fits_in_prefix() -> i32
    var buf: [8]u8
    let written: i32 = hpack_encode_int(@buf[0], 8, 10, 5, 0)

    if written != 1
        return 1

    if buf[0] != 10
        return 2

    return 0

[[test]]
fn test_encode_int_continuation() -> i32
    var buf: [8]u8
    let written: i32 = hpack_encode_int(@buf[0], 8, 1337, 5, 0)

    if written != 3
        return 1

    if buf[0] != 0x1F
        return 2

    if buf[1] != 0x9A
        return 3

    if buf[2] != 0x0A
        return 4

    return 0

[[test]]
fn test_encode_int_with_prefix_bits() -> i32
    # Encode 10 with 5-bit prefix and upper bits set to 0x80 (indexed header)
    var buf: [8]u8
    let written: i32 = hpack_encode_int(@buf[0], 8, 10, 7, 0x80)

    if written != 1
        return 1

    # Should be 0x80 | 10 = 0x8A
    if buf[0] != 0x8A
        return 2

    return 0

[[test]]
fn test_encode_decode_roundtrip() -> i32
    var buf: [8]u8
    let written: i32 = hpack_encode_int(@buf[0], 8, 12345, 5, 0)

    if written <= 0
        return 1

    var input: Span<u8> = span_from_ptr<u8>(@buf[0], written as i64)
    var value: i64 = 0
    let consumed: i32 = hpack_decode_int(@input, 5, @value)

    if consumed != written
        return 2

    if value != 12345
        return 3

    return 0

# ============================================================================
# String Encoding/Decoding Tests
# ============================================================================

[[test]]
fn test_decode_string_short() -> i32
    # Length=5, then "hello"
    var buf: [6]u8
    buf[0] = 5
    buf[1] = 'h'
    buf[2] = 'e'
    buf[3] = 'l'
    buf[4] = 'l'
    buf[5] = 'o'

    var input: Span<u8> = span_from_ptr<u8>(@buf[0], 6)
    var output: Span<u8>
    let consumed: i32 = hpack_decode_string(@input, @output)

    if consumed != 6
        return 1

    var expected: Span<u8> = span_from_cstr(c"hello")
    if span_eq(@output, @expected) != 1
        return 2

    return 0

[[test]]
fn test_encode_string() -> i32
    var buf: [16]u8
    var input: Span<u8> = span_from_cstr(c"hello")
    let written: i32 = hpack_encode_string(@buf[0], 16, @input)

    if written != 6
        return 1

    # First byte is length (no Huffman)
    if buf[0] != 5
        return 2

    # Followed by "hello"
    if buf[1] != 'h'
        return 3

    return 0

[[test]]
fn test_string_roundtrip() -> i32
    var buf: [32]u8
    var original: Span<u8> = span_from_cstr(c"test-value")
    let written: i32 = hpack_encode_string(@buf[0], 32, @original)

    if written <= 0
        return 1

    var input: Span<u8> = span_from_ptr<u8>(@buf[0], written as i64)
    var decoded: Span<u8>
    let consumed: i32 = hpack_decode_string(@input, @decoded)

    if consumed != written
        return 2

    if span_eq(@decoded, @original) != 1
        return 3

    return 0

# ============================================================================
# Dynamic Table Tests
# ============================================================================

[[test]]
fn test_dynamic_table_init() -> i32
    var table: HpackDynamicTable
    hpack_dynamic_table_init(@table, 4096)

    if table.count != 0
        return 1

    if table.size != 0
        return 2

    if table.max_size != 4096
        return 3

    return 0

[[test]]
fn test_dynamic_table_add_get() -> i32
    var table: HpackDynamicTable
    hpack_dynamic_table_init(@table, 4096)

    var name: Span<u8> = span_from_cstr(c"custom-header")
    var value: Span<u8> = span_from_cstr(c"custom-value")
    hpack_dynamic_table_add(@table, @name, @value)

    if table.count != 1
        return 1

    var entry: HpackEntry
    let result: i32 = hpack_dynamic_table_get(@table, 1, @entry)

    if result != HPACK_OK
        return 2

    if span_eq(@entry.name, @name) != 1
        return 3

    if span_eq(@entry.value, @value) != 1
        return 4

    return 0

[[test]]
fn test_dynamic_table_fifo_order() -> i32
    var table: HpackDynamicTable
    hpack_dynamic_table_init(@table, 4096)

    # Add first entry
    var name1: Span<u8> = span_from_cstr(c"header-1")
    var value1: Span<u8> = span_from_cstr(c"value-1")
    hpack_dynamic_table_add(@table, @name1, @value1)

    # Add second entry
    var name2: Span<u8> = span_from_cstr(c"header-2")
    var value2: Span<u8> = span_from_cstr(c"value-2")
    hpack_dynamic_table_add(@table, @name2, @value2)

    if table.count != 2
        return 1

    # Index 1 should be the newest (header-2)
    var entry1: HpackEntry
    hpack_dynamic_table_get(@table, 1, @entry1)
    if span_eq(@entry1.name, @name2) != 1
        return 2

    # Index 2 should be older (header-1)
    var entry2: HpackEntry
    hpack_dynamic_table_get(@table, 2, @entry2)
    if span_eq(@entry2.name, @name1) != 1
        return 3

    return 0

[[test]]
fn test_dynamic_table_size_calculation() -> i32
    var table: HpackDynamicTable
    hpack_dynamic_table_init(@table, 4096)

    # Entry size = name.len + value.len + 32
    # "test" + "value" = 4 + 5 + 32 = 41
    var name: Span<u8> = span_from_cstr(c"test")
    var value: Span<u8> = span_from_cstr(c"value")
    hpack_dynamic_table_add(@table, @name, @value)

    if table.size != 41
        return 1

    return 0

[[test]]
fn test_dynamic_table_eviction() -> i32
    var table: HpackDynamicTable
    # Small max size: only room for ~2 entries
    hpack_dynamic_table_init(@table, 100)

    # Each entry: 10 + 10 + 32 = 52 bytes
    var name1: Span<u8> = span_from_cstr(c"aaaaaaaaaa")  # 10 bytes
    var value1: Span<u8> = span_from_cstr(c"bbbbbbbbbb")  # 10 bytes
    hpack_dynamic_table_add(@table, @name1, @value1)

    if table.count != 1
        return 1

    # Add second entry - still fits
    var name2: Span<u8> = span_from_cstr(c"cccccccccc")
    var value2: Span<u8> = span_from_cstr(c"dddddddddd")
    hpack_dynamic_table_add(@table, @name2, @value2)

    # Should have evicted first entry (size would be 104 > 100)
    if table.count != 1
        return 2

    # Remaining entry should be header-2
    var entry: HpackEntry
    hpack_dynamic_table_get(@table, 1, @entry)
    if span_eq(@entry.name, @name2) != 1
        return 3

    return 0

[[test]]
fn test_dynamic_table_find_name() -> i32
    var table: HpackDynamicTable
    hpack_dynamic_table_init(@table, 4096)

    var name: Span<u8> = span_from_cstr(c"x-custom")
    var value: Span<u8> = span_from_cstr(c"value")
    hpack_dynamic_table_add(@table, @name, @value)

    let index: i32 = hpack_dynamic_table_find_name(@table, @name)
    if index != 1
        return 1

    return 0

[[test]]
fn test_dynamic_table_find_exact() -> i32
    var table: HpackDynamicTable
    hpack_dynamic_table_init(@table, 4096)

    var name: Span<u8> = span_from_cstr(c"x-custom")
    var value1: Span<u8> = span_from_cstr(c"value1")
    var value2: Span<u8> = span_from_cstr(c"value2")

    hpack_dynamic_table_add(@table, @name, @value1)
    hpack_dynamic_table_add(@table, @name, @value2)

    # Find exact match for value1 (older, index 2)
    let index: i32 = hpack_dynamic_table_find(@table, @name, @value1)
    if index != 2
        return 1

    # Find exact match for value2 (newer, index 1)
    let index2: i32 = hpack_dynamic_table_find(@table, @name, @value2)
    if index2 != 1
        return 2

    return 0

[[test]]
fn test_dynamic_table_set_max_size() -> i32
    var table: HpackDynamicTable
    hpack_dynamic_table_init(@table, 4096)

    # Add an entry
    var name: Span<u8> = span_from_cstr(c"test-header")
    var value: Span<u8> = span_from_cstr(c"test-value")
    hpack_dynamic_table_add(@table, @name, @value)

    if table.count != 1
        return 1

    # Reduce max size to 0 - should evict all
    hpack_dynamic_table_set_max_size(@table, 0)

    if table.count != 0
        return 2

    if table.size != 0
        return 3

    return 0

# ============================================================================
# HPACK Decoder Tests
# ============================================================================
#
# Note: HpackDecoder is a very large struct (~74KB) due to inline arrays.
# We use a global instance to avoid LLVM codegen crashes from stack allocation.

var g_decoder: HpackDecoder

[[test]]
fn test_decoder_init() -> i32
    hpack_decoder_init(@g_decoder, 4096)

    if g_decoder.header_count != 0
        return 1

    if g_decoder.table.max_size != 4096
        return 2

    return 0

[[test]]
fn test_decoder_indexed_static() -> i32
    # Decode indexed header field: :method GET (index 2)
    # 0x82 = 1000 0010 (indexed, index 2)
    var buf: [1]u8
    buf[0] = 0x82

    hpack_decoder_init(@g_decoder, 4096)

    var input: Span<u8> = span_from_ptr<u8>(@buf[0], 1)
    let result: i32 = hpack_decode(@g_decoder, @input)

    if result != HPACK_OK
        return 1

    if g_decoder.header_count != 1
        return 2

    var expected_name: Span<u8> = span_from_cstr(c":method")
    var expected_value: Span<u8> = span_from_cstr(c"GET")

    if span_eq(@g_decoder.headers[0].name, @expected_name) != 1
        return 3

    if span_eq(@g_decoder.headers[0].value, @expected_value) != 1
        return 4

    return 0

[[test]]
fn test_decoder_indexed_path() -> i32
    # Decode :path / (index 4)
    # 0x84 = 1000 0100
    var buf: [1]u8
    buf[0] = 0x84

    hpack_decoder_init(@g_decoder, 4096)

    var input: Span<u8> = span_from_ptr<u8>(@buf[0], 1)
    let result: i32 = hpack_decode(@g_decoder, @input)

    if result != HPACK_OK
        return 1

    var expected_name: Span<u8> = span_from_cstr(c":path")
    var expected_value: Span<u8> = span_from_cstr(c"/")

    if span_eq(@g_decoder.headers[0].name, @expected_name) != 1
        return 2

    if span_eq(@g_decoder.headers[0].value, @expected_value) != 1
        return 3

    return 0

[[test]]
fn test_decoder_indexed_status_200() -> i32
    # Decode :status 200 (index 8)
    # 0x88 = 1000 1000
    var buf: [1]u8
    buf[0] = 0x88

    hpack_decoder_init(@g_decoder, 4096)

    var input: Span<u8> = span_from_ptr<u8>(@buf[0], 1)
    let result: i32 = hpack_decode(@g_decoder, @input)

    if result != HPACK_OK
        return 1

    var expected_name: Span<u8> = span_from_cstr(c":status")
    var expected_value: Span<u8> = span_from_cstr(c"200")

    if span_eq(@g_decoder.headers[0].name, @expected_name) != 1
        return 2

    if span_eq(@g_decoder.headers[0].value, @expected_value) != 1
        return 3

    return 0

[[test]]
fn test_decoder_literal_indexed_with_name_ref() -> i32
    # Literal with incremental indexing, name from table
    # 0x44 = 0100 0100 (literal indexed, name index 4 = :path)
    # Then literal value "/api/v1"
    var buf: [10]u8
    buf[0] = 0x44       # Literal indexed, name index 4
    buf[1] = 7          # Value length
    buf[2] = '/'
    buf[3] = 'a'
    buf[4] = 'p'
    buf[5] = 'i'
    buf[6] = '/'
    buf[7] = 'v'
    buf[8] = '1'

    hpack_decoder_init(@g_decoder, 4096)

    var input: Span<u8> = span_from_ptr<u8>(@buf[0], 9)
    let result: i32 = hpack_decode(@g_decoder, @input)

    if result != HPACK_OK
        return 1

    if g_decoder.header_count != 1
        return 2

    var expected_name: Span<u8> = span_from_cstr(c":path")
    var expected_value: Span<u8> = span_from_cstr(c"/api/v1")

    if span_eq(@g_decoder.headers[0].name, @expected_name) != 1
        return 3

    if span_eq(@g_decoder.headers[0].value, @expected_value) != 1
        return 4

    # Should be added to dynamic table
    if g_decoder.table.count != 1
        return 5

    return 0

[[test]]
fn test_decoder_literal_indexed_new_name() -> i32
    # Literal with incremental indexing, new name
    # 0x40 = 0100 0000 (literal indexed, name index 0 = new name)
    # Name: "x-custom" (8 bytes)
    # Value: "test" (4 bytes)
    var buf: [16]u8
    buf[0] = 0x40       # Literal indexed, new name
    buf[1] = 8          # Name length
    buf[2] = 'x'
    buf[3] = '-'
    buf[4] = 'c'
    buf[5] = 'u'
    buf[6] = 's'
    buf[7] = 't'
    buf[8] = 'o'
    buf[9] = 'm'
    buf[10] = 4         # Value length
    buf[11] = 't'
    buf[12] = 'e'
    buf[13] = 's'
    buf[14] = 't'

    hpack_decoder_init(@g_decoder, 4096)

    var input: Span<u8> = span_from_ptr<u8>(@buf[0], 15)
    let result: i32 = hpack_decode(@g_decoder, @input)

    if result != HPACK_OK
        return 1

    if g_decoder.header_count != 1
        return 2

    var expected_name: Span<u8> = span_from_cstr(c"x-custom")
    var expected_value: Span<u8> = span_from_cstr(c"test")

    if span_eq(@g_decoder.headers[0].name, @expected_name) != 1
        return 3

    if span_eq(@g_decoder.headers[0].value, @expected_value) != 1
        return 4

    # Should be added to dynamic table
    if g_decoder.table.count != 1
        return 5

    return 0

[[test]]
fn test_decoder_literal_without_indexing() -> i32
    # Literal without indexing (0000xxxx)
    # 0x04 = 0000 0100 (name index 4 = :path)
    var buf: [10]u8
    buf[0] = 0x04       # Literal no index, name index 4
    buf[1] = 5          # Value length
    buf[2] = '/'
    buf[3] = 't'
    buf[4] = 'e'
    buf[5] = 's'
    buf[6] = 't'

    hpack_decoder_init(@g_decoder, 4096)

    var input: Span<u8> = span_from_ptr<u8>(@buf[0], 7)
    let result: i32 = hpack_decode(@g_decoder, @input)

    if result != HPACK_OK
        return 1

    if g_decoder.header_count != 1
        return 2

    var expected_name: Span<u8> = span_from_cstr(c":path")
    var expected_value: Span<u8> = span_from_cstr(c"/test")

    if span_eq(@g_decoder.headers[0].name, @expected_name) != 1
        return 3

    if span_eq(@g_decoder.headers[0].value, @expected_value) != 1
        return 4

    # Should NOT be added to dynamic table
    if g_decoder.table.count != 0
        return 5

    return 0

[[test]]
fn test_decoder_literal_never_indexed() -> i32
    # Literal never indexed (0001xxxx) - for sensitive data
    # 0x14 = 0001 0100 (name index 4 = :path)
    var buf: [10]u8
    buf[0] = 0x14       # Literal never index, name index 4
    buf[1] = 7          # Value length
    buf[2] = '/'
    buf[3] = 's'
    buf[4] = 'e'
    buf[5] = 'c'
    buf[6] = 'r'
    buf[7] = 'e'
    buf[8] = 't'

    hpack_decoder_init(@g_decoder, 4096)

    var input: Span<u8> = span_from_ptr<u8>(@buf[0], 9)
    let result: i32 = hpack_decode(@g_decoder, @input)

    if result != HPACK_OK
        return 1

    if g_decoder.header_count != 1
        return 2

    var expected_value: Span<u8> = span_from_cstr(c"/secret")

    if span_eq(@g_decoder.headers[0].value, @expected_value) != 1
        return 3

    # Should NOT be added to dynamic table
    if g_decoder.table.count != 0
        return 4

    return 0

[[test]]
fn test_decoder_table_size_update() -> i32
    # Dynamic table size update (001xxxxx)
    # 0x3F 0x00 = size = 31 (max in 5-bit prefix)
    var buf: [2]u8
    buf[0] = 0x3F       # Size update, value = 31 (max prefix)
    buf[1] = 0x00       # Continuation: +0

    hpack_decoder_init(@g_decoder, 4096)

    var input: Span<u8> = span_from_ptr<u8>(@buf[0], 2)
    let result: i32 = hpack_decode(@g_decoder, @input)

    if result != HPACK_OK
        return 1

    # Size update doesn't produce a header
    if g_decoder.header_count != 0
        return 2

    # Table max size should be updated
    if g_decoder.table.max_size != 31
        return 3

    return 0

[[test]]
fn test_decoder_multiple_headers() -> i32
    # Multiple indexed headers: :method GET, :path /, :scheme https
    # 0x82 = :method GET (index 2)
    # 0x84 = :path / (index 4)
    # 0x87 = :scheme https (index 7)
    var buf: [3]u8
    buf[0] = 0x82
    buf[1] = 0x84
    buf[2] = 0x87

    hpack_decoder_init(@g_decoder, 4096)

    var input: Span<u8> = span_from_ptr<u8>(@buf[0], 3)
    let result: i32 = hpack_decode(@g_decoder, @input)

    if result != HPACK_OK
        return 1

    if g_decoder.header_count != 3
        return 2

    var method: Span<u8> = span_from_cstr(c":method")
    var get: Span<u8> = span_from_cstr(c"GET")
    if span_eq(@g_decoder.headers[0].name, @method) != 1 || span_eq(@g_decoder.headers[0].value, @get) != 1
        return 3

    var path: Span<u8> = span_from_cstr(c":path")
    var slash: Span<u8> = span_from_cstr(c"/")
    if span_eq(@g_decoder.headers[1].name, @path) != 1 || span_eq(@g_decoder.headers[1].value, @slash) != 1
        return 4

    var scheme: Span<u8> = span_from_cstr(c":scheme")
    var https: Span<u8> = span_from_cstr(c"https")
    if span_eq(@g_decoder.headers[2].name, @scheme) != 1 || span_eq(@g_decoder.headers[2].value, @https) != 1
        return 5

    return 0

[[test]]
fn test_decoder_dynamic_table_reference() -> i32
    # First: add a header to dynamic table using literal indexed
    # Then: decode it again using indexed reference
    var buf1: [16]u8
    buf1[0] = 0x40      # Literal indexed, new name
    buf1[1] = 4         # Name length "test"
    buf1[2] = 't'
    buf1[3] = 'e'
    buf1[4] = 's'
    buf1[5] = 't'
    buf1[6] = 5         # Value length "value"
    buf1[7] = 'v'
    buf1[8] = 'a'
    buf1[9] = 'l'
    buf1[10] = 'u'
    buf1[11] = 'e'

    hpack_decoder_init(@g_decoder, 4096)

    var input1: Span<u8> = span_from_ptr<u8>(@buf1[0], 12)
    let result1: i32 = hpack_decode(@g_decoder, @input1)

    if result1 != HPACK_OK
        return 1

    if g_decoder.table.count != 1
        return 2

    # Now reference it: index 62 (first dynamic entry)
    # 0xBE = 1011 1110 = indexed, index 62
    var buf2: [1]u8
    buf2[0] = 0xBE

    var input2: Span<u8> = span_from_ptr<u8>(@buf2[0], 1)
    let result2: i32 = hpack_decode(@g_decoder, @input2)

    if result2 != HPACK_OK
        return 3

    if g_decoder.header_count != 1
        return 4

    var expected_name: Span<u8> = span_from_cstr(c"test")
    var expected_value: Span<u8> = span_from_cstr(c"value")

    if span_eq(@g_decoder.headers[0].name, @expected_name) != 1
        return 5

    if span_eq(@g_decoder.headers[0].value, @expected_value) != 1
        return 6

    return 0

# ============================================================================
# HPACK Encoder Tests
# ============================================================================

var g_encoder: HpackEncoder

[[test]]
fn test_encoder_init() -> i32
    hpack_encoder_init(@g_encoder, 4096)

    if g_encoder.table.count != 0
        return 1

    if g_encoder.table.max_size != 4096
        return 2

    return 0

[[test]]
fn test_encode_indexed_static() -> i32
    # Encode :method GET using indexed representation
    # Index 2 in static table -> 0x82
    var buf: [8]u8
    let written: i32 = hpack_encode_indexed(@buf[0], 8, 2)

    if written != 1
        return 1

    if buf[0] != 0x82
        return 2

    return 0

[[test]]
fn test_encode_indexed_status_200() -> i32
    # Encode :status 200 using indexed representation
    # Index 8 in static table -> 0x88
    var buf: [8]u8
    let written: i32 = hpack_encode_indexed(@buf[0], 8, 8)

    if written != 1
        return 1

    if buf[0] != 0x88
        return 2

    return 0

[[test]]
fn test_encode_indexed_large_index() -> i32
    # Encode index 62 (first dynamic entry)
    # 0xBE = 1011 1110 = 0x80 | 62
    var buf: [8]u8
    let written: i32 = hpack_encode_indexed(@buf[0], 8, 62)

    if written != 1
        return 1

    if buf[0] != 0xBE
        return 2

    return 0

[[test]]
fn test_encode_literal_indexed_name_from_table() -> i32
    # Encode a header with name from static table, new value
    # Name: :path (index 4), Value: /api/v1
    hpack_encoder_init(@g_encoder, 4096)

    var buf: [32]u8
    var name: Span<u8> = span_from_cstr(c":path")
    var value: Span<u8> = span_from_cstr(c"/api/v1")

    let written: i32 = hpack_encode_literal_indexed(@g_encoder, @buf[0], 32, @name, @value)

    if written <= 0
        return 1

    # First byte should be 0x44 (0100 0100 = literal indexed, name index 4)
    if buf[0] != 0x44
        return 2

    # Should be added to dynamic table
    if g_encoder.table.count != 1
        return 3

    return 0

[[test]]
fn test_encode_literal_indexed_new_name() -> i32
    # Encode a header with new name and value
    hpack_encoder_init(@g_encoder, 4096)

    var buf: [32]u8
    var name: Span<u8> = span_from_cstr(c"x-custom")
    var value: Span<u8> = span_from_cstr(c"value")

    let written: i32 = hpack_encode_literal_indexed(@g_encoder, @buf[0], 32, @name, @value)

    if written <= 0
        return 1

    # First byte should be 0x40 (literal indexed, new name)
    if buf[0] != 0x40
        return 2

    # Length of name (8)
    if buf[1] != 8
        return 3

    # First char of name
    if buf[2] != 'x'
        return 4

    # Should be added to dynamic table
    if g_encoder.table.count != 1
        return 5

    return 0

[[test]]
fn test_encode_literal_without_indexing() -> i32
    # Encode without indexing using name from table
    var buf: [32]u8
    var name: Span<u8> = span_from_cstr(c":path")
    var value: Span<u8> = span_from_cstr(c"/secret")

    let written: i32 = hpack_encode_literal(@buf[0], 32, 4, @name, @value)

    if written <= 0
        return 1

    # First byte should be 0x04 (literal no index, name index 4)
    if buf[0] != 0x04
        return 2

    return 0

[[test]]
fn test_encode_never_indexed() -> i32
    # Encode never indexed (sensitive data)
    var buf: [32]u8
    var name: Span<u8> = span_from_cstr(c"authorization")
    var value: Span<u8> = span_from_cstr(c"secret")

    # Name index 23 = authorization in static table
    let written: i32 = hpack_encode_never_indexed(@buf[0], 32, 23, @name, @value)

    if written <= 0
        return 1

    # First byte should be 0x17 (0001 0111 = never indexed, name index 23)
    # Wait, 23 > 15 so needs continuation
    # Actually with 4-bit prefix: 0x10 | (value & 0x0F)
    # For 23: 0x10 | 0x0F = 0x1F, then 23-15=8 as continuation
    # Let me check: prefix is 4 bits, max is 15
    # 23 > 15, so first byte = 0x1F (0001 1111), continuation = 8
    if buf[0] != 0x1F
        return 2

    if buf[1] != 8
        return 3

    return 0

[[test]]
fn test_encode_table_size_update() -> i32
    var buf: [8]u8
    let written: i32 = hpack_encode_table_size_update(@buf[0], 8, 1024)

    if written <= 0
        return 1

    # First byte: 001xxxxx pattern
    # 1024 doesn't fit in 5 bits (max 31), needs continuation
    # 0x20 | 0x1F = 0x3F
    if (buf[0] & 0xE0) != 0x20
        return 2

    return 0

[[test]]
fn test_encode_header_uses_static_index() -> i32
    # hpack_encode_header should find :method GET in static table
    hpack_encoder_init(@g_encoder, 4096)

    var buf: [32]u8
    var name: Span<u8> = span_from_cstr(c":method")
    var value: Span<u8> = span_from_cstr(c"GET")

    let written: i32 = hpack_encode_header(@g_encoder, @buf[0], 32, @name, @value)

    if written != 1
        return 1

    # Should use indexed representation: 0x82
    if buf[0] != 0x82
        return 2

    # Should NOT add to dynamic table (already indexed)
    if g_encoder.table.count != 0
        return 3

    return 0

[[test]]
fn test_encode_header_uses_dynamic_index() -> i32
    # First encode a custom header, then re-encode it
    hpack_encoder_init(@g_encoder, 4096)

    var buf: [32]u8
    var name: Span<u8> = span_from_cstr(c"x-test")
    var value: Span<u8> = span_from_cstr(c"abc")

    # First encode - should use literal indexed
    let written1: i32 = hpack_encode_header(@g_encoder, @buf[0], 32, @name, @value)

    if written1 <= 0
        return 1

    if g_encoder.table.count != 1
        return 2

    # Second encode - should find it in dynamic table and use indexed
    let written2: i32 = hpack_encode_header(@g_encoder, @buf[0], 32, @name, @value)

    # Should be just 1 byte (indexed header)
    if written2 != 1
        return 3

    # Index should be 62 (static table size + 1)
    # 0x80 | 62 = 0xBE
    if buf[0] != 0xBE
        return 4

    return 0

# ============================================================================
# Encoder/Decoder Roundtrip Tests
# ============================================================================

[[test]]
fn test_roundtrip_indexed() -> i32
    # Encode then decode :method GET
    hpack_encoder_init(@g_encoder, 4096)
    hpack_decoder_init(@g_decoder, 4096)

    var buf: [32]u8
    var name: Span<u8> = span_from_cstr(c":method")
    var value: Span<u8> = span_from_cstr(c"GET")

    let written: i32 = hpack_encode_header(@g_encoder, @buf[0], 32, @name, @value)

    if written <= 0
        return 1

    var input: Span<u8> = span_from_ptr<u8>(@buf[0], written as i64)
    let result: i32 = hpack_decode(@g_decoder, @input)

    if result != HPACK_OK
        return 2

    if g_decoder.header_count != 1
        return 3

    if span_eq(@g_decoder.headers[0].name, @name) != 1
        return 4

    if span_eq(@g_decoder.headers[0].value, @value) != 1
        return 5

    return 0

[[test]]
fn test_roundtrip_literal() -> i32
    # Encode then decode a custom header
    hpack_encoder_init(@g_encoder, 4096)
    hpack_decoder_init(@g_decoder, 4096)

    var buf: [64]u8
    var name: Span<u8> = span_from_cstr(c"x-custom-header")
    var value: Span<u8> = span_from_cstr(c"custom-value")

    let written: i32 = hpack_encode_header(@g_encoder, @buf[0], 64, @name, @value)

    if written <= 0
        return 1

    var input: Span<u8> = span_from_ptr<u8>(@buf[0], written as i64)
    let result: i32 = hpack_decode(@g_decoder, @input)

    if result != HPACK_OK
        return 2

    if g_decoder.header_count != 1
        return 3

    if span_eq(@g_decoder.headers[0].name, @name) != 1
        return 4

    if span_eq(@g_decoder.headers[0].value, @value) != 1
        return 5

    # Both encoder and decoder should have entry in dynamic table
    if g_encoder.table.count != 1
        return 6

    if g_decoder.table.count != 1
        return 7

    return 0

[[test]]
fn test_roundtrip_multiple_headers() -> i32
    # Encode then decode multiple headers
    hpack_encoder_init(@g_encoder, 4096)
    hpack_decoder_init(@g_decoder, 4096)

    var buf: [128]u8
    var pos: i32 = 0

    # Header 1: :method GET (static)
    var name1: Span<u8> = span_from_cstr(c":method")
    var value1: Span<u8> = span_from_cstr(c"GET")
    let w1: i32 = hpack_encode_header(@g_encoder, @buf[pos], 128 - pos, @name1, @value1)
    if w1 <= 0
        return 1
    pos += w1

    # Header 2: :path / (static)
    var name2: Span<u8> = span_from_cstr(c":path")
    var value2: Span<u8> = span_from_cstr(c"/")
    let w2: i32 = hpack_encode_header(@g_encoder, @buf[pos], 128 - pos, @name2, @value2)
    if w2 <= 0
        return 2
    pos += w2

    # Header 3: custom
    var name3: Span<u8> = span_from_cstr(c"x-test")
    var value3: Span<u8> = span_from_cstr(c"hello")
    let w3: i32 = hpack_encode_header(@g_encoder, @buf[pos], 128 - pos, @name3, @value3)
    if w3 <= 0
        return 3
    pos += w3

    # Decode all
    var input: Span<u8> = span_from_ptr<u8>(@buf[0], pos as i64)
    let result: i32 = hpack_decode(@g_decoder, @input)

    if result != HPACK_OK
        return 4

    if g_decoder.header_count != 3
        return 5

    # Verify headers
    if span_eq(@g_decoder.headers[0].name, @name1) != 1
        return 6
    if span_eq(@g_decoder.headers[0].value, @value1) != 1
        return 7

    if span_eq(@g_decoder.headers[1].name, @name2) != 1
        return 8
    if span_eq(@g_decoder.headers[1].value, @value2) != 1
        return 9

    if span_eq(@g_decoder.headers[2].name, @name3) != 1
        return 10
    if span_eq(@g_decoder.headers[2].value, @value3) != 1
        return 11

    return 0
