# test/test_hpack.ritz - Tests for HPACK header compression
#
# Tests the HPACK static table, dynamic table, and encoding/decoding.

import ritzlib.span
import ritzlib.str
import lib.hpack

# ============================================================================
# Static Table Tests
# ============================================================================

[[test]]
fn test_static_table_authority() -> i32
    var entry: HpackEntry
    let result: i32 = hpack_static_table_get(1, @entry)

    if result != HPACK_OK
        return 1

    var expected_name: Span<u8> = span_from_cstr(c":authority")
    if span_eq(@entry.name, @expected_name) != 1
        return 2

    if entry.value.len != 0
        return 3

    return 0

[[test]]
fn test_static_table_method_get() -> i32
    var entry: HpackEntry
    let result: i32 = hpack_static_table_get(2, @entry)

    if result != HPACK_OK
        return 1

    var expected_name: Span<u8> = span_from_cstr(c":method")
    if span_eq(@entry.name, @expected_name) != 1
        return 2

    var expected_value: Span<u8> = span_from_cstr(c"GET")
    if span_eq(@entry.value, @expected_value) != 1
        return 3

    return 0

