fn test_open_to_half_closed_local() -> i32
    let new_state: i32 = h2_stream_transition(H2_STREAM_OPEN, H2_EVENT_SEND_END_STREAM)

    if new_state != H2_STREAM_HALF_CLOSED_LOCAL
        return 1

