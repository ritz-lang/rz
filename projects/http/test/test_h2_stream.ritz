        return 1

    return 0

# ============================================================================
# State Transition Tests - CLOSED state
# ============================================================================

[[test]]
fn test_closed_no_transitions() -> i32
    # No valid transitions from closed
    let s1: i32 = h2_stream_transition(H2_STREAM_CLOSED, H2_EVENT_SEND_HEADERS)
    let s2: i32 = h2_stream_transition(H2_STREAM_CLOSED, H2_EVENT_RECV_HEADERS)
    let s3: i32 = h2_stream_transition(H2_STREAM_CLOSED, H2_EVENT_SEND_END_STREAM)

    if s1 != -1
        return 1
    if s2 != -1
        return 2
    if s3 != -1
        return 3

    return 0

# ============================================================================
# Apply Event Tests
# ============================================================================

[[test]]
fn test_apply_event_success() -> i32
    var stream: H2Stream
    h2_stream_init(@stream, 1)

    let result: i32 = h2_stream_apply_event(@stream, H2_EVENT_SEND_HEADERS)

    if result != H2_ERROR_NO_ERROR
        return 1

    if stream.state != H2_STREAM_OPEN
        return 2

    return 0

[[test]]
fn test_apply_event_invalid() -> i32
    var stream: H2Stream
    h2_stream_init(@stream, 1)
    stream.state = H2_STREAM_CLOSED

    let result: i32 = h2_stream_apply_event(@stream, H2_EVENT_SEND_HEADERS)

    if result != H2_ERROR_PROTOCOL_ERROR
        return 1

    # State should not change
    if stream.state != H2_STREAM_CLOSED
        return 2

    return 0

[[test]]
fn test_apply_event_sequence() -> i32
    # Test a complete request/response cycle
    var stream: H2Stream
    h2_stream_init(@stream, 1)

    # Send request headers
    let r1: i32 = h2_stream_apply_event(@stream, H2_EVENT_SEND_HEADERS)
    if r1 != H2_ERROR_NO_ERROR || stream.state != H2_STREAM_OPEN
        return 1

    # Send request body with END_STREAM
    let r2: i32 = h2_stream_apply_event(@stream, H2_EVENT_SEND_END_STREAM)
    if r2 != H2_ERROR_NO_ERROR || stream.state != H2_STREAM_HALF_CLOSED_LOCAL
        return 2

    # Receive response with END_STREAM
    let r3: i32 = h2_stream_apply_event(@stream, H2_EVENT_RECV_END_STREAM)
    if r3 != H2_ERROR_NO_ERROR || stream.state != H2_STREAM_CLOSED
        return 3

    return 0

# ============================================================================
# State Query Tests
# ============================================================================

[[test]]
fn test_stream_is_idle() -> i32
    var stream: H2Stream
    h2_stream_init(@stream, 1)

    if h2_stream_is_idle(@stream) != 1
        return 1

    h2_stream_apply_event(@stream, H2_EVENT_SEND_HEADERS)

    if h2_stream_is_idle(@stream) != 0
        return 2

    return 0

[[test]]
fn test_stream_can_send() -> i32
    var stream: H2Stream
    h2_stream_init(@stream, 1)

    # Idle: cannot send
    if h2_stream_can_send(@stream) != 0
        return 1

    # Open: can send
    h2_stream_apply_event(@stream, H2_EVENT_SEND_HEADERS)
    if h2_stream_can_send(@stream) != 1
        return 2

    # Half-closed local: cannot send
    h2_stream_apply_event(@stream, H2_EVENT_SEND_END_STREAM)
    if h2_stream_can_send(@stream) != 0
        return 3

    return 0

[[test]]
fn test_stream_can_recv() -> i32
    var stream: H2Stream
    h2_stream_init(@stream, 1)

    # Idle: cannot receive
    if h2_stream_can_recv(@stream) != 0
        return 1

    # Open: can receive
    h2_stream_apply_event(@stream, H2_EVENT_SEND_HEADERS)
    if h2_stream_can_recv(@stream) != 1
        return 2

    # Half-closed remote: cannot receive
    h2_stream_apply_event(@stream, H2_EVENT_RECV_END_STREAM)
    if h2_stream_can_recv(@stream) != 0
        return 3

    return 0

# ============================================================================
# Flow Control Tests
# ============================================================================

[[test]]
fn test_consume_local_window() -> i32
    var stream: H2Stream
    h2_stream_init(@stream, 1)

    let result: i32 = h2_stream_consume_local_window(@stream, 1000)

    if result != H2_ERROR_NO_ERROR
        return 1

    if stream.local_window != H2_DEFAULT_WINDOW_SIZE - 1000
        return 2

    return 0

[[test]]
fn test_consume_local_window_overflow() -> i32
    var stream: H2Stream
    h2_stream_init(@stream, 1)

    # Try to consume more than available
    let result: i32 = h2_stream_consume_local_window(@stream, H2_DEFAULT_WINDOW_SIZE + 1)

    if result != H2_ERROR_FLOW_CONTROL_ERROR
        return 1

    # Window should not change
    if stream.local_window != H2_DEFAULT_WINDOW_SIZE
        return 2

    return 0

[[test]]
fn test_increase_local_window() -> i32
    var stream: H2Stream
    h2_stream_init(@stream, 1)

    # Consume some
    h2_stream_consume_local_window(@stream, 10000)

    # Then increase
    let result: i32 = h2_stream_increase_local_window(@stream, 5000)

    if result != H2_ERROR_NO_ERROR
        return 1

    if stream.local_window != H2_DEFAULT_WINDOW_SIZE - 10000 + 5000
        return 2

    return 0

[[test]]
fn test_increase_window_overflow() -> i32
    var stream: H2Stream
    h2_stream_init(@stream, 1)
    stream.local_window = 2147483640  # Near max

    let result: i32 = h2_stream_increase_local_window(@stream, 100)

    if result != H2_ERROR_FLOW_CONTROL_ERROR
        return 1

    return 0

# ============================================================================
# Priority Tests
# ============================================================================

[[test]]
fn test_set_priority() -> i32
    var stream: H2Stream
    h2_stream_init(@stream, 1)

    h2_stream_set_priority(@stream, 3, 128, 1)

    if stream.dependency != 3
        return 1

    if stream.weight != 128
        return 2

    if stream.exclusive != 1
        return 3

    return 0

[[test]]
fn test_set_priority_clamp_weight() -> i32
    var stream: H2Stream
    h2_stream_init(@stream, 1)

    # Weight too low
    h2_stream_set_priority(@stream, 0, 0, 0)
    if stream.weight != 1
        return 1

    # Weight too high
    h2_stream_set_priority(@stream, 0, 1000, 0)
    if stream.weight != 256
        return 2

    return 0

# ============================================================================
# Stream Manager Tests
# ============================================================================

var g_mgr: H2StreamManager

[[test]]
fn test_stream_manager_init_server() -> i32
    h2_stream_manager_init(@g_mgr, 1)

    if g_mgr.count != 0
        return 1

    if g_mgr.next_server_id != 2
        return 2

    if g_mgr.next_client_id != 1
        return 3

    return 0

[[test]]
fn test_stream_manager_init_client() -> i32
    h2_stream_manager_init(@g_mgr, 0)

    if g_mgr.next_client_id != 1
        return 1

    if g_mgr.next_server_id != 2
        return 2

    return 0

[[test]]
fn test_stream_manager_create_client_stream() -> i32
    h2_stream_manager_init(@g_mgr, 0)

    let s1: *H2Stream = h2_stream_manager_create_client_stream(@g_mgr)
    if s1 == null
        return 1

    if s1.id != 1
        return 2

    let s2: *H2Stream = h2_stream_manager_create_client_stream(@g_mgr)
    if s2 == null
        return 3

    if s2.id != 3
        return 4

    if g_mgr.count != 2
        return 5

    return 0

[[test]]
fn test_stream_manager_create_server_stream() -> i32
    h2_stream_manager_init(@g_mgr, 1)

    let s1: *H2Stream = h2_stream_manager_create_server_stream(@g_mgr)
    if s1 == null
        return 1

    if s1.id != 2
        return 2

    let s2: *H2Stream = h2_stream_manager_create_server_stream(@g_mgr)
    if s2.id != 4
        return 3

    return 0

[[test]]
fn test_stream_manager_find() -> i32
    h2_stream_manager_init(@g_mgr, 0)

    h2_stream_manager_create_client_stream(@g_mgr)  # id=1
    h2_stream_manager_create_client_stream(@g_mgr)  # id=3
    h2_stream_manager_create_client_stream(@g_mgr)  # id=5

    let found: *H2Stream = h2_stream_manager_find(@g_mgr, 3)
    if found == null
        return 1

    if found.id != 3
        return 2

    let not_found: *H2Stream = h2_stream_manager_find(@g_mgr, 99)
    if not_found != null
        return 3

    return 0

[[test]]
fn test_stream_manager_get_or_create() -> i32
    h2_stream_manager_init(@g_mgr, 1)

    # Create new stream
    let s1: *H2Stream = h2_stream_manager_get_or_create(@g_mgr, 1)
    if s1 == null
        return 1

    if s1.id != 1
        return 2

    # Get existing stream
    let s2: *H2Stream = h2_stream_manager_get_or_create(@g_mgr, 1)
    if s2 == null
        return 3

    if s2 != s1
        return 4

    # Should still be only 1 stream
    if g_mgr.count != 1
        return 5

    return 0

[[test]]
fn test_stream_manager_active_count() -> i32
    h2_stream_manager_init(@g_mgr, 0)

    let s1: *H2Stream = h2_stream_manager_create_client_stream(@g_mgr)
    let s2: *H2Stream = h2_stream_manager_create_client_stream(@g_mgr)
    let s3: *H2Stream = h2_stream_manager_create_client_stream(@g_mgr)

    # All active
    if h2_stream_manager_active_count(@g_mgr) != 3
        return 1

    # Close one
    s2.state = H2_STREAM_CLOSED

    if h2_stream_manager_active_count(@g_mgr) != 2
        return 2

    return 0

[[test]]
fn test_stream_manager_window_update() -> i32
    h2_stream_manager_init(@g_mgr, 0)

    let s1: *H2Stream = h2_stream_manager_create_client_stream(@g_mgr)
    s1.remote_window = 1000

    let result: i32 = h2_stream_manager_window_update(@g_mgr, 1, 5000)

    if result != H2_ERROR_NO_ERROR
        return 1

    if s1.remote_window != 6000
        return 2

    return 0

[[test]]
fn test_stream_manager_window_update_not_found() -> i32
    h2_stream_manager_init(@g_mgr, 0)

    let result: i32 = h2_stream_manager_window_update(@g_mgr, 99, 1000)

    if result != H2_ERROR_PROTOCOL_ERROR
        return 1

    return 0
