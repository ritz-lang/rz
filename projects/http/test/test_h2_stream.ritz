fn test_open_to_half_closed_remote() -> i32
    let new_state: i32 = h2_stream_transition(H2_STREAM_OPEN, H2_EVENT_RECV_END_STREAM)

    if new_state != H2_STREAM_HALF_CLOSED_REMOTE
        return 1

    return 0

