# State Transition Tests - HALF_CLOSED states
# ============================================================================

[[test]]
fn test_half_closed_local_to_closed_recv_end() -> i32
    let new_state: i32 = h2_stream_transition(H2_STREAM_HALF_CLOSED_LOCAL, H2_EVENT_RECV_END_STREAM)

    if new_state != H2_STREAM_CLOSED
        return 1

    return 0

[[test]]
fn test_half_closed_local_to_closed_rst() -> i32
    let new_state: i32 = h2_stream_transition(H2_STREAM_HALF_CLOSED_LOCAL, H2_EVENT_SEND_RST_STREAM)

    if new_state != H2_STREAM_CLOSED
        return 1

    return 0

[[test]]
fn test_half_closed_remote_to_closed_send_end() -> i32
    let new_state: i32 = h2_stream_transition(H2_STREAM_HALF_CLOSED_REMOTE, H2_EVENT_SEND_END_STREAM)

    if new_state != H2_STREAM_CLOSED
        return 1

