# State Transition Tests - RESERVED states
# ============================================================================

[[test]]
fn test_reserved_local_to_half_closed_remote() -> i32
    let new_state: i32 = h2_stream_transition(H2_STREAM_RESERVED_LOCAL, H2_EVENT_SEND_HEADERS)

    if new_state != H2_STREAM_HALF_CLOSED_REMOTE
        return 1

    return 0

[[test]]
fn test_reserved_local_to_closed_send_rst() -> i32
    let new_state: i32 = h2_stream_transition(H2_STREAM_RESERVED_LOCAL, H2_EVENT_SEND_RST_STREAM)

    if new_state != H2_STREAM_CLOSED
        return 1

    return 0

[[test]]
fn test_reserved_remote_to_half_closed_local() -> i32
    let new_state: i32 = h2_stream_transition(H2_STREAM_RESERVED_REMOTE, H2_EVENT_RECV_HEADERS)

    if new_state != H2_STREAM_HALF_CLOSED_LOCAL
        return 1

    return 0

[[test]]
fn test_reserved_remote_to_closed_recv_rst() -> i32
    let new_state: i32 = h2_stream_transition(H2_STREAM_RESERVED_REMOTE, H2_EVENT_RECV_RST_STREAM)

    if new_state != H2_STREAM_CLOSED
        return 1

    return 0

