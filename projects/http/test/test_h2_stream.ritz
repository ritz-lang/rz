# test/test_h2_stream.ritz - Tests for HTTP/2 stream state machine
#
# Tests stream state transitions per RFC 7540 Section 5.1

import ritzlib.span
import lib.h2_stream

# ============================================================================
# Stream Initialization Tests
# ============================================================================

[[test]]
fn test_stream_init() -> i32
    var stream: H2Stream
    h2_stream_init(@stream, 1)

    if stream.id != 1
        return 1

    if stream.state != H2_STREAM_IDLE
        return 2

    if stream.local_window != H2_DEFAULT_WINDOW_SIZE
        return 3

    if stream.remote_window != H2_DEFAULT_WINDOW_SIZE
        return 4

    if stream.weight != H2_DEFAULT_WEIGHT
        return 5

    return 0

[[test]]
fn test_stream_init_even_id() -> i32
    var stream: H2Stream
    h2_stream_init(@stream, 2)

    if stream.id != 2
        return 1

    return 0

# ============================================================================
# State Transition Tests - IDLE state
# ============================================================================

[[test]]
fn test_idle_to_open_send_headers() -> i32
    let new_state: i32 = h2_stream_transition(H2_STREAM_IDLE, H2_EVENT_SEND_HEADERS)

    if new_state != H2_STREAM_OPEN
        return 1

    return 0

[[test]]
fn test_idle_to_open_recv_headers() -> i32
    let new_state: i32 = h2_stream_transition(H2_STREAM_IDLE, H2_EVENT_RECV_HEADERS)

    if new_state != H2_STREAM_OPEN
        return 1

    return 0

[[test]]
fn test_idle_to_reserved_local() -> i32
    let new_state: i32 = h2_stream_transition(H2_STREAM_IDLE, H2_EVENT_SEND_PUSH_PROMISE)

    if new_state != H2_STREAM_RESERVED_LOCAL
        return 1

    return 0

[[test]]
fn test_idle_to_reserved_remote() -> i32
    let new_state: i32 = h2_stream_transition(H2_STREAM_IDLE, H2_EVENT_RECV_PUSH_PROMISE)

    if new_state != H2_STREAM_RESERVED_REMOTE
        return 1

    return 0

[[test]]
fn test_idle_invalid_end_stream() -> i32
    # Cannot send END_STREAM from idle
    let new_state: i32 = h2_stream_transition(H2_STREAM_IDLE, H2_EVENT_SEND_END_STREAM)

    if new_state != -1
        return 1

    return 0

