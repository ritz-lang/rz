[[test]]
fn test_parse_chunk_size_mixed_case() -> i32
    var input: Span<u8> = span_from_cstr(c"1aB\r\n")
    var size: i64 = 0

    let result: i32 = parse_chunk_size(@input, @size)
    if result < 0
        return 1

    if size != 427  # 0x1AB = 427
        return 2

    return 0

[[test]]
fn test_parse_chunk_size_large() -> i32
    var input: Span<u8> = span_from_cstr(c"1000\r\n")
    var size: i64 = 0

    let result: i32 = parse_chunk_size(@input, @size)
    if result < 0
        return 1

    if size != 4096  # 0x1000 = 4096
        return 2

    return 0

# ============================================================================
# Chunk Decoder Tests
# ============================================================================

[[test]]
fn test_decode_single_chunk() -> i32
    var input: Span<u8> = span_from_cstr(c"5\r\nhello\r\n0\r\n\r\n")
    var decoder: ChunkDecoder
    chunk_decoder_init(@decoder)

    var chunk: Span<u8>
    let result: i32 = chunk_decode_next(@decoder, @input, @chunk)

    if result != CHUNK_DATA
        return 1

    var expected: Span<u8> = span_from_cstr(c"hello")
    if span_eq(@chunk, @expected) != 1
        return 2

    # Next call should return END
    let end_result: i32 = chunk_decode_next(@decoder, @input, @chunk)
    if end_result != CHUNK_END
        return 3

    return 0

[[test]]
fn test_decode_multiple_chunks() -> i32
    var input: Span<u8> = span_from_cstr(c"5\r\nhello\r\n6\r\n world\r\n0\r\n\r\n")
    var decoder: ChunkDecoder
    chunk_decoder_init(@decoder)

    var chunk: Span<u8>

    # First chunk
    let r1: i32 = chunk_decode_next(@decoder, @input, @chunk)
    if r1 != CHUNK_DATA
        return 1

    var expected1: Span<u8> = span_from_cstr(c"hello")
    if span_eq(@chunk, @expected1) != 1
        return 2

    # Second chunk
    let r2: i32 = chunk_decode_next(@decoder, @input, @chunk)
    if r2 != CHUNK_DATA
        return 3

    var expected2: Span<u8> = span_from_cstr(c" world")
    if span_eq(@chunk, @expected2) != 1
        return 4

    # End
    let r3: i32 = chunk_decode_next(@decoder, @input, @chunk)
    if r3 != CHUNK_END
        return 5

    return 0

[[test]]
fn test_decode_empty_chunk() -> i32
    var input: Span<u8> = span_from_cstr(c"0\r\n\r\n")
    var decoder: ChunkDecoder
    chunk_decoder_init(@decoder)

    var chunk: Span<u8>
    let result: i32 = chunk_decode_next(@decoder, @input, @chunk)

    if result != CHUNK_END
        return 1

    return 0

# ============================================================================
# Chunk Encoder Tests
# ============================================================================

[[test]]
fn test_encode_chunk_size_5() -> i32
    var buf: [16]u8
    let len: i32 = encode_chunk_size(5, @buf[0], 16)

    if len != 3  # "5\r\n"
        return 1

    if buf[0] != '5'
        return 2
    if buf[1] != '\r'
        return 3
    if buf[2] != '\n'
        return 4

    return 0

[[test]]
fn test_encode_chunk_size_ff() -> i32
    var buf: [16]u8
    let len: i32 = encode_chunk_size(255, @buf[0], 16)

    if len != 4  # "ff\r\n"
        return 1

    if buf[0] != 'f'
        return 2
    if buf[1] != 'f'
        return 3

    return 0

[[test]]
fn test_encode_chunk_size_1000() -> i32
    var buf: [16]u8
    let len: i32 = encode_chunk_size(4096, @buf[0], 16)

    if len != 6  # "1000\r\n"
        return 1

    if buf[0] != '1'
        return 2
    if buf[1] != '0'
        return 3
    if buf[2] != '0'
        return 4
    if buf[3] != '0'
        return 5

    return 0

[[test]]
fn test_encode_last_chunk() -> i32
    var buf: [16]u8
    let len: i32 = encode_last_chunk(@buf[0], 16)

    if len != 5  # "0\r\n\r\n"
        return 1

    if buf[0] != '0'
        return 2
    if buf[1] != '\r'
        return 3
    if buf[2] != '\n'
        return 4
    if buf[3] != '\r'
        return 5
    if buf[4] != '\n'
        return 6

    return 0
