# test/test_chunked.ritz - Tests for chunked transfer encoding
#
# Tests parsing and encoding of HTTP chunked transfer encoding.

import ritzlib.span
import ritzlib.str
import lib.chunked

# ============================================================================
# Chunk Size Parsing Tests
# ============================================================================

[[test]]
fn test_parse_chunk_size_zero() -> i32
    var input: Span<u8> = span_from_cstr(c"0\r\n")
    var size: i64 = 0

    let result: i32 = parse_chunk_size(@input, @size)
    if result < 0
        return 1

    if size != 0
        return 2

    return 0

[[test]]
fn test_parse_chunk_size_decimal() -> i32
    var input: Span<u8> = span_from_cstr(c"5\r\n")
    var size: i64 = 0

    let result: i32 = parse_chunk_size(@input, @size)
    if result < 0
        return 1

    if size != 5
        return 2

    return 0

[[test]]
fn test_parse_chunk_size_hex_lowercase() -> i32
    var input: Span<u8> = span_from_cstr(c"ff\r\n")
    var size: i64 = 0

    let result: i32 = parse_chunk_size(@input, @size)
    if result < 0
        return 1

    if size != 255
        return 2

    return 0

