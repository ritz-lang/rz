# test/test_h1_utils.ritz - Tests for HTTP/1.x utility functions
#
# Tests for find_byte, find_crlf, is_whitespace, to_lower,
# span_eq_cstr_ci, and parse_content_length

import ritzlib.span
import lib.h1_utils

# ============================================================================
# Error Code Tests
# ============================================================================

[[test]]
fn test_error_codes_distinct() -> i32
    if H1_OK == H1_ERR_INCOMPLETE
        return 1
    if H1_OK == H1_ERR_INVALID
        return 2
    if H1_OK == H1_ERR_TOO_MANY_HEADERS
        return 3
    if H1_ERR_INCOMPLETE == H1_ERR_INVALID
        return 4
    return 0

[[test]]
fn test_error_codes_values() -> i32
    if H1_OK != 0
        return 1
    if H1_ERR_INCOMPLETE >= 0
        return 2
    if H1_ERR_INVALID >= 0
        return 3
    if H1_ERR_TOO_MANY_HEADERS >= 0
        return 4
    return 0

# ============================================================================
# find_byte Tests
# ============================================================================

[[test]]
fn test_find_byte_found_at_start() -> i32
    var s: Span<u8> = span_from_cstr(c"hello")
    let idx: i64 = find_byte(&s, 0, 'h')
    if idx != 0
        return 1
    return 0

[[test]]
fn test_find_byte_found_at_end() -> i32
    var s: Span<u8> = span_from_cstr(c"hello")
    let idx: i64 = find_byte(&s, 0, 'o')
    if idx != 4
        return 1
    return 0

[[test]]
fn test_find_byte_found_middle() -> i32
    var s: Span<u8> = span_from_cstr(c"hello")
    let idx: i64 = find_byte(&s, 0, 'l')
    if idx != 2
        return 1
    return 0

[[test]]
fn test_find_byte_not_found() -> i32
    var s: Span<u8> = span_from_cstr(c"hello")
    let idx: i64 = find_byte(&s, 0, 'x')
    if idx != -1
        return 1
    return 0

[[test]]
fn test_find_byte_with_start_offset() -> i32
    var s: Span<u8> = span_from_cstr(c"hello")
    # First 'l' is at index 2, second at 3
    let idx: i64 = find_byte(&s, 3, 'l')
    if idx != 3
        return 1
    return 0

[[test]]
fn test_find_byte_empty_span() -> i32
    var s: Span<u8>
    s.ptr = null
    s.len = 0
    let idx: i64 = find_byte(&s, 0, 'x')
    if idx != -1
        return 1
    return 0

# ============================================================================
# find_crlf Tests
# ============================================================================

[[test]]
fn test_find_crlf_found() -> i32
    var s: Span<u8> = span_from_cstr(c"hello\r\nworld")
    let idx: i64 = find_crlf(&s, 0)
    if idx != 5
        return 1
    return 0

[[test]]
fn test_find_crlf_at_start() -> i32
    var s: Span<u8> = span_from_cstr(c"\r\nhello")
    let idx: i64 = find_crlf(&s, 0)
    if idx != 0
        return 1
    return 0

[[test]]
fn test_find_crlf_not_found() -> i32
    var s: Span<u8> = span_from_cstr(c"hello world")
    let idx: i64 = find_crlf(&s, 0)
    if idx != -1
        return 1
    return 0

[[test]]
fn test_find_crlf_only_cr() -> i32
    var s: Span<u8> = span_from_cstr(c"hello\rworld")
    let idx: i64 = find_crlf(&s, 0)
    if idx != -1
        return 1
    return 0

[[test]]
fn test_find_crlf_only_lf() -> i32
    var s: Span<u8> = span_from_cstr(c"hello\nworld")
    let idx: i64 = find_crlf(&s, 0)
    if idx != -1
        return 1
    return 0

[[test]]
fn test_find_crlf_lf_cr_wrong_order() -> i32
    var s: Span<u8> = span_from_cstr(c"hello\n\rworld")
    let idx: i64 = find_crlf(&s, 0)
    if idx != -1
        return 1
    return 0

[[test]]
fn test_find_crlf_multiple() -> i32
    var s: Span<u8> = span_from_cstr(c"a\r\nb\r\nc")
    let idx1: i64 = find_crlf(&s, 0)
    if idx1 != 1
        return 1
    let idx2: i64 = find_crlf(&s, 3)
    if idx2 != 4
        return 2
    return 0

# ============================================================================
# is_whitespace Tests
# ============================================================================

[[test]]
fn test_is_whitespace_space() -> i32
    if is_whitespace(' ') != 1
        return 1
    return 0

[[test]]
fn test_is_whitespace_tab() -> i32
    if is_whitespace('\t') != 1
        return 1
    return 0

[[test]]
fn test_is_whitespace_not_whitespace() -> i32
    if is_whitespace('a') != 0
        return 1
    if is_whitespace('0') != 0
        return 2
    if is_whitespace('\n') != 0
        return 3
    if is_whitespace('\r') != 0
        return 4
    return 0

# ============================================================================
# to_lower Tests
# ============================================================================

[[test]]
fn test_to_lower_uppercase() -> i32
    if to_lower('A') != 'a'
        return 1
    if to_lower('Z') != 'z'
        return 2
    if to_lower('M') != 'm'
        return 3
    return 0

[[test]]
fn test_to_lower_lowercase() -> i32
    if to_lower('a') != 'a'
        return 1
    if to_lower('z') != 'z'
        return 2
    return 0

[[test]]
fn test_to_lower_non_alpha() -> i32
    if to_lower('0') != '0'
        return 1
    if to_lower('-') != '-'
        return 2
    if to_lower(' ') != ' '
        return 3
    return 0

# ============================================================================
# span_eq_cstr_ci Tests
# ============================================================================

[[test]]
fn test_span_eq_cstr_ci_exact_match() -> i32
    var s: Span<u8> = span_from_cstr(c"hello")
    if span_eq_cstr_ci(&s, c"hello") != 1
        return 1
    return 0

[[test]]
fn test_span_eq_cstr_ci_case_insensitive() -> i32
    var s: Span<u8> = span_from_cstr(c"Hello")
    if span_eq_cstr_ci(&s, c"hello") != 1
        return 1
    if span_eq_cstr_ci(&s, c"HELLO") != 1
        return 2
    if span_eq_cstr_ci(&s, c"HeLLo") != 1
        return 3
    return 0

[[test]]
fn test_span_eq_cstr_ci_not_equal() -> i32
    var s: Span<u8> = span_from_cstr(c"hello")
    if span_eq_cstr_ci(&s, c"world") != 0
        return 1
    return 0

[[test]]
fn test_span_eq_cstr_ci_different_length_shorter() -> i32
    var s: Span<u8> = span_from_cstr(c"hello")
    if span_eq_cstr_ci(&s, c"hell") != 0
        return 1
    return 0

[[test]]
fn test_span_eq_cstr_ci_different_length_longer() -> i32
    var s: Span<u8> = span_from_cstr(c"hello")
    if span_eq_cstr_ci(&s, c"hello!") != 0
        return 1
    return 0

[[test]]
fn test_span_eq_cstr_ci_content_type() -> i32
    # Real-world use case
    var s: Span<u8> = span_from_cstr(c"Content-Type")
    if span_eq_cstr_ci(&s, c"content-type") != 1
        return 1
    if span_eq_cstr_ci(&s, c"CONTENT-TYPE") != 1
        return 2
    return 0

[[test]]
fn test_span_eq_cstr_ci_empty() -> i32
    var s: Span<u8>
    s.ptr = c""
    s.len = 0
    if span_eq_cstr_ci(&s, c"") != 1
        return 1
    if span_eq_cstr_ci(&s, c"x") != 0
        return 2
    return 0

# ============================================================================
# parse_content_length Tests
# ============================================================================

[[test]]
fn test_parse_content_length_zero() -> i32
    var s: Span<u8> = span_from_cstr(c"0")
    let val: i64 = parse_content_length(&s)
    if val != 0
        return 1
    return 0

[[test]]
fn test_parse_content_length_simple() -> i32
    var s: Span<u8> = span_from_cstr(c"42")
    let val: i64 = parse_content_length(&s)
    if val != 42
        return 1
    return 0

[[test]]
fn test_parse_content_length_large() -> i32
    var s: Span<u8> = span_from_cstr(c"123456789")
    let val: i64 = parse_content_length(&s)
    if val != 123456789
        return 1
    return 0

[[test]]
fn test_parse_content_length_leading_zeros() -> i32
    var s: Span<u8> = span_from_cstr(c"007")
    let val: i64 = parse_content_length(&s)
    if val != 7
        return 1
    return 0

[[test]]
fn test_parse_content_length_error_empty() -> i32
    var s: Span<u8>
    s.ptr = c""
    s.len = 0
    let val: i64 = parse_content_length(&s)
    if val != -1
        return 1
    return 0

[[test]]
fn test_parse_content_length_error_non_numeric() -> i32
    var s: Span<u8> = span_from_cstr(c"abc")
    let val: i64 = parse_content_length(&s)
    if val != -1
        return 1
    return 0

[[test]]
fn test_parse_content_length_error_mixed() -> i32
    var s: Span<u8> = span_from_cstr(c"123abc")
    let val: i64 = parse_content_length(&s)
    if val != -1
        return 1
    return 0

[[test]]
fn test_parse_content_length_error_space() -> i32
    var s: Span<u8> = span_from_cstr(c"123 456")
    let val: i64 = parse_content_length(&s)
    if val != -1
        return 1
    return 0

[[test]]
fn test_parse_content_length_error_negative() -> i32
    var s: Span<u8> = span_from_cstr(c"-42")
    let val: i64 = parse_content_length(&s)
    if val != -1
        return 1
    return 0

[[test]]
fn test_parse_content_length_max_safe() -> i32
    # Test a large but safe value: 999999999999 (12 nines)
    var s: Span<u8> = span_from_cstr(c"999999999999")
    let val: i64 = parse_content_length(&s)
    if val != 999999999999
        return 1
    return 0

