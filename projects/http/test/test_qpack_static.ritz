# test/test_qpack_static.ritz - Tests for QPACK static table
#
# RFC 9204 Appendix A defines the QPACK static table

import ritzlib.span
import lib.qpack_static

# ============================================================================
# Static Table Lookup Tests
# ============================================================================

[[test]]
fn test_qpack_static_table_size() -> i32
    if QPACK_STATIC_TABLE_SIZE != 99
        return 1
    return 0

[[test]]
fn test_qpack_static_get_authority() -> i32
    var entry: QpackStaticEntry
    let ret: i32 = qpack_static_get(0, @entry)
    if ret != 0
        return 1
    # :authority has no value
    if entry.value.len != 0
        return 2
    return 0

[[test]]
fn test_qpack_static_get_path_root() -> i32
    var entry: QpackStaticEntry
    let ret: i32 = qpack_static_get(1, @entry)
    if ret != 0
        return 1
    # :path /
    if entry.value.len != 1
        return 2
    if *(entry.value.ptr) != 0x2F  # '/'
        return 3
    return 0

[[test]]
fn test_qpack_static_get_method_get() -> i32
    var entry: QpackStaticEntry
    let ret: i32 = qpack_static_get(17, @entry)
    if ret != 0
        return 1
    # :method GET
    if entry.value.len != 3
        return 2
    return 0

[[test]]
fn test_qpack_static_get_method_post() -> i32
    var entry: QpackStaticEntry
    let ret: i32 = qpack_static_get(20, @entry)
    if ret != 0
        return 1
    # :method POST
    if entry.value.len != 4
        return 2
    return 0

[[test]]
fn test_qpack_static_get_status_200() -> i32
    var entry: QpackStaticEntry
    let ret: i32 = qpack_static_get(25, @entry)
    if ret != 0
        return 1
    # :status 200
    if entry.value.len != 3
        return 2
    return 0

[[test]]
fn test_qpack_static_get_status_404() -> i32
    var entry: QpackStaticEntry
    let ret: i32 = qpack_static_get(27, @entry)
    if ret != 0
        return 1
    # :status 404
    if entry.value.len != 3
        return 2
    return 0

[[test]]
fn test_qpack_static_get_scheme_https() -> i32
    var entry: QpackStaticEntry
    let ret: i32 = qpack_static_get(23, @entry)
    if ret != 0
        return 1
    # :scheme https
    if entry.value.len != 5
        return 2
    return 0

[[test]]
fn test_qpack_static_get_content_type_json() -> i32
    var entry: QpackStaticEntry
    let ret: i32 = qpack_static_get(46, @entry)
    if ret != 0
        return 1
    # content-type application/json
    if entry.value.len != 16
        return 2
    return 0

[[test]]
fn test_qpack_static_get_last_entry() -> i32
    var entry: QpackStaticEntry
    let ret: i32 = qpack_static_get(98, @entry)
    if ret != 0
        return 1
    # x-frame-options sameorigin
    if entry.value.len != 10  # "sameorigin"
        return 2
    return 0

[[test]]
fn test_qpack_static_get_out_of_range() -> i32
    var entry: QpackStaticEntry
    let ret: i32 = qpack_static_get(99, @entry)
    if ret != -1
        return 1
    let ret2: i32 = qpack_static_get(-1, @entry)
    if ret2 != -1
        return 2
    return 0

# ============================================================================
# Static Table Search Tests
# ============================================================================

[[test]]
fn test_qpack_static_find_name_method() -> i32
    var name: Span<u8>
    name.ptr = ":method"
    name.len = 7

    let idx: i32 = qpack_static_find_name(name)
    # First :method entry is at index 15 (CONNECT)
    if idx != 15
        return 1
    return 0

[[test]]
fn test_qpack_static_find_name_status() -> i32
    var name: Span<u8>
    name.ptr = ":status"
    name.len = 7

    let idx: i32 = qpack_static_find_name(name)
    # First :status entry is at index 24 (103)
    if idx != 24
        return 1
    return 0

[[test]]
fn test_qpack_static_find_name_content_type() -> i32
    var name: Span<u8>
    name.ptr = "content-type"
    name.len = 12

    let idx: i32 = qpack_static_find_name(name)
    # First content-type entry is at index 44
    if idx != 44
        return 1
    return 0

[[test]]
fn test_qpack_static_find_name_not_found() -> i32
    var name: Span<u8>
    name.ptr = "x-custom-header"
    name.len = 15

    let idx: i32 = qpack_static_find_name(name)
    if idx != -1
        return 1
    return 0

[[test]]
fn test_qpack_static_find_exact_method_get() -> i32
    var name: Span<u8>
    var value: Span<u8>
    name.ptr = ":method"
    name.len = 7
    value.ptr = "GET"
    value.len = 3

    let idx: i32 = qpack_static_find_exact(name, value)
    if idx != 17
        return 1
    return 0

[[test]]
fn test_qpack_static_find_exact_status_200() -> i32
    var name: Span<u8>
    var value: Span<u8>
    name.ptr = ":status"
    name.len = 7
    value.ptr = "200"
    value.len = 3

    let idx: i32 = qpack_static_find_exact(name, value)
    if idx != 25
        return 1
    return 0

[[test]]
fn test_qpack_static_find_exact_scheme_https() -> i32
    var name: Span<u8>
    var value: Span<u8>
    name.ptr = ":scheme"
    name.len = 7
    value.ptr = "https"
    value.len = 5

    let idx: i32 = qpack_static_find_exact(name, value)
    if idx != 23
        return 1
    return 0

[[test]]
fn test_qpack_static_find_exact_not_found() -> i32
    var name: Span<u8>
    var value: Span<u8>
    name.ptr = ":method"
    name.len = 7
    value.ptr = "PATCH"  # Not in static table
    value.len = 5

    let idx: i32 = qpack_static_find_exact(name, value)
    if idx != -1
        return 1
    return 0

[[test]]
fn test_qpack_static_find_exact_cache_control() -> i32
    var name: Span<u8>
    var value: Span<u8>
    name.ptr = "cache-control"
    name.len = 13
    value.ptr = "no-cache"
    value.len = 8

    let idx: i32 = qpack_static_find_exact(name, value)
    if idx != 39
        return 1
    return 0

[[test]]
fn test_qpack_static_find_exact_accept_encoding() -> i32
    var name: Span<u8>
    var value: Span<u8>
    name.ptr = "accept-encoding"
    name.len = 15
    value.ptr = "gzip, deflate, br"
    value.len = 17

    let idx: i32 = qpack_static_find_exact(name, value)
    if idx != 31
        return 1
    return 0

# ============================================================================
# Entry Name Verification
# ============================================================================

[[test]]
fn test_qpack_static_entry_names_pseudo() -> i32
    var entry: QpackStaticEntry

    # :authority
    qpack_static_get(0, @entry)
    if entry.name.len != 10
        return 1

    # :path
    qpack_static_get(1, @entry)
    if entry.name.len != 5
        return 2

    # :method
    qpack_static_get(17, @entry)
    if entry.name.len != 7
        return 3

    # :scheme
    qpack_static_get(22, @entry)
    if entry.name.len != 7
        return 4

    # :status
    qpack_static_get(25, @entry)
    if entry.name.len != 7
        return 5

    return 0

[[test]]
fn test_qpack_static_cors_headers() -> i32
    var entry: QpackStaticEntry

    # access-control-allow-origin * (index 35)
    qpack_static_get(35, @entry)
    if entry.name.len != 27
        return 1
    if entry.value.len != 1
        return 2

    # access-control-allow-headers * (index 75)
    qpack_static_get(75, @entry)
    if entry.value.len != 1
        return 3

    return 0

[[test]]
fn test_qpack_static_security_headers() -> i32
    var entry: QpackStaticEntry

    # strict-transport-security (index 56-58)
    qpack_static_get(56, @entry)
    if entry.name.len != 25
        return 1

    # x-content-type-options nosniff (index 61)
    qpack_static_get(61, @entry)
    if entry.value.len != 7  # "nosniff"
        return 2

    # x-xss-protection (index 62)
    qpack_static_get(62, @entry)
    if entry.name.len != 16
        return 3

    return 0

