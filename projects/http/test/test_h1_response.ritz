    var resp: H1Response
    h1_response_init(@resp)

    let result: i32 = h1_parse_status_line(@resp, @input)
    if result < 0
        return 1

    if resp.status != 404
        return 2

    var expected_reason: Span<u8> = span_from_cstr(c"Not Found")
    if span_eq(@resp.reason, @expected_reason) != 1
        return 3

    return 0

