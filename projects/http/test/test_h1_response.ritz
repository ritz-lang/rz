[[test]]
fn test_parse_status_line_invalid_empty() -> i32
    var input: Span<u8> = span_from_cstr(c"")
    var resp: H1Response
    h1_response_init(@resp)

    let result: i32 = h1_parse_status_line(@resp, @input)
    if result >= 0
        return 1  # Should fail

    return 0

# ============================================================================
# Full Response Parsing Tests
# ============================================================================

[[test]]
fn test_parse_full_response_no_body() -> i32
    var input: Span<u8> = span_from_cstr(c"HTTP/1.1 204 No Content\r\nServer: test\r\n\r\n")
    var resp: H1Response
    h1_response_init(@resp)

    let result: i32 = h1_parse_response(@resp, @input)
    if result < 0
        return 1

    if resp.status != 204
        return 2

    if resp.header_count != 1
        return 3

    return 0

[[test]]
fn test_parse_full_response_with_body() -> i32
    var input: Span<u8> = span_from_cstr(c"HTTP/1.1 200 OK\r\nContent-Length: 5\r\n\r\nHello")
    var resp: H1Response
    h1_response_init(@resp)

    let result: i32 = h1_parse_response(@resp, @input)
    if result < 0
        return 1

    if resp.status != 200
        return 2

    if resp.content_length != 5
        return 3

    var expected_body: Span<u8> = span_from_cstr(c"Hello")
    if span_eq(@resp.body, @expected_body) != 1
        return 4

    return 0

[[test]]
fn test_parse_response_get_header() -> i32
    var input: Span<u8> = span_from_cstr(c"HTTP/1.1 200 OK\r\nContent-Type: text/html\r\nServer: Valet\r\n\r\n")
    var resp: H1Response
    h1_response_init(@resp)

    let result: i32 = h1_parse_response(@resp, @input)
    if result < 0
        return 1

    var ct: Span<u8> = h1_response_get_header(@resp, c"Content-Type")
    var expected_ct: Span<u8> = span_from_cstr(c"text/html")
    if span_eq(@ct, @expected_ct) != 1
        return 2

    var server: Span<u8> = h1_response_get_header(@resp, c"Server")
    var expected_server: Span<u8> = span_from_cstr(c"Valet")
    if span_eq(@server, @expected_server) != 1
        return 3

    return 0

[[test]]
fn test_parse_response_keep_alive_http11() -> i32
    var input: Span<u8> = span_from_cstr(c"HTTP/1.1 200 OK\r\n\r\n")
    var resp: H1Response
    h1_response_init(@resp)

    let result: i32 = h1_parse_response(@resp, @input)
    if result < 0
        return 1

    # HTTP/1.1 defaults to keep-alive
    if h1_response_is_keep_alive(@resp) != 1
        return 2

    return 0

[[test]]
fn test_parse_response_connection_close() -> i32
    var input: Span<u8> = span_from_cstr(c"HTTP/1.1 200 OK\r\nConnection: close\r\n\r\n")
    var resp: H1Response
    h1_response_init(@resp)

    let result: i32 = h1_parse_response(@resp, @input)
    if result < 0
        return 1

    if h1_response_is_keep_alive(@resp) != 0
        return 2

    return 0

[[test]]
fn test_parse_response_chunked() -> i32
    var input: Span<u8> = span_from_cstr(c"HTTP/1.1 200 OK\r\nTransfer-Encoding: chunked\r\n\r\n")
    var resp: H1Response
    h1_response_init(@resp)

    let result: i32 = h1_parse_response(@resp, @input)
    if result < 0
        return 1

    if resp.is_chunked != 1
        return 2

    return 0
