# test/test_h1_response.ritz - Tests for HTTP/1.x response parsing
#
# Tests status line parsing, header parsing, and body handling.

import ritzlib.span
import ritzlib.str
import lib.types
import lib.h1_response

# ============================================================================
# Status Line Parsing Tests
# ============================================================================

[[test]]
fn test_parse_status_line_200() -> i32
    var input: Span<u8> = span_from_cstr(c"HTTP/1.1 200 OK\r\n")
    var resp: H1Response
    h1_response_init(@resp)

    let result: i32 = h1_parse_status_line(@resp, @input)
    if result < 0
        return 1

    if resp.version != VERSION_HTTP11
        return 2

    if resp.status != 200
        return 3

    var expected_reason: Span<u8> = span_from_cstr(c"OK")
    if span_eq(@resp.reason, @expected_reason) != 1
        return 4

    return 0

[[test]]
fn test_parse_status_line_404() -> i32
