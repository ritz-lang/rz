# ============================================================================
# Response Builder Tests
# ============================================================================

[[test]]
fn test_builder_simple_response() -> i32
    var buf: [256]u8
    var builder: H1ResponseBuilder
    h1_response_builder_init(@builder, @buf[0], 256)

    h1_response_builder_status(@builder, 200)
    h1_response_builder_header(@builder, c"Content-Type", c"text/plain")
    h1_response_builder_body(@builder, c"Hello", 5)

    let len: i32 = builder.pos

    var written: Span<u8> = span_from_ptr<u8>(@buf[0], len as i64)
    var expected: Span<u8> = span_from_cstr(c"HTTP/1.1 200 OK\r\nContent-Type: text/plain\r\nContent-Length: 5\r\n\r\nHello")

    if span_eq(@written, @expected) != 1
        return 1

    return 0

[[test]]
fn test_builder_no_body() -> i32
    var buf: [256]u8
    var builder: H1ResponseBuilder
    h1_response_builder_init(@builder, @buf[0], 256)

    h1_response_builder_status(@builder, 204)
    h1_response_builder_finish(@builder)

    let len: i32 = builder.pos

    var written: Span<u8> = span_from_ptr<u8>(@buf[0], len as i64)
    var expected: Span<u8> = span_from_cstr(c"HTTP/1.1 204 No Content\r\n\r\n")

    if span_eq(@written, @expected) != 1
        return 1

    return 0

[[test]]
fn test_builder_multiple_headers() -> i32
    var buf: [256]u8
    var builder: H1ResponseBuilder
    h1_response_builder_init(@builder, @buf[0], 256)

    h1_response_builder_status(@builder, 200)
    h1_response_builder_header(@builder, c"Server", c"Valet")
    h1_response_builder_header(@builder, c"X-Custom", c"value")
    h1_response_builder_finish(@builder)

    let len: i32 = builder.pos

    # Verify headers are present (order matters)
    var written: Span<u8> = span_from_ptr<u8>(@buf[0], len as i64)
    var server_hdr: Span<u8> = span_from_cstr(c"Server: Valet\r\n")
    var custom_hdr: Span<u8> = span_from_cstr(c"X-Custom: value\r\n")

    if span_contains(@written, @server_hdr) != 1
        return 1

    if span_contains(@written, @custom_hdr) != 1
        return 2

    return 0
