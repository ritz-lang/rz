# test/test_h1_writer.ritz - Tests for HTTP/1.x request/response serialization
#
# Tests building HTTP messages into buffers.

import ritzlib.span
import ritzlib.str
import lib.types
import lib.h1_writer

# ============================================================================
# Response Writing Tests
# ============================================================================

[[test]]
fn test_write_status_line_200() -> i32
    var buf: [64]u8
    let len: i32 = h1_write_status_line(@buf[0], 64, VERSION_HTTP11, 200)

    if len <= 0
        return 1

    var written: Span<u8> = span_from_ptr<u8>(@buf[0], len as i64)
    var expected: Span<u8> = span_from_cstr(c"HTTP/1.1 200 OK\r\n")
    if span_eq(@written, @expected) != 1
        return 2

    return 0

