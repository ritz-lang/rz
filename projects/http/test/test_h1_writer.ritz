[[test]]
fn test_write_header_content_length() -> i32
    var buf: [64]u8
    let len: i32 = h1_write_content_length(@buf[0], 64, 1234)

    if len <= 0
        return 1

    var written: Span<u8> = span_from_ptr<u8>(@buf[0], len as i64)
    var expected: Span<u8> = span_from_cstr(c"Content-Length: 1234\r\n")
    if span_eq(@written, @expected) != 1
        return 2

    return 0

[[test]]
fn test_write_crlf() -> i32
    var buf: [8]u8
    let len: i32 = h1_write_crlf(@buf[0], 8)

    if len != 2
        return 1

    if buf[0] != '\r'
        return 2
    if buf[1] != '\n'
        return 3

    return 0

