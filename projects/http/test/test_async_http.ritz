# test/test_async_http.ritz - Tests for async HTTP helpers
#
# Tests the non-io_uring parts of async_http module
# (actual io_uring operations would require kernel support)

import ritzlib.span
import lib.async_http
import lib.h1_utils

# ============================================================================
# Constants Tests
# ============================================================================

[[test]]
fn test_async_error_codes()
    # Verify error codes are distinct
    assert ASYNC_OK == 0
    assert ASYNC_ERR_RING_FULL != ASYNC_OK
    assert ASYNC_ERR_SUBMIT != ASYNC_OK
    assert ASYNC_ERR_IO != ASYNC_OK
    assert ASYNC_ERR_INCOMPLETE != ASYNC_OK
    assert ASYNC_ERR_PARSE != ASYNC_OK
    assert ASYNC_ERR_CLOSED != ASYNC_OK

[[test]]
fn test_async_buffer_sizes()
    assert DEFAULT_READ_BUF_SIZE == 8192
    assert DEFAULT_WRITE_BUF_SIZE == 8192

[[test]]
fn test_async_op_tags()
    # Verify tags are in high bits and distinct
    assert OP_TAG_READ != OP_TAG_WRITE
    assert OP_TAG_WRITE != OP_TAG_ACCEPT
    assert OP_TAG_ACCEPT != OP_TAG_CONNECT
    assert OP_TAG_CONNECT != OP_TAG_CLOSE

    # Tags should be in high nibble
    assert (OP_TAG_READ & 0xF000000000000000) == OP_TAG_READ
    assert (OP_TAG_WRITE & 0xF000000000000000) == OP_TAG_WRITE

[[test]]
fn test_async_conn_states()
    assert CONN_STATE_IDLE == 0
    assert CONN_STATE_READING != CONN_STATE_IDLE
    assert CONN_STATE_WRITING != CONN_STATE_IDLE
    assert CONN_STATE_CLOSED != CONN_STATE_IDLE

# ============================================================================
# Op Type/FD Extraction Tests
# ============================================================================

[[test]]
fn test_async_op_type_read()
    let user_data: i64 = OP_TAG_READ | 42
    let op: i64 = async_op_type(user_data)
    assert op == OP_TAG_READ

[[test]]
fn test_async_op_type_write()
    let user_data: i64 = OP_TAG_WRITE | 100
    let op: i64 = async_op_type(user_data)
    assert op == OP_TAG_WRITE

[[test]]
fn test_async_op_fd_extraction()
    let user_data: i64 = OP_TAG_READ | 42
    let fd: i32 = async_op_fd(user_data)
    assert fd == 42

[[test]]
fn test_async_op_fd_large()
    let user_data: i64 = OP_TAG_ACCEPT | 0x7FFFFFFF
    let fd: i32 = async_op_fd(user_data)
    assert fd == 0x7FFFFFFF

# ============================================================================
# Connection Initialization Tests
# ============================================================================

[[test]]
fn test_async_conn_init()
    var conn: AsyncHttpConn
    async_http_conn_init(@conn, 5)

    assert conn.fd == 5
    assert conn.read_pos == 0
    assert conn.read_len == 0
    assert conn.write_pos == 0
    assert conn.write_len == 0
    assert conn.state == CONN_STATE_IDLE
    assert conn.user_data == 0

[[test]]
fn test_async_conn_init_negative_fd()
    var conn: AsyncHttpConn
    async_http_conn_init(@conn, -1)

    assert conn.fd == -1
    assert conn.state == CONN_STATE_IDLE

# ============================================================================
# Read Completion Handler Tests
# ============================================================================

[[test]]
fn test_async_handle_read_success()
    var conn: AsyncHttpConn
    async_http_conn_init(@conn, 5)
    conn.state = CONN_STATE_READING
    conn.read_len = 100

    let ret: i32 = async_handle_read(@conn, 50)

    assert ret == ASYNC_OK
    assert conn.read_len == 150  # 100 + 50
    assert conn.state == CONN_STATE_IDLE

[[test]]
fn test_async_handle_read_error()
    var conn: AsyncHttpConn
    async_http_conn_init(@conn, 5)
    conn.state = CONN_STATE_READING

    let ret: i32 = async_handle_read(@conn, -1)

    assert ret == ASYNC_ERR_IO

[[test]]
fn test_async_handle_read_closed()
    var conn: AsyncHttpConn
    async_http_conn_init(@conn, 5)
    conn.state = CONN_STATE_READING

    let ret: i32 = async_handle_read(@conn, 0)

    assert ret == ASYNC_ERR_CLOSED
    assert conn.state == CONN_STATE_CLOSED

# ============================================================================
# Write Completion Handler Tests
# ============================================================================

[[test]]
fn test_async_handle_write_success()
    var conn: AsyncHttpConn
    async_http_conn_init(@conn, 5)
    conn.state = CONN_STATE_WRITING
    conn.write_len = 100
    conn.write_pos = 0

    let ret: i32 = async_handle_write(@conn, 50)

    assert ret == ASYNC_OK
    assert conn.write_pos == 50
    assert conn.state == CONN_STATE_IDLE

[[test]]
fn test_async_handle_write_complete()
    var conn: AsyncHttpConn
    async_http_conn_init(@conn, 5)
    conn.state = CONN_STATE_WRITING
    conn.write_len = 100
    conn.write_pos = 50

    let ret: i32 = async_handle_write(@conn, 50)

    assert ret == ASYNC_OK
    # All data written - should reset
    assert conn.write_pos == 0
    assert conn.write_len == 0
    assert conn.state == CONN_STATE_IDLE

[[test]]
fn test_async_handle_write_error()
    var conn: AsyncHttpConn
    async_http_conn_init(@conn, 5)
    conn.state = CONN_STATE_WRITING

    let ret: i32 = async_handle_write(@conn, -1)

    assert ret == ASYNC_ERR_IO

# ============================================================================
# Request Parsing Tests
# ============================================================================

[[test]]
fn test_async_try_parse_request_complete()
    var conn: AsyncHttpConn
    async_http_conn_init(@conn, 5)

    # Simulate receiving a complete request
    let req: *u8 = c"GET / HTTP/1.1\r\nHost: localhost\r\n\r\n"
    var i: i32 = 0
    while *(req + i) != 0
        conn.read_buf[i] = *(req + i)
        i = i + 1
    conn.read_len = i

    let ret: i32 = async_try_parse_request(@conn)

    assert ret == ASYNC_OK
    assert conn.read_len == 0  # Data consumed

[[test]]
fn test_async_try_parse_request_incomplete()
    var conn: AsyncHttpConn
    async_http_conn_init(@conn, 5)

    # Partial request
    let req: *u8 = c"GET / HTTP/1.1\r\n"
    var i: i32 = 0
    while *(req + i) != 0
        conn.read_buf[i] = *(req + i)
        i = i + 1
    conn.read_len = i

    let ret: i32 = async_try_parse_request(@conn)

    assert ret == ASYNC_ERR_INCOMPLETE

# ============================================================================
# Response Parsing Tests
# ============================================================================

[[test]]
fn test_async_try_parse_response_complete()
    var conn: AsyncHttpConn
    async_http_conn_init(@conn, 5)

    # Simulate receiving a complete response
    let resp: *u8 = c"HTTP/1.1 200 OK\r\nContent-Length: 0\r\n\r\n"
    var i: i32 = 0
    while *(resp + i) != 0
        conn.read_buf[i] = *(resp + i)
        i = i + 1
    conn.read_len = i

    let ret: i32 = async_try_parse_response(@conn)

    assert ret == ASYNC_OK
    assert conn.read_len == 0

[[test]]
fn test_async_try_parse_response_incomplete()
    var conn: AsyncHttpConn
    async_http_conn_init(@conn, 5)

    # Partial response
    let resp: *u8 = c"HTTP/1.1 200 OK\r\n"
    var i: i32 = 0
    while *(resp + i) != 0
        conn.read_buf[i] = *(resp + i)
        i = i + 1
    conn.read_len = i

    let ret: i32 = async_try_parse_response(@conn)

    assert ret == ASYNC_ERR_INCOMPLETE

# ============================================================================
# Response Writing Tests
# ============================================================================

[[test]]
fn test_async_write_response_simple()
    var conn: AsyncHttpConn
    async_http_conn_init(@conn, 5)

    var body: Span<u8>
    body.ptr = c"Hello"
    body.len = 5

    let ret: i32 = async_write_response(@conn, 200, body)

    assert ret == ASYNC_OK
    assert conn.write_len > 0
    assert conn.write_pos == 0

[[test]]
fn test_async_write_response_empty_body()
    var conn: AsyncHttpConn
    async_http_conn_init(@conn, 5)

    var body: Span<u8>
    body.ptr = null
    body.len = 0

    let ret: i32 = async_write_response(@conn, 204, body)

    assert ret == ASYNC_OK
    assert conn.write_len > 0  # Headers still written

