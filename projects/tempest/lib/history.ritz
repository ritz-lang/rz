# lib/history.ritz - Navigation History
#
# Browser history management:
# - Per-tab navigation history (back/forward)
# - Global browsing history (for URL suggestions)
# - Persistent storage

import ritzlib.strview { StrView }
import ritzlib.string { String, string_new, string_from_strview }
import ritzlib.gvec { Vec, vec_new, vec_push, vec_len }

import lib.tab { TabId }

# ============================================================================
# Per-Tab History (Back/Forward)
# ============================================================================

## A single navigation history entry.
pub struct HistoryEntry
    url: String
    title: String
    scroll_x: i32
    scroll_y: i32
    timestamp: i64

## Per-tab navigation history (back/forward stack).
pub struct TabHistory
    entries: Vec<HistoryEntry>
    current_index: i32           # Index of current page, -1 if empty

## Create empty tab history.
pub fn tab_history_new() -> TabHistory
    var history: TabHistory
    history.entries = vec_new<HistoryEntry>()
    history.current_index = -1
    return history

## Push a new URL (clears forward history).
pub fn tab_history_push(history:& TabHistory, url: StrView, title: StrView)
    # Clear forward history (everything after current index)
    # TODO: Implement when vec_truncate is available

    var entry: HistoryEntry
    entry.url = string_from_strview(url)
    entry.title = string_from_strview(title)
    entry.scroll_x = 0
    entry.scroll_y = 0
    entry.timestamp = 0  # TODO: Get current time

    vec_push<HistoryEntry>(@history.entries, entry)
    history.current_index = vec_len<HistoryEntry>(@history.entries) as i32 - 1

## Update scroll position for current entry.
pub fn tab_history_update_scroll(history:& TabHistory, x: i32, y: i32)
    if history.current_index >= 0
        # TODO: Update scroll in current entry
        pass

## Check if back navigation is available.
pub fn tab_history_can_go_back(history: TabHistory) -> i32
    if history.current_index > 0
        return 1
    return 0

## Check if forward navigation is available.
pub fn tab_history_can_go_forward(history: TabHistory) -> i32
    if history.current_index < vec_len<HistoryEntry>(@history.entries) as i32 - 1
        return 1
    return 0

## Go back in history. Returns the new entry.
pub fn tab_history_go_back(history:& TabHistory) -> Option<HistoryEntry>
    if tab_history_can_go_back(@*history) == 0
        return None

    history.current_index = history.current_index - 1
    # TODO: Return entry at current_index
    return None

## Go forward in history. Returns the new entry.
pub fn tab_history_go_forward(history:& TabHistory) -> Option<HistoryEntry>
    if tab_history_can_go_forward(@*history) == 0
        return None

    history.current_index = history.current_index + 1
    # TODO: Return entry at current_index
    return None

# ============================================================================
# Global Browser History
# ============================================================================

## Global history entry (for suggestions, frecency).
pub struct GlobalHistoryEntry
    url: String
    title: String
    visit_count: i32
    last_visit: i64
    frecency: f32               # Frequency + recency score

## Global browsing history.
pub struct History
    entries: Vec<GlobalHistoryEntry>
    # Index for fast URL lookup
    # url_index: HashMap<String, usize>

## Create history manager.
pub fn history_new() -> History
    var history: History
    history.entries = vec_new<GlobalHistoryEntry>()
    return history

## Record a page visit.
pub fn history_visit(history:& History, url: StrView, title: StrView)
    # TODO: Check if URL exists, update visit count
    # TODO: Otherwise add new entry
    var entry: GlobalHistoryEntry
    entry.url = string_from_strview(@url)
    entry.title = string_from_strview(@title)
    entry.visit_count = 1
    entry.last_visit = 0  # TODO: Get current time
    entry.frecency = 1.0

    vec_push<GlobalHistoryEntry>(@history.entries, entry)

## Search history for URL suggestions.
pub fn history_search(history: History, query: StrView, max_results: i32) -> Vec<GlobalHistoryEntry>
    var results = vec_new<GlobalHistoryEntry>()
    # TODO: Search entries by URL/title, rank by frecency
    return results

