import lib.config { Config }

# HTTP method constants (mirror http.types)
const METHOD_GET: i32 = 1
const METHOD_POST: i32 = 2

## Request lifecycle state.
pub enum RequestState
    Pending
    Connecting
    Sending
    Receiving
    Complete
    Error

## An HTTP request.
pub struct Request
    id: u64
    method: i32
    url: String
    headers: Vec<Header>
    body: Vec<u8>
    state: RequestState

## Header name/value pair.
pub struct Header
    name: String
    value: String

## An HTTP response.
pub struct Response
    status: i32
    headers: Vec<Header>
    body: Vec<u8>

## Network manager for handling HTTP requests.
pub struct NetworkManager
    # Connection pool: host -> Vec<Connection>
    connections: HashMap<String, Vec<Connection>>
    # Cookie jar: domain -> Vec<Cookie>
    cookies: HashMap<String, Vec<Cookie>>
    # Pending requests
    pending: Vec<Request>
    # Next request ID
    next_id: u64

# A pooled connection
struct Connection
    socket: Socket
    host: String
    port: i32
    is_tls: i32
    in_use: i32

# A cookie
struct Cookie
    name: String
    value: String
    domain: String
    path: String
    expires: i64
    secure: i32
    http_only: i32

## Create network manager.
pub fn network_manager_new(config: Config) -> NetworkManager
    var nm: NetworkManager
    nm.connections = hashmap_new<String, Vec<Connection>>()
    nm.cookies = hashmap_new<String, Vec<Cookie>>()
    nm.pending = vec_new<Request>()
    nm.next_id = 1
    return nm

# ============================================================================
# Request API
# ============================================================================

## Create a GET request. Returns request ID.
pub fn network_get(nm:& NetworkManager, url: StrView) -> u64
    var req: Request
    req.id = nm.next_id
    nm.next_id += 1
    req.method = METHOD_GET
    req.url = string_from_strview(url)
    req.headers = vec_new<Header>()
    req.body = vec_new<u8>()
    req.state = Pending

    vec_push<Request>(@nm.pending, req)
    return req.id

## Create a POST request. Returns request ID.
pub fn network_post(nm:& NetworkManager, url: StrView, body: Vec<u8>) -> u64
    var req: Request
    req.id = nm.next_id
    nm.next_id += 1
    req.method = METHOD_POST
    req.url = string_from_strview(url)
    req.headers = vec_new<Header>()
    req.body = body
    req.state = Pending

    vec_push<Request>(@nm.pending, req)
    return req.id

