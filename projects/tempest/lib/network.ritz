fn connect_to_host(host: String, port: i32, use_tls: i32) -> Connection
    var conn: Connection
    conn.socket = socket_tcp()
    conn.host = host
    conn.port = port
    conn.is_tls = use_tls
    conn.in_use = 1

    # TODO: Resolve hostname to IP
    # TODO: Connect socket
    # TODO: TLS handshake if use_tls

    return conn

fn release_connection(nm:& NetworkManager, conn:& Connection)
    conn.in_use = 0
    # Return to pool for reuse
