# lib/network.ritz - Network Manager
#
# Handles HTTP requests for the browser using ritz-lang/http library.
# Supports HTTP/1.1, HTTP/2, HTTP/3 with TLS via cryptosec.
#
# Design:
# - Connection pooling per host
# - Cookie jar
# - Resource caching
# - io_uring async I/O

import ritzlib.io { prints, printi }
import ritzlib.strview { StrView }
import ritzlib.string { String, string_from_strview }
import ritzlib.gvec { Vec, vec_new, vec_push }
import ritzlib.hashmap { HashMap, hashmap_new, hashmap_get, hashmap_set }
import ritzlib.net { Socket, socket_tcp, socket_connect, socket_send, socket_recv, socket_close }

