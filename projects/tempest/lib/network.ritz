# ============================================================================
# URL Parsing
# ============================================================================

## Parsed URL components.
pub struct ParsedUrl
    scheme: String      # "http" or "https"
    host: String
    port: i32           # 80 for http, 443 for https if not specified
    path: String        # "/" if not specified
    query: String       # Everything after "?"
    fragment: String    # Everything after "#"

## Parse a URL string into components.
pub fn parse_url(url: StrView) -> ParsedUrl
    var parsed: ParsedUrl
    # TODO: Implement URL parsing
    parsed.scheme = string_from_strview("https")
    parsed.host = string_from_strview("example.com")
    parsed.port = 443
    parsed.path = string_from_strview("/")
    parsed.query = string_from_strview("")
    parsed.fragment = string_from_strview("")
    return parsed

