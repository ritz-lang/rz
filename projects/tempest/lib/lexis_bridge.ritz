# lib/lexis_bridge.ritz - Interface to Lexis HTML/CSS Parser
#
# Lexis parses HTML and CSS, emitting events that Tempest uses
# to construct the DOM tree. Lexis also handles CSS cascade
# to produce ComputedStyle values.
#
# Design: Streaming/incremental parsing. Lexis processes chunks
# of HTML as they arrive from the network.

import ritzlib.strview { StrView }
import ritzlib.gvec { Vec }
import lib.document { NodeId, Tag }
import lib.iris_bridge { ComputedStyle }

# ============================================================================
# Parse Events - Lexis → Tempest
# ============================================================================

## Events emitted by Lexis during HTML parsing.
pub enum ParseEvent
    # Document structure
    DocumentStart
    DocumentEnd

    # Element events
    ElementStart
        tag: Tag
        attributes: Vec<Attribute>

    ElementEnd
        tag: Tag

    # Text content
    Text
        content: StrView

    # Comments (usually ignored)
    Comment
        content: StrView

    # DOCTYPE
    Doctype
        name: StrView
        public_id: StrView
        system_id: StrView

    # Errors
    ParseError
        message: StrView
        line: u32
        column: u32

## HTML attribute name/value pair.
pub struct Attribute
    name: StrView
    value: StrView

# ============================================================================
# CSS Events - Lexis → Tempest
# ============================================================================

## Style computation result for a node.
pub struct StyleResult
    node_id: NodeId
    style: ComputedStyle

# ============================================================================
# Lexis Parser Interface
# ============================================================================

## HTML parser state.
pub struct LexisParser
    # Internal parser state
    state: i32
    # Error callback stream (for debug console)
    error_count: i32

## Create a new HTML parser.
pub fn lexis_parser_new() -> LexisParser
    var parser: LexisParser
    parser.state = 0
    parser.error_count = 0
    return parser

## Feed HTML data to parser (streaming).
## Returns number of events ready to poll.
pub fn lexis_feed(parser:& LexisParser, data: StrView) -> i32
    # TODO: Call into Lexis library
    return 0

## Poll for next parse event.
pub fn lexis_poll_event(parser:& LexisParser) -> Option<ParseEvent>
    # TODO: Get next event from Lexis
    return None

## Check if parsing is complete.
pub fn lexis_is_complete(parser: LexisParser) -> i32
    return 0

## Get parse error count.
pub fn lexis_error_count(parser: LexisParser) -> i32
    return parser.error_count

# ============================================================================
# CSS Stylesheet Interface
# ============================================================================

## Parsed CSS stylesheet.
pub struct Stylesheet
    # Parsed CSS rules
    rule_count: i32

## Parse a CSS stylesheet.
pub fn lexis_parse_css(css: StrView) -> Stylesheet
    var sheet: Stylesheet
    sheet.rule_count = 0
    # TODO: Call into Lexis CSS parser
    return sheet

# ============================================================================
# Style Computation Interface
# ============================================================================

## CSS style computation engine.
pub struct StyleComputer
    # Stylesheets in cascade order
    stylesheets: Vec<Stylesheet>
    # User-agent stylesheet (built-in defaults)
    ua_stylesheet: Stylesheet

## Create style computer.
pub fn style_computer_new() -> StyleComputer
    var computer: StyleComputer
    computer.stylesheets = vec_new<Stylesheet>()
    # TODO: Load UA stylesheet
    return computer

## Add stylesheet to cascade.
pub fn style_add_stylesheet(computer:& StyleComputer, sheet: Stylesheet)
    vec_push<Stylesheet>(@computer.stylesheets, sheet)

## Compute style for a node.
## Takes node info + inherited style, returns computed style.
pub fn style_compute(computer: StyleComputer, tag: Tag, attributes: Vec<Attribute>, inherited: ComputedStyle) -> ComputedStyle
