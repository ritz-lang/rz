# lib/browser.ritz - Browser Process Core
#
# The main browser process that orchestrates everything:
# - Connects to Prism display server
# - Manages browser chrome (tabs bar, URL bar, etc.)
# - Spawns and manages tab processes
# - Handles network requests for all tabs
# - Manages history and bookmarks

import ritzlib.sys { sys_exit }
import ritzlib.io { prints, printi }
import ritzlib.gvec { Vec, vec_new, vec_push, vec_len }
import ritzlib.strview { StrView }
import ritzlib.string { String, string_from_strview }

import lib.config { Config }
import lib.tab { Tab, TabId, tab_new, tab_close }
import lib.network { NetworkManager, network_manager_new }
import lib.history { History, history_new }
import lib.chrome { BrowserChrome, chrome_new, chrome_render }
import lib.ipc { IpcManager, ipc_manager_new }

# TODO: Import from prism when available
