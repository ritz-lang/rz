# ============================================================================
# HTML Parsing
# ============================================================================

fn process_parse_events(renderer:& TabRenderer)
    var done: i32 = 0
    while done == 0
        match lexis_poll_event(@renderer.parser)
            Some(event) => handle_parse_event(renderer, event)
            None => done = 1

fn handle_parse_event(renderer:& TabRenderer, event: ParseEvent)
    match event
        DocumentStart =>
            # Reset document
            renderer.document = document_new()

        DocumentEnd =>
            # Parsing complete
            renderer.is_loading = 0
            let msg = LoadComplete
            ipc_send_to_browser(renderer.channel, msg)

        ElementStart(tag, attributes) =>
            # Create element node
            # TODO: document_create_element, add to tree
            # TODO: Queue StyleEvent.NodeCreated
            pass

        ElementEnd(tag) =>
            # Pop element stack
            pass

        Text(content) =>
            # Create text node
            # TODO: document_create_text, add to tree
            # TODO: Queue StyleEvent.TextChanged
            pass

        ParseError(message, line, column) =>
            # Log to console
            let log_msg = ConsoleLog(2, message)
            ipc_send_to_browser(renderer.channel, log_msg)

        _ =>
            pass

