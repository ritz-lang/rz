# ============================================================================
# Viewport
# ============================================================================

fn set_viewport(renderer:& TabRenderer, width: u32, height: u32)
    iris_set_viewport(@renderer.iris, width, height)

# ============================================================================
# Style Events
# ============================================================================

fn flush_style_events(renderer:& TabRenderer)
    # Send pending style events to Iris
    if vec_len<StyleEvent>(@renderer.pending_events) > 0
        iris_send_events(@renderer.iris, @renderer.pending_events)
        renderer.pending_events = vec_new<StyleEvent>()
