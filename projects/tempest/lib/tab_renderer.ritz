# lib/tab_renderer.ritz - Tab Renderer Process Core
#
# The isolated process that renders a single tab:
# - Owns DOM tree for this tab
# - Runs Lexis for HTML/CSS parsing
# - Runs Sage for JavaScript execution
# - Runs Iris for layout and rendering
# - Communicates with browser process via IPC

import ritzlib.io { prints, printi }
import ritzlib.strview { StrView }
import ritzlib.gvec { Vec, vec_new }

import lib.ipc { IpcChannel, BrowserToTabMsg, TabToBrowserMsg, ipc_recv_from_browser, ipc_send_to_browser }
import lib.document { Document, document_new, NodeId }
import lib.iris_bridge { IrisClient, iris_connect, iris_send_events, StyleEvent }
import lib.lexis_bridge { LexisParser, lexis_parser_new, lexis_feed, lexis_poll_event, ParseEvent }
import lib.sage_bridge { SageContext, sage_context_new, sage_execute }
import lib.history { TabHistory, tab_history_new }

## Tab renderer state (runs in isolated tab process).
pub struct TabRenderer
    # IPC channel to browser process
    channel:& IpcChannel

    # Document state
    document: Document
    current_url: String

    # Per-tab history
    history: TabHistory

    # Component integrations
    iris: IrisClient
    parser: LexisParser
    js_context: SageContext

    # Pending style events to send to Iris
    pending_events: Vec<StyleEvent>

    # State
    running: i32
    is_loading: i32

## Create a new tab renderer.
pub fn tab_renderer_new(channel:& IpcChannel) -> TabRenderer
    var renderer: TabRenderer
    renderer.channel = channel
    renderer.document = document_new()
    renderer.history = tab_history_new()

    # Initialize components
    renderer.iris = iris_connect()
    renderer.parser = lexis_parser_new()
    renderer.js_context = sage_context_new()

    renderer.pending_events = vec_new<StyleEvent>()
    renderer.running = 1
    renderer.is_loading = 0

    return renderer

## Run the tab renderer event loop. Returns exit code.
pub fn tab_renderer_run(renderer:& TabRenderer) -> i32
    prints("Tab renderer starting event loop\n")

    while renderer.running == 1
        # Process IPC messages from browser
        process_browser_messages(renderer)

        # Process parse events from Lexis
        process_parse_events(renderer)

        # Process JS timers
        process_js_timers(renderer)

        # Flush style events to Iris
        flush_style_events(renderer)

        # TODO: Sleep or wait on io_uring events
        # For now, just exit after one iteration
        renderer.running = 0

    prints("Tab renderer shutting down\n")
    return 0

# ============================================================================
# IPC Message Processing
# ============================================================================

fn process_browser_messages(renderer:& TabRenderer)
    var done: i32 = 0
    while done == 0
        match ipc_recv_from_browser(renderer.channel)
            Some(msg) => handle_browser_message(renderer, msg)
            None => done = 1

fn handle_browser_message(renderer:& TabRenderer, msg: BrowserToTabMsg)
    match msg
        Navigate(url) =>
            start_navigation(renderer, @url)

        Stop =>
            stop_loading(renderer)

        GoBack =>
            go_back(renderer)

        GoForward =>
            go_forward(renderer)

        Reload(bypass_cache) =>
            reload(renderer, bypass_cache)

        ExecuteScript(script) =>
            execute_script(renderer, @script)

        SetViewport(width, height) =>
            set_viewport(renderer, width, height)

        MouseMove(x, y) =>
            handle_mouse_move(renderer, x, y)

        MouseButton(x, y, button, pressed) =>
            handle_mouse_button(renderer, x, y, button, pressed)

        KeyDown(key_code, modifiers) =>
            handle_key_down(renderer, key_code, modifiers)

        KeyUp(key_code, modifiers) =>
            handle_key_up(renderer, key_code, modifiers)

        TextInput(text) =>
            handle_text_input(renderer, @text)

        Scroll(delta_x, delta_y) =>
            handle_scroll(renderer, delta_x, delta_y)

        Shutdown =>
            renderer.running = 0

# ============================================================================
# Navigation
# ============================================================================

fn start_navigation(renderer:& TabRenderer, url: String)
    prints("Starting navigation to URL\n")
    renderer.is_loading = 1

    # Notify browser that load started
    let msg = LoadStarted(url)
    ipc_send_to_browser(renderer.channel, msg)

    # TODO: Request page from browser's network manager
    # Browser will send content back via IPC

fn stop_loading(renderer:& TabRenderer)
    renderer.is_loading = 0

