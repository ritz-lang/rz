# ============================================================================
# Tab Bar Operations
# ============================================================================

## Add a tab to the tab bar.
pub fn chrome_add_tab(chrome:& BrowserChrome, id: TabId, title: StrView)
    var info: TabInfo
    info.id = id
    info.title = string_from_strview(title)
    info.favicon = None
    info.is_loading = 1
    info.is_active = 0
    info.width = 200  # Default width
    vec_push<TabInfo>(@chrome.tab_bar.tabs, info)

## Remove a tab from the tab bar.
pub fn chrome_remove_tab(chrome:& BrowserChrome, id: TabId)
    # TODO: Find and remove tab
    pass

