# ============================================================================
# URL Bar Operations
# ============================================================================

## Set the URL bar contents.
pub fn chrome_set_url(chrome:& BrowserChrome, url: StrView)
    chrome.url_bar.url = string_from_strview(url)
    # TODO: Compute display_url (shorten if needed)
    chrome.url_bar.display_url = chrome.url_bar.url

## Set the security indicator state.
pub fn chrome_set_secure(chrome:& BrowserChrome, secure: i32)
    chrome.url_bar.is_secure = secure

## Focus the URL bar for input.
pub fn chrome_focus_url_bar(chrome:& BrowserChrome)
    chrome.url_bar.is_focused = 1
    chrome.url_bar.selection_start = 0
    # TODO: Select all text

## Get the current URL input as a StrView.
pub fn chrome_get_url_input(chrome: BrowserChrome) -> StrView
    return chrome.url_bar.url.as_strview()

# ============================================================================
# Console Operations
# ============================================================================

## Toggle debug console visibility.
pub fn chrome_toggle_console(chrome:& BrowserChrome)
    if chrome.console_visible == 0
        chrome.console_visible = 1
    else
        chrome.console_visible = 0

## Log a message to the debug console.
pub fn chrome_log(chrome:& BrowserChrome, level: i32, message: StrView)
    var entry: ConsoleEntry
    entry.level = level
    entry.message = string_from_strview(message)
    entry.timestamp = 0  # TODO: Get timestamp
    vec_push<ConsoleEntry>(@chrome.console.entries, entry)

    # Trim if too many entries
    # TODO: Remove oldest entries if > max_entries

# ============================================================================
# Geometry
# ============================================================================

## Get the content area rectangle (below chrome, above console).
pub fn chrome_content_rect(chrome: BrowserChrome, window_width: i32, window_height: i32) -> ContentRect
    var rect: ContentRect
    rect.x = 0
    rect.y = chrome.tab_bar_height + chrome.toolbar_height

    if chrome.bookmarks_visible == 1
        rect.y = rect.y + chrome.bookmarks_height

    rect.width = window_width
    rect.height = window_height - rect.y

    if chrome.console_visible == 1
        rect.height = rect.height - chrome.console_height

    return rect
