# lib/chrome.ritz - Browser Chrome (Native Prism Widgets)
#
# Browser UI rendered as native Prism widgets:
# - Tab bar
# - URL/address bar
# - Back/forward/reload buttons
# - Bookmarks bar
# - Debug console (toggleable)
#
# This is NOT HTML - it's direct Prism widget rendering for performance.

import ritzlib.strview { StrView }
import ritzlib.string { String, string_new, string_from_strview }
import ritzlib.gvec { Vec, vec_new, vec_push }

import lib.config { Config }
import lib.tab { TabId }

# TODO: Import from Prism when available
# import prism.widgets { Widget, Button, TextInput, TabBar }
# import prism.draw { DrawContext, Color, Rect }

# ============================================================================
# Chrome State
# ============================================================================

## Browser chrome UI state.
pub struct BrowserChrome
    # Tab bar
    tab_bar: TabBar
    active_tab: TabId

    # Navigation controls
    can_go_back: i32
    can_go_forward: i32
    is_loading: i32

    # URL bar
    url_bar: UrlBar

    # Bookmarks bar
    bookmarks_visible: i32
    bookmarks: Vec<Bookmark>

    # Debug console
    console_visible: i32
    console: DebugConsole

    # Layout dimensions (pixels)
    tab_bar_height: i32
    toolbar_height: i32
    bookmarks_height: i32
    console_height: i32

## Tab bar widget state.
pub struct TabBar
    tabs: Vec<TabInfo>
    hover_tab: i32           # -1 = none
    close_hover: i32         # Tab index where close button is hovered

## Information about a single tab in the tab bar.
pub struct TabInfo
    id: TabId
    title: String
    favicon: FaviconState
    is_loading: i32
    is_active: i32
    width: i32               # Computed width

## Favicon loading state.
pub enum FaviconState
    None
    Loading
    # Loaded { image: Image }  # TODO: Image type from Prism

## URL bar widget state.
pub struct UrlBar
    url: String
    display_url: String      # May be shortened/styled
    is_focused: i32
    is_secure: i32           # HTTPS
    cursor_pos: i32
    selection_start: i32
    selection_end: i32

## Bookmark entry.
pub struct Bookmark
    title: String
    url: String
    # favicon: Option<Image>

## Debug console state.
pub struct DebugConsole
    entries: Vec<ConsoleEntry>
    scroll_offset: i32
    max_entries: i32

## A single console log entry.
pub struct ConsoleEntry
    level: i32               # 0=log, 1=warn, 2=error
    message: String
    timestamp: i64

## Content area rectangle.
pub struct ContentRect
    x: i32
    y: i32
    width: i32
    height: i32

# ============================================================================
# Chrome Creation
# ============================================================================

## Create browser chrome with the given configuration.
pub fn chrome_new(config: Config) -> BrowserChrome
    var chrome: BrowserChrome

    # Tab bar
    chrome.tab_bar.tabs = vec_new<TabInfo>()
    chrome.tab_bar.hover_tab = -1
    chrome.tab_bar.close_hover = -1
    chrome.active_tab = 0

    # Navigation state
    chrome.can_go_back = 0
    chrome.can_go_forward = 0
    chrome.is_loading = 0

    # URL bar
    chrome.url_bar.url = string_new()
    chrome.url_bar.display_url = string_new()
    chrome.url_bar.is_focused = 0
    chrome.url_bar.is_secure = 0
    chrome.url_bar.cursor_pos = 0
    chrome.url_bar.selection_start = 0
    chrome.url_bar.selection_end = 0

    # Bookmarks
    chrome.bookmarks_visible = 1
    chrome.bookmarks = vec_new<Bookmark>()

    # Console
    chrome.console_visible = 0
    chrome.console.entries = vec_new<ConsoleEntry>()
    chrome.console.scroll_offset = 0
    chrome.console.max_entries = 1000

    # Layout
    chrome.tab_bar_height = 36
    chrome.toolbar_height = 40
    chrome.bookmarks_height = 28
    chrome.console_height = 200

    return chrome

