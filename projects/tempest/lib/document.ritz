# ============================================================================
# Serialization (for debugging)
# ============================================================================

## Convert tag to string for debugging.
pub fn tag_to_str(tag: Tag) -> StrView
    match tag
        Html => "html"
        Head => "head"
        Body => "body"
        Div => "div"
        Span => "span"
        P => "p"
        A => "a"
        H1 => "h1"
        H2 => "h2"
        H3 => "h3"
        Ul => "ul"
        Li => "li"
        Img => "img"
        Script => "script"
        Style => "style"
        _ => "unknown"
