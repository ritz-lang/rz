# ============================================================================
# Node Access
# ============================================================================

## Get node by ID. Returns None if not found.
pub fn document_get_node(doc: Document, id: NodeId) -> Option<Node>
    if id as i64 >= vec_len<Node>(@doc.nodes)
        return None
    return Some(*vec_get<Node>(@doc.nodes, id as i64))

## Get element by ID attribute.
pub fn document_get_element_by_id(doc: Document, id: StrView) -> NodeId
    # TODO: Implement when we have string hashmap
    return NODE_ID_NONE

