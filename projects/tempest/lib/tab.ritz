# lib/tab.ritz - Tab Management
#
# Represents a browser tab. The browser process holds metadata about tabs,
# while the actual DOM/rendering happens in isolated tab processes.

import ritzlib.sys { sys_fork, sys_execve, sys_getpid }
import ritzlib.io { prints, printi }
import ritzlib.strview { StrView }
import ritzlib.string { String, string_from_strview }

import lib.ipc { IpcManager, IpcChannel, ipc_create_channel }

## Unique identifier for a tab.
pub type TabId = u32

## Tab state from browser process perspective.
pub enum TabState
    TabLoading     # Page is loading
    TabReady       # Page loaded and rendered
    TabError       # Load error occurred
    TabCrashed     # Tab process crashed

## Tab information held by browser process.
pub struct Tab
    id: TabId
    title: String
    url: String
    state: TabState
    process_pid: i32        # PID of tab renderer process
    channel: IpcChannel     # IPC channel to tab process

## Create a new tab and spawn its renderer process.
pub fn tab_new(id: TabId, url: StrView, ipc:& IpcManager) -> Tab
    var tab: Tab
    tab.id = id
    tab.title = string_from_strview("New Tab")
    tab.url = string_from_strview(url)
    tab.state = TabLoading

    # Create IPC channel for this tab
    tab.channel = ipc_create_channel(ipc, id)

    # Spawn tab renderer process
    tab.process_pid = spawn_tab_process(id, @tab.channel)

    if tab.process_pid < 0
        prints("ERROR: Failed to spawn tab process\n")
        tab.state = TabError
    else
        prints("Spawned tab process with PID: ")
        printi(tab.process_pid as i64)
        prints("\n")

    return tab

# Spawn the tab renderer process
fn spawn_tab_process(tab_id: TabId, channel:& IpcChannel) -> i32
    # TODO: Implement process spawning
    # let pid = sys_fork()
    # if pid == 0
    #     # Child process: exec tempest-tab
    #     sys_execve(c"tempest-tab", args, env)
    # return pid

    # Stub: return fake PID
    return 1000 + tab_id as i32

## Close a tab and terminate its process.
pub fn tab_close(tab:& Tab)
    prints("Closing tab ")
    printi(tab.id as i64)
    prints(" (PID: ")
    printi(tab.process_pid as i64)
    prints(")\n")

    # TODO: Send shutdown command via IPC
    # TODO: Kill process if it doesn't respond

## Send navigation command to tab process.
pub fn tab_navigate(tab:& Tab, url: StrView)
    # TODO: Send via IPC
    prints("Sending navigate command to tab ")
    printi(tab.id as i64)
    prints("\n")

## Update tab title (called when page title changes).
pub fn tab_set_title(tab:& Tab, title: StrView)
    tab.title = string_from_strview(title)

## Get tab title for display.
pub fn tab_get_title(tab: Tab) -> StrView
    return tab.title.as_strview()

## Check if tab is loading.
pub fn tab_is_loading(tab: Tab) -> i32
    match tab.state
        TabLoading => 1
        _ => 0
