# lib/sage_bridge.ritz - Interface to Sage JavaScript Engine
#
# Sage runs JavaScript. Tempest provides DOM bindings so JS can
# manipulate the document. This is the "lean" binding surface.
#
# Design:
# - Minimal binding surface (just what's needed)
# - Handler IDs for event callbacks (not direct function refs)
# - Tempest mediates all DOM access

import ritzlib.strview { StrView }
import ritzlib.gvec { Vec }
import lib.document { NodeId }

# ============================================================================
# JavaScript Context
# ============================================================================

## A JavaScript execution context (one per tab).
pub struct SageContext
    # Internal Sage state
    initialized: i32
    # Error state
    last_error: StrView

## Create a new JS context.
pub fn sage_context_new() -> SageContext
    var ctx: SageContext
    ctx.initialized = 0
    ctx.last_error = ""
    # TODO: Call into Sage to create context
    return ctx

## Destroy JS context.
pub fn sage_context_destroy(ctx:& SageContext)
    # TODO: Call into Sage to cleanup
    ctx.initialized = 0

# ============================================================================
# Script Execution
