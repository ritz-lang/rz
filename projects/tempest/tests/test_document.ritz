# tests/test_document.ritz - DOM tests
#
# TDD tests for the document module.
# Written in RERITZ syntax.

import ritzlib.strview
import lib.document

[[test]]
fn test_document_new() -> i32
    var doc = document_new()
    # Root node should be created at index 0
    if doc.root != 0
        return 1
    # Body and head should be unset
    if doc.body != NODE_ID_NONE
        return 1
    if doc.head != NODE_ID_NONE
        return 1
    0

[[test]]
fn test_create_element() -> i32
    var doc = document_new()
    let div_id = document_create_element(@&doc, Div)
    # Should get a valid node ID (not NONE)
    if div_id == NODE_ID_NONE
        return 1
    # Should be id 1 (after root at 0)
    if div_id != 1
        return 1
    0

[[test]]
fn test_create_multiple_elements() -> i32
    var doc = document_new()
    let div_id = document_create_element(@&doc, Div)
    let span_id = document_create_element(@&doc, Span)
    let p_id = document_create_element(@&doc, P)

    # Should get sequential IDs
    if div_id != 1
        return 1
    if span_id != 2
        return 1
    if p_id != 3
        return 1
    0

[[test]]
fn test_tag_to_str_div() -> i32
    let s = tag_to_str(Div)
    if s != "div"
        return 1
    0

[[test]]
fn test_tag_to_str_html() -> i32
    let s = tag_to_str(Html)
    if s != "html"
        return 1
    0

[[test]]
fn test_tag_to_str_unknown() -> i32
    let s = tag_to_str(Unknown)
    if s != "unknown"
        return 1
    0

[[test]]
fn test_node_id_none_is_max() -> i32
    # NODE_ID_NONE should be 0xFFFFFFFF
    if NODE_ID_NONE != 0xFFFFFFFF
        return 1
    0
