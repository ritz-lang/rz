# src/tab_process.ritz - Tempest Tab Renderer Process
#
# Isolated process for each browser tab. Responsibilities:
# - Own the DOM tree for this tab
# - Run Lexis for HTML/CSS parsing
# - Run Sage for JavaScript execution
# - Run Iris for layout and rendering
# - IPC with browser process for navigation, network requests
#
# Security: Each tab process is sandboxed. JS execution is isolated.
# Communication with browser process via ritzlib.ipc ringbuffers.

import ritzlib.sys { sys_exit, sys_getpid }
import ritzlib.io { prints, printi, printc }

import lib.tab_renderer { TabRenderer, tab_renderer_new, tab_renderer_run }
import lib.ipc { IpcChannel, ipc_connect_to_browser }

pub fn main() -> i32
    let pid: i32 = sys_getpid()
    prints("Tempest Tab Process started (PID: ")
    printi(pid as i64)
    prints(")\n")

    # Connect to browser process via IPC
    var channel: IpcChannel = ipc_connect_to_browser()
    if channel.connected == 0
        prints("ERROR: Failed to connect to browser process\n")
        return 1

    # Create tab renderer
    var renderer: TabRenderer = tab_renderer_new(@channel)

    # Run tab event loop (receives commands from browser, renders pages)
    let exit_code: i32 = tab_renderer_run(@renderer)

    return exit_code
