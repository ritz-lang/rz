# Conversation Tests
# ============================================================================

[[test]]
fn test_mcp_create_conversation() -> i32
    var server: McpServer = mcp_server_new()
    var zero: Uuid = uuid_zero()

    # Create a node first
    var node_id: Uuid = mcp_create_node(@&server, @zero, NODE_SPEC, null, null)

    # Create conversation
    var conv_id: Uuid = mcp_create_conversation(@&server, @node_id)
    assert uuid_eq(@conv_id, @zero) == 0, "conversation should have non-zero ID"
    assert mcp_conversation_count(@&server, @node_id) == 1, "node should have 1 conversation"
    0

[[test]]
fn test_mcp_create_conversation_invalid_node() -> i32
    var server: McpServer = mcp_server_new()
    var fake_id: Uuid = uuid_zero()
    fake_id.high = 99999

    var conv_id: Uuid = mcp_create_conversation(@&server, @fake_id)
    var zero: Uuid = uuid_zero()
    assert uuid_eq(@conv_id, @zero) == 1, "should return zero for invalid node"
    0

[[test]]
fn test_mcp_get_conversation() -> i32
    var server: McpServer = mcp_server_new()
    var zero: Uuid = uuid_zero()

    var node_id: Uuid = mcp_create_node(@&server, @zero, NODE_SPEC, null, null)
    var conv_id: Uuid = mcp_create_conversation(@&server, @node_id)

    var conv: *Conversation = mcp_get_conversation(@&server, @conv_id)
    let conv_ptr: i64 = conv as i64
    assert conv_ptr != 0, "should find conversation"
    assert uuid_eq(@conv.node_id, @node_id) == 1, "conversation should belong to correct node"
    0

[[test]]
fn test_mcp_append_message() -> i32
    var server: McpServer = mcp_server_new()
    var zero: Uuid = uuid_zero()

    var node_id: Uuid = mcp_create_node(@&server, @zero, NODE_SPEC, null, null)
    var conv_id: Uuid = mcp_create_conversation(@&server, @node_id)

    var content: Vec<u8> = vec_new<u8>()
    vec_push<u8>(@&content, 'H')
    vec_push<u8>(@&content, 'i')

    var result: i32 = mcp_append_message(@&server, @conv_id, ROLE_USER, @content)
    assert result == MCP_OK, "append should succeed"
    assert mcp_message_count(@&server, @conv_id) == 1, "conversation should have 1 message"
    0

[[test]]
fn test_mcp_append_message_invalid_conv() -> i32
    var server: McpServer = mcp_server_new()
    var fake_id: Uuid = uuid_zero()
    fake_id.high = 88888

    var content: Vec<u8> = vec_new<u8>()
    var result: i32 = mcp_append_message(@&server, @fake_id, ROLE_USER, @content)
    assert result == MCP_ERR_NOT_FOUND, "append to invalid conv should fail"
    0

[[test]]
fn test_mcp_get_message() -> i32
    var server: McpServer = mcp_server_new()
    var zero: Uuid = uuid_zero()

    var node_id: Uuid = mcp_create_node(@&server, @zero, NODE_PLAN, null, null)
    var conv_id: Uuid = mcp_create_conversation(@&server, @node_id)

    var content: Vec<u8> = vec_new<u8>()
    vec_push<u8>(@&content, 'Q')
    mcp_append_message(@&server, @conv_id, ROLE_USER, @content)

    var msg: *Message = mcp_get_message(@&server, @conv_id, 0)
    let msg_ptr: i64 = msg as i64
    assert msg_ptr != 0, "should find message"
    assert msg.role == ROLE_USER, "message should have correct role"
    0

[[test]]
fn test_mcp_conversation_flow() -> i32
    var server: McpServer = mcp_server_new()
    var zero: Uuid = uuid_zero()

    # Create node and conversation
    var node_id: Uuid = mcp_create_node(@&server, @zero, NODE_SPEC, null, null)
    var conv_id: Uuid = mcp_create_conversation(@&server, @node_id)

    # Simulate a conversation
    var q: Vec<u8> = vec_new<u8>()
    vec_push<u8>(@&q, 'Q')

    var a: Vec<u8> = vec_new<u8>()
    vec_push<u8>(@&a, 'A')

    mcp_append_message(@&server, @conv_id, ROLE_USER, @q)
    mcp_append_message(@&server, @conv_id, ROLE_ASSISTANT, @a)
    mcp_append_message(@&server, @conv_id, ROLE_USER, @q)
    mcp_append_message(@&server, @conv_id, ROLE_ASSISTANT, @a)

    assert mcp_message_count(@&server, @conv_id) == 4, "conversation should have 4 messages"

    # Verify message order
    var m0: *Message = mcp_get_message(@&server, @conv_id, 0)
    var m1: *Message = mcp_get_message(@&server, @conv_id, 1)
    var m2: *Message = mcp_get_message(@&server, @conv_id, 2)
    var m3: *Message = mcp_get_message(@&server, @conv_id, 3)

    assert m0.role == ROLE_USER, "m0 should be USER"
    assert m1.role == ROLE_ASSISTANT, "m1 should be ASSISTANT"
    assert m2.role == ROLE_USER, "m2 should be USER"
    assert m3.role == ROLE_ASSISTANT, "m3 should be ASSISTANT"
    0

[[test]]
fn test_mcp_delete_conversation() -> i32
    var server: McpServer = mcp_server_new()
    var zero: Uuid = uuid_zero()

    var node_id: Uuid = mcp_create_node(@&server, @zero, NODE_SPEC, null, null)
    var conv_id: Uuid = mcp_create_conversation(@&server, @node_id)

    var result: i32 = mcp_delete_conversation(@&server, @conv_id)
    assert result == MCP_OK, "delete should succeed"
    0

[[test]]
fn test_mcp_total_conversation_count() -> i32
    var server: McpServer = mcp_server_new()
    var zero: Uuid = uuid_zero()

    assert mcp_total_conversation_count(@server) == 0, "new server should have 0 conversations"

    var node_id: Uuid = mcp_create_node(@&server, @zero, NODE_SPEC, null, null)
    mcp_create_conversation(@&server, @node_id)
    mcp_create_conversation(@&server, @node_id)

    assert mcp_total_conversation_count(@server) == 2, "server should have 2 conversations"
    0
