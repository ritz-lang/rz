[[test]]
fn test_agent_role_constants() -> i32
    assert AGENT_OWNER == 0, "AGENT_OWNER should be 0"
    assert AGENT_REVIEWER == 1, "AGENT_REVIEWER should be 1"
    assert AGENT_WATCHER == 2, "AGENT_WATCHER should be 2"
