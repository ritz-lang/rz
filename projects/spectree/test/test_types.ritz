# test/test_types.ritz - Tests for core types
#
# Tests for lib/types.ritz:
# - NodeKind constants and names
# - Status constants and names
# - LinkKind constants and names
# - Uuid operations
# - Node creation

import ritzlib.sys
import ritzlib.io
import ritzlib.gvec
import ritzlib.span

import lib.types

# ============================================================================
# NodeKind Tests
# ============================================================================

[[test]]
fn test_node_kind_constants() -> i32
    assert NODE_ORG == 0, "NODE_ORG should be 0"
    assert NODE_SPEC == 1, "NODE_SPEC should be 1"
    assert NODE_PLAN == 2, "NODE_PLAN should be 2"
    0

[[test]]
fn test_node_kind_names() -> i32
    var org: Span<u8> = node_kind_name(NODE_ORG)
    var spec: Span<u8> = node_kind_name(NODE_SPEC)
    var plan: Span<u8> = node_kind_name(NODE_PLAN)
    var unknown: Span<u8> = node_kind_name(99)

    # Check first character as quick validation
    assert span_get<u8>(&org, 0) == 'O', "Org name should start with O"
    assert span_get<u8>(&spec, 0) == 'S', "Spec name should start with S"
    assert span_get<u8>(&plan, 0) == 'P', "Plan name should start with P"
    assert span_get<u8>(&unknown, 0) == 'U', "Unknown name should start with U"
    0

# ============================================================================
# Status Tests
# ============================================================================

[[test]]
fn test_status_constants() -> i32
    assert STATUS_DRAFT == 0, "STATUS_DRAFT should be 0"
    assert STATUS_IN_PROGRESS == 1, "STATUS_IN_PROGRESS should be 1"
    assert STATUS_REVIEW == 2, "STATUS_REVIEW should be 2"
    assert STATUS_COMPLETE == 3, "STATUS_COMPLETE should be 3"
    assert STATUS_ARCHIVED == 4, "STATUS_ARCHIVED should be 4"
    0

[[test]]
fn test_status_names() -> i32
    var draft: Span<u8> = status_name(STATUS_DRAFT)
    var progress: Span<u8> = status_name(STATUS_IN_PROGRESS)
    var review: Span<u8> = status_name(STATUS_REVIEW)
    var complete: Span<u8> = status_name(STATUS_COMPLETE)
    var archived: Span<u8> = status_name(STATUS_ARCHIVED)

    assert span_get<u8>(&draft, 0) == 'D', "Draft should start with D"
    assert span_get<u8>(&progress, 0) == 'I', "InProgress should start with I"
    assert span_get<u8>(&review, 0) == 'R', "Review should start with R"
    assert span_get<u8>(&complete, 0) == 'C', "Complete should start with C"
    assert span_get<u8>(&archived, 0) == 'A', "Archived should start with A"
    0

# ============================================================================
# LinkKind Tests
# ============================================================================

[[test]]
fn test_link_kind_constants() -> i32
    assert LINK_IMPLEMENTS == 0, "LINK_IMPLEMENTS should be 0"
    assert LINK_DEPENDS_ON == 1, "LINK_DEPENDS_ON should be 1"
    assert LINK_RELATED_TO == 2, "LINK_RELATED_TO should be 2"
    0

[[test]]
fn test_link_kind_names() -> i32
    var implements_name: Span<u8> = link_kind_name(LINK_IMPLEMENTS)
    var depends: Span<u8> = link_kind_name(LINK_DEPENDS_ON)
    var related: Span<u8> = link_kind_name(LINK_RELATED_TO)

    assert span_get<u8>(&implements_name, 0) == 'I', "Implements should start with I"
    assert span_get<u8>(&depends, 0) == 'D', "DependsOn should start with D"
    assert span_get<u8>(&related, 0) == 'R', "RelatedTo should start with R"
    0

# ============================================================================
# UUID Tests
# ============================================================================

[[test]]
fn test_uuid_zero() -> i32
    let z: Uuid = uuid_zero()
    assert z.high == 0, "uuid_zero high should be 0"
    assert z.low == 0, "uuid_zero low should be 0"
    0

[[test]]
fn test_uuid_eq_same() -> i32
    var a: Uuid
    a.high = 0x1234567890ABCDEF
    a.low = 0xFEDCBA0987654321

    var b: Uuid
    b.high = 0x1234567890ABCDEF
    b.low = 0xFEDCBA0987654321

    assert uuid_eq(&a, &b) == 1, "identical UUIDs should be equal"
    0

[[test]]
fn test_uuid_eq_different() -> i32
    var a: Uuid
    a.high = 0x1234567890ABCDEF
    a.low = 0xFEDCBA0987654321

    var b: Uuid
    b.high = 0x1234567890ABCDEF
    b.low = 0x0000000000000000  # Different low

    assert uuid_eq(&a, &b) == 0, "different UUIDs should not be equal"
    0

[[test]]
fn test_uuid_eq_zero() -> i32
    var a: Uuid = uuid_zero()
    var b: Uuid = uuid_zero()

    assert uuid_eq(&a, &b) == 1, "two zero UUIDs should be equal"
    0

# ============================================================================
# Node Tests
# ============================================================================

[[test]]
fn test_node_new_org() -> i32
    let n: Node = node_new(NODE_ORG)

    assert n.kind == NODE_ORG, "node kind should be ORG"
    assert n.status == STATUS_DRAFT, "new node should be DRAFT"
    0

[[test]]
fn test_node_new_spec() -> i32
    let n: Node = node_new(NODE_SPEC)

    assert n.kind == NODE_SPEC, "node kind should be SPEC"
    assert n.status == STATUS_DRAFT, "new node should be DRAFT"
    0

[[test]]
fn test_node_new_plan() -> i32
    let n: Node = node_new(NODE_PLAN)

    assert n.kind == NODE_PLAN, "node kind should be PLAN"
    assert n.status == STATUS_DRAFT, "new node should be DRAFT"
    0

[[test]]
fn test_node_is_root() -> i32
    var n: Node = node_new(NODE_ORG)
    # Parent is zero by default
    assert node_is_root(&n) == 1, "node with zero parent should be root"

    # Set a parent
    n.parent_id.high = 1
    assert node_is_root(&n) == 0, "node with parent should not be root"
    0

