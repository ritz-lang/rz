# test/test_conversation.ritz - Tests for conversation storage
#
# Tests for lib/conversation.ritz:
# - Conversation creation
# - Message appending
# - Conversation retrieval
# - Multiple conversations per node

import ritzlib.sys
import ritzlib.io
import ritzlib.gvec

import lib.types
import lib.uuid { uuid_generate }
import lib.conversation

# ============================================================================
# Store Creation Tests
# ============================================================================

[[test]]
fn test_conv_store_new() -> i32
    var store: ConversationStore = conv_store_new()
    assert conv_store_count(@store) == 0, "new store should be empty"
    0

# ============================================================================
# Conversation Creation Tests
# ============================================================================

[[test]]
fn test_conv_create() -> i32
    var store: ConversationStore = conv_store_new()
    var node_id: Uuid = uuid_generate()

    var conv_id: Uuid = conv_create(@&store, @node_id)

    var zero: Uuid = uuid_zero()
    assert uuid_eq(@conv_id, @zero) == 0, "conversation should have non-zero ID"
    assert conv_store_count(@store) == 1, "store should have 1 conversation"
    0

[[test]]
fn test_conv_create_multiple_for_node() -> i32
    var store: ConversationStore = conv_store_new()
    var node_id: Uuid = uuid_generate()

    var conv1_id: Uuid = conv_create(@&store, @node_id)
    var conv2_id: Uuid = conv_create(@&store, @node_id)

    assert conv_store_count(@store) == 2, "store should have 2 conversations"
    assert uuid_eq(@conv1_id, @conv2_id) == 0, "conversations should have different IDs"
    assert conv_count_for_node(@&store, @node_id) == 2, "node should have 2 conversations"
    0

[[test]]
fn test_conv_create_different_nodes() -> i32
    var store: ConversationStore = conv_store_new()
    var node1_id: Uuid = uuid_generate()
    var node2_id: Uuid = uuid_generate()

    conv_create(@&store, @node1_id)
    conv_create(@&store, @node1_id)
    conv_create(@&store, @node2_id)

    assert conv_count_for_node(@&store, @node1_id) == 2, "node1 should have 2 conversations"
    assert conv_count_for_node(@&store, @node2_id) == 1, "node2 should have 1 conversation"
    0

# ============================================================================
# Conversation Retrieval Tests
# ============================================================================

[[test]]
fn test_conv_get() -> i32
    var store: ConversationStore = conv_store_new()
    var node_id: Uuid = uuid_generate()

    var conv_id: Uuid = conv_create(@&store, @node_id)
    var conv: *Conversation = conv_get(@&store, @conv_id)

    let conv_ptr: i64 = conv as i64
    assert conv_ptr != 0, "should find conversation"
    assert uuid_eq(@conv.uuid, @conv_id) == 1, "conversation should have correct ID"
    assert uuid_eq(@conv.node_id, @node_id) == 1, "conversation should belong to correct node"
    0

[[test]]
fn test_conv_get_nonexistent() -> i32
    var store: ConversationStore = conv_store_new()
    var fake_id: Uuid = uuid_generate()

    var conv: *Conversation = conv_get(@&store, @fake_id)
    let conv_ptr: i64 = conv as i64
    assert conv_ptr == 0, "should not find nonexistent conversation"
    0

[[test]]
fn test_conv_get_for_node() -> i32
    var store: ConversationStore = conv_store_new()
    var node_id: Uuid = uuid_generate()

    var conv1_id: Uuid = conv_create(@&store, @node_id)
    var conv2_id: Uuid = conv_create(@&store, @node_id)

    var conv0: *Conversation = conv_get_for_node(@&store, @node_id, 0)
    var conv1: *Conversation = conv_get_for_node(@&store, @node_id, 1)
    var conv2: *Conversation = conv_get_for_node(@&store, @node_id, 2)

    let conv0_ptr: i64 = conv0 as i64
    let conv1_ptr: i64 = conv1 as i64
    let conv2_ptr: i64 = conv2 as i64

    assert conv0_ptr != 0, "should find first conversation"
    assert conv1_ptr != 0, "should find second conversation"
    assert conv2_ptr == 0, "should not find third conversation"
    0

# ============================================================================
# Message Tests
# ============================================================================

[[test]]
fn test_conv_append_message() -> i32
    var store: ConversationStore = conv_store_new()
    var node_id: Uuid = uuid_generate()
    var conv_id: Uuid = conv_create(@&store, @node_id)

    var content: Vec<u8> = vec_new<u8>()
    vec_push<u8>(@&content, 'H')
    vec_push<u8>(@&content, 'i')

    let result: i32 = conv_append_message(@&store, @conv_id, ROLE_USER, @content)
    assert result == 0, "append should succeed"

    assert conv_message_count(@&store, @conv_id) == 1, "conversation should have 1 message"
    0

[[test]]
fn test_conv_append_multiple_messages() -> i32
    var store: ConversationStore = conv_store_new()
    var node_id: Uuid = uuid_generate()
    var conv_id: Uuid = conv_create(@&store, @node_id)

    var msg1: Vec<u8> = vec_new<u8>()
    vec_push<u8>(@&msg1, 'Q')

    var msg2: Vec<u8> = vec_new<u8>()
    vec_push<u8>(@&msg2, 'A')

    conv_append_message(@&store, @conv_id, ROLE_USER, @msg1)
    conv_append_message(@&store, @conv_id, ROLE_ASSISTANT, @msg2)

    assert conv_message_count(@&store, @conv_id) == 2, "conversation should have 2 messages"
    0

[[test]]
fn test_conv_append_to_nonexistent() -> i32
    var store: ConversationStore = conv_store_new()
    var fake_id: Uuid = uuid_generate()

    var content: Vec<u8> = vec_new<u8>()
    let result: i32 = conv_append_message(@&store, @fake_id, ROLE_USER, @content)

    assert result == -1, "appending to nonexistent should fail"
    0

[[test]]
fn test_conv_get_message() -> i32
    var store: ConversationStore = conv_store_new()
    var node_id: Uuid = uuid_generate()
    var conv_id: Uuid = conv_create(@&store, @node_id)

    var content: Vec<u8> = vec_new<u8>()
    vec_push<u8>(@&content, 'X')
    vec_push<u8>(@&content, 'Y')

    conv_append_message(@&store, @conv_id, ROLE_USER, @content)

    var msg: *Message = conv_get_message(@&store, @conv_id, 0)
    let msg_ptr: i64 = msg as i64
    assert msg_ptr != 0, "should find message"
    assert msg.role == ROLE_USER, "message should have correct role"
    assert vec_len<u8>(@msg.content) == 2, "message should have correct content length"
    0

[[test]]
fn test_conv_get_message_out_of_bounds() -> i32
    var store: ConversationStore = conv_store_new()
    var node_id: Uuid = uuid_generate()
    var conv_id: Uuid = conv_create(@&store, @node_id)

    var msg: *Message = conv_get_message(@&store, @conv_id, 0)
    let msg_ptr: i64 = msg as i64
    assert msg_ptr == 0, "should not find message at invalid index"
    0

[[test]]
fn test_conv_message_roles() -> i32
    var store: ConversationStore = conv_store_new()
    var node_id: Uuid = uuid_generate()
    var conv_id: Uuid = conv_create(@&store, @node_id)

    var c1: Vec<u8> = vec_new<u8>()
    var c2: Vec<u8> = vec_new<u8>()
    var c3: Vec<u8> = vec_new<u8>()

    conv_append_message(@&store, @conv_id, ROLE_USER, @c1)
    conv_append_message(@&store, @conv_id, ROLE_ASSISTANT, @c2)
    conv_append_message(@&store, @conv_id, ROLE_SYSTEM, @c3)

    var m0: *Message = conv_get_message(@&store, @conv_id, 0)
    var m1: *Message = conv_get_message(@&store, @conv_id, 1)
    var m2: *Message = conv_get_message(@&store, @conv_id, 2)

    assert m0.role == ROLE_USER, "first message should be USER"
    assert m1.role == ROLE_ASSISTANT, "second message should be ASSISTANT"
    assert m2.role == ROLE_SYSTEM, "third message should be SYSTEM"
    0

# ============================================================================
# Delete Tests
# ============================================================================

[[test]]
fn test_conv_delete() -> i32
    var store: ConversationStore = conv_store_new()
    var node_id: Uuid = uuid_generate()
    var conv_id: Uuid = conv_create(@&store, @node_id)

    let result: i32 = conv_delete(@&store, @conv_id)
    assert result == 0, "delete should succeed"
    0

[[test]]
fn test_conv_delete_nonexistent() -> i32
    var store: ConversationStore = conv_store_new()
    var fake_id: Uuid = uuid_generate()

    let result: i32 = conv_delete(@&store, @fake_id)
    assert result == -1, "deleting nonexistent should fail"
    0
