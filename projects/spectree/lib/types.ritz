# lib/types.ritz - Core types for spectree
#
# Defines the fundamental data structures for the specification tree:
# - NodeKind: Classification of nodes (Org, Spec, Plan)
# - NodeStatus: Lifecycle state of a node
# - LinkKind: Types of relationships between nodes
# - Node: The primary tree node structure
# - Link: Relationship between nodes

import ritzlib.gvec
import ritzlib.span

# ============================================================================
# Node Kind
# ============================================================================
# Distinguishes between organizational structure, specifications, and plans.

pub const NODE_ORG: i32 = 0    # Root organizational context
pub const NODE_SPEC: i32 = 1   # Declarative truth - what IS or SHOULD BE
pub const NODE_PLAN: i32 = 2   # Imperative work - what TO DO

pub fn node_kind_name(kind: i32) -> Span<u8>
    if kind == NODE_ORG
        return span_from_cstr(c"Org")
    else if kind == NODE_SPEC
        return span_from_cstr(c"Spec")
    else if kind == NODE_PLAN
        return span_from_cstr(c"Plan")
    return span_from_cstr(c"Unknown")

# ============================================================================
# Node Status
# ============================================================================
# Lifecycle state tracking for nodes.

pub const STATUS_DRAFT: i32 = 0       # Initial creation, not finalized
pub const STATUS_IN_PROGRESS: i32 = 1 # Actively being worked on
pub const STATUS_REVIEW: i32 = 2      # Ready for review/approval
pub const STATUS_COMPLETE: i32 = 3    # Finished, accepted
pub const STATUS_ARCHIVED: i32 = 4    # Historical, no longer active

pub fn status_name(status: i32) -> Span<u8>
    if status == STATUS_DRAFT
        return span_from_cstr(c"Draft")
    else if status == STATUS_IN_PROGRESS
        return span_from_cstr(c"InProgress")
    else if status == STATUS_REVIEW
        return span_from_cstr(c"Review")
    else if status == STATUS_COMPLETE
        return span_from_cstr(c"Complete")
    else if status == STATUS_ARCHIVED
        return span_from_cstr(c"Archived")
    return span_from_cstr(c"Unknown")

# ============================================================================
# Link Kind
# ============================================================================
# Types of relationships between nodes.

pub const LINK_IMPLEMENTS: i32 = 0   # Plan implements a Spec
pub const LINK_DEPENDS_ON: i32 = 1   # Node depends on another
pub const LINK_RELATED_TO: i32 = 2   # General relationship

pub fn link_kind_name(kind: i32) -> Span<u8>
    if kind == LINK_IMPLEMENTS
        return span_from_cstr(c"Implements")
    else if kind == LINK_DEPENDS_ON
        return span_from_cstr(c"DependsOn")
    else if kind == LINK_RELATED_TO
        return span_from_cstr(c"RelatedTo")
    return span_from_cstr(c"Unknown")

# ============================================================================
# UUID
# ============================================================================
# 128-bit unique identifier stored as two u64 values.

pub struct Uuid
    high: u64
    low: u64

pub fn uuid_zero() -> Uuid
    var u: Uuid
    u.high = 0
    u.low = 0
    return u

pub fn uuid_eq(a: @Uuid, b: @Uuid) -> i32
    if a.high == b.high && a.low == b.low
        return 1
    return 0

# ============================================================================
# Link
# ============================================================================
# A directed relationship from one node to another.

pub struct Link
    kind: i32       # LINK_IMPLEMENTS, LINK_DEPENDS_ON, LINK_RELATED_TO
    target: Uuid    # Target node ID

# ============================================================================
# AgentRef
# ============================================================================
# Reference to an AI agent with its role.

pub const AGENT_OWNER: i32 = 0     # Responsible for completion
pub const AGENT_REVIEWER: i32 = 1  # Reviewing/approving
pub const AGENT_WATCHER: i32 = 2   # Observing, not acting

pub struct AgentRef
    agent_id: Vec<u8>  # Agent identifier (e.g., "adele-1")
    role: i32          # AGENT_OWNER, AGENT_REVIEWER, AGENT_WATCHER

# ============================================================================
# Timestamp
# ============================================================================
# Unix timestamp in nanoseconds.

pub struct Timestamp
    nanos: i64

pub fn timestamp_now() -> Timestamp
    # TODO: Get actual time via syscall
    var t: Timestamp
    t.nanos = 0
    return t

# ============================================================================
# Node
# ============================================================================
# The primary tree node structure.
#
# Each node represents either:
# - An organizational unit (Org)
# - A specification (Spec) - declarative truth
# - A plan (Plan) - imperative work items

pub struct Node
    uuid: Uuid             # Node's unique identifier
    kind: i32              # NODE_ORG, NODE_SPEC, NODE_PLAN
    title: Vec<u8>         # Short descriptive title
    content: Vec<u8>       # Markdown content
    status: i32            # STATUS_DRAFT, etc.
    parent_id: Uuid        # Parent node (zero for root)
    created_at: Timestamp
    updated_at: Timestamp
    # Note: children, links, agents stored separately for efficiency

pub fn node_new(kind: i32) -> Node
    var n: Node
    n.uuid = uuid_zero()
    n.kind = kind
    n.title = vec_new<u8>()
    n.content = vec_new<u8>()
    n.status = STATUS_DRAFT
    n.parent_id = uuid_zero()
    n.created_at = timestamp_now()
    n.updated_at = timestamp_now()
    return n

pub fn node_is_root(n: @Node) -> i32
    var zero: Uuid = uuid_zero()
    return uuid_eq(@n.parent_id, @zero)

# ============================================================================
# Message Role
# ============================================================================
# Who sent the message in a conversation.

pub const ROLE_USER: i32 = 0      # Human user message
pub const ROLE_ASSISTANT: i32 = 1  # AI agent response
pub const ROLE_SYSTEM: i32 = 2     # System/tool message

pub fn role_name(role: i32) -> Span<u8>
    if role == ROLE_USER
        return span_from_cstr(c"User")
    else if role == ROLE_ASSISTANT
        return span_from_cstr(c"Assistant")
    else if role == ROLE_SYSTEM
        return span_from_cstr(c"System")
    return span_from_cstr(c"Unknown")

# ============================================================================
# Message
# ============================================================================
# A single message in a conversation.

pub struct Message
    uuid: Uuid             # Message unique ID
    role: i32              # ROLE_USER, ROLE_ASSISTANT, ROLE_SYSTEM
    agent_id: Vec<u8>      # Agent that sent (for ASSISTANT) or "" for USER
    content: Vec<u8>       # Message text (markdown)
    created_at: Timestamp

pub fn message_new(role: i32) -> Message
    var m: Message
    m.uuid = uuid_zero()
    m.role = role
    m.agent_id = vec_new<u8>()
    m.content = vec_new<u8>()
    m.created_at = timestamp_now()
    return m

# ============================================================================
# Conversation
# ============================================================================
# A sequence of messages attached to a node.
# Nodes may have multiple conversations (e.g., different threads).

pub struct Conversation
    uuid: Uuid             # Conversation unique ID
    node_id: Uuid          # Node this conversation belongs to
    title: Vec<u8>         # Optional title/topic
    created_at: Timestamp
    updated_at: Timestamp
    # Messages stored separately for efficiency

pub fn conversation_new(node_id: @Uuid) -> Conversation
    var c: Conversation
    c.uuid = uuid_zero()
    c.node_id = *node_id
    c.title = vec_new<u8>()
    c.created_at = timestamp_now()
    c.updated_at = timestamp_now()
    return c

# ============================================================================
# ConversationSummary
# ============================================================================
# Compressed summary of a conversation for context windows.

pub struct ConversationSummary
    conversation_id: Uuid
    summary: Vec<u8>       # Compressed summary text
    message_count: i64     # Number of messages summarized
    created_at: Timestamp
