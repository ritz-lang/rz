#!/usr/bin/env python3
"""
rz - Unified workspace CLI for the Ritz ecosystem

Usage:
    rz build [PROJECT]     Build a project (or all with --all)
    rz test [PROJECT]      Run tests for a project (or all with --all)
    rz run PROJECT         Build and run a project
    rz list                List all projects in workspace
    rz clean [PROJECT]     Clean build artifacts
    rz compare [TIER]      Compare ritz0 vs ritz1 on examples

Compiler Selection:
    --compiler ritz0       Use Python bootstrap compiler (default)
    --compiler ritz1       Use self-hosted Ritz compiler

Examples:
    rz build tome                Build the tome project
    rz test --all                Run all tests
    rz run nexus                 Build and run nexus
    rz build --compiler ritz1    Build with self-hosted compiler
    rz compare tier1             Compare compilers on tier1 examples
"""

import argparse
import os
import subprocess
import sys
import tomllib
from pathlib import Path

# Workspace root is where this script lives
WORKSPACE_ROOT = Path(__file__).parent.resolve()
PROJECTS_DIR = WORKSPACE_ROOT / "projects"
RITZ_BUILD = WORKSPACE_ROOT / "projects" / "ritz" / "build.py"
RITZ1_BIN = WORKSPACE_ROOT / "projects" / "ritz" / "ritz1" / "build" / "debug" / "ritz1"

# Global compiler selection (can be overridden per command)
COMPILER = "ritz0"  # default


def load_workspace_config():
    """Load rz.toml workspace configuration."""
    config_path = WORKSPACE_ROOT / "rz.toml"
    if not config_path.exists():
        print(f"Error: {config_path} not found", file=sys.stderr)
        sys.exit(1)

    with open(config_path, "rb") as f:
        return tomllib.load(f)


def discover_projects():
    """Discover all projects in the workspace."""
    projects = []
    for item in PROJECTS_DIR.iterdir():
        if item.is_dir() and (item / "ritz.toml").exists():
            projects.append(item.name)
    return sorted(projects)


def get_project_config(project_name):
    """Load a project's ritz.toml configuration."""
    config_path = PROJECTS_DIR / project_name / "ritz.toml"
    if not config_path.exists():
        return None

    with open(config_path, "rb") as f:
        return tomllib.load(f)


def collect_dependency_paths(project_name, seen=None):
    """Recursively collect all dependency paths for a project."""
    if seen is None:
        seen = set()

    if project_name in seen:
        return []

    seen.add(project_name)
    paths = [PROJECTS_DIR / project_name]

    config = get_project_config(project_name)
    if config and "dependencies" in config:
        for dep_name, dep_spec in config["dependencies"].items():
            if isinstance(dep_spec, dict) and "path" in dep_spec:
                # Resolve relative path
                dep_path = Path(dep_spec["path"])
                if not dep_path.is_absolute():
                    dep_path = (PROJECTS_DIR / project_name / dep_path).resolve()
                # Extract project name from path
                if dep_path.parent == PROJECTS_DIR:
                    dep_project = dep_path.name
                    paths.extend(collect_dependency_paths(dep_project, seen))
                else:
                    # Direct path (like ritzlib inside ritz)
                    paths.append(dep_path)

    return paths


def run_build(project_name, extra_args=None):
    """Run build.py for a specific project."""
    project_dir = PROJECTS_DIR / project_name
    if not project_dir.exists():
        print(f"Error: Project '{project_name}' not found", file=sys.stderr)
        return 1

    # Collect all dependency paths for RITZ_PATH (for lib.* imports in dependencies)
    dep_paths = collect_dependency_paths(project_name)
    # Always include ritz for ritzlib
    dep_paths.append(PROJECTS_DIR / "ritz")
    # Build colon-separated RITZ_PATH
    ritz_path = ":".join(str(p) for p in dep_paths)

    env = os.environ.copy()
    env["RITZ_PATH"] = ritz_path

    cmd = [sys.executable, str(RITZ_BUILD), "build", str(project_dir)]
    if extra_args:
        cmd.extend(extra_args)

    result = subprocess.run(cmd, env=env, cwd=WORKSPACE_ROOT)
    return result.returncode


def run_test(project_name, extra_args=None):
    """Run tests for a specific project."""
    project_dir = PROJECTS_DIR / project_name
    if not project_dir.exists():
        print(f"Error: Project '{project_name}' not found", file=sys.stderr)
        return 1

    # Collect all dependency paths for RITZ_PATH (for lib.* imports in dependencies)
    dep_paths = collect_dependency_paths(project_name)
    # Always include ritz for ritzlib
    dep_paths.append(PROJECTS_DIR / "ritz")
    # Build colon-separated RITZ_PATH
    ritz_path = ":".join(str(p) for p in dep_paths)

    env = os.environ.copy()
    env["RITZ_PATH"] = ritz_path

    cmd = [sys.executable, str(RITZ_BUILD), "test", str(project_dir)]
    if extra_args:
        cmd.extend(extra_args)

    result = subprocess.run(cmd, env=env, cwd=WORKSPACE_ROOT)
    return result.returncode


def cmd_build(args):
    """Handle 'rz build' command."""
    extra_args = ["--release"] if getattr(args, "release", False) else []

    if args.all:
        projects = discover_projects()
        failed = []
        for project in projects:
            print(f"\n{'='*60}")
            print(f"Building: {project}")
            print('='*60)
            if run_build(project, extra_args) != 0:
                failed.append(project)

        if failed:
            print(f"\nFailed projects: {', '.join(failed)}")
            return 1
        print(f"\nAll {len(projects)} projects built successfully!")
        return 0

    if not args.project:
        print("Error: Specify a project or use --all", file=sys.stderr)
        return 1

    return run_build(args.project, extra_args)


def cmd_test(args):
    """Handle 'rz test' command."""
    if args.all:
        projects = discover_projects()
        failed = []
        for project in projects:
            config = get_project_config(project)
            # Skip projects without tests
            if not config or "test" not in config.get("build", {}):
                continue

            print(f"\n{'='*60}")
            print(f"Testing: {project}")
            print('='*60)
            if run_test(project) != 0:
                failed.append(project)

        if failed:
            print(f"\nFailed tests: {', '.join(failed)}")
            return 1
        print("\nAll tests passed!")
        return 0

    if not args.project:
        print("Error: Specify a project or use --all", file=sys.stderr)
        return 1

    return run_test(args.project)


def cmd_run(args):
    """Handle 'rz run' command."""
    if not args.project:
        print("Error: Specify a project to run", file=sys.stderr)
        return 1

    # First build
    if run_build(args.project) != 0:
        return 1

    # Then run - look for the binary
    project_dir = PROJECTS_DIR / args.project
    build_dir = project_dir / "build"

    # Find the binary (typically named after the project)
    binary = build_dir / args.project
    if not binary.exists():
        # Try debug subdirectory
        binary = build_dir / "debug" / args.project

    if not binary.exists():
        print(f"Error: Could not find binary for '{args.project}'", file=sys.stderr)
        return 1

    env = os.environ.copy()
    env["RITZ_PATH"] = str(PROJECTS_DIR / "ritz")

    result = subprocess.run([str(binary)] + args.args, env=env)
    return result.returncode


def cmd_list(args):
    """Handle 'rz list' command."""
    projects = discover_projects()

    print(f"Workspace: {WORKSPACE_ROOT.name}")
    print(f"Projects ({len(projects)}):\n")

    for project in projects:
        config = get_project_config(project)
        if config and "package" in config:
            desc = config["package"].get("description", "")
            name = config["package"].get("name", project)
            print(f"  {name:20} {desc}")
        else:
            print(f"  {project}")

    return 0


def cmd_clean(args):
    """Handle 'rz clean' command."""
    if args.all:
        projects = discover_projects()
    elif args.project:
        projects = [args.project]
    else:
        print("Error: Specify a project or use --all", file=sys.stderr)
        return 1

    for project in projects:
        project_dir = PROJECTS_DIR / project
        build_dir = project_dir / "build"
        if build_dir.exists():
            print(f"Cleaning: {project}")
            import shutil
            shutil.rmtree(build_dir)

    return 0


def compile_with_ritz1(source_path, output_path):
    """Compile a single .ritz file with ritz1."""
    if not RITZ1_BIN.exists():
        print(f"Error: ritz1 not found at {RITZ1_BIN}", file=sys.stderr)
        print("  Run: cd projects/ritz && python3 build.py build ritz1", file=sys.stderr)
        return False

    env = os.environ.copy()
    env["RITZ_PATH"] = str(PROJECTS_DIR / "ritz")

    result = subprocess.run(
        [str(RITZ1_BIN), str(source_path), "-o", str(output_path)],
        env=env,
        capture_output=True,
        text=True
    )
    return result.returncode == 0


def compile_with_ritz0(source_path, output_path):
    """Compile a single .ritz file with ritz0."""
    ritz0_py = PROJECTS_DIR / "ritz" / "ritz0" / "ritz0.py"
    env = os.environ.copy()
    env["RITZ_PATH"] = str(PROJECTS_DIR / "ritz")

    result = subprocess.run(
        [sys.executable, str(ritz0_py), str(source_path), "-o", str(output_path)],
        env=env,
        capture_output=True,
        text=True
    )
    return result.returncode == 0


def link_llvm_ir(ll_path, binary_path):
    """Link LLVM IR to a binary.

    Detects whether the IR has a _start function (freestanding) and
    adjusts linker flags accordingly.
    """
    # Check if the IR has _start (freestanding mode)
    with open(ll_path, 'r') as f:
        ir_content = f.read()

    has_start = 'define void @_start' in ir_content or 'define void @"_start"' in ir_content

    if has_start:
        # Freestanding: use -nostdlib to avoid conflicting _start
        cmd = ["clang", str(ll_path), "-o", str(binary_path), "-nostdlib", "-no-pie"]
    else:
        # Normal: let system provide _start
        cmd = ["clang", str(ll_path), "-o", str(binary_path), "-no-pie"]

    result = subprocess.run(cmd, capture_output=True, text=True)
    return result.returncode == 0


def cmd_compare(args):
    """Handle 'rz compare' command - compare ritz0 vs ritz1 on examples."""
    import tempfile

    examples_dir = PROJECTS_DIR / "ritz" / "examples"
    tier = args.tier or "tier1"

    # Map tier names
    tier_dirs = {
        "tier1": "tier1_basics",
        "tier2": "tier2_stdlib",
        "tier3": "tier3_coreutils",
        "tier4": "tier4_applications",
        "tier5": "tier5_async",
    }

    if tier not in tier_dirs:
        print(f"Error: Unknown tier '{tier}'. Available: {', '.join(tier_dirs.keys())}")
        return 1

    tier_path = examples_dir / tier_dirs[tier]
    if not tier_path.exists():
        print(f"Error: Tier directory not found: {tier_path}")
        return 1

    print(f"Comparing ritz0 vs ritz1 on {tier} examples")
    print("=" * 70)
    print(f"{'Example':<25} {'ritz0':<15} {'ritz1':<15} {'Match':<10}")
    print("-" * 70)

    results = {"ritz0_only": [], "ritz1_only": [], "both": [], "neither": []}

    for example_dir in sorted(tier_path.iterdir()):
        if not example_dir.is_dir():
            continue

        src = example_dir / "src" / "main.ritz"
        if not src.exists():
            continue

        name = example_dir.name

        with tempfile.TemporaryDirectory() as tmpdir:
            tmpdir = Path(tmpdir)

            # Try ritz0
            ll0 = tmpdir / "ritz0.ll"
            bin0 = tmpdir / "ritz0_bin"
            r0_compile = compile_with_ritz0(src, ll0)
            r0_link = link_llvm_ir(ll0, bin0) if r0_compile else False
            r0_status = "✅ ok" if r0_link else ("⚠️ link" if r0_compile else "❌ fail")

            # Try ritz1
            ll1 = tmpdir / "ritz1.ll"
            bin1 = tmpdir / "ritz1_bin"
            r1_compile = compile_with_ritz1(src, ll1)
            r1_link = link_llvm_ir(ll1, bin1) if r1_compile else False
            r1_status = "✅ ok" if r1_link else ("⚠️ link" if r1_compile else "❌ fail")

            # Determine match status
            if r0_link and r1_link:
                match = "✅ both"
                results["both"].append(name)
            elif r0_link and not r1_link:
                match = "🔶 r0"
                results["ritz0_only"].append(name)
            elif r1_link and not r0_link:
                match = "🔷 r1"
                results["ritz1_only"].append(name)
            else:
                match = "❌ none"
                results["neither"].append(name)

            print(f"{name:<25} {r0_status:<15} {r1_status:<15} {match:<10}")

    print("-" * 70)
    print(f"\nSummary:")
    print(f"  Both work:     {len(results['both'])} examples")
    print(f"  ritz0 only:    {len(results['ritz0_only'])} examples")
    print(f"  ritz1 only:    {len(results['ritz1_only'])} examples")
    print(f"  Neither work:  {len(results['neither'])} examples")

    total = sum(len(v) for v in results.values())
    ritz1_pct = (len(results['both']) + len(results['ritz1_only'])) / total * 100 if total > 0 else 0
    print(f"\n  ritz1 coverage: {ritz1_pct:.1f}%")

    return 0


def main():
    parser = argparse.ArgumentParser(
        description="Unified workspace CLI for the Ritz ecosystem",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__
    )

    subparsers = parser.add_subparsers(dest="command", help="Command to run")

    # build
    build_parser = subparsers.add_parser("build", help="Build a project")
    build_parser.add_argument("project", nargs="?", help="Project to build")
    build_parser.add_argument("--all", action="store_true", help="Build all projects")
    build_parser.add_argument("--release", action="store_true", help="Build with release profile")

    # test
    test_parser = subparsers.add_parser("test", help="Run tests")
    test_parser.add_argument("project", nargs="?", help="Project to test")
    test_parser.add_argument("--all", action="store_true", help="Test all projects")

    # run
    run_parser = subparsers.add_parser("run", help="Build and run a project")
    run_parser.add_argument("project", help="Project to run")
    run_parser.add_argument("args", nargs="*", help="Arguments to pass to the binary")

    # list
    subparsers.add_parser("list", help="List all projects")

    # clean
    clean_parser = subparsers.add_parser("clean", help="Clean build artifacts")
    clean_parser.add_argument("project", nargs="?", help="Project to clean")
    clean_parser.add_argument("--all", action="store_true", help="Clean all projects")

    # compare
    compare_parser = subparsers.add_parser("compare", help="Compare ritz0 vs ritz1 on examples")
    compare_parser.add_argument("tier", nargs="?", default="tier1",
                               help="Tier to compare (tier1, tier2, tier3, tier4, tier5)")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        return 1

    commands = {
        "build": cmd_build,
        "test": cmd_test,
        "run": cmd_run,
        "list": cmd_list,
        "clean": cmd_clean,
        "compare": cmd_compare,
    }

    return commands[args.command](args)


if __name__ == "__main__":
    sys.exit(main())
