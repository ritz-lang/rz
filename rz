#!/usr/bin/env python3
"""
rz - Unified workspace CLI for the Ritz ecosystem

Usage:
    rz build [PROJECT]     Build a project (or all with --all)
    rz test [PROJECT]      Run tests for a project (or all with --all)
    rz run PROJECT         Build and run a project
    rz list                List all projects in workspace
    rz clean [PROJECT]     Clean build artifacts
    rz compare [TIER]      Compare ritz0 vs ritz1 on examples

Compiler Selection:
    --compiler ritz0       Use Python bootstrap compiler (default)
    --compiler ritz1       Use self-hosted Ritz compiler

Examples:
    rz build tome                Build the tome project
    rz test --all                Run all tests
    rz run nexus                 Build and run nexus
    rz build --compiler ritz1    Build with self-hosted compiler
    rz compare tier1             Compare compilers on tier1 examples
"""

import argparse
import os
import subprocess
import sys
import tomllib
from pathlib import Path

# Workspace root is where this script lives
WORKSPACE_ROOT = Path(__file__).parent.resolve()
PROJECTS_DIR = WORKSPACE_ROOT / "projects"
RITZ_BUILD = WORKSPACE_ROOT / "projects" / "ritz" / "build.py"
RITZ1_BIN = WORKSPACE_ROOT / "projects" / "ritz" / "ritz1" / "build" / "ritz1"

# Global compiler selection (can be overridden per command)
COMPILER = "ritz0"  # default


def load_workspace_config():
    """Load rz.toml workspace configuration."""
    config_path = WORKSPACE_ROOT / "rz.toml"
    if not config_path.exists():
        print(f"Error: {config_path} not found", file=sys.stderr)
        sys.exit(1)

    with open(config_path, "rb") as f:
        return tomllib.load(f)


def discover_projects():
    """Discover all projects in the workspace."""
    projects = []
    for item in PROJECTS_DIR.iterdir():
        if item.is_dir() and (item / "ritz.toml").exists():
            projects.append(item.name)
    return sorted(projects)


def get_project_config(project_name):
    """Load a project's ritz.toml configuration."""
    config_path = PROJECTS_DIR / project_name / "ritz.toml"
    if not config_path.exists():
        return None

    with open(config_path, "rb") as f:
        return tomllib.load(f)


def collect_dependency_paths(project_name, seen=None):
    """Recursively collect all dependency paths for a project."""
    if seen is None:
        seen = set()

    if project_name in seen:
        return []

    seen.add(project_name)
    paths = [PROJECTS_DIR / project_name]

    config = get_project_config(project_name)
    if config and "dependencies" in config:
        for dep_name, dep_spec in config["dependencies"].items():
            if isinstance(dep_spec, dict) and "path" in dep_spec:
                # Resolve relative path
                dep_path = Path(dep_spec["path"])
                if not dep_path.is_absolute():
                    dep_path = (PROJECTS_DIR / project_name / dep_path).resolve()
                # Extract project name from path
                if dep_path.parent == PROJECTS_DIR:
                    dep_project = dep_path.name
                    paths.extend(collect_dependency_paths(dep_project, seen))
                else:
                    # Direct path (like ritzlib inside ritz)
                    paths.append(dep_path)

    return paths


def run_build(project_name, extra_args=None):
    """Run build.py for a specific project."""
    project_dir = PROJECTS_DIR / project_name
    if not project_dir.exists():
        print(f"Error: Project '{project_name}' not found", file=sys.stderr)
        return 1

    # Collect all dependency paths for RITZ_PATH (for lib.* imports in dependencies)
    dep_paths = collect_dependency_paths(project_name)
    # Always include ritz for ritzlib
    dep_paths.append(PROJECTS_DIR / "ritz")
    # Build colon-separated RITZ_PATH using absolute paths
    ritz_path = ":".join(str(p.resolve()) for p in dep_paths)

    env = os.environ.copy()
    env["RITZ_PATH"] = ritz_path

    cmd = [sys.executable, str(RITZ_BUILD), "build", str(project_dir)]
    if extra_args:
        cmd.extend(extra_args)

    result = subprocess.run(cmd, env=env, cwd=WORKSPACE_ROOT)
    return result.returncode


def run_test(project_name, extra_args=None):
    """Run tests for a specific project."""
    project_dir = PROJECTS_DIR / project_name
    if not project_dir.exists():
        print(f"Error: Project '{project_name}' not found", file=sys.stderr)
        return 1

    # Collect all dependency paths for RITZ_PATH (for lib.* imports in dependencies)
    dep_paths = collect_dependency_paths(project_name)
    # Always include ritz for ritzlib
    dep_paths.append(PROJECTS_DIR / "ritz")
    # Build colon-separated RITZ_PATH using absolute paths
    ritz_path = ":".join(str(p.resolve()) for p in dep_paths)

    env = os.environ.copy()
    env["RITZ_PATH"] = ritz_path

    cmd = [sys.executable, str(RITZ_BUILD), "test", str(project_dir)]
    if extra_args:
        cmd.extend(extra_args)

    result = subprocess.run(cmd, env=env, cwd=WORKSPACE_ROOT)
    return result.returncode


def cmd_build(args):
    """Handle 'rz build' command."""
    extra_args = ["--release"] if getattr(args, "release", False) else []

    if args.all:
        projects = discover_projects()
        failed = []
        for project in projects:
            print(f"\n{'='*60}")
            print(f"Building: {project}")
            print('='*60)
            if run_build(project, extra_args) != 0:
                failed.append(project)

        if failed:
            print(f"\nFailed projects: {', '.join(failed)}")
            return 1
        print(f"\nAll {len(projects)} projects built successfully!")
        return 0

    if not args.project:
        print("Error: Specify a project or use --all", file=sys.stderr)
        return 1

    return run_build(args.project, extra_args)


def cmd_test(args):
    """Handle 'rz test' command."""
    if args.all:
        projects = discover_projects()
        failed = []
        for project in projects:
            config = get_project_config(project)
            # Skip projects without tests
            if not config or "test" not in config.get("build", {}):
                continue

            print(f"\n{'='*60}")
            print(f"Testing: {project}")
            print('='*60)
            if run_test(project) != 0:
                failed.append(project)

        if failed:
            print(f"\nFailed tests: {', '.join(failed)}")
            return 1
        print("\nAll tests passed!")
        return 0

    if not args.project:
        print("Error: Specify a project or use --all", file=sys.stderr)
        return 1

    return run_test(args.project)


def cmd_run(args):
    """Handle 'rz run' command."""
    if not args.project:
        print("Error: Specify a project to run", file=sys.stderr)
        return 1

    # First build
    if run_build(args.project) != 0:
        return 1

    # Then run - look for the binary
    project_dir = PROJECTS_DIR / args.project
    build_dir = project_dir / "build"

    # Find the binary (typically named after the project)
    binary = build_dir / args.project
    if not binary.exists():
        # Try debug subdirectory
        binary = build_dir / "debug" / args.project

    if not binary.exists():
        print(f"Error: Could not find binary for '{args.project}'", file=sys.stderr)
        return 1

    env = os.environ.copy()
    env["RITZ_PATH"] = str(PROJECTS_DIR / "ritz")

    result = subprocess.run([str(binary)] + args.args, env=env)
    return result.returncode


def cmd_list(args):
    """Handle 'rz list' command."""
    projects = discover_projects()

    print(f"Workspace: {WORKSPACE_ROOT.name}")
    print(f"Projects ({len(projects)}):\n")

    for project in projects:
        config = get_project_config(project)
        if config and "package" in config:
            desc = config["package"].get("description", "")
            name = config["package"].get("name", project)
            print(f"  {name:20} {desc}")
        else:
            print(f"  {project}")

    return 0


def cmd_clean(args):
    """Handle 'rz clean' command."""
    if args.all:
        projects = discover_projects()
    elif args.project:
        projects = [args.project]
    else:
        print("Error: Specify a project or use --all", file=sys.stderr)
        return 1

    for project in projects:
        project_dir = PROJECTS_DIR / project
        build_dir = project_dir / "build"
        if build_dir.exists():
            print(f"Cleaning: {project}")
            import shutil
            shutil.rmtree(build_dir)

    return 0


def compile_with_ritz1(source_path, output_path):
    """Compile a single .ritz file with ritz1.

    ritz1's CLI is minimal: `<input> -o <output> [-I <ritz_path>]`. It has no
    `--no-runtime` flag — its emitter is non-freestanding by default, so the
    resulting IR does NOT embed _start and must be linked against a runtime
    object (see link_ritz_ir → runtime_obj_for).
    """
    if not RITZ1_BIN.exists():
        print(f"Error: ritz1 not found at {RITZ1_BIN}", file=sys.stderr)
        print("  Run: cd projects/ritz/ritz1 && make ritz1", file=sys.stderr)
        return False

    env = os.environ.copy()
    env["RITZ_PATH"] = str(PROJECTS_DIR / "ritz")

    result = subprocess.run(
        [str(RITZ1_BIN), str(source_path), "-o", str(output_path),
         "-I", str(PROJECTS_DIR / "ritz")],
        env=env,
        capture_output=True,
        text=True
    )
    return result.returncode == 0


def compile_with_ritz0(source_path, output_path):
    """Compile a single .ritz file with ritz0, emitting runtime-free IR.

    Passes `--no-runtime` so ritz0 does NOT emit _start in the IR — _start
    is provided by linking against the appropriate runtime object in
    link_ritz_ir (matches what projects/ritz/build.py does).
    """
    ritz0_py = PROJECTS_DIR / "ritz" / "ritz0" / "ritz0.py"
    env = os.environ.copy()
    env["RITZ_PATH"] = str(PROJECTS_DIR / "ritz")

    result = subprocess.run(
        [sys.executable, str(ritz0_py), str(source_path), "-o", str(output_path), "--no-runtime"],
        env=env,
        capture_output=True,
        text=True
    )
    return result.returncode == 0


def detect_main_params(source_path):
    """Count the parameters of `fn main(...)` in the source file.

    Returns 0, 2, or 3 — which runtime variant to link against.
    Mirrors projects/ritz/build.py:detect_main_signature but simpler.
    """
    try:
        with open(source_path) as f:
            text = f.read()
    except Exception:
        return 0
    import re
    # Match: fn main(...)  — capture everything between parens
    m = re.search(r"\bfn\s+main\s*\(([^)]*)\)", text)
    if not m:
        return 0
    args_str = m.group(1).strip()
    if not args_str:
        return 0
    # Count comma-separated params
    return len([p for p in args_str.split(",") if p.strip()])


def runtime_obj_for(source_path):
    """Pick the right ritz_start object file based on main's arity."""
    import platform
    arch = platform.machine()
    runtime_dir = PROJECTS_DIR / "ritz" / "runtime"
    params = detect_main_params(source_path)
    if params == 0:
        return runtime_dir / f"ritz_start_noargs.{arch}.o"
    elif params == 3:
        return runtime_dir / f"ritz_start_envp.{arch}.o"
    else:  # 2-arg (argc, argv)
        return runtime_dir / f"ritz_start.{arch}.o"


def link_llvm_ir(ll_path, binary_path, source_path=None):
    """Link LLVM IR to a binary.

    Uses the same runtime-object linking strategy as projects/ritz/build.py:
      * Compile with `--no-runtime` → IR has no _start
      * Link with the appropriate ritz_start runtime .o (provides _start +
        the minimal syscall wrappers programs rely on)
      * `-nostdlib` keeps us off libc's _start / crt1.o
      * Falls back to the old "let system provide _start" path for bitcode
        that happens to define _start itself (freestanding experiments)

    `source_path` is used to pick the runtime variant (main arity).
    """
    # Check if the IR has _start (legacy freestanding mode — pre --no-runtime)
    with open(ll_path, 'r') as f:
        ir_content = f.read()

    has_start = 'define void @_start' in ir_content or 'define void @"_start"' in ir_content

    if has_start:
        # Freestanding: IR already provides _start, use -nostdlib
        cmd = ["clang", str(ll_path), "-o", str(binary_path), "-nostdlib", "-no-pie"]
    else:
        # Non-freestanding: link the runtime .o which provides _start + syscalls
        runtime_obj = runtime_obj_for(source_path) if source_path else None
        if runtime_obj and runtime_obj.exists():
            cmd = ["clang", str(ll_path), str(runtime_obj), "-o", str(binary_path),
                   "-nostdlib", "-no-pie"]
        else:
            # Last resort: let clang/libc provide _start (will fail if IR calls syscalls)
            cmd = ["clang", str(ll_path), "-o", str(binary_path), "-no-pie"]

    result = subprocess.run(cmd, capture_output=True, text=True)
    return result.returncode == 0


def build_example_with_build_py(example_rel_path, compiler="ritz0"):
    """Build an example using projects/ritz/build.py (full multi-file support).

    Returns True if build succeeded, False otherwise.

    Both compilers now route through build.py — single-file probe modes are
    retired because they couldn't resolve ritzlib imports / generic
    monomorphization, producing misleading "ritz1 only" green cells.
    """
    env = os.environ.copy()
    env["RITZ_PATH"] = str(PROJECTS_DIR / "ritz")

    build_py = PROJECTS_DIR / "ritz" / "build.py"

    # Clean first to ensure fresh build (avoid cross-compiler cache pollution)
    subprocess.run(
        [sys.executable, str(build_py), "clean", example_rel_path],
        env=env, capture_output=True, text=True,
        cwd=PROJECTS_DIR / "ritz",
    )

    # Build with the selected compiler (build.py gained --compiler ritz1 in Phase I)
    cmd = [sys.executable, str(build_py), "build", example_rel_path,
           "--compiler", compiler]
    result = subprocess.run(
        cmd, env=env, capture_output=True, text=True,
        cwd=PROJECTS_DIR / "ritz",
    )
    return result.returncode == 0


def test_example_with_build_py(example_rel_path, compiler="ritz0"):
    """Run an example's `[[test]]` suite (if any), re-building with `compiler`.

    Returns:
        "ok"   — tests exist and all passed
        "fail" — tests exist and at least one failed
        "none" — no tests defined (no test/ dir, no test.sh)
    """
    env = os.environ.copy()
    env["RITZ_PATH"] = str(PROJECTS_DIR / "ritz")

    example_dir = PROJECTS_DIR / "ritz" / example_rel_path
    has_test_dir = (example_dir / "test").is_dir()
    has_test_sh = (example_dir / "test.sh").is_file()
    if not has_test_dir and not has_test_sh:
        return "none"

    build_py = PROJECTS_DIR / "ritz" / "build.py"
    # `build.py test` builds the binary first (needed for integration tests)
    # then runs ritz0 --test on test/*.ritz and bash ./test.sh.
    cmd = [sys.executable, str(build_py), "test", example_rel_path,
           "--compiler", compiler]
    result = subprocess.run(
        cmd, env=env, capture_output=True, text=True,
        cwd=PROJECTS_DIR / "ritz",
    )
    return "ok" if result.returncode == 0 else "fail"


def cmd_compare(args):
    """Handle 'rz compare' command — ritz0 vs ritz1 build + test dashboard.

    Shows four columns per example:
        build-r0   build-r1   tests-r0   tests-r1
    Every cell routes through projects/ritz/build.py so the measurement
    matches how the user actually builds/tests. ritz1 is now a first-class
    --compiler in build.py (Phase I) so both columns have teeth.
    """
    examples_dir = PROJECTS_DIR / "ritz" / "examples"
    tier = args.tier or "tier1"

    tier_dirs = {
        "tier1": "tier1_basics",
        "tier2": "tier2_stdlib",
        "tier3": "tier3_coreutils",
        "tier4": "tier4_applications",
        "tier5": "tier5_async",
    }

    if tier not in tier_dirs:
        print(f"Error: Unknown tier '{tier}'. Available: {', '.join(tier_dirs.keys())}")
        return 1

    tier_path = examples_dir / tier_dirs[tier]
    if not tier_path.exists():
        print(f"Error: Tier directory not found: {tier_path}")
        return 1

    skip_tests = getattr(args, "skip_tests", False)

    print(f"Comparing ritz0 vs ritz1 on {tier} examples (builds + tests)")
    print("=" * 84)
    header_fmt = "{:<22} {:<10} {:<10} {:<10} {:<10} {:<10}"
    row_fmt    = "{:<22} {:<10} {:<10} {:<10} {:<10} {:<10}"
    print(header_fmt.format("Example", "build-r0", "build-r1", "test-r0", "test-r1", "match"))
    print("-" * 84)

    totals = {
        "b0": 0, "b1": 0, "t0_ok": 0, "t0_fail": 0, "t1_ok": 0, "t1_fail": 0,
        "both_build": 0, "both_test_pass": 0, "count": 0,
    }

    for example_dir in sorted(tier_path.iterdir()):
        if not example_dir.is_dir():
            continue
        if not (example_dir / "src" / "main.ritz").exists():
            continue

        name = example_dir.name
        example_rel = f"examples/{tier_dirs[tier]}/{name}"
        totals["count"] += 1

        # Builds
        b0 = build_example_with_build_py(example_rel, "ritz0")
        b1 = build_example_with_build_py(example_rel, "ritz1")
        if b0: totals["b0"] += 1
        if b1: totals["b1"] += 1
        if b0 and b1: totals["both_build"] += 1

        b0_str = "✅" if b0 else "❌"
        b1_str = "✅" if b1 else "❌"

        # Tests (only if the build worked — there's nothing to test otherwise)
        if skip_tests:
            t0_str, t1_str = "—", "—"
        else:
            if b0:
                t0 = test_example_with_build_py(example_rel, "ritz0")
                t0_str = {"ok": "✅", "fail": "❌", "none": "—"}[t0]
                if t0 == "ok":   totals["t0_ok"]   += 1
                if t0 == "fail": totals["t0_fail"] += 1
            else:
                t0_str = "·"  # build failed → test not attempted

            if b1:
                t1 = test_example_with_build_py(example_rel, "ritz1")
                t1_str = {"ok": "✅", "fail": "❌", "none": "—"}[t1]
                if t1 == "ok":   totals["t1_ok"]   += 1
                if t1 == "fail": totals["t1_fail"] += 1
            else:
                t1_str = "·"

        # Cross-compiler match verdict
        if b0 and b1:
            if not skip_tests and t0_str == "✅" and t1_str == "✅":
                totals["both_test_pass"] += 1
                match = "✅ both"
            else:
                match = "🟡 build"
        elif b0:
            match = "🔶 r0"
        elif b1:
            match = "🔷 r1"
        else:
            match = "❌ none"

        print(row_fmt.format(name, b0_str, b1_str, t0_str, t1_str, match))

    print("-" * 84)
    n = totals["count"]
    print(f"\nBuilds:  ritz0 {totals['b0']}/{n}    ritz1 {totals['b1']}/{n}    both {totals['both_build']}/{n}")
    if not skip_tests:
        print(f"Tests:   r0-pass {totals['t0_ok']}  r0-fail {totals['t0_fail']}    r1-pass {totals['t1_ok']}  r1-fail {totals['t1_fail']}")
        print(f"Green (build+test on both): {totals['both_test_pass']}/{n}")
    if n:
        r1_pct = totals["b1"] / n * 100
        print(f"\nritz1 build coverage: {r1_pct:.1f}%")
    return 0


def main():
    parser = argparse.ArgumentParser(
        description="Unified workspace CLI for the Ritz ecosystem",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__
    )

    subparsers = parser.add_subparsers(dest="command", help="Command to run")

    # build
    build_parser = subparsers.add_parser("build", help="Build a project")
    build_parser.add_argument("project", nargs="?", help="Project to build")
    build_parser.add_argument("--all", action="store_true", help="Build all projects")
    build_parser.add_argument("--release", action="store_true", help="Build with release profile")

    # test
    test_parser = subparsers.add_parser("test", help="Run tests")
    test_parser.add_argument("project", nargs="?", help="Project to test")
    test_parser.add_argument("--all", action="store_true", help="Test all projects")

    # run
    run_parser = subparsers.add_parser("run", help="Build and run a project")
    run_parser.add_argument("project", help="Project to run")
    run_parser.add_argument("args", nargs="*", help="Arguments to pass to the binary")

    # list
    subparsers.add_parser("list", help="List all projects")

    # clean
    clean_parser = subparsers.add_parser("clean", help="Clean build artifacts")
    clean_parser.add_argument("project", nargs="?", help="Project to clean")
    clean_parser.add_argument("--all", action="store_true", help="Clean all projects")

    # compare
    compare_parser = subparsers.add_parser("compare", help="Compare ritz0 vs ritz1 on examples")
    compare_parser.add_argument("tier", nargs="?", default="tier1",
                               help="Tier to compare (tier1, tier2, tier3, tier4, tier5)")
    compare_parser.add_argument("--skip-tests", action="store_true",
                               help="Only run builds, skip test execution (faster)")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        return 1

    commands = {
        "build": cmd_build,
        "test": cmd_test,
        "run": cmd_run,
        "list": cmd_list,
        "clean": cmd_clean,
        "compare": cmd_compare,
    }

    return commands[args.command](args)


if __name__ == "__main__":
    sys.exit(main())
